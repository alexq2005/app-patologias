__d(function(a,e,i,o,r,n,s){r.exports=[{id:"pat_hta",nombre:"Hipertension Arterial",bodySystemId:"cardiovascular",definicion:"Elevacion persistente de la presion arterial sistolica >= 140 mmHg y/o diastolica >= 90 mmHg, considerada un factor de riesgo cardiovascular mayor y causa de da\xf1o en organos diana.",epidemiologia:"Afecta al 30-45% de la poblacion adulta mundial. En Argentina, la prevalencia es del 36,3%. Es la principal causa de accidente cerebrovascular y una de las causas mas frecuentes de insuficiencia renal y cardiopatia.",factoresRiesgo:["Edad avanzada","Antecedentes familiares","Obesidad","Sedentarismo","Dieta hipersodica","Tabaquismo","Consumo de alcohol","Estres cronico","Diabetes mellitus","Dislipemia"],fisiopatologia:"La HTA resulta del aumento del gasto cardiaco y/o de la resistencia vascular periferica. El sistema renina-angiotensina-aldosterona juega un rol central: la angiotensina II produce vasoconstriccion y estimula la retencion de sodio y agua. El da\xf1o cronico en organos diana se debe a fuerzas de cizallamiento que lesionan el endotelio vascular, promoviendo ateroesclerosis, hipertrofia ventricular izquierda y nefroesclerosis.",signosYSintomas:{signos:["PA sistolica >= 140 mmHg en dos o mas mediciones","Hipertrofia ventricular izquierda en ECG","Estrechamiento arteriovenoso en fondo de ojo","Soplo carotideo","Pulso irregular"],sintomas:["Cefalea occipital matutina","Mareos","Tinnitus","Vision borrosa","Epistaxis","Palpitaciones","Fatiga","Frecuentemente asintomatica (hipertension silente)"]},clasificacion:{nombre:"Clasificacion JNC 8 / ESC 2018",tipos:[{nombre:"Normal",descripcion:"PAS < 120 y PAD < 80 mmHg"},{nombre:"Elevada",descripcion:"PAS 120-129 y PAD < 80 mmHg"},{nombre:"HTA Grado 1",descripcion:"PAS 130-139 o PAD 80-89 mmHg"},{nombre:"HTA Grado 2",descripcion:"PAS >= 140 o PAD >= 90 mmHg"},{nombre:"Crisis hipertensiva",descripcion:"PAS > 180 y/o PAD > 120 mmHg"}]},diagnostico:{anamnesis:["Antecedentes familiares de HTA o ECV","Tiempo de evolucion y tratamientos previos","Habitos: tabaco, alcohol, sal, actividad fisica","Sintomas de da\xf1o en organos diana","Medicacion actual (AINEs, anticonceptivos, corticoides)","Antecedentes de enfermedad renal o endocrina"],examenFisico:["Medicion de PA en ambos brazos","Frecuencia cardiaca","Indice de masa corporal y perimetro abdominal","Fondo de ojo (retinopatia hipertensiva)","Auscultacion cardiaca y carotidea","Palpacion de pulsos perifericos","Exploracion abdominal (soplos renales)"],pruebas:[{nombre:"Hemograma completo",descripcion:"Descarta anemia y poliglobulia como causas secundarias",valoresReferencia:"Hb: 12-16 g/dL (mujer), 13-18 g/dL (hombre)",cuidadosEnfermeria:["Explicar procedimiento al paciente","Obtener muestra en ayunas si se solicita glucemia simultanea","Aplicar presion en sitio de puncion"]},{nombre:"Perfil lipidico",descripcion:"Evalua riesgo cardiovascular global",valoresReferencia:"CT < 200, LDL < 100, HDL > 40 (H) > 50 (M), TG < 150 mg/dL",cuidadosEnfermeria:["Ayuno de 12 horas previo","Evitar ejercicio intenso 24h antes"]},{nombre:"Glucemia en ayunas",descripcion:"Detecta diabetes mellitus asociada",valoresReferencia:"70-100 mg/dL normal; >= 126 mg/dL criterio de DM",cuidadosEnfermeria:["Verificar ayuno de al menos 8 horas","Registrar hora de ultima ingesta"]},{nombre:"Creatinina y urea serica",descripcion:"Evalua funcion renal como organo diana",valoresReferencia:"Creatinina: 0.6-1.2 mg/dL; Urea: 15-40 mg/dL",cuidadosEnfermeria:["No requiere ayuno","Registrar diuresis de 24h si se solicita"]},{nombre:"Electrocardiograma de 12 derivaciones",descripcion:"Detecta hipertrofia ventricular izquierda, arritmias e isquemia",valoresReferencia:"Criterio Sokolow-Lyon: SV1 + RV5/V6 >= 35 mm = HVI",cuidadosEnfermeria:["Paciente en decubito supino tranquilo","Correcta colocacion de electrodos","Verificar calidad de la se\xf1al"]},{nombre:"Microalbuminuria en orina de 24h",descripcion:"Marcador precoz de da\xf1o renal hipertensivo",valoresReferencia:"Normal < 30 mg/24h; Microalbuminuria 30-300 mg/24h",cuidadosEnfermeria:["Instruir recoleccion correcta de orina de 24h","Conservar muestra refrigerada","Descartar primera miccion del dia"]}]},tratamientoMedico:{objetivos:["Reducir PA a < 130/80 mmHg en general","Prevenir da\xf1o en organos diana","Reducir riesgo cardiovascular global","Mejorar calidad de vida"],farmacologico:[{nombre:"Enalapril",grupo:"IECA (Inhibidor de la Enzima Convertidora de Angiotensina)",mecanismo:"Inhibe la conversion de angiotensina I a II, reduciendo vasoconstriccion y retencion de sodio",dosis:"5-40 mg/dia en 1-2 tomas",cuidadosEnfermeria:["Monitorizar PA antes de cada dosis","Vigilar tos seca (efecto adverso frecuente)","Controlar potasio y creatinina periodicamente","Contraindicado en embarazo","Alertar sobre hipotension de primera dosis"]},{nombre:"Amlodipina",grupo:"Antagonista de calcio dihidropiridinico",mecanismo:"Bloquea canales de calcio en musculo liso vascular, produciendo vasodilatacion",dosis:"5-10 mg/dia en dosis unica",cuidadosEnfermeria:["Vigilar edema de miembros inferiores","Monitorizar PA y FC","Administrar a la misma hora cada dia","Puede causar rubor facial y cefalea"]},{nombre:"Hidroclorotiazida",grupo:"Diuretico tiazidico",mecanismo:"Inhibe reabsorcion de sodio en tubulo distal, reduciendo volumen circulante",dosis:"12.5-25 mg/dia",cuidadosEnfermeria:["Monitorizar electrolitos (hipopotasemia)","Vigilar diuresis y peso diario","Administrar en la ma\xf1ana para evitar nocturia","Controlar glucemia (puede elevarla)","Hidratar adecuadamente"]},{nombre:"Losartan",grupo:"ARA-II (Antagonista del Receptor de Angiotensina II)",mecanismo:"Bloquea el receptor AT1 de angiotensina II, sin producir tos como los IECAs",dosis:"50-100 mg/dia",cuidadosEnfermeria:["Similar vigilancia que IECAs","Alternativa en intolerancia a IECAs por tos","Contraindicado en embarazo","Monitorizar funcion renal"]}],noFarmacologico:["Dieta DASH (rica en frutas, verduras, baja en sodio)","Restriccion de sodio < 2.3 g/dia","Actividad fisica aerobica 30 min/dia, 5 dias/semana","Reduccion de peso (IMC objetivo < 25)","Cese del tabaquismo","Limitacion de alcohol","Manejo del estres (tecnicas de relajacion)","Monitoreo domiciliario de PA"]},cuidadosEnfermeria:{valoracion:["Medir PA en ambos brazos, en reposo de 5 min","Evaluar sintomas de da\xf1o en organos diana","Registrar peso y perimetro abdominal","Valorar adherencia al tratamiento","Identificar factores de riesgo modificables","Evaluar nivel de conocimiento del paciente sobre su enfermedad"],intervenciones:["Tecnica correcta de medicion de PA (brazo a nivel cardiaco, manguito adecuado)","Registrar PA en ambos brazos en primera consulta","Administrar medicacion antihipertensiva segun indicacion","Implementar medidas de cambio de estilo de vida","Coordinar con equipo multidisciplinario","Monitorizar efectos adversos de medicacion"],educacionPaciente:["Explicar que la HTA es cronica y requiere tratamiento permanente","Demostrar tecnica de medicion de PA domiciliaria","Ense\xf1ar dieta baja en sodio con ejemplos practicos","Importancia de no suspender medicacion sin consultar medico","Reconocer signos de alarma (cefalea intensa, vision borrosa, dolor toracico)","Registro de PA en libreta o app"],monitorizacion:["PA cada 4-8 horas en hospitalizados","Peso diario en ayunas","Diuresis en pacientes con diureticos","Electrolitos semanales al inicio del tratamiento","Funcion renal mensual en primeros 3 meses","ECG periodico para detectar HVI"]},npiNanda:[{codigo:"00233",nombre:"Riesgo de presion arterial inestable",definicion:"Vulnerable a cambios en las fuerzas de la sangre en los vasos sanguineos arteriales que pueden comprometer la salud",caracteristicasDefinitorias:["Presion arterial elevada en mediciones repetidas","Cefalea","Tinnitus"],factoresRelacionados:["Conocimiento insuficiente del regimen terapeutico","Dieta alta en sodio","Sedentarismo","Estres","Incumplimiento del tratamiento farmacologico"]},{codigo:"00078",nombre:"Gestion de salud ineficaz",definicion:"Patron de regulacion e integracion en la vida diaria de un regimen terapeutico para el tratamiento de la enfermedad que no es adecuado para alcanzar objetivos de salud especificos",caracteristicasDefinitorias:["Falta de adherencia al tratamiento","Dificultad para integrar cambios de estilo de vida","Fracaso al incluir regimen de tratamiento en la vida diaria"],factoresRelacionados:["Complejidad del regimen terapeutico","Conocimiento deficiente","Barreras economicas","Falta de apoyo social"]},{codigo:"00162",nombre:"Disposicion para mejorar la gestion de la salud",definicion:"Patron de regulacion e integracion en la vida diaria de un regimen terapeutico para el tratamiento de la enfermedad que es suficiente para alcanzar los objetivos de salud y puede ser reforzado",caracteristicasDefinitorias:["Expresa deseo de mejorar el manejo de la enfermedad","Realiza mediciones de PA domiciliarias","Sigue la dieta indicada"],factoresRelacionados:["Motivacion del paciente","Apoyo familiar adecuado"]}],npiNic:[{codigo:"4162",nombre:"Manejo de la hipertension",actividades:["Monitorizar PA segun protocolo","Administrar antihipertensivos prescritos","Instruir al paciente sobre dieta y ejercicio","Evaluar respuesta al tratamiento","Coordinar seguimiento ambulatorio"]},{codigo:"5510",nombre:"Educacion para la salud",actividades:["Ense\xf1ar tecnica correcta de medicion de PA","Proporcionar informacion sobre dieta DASH","Explicar importancia de adherencia al tratamiento","Identificar barreras para el cumplimiento"]},{codigo:"4480",nombre:"Facilitar la autorresponsabilidad",actividades:["Animar al paciente a asumir responsabilidad de su autocuidado","Apoyar el establecimiento de metas realistas","Proporcionar refuerzo positivo por comportamientos saludables"]}],npiNoc:[{codigo:"0401",nombre:"Estado circulatorio",indicadores:["PA sistolica en rango normal","PA diastolica en rango normal","Ausencia de cefalea hipertensiva","Ausencia de edema"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"},{codigo:"1803",nombre:"Conocimiento: proceso de la enfermedad",indicadores:["Describe el proceso de la enfermedad","Describe factores de riesgo","Describe signos y sintomas de complicaciones"],escala:"1=Ningun conocimiento, 2=Conocimiento escaso, 3=Conocimiento moderado, 4=Conocimiento sustancial, 5=Conocimiento extenso"}],complicaciones:["Accidente cerebrovascular isquemico o hemorragico","Infarto agudo de miocardio","Insuficiencia cardiaca","Insuficiencia renal cronica","Retinopatia hipertensiva con perdida de vision","Diseccion aortica","Encefalopatia hipertensiva"],criteriosAlarma:["PA > 180/120 mmHg (crisis hipertensiva)","Cefalea intensa de inicio brusco","Deficit neurologico focal agudo","Dolor toracico","Disnea aguda","Vision borrosa o perdida subita de vision","Epistaxis masiva que no cede"],emergencyLevel:"leve",relatedPathologyIds:["pat_icc","pat_iam","pat_acv","pat_irc","pat_dm2"],isPremium:!1},{id:"pat_icc",nombre:"Insuficiencia Cardiaca Congestiva",bodySystemId:"cardiovascular",definicion:"Sindrome clinico caracterizado por la incapacidad del corazon para bombear suficiente sangre para satisfacer las demandas metabolicas del organismo, o solo puede hacerlo a presiones de llenado elevadas.",epidemiologia:"Prevalencia del 1-2% en la poblacion general adulta, aumentando al 10% en mayores de 70 a\xf1os. Es la primera causa de hospitalizacion en mayores de 65 a\xf1os en paises desarrollados. Mortalidad del 50% a los 5 a\xf1os del diagnostico.",factoresRiesgo:["Cardiopatia isquemica (causa mas frecuente)","Hipertension arterial","Diabetes mellitus","Obesidad","Valvulopatias","Miocardiopatias","Arritmias cronicas (FA)","Abuso de alcohol","Quimioterapia cardiotoxica","Enfermedad renal cronica"],fisiopatologia:"Ante la falla del miocardio, se activan mecanismos compensadores: el sistema nervioso simpatico aumenta FC y contractilidad; el SRAA retiene sodio y agua para aumentar precarga; hay hipertrofia ventricular. A largo plazo estos mecanismos son deletereos: la retencion hidrica produce congestion pulmonar y sistemica, la hipertrofia lleva a fibrosis y mayor disfuncion. La fraccion de eyeccion puede estar reducida (HFrEF < 40%) o preservada (HFpEF >= 50%).",signosYSintomas:{signos:["Estertores crepitantes bibasales","Ingurgitacion yugular","Edema con godet en miembros inferiores","Tercer ruido cardiaco (galope)","Hepatomegalia congestiva","Ascitis en casos avanzados","Taquicardia","Pulso alternante"],sintomas:["Disnea de esfuerzo progresiva","Ortopnea (disnea en decubito)","Disnea paroxistica nocturna","Fatiga y debilidad","Tos nocturna","Oliguria","Anorexia y nauseas","Confusion en ancianos"]},clasificacion:{nombre:"Clasificacion funcional NYHA",tipos:[{nombre:"Clase I",descripcion:"Sin limitacion de actividad fisica. Actividad ordinaria no produce sintomas"},{nombre:"Clase II",descripcion:"Ligera limitacion. Comodo en reposo. Actividad ordinaria produce sintomas"},{nombre:"Clase III",descripcion:"Marcada limitacion. Comodo en reposo. Actividad menor que la ordinaria produce sintomas"},{nombre:"Clase IV",descripcion:"Incapacidad para realizar actividad sin sintomas. Sintomas en reposo"}]},diagnostico:{anamnesis:["Evaluar sintomas cardinales: disnea, fatiga, edemas","Cuantificar clase funcional NYHA","Antecedentes de cardiopatia isquemica, HTA, FA","Historia de hospitalizaciones previas","Medicacion actual y cumplimiento","Consumo de alcohol y AINES"],examenFisico:["Auscultacion cardiaca (3er ruido, soplos)","Auscultacion pulmonar (crepitantes)","Valorar ingurgitacion yugular (reflujo hepatoyugular)","Buscar edema con godet bilateral","Medir PA y FC","Palpar hepatomegalia"],pruebas:[{nombre:"BNP / NT-proBNP",descripcion:"Peptido natriuretico cerebral, marcador especifico de IC",valoresReferencia:"BNP < 100 pg/mL descarta IC; > 400 sugiere IC. NT-proBNP < 300 descarta IC",cuidadosEnfermeria:["No requiere ayuno","Muestra venosa estandar","Resultado rapido orienta tratamiento urgente"]},{nombre:"Ecocardiograma transtorax",descripcion:"Estudio definitivo: evalua FEVI, funcion valvular, tamano de camaras",valoresReferencia:"FEVI normal >= 55%; HFrEF si FEVI < 40%",cuidadosEnfermeria:["Posicionar en decubito lateral izquierdo","No requiere preparacion especial","Facilitar acceso al torax del paciente"]},{nombre:"Radiografia de torax",descripcion:"Detecta cardiomegalia, congestion vascular pulmonar, derrame pleural",valoresReferencia:"Indice cardiotorax < 0.5 normal; lineas B de Kerley en congestion",cuidadosEnfermeria:["Posicion PA estandar de pie si el paciente puede","Verificar que no tenga elementos metalicos","En IC aguda puede realizarse en cama (AP)"]},{nombre:"Ionograma y funcion renal",descripcion:"Monitoriza efectos de diureticos y funcion renal",valoresReferencia:"Na 135-145, K 3.5-5, Creatinina 0.6-1.2 mg/dL",cuidadosEnfermeria:["Monitorizar diariamente en hospitalizados con diureticos IV","Vigilar hipopotasemia con furosemida"]}]},tratamientoMedico:{objetivos:["Mejorar sintomas y calidad de vida","Prevenir hospitalizaciones","Reducir mortalidad","Tratar causas subyacentes"],farmacologico:[{nombre:"Furosemida",grupo:"Diuretico de asa",mecanismo:"Inhibe cotransportador Na-K-2Cl en asa de Henle, produciendo diuresis potente",dosis:"20-80 mg IV o VO segun respuesta; hasta 400 mg en casos refractarios",cuidadosEnfermeria:["Monitorizar diuresis horaria en IC aguda","Peso diario en mismas condiciones","Control de electrolitos (hipopotasemia, hiponatremia)","Vigilar signos de deshidratacion","Administrar IV lento (max 4 mg/min para evitar ototoxicidad)","Medir balance hidrico estricto"]},{nombre:"Carvedilol",grupo:"Betabloqueante no selectivo con efecto alfa1",mecanismo:"Bloquea receptores beta1, beta2 y alfa1 reduciendo FC, PA y remodelado cardiaco",dosis:"Iniciar con 3.125 mg c/12h, doblar cada 2 semanas hasta 25-50 mg c/12h",cuidadosEnfermeria:["NO iniciar en IC descompensada aguda","Monitorizar FC (bradicardia) y PA (hipotension)","Advertir que empeoramiento inicial es posible","No suspender abruptamente","Administrar con alimentos para reducir hipotension"]},{nombre:"Enalapril / Ramipril",grupo:"IECA",mecanismo:"Reduce postcarga y precarga, revierte remodelado cardiaco, reduce mortalidad en HFrEF",dosis:"Enalapril 2.5-20 mg c/12h; Ramipril 1.25-10 mg/dia",cuidadosEnfermeria:["Vigilar hipotension en primera dosis","Monitorizar potasio y creatinina","Advertir sobre tos seca","Contraindicado si K > 5.5 o creatinina > 2.5 mg/dL"]},{nombre:"Espironolactona",grupo:"Diuretico ahorrador de potasio / Antagonista de aldosterona",mecanismo:"Bloquea receptor de aldosterona, reduce fibrosis miocardica y retencion de sodio",dosis:"25-50 mg/dia",cuidadosEnfermeria:["Monitorizar potasio (riesgo de hiperpotasemia)","Contraindicada con K > 5.0 o creatinina > 2.5","Vigilar ginecomastia en hombres","No combinar con IECAs + ARA-II simultaneamente"]}],noFarmacologico:["Restriccion hidrica 1.5-2 L/dia en IC avanzada","Dieta hiposodica < 2 g de sodio/dia","Pesarse diario: consultar si aumento > 2 kg en 3 dias","Actividad fisica adaptada (rehabilitacion cardiaca)","Elevacion de cabecera a 30-45 grados","Medias de compresion para edema"],quirurgico:["Trasplante cardiaco en IC terminal refractaria","Dispositivo de asistencia ventricular (DAV)","Desfibrilador automatico implantable (DAI) si FEVI < 35%","Resincronizacion cardiaca (TRC) si bloqueo de rama izquierda"]},cuidadosEnfermeria:{valoracion:["Valorar nivel de disnea (escala 0-10)","Medir PA, FC, FR, SpO2 cada 4-8h","Peso diario en mismas condiciones (ma\xf1ana, en ayunas, despues de orinar)","Balance hidrico estricto (ingresos vs egresos)","Evaluar edemas (godet, localizacion, grado)","Auscultar campos pulmonares","Valorar ingurgitacion yugular"],intervenciones:["Posicionar con cabecera elevada 30-45\xb0 (Fowler)","Administrar oxigenoterapia si SpO2 < 90%","Administrar medicacion segun prescripcion","Pesar al paciente diariamente a la misma hora","Restringir liquidos segun indicacion medica","Controlar acceso venoso para medicacion IV","Monitorizar ECG continuo si arritmia asociada"],educacionPaciente:["Automonitoreo de peso diario y cuando consultar","Dieta hiposodica con ejemplos de alimentos prohibidos","Importancia de no suspender betabloqueantes abruptamente","Posicion de descanso con cabeza elevada","Reconocer signos de descompensacion: aumento de disnea, peso, edemas","Actividad fisica progresiva y limitaciones"],monitorizacion:["PA y FC cada 4-8h o continua en IC aguda","SpO2 continua o cada turno","Diuresis horaria en IC aguda","Balance hidrico cada 8h","Peso diario","Electrolitos y creatinina segun pauta medica","Nivel de BNP en evoluci\xf3n"]},npiNanda:[{codigo:"00032",nombre:"Patron respiratorio ineficaz",definicion:"La inspiracion o espiracion no proporciona una ventilacion adecuada",caracteristicasDefinitorias:["Disnea","Ortopnea","Uso de musculos accesorios","Taquipnea","SpO2 disminuida"],factoresRelacionados:["Congestion pulmonar por falla cardiaca","Fatiga de musculos respiratorios","Ansiedad"]},{codigo:"00025",nombre:"Exceso de volumen de liquidos",definicion:"Aumento de la retencion de liquidos isotonicos",caracteristicasDefinitorias:["Edema","Aumento de peso en corto tiempo","Crepitantes pulmonares","Ingurgitacion yugular","Oliguria"],factoresRelacionados:["Falla de mecanismos reguladores cardiacos","Tratamiento con corticoides","Dieta hipersodica"]},{codigo:"00092",nombre:"Intolerancia a la actividad",definicion:"Insuficiencia de energia fisiologica o psicologica para tolerar o completar las actividades diarias requeridas o deseadas",caracteristicasDefinitorias:["Disnea de esfuerzo","Fatiga","Aumento de FC ante minima actividad","Debilidad"],factoresRelacionados:["Desequilibrio entre aporte y demanda de oxigeno","Debilidad muscular","Reposo prolongado en cama"]}],npiNic:[{codigo:"4040",nombre:"Cuidados cardiacos",actividades:["Monitorizar signos vitales con frecuencia","Monitorizar ritmo cardiaco","Administrar medicacion cardiaca","Evaluar respuesta al tratamiento","Controlar balance hidrico"]},{codigo:"0480",nombre:"Manejo del liquido/electroliticos",actividades:["Monitorizar electrolitos sericos","Administrar diureticos prescritos","Controlar ingresos y egresos","Pesar diariamente","Restringir ingesta de sodio y liquidos"]},{codigo:"3140",nombre:"Manejo de la via aerea",actividades:["Posicionar en Fowler alto","Administrar oxigenoterapia","Monitorizar SpO2","Auscultar ruidos respiratorios"]}],npiNoc:[{codigo:"0400",nombre:"Efectividad de la bomba cardiaca",indicadores:["PA en rango terapeutico","FC en rango normal","Ausencia de edema pulmonar","Fraccion de eyeccion mejorada","Disnea reducida"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"},{codigo:"0601",nombre:"Equilibrio hidrico",indicadores:["Presion arterial estable","Ausencia de edema periferico","Peso estable","Electrolitos en rango normal"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Edema agudo de pulmon","Shock cardiogenico","Arritmias ventriculares y muerte subita","Tromboembolia pulmonar","Insuficiencia renal (sindrome cardiorrenal)","Hiponatremia dilucional","Caquexia cardiaca","Muerte"],criteriosAlarma:["Aumento de peso > 2 kg en 3 dias","Disnea en reposo o que no cede con posicion","SpO2 < 90%","PA sistolica < 90 mmHg","FC > 120 lpm o < 50 lpm","Disminucion marcada de diuresis","Sincope o presincope"],emergencyLevel:"moderado",relatedPathologyIds:["pat_hta","pat_iam","pat_fa","pat_eap"],isPremium:!1},{id:"pat_iam",nombre:"Infarto Agudo de Miocardio",bodySystemId:"cardiovascular",definicion:"Necrosis del musculo cardiaco causada por isquemia prolongada secundaria a oclusion total o subtotal de una arteria coronaria, generalmente por rotura de placa aterosclerotica con formacion de trombo.",epidemiologia:"Primera causa de muerte en el mundo desarrollado. En Argentina, las enfermedades cardiovasculares causan el 30% de las muertes. La mortalidad hospitalaria del IAMCEST es del 5-7% con tratamiento de reperfusion precoz.",factoresRiesgo:["Tabaquismo (mayor factor de riesgo modificable)","Hipertension arterial","Diabetes mellitus","Dislipemia (LDL elevado, HDL bajo)","Obesidad y sedentarismo","Historia familiar de ECV precoz","Sexo masculino > 45 a\xf1os, femenino > 55 a\xf1os","Enfermedad renal cronica","Cocaina y estimulantes"],fisiopatologia:"La aterosclerosis produce placas lipidicas inestables en arterias coronarias. La rotura de la capsula fibrosa de la placa expone material lipidico al flujo sanguineo, activando la cascada de coagulacion y agregacion plaquetaria. El trombo resultante oclui el vaso (total en IAMCEST, subtotal en IAMSEST). La isquemia de mas de 20-40 min produce necrosis irreversible del miocardio. La zona afectada depende del vaso ocluido.",signosYSintomas:{signos:["Diaforesis profusa","Palidez o cianosis periferal","Hipotension o hipertension reactiva","Bradicardia (IAM inferior) o taquicardia","Crepitantes si hay IC asociada","Frote pericardico en primeras horas","Soplos de regurgitacion mitral"],sintomas:["Dolor toracico opresivo, intenso (8-10/10), > 20 min","Irradiacion a brazo izquierdo, cuello, mandibula o espalda","Nauseas y vomitos","Diaforesis","Sensacion de muerte inminente","Disnea","IAM silente en diabeticos y ancianos"]},clasificacion:{nombre:"Clasificacion por ECG y biomarcadores",tipos:[{nombre:"IAMCEST",descripcion:"IAM con elevacion del segmento ST: oclusion total de coronaria. Requiere reperfusion urgente"},{nombre:"IAMSEST",descripcion:"IAM sin elevacion del ST: oclusion subtotal. Diagnostico por biomarcadores"},{nombre:"IAM tipo 1",descripcion:"Por rotura de placa aterosclerotica con trombo"},{nombre:"IAM tipo 2",descripcion:"Por desequilibrio oferta/demanda (espasmo, anemia, taquicardia severa)"}]},diagnostico:{anamnesis:["Caracteristicas del dolor: inicio, duracion, irradiacion, factores agravantes/atenuantes","Factores de riesgo cardiovascular","Tratamiento previo con nitratos (respuesta)","Medicacion anticoagulante o antiagregante previa","Alergias (especialmente a contrastes iodados y aspirina)"],examenFisico:["Signos vitales completos urgente","Auscultacion cardiaca (soplos, galope)","Auscultacion pulmonar (crepitantes = IC)","Evaluar signos de hipoperfusion (piel, estado mental)","Pulsos perifericos","Signos de ICC"],pruebas:[{nombre:"ECG de 12 derivaciones",descripcion:"Debe realizarse en los primeros 10 minutos del primer contacto medico. Elevacion del ST >= 1mm en 2 derivaciones contiguas indica IAMCEST",valoresReferencia:"Elevacion ST >= 1mm en V1-V4 (anterior), II,III,aVF (inferior), I, aVL (lateral)",cuidadosEnfermeria:["Realizar INMEDIATAMENTE al ingreso","Correcta colocacion de electrodos","Identificar derivaciones con cambios","Repetir cada 30 min o ante cambio de sintomas","Trasmitir al medico urgente"]},{nombre:"Troponina I o T de alta sensibilidad",descripcion:"Marcador especifico de necrosis miocardica. Se eleva a las 3-6h, pico a las 12-24h",valoresReferencia:"Troponina I hs: < 0.016 ng/mL (normal); 0-1h protocolo de descarte rapido",cuidadosEnfermeria:["Obtener muestra al ingreso y repetir a las 3h","Tiempo de extraccion critico para diagnostico","Anotar hora exacta de extraccion"]},{nombre:"CK-MB",descripcion:"Fraccion miocardica de creatinkinasa; se eleva a las 4-8h, pico 12-24h, normaliza en 48-72h",valoresReferencia:"CK-MB < 6.3 ng/mL normal; fraccion > 5% del CK total sugiere origen cardiaco",cuidadosEnfermeria:["Obtener al ingreso y cada 8h en primeras 24h","Util para detectar reinfarto por reinicio de elevacion"]},{nombre:"Coronariografia urgente",descripcion:"Visualizacion directa de arterias coronarias. En IAMCEST, objetivo es realizarla en < 90 min del primer contacto medico",cuidadosEnfermeria:["Preparacion de sitio de acceso (radial o femoral)","Verificar alergias a contraste iodado","Acceso venoso periferico de buen calibre","Premedicar con antialergicos si alergia al contraste","Consentimiento informado urgente","Rasurado y asepsia de zona de puncion"]}]},tratamientoMedico:{objetivos:["Reperfusion coronaria lo mas rapido posible (tiempo = miocardio)","Limitar extension de la necrosis","Prevenir complicaciones (arritmias, IC, shock)","Iniciar prevencion secundaria"],farmacologico:[{nombre:"Acido acetilsalicilico (AAS)",grupo:"Antiagregante plaquetario - inhibidor de COX-1",mecanismo:"Inhibicion irreversible de la COX-1 plaquetaria, reduce produccion de tromboxano A2 y agregacion plaquetaria",dosis:"300 mg VO masticado al diagnostico, luego 100 mg/dia indefinido",cuidadosEnfermeria:["Administrar INMEDIATAMENTE al diagnostico","Indicar masticar la tableta para absorcion rapida","Verificar ausencia de alergia","Advertir sobre riesgo de sangrado"]},{nombre:"Ticagrelor / Clopidogrel",grupo:"Inhibidor del receptor P2Y12 - antiagregante",mecanismo:"Bloquea receptor plaquetario P2Y12 del ADP, inhibiendo agregacion plaquetaria",dosis:"Ticagrelor: 180 mg dosis carga, luego 90 mg c/12h. Clopidogrel: 600 mg carga, luego 75 mg/dia",cuidadosEnfermeria:["Administrar junto a AAS (doble antiagregacion)","Vigilar signos de sangrado (enc\xedas, hematomas, melena)","No suspender sin indicacion medica (riesgo de trombosis de stent)","Ticagrelor contraindicado con ACV hemorragico previo"]},{nombre:"Heparina no fraccionada / HBPM",grupo:"Anticoagulante",mecanismo:"Potencia accion de antitrombina III, inhibiendo factores de coagulacion Xa y IIa",dosis:"HNF: 60-70 UI/kg IV bolo + infusion. Enoxaparina: 1 mg/kg SC c/12h",cuidadosEnfermeria:["Monitorizar APTT cada 6h con HNF (objetivo 50-70 seg)","Vigilar sangrado activo","No inyectar IM","Tecnica correcta de inyeccion SC para HBPM","Antidoto: protamina para HNF"]},{nombre:"Morfina",grupo:"Analgesico opiode",mecanismo:"Agonista opioide mu; reduce dolor, ansiedad y precarga cardiaca",dosis:"2-4 mg IV lento, repetir cada 5-15 min si necesario",cuidadosEnfermeria:["Monitorizar FR y SpO2 tras administracion","Antidoto: naloxona disponible","Precaucion en hipotension o bradicardia","Puede enmascarar sintomas de complicaciones"]}],noFarmacologico:["Reposo absoluto en las primeras horas","Oxigenoterapia si SpO2 < 90%","Acceso venoso periferico de grueso calibre","Monitor cardiaco continuo","Ambiente tranquilo para reducir demanda de oxigeno"],quirurgico:["Angioplastia primaria (ICP-p): tratamiento de eleccion en IAMCEST si < 90 min","Cirugia de bypass coronario (CABG): si falla ICP o enfermedad multivaso","Fibrinolisis: si no disponible ICP en tiempo adecuado"]},cuidadosEnfermeria:{valoracion:["Valoracion del dolor: escala numerica, caracteristicas, irradiacion","Monitorizar signos vitales cada 15 min en fase aguda","Evaluar nivel de conciencia y perfusion periferica","Control de ritmo cardiaco (ECG continuo)","Valorar signos de IC o shock","Balance hidrico horario"],intervenciones:["Canalizar via venosa periferica inmediata (2 accesos)","ECG de 12 derivaciones urgente (primeros 10 min)","Administrar medicacion segun protocolo IAM","Monitoreo cardiaco continuo","Preparar al paciente para cateterismo urgente","Administrar oxigeno si SpO2 < 90%","Mantener reposo absoluto con cabecera 30\xb0","Confortar y reducir ansiedad del paciente y familia"],educacionPaciente:["Explicar el procedimiento de cateterismo si aplica","Importancia de referir cualquier dolor o sintoma nuevo","No realizar esfuerzo durante la fase aguda","Proceso de rehabilitacion cardiaca tras el IAM","Cambios de estilo de vida para prevencion secundaria","Medicacion que debe tomar de por vida y por que"],monitorizacion:["ECG continuo las primeras 24-72h","Signos vitales cada 15-30 min en fase aguda, luego cada 2-4h","Troponinas seriadas cada 8h","SpO2 continua","Diuresis horaria","Balance hidrico","Glucemia (hiperglucemia de estres empeora pronostico)"]},npiNanda:[{codigo:"00102",nombre:"Deficit de autocuidado para alimentarse",definicion:"Deterioro de la capacidad para realizar o completar las actividades de alimentacion de manera independiente",caracteristicasDefinitorias:["Incapacidad para llevar alimentos a la boca","Reposo absoluto indicado"],factoresRelacionados:["Reposo obligado por IAM agudo","Dolor","Debilidad"]},{codigo:"00062",nombre:"Riesgo de disminucion de la perfusion tisular cardiaca",definicion:"Vulnerable a una disminucion en la circulacion cardiaca que puede comprometer la salud",caracteristicasDefinitorias:["Cambios en el ECG","Dolor toracico","Troponinas elevadas"],factoresRelacionados:["Trombo coronario","Espasmo coronario","Lesion aterosclerotica"]},{codigo:"00146",nombre:"Ansiedad",definicion:"Sensacion vaga e inquietante de malestar o amenaza acompanada de una respuesta autonoma",caracteristicasDefinitorias:["Expresion de miedo","Taquicardia","Diaforesis","Sensacion de muerte inminente"],factoresRelacionados:["Amenaza para el estado de salud","Hospitalizacion","Incertidumbre sobre el pronostico"]}],npiNic:[{codigo:"4044",nombre:"Cuidados cardiacos: agudos",actividades:["Monitorizar ritmo cardiaco continuamente","Obtener ECG de 12 derivaciones urgente","Administrar oxigeno si SpO2 < 90%","Administrar medicacion segun protocolo","Preparar para ICP si indicado","Monitorizar biomarcadores cardiacos"]},{codigo:"1400",nombre:"Manejo del dolor",actividades:["Evaluar dolor con escala numerica cada 15-30 min","Administrar analgesicos prescritos (morfina)","Administrar nitroglicerina si PA lo permite","Posicionar comodamente","Tecnicas de relajacion complementarias"]},{codigo:"5820",nombre:"Disminucion de la ansiedad",actividades:["Explicar todos los procedimientos al paciente y familia","Permanecer con el paciente en momentos de angustia","Proporcionar informacion veraz sobre el proceso","Facilitar visitas familiares controladas"]}],npiNoc:[{codigo:"0405",nombre:"Perfusion tisular: cardiaca",indicadores:["ECG normal para el paciente","Angina ausente","PA en rango normal","FC en rango normal","Troponinas disminuyendo"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"},{codigo:"1605",nombre:"Control del dolor",indicadores:["Dolor referido 0-2/10","Uso de analgesicos eficaz","Paciente sin gestos de dolor"],escala:"1=Nunca demostrado, 2=Raramente, 3=A veces, 4=Frecuentemente, 5=Siempre demostrado"}],complicaciones:["Fibrilacion ventricular y muerte subita","Bloqueo auriculoventricular completo (IAM inferior)","Shock cardiogenico","Insuficiencia cardiaca aguda","Rotura de pared libre, tabique o musculo papilar","Pericarditis postinfarto (sindrome de Dressler)","Trombo mural y embolia sistemica","Extension del infarto o reinfarto"],criteriosAlarma:["Dolor toracico persistente o recurrente","PA sistolica < 90 mmHg","FC < 40 o > 150 lpm","Nueva elevacion del ST en ECG","SpO2 < 90%","Perdida de conciencia o convulsiones","Diuresis < 20 mL/h"],emergencyLevel:"critico",relatedPathologyIds:["pat_hta","pat_angina","pat_icc","pat_eap","pat_fa"],isPremium:!1},{id:"pat_angina",nombre:"Angina de Pecho",bodySystemId:"cardiovascular",definicion:"Sindrome clinico caracterizado por dolor o malestar toracico transitorio causado por isquemia miocardica sin necrosis, generalmente precipitado por esfuerzo o estres y aliviado con reposo o nitroglicerina.",epidemiologia:"Prevalencia del 2-4% en la poblacion adulta general. Afecta a 9 millones de personas en EEUU. Es la manifestacion mas frecuente de la cardiopatia isquemica cronica.",factoresRiesgo:["Tabaquismo","Hipertension arterial","Diabetes mellitus","Dislipemia","Obesidad","Sedentarismo","Historia familiar de enfermedad coronaria","Edad: hombres > 45, mujeres > 55 a\xf1os"],fisiopatologia:"La angina resulta de un desequilibrio entre el aporte y la demanda miocardica de oxigeno. Las placas ateroscleroticas fijas reducen la luz coronaria, limitando el flujo durante el esfuerzo. En la angina inestable, la rotura parcial de placa con trombo no oclusivo produce isquemia en reposo. La isquemia activa receptores de dolor miocardico que viajan por fibras C y nervios simp\xe1ticos hasta la m\xe9dula C8-T4, explicando la irradiacion tipica.",signosYSintomas:{signos:["Cambios del ST en ECG durante el episodio (depresion en angina estable, elevacion en vasoespastica)","Galope ventricular transitorio","Crepitantes fugaces si hay disfuncion ventricular"],sintomas:["Dolor/presion/opresion toracica retroesternal","Irradiacion a brazo izquierdo, cuello, mandibula","Precipitado por esfuerzo, frio, emociones","Dura 3-15 minutos","Alivia con reposo o nitroglicerina en 3-5 min","Equivalentes anginosos: disnea, fatiga extrema en diabeticos"]},clasificacion:{nombre:"Clasificacion CCS y tipo clinico",tipos:[{nombre:"CCS I",descripcion:"Solo actividades extenuantes producen angina"},{nombre:"CCS II",descripcion:"Ligera limitacion. Angina al caminar > 2 cuadras o subir > 1 piso"},{nombre:"CCS III",descripcion:"Marcada limitacion. Angina con actividad minima"},{nombre:"CCS IV",descripcion:"Angina en reposo"},{nombre:"Angina inestable",descripcion:"Nuevo inicio, en reposo, o patron en aumento - requiere hospitalizacion urgente"},{nombre:"Angina de Prinzmetal",descripcion:"Vasoespasmo coronario: ocurre en reposo, madrugada, con elevacion del ST"}]},diagnostico:{anamnesis:["Caracteristicas del dolor (OPQRST)","Factores desencadenantes y atenuantes","Consumo de nitroglicerina y respuesta","Factores de riesgo cardiovascular","Historia de IAM previo o revascularizacion"],examenFisico:["ECG en reposo (puede ser normal)","Auscultar soplos o galope","Evaluar PA en ambos brazos","Buscar signos de ICC o enfermedad vascular periferica"],pruebas:[{nombre:"ECG en reposo",descripcion:"Puede ser normal entre episodios. Durante angina: depresion del ST, inversion de T",valoresReferencia:"Depresion ST > 1mm en 2 derivaciones contiguas indica isquemia",cuidadosEnfermeria:["Realizar durante el episodio doloroso si es posible","Guardar trazado para comparacion futura"]},{nombre:"Prueba de esfuerzo (ergometria)",descripcion:"Detecta isquemia inducible mediante ejercicio gradual en cinta o bicicleta",valoresReferencia:"Positiva: depresion ST > 1mm, dolor, hipotension, arritmias a bajo nivel de esfuerzo",cuidadosEnfermeria:["Verificar contraindicaciones: IAM reciente, IC descompensada, estenosis aortica severa","Monitorizar ECG y PA continua durante el estudio","Tener desfibrilador y medicacion de emergencia disponibles","Suspender si PA cae, arritmias severas o dolor intenso","Paciente en ayunas 3h previas"]},{nombre:"Coronariografia diagnostica",descripcion:"Visualizacion directa de coronarias; standard de oro para diagnostico y planificacion",cuidadosEnfermeria:["Verificar alergias a contraste","Preparar acceso radial o femoral","Monitorizar post-procedimiento","Hemostasia adecuada del sitio de puncion"]}]},tratamientoMedico:{objetivos:["Alivio inmediato de episodio anginoso","Prevenir IAM y muerte","Mejorar calidad de vida","Controlar factores de riesgo"],farmacologico:[{nombre:"Nitroglicerina sublingual",grupo:"Nitrato de accion corta - vasodilatador",mecanismo:"Libera oxido nitrico que relaja musculo liso vascular, reduce precarga y mejora flujo coronario",dosis:"0.4 mg SL al inicio del episodio; repetir cada 5 min hasta 3 dosis; si no alivia a los 15 min: llamar emergencias",cuidadosEnfermeria:["Ense\xf1ar tecnica correcta de administracion SL","Advertir hipotension ortost\xe1tica: paciente sentado o acostado","Conservar en frasco original oscuro","Verificar PA antes de administrar (no dar si PA < 90/60)","Contraindicada con sildenafil en ultimas 24-48h"]},{nombre:"Atenolol / Metoprolol",grupo:"Betabloqueante cardioselectivo",mecanismo:"Bloquea receptores beta1, reduciendo FC y contractilidad, disminuyendo demanda de oxigeno",dosis:"Atenolol 25-100 mg/dia; Metoprolol 50-200 mg/dia",cuidadosEnfermeria:["Medir FC antes de administrar (no dar si FC < 60)","No suspender abruptamente (angina de rebote)","Vigilar broncoespasmo en asmaticos","Controlar glucemia en diabeticos (enmascara hipoglucemia)"]},{nombre:"Acido acetilsalicilico",grupo:"Antiagregante plaquetario",mecanismo:"Inhibe COX-1 plaquetaria, reduce riesgo de IAM",dosis:"100 mg/dia en dosis unica",cuidadosEnfermeria:["Administrar con alimentos para reducir irritacion gastrica","Vigilar signos de sangrado gastrointestinal","Contraindicado con alergia o ulcera activa"]},{nombre:"Estatinas (Atorvastatina)",grupo:"Inhibidor de HMG-CoA reductasa - hipolipemiante",mecanismo:"Reduce sintesis de colesterol hepatico, estabiliza placas ateroscleroticas",dosis:"Atorvastatina 40-80 mg/noche",cuidadosEnfermeria:["Administrar por la noche (mayor sintesis de colesterol nocturna)","Monitorizar transaminasas y CK","Vigilar mialgias (miopatia, raro rabdomiolisis)","Interaccion con jugo de pomelo"]}],noFarmacologico:["Modificacion de factores de riesgo (tabaco, dieta, ejercicio)","Rehabilitacion cardiaca supervisada","Control del estres","Dieta mediterranea o DASH"],quirurgico:["Angioplastia coronaria transluminal percutanea (ACTP) con stent","Cirugia de bypass coronario (CABG) si enfermedad multivaso o tronco izquierdo"]},cuidadosEnfermeria:{valoracion:["Caracterizar episodio de dolor (EVA, duracion, irradiacion)","ECG durante el episodio si posible","Medir PA y FC","Evaluar respuesta a nitroglicerina sublingual","Identificar factores desencadenantes"],intervenciones:["Reposo en posicion comoda durante episodio","Administrar NTG SL segun protocolo","Obtener ECG urgente durante el dolor","Avisar al medico si no cede con 3 dosis de NTG","Monitoreo cardiaco si disponible"],educacionPaciente:["Tecnica correcta de uso de NTG SL","Cuando llamar al servicio de emergencias","Evitar factores desencadenantes (frio, esfuerzo intenso, emociones)","No suspender medicacion sin consulta","Llevar siempre NTG encima"],monitorizacion:["ECG en reposo periodico","PA y FC en cada visita","Perfil lipidico trimestral","Frecuencia de episodios anginosos semanales"]},npiNanda:[{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable ocasionada por una lesion tisular real o potencial",caracteristicasDefinitorias:["Verbalizacion de dolor toracico","Cambios en PA y FC","Expresion facial de dolor","Diaforesis"],factoresRelacionados:["Isquemia miocardica","Desequilibrio aporte/demanda de oxigeno coronario"]},{codigo:"00146",nombre:"Ansiedad",definicion:"Sensacion vaga e inquietante de malestar o amenaza acompanada de una respuesta autonoma",caracteristicasDefinitorias:["Preocupacion por IAM","Taquicardia","Diaforesis"],factoresRelacionados:["Amenaza percibida para la vida","Incertidumbre diagnostica"]},{codigo:"00092",nombre:"Intolerancia a la actividad",definicion:"Insuficiencia de energia para tolerar o completar actividades diarias requeridas",caracteristicasDefinitorias:["Dolor anginoso ante el esfuerzo","Disnea de esfuerzo","Fatiga"],factoresRelacionados:["Desequilibrio aporte/demanda de oxigeno","Sedentarismo"]}],npiNic:[{codigo:"1400",nombre:"Manejo del dolor",actividades:["Evaluar dolor con escala numerica","Administrar NTG SL segun protocolo","Monitorizar respuesta al tratamiento","Realizar ECG durante episodio"]},{codigo:"4046",nombre:"Cuidados cardiacos: rehabilitacion",actividades:["Instruir sobre progresion gradual de actividad","Ense\xf1ar reconocimiento de angina y accion a tomar","Fomentar adherencia a medicacion","Educacion sobre factores de riesgo"]}],npiNoc:[{codigo:"1605",nombre:"Control del dolor",indicadores:["Dolor referido 0-2/10","Uso efectivo de NTG","Reconoce factores desencadenantes","Busca ayuda oportuna"],escala:"1=Nunca demostrado, 2=Raramente, 3=A veces, 4=Frecuentemente, 5=Siempre demostrado"}],complicaciones:["Progresion a angina inestable","Infarto agudo de miocardio","Arritmias cardiacas","Muerte subita cardiaca","Insuficiencia cardiaca por isquemia cronica"],criteriosAlarma:["Dolor que no cede con 3 dosis de NTG en 15 min","Angina en reposo o nocturna","Aumento en frecuencia o intensidad (angina inestable)","Sindopes o presincopes","Disnea severa asociada","PA sistolica < 90 mmHg"],emergencyLevel:"moderado",relatedPathologyIds:["pat_iam","pat_hta","pat_icc"],isPremium:!1},{id:"pat_fa",nombre:"Fibrilacion Auricular",bodySystemId:"cardiovascular",definicion:"Arritmia supraventricular mas frecuente, caracterizada por activacion electrica desorganizada y rapida de las auriculas (350-600 lpm), con respuesta ventricular irregular. Conlleva riesgo de ACV embolico y deterioro hemodinamico.",epidemiologia:"Prevalencia del 1-2% en la poblacion general, aumentando al 10% en mayores de 80 a\xf1os. Causa el 15-20% de todos los accidentes cerebrovasculares isquemicos. Duplica el riesgo de mortalidad.",factoresRiesgo:["Hipertension arterial (factor mas frecuente)","Insuficiencia cardiaca","Cardiopatia isquemica","Valvulopatia mitral","Hipertiroidismo","Apnea del sueno","Obesidad","Diabetes mellitus","Consumo excesivo de alcohol","Cirugia cardiaca reciente"],fisiopatologia:"La FA se origina principalmente por focos ectopicos en las venas pulmonares y su union con la auricula izquierda. La activacion electrica ca\xf3tica impide la contraccion auricular coordinada, generando un ritmo ventricular irregularmente irregular. La perdida de la contribucion auricular al llenado ventricular reduce el gasto cardiaco un 15-30%. El estasis sanguineo en la orejuela izquierda favorece la formacion de trombos y embolia sistemica.",signosYSintomas:{signos:["Ritmo cardiaco irregularmente irregular","Pulso radial deficit (diferencia entre FC apical y radial)","PA variable entre latidos","Ausencia de onda P en ECG con intervalo RR irregular"],sintomas:["Palpitaciones","Disnea de esfuerzo o reposo","Fatiga","Mareos o presincopes","Dolor toracico atipico","Reduccion de la tolerancia al ejercicio","Puede ser asintomatica (hallazgo casual)"]},clasificacion:{nombre:"Clasificacion temporal",tipos:[{nombre:"FA de primer diagnostico",descripcion:"Primera vez que se detecta, independientemente del tiempo de evolucion"},{nombre:"FA paroxistica",descripcion:"Episodios que terminan espontaneamente en < 7 dias"},{nombre:"FA persistente",descripcion:"Dura > 7 dias o requiere cardioversion para terminar"},{nombre:"FA persistente de larga duracion",descripcion:"> 12 meses de duracion"},{nombre:"FA permanente",descripcion:"Se acepta la FA como ritmo definitivo, sin intentar cardioversion"}]},diagnostico:{anamnesis:["Inicio y duracion de los sintomas","Episodios previos y su terminacion","Patologias asociadas (hipertiroidismo, IC, valvulopatia)","Medicacion actual","Calculo de score CHA2DS2-VASc para riesgo embolico"],examenFisico:["Pulso irregular en ritmo y amplitud","Deficit de pulso (apical vs radial)","Signos de IC","Buscar soplos valvulares","Evaluar PA y signos de bajo gasto"],pruebas:[{nombre:"ECG de 12 derivaciones",descripcion:"Diagnostico definitivo: ausencia de ondas P, linea de base irregular (ondas f), intervalos RR irregulares",cuidadosEnfermeria:["Realizar urgente si palpitaciones o disnea aguda","Tira larga de ritmo para confirmar irregularidad"]},{nombre:"Ecocardiograma transtorax",descripcion:"Evalua funcion ventricular, tamano auricular, valvulas, y descarta trombo (aunque TEE es superior para orejuela)",cuidadosEnfermeria:["No requiere preparacion especial","Facilitar acceso al torax"]},{nombre:"TSH (funcion tiroidea)",descripcion:"Descarta hipertiroidismo como causa reversible de FA",valoresReferencia:"TSH normal: 0.4-4.0 mUI/L; T4L 0.8-1.8 ng/dL",cuidadosEnfermeria:["Muestra venosa estandar","Informar al medico si TSH suprimido"]},{nombre:"Score CHA2DS2-VASc",descripcion:"Herramienta de evaluacion de riesgo tromboemb\xf3lico para indicacion de anticoagulacion",valoresReferencia:"Score >= 2 en hombres o >= 3 en mujeres indica anticoagulacion. IC=1, HTA=1, edad>75=2, DM=1, ACV previo=2, EV periferica=1, edad65-74=1, sexo femenino=1",cuidadosEnfermeria:["Calcular en todo paciente con FA","Documentar y comunicar al medico para decision terapeutica"]}]},tratamientoMedico:{objetivos:["Controlar la frecuencia cardiaca ventricular","Prevenir tromboembolia cerebral","Restaurar ritmo sinusal si es posible y beneficioso","Tratar causas subyacentes"],farmacologico:[{nombre:"Metoprolol / Bisoprolol",grupo:"Betabloqueante - control de frecuencia",mecanismo:"Bloquea receptores beta1, ralentiza la conduccion en el nodo AV, reduciendo respuesta ventricular",dosis:"Metoprolol 25-200 mg/dia; Bisoprolol 2.5-10 mg/dia",cuidadosEnfermeria:["Medir FC antes de administrar (objetivo 60-80 lpm en reposo)","Vigilar bloqueo AV","No dar si FC < 50 o bloqueo AV de segundo grado"]},{nombre:"Apixaban / Rivaroxaban",grupo:"Anticoagulante oral directo (ACOD) - inhibidor del factor Xa",mecanismo:"Inhibe directamente el factor Xa, interrumpiendo la cascada de coagulacion sin monitoreo de INR",dosis:"Apixaban 5 mg c/12h (2.5 si criterios de reduccion de dosis); Rivaroxaban 20 mg/dia con cena",cuidadosEnfermeria:["Administrar con alimentos (Rivaroxaban)","Vigilar signos de sangrado: hematuria, melena, epistaxis, equimosis","No requiere control de INR","Antidoto: Andexanet alfa para anti-Xa"]},{nombre:"Amiodarona",grupo:"Antiarritmico clase III - control de ritmo",mecanismo:"Bloquea multiples canales ionicos (K, Na, Ca) y receptores beta/alfa; prolonga refractariedad",dosis:"IV: 300 mg en bolo lento + 900 mg en 24h. VO: 200-400 mg/dia mantenimiento",cuidadosEnfermeria:["Monitorizar FC y PA durante infusion IV","Administrar por via central si posible (irritante venoso)","Vigilar toxicidad tiroidea, pulmonar, hepatica a largo plazo","Fotosensibilidad cutanea","Muchos interacciones medicamentosas"]},{nombre:"Digoxina",grupo:"Glucosido cardiaco - control de frecuencia",mecanismo:"Inhibe la ATPasa Na/K, aumenta tono vagal, ralentiza conduccion AV",dosis:"0.125-0.25 mg/dia VO (ajustar en renal); nivel terapeutico 0.5-0.9 ng/mL",cuidadosEnfermeria:["Medir FC 60 segundos antes de administrar: retener si < 60 lpm","Vigilar toxicidad: nauseas, vision amarilla-verde, arritmias","Monitorizar nivel serico y potasio (hipopotasemia aumenta toxicidad)","Interaccion con amiodarona (dobla nivel de digoxina)"]}],noFarmacologico:["Control de factores predisponentes (HTA, peso, alcohol)","Cardioversion electrica si FA de < 48h o con anticoagulacion adecuada","Ablacion con cateter (aislamiento de venas pulmonares) en FA paroxistica sintomatica"],quirurgico:["Ablacion quirurgica (procedimiento Maze)","Cierre de orejuela izquierda (WATCHMAN) si contraindicacion a anticoagulacion"]},cuidadosEnfermeria:{valoracion:["Tomar pulso apical por 60 segundos (ritmo, frecuencia)","Calcular deficit de pulso (apical vs radial)","Monitorizar PA","Evaluar sintomas: palpitaciones, disnea, mareos","Identificar signos de ACV (FAST)","Valorar signos de IC"],intervenciones:["ECG de 12 derivaciones ante FA aguda","Administrar medicacion para control de frecuencia segun indicacion","Preparar para cardioversion electrica si indicado","Monitoreo cardiaco continuo","Anticoagulacion segun protocolo"],educacionPaciente:["Explicar la FA y riesgo de ACV","Importancia de anticoagulacion y no suspenderla","Reconocer sintomas de ACV (FAST): buscar emergencia inmediata","Automedicion de pulso radial","Evitar factores desencadenantes (cafe excesivo, alcohol, estres)"],monitorizacion:["FC y ritmo continuo o cada 4h","PA cada 4-8h","INR si usa warfarina (objetivo 2-3)","Funcion renal y hepatica con ACODs","Signos neurologicos para detectar ACV"]},npiNanda:[{codigo:"00029",nombre:"Disminucion del gasto cardiaco",definicion:"Cantidad de sangre bombeada por el corazon en un minuto, insuficiente para satisfacer las necesidades metabolicas del cuerpo",caracteristicasDefinitorias:["Palpitaciones","Disnea","Fatiga","Pulso irregular"],factoresRelacionados:["Frecuencia cardiaca irregular y elevada","Falta de contribucion auricular al llenado ventricular"]},{codigo:"00201",nombre:"Riesgo de perfusion tisular cerebral ineficaz",definicion:"Vulnerable a una disminucion en la circulacion tisular cerebral que puede comprometer la salud",caracteristicasDefinitorias:["FA con trombo auricular potencial","Score CHA2DS2-VASc elevado"],factoresRelacionados:["Fibrilacion auricular","Anticoagulacion inadecuada","Hipertension arterial"]}],npiNic:[{codigo:"4090",nombre:"Manejo de la disritmia",actividades:["Monitorizar ECG continuamente","Administrar antiarritmicos prescritos","Evaluar tolerancia hemodinamica de la arritmia","Preparar para cardioversion si indicado"]},{codigo:"4270",nombre:"Terapia embolica",actividades:["Administrar anticoagulantes prescritos","Monitorizar INR o niveles de anticoagulantes","Vigilar signos de ACV o embolia periferica","Educar sobre signos de sangrado"]}],npiNoc:[{codigo:"0400",nombre:"Efectividad de la bomba cardiaca",indicadores:["FC ventricular controlada 60-100 lpm","Ausencia de sintomas de bajo gasto","PA estable"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Accidente cerebrovascular isquemico (riesgo 5x mayor)","Embolias sistemicas (mesent\xe9rica, renal, perif\xe9rica)","Insuficiencia cardiaca o descompensacion de IC preexistente","Miocardiopatia taquicardia-inducida","Muerte subita"],criteriosAlarma:["FC ventricular > 150 lpm con inestabilidad hemodinamica","PA sistolica < 90 mmHg","Sintomas neurologicos focales (ACV)","Dolor toracico","Sincope","Disnea severa"],emergencyLevel:"moderado",relatedPathologyIds:["pat_hta","pat_icc","pat_acv","pat_iam"],isPremium:!0},{id:"pat_tvp",nombre:"Trombosis Venosa Profunda",bodySystemId:"cardiovascular",definicion:"Formacion de un trombo en el sistema venoso profundo, principalmente en miembros inferiores, con riesgo de embolismo pulmonar. Forma parte del espectro de la enfermedad tromboembolica venosa (ETV).",epidemiologia:"Incidencia de 1-2 por 1000 habitantes/ano. Es la tercera causa de muerte cardiovascular tras el IAM y ACV. El 30% de los casos desarrolla TEP sintomatico. Hasta el 50% desarrolla sindrome postromb\xf3tico.",factoresRiesgo:["Inmovilizacion prolongada (viajes, hospitalizacion)","Cirugia mayor (especialmente cadera y rodilla)","Cancer activo","Embarazo y puerperio","Anticonceptivos orales con estrogenos","Trombofilia (Factor V Leiden, deficit Proteinas C/S)","Sindrome antifosfolipido","Obesidad","Edad avanzada","TVP previa"],fisiopatologia:"La triada de Virchow explica la trombogenesis: estasis venosa (inmovilizacion, insuficiencia venosa), lesion endotelial (trauma, cirugia, inflamacion) e hipercoagulabilidad (estados protromb\xf3ticos, cancer, embarazo). El trombo se forma inicialmente en las valvas de las venas y progresa proximal y distalmente. La propagacion hacia venas proximales aumenta el riesgo de TEP.",signosYSintomas:{signos:["Edema unilateral del miembro afectado","Eritema y calor local","Signo de Homans positivo (dolor en pantorrilla con dorsiflexion del pie) - baja especificidad","Cord\xf3n venoso palpable","Dilatacion de venas superficiales colaterales"],sintomas:["Dolor en pantorrilla o muslo de inicio insidioso","Sensacion de pesadez o tension en el miembro","Puede ser completamente asintomatica (en hospitalizados)"]},clasificacion:{nombre:"Clasificacion por localizacion",tipos:[{nombre:"TVP distal",descripcion:"Venas por debajo de la rodilla (sural, peronea). Menor riesgo de TEP"},{nombre:"TVP proximal",descripcion:"Vena poplitea o superior. Mayor riesgo de TEP y sindrome postromb\xf3tico"},{nombre:"TVP de miembro superior",descripcion:"Asociada a cateter central o trombosis de esfuerzo (sindrome de Paget-Schroetter)"}]},diagnostico:{anamnesis:["Factores de riesgo de ETV","Inicio y caracteristicas del dolor","Viajes largos o inmovilizacion reciente","Cirugias previas","Antecedentes familiares de trombosis","Medicacion actual (anticonceptivos, quimioterapia)"],examenFisico:["Medicion de perimetros de ambos miembros","Evaluar temperatura, color y turgencia","Buscar cord\xf3n venoso palpable","Evaluar signos de TEP (taquipnea, taquicardia, hipoxia)"],pruebas:[{nombre:"Ecografia Doppler venosa",descripcion:"Prueba de eleccion. Detecta trombo por incompresibilidad venosa y ausencia de flujo Doppler",valoresReferencia:"Vena compresible = normal; no compresible con/sin trombo ecogenico = TVP",cuidadosEnfermeria:["No requiere preparacion","Posicionar miembro correctamente","Anotacion de hallazgos para comparacion futura"]},{nombre:"Dimero-D",descripcion:"Producto de degradacion de fibrina. Alta sensibilidad, baja especificidad. Util para descartar TVP en baja probabilidad clinica",valoresReferencia:"< 500 ng/mL descarta TVP en baja probabilidad (score Wells bajo)",cuidadosEnfermeria:["Muestra venosa estandar","Resultado elevado no confirma TVP (muchas causas de elevacion)"]},{nombre:"Score de Wells para TVP",descripcion:"Herramienta de probabilidad clinica pretest: cancer+1, paralisis+1, inmovilizacion>3d+1, sensibilidad a lo largo de venas+1, edema toda la pierna+1, edema 3cm mayor+1, edema con godet+1, venas colaterales+1, TVP previa+1, diagnostico alternativo probable -2",valoresReferencia:"< 2: baja probabilidad; >= 2: alta probabilidad",cuidadosEnfermeria:["Calcular al ingreso y documentar","Guia para decidir si solicitar dimero-D o eco Doppler directamente"]}]},tratamientoMedico:{objetivos:["Prevenir propagacion del trombo","Prevenir embolismo pulmonar","Aliviar sintomas agudos","Prevenir recurrencia y sindrome postromb\xf3tico"],farmacologico:[{nombre:"Enoxaparina (HBPM)",grupo:"Heparina de bajo peso molecular - anticoagulante",mecanismo:"Inhibe principalmente factor Xa via antitrombina; predecible, no requiere monitoreo de APTT",dosis:"1 mg/kg SC c/12h o 1.5 mg/kg c/24h",cuidadosEnfermeria:["Tecnica correcta de inyeccion SC (zona periumbilical, angulo 90\xb0, no frote)","Rotacion de zonas de puncion","Vigilar hematomas en sitio de inyeccion","Ajustar dosis en insuficiencia renal severa (anti-Xa)"]},{nombre:"Rivaroxaban",grupo:"Anticoagulante oral directo - inhibidor Factor Xa",mecanismo:"Inhibe directamente factor Xa",dosis:"15 mg c/12h con alimentos x 21 dias, luego 20 mg/dia",cuidadosEnfermeria:["Administrar con la comida principal","Vigilar sangrado","No requiere INR","Interacciones con antimic\xf3ticos e inhibidores de proteasa"]},{nombre:"Warfarina",grupo:"Anticoagulante oral - antagonista vitamina K",mecanismo:"Inhibe la sintesis hepatica de factores dependientes de vitamina K (II, VII, IX, X)",dosis:"Inicio 5-10 mg/dia; ajustar segun INR",cuidadosEnfermeria:["Monitorizar INR objetivo 2-3","Muchas interacciones alimentarias (vitamina K) y medicamentosas","Educar sobre alimentos ricos en vitamina K","Antidoto: vitamina K, PFC en sangrado grave"]}],noFarmacologico:["Medias de compresion elastica graduada para reducir sindrome postromb\xf3tico","Deambulacion precoz (no se recomienda inmovilizacion absoluta)","Elevacion del miembro afectado"],quirurgico:["Trombectomia quirurgica en casos raros de TVP masiva iliofemoral","Filtro de vena cava inferior si contraindicacion absoluta a anticoagulacion"]},cuidadosEnfermeria:{valoracion:["Medir perimetros de ambas piernas (misma altura) diariamente","Valorar color, temperatura y edema del miembro afectado","Vigilar sintomas de TEP: disnea subita, dolor toracico, hemoptisis, taquicardia","Evaluar sitios de puncion en caso de anticoagulacion SC","Escala de riesgo de Caprini para prevencion en hospitalizados"],intervenciones:["Administrar anticoagulacion segun prescripcion","Aplicar medias de compresion en miembro NO afectado (profilaxis contralateral)","Fomentar deambulacion precoz cuando sea posible","Elevar miembro afectado 15-20 cm por encima del corazon","No masajear el area afectada (riesgo de desprendimiento de trombo)"],educacionPaciente:["No masajear nunca el miembro con TVP","Importancia y duracion del tratamiento anticoagulante","Reconocer signos de TEP y acudir a emergencias","Medias de compresion: como colocarlas y cuanto tiempo usarlas","Cambios de posicion frecuentes en viajes largos"],monitorizacion:["Signos vitales cada 4-8h buscando taquicardia o hipoxia (TEP)","SpO2 para detectar TEP precoz","Perimetros de miembros diariamente","APTT si usa HNF (objetivo 50-70s)","INR si usa warfarina (objetivo 2-3)","Signos de sangrado (hematuria, melena, hematomas)"]},npiNanda:[{codigo:"00291",nombre:"Riesgo de trombosis",definicion:"Vulnerable a la formacion de un trombo en una vena u arteria que puede comprometer la salud",caracteristicasDefinitorias:["Inmovilizacion","Cirugias recientes","Estasis venosa"],factoresRelacionados:["Inmovilizacion prolongada","Estado hipercoagulable","Deshidratacion"]},{codigo:"00204",nombre:"Perfusion tisular periferica ineficaz",definicion:"Disminucion en la circulacion sanguinea periferica que puede comprometer la salud",caracteristicasDefinitorias:["Edema unilateral","Dolor en miembro afectado","Cambios de color y temperatura"],factoresRelacionados:["Obstruccion venosa por trombo","Estasis venosa"]}],npiNic:[{codigo:"4110",nombre:"Precauciones con los emboles",actividades:["Realizar evaluacion del sistema circulatorio","Administrar anticoagulantes prescritos","No masajear el miembro afectado","Aplicar medias de compresion","Vigilar signos de TEP"]},{codigo:"4104",nombre:"Manejo de la terapia trombolytica o anticoagulante",actividades:["Monitorizar INR/APTT segun protocolo","Vigilar signos de sangrado","Educar sobre medicacion anticoagulante"]}],npiNoc:[{codigo:"0407",nombre:"Perfusion tisular: periferica",indicadores:["Edema disminuido","Dolor reducido","Perimetros simetricos","Sin signos de TEP"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Tromboembolismo pulmonar (potencialmente fatal)","Sindrome postromb\xf3tico (dolor cronico, edema, ulcera venosa)","TVP recurrente","Hipertension pulmonar cronica tromboembolica"],criteriosAlarma:["Disnea subita o taquipnea","Dolor toracico pleuritico","Hemoptisis","Taquicardia > 100 lpm sin otra causa","Hipoxia (SpO2 < 94%)","Hipotension subita","Sincope"],emergencyLevel:"moderado",relatedPathologyIds:["pat_tep","pat_icc"],isPremium:!0},{id:"pat_eap",nombre:"Edema Agudo de Pulmon",bodySystemId:"cardiovascular",definicion:"Sindrome de insuficiencia respiratoria aguda grave por acumulacion rapida de liquido en el intersticio y alveolos pulmonares, generalmente de origen cardiogenico, que representa una emergencia medica.",epidemiologia:"Complicacion grave de la IC descompensada. Mortalidad hospitalaria del 10-20%. Es causa frecuente de ingreso en urgencias en pacientes con ICC conocida.",factoresRiesgo:["Insuficiencia cardiaca preexistente","IAM agudo","Crisis hipertensiva","Arritmias rapidas (FA con respuesta ventricular alta)","Sobrecarga de volumen","Incumplimiento de restriccion hidrica o medicacion","Infeccion intercurrente en cardiaco"],fisiopatologia:"El aumento de la presion en el capilar pulmonar (> 18-20 mmHg) supera la presion oncotica plasmatica, forzando liquido hacia el intersticio pulmonar y luego hacia los alveolos. El liquido alveolar interfiere con el intercambio gaseoso, produciendo hipoxemia severa. La hipoxemia activa el sistema adrenergico, aumentando la poscarga y perpetuando el ciclo. La espuma rosada en la via aerea es la mezcla de liquido rico en proteinas con surfactante y eritrocitos.",signosYSintomas:{signos:["Disnea intensa con uso de musculos accesorios","Crepitantes bilaterales difusos (marea ascendente)","SpO2 < 90%","Taquipnea > 30 rpm","Taquicardia","Espuma rosada por boca y nariz (signo grave)","Diaforesis profusa","Piel fria y palida (vasoconstriccion simpatica)","Tercer ruido en la auscultacion"],sintomas:["Disnea severa de inicio brusco","Sensacion de asfixia o ahogo","Ansiedad extrema","Tos con expectoracion rosada o espumosa","Posicion de ortopnea obligada"]},clasificacion:{nombre:"Clasificacion de Killip-Kimball (en contexto de IAM)",tipos:[{nombre:"Killip I",descripcion:"Sin IC: sin crepitantes ni tercer ruido. Mortalidad ~6%"},{nombre:"Killip II",descripcion:"IC leve: crepitantes en < 50% del campo pulmonar. Mortalidad ~17%"},{nombre:"Killip III",descripcion:"Edema agudo de pulmon: crepitantes en > 50%. Mortalidad ~38%"},{nombre:"Killip IV",descripcion:"Shock cardiogenico: hipotension + signos de hipoperfusion. Mortalidad ~81%"}]},diagnostico:{anamnesis:["Inicio brusco de disnea","Antecedentes de IC o IAM","Medicacion y adherencia","Ingesta reciente de sodio o liquidos","Infeccion reciente"],examenFisico:["Auscultacion pulmonar con crepitantes difusos","Evaluar uso de musculatura accesoria","Taquicardia y taquipnea","Buscar ingurgitacion yugular","Piel: diaforesis, palidez, cianosis periferal"],pruebas:[{nombre:"Saturacion de oxigeno",descripcion:"Oximetria de pulso: refleja hipoxemia grave en EAP",valoresReferencia:"SpO2 < 90% = hipoxemia grave, indica soporte ventilatorio urgente",cuidadosEnfermeria:["Colocar pulsioximetro de inmediato al ingreso","Iniciar O2 sin esperar resultado si cuadro clinico es claro","Verificar buena se\xf1al del sensor"]},{nombre:"Radiografia de torax urgente",descripcion:"Muestra patron alveolar bilateral, lineas B de Kerley, cardiomegalia, derrame pleural",cuidadosEnfermeria:["Realizar en cama (AP) si paciente no puede estar de pie","Resultado orienta diagnostico y respuesta al tratamiento"]},{nombre:"Gasometria arterial",descripcion:"Cuantifica hipoxemia, hipercapnia y acidosis",valoresReferencia:"pH 7.35-7.45, PaO2 80-100 mmHg, PaCO2 35-45, HCO3 22-26",cuidadosEnfermeria:["Puncion arterial (radial preferida)","Comprimir al menos 5 min post-puncion","Transportar muestra en hielo o procesar inmediato","Resultado en < 15 min en situacion de urgencia"]},{nombre:"BNP / NT-proBNP urgente",descripcion:"Confirma origen cardiogenico; niveles muy elevados en EAP",cuidadosEnfermeria:["Obtener junto a otras muestras urgentes","No retrasar tratamiento esperando resultado"]}]},tratamientoMedico:{objetivos:["Restaurar oxigenacion (SpO2 > 94%)","Reducir precarga y congestion pulmonar","Tratar causa desencadenante","Prevenir muerte"],farmacologico:[{nombre:"Furosemida IV",grupo:"Diuretico de asa",mecanismo:"Rapida venodilacion y luego diuresis potente; reduce precarga en minutos",dosis:"40-80 mg IV en bolo lento; puede repetirse o usar infusion continua 5-40 mg/h",cuidadosEnfermeria:["Administrar IV lento (max 4 mg/min)","Diuresis horaria rigurosa","Electrolitos cada 6-8h","Balance hidrico estricto negativo","Objetivo: diuresis 100-200 mL/h"]},{nombre:"Nitroglicerina IV",grupo:"Nitrato - vasodilatador venoso y arterial",mecanismo:"Reduce drasticamente precarga (vasodilatacion venosa) y postcarga, mejorando funcion cardiaca",dosis:"Iniciar 5-10 mcg/min; titular hasta 200 mcg/min segun respuesta y PA",cuidadosEnfermeria:["Monitorizar PA continua (arterial si posible)","No administrar si PA sistolica < 90 mmHg","Contraindicada con sildenafil","Usar bomba de infusion precisa","Tolerancia a las 24-48h: escalonar dosis"]},{nombre:"Morfina IV",grupo:"Opiaceo - ansiol\xedtico y venodilator",mecanismo:"Reduce ansiedad, disminuye frecuencia respiratoria, produce vasodilatacion venosa leve",dosis:"2-4 mg IV lento, repetir segun respuesta",cuidadosEnfermeria:["Monitorizar FR y SpO2 post-dosis","Antidoto naloxona disponible","Usada con precaucion en EAP cardiogenico actual (evidencia cuestionada)"]}],noFarmacologico:["Posicion sentada con piernas colgando (reduce retorno venoso)","Oxigenoterapia de alto flujo (mascarilla Venturi o de reservorio)","CPAP o VNI si hipoxemia refractaria a O2 convencional","Intubacion si VNI falla o hay paro respiratorio inminente"],quirurgico:["Reperfusion coronaria urgente si causa es IAM","Soporte circulatorio mecanico en shock cardiogenico"]},cuidadosEnfermeria:{valoracion:["Frecuencia respiratoria y patron respiratorio","SpO2 continua","PA y FC continuas","Nivel de conciencia","Coloracion cutanea y diaforesis","Auscultar campos pulmonares"],intervenciones:["POSICIONAR: sentado con piernas colgando INMEDIATAMENTE","Ox\xedgeno a alto flujo (mascarilla de reservorio 15 L/min)","Acceso venoso grueso inmediato (2 vias)","Administrar furosemida IV urgente","Sonda vesical para medicion de diuresis horaria","Preparar equipo de intubacion y CPAP","ECG de 12 derivaciones urgente","Monitor continuo"],educacionPaciente:["Post-EAP: explicar desencadenantes y como prevenirlos","Importancia del pesaje diario","Restriccion hidrica y de sodio","Cuando llamar a emergencias"],monitorizacion:["SpO2 continua (objetivo > 94%)","FR cada 15-30 min en fase aguda","Diuresis horaria","PA cada 15-30 min o continua","ECG continuo","Electrolitos cada 6-8h","Gasometria arterial ante deterioro"]},npiNanda:[{codigo:"00032",nombre:"Patron respiratorio ineficaz",definicion:"La inspiracion o espiracion no proporciona una ventilacion adecuada",caracteristicasDefinitorias:["Taquipnea > 30 rpm","Uso de musculos accesorios","SpO2 < 90%","Ortopnea"],factoresRelacionados:["Edema alveolar por falla cardiaca","Disminucion del surfactante"]},{codigo:"00025",nombre:"Exceso de volumen de liquidos",definicion:"Aumento de la retencion de liquidos isotonicos",caracteristicasDefinitorias:["Crepitantes pulmonares","Edema","Aumento de peso rapido"],factoresRelacionados:["Disfuncion ventricular izquierda","Retension de sodio y agua"]}],npiNic:[{codigo:"3300",nombre:"Manejo de la ventilacion mecanica",actividades:["Preparar equipo de via aerea","Aplicar VNI/CPAP segun indicacion","Monitorizar SpO2 y FR continuamente","Aspirar secreciones si necesario"]},{codigo:"4040",nombre:"Cuidados cardiacos",actividades:["Posicionar en Fowler alto o con piernas colgando","Administrar diureticos IV urgentes","Monitorizar PA, FC, SpO2 continua","Preparar para tratamiento causal"]}],npiNoc:[{codigo:"0402",nombre:"Estado respiratorio: intercambio gaseoso",indicadores:["SpO2 > 94%","Gasometria normal","FR < 20 rpm","Ausencia de crepitantes","Sin uso de musculos accesorios"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Insuficiencia respiratoria grave con necesidad de intubacion","Shock cardiogenico","Paro cardiorrespiratorio","Dano cerebral anoxico","Muerte"],criteriosAlarma:["SpO2 < 85% a pesar de O2 de alto flujo","FR > 35 rpm o apnea","Nivel de conciencia disminuido","PA sistolica < 90 mmHg","FC > 150 o < 40 lpm","Espuma rosada abundante"],emergencyLevel:"critico",relatedPathologyIds:["pat_icc","pat_iam","pat_hta"],isPremium:!0},{id:"pat_endocarditis",nombre:"Endocarditis Infecciosa",bodySystemId:"cardiovascular",definicion:"Infeccion del endocardio, principalmente de las valvulas cardiacas, causada por microorganismos (bacterias, hongos), que produce vegetaciones tromb\xf3ticas infectadas y puede destruir estructuras valvulares.",epidemiologia:"Incidencia de 3-10 casos por 100,000 habitantes/ano. Mortalidad hospitalaria del 15-25%. El Staphylococcus aureus es el agente mas frecuente actualmente, seguido de Streptococcus viridans.",factoresRiesgo:["Uso de drogas intravenosas (UDIV)","Protesis valvular cardiaca","Valvulopatia preexistente (reum\xe1tica, prolapse mitral)","Cateter venoso central o dispositivos intravasculares","Cardiopatia congenita","Dialisis cronica","Inmunosupresion","Procedimientos dentales u odontologicos (bacteriemia transitoria)","Endocarditis previa"],fisiopatologia:"El endotelio valvular danado o turbulencia de flujo favorece el deposito de fibrina y plaquetas, creando vegetaciones esteriles (NBTE). La bacteriemia transitoria (procedimientos dentales, UDIV) lleva microorganismos a estas vegetaciones. La infeccion produce mas deposito de fibrina, destruccion valvular, abscesos perivalvulares y embolias septicas. Las vegetaciones pueden fragmentarse y embolizar a cualquier organo.",signosYSintomas:{signos:["Soplo cardiaco nuevo o cambiante","Fiebre prolongada (> 38\xb0C) de origen desconocido","Esplenomegalia","Petequias conjuntivales y cutaneas","Nodulos de Osler (nodulos dolorosos en pulpejos)","Lesiones de Janeway (manchas eritematosas palmoplantares, indoloras)","Manchas de Roth en fondo de ojo","Embolia arterial (ACV, embolias renales, esplenicas)"],sintomas:["Fiebre con escalofrios","Sudoracion nocturna","Perdida de peso","Fatiga","Mialgias y artralgias","Dolor pleur\xedtico si embolia pulmonar (UDIV)"]},clasificacion:{nombre:"Criterios de Duke (modificados)",tipos:[{nombre:"EI definitiva",descripcion:"2 criterios mayores, o 1 mayor + 3 menores, o 5 menores"},{nombre:"EI posible",descripcion:"1 mayor + 1 menor, o 3 menores"},{nombre:"EI rechazada",descripcion:"Diagnostico alternativo o resolucion con antibioticos < 4 dias"}]},diagnostico:{anamnesis:["Fiebre prolongada sin foco aparente","Factores de riesgo: UDIV, protesis valvular, cateter","Procedimientos recientes","Tratamientos antibioticos previos","Historia de cardiopatia"],examenFisico:["Auscultacion cardiaca (soplo nuevo)","Buscar petequias, nodulos de Osler, lesiones de Janeway","Fondo de ojo (manchas de Roth)","Esplenomegalia","Signos neurologicos (embolia cerebral)"],pruebas:[{nombre:"Hemocultivos",descripcion:"3 pares de hemocultivos de sitios distintos, separados por 30-60 min, ANTES de antibioticos",valoresReferencia:"Positivos en > 85% de casos. Bacteriemia persistente es criterio mayor de Duke",cuidadosEnfermeria:["Tecnica estrictamente est\xe9ril","Obtener ANTES de iniciar antibioticos","Volumen adecuado (10 mL por frasco)","Rotar sitios de extraccion","Temperatura del paciente al momento de extraccion"]},{nombre:"Ecocardiograma transesofagico (TEE)",descripcion:"Estudio de eleccion para detectar vegetaciones, abscesos y complicaciones valvulares",valoresReferencia:"Vegetacion: masa ecogenica movil en valvula; sensibilidad TEE > 90%, ETT ~75%",cuidadosEnfermeria:["Ayuno 6h previo","Sedacion consciente segun protocolo","Explicar procedimiento","Monitorizar post-procedimiento"]},{nombre:"PCR y Velocidad de Eritrosedimentacion",descripcion:"Marcadores de inflamacion; elevados pero inespecificos",valoresReferencia:"PCR > 5 mg/L; VES > 20 mm/h en hombres, > 30 en mujeres",cuidadosEnfermeria:["Obtener junto a hemocultivos al ingreso","Monitorizar evolucion bajo tratamiento"]}]},tratamientoMedico:{objetivos:["Erradicar la infeccion con antibioticos bactericidas","Prevenir complicaciones embolicas y valvulares","Indicacion quirurgica si falla medica o complicaciones"],farmacologico:[{nombre:"Penicilina G + Gentamicina",grupo:"Betalactamico + Aminoglucosido - antibioticos bactericidas",mecanismo:"Penicilina G inhibe sintesis de pared bacteriana; Gentamicina tiene efecto sinergico bactericida",dosis:"Penicilina G 12-18 MU/dia IV en 6 dosis; Gentamicina 3 mg/kg/dia en 3 dosis",cuidadosEnfermeria:["Administrar IV estricto (penicilina G inestable)","Monitorizar funcion renal y auditiva con gentamicina (nefrotoxicidad, ototoxicidad)","Niveles pico y valle de aminoglucosido","Tratamiento 4-6 semanas en Streptococcus viridans"]},{nombre:"Oxacilina / Cloxacilina",grupo:"Penicilina antiestafilococica",mecanismo:"Inhibe sintesis de pared de Staphylococcus sensible a meticilina (SAMS)",dosis:"2 g IV cada 4h (12 g/dia)",cuidadosEnfermeria:["Via venosa periferica de buen calibre o central","Vigilar flebitis","Funcion hepatica periodica"]},{nombre:"Vancomicina",grupo:"Glucopeptido - antibiotico activo frente a SAMR",mecanismo:"Inhibe la sintesis de la pared celular de grampositivos, incluyendo Staphylococcus aureus meticilino-resistente",dosis:"30-45 mg/kg/dia IV en 2-3 dosis",cuidadosEnfermeria:["Infundir LENTAMENTE en > 60 min (sindrome del hombre rojo)","Monitorizar niveles traje (objetivo AUC/MIC)","Nefrotoxicidad: vigilar creatinina cada 48h","Red Man Syndrome: rubor, hipotension si infusion rapida"]}],noFarmacologico:["Reposo relativo con movilizacion progresiva","Higiene oral rigurosa","Profilaxis antibiotica en procedimientos invasivos futuros"],quirurgico:["Cirugia valvular urgente si: IC refractaria, absceso perivalvular, embolias recurrentes, infeccion f\xfangica, fallo del tratamiento medico","Reemplazo valvular (biologico o mecanico)"]},cuidadosEnfermeria:{valoracion:["Temperatura cada 4-6h (curva febril)","Auscultar soplos cardiacos en cada turno","Valorar signos embolicos: neurologicos, cutaneos, abdominales","Evaluar sitios de acceso venoso (flebitis)","Balance hidrico y funcion renal"],intervenciones:["Obtener hemocultivos ANTES de iniciar antibioticos","Administrar antibioticos IV a horarios exactos","Via venosa central para antibioticoterapia prolongada","Temperatura cada 4-6h","Registrar soplos y notificar cambios al medico","Cuidado estricto de acceso venoso central"],educacionPaciente:["Explicar duracion del tratamiento (4-6 semanas IV)","Necesidad de profilaxis antibiotica en procedimientos dentales futuros","Higiene oral como medida preventiva","Reconocer sintomas de recaida: fiebre, escalofrios","Cuidados del cateter central en domicilio si hay TADE"],monitorizacion:["Temperatura cada 4-6h","Hemocultivos de control post-tratamiento","Ecocardiograma seriado","Funcion renal y electrolitos","Niveles de aminoglucosidos y vancomicina","Signos neurologicos (embolia cerebral)"]},npiNanda:[{codigo:"00004",nombre:"Riesgo de infeccion",definicion:"Vulnerable a la invasion y multiplicacion de organismos patogenos que pueden comprometer la salud",caracteristicasDefinitorias:["Bacteriemia persistente","Vegetaciones en valvulas"],factoresRelacionados:["Destruccion del endotelio valvular","Uso de drogas IV","Cateter vascular"]},{codigo:"00007",nombre:"Hipertermia",definicion:"Temperatura corporal central superior a la normal diurna a causa de un fallo en la termorregulacion",caracteristicasDefinitorias:["Temperatura > 38\xb0C","Escalofrios","Diaforesis","Piel caliente al tacto"],factoresRelacionados:["Proceso infeccioso por bacteriemia","Vegetaciones infectadas"]}],npiNic:[{codigo:"6540",nombre:"Control de infecciones",actividades:["Administrar antibioticos IV en horarios exactos","Mantener tecnica esteril en acceso vascular","Obtener hemocultivos correctamente antes de antibioticos","Vigilar signos de resistencia o fallo terapeutico"]},{codigo:"3740",nombre:"Tratamiento de la fiebre",actividades:["Monitorizar temperatura cada 4-6h","Administrar antipireticos segun indicacion","Fomentar ingesta hidrica","Cambio de ropa si diaforesis"]}],npiNoc:[{codigo:"0703",nombre:"Severidad de la infeccion",indicadores:["Temperatura < 37.5\xb0C","PCR en descenso","Hemocultivos negativos","Ausencia de nuevas embolias"],escala:"1=Grave, 2=Sustancial, 3=Moderada, 4=Leve, 5=Sin desviacion"}],complicaciones:["Embolias septicas cerebrales (ACV hemorragico o isquemico)","Insuficiencia cardiaca por destruccion valvular","Absceso perivalvular con bloqueo AV","Aneurisma micotico","Insuficiencia renal (inmunocomplejos)","Muerte (mortalidad 15-25%)"],criteriosAlarma:["Nuevo deficit neurologico (embolia cerebral)","IC aguda por regurgitacion valvular","Fiebre persistente a los 7 dias de antibioticos","Bloqueo AV de novo en ECG","Hipotension o shock septico"],emergencyLevel:"critico",relatedPathologyIds:["pat_icc","pat_acv"],isPremium:!0},{id:"pat_epoc",nombre:"Enfermedad Pulmonar Obstructiva Cronica (EPOC)",bodySystemId:"respiratorio",definicion:"Enfermedad prevenible y tratable caracterizada por limitacion persistente del flujo aereo que no es completamente reversible, asociada a una respuesta inflamatoria cronica de la via aerea y del pulmon a particulas nocivas o gases, principalmente el humo del tabaco.",epidemiologia:"Afecta al 10-15% de los adultos mayores de 40 a\xf1os. Cuarta causa de muerte mundial. En Argentina, prevalencia del 14.5% en mayores de 40 a\xf1os. Infradiagnosticada: solo el 25-40% de los casos estan diagnosticados.",factoresRiesgo:["Tabaquismo (causa del 80-90% de casos)","Exposicion laboral (polvo, quimicos, humos)","Contaminacion ambiental y del hogar (biomasa, carbon)","Infecciones respiratorias recurrentes en la infancia","Deficit de alfa-1 antitripsina (causa genetica)","Hiperreactividad bronquial","Bajo nivel socioeconomico","Sexo masculino (historicamente, ahora igualando)"],fisiopatologia:"El humo del tabaco activa macr\xf3fagos y neutrofilos en la via aerea, liberando proteasas que destruyen el tejido elastico alveolar (enfisema). Simultaneamente, la inflamacion cronica de bronquios produce hipersecrecion mucosa, edema e hipertrofia de musculo liso (bronquitis cronica). La obstruccion fija del flujo aereo resulta de la combinacion de ambos mecanismos: perdida del retroceso elastico alveolar y estrechamiento de la via aerea. La hipoxemia cronica desencadena vasoconstriccion pulmonar hipoxica, hipertension pulmonar y cor pulmonale.",signosYSintomas:{signos:["Taquipnea","Uso de musculos accesorios respiratorios","Torax en barril (hiperinsuflacion)","Espiraci\xf3n prolongada y labios fruncidos","Cianosis central (labios, lengua) en enfermedad avanzada","Acropaquias (hipocratismo digital)","Ingurgitacion yugular en cor pulmonale","Edema bimaleolar"],sintomas:["Disnea progresiva, inicialmente de esfuerzo","Tos cronica productiva, especialmente matutina","Expectoracion mucoide cronica","Sibilancias espiractorias","Intolerancia al ejercicio","Perdida de peso en EPOC avanzada"]},clasificacion:{nombre:"Clasificacion GOLD segun FEV1/FVC post-broncodilatador",tipos:[{nombre:"GOLD 1 - Leve",descripcion:"FEV1/FVC < 0.70 y FEV1 >= 80% del predicho"},{nombre:"GOLD 2 - Moderado",descripcion:"FEV1 50-79% del predicho"},{nombre:"GOLD 3 - Grave",descripcion:"FEV1 30-49% del predicho"},{nombre:"GOLD 4 - Muy grave",descripcion:"FEV1 < 30% del predicho"}]},diagnostico:{anamnesis:["Historia de tabaquismo (paquetes/ano)","Exposicion laboral o ambiental","Tiempo de evolucion de sintomas","Frecuencia de exacerbaciones en el ultimo ano","Medicacion actual y respuesta","Limitacion de actividades diarias"],examenFisico:["Inspeccion: torax en barril, uso de accesorios","Percusion: hiperrresonancia bilateral","Auscultacion: murmullo vesicular disminuido, espiraci\xf3n prolongada, sibilancias","Evaluar cianosis y acropaquias","Buscar signos de cor pulmonale"],pruebas:[{nombre:"Espirometria con prueba broncodilatadora",descripcion:"Estudio diagnostico definitivo. FEV1/FVC < 0.70 post-broncodilatador confirma EPOC",valoresReferencia:"FEV1/FVC < 0.70 post-BD (criterio GOLD). FVC, FEV1, VEF1/CVF como porcentaje del predicho",cuidadosEnfermeria:["Paciente sin broncodilatadores de accion corta en 4h","Instruir sobre maniobra espirometrica (maxima inspiracion + espiraci\xf3n forzada)","No realizar si exacerbacion aguda activa","Contraindicada si IAM reciente o SpO2 < 85%"]},{nombre:"Gasometria arterial",descripcion:"Evalua hipoxemia y hipercapnia en EPOC moderado-severo",valoresReferencia:"En EPOC: PaO2 puede ser < 60 mmHg, PaCO2 > 45 (con retencion cronica de CO2)",cuidadosEnfermeria:["En EPOC con hipercapnia cronica, O2 excesivo puede empeorar ventilacion (pierde drive hipoxico)","Registrar FiO2 al momento de la extraccion"]},{nombre:"Radiografia de torax",descripcion:"Muestra hiperinsuflacion, aplanamiento diafragmatico, aumento del espacio retroesternal, bullas",cuidadosEnfermeria:["Util para descartar neumon\xeda en exacerbaciones","No es diagnostica de EPOC por si sola"]},{nombre:"TAC de torax de alta resolucion",descripcion:"Cuantifica enfisema, detecta bullas y diferencia fenotipos (enfisema vs bronquitis cronica)",cuidadosEnfermeria:["Preparar acceso venoso si se usa contraste","Verificar funcion renal pre-contraste"]}]},tratamientoMedico:{objetivos:["Reducir sintomas y mejorar tolerancia al ejercicio","Prevenir exacerbaciones","Reducir progresion de la enfermedad","Reducir mortalidad"],farmacologico:[{nombre:"Salbutamol (Albuterol)",grupo:"Beta-2 agonista de accion corta (SABA) - broncodilatador",mecanismo:"Activa receptores beta-2 en musculo liso bronquial, produciendo broncodilatacion por via del AMPc",dosis:"2 puffs (200 mcg) cada 4-6h o a demanda; nebulizacion 2.5 mg en 3 mL SF",cuidadosEnfermeria:["Ense\xf1ar tecnica correcta de inhalacion con espaciador","Taquicardia e hipokalemia como efectos adversos","Uscar con protocolo del medico (de rescate vs pautado)","Enjuague bucal post-inhalacion para reducir efectos sistemicos"]},{nombre:"Tiotropio",grupo:"Anticolinergico de accion larga (LAMA) - broncodilatador",mecanismo:"Bloquea receptores muscarinicos M3 en musculo liso bronquial, reduce broncoconstriccion y secreciones",dosis:"18 mcg inhalado 1 vez/dia (Handihaler) o 5 mcg (Respimat)",cuidadosEnfermeria:["Ense\xf1ar uso del dispositivo Handihaler o Respimat especificamente","Vigilar retencion urinaria en prostata","Contraindicado en glaucoma de angulo estrecho","Sequedad bucal frecuente"]},{nombre:"Fluticasona/Salmeterol",grupo:"Corticoide inhalado + beta-2 agonista de accion larga (ICS+LABA)",mecanismo:"Corticoide reduce inflamacion de via aerea; LABA produce broncodilatacion sostenida (12h)",dosis:"500/50 mcg c/12h inhalado",cuidadosEnfermeria:["Ense\xf1ar inhalacion con espaciador","Enjuague bucal OBLIGATORIO para prevenir candidiasis oral","En EPOC: indicado si exacerbaciones frecuentes o asma-EPOC overlap (ACO)","Monitorizar densidad osea con uso prolongado"]},{nombre:"Prednisona / Metilprednisolona sist\xe9mica",grupo:"Corticoide sistemico - en exacerbacion aguda",mecanismo:"Potente antiinflamatorio que reduce edema de via aerea en exacerbaciones",dosis:"Prednisona 40 mg/dia VO x 5 dias en exacerbacion",cuidadosEnfermeria:["Administrar con desayuno para reducir irritacion gastrica","Hiperglucemia frecuente: monitorizar glucemia","Proteccion gastrica con IBP","No suspender abruptamente tratamientos largos"]}],noFarmacologico:["Cesacion tabaquica (tratamiento mas eficaz para frenar progresion)","Rehabilitacion respiratoria","Oxigenoterapia domiciliaria si PaO2 < 55 mmHg o < 60 con cor pulmonale","Vacunacion antiinfluenza y antineumococica","Nutricion adecuada","Tecnicas de fisioterapia respiratoria y drenaje postural"],quirurgico:["Cirugia de reduccion de volumen pulmonar (bullas gigantes)","Trasplante pulmonar en EPOC muy severo GOLD 4 refractario"]},cuidadosEnfermeria:{valoracion:["Patron respiratorio: FR, ritmo, uso de musculatura accesoria","SpO2 en reposo y esfuerzo","Caracter de la tos y expectoracion (cantidad, color, consistencia)","Escala de disnea mMRC o eCOPD","Nivel de actividad y limitaciones funcionales","Tecnica de inhalacion"],intervenciones:["Posicion de Fowler o sentado para optimizar ventilacion","Fomentar tecnica de respiracion con labios fruncidos","Administrar broncodilatadores inhalados y ense\xf1ar tecnica correcta","Oxigenoterapia controlada (si hipoxemia: objetivo SpO2 88-92%)","Fisioterapia respiratoria: tos efectiva, drenaje de secreciones","Fomentar hidratacion para fluidificar secreciones"],educacionPaciente:["Cesacion tabaquica: opciones de tratamiento y recursos","Tecnica correcta de uso de inhaladores (con espaciador)","Reconocer y actuar ante exacerbaciones","Vacunacion anual contra influenza","Programa de rehabilitacion respiratoria","Plan de accion escrito ante exacerbacion"],monitorizacion:["SpO2 en reposo y post-actividad","FR, patron respiratorio cada 4-8h","Color y cantidad de esputo en exacerbaciones","Signos de cor pulmonale: edemas, ingurgitacion yugular","Efectos adversos de broncodilatadores (taquicardia, temblores)","Funcion renal si corticoides sistemicos prolongados"]},npiNanda:[{codigo:"00032",nombre:"Patron respiratorio ineficaz",definicion:"La inspiracion o espiracion no proporciona una ventilacion adecuada",caracteristicasDefinitorias:["Disnea","Taquipnea","Uso de musculos accesorios","Espiracion prolongada"],factoresRelacionados:["Obstruccion de la via aerea","Atrapamiento aereo","Fatiga muscular respiratoria"]},{codigo:"00092",nombre:"Intolerancia a la actividad",definicion:"Insuficiencia de energia fisiologica o psicologica para tolerar actividades diarias",caracteristicasDefinitorias:["Disnea de esfuerzo","Fatiga extrema","SpO2 cae con actividad"],factoresRelacionados:["Hipoxemia","Desequilibrio ventilacion/perfusion","Debilidad muscular"]},{codigo:"00031",nombre:"Limpieza ineficaz de las vias aereas",definicion:"Incapacidad para eliminar las secreciones u obstrucciones del tracto respiratorio para mantener la via aerea permeable",caracteristicasDefinitorias:["Tos ineficaz","Expectoracion mucosa abundante","Sibilancias","Estertores"],factoresRelacionados:["Hipersecrecion mucosa","Obstruccion de via aerea","Fatiga"]}],npiNic:[{codigo:"3350",nombre:"Monitorizacion respiratoria",actividades:["Vigilar FR, SpO2 y patron respiratorio","Auscultar campos pulmonares","Monitorizar gasometria arterial","Evaluar uso de musculatura accesoria"]},{codigo:"3140",nombre:"Manejo de la via aerea",actividades:["Posicionar en Fowler para optimizar ventilacion","Administrar broncodilatadores inhalados","Fomentar tos efectiva y tecnicas de drenaje","Oxigenoterapia controlada segun gasometria"]},{codigo:"4490",nombre:"Ayuda para dejar de fumar",actividades:["Abordar tabaquismo en cada contacto","Proporcionar informacion sobre opciones terapeuticas","Derivar a programa de cesacion tabaquica","Usar modelo de las 5 A: preguntar, aconsejar, valorar, ayudar, acordar seguimiento"]}],npiNoc:[{codigo:"0415",nombre:"Estado respiratorio",indicadores:["FR en rango normal","SpO2 > 88%","Uso de musculatura accesoria reducido","Esputo manejable"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"},{codigo:"1602",nombre:"Conducta de promocion de la salud",indicadores:["Cesa tabaquismo","Usa inhaladores correctamente","Asiste a rehabilitacion respiratoria","Recibe vacunaciones"],escala:"1=Nunca demostrado, 2=Raramente, 3=A veces, 4=Frecuentemente, 5=Siempre demostrado"}],complicaciones:["Exacerbacion aguda con insuficiencia respiratoria","Neumonia bacteriana","Neumotorax espontaneo (por rotura de bulla)","Cor pulmonale e insuficiencia cardiaca derecha","Poliglobulia secundaria","Depresion y ansiedad","Cancer de pulmon (mayor riesgo en EPOC tabaquico)","Caquexia y sarcopenia"],criteriosAlarma:["Disnea que no responde a broncodilatadores habituales","SpO2 < 88% a pesar de O2","Confusion o letargia (hipercapnia)","Cianosis central de aparicion aguda","Expectoracion purulenta abundante con fiebre alta","FR > 30 rpm sin respuesta al tratamiento"],emergencyLevel:"leve",relatedPathologyIds:["pat_asma","pat_ira","pat_neumonia","pat_neumotorax"],isPremium:!1},{id:"pat_asma",nombre:"Asma Bronquial",bodySystemId:"respiratorio",definicion:"Enfermedad inflamatoria cronica de la via aerea caracterizada por obstruccion bronquial variable y reversible, hiperreactividad bronquial y remodelado de la via aerea, que produce episodios recurrentes de sibilancias, disnea, opresion toracica y tos.",epidemiologia:"Afecta al 8-10% de la poblacion mundial. En Argentina, prevalencia del 6-10%. Causa el 0.4% de las muertes en el mundo (400.000 anuales). Alta morbilidad: absentismo escolar y laboral significativo.",factoresRiesgo:["Atopia y alergia (asma alergica mas frecuente)","Historia familiar de asma","Exposicion a aeroalergenos: polvo, animales, pollen","Obesidad","Tabaquismo pasivo en ni\xf1os","Contaminacion ambiental","Infecciones respiratorias en la infancia","Sensibilizacion ocupacional (asma del panadero, harinas, isocianatos)","Ejercicio (asma inducida por ejercicio)","AINEs / Aspirina (asma de Widal)"],fisiopatologia:"La exposicion al al\xe9rgeno activa mastocitos y eosinofilos que liberan mediadores inflamatorios (histamina, leucotrienos, prostaglandinas). Esto produce broncoespasmo (respuesta inmediata), inflamacion y edema de la mucosa y tapones de moco (respuesta tardia). La inflamacion cronica lleva al remodelado de la via aerea (fibrosis subepitelial, hipertrofia del musculo liso). La hiperreactividad bronquial hace que estimulos minimos (frio, ejercicio, irritantes) desencadenen broncoespasmo severo.",signosYSintomas:{signos:["Sibilancias espiratorias difusas (y a veces inspiratorias)","Espiracion prolongada","Uso de musculos accesorios en crisis severa","Pulso paradojico (caida de PA sistolica > 10 mmHg en inspiracion) en crisis severa","Silencio auscultatorio en crisis muy severa (torax silente = emergency)","Taquicardia y taquipnea en crisis"],sintomas:["Sibilancias episodicas","Disnea paroxistica","Opresion toracica","Tos seca o productiva, especialmente nocturna o matutina","Sintomas nocturnos que despiertan al paciente","Precipitados por ejercicio, al\xe9rgenos, infecciones, AINES"]},clasificacion:{nombre:"Clasificacion de severidad GINA (segun control)",tipos:[{nombre:"Bien controlado",descripcion:"Sintomas diurnos <= 2 dias/semana, sin limitacion de actividad, sin sintomas nocturnos, uso de rescate <= 2 dias/semana, FEV1 >= 80%"},{nombre:"Parcialmente controlado",descripcion:"1-2 criterios no cumplidos"},{nombre:"No controlado",descripcion:"3-4 criterios no cumplidos"},{nombre:"Crisis asm\xe1tica leve",descripcion:"Sibilancias, habla en frases, SpO2 > 95%, PEF > 70%"},{nombre:"Crisis moderada",descripcion:"Habla en palabras, SpO2 91-95%, PEF 40-69%"},{nombre:"Crisis severa / Status asmaticus",descripcion:"No puede hablar, SpO2 < 90%, PEF < 40%, 'torax silente'"}]},diagnostico:{anamnesis:["Patron de sintomas: frecuencia, triggers, variacion circadiana","Historia familiar de atopia o asma","Historia de rinitis alergica, eccema","Respuesta a broncodilatadores","Identificar desencadenantes especificos"],examenFisico:["Sibilancias a la auscultacion","Evaluar severidad de crisis (capacidad de hablar, FR, SpO2, uso de accesorios)","Buscar signos de atopia (eccema, rinitis)"],pruebas:[{nombre:"Espirometria con prueba broncodilatadora",descripcion:"Obstruccion reversible: FEV1/FVC < 0.70 que mejora >= 12% y 200 mL con broncodilatador",cuidadosEnfermeria:["Sin broncodilatadores de accion corta 4h antes","Tecnica correcta de maniobra espirometrica","No realizar en crisis aguda"]},{nombre:"Pico flujo espiratorio (PEF) con peak-flow meter",descripcion:"Monitoreo domiciliario de obstruccion; variabilidad > 20% sugiere asma activa",valoresReferencia:"Variabilidad diurna > 20%, o mejora > 15% post-broncodilatador es positivo",cuidadosEnfermeria:["Ense\xf1ar tecnica correcta de uso del peak flow meter","Registrar en diario","3 maniobras, tomar el mayor valor"]},{nombre:"Pruebas de alergia (prick test o IgE especifica)",descripcion:"Identifica sensibilizacion a al\xe9rgenos especificos para guiar medidas de evitacion",cuidadosEnfermeria:["Suspender antihistaminicos 5-7 dias antes del prick test","Material de reanimacion disponible (raro choque anafilactico)","Registrar reacciones positivas"]}]},tratamientoMedico:{objetivos:["Control de sintomas y prevencion de crisis","Mantener funcion pulmonar normal","Permitir vida normal sin limitaciones","Minimizar uso de broncodilatadores de rescate"],farmacologico:[{nombre:"Salbutamol",grupo:"Beta-2 agonista de accion corta (SABA) - broncodilatador de rescate",mecanismo:"Broncodilatacion rapida (inicio 3-5 min) por activacion de receptores beta-2",dosis:"Crisis: 2-4 puffs (200-400 mcg) con espaciador cada 20 min x 3 en la primera hora; luego 2 puffs cada 4-6h",cuidadosEnfermeria:["Ense\xf1ar uso correcto de inhalador presurizado + espaciador","Taquicardia, temblor, hipokalemia como efectos adversos","Si necesita > 2 dias/semana: asma no controlada - informar al medico"]},{nombre:"Budesonida (corticoide inhalado)",grupo:"Corticoide inhalado (ICS) - tratamiento controlador",mecanismo:"Reduce inflamacion cronica de la via aerea, disminuye hiperreactividad bronquial",dosis:"200-800 mcg/dia en 2 dosis segun severidad",cuidadosEnfermeria:["Enjuague bucal OBLIGATORIO para prevenir candidiasis orofaringea","Uso diario aunque sin sintomas (tratamiento controlador)","Disfon\xeda como efecto adverso (candidiasis o miopatia laringe)"]},{nombre:"Budesonida/Formoterol (ICS+LABA)",grupo:"Corticoide inhalado + beta-2 agonista de accion larga - terapia combinada",mecanismo:"Doble accion: antiinflamatoria (ICS) + broncodilatacion sostenida 12h (LABA)",dosis:"160/4.5 mcg 1-2 puffs c/12h; puede usarse tambien como alivio (estrategia SMART)",cuidadosEnfermeria:["LABA nunca en monoterapia sin ICS (riesgo de muerte por asma)","Enjuague bucal post-inhalacion","Ense\xf1ar estrategia SMART si indicada"]},{nombre:"Metilprednisolona IV",grupo:"Corticoide sistemico - crisis moderada/severa",mecanismo:"Antiinflamatorio potente que revierte edema e inflamacion de via aerea en crisis",dosis:"40-80 mg IV cada 6-8h en crisis severa, luego prednisona VO 40 mg/dia x 5-7 dias",cuidadosEnfermeria:["Administrar IV lento","Hiperglucemia frecuente: monitorizar glucemia","No suspender abruptamente cursos prolongados"]}],noFarmacologico:["Control ambiental: evitar al\xe9rgenos identificados","No fumar y evitar humo de tabaco","Vacuna antigripal anual","Plan de accion escrito ante crisis","Evitar AINEs si asma sensible a aspirina","Inmunoterapia alergica subcutanea o sublingual si asma alergica"],quirurgico:[]},cuidadosEnfermeria:{valoracion:["Valorar severidad de crisis: escala de Borg, capacidad de hablar, SpO2, FR, uso de accesorios","Auscultacion de sibilancias","PEF si disponible (% del mejor personal o predicho)","Identificar desencadenante del episodio","Evaluar tecnica de inhalacion"],intervenciones:["Posicion sentada con apoyo en brazos (facilita respiracion)","Oxigeno para mantener SpO2 > 94%","Administrar broncodilatadores segun protocolo de crisis","Corticoides sistemicos si crisis moderada/severa","Espirometria/PEF antes y 15-20 min despues de broncodilatadores","Preparar nebulizaciones si necesario"],educacionPaciente:["Tecnica correcta de inhaladores (con y sin espaciador)","Diferenciar medicacion de rescate vs controladora","Plan escrito de accion ante crisis (zona verde/amarilla/roja)","Identificar y evitar desencadenantes personales","Monitorizacion con peak flow meter domiciliario"],monitorizacion:["SpO2 continua en crisis","FR y patron respiratorio cada 15-30 min en crisis","PEF cada hora en crisis hasta estabilizacion","ECG si taquicardia severa o salbutamol en dosis altas","Potasio si salbutamol y/o corticoides a dosis altas"]},npiNanda:[{codigo:"00031",nombre:"Limpieza ineficaz de las vias aereas",definicion:"Incapacidad para eliminar las secreciones u obstrucciones del tracto respiratorio",caracteristicasDefinitorias:["Sibilancias","Tos ineficaz","Disnea","Tapones de moco"],factoresRelacionados:["Broncoespasmo","Inflamacion de la mucosa bronquial","Secreciones espesas"]},{codigo:"00146",nombre:"Ansiedad",definicion:"Sensacion vaga e inquietante de malestar o amenaza",caracteristicasDefinitorias:["Miedo a la asfixia durante la crisis","Taquicardia","Diaforesis"],factoresRelacionados:["Dificultad respiratoria","Amenaza percibida para la vida"]}],npiNic:[{codigo:"3210",nombre:"Manejo del asma",actividades:["Administrar broncodilatadores prescritos","Monitorizar respuesta al tratamiento con PEF y SpO2","Identificar desencadenantes","Ense\xf1ar plan de accion escrito","Tecnica de inhalacion correcta"]},{codigo:"3120",nombre:"Oxigenoterapia",actividades:["Administrar O2 para mantener SpO2 > 94%","Monitorizar SpO2 y gasometria si necesario","Seleccionar dispositivo de O2 adecuado"]}],npiNoc:[{codigo:"0410",nombre:"Estado respiratorio: permeabilidad de las vias aereas",indicadores:["Ausencia de sibilancias","SpO2 > 94%","FR normal","Habla en frases completas"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Status asmaticus (crisis refractaria a tratamiento)","Insuficiencia respiratoria con necesidad de ventilacion mecanica","Neumotorax por barotrauma","Neumon\xeda","Remodelado permanente de la via aerea","Muerte (raro si tratamiento adecuado)"],criteriosAlarma:["SpO2 < 90%","Incapacidad para hablar","Torax silente en auscultacion","Alteracion del nivel de conciencia","Bradicardia o arritmias","PEF < 25% del predicho","Cianosis"],emergencyLevel:"moderado",relatedPathologyIds:["pat_epoc","pat_ira","pat_anafilaxia"],isPremium:!1},{id:"pat_neumonia",nombre:"Neumonia",bodySystemId:"respiratorio",definicion:"Infeccion del parenquima pulmonar (alveolos y espacio intersticial) causada por microorganismos (bacterias, virus, hongos), caracterizada por consolidacion alveolar con exudado inflamatorio que interfiere con el intercambio gaseoso.",epidemiologia:"Incidencia de 5-11 casos/1000 habitantes/ano. Causa de muerte mas frecuente por infeccion en el mundo desarrollado. Mortalidad del 1-5% ambulatorio, 12% hospitalizado, 30-40% en UCI. La NAC (neumonia adquirida en la comunidad) es mas frecuente que la NAVM (nosocomial).",factoresRiesgo:["Edad avanzada > 65 a\xf1os","Tabaquismo","EPOC y enfermedades pulmonares previas","Inmunosupresion (VIH, corticoides, quimioterapia)","Diabetes mellitus","Insuficiencia cardiaca","Disfagia y aspiracion (ACV, demencia)","Alcoholismo","Hospitalizacion y ventilacion mecanica (NAVM)"],fisiopatologia:"Los microorganismos alcanzan los alveolos por microaspiracion de secreciones orofaringeas (via mas comun), inhalacion de aerosoles, o hematogena. La respuesta inflamatoria alveolar produce exudado fibrino-leucocitario que llena los alveolos (consolidacion). La consolidacion impide el intercambio gaseoso, produciendo efecto shunt intrapulmonar e hipoxemia. La fiebre, leucocitosis y los sintomas sistemicos reflejan la respuesta inflamatoria.",signosYSintomas:{signos:["Fiebre > 38.5\xb0C","Crepitantes finos en area afectada","Matidez a la percusion en consolidacion","Soplo tub\xe1rico y broncofon\xeda en consolidacion","Taquipnea y taquicardia","Hipoxemia (SpO2 reducida)","Consolidacion en radiografia"],sintomas:["Fiebre con escalofrios","Tos productiva con esputo mucopurulento o herrumbroso (Streptococcus)","Dolor pleur\xedtico (si pleura afectada)","Disnea","Malestar general","En ancianos: confusion mental como unico sintoma (presentacion atipica)"]},clasificacion:{nombre:"Clasificacion por lugar de adquisicion y agente",tipos:[{nombre:"NAC tipica",descripcion:"Inicio brusco, fiebre alta, esputo purulento, consolidacion lobar. Agente: Streptococcus pneumoniae"},{nombre:"NAC atipica",descripcion:"Inicio insidioso, sintomas extrapulmonares, esputo escaso. Agentes: Mycoplasma, Legionella, Chlamydia"},{nombre:"Neumonia nosocomial (NAVM)",descripcion:"Aparece > 48h tras hospitalizacion o ventilacion. Agentes: Pseudomonas, Klebsiella, SAMR"},{nombre:"Neumonia aspirativa",descripcion:"Por inhalacion de contenido orofaringeo. Lobulos inferiores y medios"}]},diagnostico:{anamnesis:["Inicio y duracion de sintomas","Caracteristicas del esputo","Factores de riesgo especificos","Hospitalizaciones o antibioticos recientes","Estado de vacunacion (neumococo, gripe)","Inmunosupresion"],examenFisico:["Temperatura, FC, FR, SpO2","Crepitantes focales, matidez, soplo tub\xe1rico","Evaluar severidad: FR, PA, nivel de conciencia","Calcular score PSI o CURB-65"],pruebas:[{nombre:"Radiografia de torax PA y lateral",descripcion:"Muestra consolidacion, infiltrados intersticiales, derrame pleural. Confirma diagnostico",cuidadosEnfermeria:["PA de pie si posible","Comparar con radiografias previas si disponibles","Repetir a las 4-6 semanas para confirmar resolucion"]},{nombre:"Hemocultivos (2 pares)",descripcion:"Identifica bacteriemia en NAC grave; positivos en 10-15% de las NAC bacterianas",cuidadosEnfermeria:["Obtener ANTES de antibioticos","Tecnica est\xe9ril rigurosa","Dos sitios diferentes de puncion","Temperatura al momento de la extraccion"]},{nombre:"Antigeno urinario de Legionella y Neumococo",descripcion:"Rapido, detecta ant\xedgenos en orina. Legionella serogrupo 1 y S. pneumoniae",valoresReferencia:"Positivo/Negativo. Alta especificidad (> 95%)",cuidadosEnfermeria:["Muestra de orina fresca (primer orina de la ma\xf1ana ideal)","Resultado en 15-30 min"]},{nombre:"CURB-65 score",descripcion:"Herramienta de severidad: Confusion+1, Urea>7+1, FR>30+1, PAS<90 o PAD<60+1, edad>65+1",valoresReferencia:"0-1: ambulatorio; 2: hospitalizacion; 3-5: UCI",cuidadosEnfermeria:["Calcular al ingreso","Documenta la decision de ingreso y nivel de cuidado"]}]},tratamientoMedico:{objetivos:["Erradicar microorganismo causante","Aliviar sintomas","Prevenir complicaciones","Reducir mortalidad"],farmacologico:[{nombre:"Amoxicilina-Clavulanico",grupo:"Aminopenicilina + inhibidor de betalactamasa - antibiotico primera linea NAC leve",mecanismo:"Inhibe sintesis de pared bacteriana; el acido clavulanico protege de betalactamasas bacterianas",dosis:"875/125 mg c/8h VO o 1-2 g IV c/8h",cuidadosEnfermeria:["Administrar con alimentos (reduce nauseas)","Vigilar rash alergico y diarrea","Verificar alergias a penicilinas"]},{nombre:"Azitromicina",grupo:"Macrolido - NAC atipica o en combinacion",mecanismo:"Inhibe sintesis proteica bacteriana unienidose al ribosoma 50S; activo frente a atipicos",dosis:"500 mg el primer dia, luego 250 mg/dia x 4 dias VO; o 500 mg/dia IV",cuidadosEnfermeria:["Monitorizar intervalo QT (riesgo de arritmias)","Interaccion con digoxina, warfarina","Nauseas frecuentes: administrar con alimentos"]},{nombre:"Ceftriaxona",grupo:"Cefalosporina de 3a generacion - NAC hospitalaria o grave",mecanismo:"Inhibe sintesis de pared bacteriana de amplio espectro grampositivos y negativos",dosis:"1-2 g IV cada 24h",cuidadosEnfermeria:["Administrar IV en 30 min disuelto en SF 0.9%","Vigilar reaccion alergica cruzada con penicilinas (5-10%)","No mezclar en misma via con calcio (precipita)"]}],noFarmacologico:["Fisioterapia respiratoria para movilizar secreciones","Hidratacion adecuada (fluidificar secreciones)","Oxigenoterapia si SpO2 < 94%","Posicion semisentada para reducir aspiracion","Incentivador respiratorio (volumen)"],quirurgico:["Drenaje pleural si derrame paraneumonico complicado o empiema","Decorticacion pulmonar en empiema organizado"]},cuidadosEnfermeria:{valoracion:["Valorar patron respiratorio: FR, SpO2, uso de accesorios","Temperatura cada 4-6h (curva febril)","Caracteristicas del esputo: color, cantidad, consistencia","Nivel de conciencia (confusion = signo de gravedad)","Auscultar campos pulmonares en cada turno","CURB-65 al ingreso"],intervenciones:["Posicionar en Fowler 30-45\xb0","Oxigenoterapia si SpO2 < 94%","Administrar antibioticos en tiempo exacto (primeras 4h de ingreso)","Fomentar tos efectiva y expectoracion","Fisioterapia respiratoria 2-3 veces/dia","Hidratacion IV o VO adecuada","Nebulizaciones con SF para humidificacion"],educacionPaciente:["Cumplimiento completo del ciclo antibiotico","Tecnicas de tos efectiva","Vacunacion antineumococica y antigripal","Cese del tabaquismo","Reconocer signos de empeoramiento: mayor disnea, fiebre persistente"],monitorizacion:["SpO2 continua o cada 4h","FR y PA cada 4-8h","Temperatura cada 4-6h","Leucocitosis seriada (respuesta al tratamiento)","Rx de torax de control a los 5-7 dias si no mejoria","Balance hidrico"]},npiNanda:[{codigo:"00032",nombre:"Patron respiratorio ineficaz",definicion:"La inspiracion o espiracion no proporciona ventilacion adecuada",caracteristicasDefinitorias:["Taquipnea","Disnea","SpO2 reducida","Uso de musculatura accesoria"],factoresRelacionados:["Consolidacion pulmonar","Dolor pleur\xedtico que limita expansion","Fatiga muscular"]},{codigo:"00007",nombre:"Hipertermia",definicion:"Temperatura corporal central superior a la normal",caracteristicasDefinitorias:["Temperatura > 38.5\xb0C","Escalofrios","Diaforesis","Taquicardia"],factoresRelacionados:["Proceso infeccioso pulmonar","Bacteriemia"]},{codigo:"00031",nombre:"Limpieza ineficaz de las vias aereas",definicion:"Incapacidad para eliminar secreciones del tracto respiratorio",caracteristicasDefinitorias:["Tos ineficaz","Esputo abundante y espeso","Crepitantes"],factoresRelacionados:["Exceso de secreciones","Fatiga","Dolor al toser"]}],npiNic:[{codigo:"6550",nombre:"Proteccion contra las infecciones",actividades:["Administrar antibioticos en tiempo y forma","Obtener cultivos antes de antibioticos","Monitorizar temperatura y leucocitosis","Aislar si patogeno transmisible"]},{codigo:"3390",nombre:"Ayuda a la ventilacion",actividades:["Posicionar en Fowler para optimizar ventilacion","Fomentar tos efectiva y expectoracion","Fisioterapia respiratoria","Oxigenoterapia segun SpO2"]}],npiNoc:[{codigo:"0703",nombre:"Severidad de la infeccion",indicadores:["Temperatura < 37.5\xb0C","SpO2 > 95%","Leucocitosis normalizada","Esputo disminuido"],escala:"1=Grave, 2=Sustancial, 3=Moderada, 4=Leve, 5=Sin desviacion"}],complicaciones:["Derrame pleural y empiema","Bacteriemia y sepsis","Insuficiencia respiratoria aguda","Sindrome de dificultad respiratoria aguda (SDRA)","Absceso pulmonar","Meningitis (en neumococcemia)","Muerte"],criteriosAlarma:["FR > 30 rpm","SpO2 < 90%","PA sistolica < 90 mmHg","Confusion aguda","Temperatura > 40\xb0C o hipotermia < 36\xb0C","Deterioro rapido de la funcion pulmonar"],emergencyLevel:"moderado",relatedPathologyIds:["pat_epoc","pat_ira","pat_tep"],isPremium:!1},{id:"pat_tep",nombre:"Tromboembolismo Pulmonar",bodySystemId:"respiratorio",definicion:"Oclusion de una o mas arterias pulmonares por material tromb\xf3tico generalmente procedente de trombosis venosa profunda de miembros inferiores, con consecuencias hemodinamicas y de intercambio gaseoso que pueden ser fatales.",epidemiologia:"Incidencia de 1-2 por 1000 habitantes/ano. Tercera causa de muerte cardiovascular. Mortalidad del 2-8% con tratamiento, hasta 30-50% en TEP masivo no tratado. El 70-80% se origina de TVP en MMII.",factoresRiesgo:["TVP previa o actual","Inmovilizacion prolongada","Cirugia mayor reciente (especialmente ortopedica)","Cancer activo","Embarazo y puerperio","Anticonceptivos orales con estrogenos","Trombofilias hereditarias","Vuelos largos (> 8h)","Insuficiencia cardiaca"],fisiopatologia:"El trombo embolico (generalmente de TVP proximal en MMII) se desplaza por la circulacion venosa hasta impactarse en ramas de la arteria pulmonar. La obstruccion produce: 1) Hipertension pulmonar aguda por aumento de resistencia vascular, con dilatacion y fallo del ventriculo derecho. 2) Efecto espacio muerto: zonas ventiladas no perfundidas. 3) Hipoxemia por redistribucion del flujo a alveolos hipoventilados. El shock obstructivo en TEP masivo resulta de la falla aguda del VD.",signosYSintomas:{signos:["Taquicardia (signo mas frecuente)","Taquipnea","Hipotension en TEP masivo","Ingurgitacion yugular (falla VD)","Acentuacion del componente pulmonar del 2do ruido","Roce pleural si infarto pulmonar","Signos de TVP en MMII (asimetria, edema)"],sintomas:["Disnea de inicio subito (mas frecuente)","Dolor toracico pleuritico","Hemoptisis (infarto pulmonar)","Sincope (TEP masivo)","Ansiedad","Puede ser asintomatico (hallazgo incidental en TC)"]},clasificacion:{nombre:"Clasificacion por riesgo hemodinamico (ESC 2019)",tipos:[{nombre:"TEP masivo (alto riesgo)",descripcion:"Shock o hipotension PA < 90 mmHg. Mortalidad > 15%. Requiere tromb\xf3lisis o embolectomia"},{nombre:"TEP submasivo (riesgo intermedio)",descripcion:"Sin hipotension pero con disfuncion de VD y/o troponina elevada. Mortalidad 3-15%"},{nombre:"TEP no masivo (bajo riesgo)",descripcion:"Sin signos de disfuncion de VD ni hipotension. Mortalidad < 1%"}]},diagnostico:{anamnesis:["Inicio subito de disnea sin otra causa aparente","Factores de riesgo de ETV","Viajes recientes, cirugia, inmovilizacion","Historia de TVP previa","Calculo del score de Wells para TEP"],examenFisico:["Taquicardia y taquipnea como signos mas sensibles","SpO2 reducida","Signos de falla VD (ingurgitacion yugular, galope derecho)","Buscar signos de TVP en MMII"],pruebas:[{nombre:"Angiotomografia de torax (Angio-TC)",descripcion:"Prueba de eleccion. Visualizacion directa de thrombo en arterias pulmonares con sensibilidad > 95%",cuidadosEnfermeria:["Via venosa de buen calibre para contraste IV","Verificar funcion renal y alergias al contraste","Hidratacion pre y post-contraste","Paciente no puede moverse durante el estudio","Resultado rapido en emergencias"]},{nombre:"Dimero-D",descripcion:"Alta sensibilidad, baja especificidad. Negativo en baja probabilidad descarta TEP",valoresReferencia:"< 500 ng/mL descarta TEP en baja probabilidad clinica",cuidadosEnfermeria:["No retrasa la anticoagulacion si clinica compatible","Elevado en: embarazo, cirug\xeda, cancer, infeccion (inespec\xedfico)"]},{nombre:"Troponina I o T",descripcion:"Marcador de disfuncion y da\xf1o del VD por sobrecarga de presion",valoresReferencia:"Troponina elevada = TEP de riesgo intermedio-alto (mayor mortalidad)",cuidadosEnfermeria:["Obtener junto a otros marcadores al ingreso","Orienta la decision de trombolisis en TEP submasivo"]},{nombre:"Ecocardiograma urgente",descripcion:"Evalua disfuncion del VD, signo de McConnel, trombo en VD, excluye otras causas de shock",cuidadosEnfermeria:["En TEP masivo con shock: ecograf\xeda a pie de cama (FOCUS)","No debe retrasar anticoagulacion ni trombolisis"]}]},tratamientoMedico:{objetivos:["Anticoagulacion para prevenir propagacion y recurrencia","Reperfusion en TEP masivo (trombolisis)","Soporte hemodinamico","Prevenir muerte"],farmacologico:[{nombre:"Heparina no fraccionada IV",grupo:"Anticoagulante parenteral - de eleccion en TEP masivo o riesgo de trombolisis",mecanismo:"Potencia antitrombina III, inhibe factores IIa y Xa; rapidamente reversible",dosis:"80 UI/kg bolo IV, luego infusion 18 UI/kg/h; ajustar segun APTT (objetivo 50-70 seg)",cuidadosEnfermeria:["Control de APTT cada 6h en primeras 24h","Protamina como antidoto","Vigilar trombocitopenia inducida por heparina (HIT) con plaquetas cada 2-3 dias","Via venosa exclusiva para heparina"]},{nombre:"Alteplasa (rtPA)",grupo:"Trombol\xedtico - activador del plasminogeno",mecanismo:"Convierte plasminogeno en plasmina que destruye el trombo de fibrina; reduce rapidamente la obstruccion pulmonar",dosis:"100 mg IV en 2h (TEP masivo)",cuidadosEnfermeria:["Contraindicaciones absolutas: ACV hemorragico previo, sangrado activo","Monitorizar PA cada 15 min durante la infusion","Riesgo de sangrado mayor 13-20% (incluyendo intracraneal 1-2%)","Comprimir todos los sitios de puncion al menos 30 min","No extraer sangre ni canalizar nuevas vias durante la infusion si posible"]},{nombre:"Rivaroxaban / Apixaban",grupo:"Anticoagulante oral directo - tratamiento a largo plazo",mecanismo:"Inhibicion directa del factor Xa",dosis:"Rivaroxaban: 15 mg c/12h x 21 dias, luego 20 mg/dia; Apixaban: 10 mg c/12h x 7 dias, luego 5 mg c/12h",cuidadosEnfermeria:["Administrar con comida (Rivaroxaban)","Vigilar sangrado","Duracion minima 3 meses; indefinido si factor de riesgo persistente"]}],noFarmacologico:["Oxigenoterapia para mantener SpO2 > 94%","Soporte hemodinamico con fluidos IV con precaucion (riesgo de sobrecarga VD)","Vasopresores (norepinefrina) si shock a pesar de fluidos"],quirurgico:["Embolectomia quirurgica o percutanea en TEP masivo con contraindicacion a trombolisis","Filtro de vena cava inferior si anticoagulacion contraindicada"]},cuidadosEnfermeria:{valoracion:["SpO2 continua","PA, FC, FR cada 15-30 min en fase aguda","Nivel de conciencia","Signos de shock: piel fria, palida, oliguria","Disnea y dolor toracico (EVA)","Signos de TVP en MMII"],intervenciones:["Posicion de Fowler para mejorar ventilacion","Oxigenoterapia de alto flujo si hipoxemia","Anticoagulacion IV urgente segun protocolo","Dos vias venosas perifericas de grueso calibre","Monitor cardiaco continuo","Sonda vesical para diuresis horaria en shock","Preparar medicacion para trombolisis si indicado"],educacionPaciente:["Importancia y duracion de la anticoagulacion","Reconocer signos de sangrado","Actividad fisica gradual post-TEP","Medidas de prevencion de nueva TVP/TEP (medias de compresion, activacion muscular en viajes)"],monitorizacion:["SpO2 continua (objetivo > 94%)","PA y FC cada 15-30 min en fase aguda","APTT cada 6h con HNF","Diuresis horaria","Signos de sangrado post-trombolisis","ECG (signos de sobrecarga VD: S1Q3T3, bloqueo de rama derecha)"]},npiNanda:[{codigo:"00033",nombre:"Deterioro de la ventilacion espontanea",definicion:"Disminucion de las reservas energeticas que produce incapacidad para mantener la ventilacion adecuada",caracteristicasDefinitorias:["Taquipnea","SpO2 reducida","Uso de musculatura accesoria","Hipoxemia"],factoresRelacionados:["Obstruccion de arteria pulmonar","Aumento del espacio muerto","Hipoxemia"]},{codigo:"00029",nombre:"Disminucion del gasto cardiaco",definicion:"Cantidad insuficiente de sangre bombeada por el corazon",caracteristicasDefinitorias:["Hipotension","Taquicardia","Oliguria","Confusion"],factoresRelacionados:["Fallo agudo del ventriculo derecho por hipertension pulmonar"]}],npiNic:[{codigo:"4270",nombre:"Terapia embolica",actividades:["Administrar anticoagulacion segun protocolo urgente","Preparar y administrar trombolisis si indicado","Monitorizar respuesta hemodinamica","Vigilar sangrado post-trombolisis"]},{codigo:"3120",nombre:"Oxigenoterapia",actividades:["Administrar O2 de alto flujo","Monitorizar SpO2 continua","Preparar VNI o intubacion si deterioro respiratorio"]}],npiNoc:[{codigo:"0401",nombre:"Estado circulatorio",indicadores:["PA sistolica > 90 mmHg","FC < 100 lpm","SpO2 > 94%","Diuresis > 0.5 mL/kg/h"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Shock obstructivo y paro cardiaco","Infarto pulmonar","Hipertension pulmonar cronica tromboembolica (HTPC)","Muerte (30-50% en TEP masivo no tratado)","Sangrado por anticoagulacion/trombolisis"],criteriosAlarma:["PA sistolica < 90 mmHg o caida de > 40 mmHg","Sincope o presincope","SpO2 < 88% a pesar de O2","Taquicardia > 130 lpm","Confusion o deterioro del nivel de conciencia"],emergencyLevel:"critico",relatedPathologyIds:["pat_tvp","pat_ira","pat_iam"],isPremium:!1},{id:"pat_neumotorax",nombre:"Neumotorax",bodySystemId:"respiratorio",definicion:"Presencia de aire en el espacio pleural que colapsa total o parcialmente el pulmon ipsilateral, comprometiendo la funcion respiratoria. Puede ser espontaneo, traumatico o yatrogeno.",epidemiologia:"Neumotorax espontaneo primario: 7-18/100.000 hombres y 1-6/100.000 mujeres/ano. Predomina en hombres jovenes, altos y delgados. El 30-50% recurrencia en primeros 2 a\xf1os sin tratamiento definitivo.",factoresRiesgo:["Habito marfanoide (alto, delgado) para espontaneo primario","EPOC y enfisema (bullas) para espontaneo secundario","Tabaquismo","Tuberculosis pulmonar","Fibrosis pulmonar","Trauma toracico (accidente, puncion pleural, biopsia)","Ventilacion mecanica con presiones elevadas"],fisiopatologia:"En el neumotorax espontaneo primario, la rotura de blebs subpleurales (pequenas vesiculas en apex pulmonar) permite la entrada de aire al espacio pleural virtual. La presion pleural que normalmente es negativa se vuelve positiva, eliminando la fuerza de expansion del pulmon. En el neumotorax a tension, el aire entra en cada inspiracion pero no puede salir (mecanismo de valvula), aumentando progresivamente la presion intrapleural, comprimiendo el pulmon contralateral y desviando el mediastino, comprometiendo el retorno venoso y produciendo shock obstructivo.",signosYSintomas:{signos:["Disminucion o abolicion del murmullo vesicular en hemitorax afectado","Hipersonoridad a la percusion en el lado afectado","Desviacion traqueal al lado contralateral (neumotorax a tension)","Taquicardia e hipotension (tension)","Distension yugular (tension)","Desviacion del PMI"],sintomas:["Dolor toracico pleuritico de inicio brusco","Disnea de inicio subito","En espontaneo primario leve: dolor sin disnea severa","Agitacion y sensacion de muerte en el de tension"]},clasificacion:{nombre:"Clasificacion por causa y severidad",tipos:[{nombre:"Espontaneo primario",descripcion:"Sin enfermedad pulmonar subyacente conocida. Blebs en apex. Benigno en la mayoria"},{nombre:"Espontaneo secundario",descripcion:"Con enfermedad pulmonar previa (EPOC, TB, fibrosis). Mas grave por menor reserva"},{nombre:"Traumatico",descripcion:"Por trauma tor\xe1cico penetrante o cerrado. Frecuentemente asociado a hemotorax"},{nombre:"Yatrogeno",descripcion:"Por puncion pleural, biopsia pulmonar, ventilacion mecanica (barotrauma)"},{nombre:"A tension",descripcion:"Emergencia vital: presion creciente colapsa pulmon y mediastino. Requiere descompresion urgente"}]},diagnostico:{anamnesis:["Inicio brusco de dolor pleuritico y disnea","Antecedentes de EPOC, tabaquismo, TB","Trauma toracico reciente","Procedimientos invasivos previos"],examenFisico:["Ausencia de murmullo vesicular unilateral","Hipersonoridad a la percusion ipsilateral","Desviacion traqueal (tardio, tension)","SpO2 disminuida"],pruebas:[{nombre:"Radiografia de torax PA",descripcion:"Visualiza linea pleural del pulmon colapsado, ausencia de trama vascular periferica, desviacion de mediastino en tension",cuidadosEnfermeria:["En neumotorax a tension: NO esperar Rx, descomprimir primero si diagnostico clinico claro","Radiografia en espiraci\xf3n maximiza la visibilidad del neumotorax peque\xf1o"]},{nombre:"Ecografia pleural (POCUS)",descripcion:"Rapida en urgencias. Ausencia de deslizamiento pleural y ausencia de lineas B confirman neumotorax",cuidadosEnfermeria:["Aplicable a pie de cama en tiempo real","Sensibilidad superior a Rx en decubito"]}]},tratamientoMedico:{objetivos:["Eliminar el aire del espacio pleural","Re-expansion pulmonar","Prevenir recurrencias"],farmacologico:[{nombre:"Oxigeno a alto flujo",grupo:"Terapia de soporte",mecanismo:"La hiperoxia acelera la reabsorcion del nitrogen del aire pleural (hasta 4x mas rapida)",dosis:"O2 al 100% via mascarilla con reservorio 10-15 L/min",cuidadosEnfermeria:["En EPOC: cuidado con hipercapnia por O2 excesivo","Monitorizar SpO2 continuamente"]},{nombre:"Analgesicos (Ketorolac, Morfina)",grupo:"Analgesicos para dolor pleuritico",mecanismo:"Control del dolor para permitir respiracion adecuada",dosis:"Ketorolac 30 mg IV; Morfina 2-4 mg IV si dolor severo",cuidadosEnfermeria:["Valorar el dolor con EVA antes y despues","Morfina: vigilar FR y SpO2"]}],noFarmacologico:["Observacion y reposo en neumotorax peque\xf1o (< 2 cm en Rx)","Aspiracion simple con aguja (neumotorax espontaneo primario moderado-grande)","Drenaje toracico con tubo intercostal conectado a trampa de agua o valvula de Heimlich"],quirurgico:["Videotoracoscopia (VATS) con bullectomia + pleurodesis para prevenir recurrencias","Toracotomia en casos complejos o fallo de VATS"]},cuidadosEnfermeria:{valoracion:["Auscultar ambos hemitorax comparativamente","SpO2 y FR continuas","Dolor (EVA)","Evaluar signos de neumotorax a tension: hipotension, distension yugular, taquicardia, desviacion traqueal","Si tubo pleural: permeabilidad, fluctuacion, burbujas, debito"],intervenciones:["En neumotorax a tension: descompresion con aguja gruesa en 2\xb0 EIC en LMC INMEDIATAMENTE","Oxigenoterapia","Preparar drenaje pleural","Cuidados del tubo pleural: comprobar fluctuacion, sello de agua, fijar apositura","Posicion Fowler","Alivio del dolor"],educacionPaciente:["Cese del tabaquismo","Riesgo de recurrencia y signos para acudir a urgencias","Restricciones: no volar en avion hasta documentar resolucion completa","Actividad fisica progresiva post-resolucion"],monitorizacion:["SpO2 continua","Signos vitales cada 4h","Debito del tubo pleural","Rx de torax de control post-drenaje","Signos de tension si deterioro rapido"]},npiNanda:[{codigo:"00032",nombre:"Patron respiratorio ineficaz",definicion:"La inspiracion o espiracion no proporciona ventilacion adecuada",caracteristicasDefinitorias:["Disnea","Taquipnea","SpO2 reducida","Disminucion de murmullo vesicular"],factoresRelacionados:["Colapso pulmonar por presencia de aire intrapleural"]},{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable por lesion tisular",caracteristicasDefinitorias:["Dolor pleuritico","Facies de dolor","Restriccion de movimientos respiratorios por dolor"],factoresRelacionados:["Irritacion pleural por aire","Procedimiento de drenaje"]}],npiNic:[{codigo:"3390",nombre:"Ayuda a la ventilacion",actividades:["Administrar oxigenoterapia de alto flujo","Posicionar en Fowler","Preparar y asistir en drenaje pleural","Monitorizar SpO2 y FR"]},{codigo:"1872",nombre:"Cuidados del tubo de torax",actividades:["Comprobar permeabilidad del tubo","Verificar fluctuacion y burbujeo","Mantener el sello de agua bajo el nivel del torax","Registrar debito en volumen y caracteristicas","No pinzar el tubo salvo instruccion medica"]}],npiNoc:[{codigo:"0402",nombre:"Estado respiratorio: intercambio gaseoso",indicadores:["SpO2 > 94%","Murmullo vesicular bilateral","FR < 20 rpm"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Neumotorax a tension (emergencia vital)","Hemotorax asociado","Reexpansion con edema pulmonar (descompresion muy rapida)","Recurrencia (30-50% sin tratamiento definitivo)","Empiema (si drenaje prolongado o contaminacion)"],criteriosAlarma:["Hipotension subita + distension yugular + ausencia de murmullo (TENSION)","SpO2 < 88%","FR > 35 rpm","Taquicardia > 130 lpm","Desviacion traqueal visible"],emergencyLevel:"critico",relatedPathologyIds:["pat_epoc","pat_ira","pat_tep"],isPremium:!0},{id:"pat_ira",nombre:"Insuficiencia Respiratoria Aguda",bodySystemId:"respiratorio",definicion:"Incapacidad aguda del sistema respiratorio para mantener una adecuada oxigenacion (PaO2 < 60 mmHg) y/o eliminar CO2 (PaCO2 > 50 mmHg con pH < 7.35), requiriendo soporte ventilatorio urgente.",epidemiologia:"Causa frecuente de ingreso en UCI (20-30% de los ingresos criticos). El SDRA (forma mas grave de IRA hipoxemica) tiene mortalidad del 30-45%. La hipercapnia aguda en EPOC exacerbado tiene mortalidad del 10-15%.",factoresRiesgo:["EPOC exacerbado","Asma grave (status asmaticus)","Neumonia grave","Edema agudo de pulmon","Sepsis y SDRA","TEP masivo","Intoxicacion por depresores del SNC (opioides, benzodiacepinas)","Trauma toracico severo","Enfermedades neuromusculares (Guillain-Barre, miastenia)"],fisiopatologia:"La IRA tipo I (hipoxemica) resulta de alteraciones V/Q, shunt intrapulmonar o alteracion de difusion alveolo-capilar: el gas no llega a los alveolos o no puede difundir (edema, consolidacion, SDRA). La IRA tipo II (hipercapnica, ventilatoria) resulta de incapacidad de los musculos respiratorios o el centro respiratorio para generar la ventilacion alveolar minima necesaria para eliminar el CO2 producido (EPOC, depresion del SNC, fatiga muscular). La hipoxemia grave produce disfuncion multiorganica y muerte.",signosYSintomas:{signos:["Taquipnea > 30 rpm","Uso intenso de musculos accesorios y retraccion supraesternal","Cianosis central (labios y lengua)","SpO2 < 90%","Agitacion o somnolencia (hipercapnia)","Diaforesis profusa","Bradicardia e hipotension en fase terminal"],sintomas:["Disnea intensa en reposo","Sensacion de asfixia","Confusion y agitacion (hipoxemia)","Somnolencia y letargo (hipercapnia)","Cefalea matutina (hipercapnia cronica exacerbada)"]},clasificacion:{nombre:"Clasificacion por mecanismo fisiopatologico",tipos:[{nombre:"IRA tipo I (hipoxemica)",descripcion:"PaO2 < 60 mmHg con PaCO2 normal o baja. Causa: SDRA, neumonia, EAP, TEP"},{nombre:"IRA tipo II (hipercapnica)",descripcion:"PaCO2 > 50 mmHg con acidosis respiratoria. Causa: EPOC exacerbado, depresion SNC, fatiga muscular"},{nombre:"IRA mixta",descripcion:"Hipoxemia + hipercapnia: EPOC grave, status asmaticus"}]},diagnostico:{anamnesis:["Causa desencadenante","Enfermedad pulmonar o neuromuscular previa","Medicacion (opioides, sedantes)","Velocidad de instalacion"],examenFisico:["Frecuencia y patron respiratorio","SpO2","Uso de musculos accesorios","Nivel de conciencia (Glasgow)","Auscultacion pulmonar"],pruebas:[{nombre:"Gasometria arterial urgente",descripcion:"Confirma tipo y gravedad de la IRA; indispensable para decision de soporte ventilatorio",valoresReferencia:"pH 7.35-7.45, PaO2 80-100, PaCO2 35-45, HCO3 22-26. Acidosis respiratoria: pH bajo + PaCO2 alto",cuidadosEnfermeria:["Puncion arteria radial en angulo 45\xb0","Comprimir 5 min post-puncion (mas en anticoagulados)","Transportar en hielo, procesar en 15 min","Anotar FiO2 exacta al momento de la extraccion","Resultado urgente: avisar al medico inmediatamente"]},{nombre:"Rx de torax urgente",descripcion:"Identifica causa de IRA: EAP, neumonia, neumotorax, derrame, SDRA",cuidadosEnfermeria:["Portable/AP en cama si paciente critico","No retrasar otras intervenciones urgentes"]}]},tratamientoMedico:{objetivos:["Corregir hipoxemia (SpO2 > 90%)","Tratar la causa subyacente","Soporte ventilatorio segun gravedad"],farmacologico:[{nombre:"Naloxona",grupo:"Antagonista opiode - en IRA por sobredosis",mecanismo:"Revierte rapidamente la depresion respiratoria por opioides",dosis:"0.4-2 mg IV cada 2-3 min; puede repetirse",cuidadosEnfermeria:["Efecto dura 30-90 min (mas corto que el opiode): vigilar re-narcotizacion","Puede precipitar sindrome de abstinencia agudo","Preparar reanimacion por si acaso"]},{nombre:"Flumazenil",grupo:"Antagonista de benzodiacepinas",mecanismo:"Revierte sedacion y depresion respiratoria por benzodiacepinas",dosis:"0.2 mg IV cada 60 seg hasta 1 mg",cuidadosEnfermeria:["Efecto corto: riesgo de re-sedacion (mayor duracion de BZD)","Puede precipitar convulsiones en epilepticos tratados con BZD"]},{nombre:"Broncodilatadores (Salbutamol + Ipratropio nebulizados)",grupo:"Broncodilatadores - en IRA por EPOC o asma",mecanismo:"Reducen obstruccion bronquial mejorando flujo aereo y trabajo respiratorio",dosis:"Salbutamol 2.5 mg + Ipratropio 0.5 mg en nebulizacion cada 20 min",cuidadosEnfermeria:["Vigilar taquicardia e hipokalemia","O2 impulsor de la nebulizacion en hipoxemicos","Aire comprimido en hipercapnicos (EPOC)"]}],noFarmacologico:["Oxigenoterapia controlada (objetivo SpO2 88-92% en EPOC, 94-98% en otros)","VNI (CPAP/BiPAP): de eleccion en IRA hipercapnica por EPOC y EAP cardiogenico","Intubacion orotraqueal y ventilacion mecanica invasiva si falla VNI o hipoxemia refractaria","Posicion prono en SDRA grave (mejora oxigenacion)"],quirurgico:[]},cuidadosEnfermeria:{valoracion:["SpO2 continua y gasometria arterial","FR, patron respiratorio, uso de accesorios","Nivel de conciencia (Glasgow)","PA y FC cada 15 min en fase aguda","Coloracion y signos de fatiga muscular"],intervenciones:["Posicion de Fowler alto","O2 a flujo adecuado segun objetivo de SpO2","Preparar y asistir en colocacion de VNI o intubacion","Aspirar secreciones si precisa","Monitoreo cardiaco continuo","Dos accesos venosos de grueso calibre"],educacionPaciente:["Post-episodio: explicar causa y prevencion de recurrencias","Uso correcto de inhaladores si EPOC o asma","Reconocer signos de alarma precoz"],monitorizacion:["SpO2 continua","Gasometrias seriadas cada 1-2h en ventilacion mecanica","FR y patron respiratorio continuo","PA, FC cada 15-30 min","Nivel de conciencia horario","Diuresis horaria"]},npiNanda:[{codigo:"00030",nombre:"Deterioro del intercambio gaseoso",definicion:"Exceso o defecto en la oxigenacion y/o la eliminacion del dioxido de carbono",caracteristicasDefinitorias:["PaO2 < 60 mmHg","Cianosis","Confusion","Diaforesis"],factoresRelacionados:["Desequilibrio ventilacion-perfusion","Shunt intrapulmonar","Hipoventilacion alveolar"]},{codigo:"00033",nombre:"Deterioro de la ventilacion espontanea",definicion:"Incapacidad para mantener la ventilacion adecuada por disminucion de reservas energeticas",caracteristicasDefinitorias:["Fatiga muscular respiratoria","SpO2 decreciente","PaCO2 creciente"],factoresRelacionados:["Fatiga de musculos respiratorios","Obstruccion de via aerea","Depresion del centro respiratorio"]}],npiNic:[{codigo:"3300",nombre:"Manejo de la ventilacion mecanica: invasiva",actividades:["Ajustar parametros ventilatorios segun prescripcion","Monitorizar presiones y volumenes","Aspirar secreciones con tecnica est\xe9ril","Cuidados de la via aerea artificial","Prevenir NAVM (posicion, higiene oral)"]},{codigo:"3320",nombre:"Oxigenoterapia",actividades:["Administrar O2 al flujo prescrito","Monitorizar SpO2 y gasometria","Seleccionar dispositivo de O2 adecuado","Humidificar O2 si flujo > 4 L/min"]}],npiNoc:[{codigo:"0402",nombre:"Estado respiratorio: intercambio gaseoso",indicadores:["PaO2 > 60 mmHg","PaCO2 < 50 mmHg","pH normal","SpO2 > 90%"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Paro cardiorrespiratorio","Dano cerebral anoxico","Lesion pulmonar asociada a ventilacion mecanica","Infeccion nosocomial (NAVM)","Sindrome de abstinencia a sedantes","Muerte"],criteriosAlarma:["SpO2 < 85% a pesar de O2 de alto flujo","FR > 40 rpm o bradipnea < 8 rpm","Glasgow < 10","Apnea o bradipnea preterminal","Agitacion extrema o coma","Hipercapnia con pH < 7.20"],emergencyLevel:"critico",relatedPathologyIds:["pat_epoc","pat_asma","pat_eap","pat_neumonia","pat_tep"],isPremium:!0},{id:"pat_tuberculosis",nombre:"Tuberculosis",bodySystemId:"respiratorio",definicion:"Enfermedad infecciosa cronica causada por Mycobacterium tuberculosis, de transmision aerea, que afecta principalmente al pulmon aunque puede diseminarse a cualquier organo. Es la segunda causa infecciosa de muerte en el mundo.",epidemiologia:"10 millones de casos nuevos/ano a nivel mundial. 1.5 millones de muertes/ano. Incidencia en Argentina de 25-30 casos/100.000 hab. Coinfeccion VIH-TB es muy frecuente y grave. 25% de la poblacion mundial tiene infeccion tuberculosa latente.",factoresRiesgo:["Contacto estrecho con caso bacil\xedfero","VIH/SIDA (mayor riesgo de reactivacion)","Desnutricion y pobreza","Hacinamiento","Diabetes mellitus","Tratamiento con anti-TNF (biologicos)","Insuficiencia renal cronica","Silicosis","Alcoholismo","Edad: ni\xf1os < 5 a\xf1os y ancianos"],fisiopatologia:"M. tuberculosis se inhala en gotitas de Fl\xfcgge (< 5 micras) que llegan a los alveolos. Los macr\xf3fagos alveolares fagocitan el bacilo pero no lo destruyen; este se replica intracelularmente. La respuesta inmune celular (linfocitos T) forma el granuloma tuberculoso (tuberculo) que limita la expansion. Si la inmunidad es insuficiente, los bacilos se multiplican, el granuloma se necrosa (necrosis caseosa) y se forma la caverna tuberculosa con alta carga bacilar y alta contagiosidad.",signosYSintomas:{signos:["Crepitantes en apex pulmonar (tuberculosis apical)","Signos de caverna: soplo anf\xf3rico, pectoriloquia","Fiebre vespertina","Linfadenopatias (TB ganglionar)","Estertores en bases si derrame pleural"],sintomas:["Tos productiva > 2-3 semanas (sintoma cardinal)","Hemoptisis (erosion vascular)","Perdida de peso progresiva","Sudoracion nocturna","Fiebre vespertina persistente","Fatiga y anorexia","Dolor pleuritico si pleures\xeda tuberculosa"]},clasificacion:{nombre:"Clasificacion por estado y localizacion",tipos:[{nombre:"Infeccion tuberculosa latente (ITBL)",descripcion:"PPD/IGRA positivo sin sintomas ni evidencia de enfermedad activa. Riesgo de reactivacion 10% de por vida"},{nombre:"TB pulmonar activa",descripcion:"Bacilos en esputo. Forma mas frecuente y contagiosa"},{nombre:"TB extrapulmonar",descripcion:"Ganglionar, pleural, meningea, osea, renal. Mas frecuente en VIH+"},{nombre:"TB multidrogorresistente (MDR-TB)",descripcion:"Resistente a Isoniacida + Rifampicina. Tratamiento largo y toxico"}]},diagnostico:{anamnesis:["Tos > 3 semanas (sintoma cardinal)","Contacto con caso conocido de TB","VIH u otras inmunodeficiencias","Historia de TB previa y tratamientos","Origen de paises de alta endemicidad"],examenFisico:["Signos en apex pulmonar","Linfadenopatias cervicales","Signos de perdida de peso","Buscar localizaciones extrapulmonares"],pruebas:[{nombre:"Baciloscopia de esputo (Ziehl-Neelsen x3)",descripcion:"Deteccion de bacilos acido-alcohol resistentes (BAAR) en esputo. Rapida, barata, confirma contagiosidad",valoresReferencia:"Positivo (1+ a 3+): TB activa bacilifera hasta confirmar cultivo. Negativo no descarta TB",cuidadosEnfermeria:["Obtener 3 muestras en dias consecutivos (primera de la ma\xf1ana, espontanea o inducida)","Paciente debe toser en frasco esteril alejado de otras personas","Usar EPP completo (mascarilla FFP2, guantes, bata)","Rotular, refrigerar y enviar al laboratorio el mismo dia"]},{nombre:"Cultivo de esputo en medio de L\xf6wenstein-Jensen",descripcion:"Standard de oro para diagnostico y antibiograma. Demora 4-8 semanas",cuidadosEnfermeria:["Muestra obtenida antes de iniciar tratamiento","Imprescindible para identificar resistencias"]},{nombre:"PCR/GeneXpert MTB/RIF",descripcion:"Diagnostico molecular rapido (2h). Detecta M. tuberculosis y resistencia a rifampicina",cuidadosEnfermeria:["Muestra de esputo o biopsias","Resultado en 2h orienta tratamiento y aislamiento urgente"]},{nombre:"Radiografia de torax",descripcion:"Infiltrados en lobulos superiores con o sin cavernas, adenopatias, derrame pleural",cuidadosEnfermeria:["Guardar para comparacion evolutiva","Rx normal no descarta TB extrapulmonar"]}]},tratamientoMedico:{objetivos:["Curar la enfermedad","Prevenir la transmision a contactos","Prevenir el desarrollo de resistencias"],farmacologico:[{nombre:"Isoniacida (H)",grupo:"Antituberculoso de primera linea",mecanismo:"Inhibe la sintesis del acido micolico de la pared de M. tuberculosis (bactericida)",dosis:"5 mg/kg/dia (max 300 mg) VO junto a piridoxina",cuidadosEnfermeria:["Administrar en ayunas para mejor absorcion","Dar SIEMPRE con piridoxina (vit B6) 25-50 mg/dia para prevenir neuropatia periferica","Monitorizar funcion hepatica mensualmente","Hepatotoxicidad: suspender si transaminasas > 3-5x el limite superior"]},{nombre:"Rifampicina (R)",grupo:"Antituberculoso de primera linea - bactericida potente",mecanismo:"Inhibe la ARN polimerasa dependiente de DNA bacteriana",dosis:"10 mg/kg/dia (max 600 mg) VO en ayunas",cuidadosEnfermeria:["Tine de rojo-anaranjado orina, lagrimas, sudor (ADVERTIR al paciente)","Puede decolorar lentes de contacto","Muchas interacciones medicamentosas (reduce niveles de anticonceptivos, warfarina, antirretrovirales)","Hepatotoxicidad: monitorizar transaminasas"]},{nombre:"Pirazinamida (Z)",grupo:"Antituberculoso primera linea - bactericida en pH acido",mecanismo:"Actua en el medio acido de los macrofagos, matando bacilos intracelulares",dosis:"25 mg/kg/dia (max 2 g) VO",cuidadosEnfermeria:["Puede elevar acido urico (artritis gotosa)","Hepatotoxicidad: mas frecuente que Isoniacida","Solo los primeros 2 meses en regimen HRZE"]},{nombre:"Etambutol (E)",grupo:"Antituberculoso primera linea - bacteriostatico",mecanismo:"Inhibe la sintesis del arabinogalactano de la pared micobacteriana",dosis:"15-20 mg/kg/dia (max 1.6 g) VO",cuidadosEnfermeria:["Neuritis optica retrobulbar: monitorizar agudeza visual y vision de colores mensualmente","Contraindicado si no puede reportar cambios visuales (ni\xf1os peque\xf1os)","Solo 2 primeros meses en regimen HRZE"]}],noFarmacologico:["Aislamiento respiratorio: habitacion individual con presion negativa o ventilacion forzada al exterior","Mascarilla quirurgica para el paciente al salir de la habitacion","FFP2 para el personal sanitario","Tratamiento directamente observado (TDO) para asegurar adherencia","Estudio de contactos y quimioprofilaxis"],quirurgico:["Lobectomia o segmentectomia en TB MDR localizada con fallo terapeutico","Drenaje quirurgico de empiema tuberculoso"]},cuidadosEnfermeria:{valoracion:["Valorar sintomas: tos, hemoptisis, fiebre, sudoracion, perdida de peso","Signos vitales con temperatura cada 4-6h","Valorar cumplimiento del tratamiento","Evaluar efectos adversos de tuberculostaticos (ictericia, neuropatia)","Estado nutricional"],intervenciones:["AISLAMIENTO RESPIRATORIO con mascarilla FFP2 del personal","Habitacion con ventilacion adecuada o presion negativa","Mascarilla quirurgica para el paciente al salir","Educacion sobre higiene respiratoria: toser en pa\xf1o de un solo uso","Administrar medicacion con TDO (tratamiento observado)","Notificacion obligatoria a salud publica"],educacionPaciente:["Explicar que el tratamiento dura 6 meses y debe completarse SIN INTERRUPCIONES","Consecuencias de abandono: resistencia y recidiva","Modo de transmision y medidas de prevencion para convivientes","Estudio de contactos familiares y cercanos","Signos de alarma: ictericia, cambios visuales, neuropatia"],monitorizacion:["Baciloscopias mensualmente hasta negativizacion","Transaminasas mensualmente (hepatotoxicidad de tuberculostaticos)","Vision mensualmente (Etambutol)","Acido urico (Pirazinamida)","Peso mensual","Radiografia de torax a los 2 y 6 meses"]},npiNanda:[{codigo:"00004",nombre:"Riesgo de infeccion",definicion:"Vulnerable a la transmision de infeccion a contactos",caracteristicasDefinitorias:["Baciloscopia positiva","Tos bacilifera activa"],factoresRelacionados:["Infeccion activa por M. tuberculosis","Aislamiento inadecuado"]},{codigo:"00078",nombre:"Gestion de salud ineficaz",definicion:"Patron de regulacion e integracion inadecuado del regimen terapeutico",caracteristicasDefinitorias:["Dificultad para mantener tratamiento 6 meses","Abandono previo de tratamiento"],factoresRelacionados:["Duracion del tratamiento","Efectos adversos medicamentosos","Factores socioeconomicos"]}],npiNic:[{codigo:"6540",nombre:"Control de infecciones",actividades:["Implementar aislamiento respiratorio inmediato","Usar EPP adecuado (FFP2)","Notificar a salud publica","Estudio de contactos","Educacion sobre higiene respiratoria"]},{codigo:"2380",nombre:"Manejo de la medicacion",actividades:["Administrar medicacion con tratamiento directamente observado (TDO)","Monitorizar efectos adversos de tuberculostaticos","Identificar y resolver barreras para la adherencia"]}],npiNoc:[{codigo:"0703",nombre:"Severidad de la infeccion",indicadores:["Baciloscopias negativas","Temperatura normal","Perdida de peso detenida","Sintomas respiratorios reducidos"],escala:"1=Grave, 2=Sustancial, 3=Moderada, 4=Leve, 5=Sin desviacion"}],complicaciones:["Hemoptisis masiva (erosion de arteria de Rasmussen)","Neumotorax espontaneo","Fistula broncopleural","TB miliar (diseminacion hematogena)","Meningitis tuberculosa","Insuficiencia respiratoria cronica","TB MDR por abandono del tratamiento"],criteriosAlarma:["Hemoptisis masiva (> 200 mL/24h)","Disnea severa de rapida instauracion","Confusion o meningismo (meningitis TB)","Hemoptisis de cualquier cuantia con inestabilidad hemodinamica"],emergencyLevel:"moderado",relatedPathologyIds:["pat_vih","pat_ira","pat_neumonia"],isPremium:!0},{id:"pat_acv",nombre:"Accidente Cerebrovascular",bodySystemId:"neurologico",definicion:"Interrupcion subita del flujo sanguineo cerebral que produce un deficit neurologico focal de inicio brusco que persiste mas de 24 horas. Puede ser isquemico (80%) por trombo u embolo, o hemorragico (20%) por rotura vascular.",epidemiologia:"Segunda causa de muerte mundial y primera causa de discapacidad en adultos. Incidencia de 150-200/100.000 hab/ano. En Argentina causa el 8% de las muertes. Mortalidad a 30 dias: 20-25% para isquemico, 40-50% para hemorragico.",factoresRiesgo:["Hipertension arterial (principal factor modificable)","Fibrilacion auricular (riesgo 5x mayor)","Diabetes mellitus","Tabaquismo","Dislipemia","Cardiopatias emboligenicas","Estenosis carotidea","Edad avanzada","Antecedente de AIT o ACV previo","Uso de anticonceptivos orales"],fisiopatologia:"En el ACV isquemico, la oclusion arterial produce una zona de infarto (necrosis irreversible) rodeada por la penumbra isquemica (tejido en riesgo pero recuperable si se reperfunde rapidamente). Cada minuto sin tratamiento se pierden 1.9 millones de neuronas ('tiempo es cerebro'). En el ACV hemorragico, el hematoma comprime el tejido circundante y el edema cerebrales produce efecto de masa con posible herniacion. La hipertension arterial cronica es la causa principal de hemorragia intracerebral.",signosYSintomas:{signos:["Hemiparesia o hemiplejia contralateral al hemisferio lesionado","Desviacion de la comisura bucal","Asimetria facial","Disartria o afasia","Hemianopsia","Ataxia (cerebelo)","Nistagmo (tronco)","Alteracion del nivel de conciencia"],sintomas:["Debilidad o paralisis en brazo, pierna o cara de un lado","Dificultad para hablar o comprender (afasia)","Vision doble o perdida de vision en un ojo","Cefalea subita intensa (hemorragico: 'la peor cefalea de mi vida')","Vertigo, inestabilidad, caidas","Confusion aguda"]},clasificacion:{nombre:"Clasificacion por mecanismo",tipos:[{nombre:"ACV isquemico tromb\xf3tico",descripcion:"Trombo local en arteria aterosclerotica. Inicio gradual o por escalones"},{nombre:"ACV isquemico embolico",descripcion:"Embolo cardiaco (FA, IAM) o arterial. Inicio subito, deficit maximo al inicio"},{nombre:"Hemorragia intracerebral (HIC)",descripcion:"Rotura de arteria perforante. Hipertension es causa principal. Deficit progresivo"},{nombre:"Hemorragia subaracnoidea (HSA)",descripcion:"Rotura de aneurisma en espacio subaracnoideo. Cefalea subita 'thunderclap'"},{nombre:"Ataque isquemico transitorio (AIT)",descripcion:"Deficit focal < 24h (generalmente < 1h). Alto riesgo de ACV en siguientes 48h"}]},diagnostico:{anamnesis:["Hora exacta de inicio de sintomas (o cuando se vio bien por ultima vez)","Caracteristicas del deficit neurologico","Factores de riesgo","Medicacion anticoagulante o antiagregante actual","Cirugia o trauma reciente (contraindica trombolisis)"],examenFisico:["Escala NIH Stroke Scale (NIHSS) para cuantificar deficit","Nivel de conciencia (Glasgow)","Signos meningeos (hemorragia subaracnoidea)","Auscultacion carotidea (soplos)","PA en ambos brazos","Ritmo cardiaco (FA)"],pruebas:[{nombre:"TC de craneo sin contraste urgente",descripcion:"Primer estudio: descarta hemorragia (hiperintenso en TC) antes de trombolisis. En isquemico precoz puede ser normal",cuidadosEnfermeria:["Realizacion en < 25 min del ingreso (objetivo)","Sin contraste inicialmente","Acompanar al paciente monitorizado","Si agitacion: sedacion minima"]},{nombre:"RMN cerebral con DWI",descripcion:"Superior a TC para infartos tempranos y lacunares; secuencia difusion (DWI) detecta isquemia en minutos",cuidadosEnfermeria:["Verificar contraindicaciones para RMN (marcapasos, clips metalicos)","Tiempo mas largo que TC: no demorar trombolisis por RMN"]},{nombre:"Glucemia urgente",descripcion:"La hipoglucemia y la hiperglucemia pueden simular o agravar un ACV",valoresReferencia:"Objetivo en ACV agudo: 140-180 mg/dL. Hipoglucemia < 70 causa deficit neurologico similar",cuidadosEnfermeria:["Resultado en < 5 min del ingreso","Corregir hipoglucemia si < 70 mg/dL antes de TC"]},{nombre:"NIHSS (NIH Stroke Scale)",descripcion:"Escala de 0-42 que cuantifica el deficit neurologico. Orienta tratamiento y pronostico",valoresReferencia:"0=normal, 1-4=leve, 5-15=moderado, 16-20=moderado-grave, >20=grave",cuidadosEnfermeria:["Aplicar al ingreso y monitorizacion seriada","Documenta mejoria o empeoramiento para decision de trombolisis"]}]},tratamientoMedico:{objetivos:["Reperfusion cerebral urgente en isquemico (tPA o trombectomia)","Reducir el area de penumbra isquemica","Prevenir complicaciones neurologicas y sistemicas","Rehabilitacion precoz"],farmacologico:[{nombre:"Alteplasa IV (tPA)",grupo:"Trombol\xedtico - tratamiento de reperfusion en ACV isquemico",mecanismo:"Disuelve el trombo arterial cerebral, restaurando flujo a la penumbra isquemica",dosis:"0.9 mg/kg IV (max 90 mg): 10% en bolo IV en 1 min, resto en 60 min",cuidadosEnfermeria:["Ventana terapeutica: 4.5 horas desde inicio de sintomas","Contraindicaciones absolutas: hemorragia en TC, anticoagulacion activa, cirugia reciente","Monitorizar PA cada 15 min durante y 2h post-infusion: objetivo < 180/105","Vigilar signos de hemorragia intracraneal: empeoramiento neurologico, cefalea, nauseas","NO dar AAS hasta 24h post-tPA"]},{nombre:"Acido acetilsalicilico",grupo:"Antiagregante - prevencion secundaria y tratamiento de ACV isquemico no tPA",mecanismo:"Inhibe agregacion plaquetaria, reduce riesgo de extension del trombo y recurrencia",dosis:"300 mg en fase aguda (si no tPA), luego 100 mg/dia",cuidadosEnfermeria:["No administrar si hay hemorragia en TC","Esperar 24h post-tPA antes de iniciar","Asegurar que paciente puede deglutir (riesgo de aspiracion en ACV)"]},{nombre:"Labetalol / Nicardipino IV",grupo:"Antihipertensivo IV - control de PA en fase aguda",mecanismo:"Labetalol: betabloqueante + alfabloqueante. Nicardipino: bloqueante de calcio",dosis:"Labetalol 10-20 mg IV en bolo, repetir; Nicardipino infusion 5-15 mg/h",cuidadosEnfermeria:["En ACV isquemico: no bajar PA salvo > 220/120 o si se va a tPA (objetivo < 185/110)","En hemorragico: objetivo PA sistolica < 140 mmHg","Monitorizar PA continua","NUNCA bajar la PA bruscamente en ACV isquemico (empeora isquemia)"]}],noFarmacologico:["Cabecera a 0\xb0 las primeras 24h en ACV isquemico (aumenta perfusion cerebral)","Trombectomia mecanica si oclusion de grande vaso hasta 24h (con imagen de penumbra)","Temperatura normal (tratar fiebre > 37.5\xb0C)","Glucemia 140-180 mg/dL","Evitar hipotension","Profilaxis de TVP con HBPM a las 24-48h"],quirurgico:["Hemicraniectomia descompresiva en infarto maligno de ACM con edema cerebral grave","Evacuacion quirurgica de hematoma intracerebral en casos seleccionados","Clipaje o embolizacion de aneurisma en hemorragia subaracnoidea"]},cuidadosEnfermeria:{valoracion:["NIHSS o evaluacion neurologica completa cada 1-4h","Nivel de conciencia (Glasgow)","PA, FC, FR, temperatura, glucemia cada 1-2h en fase aguda","Evaluacion de la deglucion antes de dar nada VO (test agua)","Evaluacion de continencia urinaria e intestinal","Riesgo de caidas y UPP"],intervenciones:["Cabecera a 0-15\xb0 en isquemico (30\xb0 en hemorragico)","Monitoreo cardiaco continuo (detectar FA)","Acceso venoso y toma de muestras urgentes","Asistir en administracion de tPA si indicado","Nada VO hasta evaluacion de deglucion (riesgo de aspiracion)","SNG si imposibilidad de deglusion","Prevision de cateter urinario si incontinencia o retencion","Presion de enfermedades concomitantes"],educacionPaciente:["Reconocimiento precoz de ACV con metodo FAST (Face, Arm, Speech, Time)","Importancia de llamar inmediatamente al servicio de emergencias","Factores de riesgo y control de la HTA, FA, DM","Adherencia a anticoagulacion/antiagregacion post-ACV","Rehabilitacion: fisioterapia, logopedia, terapia ocupacional"],monitorizacion:["NIHSS o evaluacion neurologica cada 1h en primeras 24h","PA cada 15 min durante tPA, luego cada hora","Glucemia cada 1-4h","Temperatura cada 4-6h (fiebre empeora pronostico)","Diuresis horaria","Signos de aumento de PIC: cefalea, vomitos, Cushing (HTA + bradicardia)"]},npiNanda:[{codigo:"00085",nombre:"Deterioro de la movilidad fisica",definicion:"Limitacion del movimiento fisico independiente e intencionado del cuerpo o de extremidades",caracteristicasDefinitorias:["Hemiplejia o hemiparesia","Limitacion del movimiento","Incapacidad para moverse independientemente"],factoresRelacionados:["Deficit neurologico por isquemia o hemorragia cerebral","Dano motor corticospinal"]},{codigo:"00039",nombre:"Riesgo de aspiracion",definicion:"Vulnerable a la entrada de secreciones gastrointestinales, orofaringeas, solidos o fluidos en el tracto traqueobronquial",caracteristicasDefinitorias:["Disfagia por ACV","Reflejo nauseoso disminuido"],factoresRelacionados:["Disfuncion deglutoria por lesion neurol\xf3gica","Nivel de conciencia reducido"]},{codigo:"00011",nombre:"Estrenimineto",definicion:"Disminucion de la frecuencia normal de evacuacion intestinal",caracteristicasDefinitorias:["Inmovilizacion","Disfuncion autonomica post-ACV"],factoresRelacionados:["Inmovilizacion","Deficit neurologico","Deshidratacion"]}],npiNic:[{codigo:"2620",nombre:"Monitorizacion neurol\xf3gica",actividades:["Evaluar NIHSS o escala de Glasgow cada 1-4h","Monitorizar PA, glucemia, temperatura","Vigilar signos de HIC o herniacion","Documentar cambios neurologicos con hora exacta"]},{codigo:"1860",nombre:"Terapia de deglucion",actividades:["Evaluar deglucion antes de dar VO","Posicion correcta para comer","Consistencias adaptadas segun grado de disfagia","Coordinacion con fonoaudiologo"]},{codigo:"3440",nombre:"Cuidados del sitio de incision: ventana de tPA",actividades:["Comprimir todos los sitios de puncion durante y post-tPA","Vigilar signos de hemorragia sistemica","Monitorizar estado neurologico estrecho post-tPA"]}],npiNoc:[{codigo:"0909",nombre:"Estado neurologico",indicadores:["NIHSS estable o en mejoria","Glasgow estable o en mejoria","PA controlada","Glucemia en rango normal"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"},{codigo:"1010",nombre:"Estado de deglucion",indicadores:["Sin tos al comer","Sin atragantamiento","Progresion de consistencias","Sin episodios de aspiracion"],escala:"1=Gravemente comprometido, 2=Sustancialmente, 3=Moderadamente, 4=Levemente, 5=No comprometido"}],complicaciones:["Herniacion cerebral por edema","Transformacion hemorragica en ACV isquemico","Neumonia aspirativa (disfagia)","Trombosis venosa profunda y TEP (inmovilizacion)","Ulceras por presion","Depresion post-ACV","Epilepsia post-ACV","Deterioro cognitivo o demencia vascular"],criteriosAlarma:["Empeoramiento neurologico subito (caida > 4 puntos en NIHSS)","Cefalea intensa de inicio brusco","Convulsiones","Signos de herniacion: midriasis, rigidez de descerebraci\xf3n, Cushing","Fiebre alta","Caida de PA < 120/70 (empeora isquemia)"],emergencyLevel:"critico",relatedPathologyIds:["pat_hta","pat_fa","pat_dm2","pat_epilepsia"],isPremium:!1},{id:"pat_epilepsia",nombre:"Epilepsia",bodySystemId:"neurologico",definicion:"Trastorno neurologico cronico caracterizado por predisposicion persistente a generar crisis epilepticas (descargas electricas neuronales excesivas, sincronas y autolimitadas), con consecuencias neurobiologicas, cognitivas, psicologicas y sociales.",epidemiologia:"Prevalencia del 0.5-1% de la poblacion mundial (50-70 millones). En Argentina, prevalencia del 1.2%. 30% de los pacientes son refractarios al tratamiento farmacologico.",factoresRiesgo:["Trauma craneoencefalico severo","ACV","Tumores cerebrales","Infecciones del SNC (meningitis, encefalitis)","Malformaciones corticales","Esclerosis del hipocampo","Alteraciones geneticas (epilepsias idiopaticas)","Encefalopatia neonatal","Historia familiar"],fisiopatologia:"La crisis epileptica resulta de una descarga neuronal excesiva, sincr\xf3nica y autolimitada de una red neuronal. El foco epileptogeno puede ser una zona de corteza con umbral de excitacion reducido (perdida de GABAergico o exceso de glutamatergico). La propagacion de la descarga a otras areas cerebrales produce las manifestaciones clinicas de la crisis (motoras, sensitivas, auton\xf3micas, cognitivas). El status epilepticus ocurre cuando los mecanismos de terminacion de la crisis fallan, con riesgo de da\xf1o neuronal irreversible si dura > 30 min.",signosYSintomas:{signos:["Crisis convulsiva tonico-clonica generalizada","Perdida de conciencia","Mordedura de lengua","Incontinencia esfinteriana","Cianosis labial durante la crisis","Estado postictal (confusion y somnolencia post-crisis)","Paralisis de Todd post-crisis focal"],sintomas:["Aura pre-ictal (sensaciones que preceden la crisis: olfato, miedo, deja vu)","Durante la crisis: ausencia de memoria (amnesia ictal)","Post-crisis: confusion, somnolencia, cefalea, mialgias"]},clasificacion:{nombre:"Clasificacion ILAE 2017",tipos:[{nombre:"Crisis de inicio focal",descripcion:"Comienzan en una red neuronal limitada a un hemisferio. Pueden ser con o sin alteracion de conciencia"},{nombre:"Crisis de inicio generalizado",descripcion:"Inicio en redes neuronales bilaterales simultaneamente. Tonico-clonica, ausencia, mioclonica"},{nombre:"Crisis de inicio desconocido",descripcion:"Cuando no puede clasificarse por informacion insuficiente"},{nombre:"Status epilepticus",descripcion:"Crisis que dura > 5 min o dos crisis sin recuperacion intercrisis. EMERGENCIA NEUROLOGICA"}]},diagnostico:{anamnesis:["Descripcion de la crisis por testigos (fundamental)","Duracion y frecuencia de las crisis","Factores desencadenantes: privacion de sueno, alcohol, estres","Antecedentes familiares","Historia de trauma, infeccion, ACV"],examenFisico:["Examen neurologico completo post-ictal","Buscar signos de causa secundaria","Glasgow y estado de conciencia post-crisis"],pruebas:[{nombre:"Electroencefalograma (EEG)",descripcion:"Registro de actividad electrica cerebral; detecta foco epileptico, tipo de epilepsia, patron ictual",valoresReferencia:"Normal: sin actividad epileptiforme. Anomalias: descargas, punta-onda, foco",cuidadosEnfermeria:["Instruir sobre privacion de sueno si es EEG de sueno","Limpieza del cabello (sin gominas)","Puede requerir hiperventilacion y fotoestimulacion durante el estudio"]},{nombre:"RMN cerebral con protocolo epilepsia",descripcion:"Detecta causas estructurales: esclerosis hipocampal, tumor, malformacion, ACV, encefalitis",cuidadosEnfermeria:["Verificar contraindicaciones","Protocolos especiales (FLAIR, T2, IR) para epilepsia"]},{nombre:"Niveles plasmaticos de antiepil\xe9pticos",descripcion:"Controla efectividad y toxicidad del tratamiento farmacologico",valoresReferencia:"Fenitoina: 10-20 mcg/mL; Acido valproico: 50-100 mcg/mL; Carbamazepina: 4-12 mcg/mL",cuidadosEnfermeria:["Muestra pre-dosis (nivel valle) para valorar si es suficiente","Extraer en el momento correcto del ciclo farmacologico"]}]},tratamientoMedico:{objetivos:["Controlar las crisis sin afectar la calidad de vida","Evitar el status epilepticus","Tratar la causa subyacente si existe"],farmacologico:[{nombre:"Acido valproico (VPA)",grupo:"Antiepil\xe9ptico de amplio espectro",mecanismo:"Aumenta GABA cerebral, inhibe canales de sodio. Eficaz en crisis generalizadas y focales",dosis:"15-30 mg/kg/dia en 2-3 tomas; iniciar 200-300 mg c/12h",cuidadosEnfermeria:["Monitorizar nivel plasmatico y funcion hepatica","Teratogenico: mujeres en edad fertil requieren anticoncepcion","Aumento de peso frecuente","Trombocitopenia: monitorizar plaquetas"]},{nombre:"Levetiracetam",grupo:"Antiepil\xe9ptico nueva generacion",mecanismo:"Se une a proteina SV2A de la vesicula sinaptica, modulando la liberacion de neurotransmisores",dosis:"250-1500 mg c/12h",cuidadosEnfermeria:["Bien tolerado, pocas interacciones","Irritabilidad y cambios de humor frecuentes: informar al paciente y familia","No requiere monitoreo de niveles rutinario","Reducir dosis en insuficiencia renal"]},{nombre:"Diazepam IV (Status epilepticus)",grupo:"Benzodiacepina - tratamiento de primera linea del status",mecanismo:"Potencia GABA-A, produce rapida inhibicion neuronal y termina la crisis en > 50% de casos",dosis:"0.15-0.20 mg/kg IV a 5 mg/min; maximo 20 mg",cuidadosEnfermeria:["Preparar equipo de via aerea antes de administrar (depresion respiratoria)","Tener flumazenil como antidoto","Monitorizar SpO2 y PA continuamente","Si no IV: diazepam rectal 0.5 mg/kg (hasta 20 mg)"]},{nombre:"Fenitoina / Fosfenitoina IV (Status 2\xb0 linea)",grupo:"Antiepil\xe9ptico - bloquea canales de sodio",mecanismo:"Estabiliza la membrana neuronal bloqueando canales de sodio voltaje-dependientes",dosis:"Fosfenitoina 20 mg EFP/kg IV a 150 mg/min",cuidadosEnfermeria:["Monitorizar ECG durante infusion (arritmias, hipotension)","No mezclar con glucosa (precipita)","Velocidad de infusion maxima: no superar","Sindrome del guante purpura con fenitoina IV periferico: usar central"]}],noFarmacologico:["Dieta cetogenica en epilepsia refractaria pediatrica","Evitar desencadenantes: privacion de sueno, alcohol, estres","Estimulacion del nervio vago (VNS) en refractarios","Neurocirugia de epilepsia si foco resecable"],quirurgico:["Reseccion del foco epileptogeno (temporal, frontal)","Hemisferectomia funcional en epilepsias hemisfericas graves","Cuerpo calloso: callosotomia en crisis atonicas refractarias"]},cuidadosEnfermeria:{valoracion:["Caracteristicas de la crisis: inicio, duracion, tipo de movimientos, estado de conciencia","Estado post-ictal: Glasgow, orientacion, deficit focal","Signos de trauma durante la crisis","Frecuencia de crisis (diario de crisis)","Efectos adversos de la medicacion"],intervenciones:["DURANTE LA CRISIS: proteger cabeza, tiempo de duracion, no introducir objetos en boca, posicion lateral de seguridad post-crisis","NO sujetar los movimientos tonicos-clonicos (fracturas)","Administrar benzodiacepinas si crisis > 5 min segun protocolo de status","Oxigenoterapia post-crisis si cianosis","Vigilancia continua hasta recuperacion completa"],educacionPaciente:["Que hacer durante una crisis (posicion lateral, tiempo, cuando llamar al 911)","Importancia de tomar medicacion siempre a la misma hora","No suspender antiepil\xe9pticos abruptamente (riesgo de status)","Evitar desencadenantes: privacion de sueno, alcohol","Restricciones: no conducir hasta 6-12 meses sin crisis (segun ley)"],monitorizacion:["Frecuencia y tipo de crisis (diario)","Niveles de antiepil\xe9pticos","Efectos adversos: hepatotoxicidad (VPA), depresion (levetiracetam)","Estado post-ictal: Glasgow, deficit neurologico focal"]},npiNanda:[{codigo:"00155",nombre:"Riesgo de caidas",definicion:"Vulnerable a un aumento de la susceptibilidad a caidas que pueden causar da\xf1o fisico y comprometer la salud",caracteristicasDefinitorias:["Perdida de conciencia durante la crisis","Ataxia post-ictal"],factoresRelacionados:["Crisis epilepticas sin advertencia","Estado post-ictal con desorientacion","Efectos secundarios de antiepil\xe9pticos"]},{codigo:"00035",nombre:"Riesgo de lesion",definicion:"Vulnerable a sufrir da\xf1os como consecuencia de la interaccion de condiciones ambientales con los recursos adaptativos y defensivos del individuo",caracteristicasDefinitorias:["Movimientos tonico-clonicos incontrolados"],factoresRelacionados:["Crisis convulsivas","Entorno no adaptado"]}],npiNic:[{codigo:"2680",nombre:"Manejo de las convulsiones",actividades:["Posicion lateral de seguridad durante y post-crisis","Proteger la cabeza durante los movimientos","Cronometrar la duracion de la crisis","Administrar benzodiacepinas si status segun protocolo","Documentar caracteristicas de la crisis"]},{codigo:"6490",nombre:"Prevencion de caidas",actividades:["Barandillas levantadas en hospitalizado","Identificacion de riesgo de caidas","Colchon antidecubito en suelo si necesario","Pulsera de identificacion con 'epilepsia'"]}],npiNoc:[{codigo:"0909",nombre:"Estado neurologico",indicadores:["Frecuencia de crisis reducida","Post-ictal breve","Sin lesiones durante las crisis","Medicacion efectiva"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Status epilepticus (emergencia neurol\xf3gica, mortalidad 10-20%)","Dano cerebral por hipoxia en crisis prolongadas","Trauma craneal y fracturas durante crisis","Muerte subita en epilepsia (SUDEP)","Depresion y ansiedad","Efectos adversos de antiepil\xe9pticos a largo plazo"],criteriosAlarma:["Crisis > 5 minutos (riesgo de status epilepticus)","Crisis en cluster sin recuperacion entre ellas","Primera crisis tonico-clonica generalizada","Crisis seguida de deficit neurologico focal persistente","Crisis febril compleja en ni\xf1os"],emergencyLevel:"moderado",relatedPathologyIds:["pat_acv","pat_tce","pat_meningitis"],isPremium:!1},{id:"pat_meningitis",nombre:"Meningitis",bodySystemId:"neurologico",definicion:"Inflamacion de las meninges (membranas que recubren el cerebro y medula espinal) causada por microorganismos (bacterias, virus, hongos, parasitos), con posible compromiso del espacio subaracnoideo y liquido cefalorraquideo.",epidemiologia:"Incidencia de meningitis bacteriana: 1-3 casos/100.000 hab/ano. Mortalidad de la meningitis bacteriana: 10-30% con tratamiento; hasta 80% sin tratamiento. Neisseria meningitidis causa brotes epidemicos.",factoresRiesgo:["Edad extrema (neonatos y ancianos)","Inmunosupresion (VIH, asplenia)","Traumatismo craneoencefalico o cirugia neurol\xf3gica reciente","Otitis o sinusitis cronica","Fistula LCR","Contacto con caso de meningococo","No vacunado (neumococo, meningococo, Hib)"],fisiopatologia:"Los microorganismos alcanzan las meninges principalmente por via hematogena desde una bacteriemia (neumococo, meningococo) o por contig\xfcidad desde focos contiguos (otitis, sinusitis). La infeccion del espacio subaracnoideo desencadena una respuesta inflamatoria intensa con liberacion de citoquinas, produciendo edema cerebral, vasculitis, trombosis venosa e hidrocefalia. La hipertension intracraneal y la herniacion cerebral son las principales causas de muerte.",signosYSintomas:{signos:["Rigidez de nuca (signo cardinal)","Signo de Kernig positivo (no puede extender rodilla con cadera a 90\xb0)","Signo de Brudzinski (flexion de rodillas al flexionar el cuello)","Fiebre alta","Petequias y purpura (meningococcemia)","Fotofobia y fonofobia","Papiledema (HIC)"],sintomas:["Cefalea intensa de inicio relativamente rapido","Fiebre alta con escalofrios","Nauseas y vomitos","Fotofobia y fonofobia","Rigidez de nuca dolorosa","Confusi\xf3n o alteracion del nivel de conciencia","Convulsiones (complicacion)"]},clasificacion:{nombre:"Clasificacion por agente etiologico",tipos:[{nombre:"Meningitis bacteriana",descripcion:"Mas grave. Agentes: Neisseria meningitidis, S. pneumoniae, Listeria (ancianos e inmunosuprimidos). Alta mortalidad sin tratamiento rapido"},{nombre:"Meningitis viral (aseptica)",descripcion:"Causa mas frecuente. Enterovirus, herpes. Beninga en inmunocompetentes. Tratamiento de soporte"},{nombre:"Meningitis por hongos",descripcion:"Cryptococcus neoformans en VIH. Curso subagudo, alta mortalidad"},{nombre:"Meningitis tuberculosa",descripcion:"Curso subagudo/cronico. Alta mortalidad si no tratada. Paresia de pares craneales frecuente"}]},diagnostico:{anamnesis:["Inicio y evolucion de sintomas (horas = bacteriana, dias = viral/tubercular)","Fiebre, cefalea, rigidez de nuca: triada clasica","Exposicion a caso conocido","Estado de vacunacion","Inmunosupresion"],examenFisico:["Signos meningeos (Kernig, Brudzinski, rigidez de nuca)","Nivel de conciencia (Glasgow)","Buscar petequias y purpura (meningococcemia)","Papiledema (contraindicacion para PL si presente)"],pruebas:[{nombre:"Puncion lumbar con analisis de LCR",descripcion:"Estudio definitivo: citologia, bioquimica, cultivo, Gram del LCR. NO DEMORAR por encima de iniciar antibioticos si sospecha bacteriana",valoresReferencia:"LCR normal: glucosa 50-80, proteinas 15-45, leucocitos < 5. Bacteriana: glucosa baja, proteinas altas, PMN; viral: linfocitos predominantes",cuidadosEnfermeria:["Posicion correcta en decubito lateral o sentada","Mantener posicion estatica durante la puncion","Material esteril completo","Preparar tubos numerados en orden","Vigilar post-PL: cefalea postural, hematoma","Reposo horizontal 1-4h post-PL"]},{nombre:"Hemocultivos (2 pares) urgentes",descripcion:"Obtener ANTES de antibioticos; positivos en 50-80% de meningitis bacteriana",cuidadosEnfermeria:["Obtener INMEDIATAMENTE al ingreso, antes de antibioticos","No retrasar antibioticos mas de 30 min"]},{nombre:"TC craneal antes de PL",descripcion:"Descartar HIC y efecto de masa antes de PL (riesgo de herniacion)",cuidadosEnfermeria:["SOLO si nivel de conciencia reducido, papiledema, deficit focal o inmunosuprimido","No demorar antibioticos esperando TC en meningitis evidente sin HIC"]}]},tratamientoMedico:{objetivos:["Erradicacion del agente infeccioso con antibioticos URGENTES","Reducir inflamacion meningea con dexametasona","Control de complicaciones neurologicas"],farmacologico:[{nombre:"Ceftriaxona IV",grupo:"Cefalosporina 3a generacion - antibiotico empirico de primera linea",mecanismo:"Bactericida de amplio espectro, penetra la barrera hematoencefalica (BHE) inflamada",dosis:"2 g IV c/12h (4 g/dia)",cuidadosEnfermeria:["ADMINISTRAR EN < 30-60 MIN DEL INGRESO","Via venosa periferica o central","Infundir en 30 min","Primer dosis ANTES de esperar resultado de cultivos pero DESPUES de obtener hemocultivos y LCR si posible"]},{nombre:"Dexametasona IV",grupo:"Corticoide - antiinflamatorio",mecanismo:"Reduce la inflamacion meningea, disminuye edema y secuelas neurologicas (sordera en neumococo)",dosis:"0.15 mg/kg c/6h x 4 dias, ANTES o simultaneamente con primera dosis de antibiotico",cuidadosEnfermeria:["Administrar ANTES o junto a la primera dosis de antibiotico (maxima eficacia)","Monitorizar glucemia (puede elevarla)","Proteccion gastrica"]},{nombre:"Aciclovir IV",grupo:"Antiviral - si sospecha de encefalitis herpetica",mecanismo:"Inhibe la ADN polimerasa viral del HSV",dosis:"10 mg/kg IV c/8h x 14-21 dias",cuidadosEnfermeria:["Infundir en 1h (evitar precipitacion renal)","Hidratacion adecuada para prevenir nefrotoxicidad","Monitorizar funcion renal"]}],noFarmacologico:["Aislamiento respiratorio (gotas) para Neisseria meningitidis hasta 24h de antibioticos","Habitacion tranquila (fotofobia y fonofobia)","Control de hipertension intracraneal","Quimioprofilaxis a contactos con meningococo (rifampicina 600 mg c/12h x 2 dias)"],quirurgico:["Derivacion ventricular externa en hidrocefalia aguda","Desbridamiento en caso de empiema subdural"]},cuidadosEnfermeria:{valoracion:["Glasgow y signos neurologicos cada 1-2h","Signos meningeos en cada turno","Temperatura cada 2-4h (curva febril)","Fotofonofobia: valorar necesidad de habitacion oscura y silenciosa","Buscar petequias progresivas (meningococcemia)","Diuresis horaria (riesgo de SIADH)"],intervenciones:["AISLAMIENTO RESPIRATORIO por gotas hasta 24h de antibioticos (N. meningitidis)","Administrar antibioticos y dexametasona URGENTE (< 30-60 min del ingreso)","V\xeda venosa periferica de inmediato","Habitacion oscura y silenciosa para reducir estimulacion","Cabecera elevada 30\xb0","Hidratacion IV controlada (evitar SIADH)"],educacionPaciente:["Quimioprofilaxis para contactos familiares (rifampicina)","Vacunacion para convivientes no vacunados","Signos de alarma de complicaciones tras el alta"],monitorizacion:["Glasgow horario en fase aguda","Temperatura cada 2-4h","Petequias: medir y documentar extension","Ionograma (hiponatremia por SIADH)","Diuresis horaria","Signos de HIC: Triada de Cushing, midriasis, rigidez en descerebraci\xf3n"]},npiNanda:[{codigo:"00201",nombre:"Riesgo de perfusion tisular cerebral ineficaz",definicion:"Vulnerable a una disminucion en la circulacion tisular cerebral",caracteristicasDefinitorias:["Inflamacion meningea","Edema cerebral potencial"],factoresRelacionados:["Infeccion meningea","Vasculitis","Trombosis venosa cerebral"]},{codigo:"00007",nombre:"Hipertermia",definicion:"Temperatura corporal superior a la normal",caracteristicasDefinitorias:["Temperatura > 39\xb0C","Escalofrios","Taquicardia"],factoresRelacionados:["Proceso infeccioso del SNC"]}],npiNic:[{codigo:"2590",nombre:"Monitorizacion de la presion intracraneal",actividades:["Evaluar Glasgow horariamente","Vigilar signos de HIC: cefalea creciente, vomitos, midriasis","Mantener cabecera elevada 30\xb0","Evitar maniobras que aumenten PIC (valsalva, flexion cervical)"]},{codigo:"6540",nombre:"Control de infecciones",actividades:["Aislamiento respiratorio (N. meningitidis)","Administrar antibioticos urgentes","Quimioprofilaxis a contactos","Notificacion a salud publica"]}],npiNoc:[{codigo:"0909",nombre:"Estado neurologico",indicadores:["Glasgow estable o en mejoria","Temperatura < 38\xb0C","Signos meningeos negativos en evolucion favorable"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Herniacion cerebral (mortal)","Sordera (principal secuela en meningitis neumocococica)","Hidrocefalia","Deficit neurologico focal","Purpura fulminante y amputaciones (meningococcemia)","Convulsiones","Sindrome de secrecion inadecuada de ADH (SIADH)","Muerte (10-30%)"],criteriosAlarma:["Deterioro rapido del nivel de conciencia","Petequias que se extienden rapidamente (purpura fulminante)","Signos de herniacion cerebral: midriasis, rigidez, Cushing","Convulsiones refractarias","Sepsis con hipotension","Glasgow < 8"],emergencyLevel:"critico",relatedPathologyIds:["pat_acv","pat_epilepsia","pat_vih"],isPremium:!1},{id:"pat_parkinson",nombre:"Enfermedad de Parkinson",bodySystemId:"neurologico",definicion:"Enfermedad neurodegenerativa progresiva caracterizada por la perdida de neuronas dopaminergicas de la sustancia negra del mesencefalo y la presencia de cuerpos de Lewy (depositos de alfa-sinucleina), con manifestaciones motoras y no motoras.",epidemiologia:"Segunda enfermedad neurodegenerativa mas frecuente (tras el Alzheimer). Prevalencia del 0.3% de la poblacion general, aumentando al 3% en mayores de 80 a\xf1os. Inicio tipico a los 60 a\xf1os.",factoresRiesgo:["Edad avanzada (factor principal)","Sexo masculino (1.5x mayor)","Genetica: mutaciones LRRK2, PINK1, Parkin","Exposicion a pesticidas y herbicidas","Traumatismos craneoencefalicos repetidos","Residencia rural y consumo de agua de pozo"],fisiopatologia:"La perdida progresiva de neuronas dopaminergicas en la sustancia negra pars compacta reduce la dopamina estriatal, alterando el circuito de los ganglios basales. El circuito directo (facilitador del movimiento) se hipoactiva y el indirecto (inhibidor) se hipervalida, produciendo la bradicinesia y rigidez caracteristicas. La deficiencia de dopamina en el cuerpo estriado por debajo del 60-80% produce los sintomas clinicos. Los cuerpos de Lewy (alfa-sinucleina) se extienden desde el tronco hasta la corteza siguiendo la clasificacion de Braak.",signosYSintomas:{signos:["Temblor de reposo (signo cardinal, 4-6 Hz, 'rodar monedas')","Rigidez en rueda dentada o plastica (cogwheel)","Bradicinesia (lentitud de movimientos)","Inestabilidad postural (tard\xeda)","Marcha festinante (pasos cortos y rapidos)","Hipomimia (cara de mascara)","Micrografia","Sialorrea por disfagia"],sintomas:["Temblor que empieza unilateral en la mano","Lentitud para iniciar y realizar movimientos","Dificultad para caminar y equilibrio","Voz hipofonica (apagada)","Olfato disminuido (uno de los primeros sintomas)","Constipacion cronica (precede sintomas motores)","Depresion y ansiedad","Trastorno de conducta del sueno REM"]},clasificacion:{nombre:"Estadificacion de Hoehn & Yahr",tipos:[{nombre:"Estadio I",descripcion:"Sintomas unilaterales sin alteracion funcional"},{nombre:"Estadio II",descripcion:"Sintomas bilaterales sin inestabilidad postural"},{nombre:"Estadio III",descripcion:"Inicio de inestabilidad postural, funcionalmente independiente"},{nombre:"Estadio IV",descripcion:"Discapacidad severa, pero puede caminar o estar de pie sin ayuda"},{nombre:"Estadio V",descripcion:"En silla de ruedas o cama sin ayuda, cuidado constante"}]},diagnostico:{anamnesis:["Inicio unilateral de temblor, rigidez o bradicinesia","Evolucion progresiva","Respuesta a levodopa (diagnostico terapeutico)","Sintomas no motores: anosmia, constipacion, depresion, trastorno del sueno REM","Medicacion previa (metoclopramida puede causar parkinsonismo)"],examenFisico:["Temblor de reposo (cesa con movimiento intencional)","Rigidez a la movilizacion pasiva de extremidades","Bradicinesia: movimientos en espejo lentos y de amplitud decreciente","Marcha y postura","Pull test: inestabilidad postural"],pruebas:[{nombre:"DaTscan (DAT-SPECT)",descripcion:"Gammagrafia con FP-CIT que detecta la perdida de neuronas dopaminergicas presin\xe1pticas en estriado",cuidadosEnfermeria:["Informar al paciente sobre el procedimiento de medicina nuclear","Suspender medicacion que interfiere con DAT 5 dias antes","Proteger tiroides con ioduro potasico previo a la inyeccion del radiofarmaco"]},{nombre:"Escala UPDRS (Unified Parkinson's Disease Rating Scale)",descripcion:"Cuantifica la severidad y evolucion del Parkinson en aspectos motores y no motores",cuidadosEnfermeria:["Aplicar al ingreso y en cada visita para monitorizar progresion y respuesta al tratamiento"]}]},tratamientoMedico:{objetivos:["Controlar los sintomas motores y mejorar la calidad de vida","Prevenir complicaciones de la inmovilidad","Tratar sintomas no motores (depresion, demencia)"],farmacologico:[{nombre:"Levodopa + Carbidopa (Sinemet)",grupo:"Precursor de dopamina - farmaco mas eficaz en Parkinson",mecanismo:"La levodopa cruza la BHE y se convierte en dopamina en neuronas estriatales. La carbidopa inhibe la descarboxilacion periferica, reduciendo efectos adversos y aumentando la disponibilidad central",dosis:"Iniciar 100/25 mg c/8h, ajustar segun respuesta",cuidadosEnfermeria:["Administrar 30-60 min ANTES de las comidas (absorcion reducida por proteinas)","Nauseas frecuentes al inicio: puede tomar con galleta de sal","Vigilar hipotension ortost\xe1tica (riesgo de caidas)","Discinesias tardias: movimientos involuntarios por uso cronico","NUNCA suspender abruptamente (sindrome de hiperpirexia maligna)"]},{nombre:"Pramipexol / Ropinirol",grupo:"Agonista dopaminergico",mecanismo:"Activa directamente los receptores dopaminergicos D2/D3 en el estriado sin necesidad de conversion",dosis:"Pramipexol: iniciar 0.125 mg c/8h, escalar lentamente",cuidadosEnfermeria:["Somnolencia diurna excesiva: no conducir","Ataques de sueno subito: advertir al paciente","Trastornos de control de impulsos: juego compulsivo, hipersexualidad (informar a la familia)","Edemas perifericos","Alucinaciones en ancianos"]},{nombre:"Rasagilina / Selegilina",grupo:"Inhibidor MAO-B - neuroprotector y sinergico",mecanismo:"Inhibe la MAO-B que degrada la dopamina, aumentando su disponibilidad en la sinapsis",dosis:"Rasagilina 1 mg/dia en dosis unica",cuidadosEnfermeria:["Interaccion con serotonina: no combinar con ISRS/IRSN (sindrome serotoninergico)","Selegilina puede causar insomnio: dar en la ma\xf1ana"]}],noFarmacologico:["Fisioterapia especifica para Parkinson (LSVT Big para movimientos grandes)","Logopedia (LSVT Loud para hipofonia)","Terapia ocupacional para AVD","Ejercicio regular (tai chi, baile, marcha nordica)","Nutricion: dieta rica en fibra para constipacion"],quirurgico:["Estimulacion cerebral profunda (DBS) del nucleo subtalamico: para pacientes con respuesta a levodopa pero con fluctuaciones y discinesias"]},cuidadosEnfermeria:{valoracion:["Evaluar sintomas motores: temblor, rigidez, bradicinesia, marcha","Riesgo de caidas (Escala de Tinetti)","Estado nutricional y deglucion (disfagia frecuente)","Sintomas no motores: depresion, constipacion, dolor","Eficacia del tratamiento y fluctuaciones 'on-off'","Autonomia para AVD"],intervenciones:["Administrar levodopa a horarios EXACTOS (fluctuaciones 'on-off' graves si se retrasa)","Ejercicios de amplitud de movimiento y marcha","Adaptar el entorno: eliminar alfombras, instalar barandillas","Tecnicas de facilitacion para levantarse y girar en cama","Fisioterapia respiratoria (reduce riesgo de neumonia aspirativa)"],educacionPaciente:["Administrar levodopa 30-60 min antes de las comidas","Tecnicas de marcha y giro (pasos grandes, brazalete metronomo)","Estrategias para el bloqueo de la marcha (lineas en el suelo, musica)","Prevenir caidas en el hogar","Plan de emergencia si 'off' severo"],monitorizacion:["Frecuencia y duracion de 'on-off' con levodopa","Discinesias (aparicion durante pico de dosis)","Peso y estado nutricional mensual","Signos de neumonia aspirativa","Depresion (escala de Hamilton o GDS)","Caidas: registro en cada visita"]},npiNanda:[{codigo:"00085",nombre:"Deterioro de la movilidad fisica",definicion:"Limitacion del movimiento fisico independiente del cuerpo",caracteristicasDefinitorias:["Bradicinesia","Rigidez","Temblor","Marcha festinante"],factoresRelacionados:["Perdida de neuronas dopaminergicas","Alteracion del circuito de ganglios basales"]},{codigo:"00155",nombre:"Riesgo de caidas",definicion:"Vulnerable a un aumento de la susceptibilidad a caidas",caracteristicasDefinitorias:["Inestabilidad postural","Marcha festinante","Hipotension ortost\xe1tica"],factoresRelacionados:["Inestabilidad postural progresiva","Bradicinesia","Efectos adversos de medicacion"]}],npiNic:[{codigo:"0221",nombre:"Terapia de ejercicios: deambulacion",actividades:["Fisioterapia especifica para Parkinson","Tecnicas de marcha y manejo del bloqueo","Entrenamiento de equilibrio y coordinacion","Uso de dispositivos de ayuda a la marcha"]},{codigo:"2380",nombre:"Manejo de la medicacion",actividades:["Administrar levodopa en horarios EXACTOS","Vigilar fluctuaciones 'on-off' y discinesias","Coordinacion con neurologo para ajuste de dosis","Educar sobre no omitir dosis"]}],npiNoc:[{codigo:"0208",nombre:"Movimiento coordinado",indicadores:["Marcha mejorada","Temblor controlado","AVD realizadas con minima asistencia","Sin caidas"],escala:"1=Gravemente comprometido, 2=Sustancialmente, 3=Moderadamente, 4=Levemente, 5=No comprometido"}],complicaciones:["Neumonia aspirativa (principal causa de muerte)","Caidas y fracturas (cadera)","Demencia (Parkinson con demencia, 50% a los 10 a\xf1os)","Depresion severa","Discinesias tardias por levodopa","Disfagia y desnutricion","Sindrome de hiperpirexia maligna por supresion abrupta de levodopa"],criteriosAlarma:["Rigidez severa con fiebre alta (sindrome maligno de neurolepticos/hiperpirexia por omision de levodopa)","Caida con posible fractura","Disfagia con signos de aspiracion","Confusion aguda (descartar infeccion, toxicidad)","Bloqueos de marcha frecuentes con caidas repetidas"],emergencyLevel:"leve",relatedPathologyIds:["pat_alzheimer","pat_fractura_cadera"],isPremium:!0},{id:"pat_alzheimer",nombre:"Enfermedad de Alzheimer",bodySystemId:"neurologico",definicion:"Enfermedad neurodegenerativa progresiva e irreversible, causa mas frecuente de demencia (60-70%), caracterizada por deterioro cognitivo progresivo con perdida de memoria, lenguaje, razonamiento y capacidad funcional, por acumulacion de amiloide beta y proteina tau hiperfosforilada.",epidemiologia:"Afecta a 55 millones de personas en el mundo. Prevalencia del 10% en mayores de 65 a\xf1os, 30-40% en mayores de 85. Argentina tiene estimados 500.000 casos. Octava causa de muerte en adultos mayores.",factoresRiesgo:["Edad avanzada (factor principal)","Genotipo APOE4","Historia familiar de Alzheimer","Bajo nivel educativo","Diabetes mellitus tipo 2","Hipertension arterial","Obesidad y sedentarismo","Depresion (factor de riesgo y comorbilidad)","Traumatismo craneoencefalico"],fisiopatologia:"La enfermedad de Alzheimer se caracteriza por dos cambios neuropatologicos principales: las placas seniles de beta-amiloide extracelular (producto de procesamiento aberrante de la APP) y los ovillos neurofibrilares intraneuronales de proteina tau hiperfosforilada. Estos cambios producen sinaptopatia, perdida neuronal y atrofia cortical que comienza en el hipocampo (memoria) y se extiende progresivamente. La perdida colinergica del nucleo basal de Meynert contribuye al deficit de memoria.",signosYSintomas:{signos:["Atrofia hipocampal en RMN (diagnostico)","Reduccion del metabolismo temporo-parietal en PET","Afasia progresiva (busqueda de palabras)","Apraxia (incapacidad para realizar AVD secuenciales)","Agnosia","Desorientacion temporo-espacial","Cambios de personalidad"],sintomas:["Perdida de memoria reciente (primero)","Repeticion de preguntas y relatos","Perdida de objetos y acusaciones de robo","Desorientacion en lugares conocidos","Dificultad para manejar finanzas o conducir","Cambios de caracter: apatia, irritabilidad","En fases avanzadas: incontinencia, disfagia, mutismo"]},clasificacion:{nombre:"Estadios segun GDS (Global Deterioration Scale)",tipos:[{nombre:"GDS 1-2",descripcion:"Normal o olvidos subjetivos benignos. Sin deterioro funcional"},{nombre:"GDS 3",descripcion:"Defecto cognitivo leve. Dificultad laboral y social leve. Aun independiente"},{nombre:"GDS 4",descripcion:"Demencia leve. Dificultad para actividades instrumentales (finanzas, viajes)"},{nombre:"GDS 5",descripcion:"Demencia moderada. Necesita asistencia para elegir ropa y otras AVD"},{nombre:"GDS 6",descripcion:"Demencia moderada-grave. Incontinencia, asistencia para higiene"},{nombre:"GDS 7",descripcion:"Demencia grave. Perdida del lenguaje, incapacidad de caminar, total dependencia"}]},diagnostico:{anamnesis:["Historia del deterioro cognitivo: inicio, evolucion, areas afectadas","Cambios de personalidad y conducta","Impacto funcional en AVD","Historia familiar","Medicacion actual (anticolinergicos pueden empeorar)"],examenFisico:["MMSE (Mini-Mental State Exam) o MoCA","Examen neurologico completo","Evaluacion funcional (Barthel, Lawton)","Buscar signos de otras causas de demencia"],pruebas:[{nombre:"MMSE / MoCA",descripcion:"Test neuropsicologico breve. MMSE: 0-30, < 24 sugiere deterioro. MoCA mas sensible para deterioro leve",valoresReferencia:"MMSE: 24-30 normal, 18-23 deterioro leve, 10-17 moderado, < 10 grave",cuidadosEnfermeria:["Aplicar en ambiente tranquilo","Ajustar por nivel educativo","Aplicar siempre a la misma hora del dia"]},{nombre:"RMN cerebral",descripcion:"Detecta atrofia hipocampal y cortical, descarta causas tratables (hematoma, tumor, hidrocefalia)",cuidadosEnfermeria:["Verificar si el paciente puede colaborar o necesita sedacion leve","Acompanar al paciente con demencia durante el estudio"]}]},tratamientoMedico:{objetivos:["Enlentener el deterioro cognitivo","Manejar sintomas conductuales","Apoyar al cuidador principal","Mantener la maxima funcionalidad e independencia"],farmacologico:[{nombre:"Donepezilo",grupo:"Inhibidor de la acetilcolinesterasa (IACE) - primera linea",mecanismo:"Inhibe la degradacion de acetilcolina en la sinapsis, mejorando la transmision colinergica en la corteza",dosis:"5 mg/noche por 4-6 semanas, luego aumentar a 10 mg/noche",cuidadosEnfermeria:["Administrar por la noche (reduce nauseas y efectos colinergicos)","Nauseas, diarrea, insomnia como efectos adversos frecuentes","Bradicardia: medir FC antes de administrar","No descontinuar abruptamente (deterioro agudo de cognicion)"]},{nombre:"Memantina",grupo:"Antagonista del receptor NMDA - moderada/grave",mecanismo:"Bloquea receptores NMDA del glutamato reduciendo la excitotoxicidad, indicado en demencia moderada-grave",dosis:"5 mg/dia, escalar 5 mg/semana hasta 20 mg/dia",cuidadosEnfermeria:["Bien tolerada","Vigilar agitacion parad\xf3jica al inicio","Puede combinarse con donepezilo"]},{nombre:"Risperidona (dosis bajas)",grupo:"Antips\xedcotico at\xedpico - para sintomas conductuales severos",mecanismo:"Bloqueo de receptores D2 y 5HT2, reduce agitacion, alucinaciones y agresividad",dosis:"0.25-1 mg/dia en dosis bajas",cuidadosEnfermeria:["Usar solo si no hay respuesta a medidas no farmacologicas","Riesgo aumentado de ACV y muerte en demencia","Vigilar sedacion excesiva, caidas, extrapiramidalismo","Obtener consentimiento informado del familiar"]}],noFarmacologico:["Estimulacion cognitiva y reminiscencia","Actividad fisica adaptada","Musicoterapia","Ambiente estructurado y predecible","Apoyo al cuidador (grupos de apoyo, descanso del cuidador)"],quirurgico:[]},cuidadosEnfermeria:{valoracion:["MMSE o MoCA en cada internacion para comparar con linea de base","Evaluacion funcional: Barthel, Lawton","Sintomas conductuales y psicologicos de la demencia (SCPD)","Estado nutricional y deglucion","Riesgo de caidas y UPP","Evaluacion del cuidador: sobrecarga (Zarit)"],intervenciones:["Comunicacion simple y directa: frases cortas, una orden a la vez","Ambiente conocido y rutinas estructuradas","Orientacion a la realidad sin confrontacion","Prevenir deambulacion nocturna y fuga","Asistencia en AVD segun nivel de dependencia","Higiene y cuidado de la piel"],educacionPaciente:["Principalmente orientada al cuidador familiar","Tecnicas de comunicacion con el paciente con demencia","Manejo de conductas disruptivas","Recursos comunitarios y grupos de apoyo (Asociacion de Alzheimer)","Planificacion anticipada: decision por representante, instrucciones previas"],monitorizacion:["Cambios en cognicion o conducta desde la linea de base","Estado nutricional y peso mensual","Signos de infeccion (a menudo no tipicos: confusion aguda)","Caidas y lesiones","Efectos adversos de medicacion (donepezilo, memantina)"]},npiNanda:[{codigo:"00128",nombre:"Confusion cronica",definicion:"Deterioro irreversible, de larga evolucion o progresivo, del intelecto y la personalidad caracterizado por disminucion de la capacidad de interpretar los estimulos ambientales",caracteristicasDefinitorias:["Memoria disminuida","Desorientacion temporo-espacial","Incapacidad para recordar eventos recientes"],factoresRelacionados:["Enfermedad de Alzheimer","Perdida neuronal progresiva"]},{codigo:"00108",nombre:"Deficit de autocuidado: bano",definicion:"Deterioro de la capacidad para realizar o completar las actividades de bano/higiene de manera independiente",caracteristicasDefinitorias:["Incapacidad para llegar al cuarto de bano","Incapacidad para lavar el cuerpo"],factoresRelacionados:["Deterioro cognitivo","Incapacidad para secuenciar acciones"]}],npiNic:[{codigo:"4820",nombre:"Orientacion a la realidad",actividades:["Proporcionar calendarios y relojes grandes","Reorientar gentilmente sin confrontar","Ambiente con referencias conocidas (fotos, objetos)","Iluminacion adecuada para reducir confusion nocturna"]},{codigo:"5606",nombre:"Ensenanza: grupo de apoyo",actividades:["Derivar a grupos de apoyo para cuidadores","Informar sobre asociaciones de Alzheimer","Ense\xf1ar tecnicas de manejo de conductas disruptivas"]}],npiNoc:[{codigo:"0900",nombre:"Cognicion",indicadores:["MMSE estable","Orientacion temporal relativa mantenida","Reconocimiento de personas cercanas"],escala:"1=Gravemente comprometido, 2=Sustancialmente, 3=Moderadamente, 4=Levemente, 5=No comprometido"}],complicaciones:["Sindrome de conducta disruptiva (agitacion, agresividad, alucinaciones)","Neumonia aspirativa (principal causa de muerte)","Infecciones urinarias recurrentes","Desnutricion y deshidratacion","Ulceras por presion en fase avanzada","Deambulacion nocturna y caidas","Sobrecarga del cuidador"],criteriosAlarma:["Confusion aguda sobre la demencia (puede indicar infeccion, medicacion, ACV)","Disfagia severa con riesgo de aspiracion","Agitacion intensa con riesgo para el paciente o cuidadores","Signos de maltrato o abandono","Perdida de peso > 10% en un mes"],emergencyLevel:"leve",relatedPathologyIds:["pat_parkinson","pat_acv","pat_epilepsia"],isPremium:!0},{id:"pat_guillain_barre",nombre:"Sindrome de Guillain-Barre",bodySystemId:"neurologico",definicion:"Polineuropatia inflamatoria aguda autoinmune, caracterizada por paralisis ascendente rapida, arreflexia y posible compromiso respiratorio, desencadenada habitualmente por una infeccion previa que genera anticuerpos que atacan la mielina del sistema nervioso periferico.",epidemiologia:"Incidencia de 1-2 casos/100.000 hab/ano. Causa mas frecuente de paralisis flacida aguda en el mundo desarrollado. El 15-25% requiere ventilacion mecanica. Mortalidad del 5-10%.",factoresRiesgo:["Infeccion por Campylobacter jejuni (causa mas frecuente, 30-40%)","Infeccion por citomegalovirus","Virus de Epstein-Barr","Virus Zika","Vacunacion (muy raro, 1-2 casos/million dosis)"],fisiopatologia:"Una infeccion previa (tipicamente 2-4 semanas antes) genera anticuerpos que por mimetismo molecular atacan los gangliosidos de la mielina del nervio periferico. La desmielinizacion y la lesion axonal producen el bloqueo de la conduccion nerviosa motora, sensitiva y autonomica. La progresion ascendente desde los MMII hasta los nervios craneales y el nervio frenico puede comprometer la musculatura respiratoria.",signosYSintomas:{signos:["Debilidad muscular bilateral y simetrica ascendente","Hiporreflexia o arreflexia","Paralisis facial bilateral (50% de casos)","Disfuncion autonomica: taquicardia, labilidad de PA, arritmias","Paralisis ocular (variante Miller Fisher)","Proteinas elevadas en LCR con celulas normales (disociacion albumino-citologica)"],sintomas:["Parestesias en manos y pies (signo inicial)","Debilidad que asciende en dias/semanas","Dolor lumbar intenso frecuente","Disfagia y disfonia si nervios craneales afectos","Retencion urinaria (disfuncion autonomica)"]},clasificacion:{nombre:"Variantes clinicas",tipos:[{nombre:"AIDP",descripcion:"Polineuropatia inflamatoria desmielinizante aguda: forma mas frecuente en occidente"},{nombre:"AMAN",descripcion:"Neuropatia axonal motora aguda: frecuente en Asia, asociada a Campylobacter"},{nombre:"Sindrome de Miller Fisher",descripcion:"Triada: oftalmoplegia + ataxia + arreflexia. Anticuerpos anti-GQ1b"}]},diagnostico:{anamnesis:["Infeccion previa 2-4 semanas (diarrea, infeccion respiratoria)","Inicio de parestesias ascendentes","Velocidad de progresion (dias)"],examenFisico:["Fuerza muscular: 0-5 en MMSS y MMII (mayor debilidad distal)","Reflejos osteotendinosos ausentes o disminuidos","Sensibilidad: hipoestesia en guante y calcetin","Evaluar musculatura respiratoria: capacidad vital forzada","Nervios craneales"],pruebas:[{nombre:"Puncion lumbar y analisis de LCR",descripcion:"Disociacion albumino-citologica: proteinas altas (> 0.5 g/L) con celulas normales (< 10 cel/mL)",cuidadosEnfermeria:["Igual cuidados que en meningitis","En primeros 7 dias puede ser normal: repetir"]},{nombre:"Electromiografia y velocidad de conduccion nerviosa",descripcion:"Confirma neuropatia y tipo (desmielinizante vs axonal); orienta pronostico",cuidadosEnfermeria:["Proceso no doloroso pero inc\xf3modo","Puede realizarse en cama si paciente encamado"]},{nombre:"Capacidad vital forzada (FVC) seriada",descripcion:"Monitoriza la funcion respiratoria para decidir intubacion profilactica (regla 20/30/40)",valoresReferencia:"Regla 20-30-40: intubacion si FVC < 20 mL/kg o PEM < 30 cmH2O o PIM < 40 cmH2O",cuidadosEnfermeria:["Medir FVC cada 4-6h en fase de progresion","Avisar si reduccion rapida o < 20 mL/kg","Junto con evaluacion clinica de la musculatura bulbar"]}]},tratamientoMedico:{objetivos:["Detener la progresion con inmunoterapia","Soporte respiratorio si paralisis diafragmatica","Prevenir complicaciones de la inmovilizacion"],farmacologico:[{nombre:"Inmunoglobulina IV (IVIG)",grupo:"Inmunomodulador - primera linea de tratamiento especifico",mecanismo:"Modula la respuesta inmune y bloquea los anticuerpos patogenicos, reduciendo la desmielinizacion",dosis:"0.4 g/kg/dia IV x 5 dias (total 2 g/kg)",cuidadosEnfermeria:["Infundir lentamente e iniciar a baja velocidad (reacciones anafilacticas)","Premedicar con paracetamol y antihistaminico","Monitorizar PA, FC y temperatura durante infusion","Riesgo de trombosis: hidratacion adecuada","Deficiencia de IgA: contraindicada (riesgo de anafilaxia)"]},{nombre:"Heparina de bajo peso molecular",grupo:"Anticoagulante profilactico",mecanismo:"Previene TVP y TEP en paciente inmovilizado",dosis:"Enoxaparina 40 mg SC/dia",cuidadosEnfermeria:["Tecnica correcta de inyeccion SC","Vigilar sangrado","Junto con medias de compresion"]}],noFarmacologico:["Plasmaferesis: alternativa a IVIG, igual eficacia (5 sesiones en 2 semanas)","Monitorizacion respiratoria con FVC seriada","Intubacion profilactica si signos de fatiga respiratoria","Fisioterapia temprana para prevenir atrofia y contracturas","Soporte nutricional (SNG o parenteral si disfagia)"],quirurgico:[]},cuidadosEnfermeria:{valoracion:["Fuerza muscular en escala MRC cada 4-6h","Capacidad vital forzada cada 4-6h en progresion","Disfuncion autonomica: PA, FC, diuresis cada 2-4h","Dolor neuropatico: EVA","Deglucion y aspiracion","Riesgo de UPP (inmovilizacion)"],intervenciones:["Monitorizacion respiratoria urgente: preparar intubacion si FVC < 20 mL/kg","Cambios posturales cada 2h para prevenir UPP","Fisioterapia precoz para prevenir contracturas y atrofia","Cateter urinario si retencion","Administrar IVIG segun protocolo","Medias de compresion + HBPM profilactica"],educacionPaciente:["Explicar la naturaleza autolimitada del SGB (mayoria se recupera)","Proceso de rehabilitacion prolongado (semanas-meses)","Fatiga post-SGB puede persistir meses","Reconocer dificultad respiratoria y acudir urgente"],monitorizacion:["FVC cada 4-6h en progresion (CRITICO)","PA y FC continuos (disfuncion autonomica)","Signos vitales cada 2-4h","Fuerza muscular seriada","Signos de TVP o TEP"]},npiNanda:[{codigo:"00033",nombre:"Deterioro de la ventilacion espontanea",definicion:"Incapacidad para mantener ventilacion adecuada",caracteristicasDefinitorias:["Reduccion de FVC","Debilidad de musculos respiratorios","Fatiga"],factoresRelacionados:["Paralisis ascendente del nervio frenico","Desmielinizacion de nervios motores respiratorios"]},{codigo:"00085",nombre:"Deterioro de la movilidad fisica",definicion:"Limitacion del movimiento fisico independiente",caracteristicasDefinitorias:["Paralisis ascendente bilateral","Arreflexia","Incapacidad para movimiento voluntario"],factoresRelacionados:["Desmielinizacion del sistema nervioso periferico","Bloqueo de conduccion nerviosa"]}],npiNic:[{codigo:"3350",nombre:"Monitorizacion respiratoria",actividades:["Medir FVC seriada cada 4-6h","Monitorizar signos de fatiga respiratoria","Preparar equipo de intubacion","Aplicar regla 20-30-40 para intubacion"]},{codigo:"4266",nombre:"Administracion de inmunoglobulinas",actividades:["Administrar IVIG segun protocolo","Monitorizar signos de reaccion adversa","Controlar velocidad de infusion","Hidratacion adecuada"]}],npiNoc:[{codigo:"0403",nombre:"Estado respiratorio: ventilacion",indicadores:["FVC > 20 mL/kg","FR normal","SpO2 normal","Sin uso de musculos accesorios"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Insuficiencia respiratoria con necesidad de ventilacion mecanica (25%)","Muerte por fallo respiratorio o disfuncion autonomica","TVP y TEP (inmovilizacion)","Neumonia aspirativa (disfagia)","Dolor neuropatico cronico","Sindrome de fatiga cronica post-SGB"],criteriosAlarma:["FVC < 20 mL/kg o disminucion rapida de mas del 30%","Disfagia con signos de aspiracion","Labilidad autonomica severa (PA fluctuante, arritmias)","Debilidad de musculos respiratorios con disnea de reposo","Retension urinaria aguda"],emergencyLevel:"critico",relatedPathologyIds:["pat_ira","pat_tvp"],isPremium:!0},{id:"pat_ulcera_peptica",nombre:"Ulcera Peptica",bodySystemId:"digestivo",definicion:"Solucion de continuidad de la mucosa gastrointestinal que se extiende mas alla de la muscular de la mucosa, localizada principalmente en estomago o duodeno, causada por desequilibrio entre factores agresivos (acido, pepsina, H. pylori) y protectores (moco, bicarbonato, prostaglandinas).",epidemiologia:"Prevalencia de 5-10% en paises occidentales. Incidencia de 0.1-0.3% por ano. Helicobacter pylori es responsable del 70-85% de ulceras gastroduodenales.",factoresRiesgo:["Infeccion por H. pylori (principal causa)","Uso de AINEs y aspirina","Tabaquismo","Alcohol","Estres fisiologico (grandes quemaduras, TCE, sepsis)","Cirrosis hepatica","EPOC","Sindrome de Zollinger-Ellison (gastrinoma)"],fisiopatologia:"H. pylori coloniza la mucosa gastrica, produciendo inflamacion cronica que altera los mecanismos de defensa mucosa (reduce moco y bicarbonato) y aumenta la secrecion acida (gastrina). Los AINEs inhiben la COX-1, reduciendo la sintesis de prostaglandinas protectoras que estimulan el moco y el bicarbonato y mantienen el flujo sanguineo mucoso. El desequilibrio resultante entre los factores agresivos y protectores permite que el acido erosione la mucosa hasta la submucosa, formando la ulcera.",signosYSintomas:{signos:["Signo de succusion gastrica (obstruccion pil\xf3rica)","Abdomen en tabla (perforacion)","Hematemesis o melena (hemorragia)","Sensibilidad epigastrica a la palpacion"],sintomas:["Dolor epigastrico tipo ardor o quemaz\xf3n","Ulcera duodenal: dolor 2-4h post-ingesta, alivio con comida (hambre dolorosa)","Ulcera gastrica: dolor que puede empeorar con la ingesta","Nauseas y vomitos","Pirosis","Puede ser silente (ancians, AINEs)"]},clasificacion:{nombre:"Clasificacion de Johnson (ulcera gastrica) y por localizacion",tipos:[{nombre:"Ulcera duodenal",descripcion:"70-80% de los casos. Bulbo duodenal. H. pylori 90%"},{nombre:"Ulcera gastrica tipo I",descripcion:"Curvatura menor, incisura angularis. Baja secrecion acida. H. pylori frecuente"},{nombre:"Ulcera gastrica tipo II",descripcion:"Gastrica + duodenal asociada. Hipersecrecion acida"},{nombre:"Ulcera gastrica tipo III",descripcion:"Prepil\xf3rica. Similar a duodenal en patogenia"},{nombre:"Ulcera por AINEs",descripcion:"Cualquier localizacion. Frecuentemente silente hasta hemorragia"}]},diagnostico:{anamnesis:["Caracteristicas del dolor: horario, relacion con comidas","Uso de AINEs, aspirina, corticoides","Historia de H. pylori o tratamiento previo","Consumo de alcohol y tabaco","Hematemesis o melena previa"],examenFisico:["Sensibilidad epigastrica","Buscar signos de complicaciones: abdomen en tabla, hipovolemia"],pruebas:[{nombre:"Endoscopia digestiva alta (EDA)",descripcion:"Estudio de eleccion: visualiza la ulcera, toma biopsia para H. pylori y descarta malignidad",cuidadosEnfermeria:["Ayuno de 8h","Retirar protesis dentales","Acceso venoso para sedacion","Vigilar signos vitales durante la sedacion","Post-procedimiento: nada VO hasta recuperar el reflejo nauseoso"]},{nombre:"Test del aliento con urea-C13",descripcion:"Detecta H. pylori activo con alta sensibilidad y especificidad (> 95%). Indica tratamiento y confirma erradicacion",valoresReferencia:"Positivo: H. pylori activo. Negativo: sin H. pylori activo",cuidadosEnfermeria:["Suspender IBPs 2 semanas antes","Suspender antibioticos 4 semanas antes","Ayuno de 4h previo","El paciente exhala en tubos antes y 30 min despues de tomar la capsula marcada"]}]},tratamientoMedico:{objetivos:["Aliviar el dolor","Cicatrizar la ulcera","Erradicar H. pylori","Prevenir recidivas y complicaciones"],farmacologico:[{nombre:"Omeprazol / Pantoprazol (IBP)",grupo:"Inhibidor de la bomba de protones",mecanismo:"Inhibe irreversiblemente la bomba H+/K+-ATPasa en las celulas parietales, reduciendo la secrecion acida",dosis:"Omeprazol 20-40 mg/dia, 30 min antes del desayuno",cuidadosEnfermeria:["Administrar ANTES de las comidas (no despues)","Uso prolongado: vigilar hipomagnesemia, deficit de B12, osteoporosis","No triturar capsulas de liberacion retardada (usar granulos del interior)"]},{nombre:"Amoxicilina + Claritromicina + Omeprazol (triple terapia)",grupo:"Antibioticos + IBP - erradicacion H. pylori",mecanismo:"Eliminacion de H. pylori para curar y prevenir recidiva de la ulcera",dosis:"Omeprazol 20 mg + Amoxicilina 1 g + Claritromicina 500 mg, todo c/12h x 14 dias",cuidadosEnfermeria:["Enfatizar cumplimiento completo de los 14 dias","Tomar todas las pastillas juntas en cada toma","Interaccion de claritromicina con muchos medicamentos","Verificar alergia a penicilina (alternativa: Metronidazol)"]},{nombre:"Sucralfato",grupo:"Protector de mucosa gastrica",mecanismo:"Forma una barrera protectora sobre la ulcera, estimula la produccion de moco y prostaglandinas",dosis:"1 g c/6h en ayunas, 1h antes de las comidas",cuidadosEnfermeria:["Tomar en AYUNAS estricto","No administrar junto a IBPs (inactiva el sucralfato)","Constipacion frecuente como efecto adverso","Reduccion de absorcion de otros medicamentos: separar 2h"]}],noFarmacologico:["Suspension de AINEs si es posible; si no: usar COX-2 selectivos + IBP","Cese del tabaquismo","Evitar alcohol","No tomar AINEs con estomago vacio"],quirurgico:["Cirugia urgente en perforacion (sutura de perforacion)","Cirugia en hemorragia masiva refractaria a endoscopia","Vagotomia + piloroplastia (en desuso con IBPs)"]},cuidadosEnfermeria:{valoracion:["Caracteristicas del dolor epigastrico","Signos de complicaciones: hematemesis, melena, abdomen en tabla","Uso de AINEs u otros gastroprotectores","Historia de H. pylori"],intervenciones:["Administrar IBPs segun protocolo","Ayuno si sospecha de complicacion hemorragica o cirugia urgente","Asegurar acceso venoso","Administrar tratamiento de erradicacion de H. pylori correctamente"],educacionPaciente:["Tomar IBPs antes de las comidas","Cumplimiento completo de los antibioticos para H. pylori","Evitar AINEs o tomarlos siempre con IBP","Cese del tabaco y alcohol","Reconocer signos de hemorragia: vomitos con sangre, heces negras alquitranadas"],monitorizacion:["Control endoscopico a las 6-8 semanas (ulcera gastrica para descartar malignidad)","Test del aliento 4 semanas post-tratamiento para confirmar erradicacion","Signos de hemorragia o perforacion en hospitalizados"]},npiNanda:[{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable por lesion tisular real",caracteristicasDefinitorias:["Dolor epigastrico","Expresion facial de dolor","Cambios en apetito"],factoresRelacionados:["Erosion de la mucosa gastrica","Irritacion quimica por acido peptico"]}],npiNic:[{codigo:"1080",nombre:"Manejo de la eliminacion gastrointestinal",actividades:["Administrar IBPs segun protocolo","Monitorizar signos de hemorragia","Indicar dieta adecuada"]},{codigo:"2380",nombre:"Manejo de la medicacion",actividades:["Ense\xf1ar administracion correcta de IBPs (antes de comer)","Enfatizar cumplimiento de antibioticos para H. pylori"]}],npiNoc:[{codigo:"1605",nombre:"Control del dolor",indicadores:["Dolor referido 0-2/10","Sin necesidad de analgesicos de rescate frecuentes"],escala:"1=Nunca demostrado, 2=Raramente, 3=A veces, 4=Frecuentemente, 5=Siempre demostrado"}],complicaciones:["Hemorragia digestiva alta (mas frecuente)","Perforacion (peritonitis)","Penetracion a pancreas (dolor dorsal irradiado)","Obstruccion pil\xf3rica (vomitos post-prandiales)","Malignizacion (ulcera gastrica)"],criteriosAlarma:["Hematemesis o melena","Dolor abdominal subito intenso (perforacion)","Hipotension y taquicardia (hemorragia)"],emergencyLevel:"leve",relatedPathologyIds:["pat_hemorragia_digestiva","pat_cirrosis"],isPremium:!1},{id:"pat_cirrosis",nombre:"Cirrosis Hepatica",bodySystemId:"digestivo",definicion:"Estadio final de las hepatopatias cronicas caracterizado por fibrosis difusa del par\xe9nquima hepatico con formacion de nodulos de regeneracion, que produce disfuncion hepatica e hipertension portal, con multiples complicaciones sistemicas.",epidemiologia:"Prevalencia de 0.3% en la poblacion general de paises desarrollados. Principal causa: alcohol (30-40%) y virus hepatitis C (25%) en Argentina. Mortalidad elevada en estadios avanzados (30-50% a 5 a\xf1os en Child-Pugh C).",factoresRiesgo:["Alcoholismo cronico","Hepatitis viral cronica (VHC 25%, VHB 10%)","Esteatohepatitis no alcoholica (EHNA) - por obesidad y diabetes","Enfermedades autoinmunes hepaticas","Colestasis cronica (CBP, CEP)","Hemocromatosis, Wilson","Medicamentos hepatotoxicos"],fisiopatologia:"La lesion hepatica cronica activa las celulas estrelladas hepaticas (celulas de Ito), que se transforman en miofibroblastos productores de col\xe1geno. La fibrosis progresiva destruye la arquitectura hepatica normal, formando bands fibrosas que conectan los espacios porta entre si y con las venas centrales. Los nodulos de regeneracion comprimen los sinusoides, aumentando la resistencia al flujo portal (hipertension portal). La disfuncion hepatocelular reduce la sintesis proteica (albumina, factores de coagulacion), la depuracion de toxinas (encefalopatia) y el metabolismo de hormonas y farmacos.",signosYSintomas:{signos:["Ictericia y coluria","Eritema palmar y aranas vasculares","Ginecomastia e hipogonadismo (hombre)","Ascitis (distension abdominal)","Esplenomegalia","Circulacion colateral abdominal (caput medusae)","Encefalopatia: flapping tremor (asterixis)","Edemas bilaterales"],sintomas:["Fatiga y astenia intensa","Perdida de peso y masa muscular","Prurito (colestasis)","Confusion y desorientacion (encefalopatia)","Disnea (hidrotorax hepatico)","Dolor abdominal (hepatomegalia, peritonitis bacteriana)"]},clasificacion:{nombre:"Clasificacion de Child-Pugh",tipos:[{nombre:"Child-Pugh A (5-6 puntos)",descripcion:"Cirrosis compensada. Supervivencia a 1 ano > 95%"},{nombre:"Child-Pugh B (7-9 puntos)",descripcion:"Cirrosis con deterioro funcional moderado. Supervivencia a 1 ano ~80%"},{nombre:"Child-Pugh C (10-15 puntos)",descripcion:"Cirrosis descompensada. Supervivencia a 1 ano ~45%. Candidato a trasplante"}]},diagnostico:{anamnesis:["Consumo de alcohol (cantidad y duracion)","Historia de hepatitis viral","Medicacion hepatotoxica","Historia familiar de hepatopatia","Sintomas de descompensacion"],examenFisico:["Signos de hepatopatia cronica","Ascitis: matidez en flancos, ola ascitica","Encefalopatia: asterixis, confusion, Glasgow"],pruebas:[{nombre:"Perfil hepatico completo",descripcion:"Bilirrubina, transaminasas (ALT, AST), fosfatasa alcalina, GGT, albumina, tiempo de protrombina",valoresReferencia:"ALT/AST < 40 UI/L normal; Albumina < 3.5 g/dL = disfuncion; TP prolongado = coagulopatia",cuidadosEnfermeria:["Extraer en ayunas","Registrar en conjunto con manifestaciones clinicas para estadificacion"]},{nombre:"Ecografia abdominal con Doppler",descripcion:"Evalua tamano y ecogenicidad hepatica, ascitis, esplenomegalia, flujo portal, signos de carcinoma hepatocelular",cuidadosEnfermeria:["Ayuno de 4-6h","No requiere preparacion especial","Vigilancia seriada cada 6 meses para screening de CHC"]},{nombre:"MELD score",descripcion:"Modelo predictivo de mortalidad en hepatopatia terminal: 3.78 x loge(bilirrubina) + 11.2 x loge(INR) + 9.57 x loge(creatinina) + 6.43",valoresReferencia:"MELD > 15: considerar trasplante; MELD > 25: alta mortalidad sin trasplante",cuidadosEnfermeria:["Calcular en cada hospitalizacion para evaluar urgencia de trasplante"]}]},tratamientoMedico:{objetivos:["Tratar la causa subyacente","Prevenir y tratar complicaciones","Preparacion para trasplante hepatico si indicado"],farmacologico:[{nombre:"Espironolactona + Furosemida",grupo:"Diureticos - tratamiento de ascitis",mecanismo:"Espironolactona bloquea aldosterona (excess en cirrosis); furosemida aumenta la diuresis",dosis:"Espironolactona 100-400 mg/dia + Furosemida 40-160 mg/dia; relacion 100:40",cuidadosEnfermeria:["Peso diario (objetivo: perdida de 500 g/dia en ascitis sola o 1 kg/dia con edema)","Electrolitos cada 3-5 dias inicialmente (hipo/hiperpotasemia)","No perder mas de 1 kg/dia (precipita encefalopatia y sindrome hepatorrenal)","Balance hidrico diario"]},{nombre:"Propranolol / Carvedilol",grupo:"Betabloqueante no selectivo - profilaxis de hemorragia variceal",mecanismo:"Reduce el flujo esplacnico y la presion portal, disminuyendo el riesgo de hemorragia por varices esofagicas",dosis:"Propranolol 40-160 mg/dia; Carvedilol 6.25-12.5 mg/dia",cuidadosEnfermeria:["Medir FC y PA antes de administrar","Objetivo: FC 55-60 lpm o reduccion del 25%","Contraindicado: PA < 90 mmHg, broncoespasmo, bloqueo AV"]},{nombre:"Rifaximina + Lactulosa",grupo:"Antibiotico intestinal + laxante osmotico - encefalopatia hepatica",mecanismo:"Rifaximina reduce bacterias intestinales productoras de amoniaco; Lactulosa reduce absorcion de amoniaco por acidificar el colon",dosis:"Rifaximina 550 mg c/12h; Lactulosa 15-30 mL c/8-12h (objetivo 2-3 deposiciones blandas/dia)",cuidadosEnfermeria:["Evaluar numero y consistencia de deposiciones con lactulosa","No dar en exceso (acidosis lactica por diarrea severa)","Explicar al cuidador sobre la encefalopatia"]},{nombre:"Ceftriaxona / Norfloxacino",grupo:"Antibiotico - profilaxis y tratamiento de peritonitis bacteriana espontanea (PBE)",mecanismo:"Elimina microorganismos responsables de la PBE (E. coli, Klebsiella)",dosis:"PBE: Ceftriaxona 2 g/dia IV x 5 dias. Profilaxis: Norfloxacino 400 mg/dia VO",cuidadosEnfermeria:["Paracentesis diagnostica ante ascitis nueva o deterioro clinico","LCR asc\xedtico: PMN > 250 cel/mL diagnostica PBE","Albumina IV junto a antibiotico (1.5 g/kg dia 1, 1 g/kg dia 3) para prevenir sindrome hepatorrenal"]}],noFarmacologico:["Abstinencia de alcohol ABSOLUTA (unico tratamiento que puede estabilizar la cirrosis alcoholica)","Dieta hipoproteica moderada NO necesaria (salvo encefalopatia activa)","Restriccion de sodio < 2 g/dia en ascitis","Paracentesis terapeutica en ascitis a tension","Banda elastica de varices esofagicas endoscopica"],quirurgico:["TIPS (shunt portosistemico intrahep\xe1tico transyugular) en ascitis refractaria o HDA variceal","Trasplante hepatico en cirrosis descompensada (MELD > 15)"]},cuidadosEnfermeria:{valoracion:["Peso y perimetro abdominal diariamente (ascitis)","Evaluar signos de encefalopatia: asterixis, confusion, Glasgow","Valorar ictericia y coloracion de orina y heces","Signos de sangrado: hematemesis, melena, hematomas","Balance hidrico estricto","Escala de Child-Pugh y MELD"],intervenciones:["Administrar diureticos y controlar respuesta","Posicion adecuada para aliviar dispnea si ascitis voluminosa","Cuidados de piel en ictericia (prurito: antihistaminicos, cuidados topicos)","Cuidado de acceso venoso","Asegurar cumplimiento de abstinencia de alcohol"],educacionPaciente:["Abstinencia absoluta de alcohol y sus beneficios demostrados","Restriccion de sal (alimentos con alto sodio)","Vigilar signos de encefalopatia: confusion, conducta inusual","Reconocer hemorragia digestiva","Importancia del seguimiento para screening de CHC cada 6 meses"],monitorizacion:["Peso y perimetro abdominal diarios","Electrolitos, funcion renal y hepatica frecuentes","INR periodico","Buscar PBE ante fiebre sin foco","Ecografia cada 6 meses para CHC","Child-Pugh y MELD en cada hospitalizacion"]},npiNanda:[{codigo:"00025",nombre:"Exceso de volumen de liquidos",definicion:"Aumento de la retencion de liquidos isotonicos",caracteristicasDefinitorias:["Ascitis","Edema bilateral","Aumento de peso"],factoresRelacionados:["Hipertension portal","Hipoalbuminemia","Hiperaldosteronismo secundario"]},{codigo:"00178",nombre:"Gestion de la salud ineficaz",definicion:"Patron de regulacion e integracion en la vida diaria del regimen terapeutico inadecuado",caracteristicasDefinitorias:["Consumo continuado de alcohol","No adherencia a dieta hiposodica"],factoresRelacionados:["Dependencia alcoh\xf3lica","Negacion de la enfermedad"]}],npiNic:[{codigo:"0480",nombre:"Manejo del liquido/electroliticos",actividades:["Pesar al paciente diariamente","Controlar balance hidrico","Administrar diureticos y monitorizar respuesta","Electrolitos seriados","Preparar para paracentesis si necesario"]},{codigo:"6040",nombre:"Manejo de la encefalopatia hepatica",actividades:["Evaluar asterixis y nivel de conciencia cada turno","Administrar lactulosa y rifaximina","Identificar y tratar factor precipitante","Restriccion proteica temporal si encefalopatia activa"]}],npiNoc:[{codigo:"0601",nombre:"Equilibrio hidrico",indicadores:["Peso estable","Ascitis reducida o controlada","Sin edemas severos","Electrolitos normales"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Hemorragia por varices esofagicas (40% mortalidad)","Peritonitis bacteriana espontanea (30% mortalidad)","Encefalopatia hepatica","Sindrome hepatorrenal","Carcinoma hepatocelular (1-5%/ano)","Coagulopatia y sangrado","Hidrotorax hepatico"],criteriosAlarma:["Hematemesis o melena (varices esofagicas)","Fiebre con ascitis (PBE)","Confusion o desorientacion progresiva (encefalopatia)","Diuresis < 500 mL/dia con ascitis (sindrome hepatorrenal)","Ictericia de rapido empeoramiento"],emergencyLevel:"moderado",relatedPathologyIds:["pat_hemorragia_digestiva","pat_ulcera_peptica"],isPremium:!1},{id:"pat_pancreatitis",nombre:"Pancreatitis Aguda",bodySystemId:"digestivo",definicion:"Inflamacion aguda del pancreas por autodigestion producida por activacion prematura de enzimas pancreatticas dentro del organo, que produce desde edema intersticial leve hasta necrosis pancreatica severa con fallo multiorganico.",epidemiologia:"Incidencia de 13-45 casos/100.000 hab/ano. Principal causa de hospitalizacion por patologia gastrointestinal. La mayoria (80%) son leves con recuperacion completa; el 15-20% son severas con mortalidad del 20-40%.",factoresRiesgo:["Colelitiasis (50-70% de casos)","Consumo excesivo de alcohol (25-35%)","Hipertrigliceridemia (TG > 1000 mg/dL)","Medicamentos: azatioprina, estr\xf3genos, diur\xe9ticos tiaz\xeddicos","CPRE (post-procedimiento 5%)","Traumatismo abdominal","Infecciones virales (parotiditis)"],fisiopatologia:"Independientemente de la causa, el mecanismo comun es la activacion prematura del tripsinogeno a tripsina dentro del pancreas (normalmente ocurre en el duodeno). La tripsina activa otras proenzimas en cascada (fosfolipasa A2, elastasa), produciendo autodigestion del par\xe9nquima pancre\xe1tico. La fosfolipasa A2 destruye las membranas celulares; la elastasa erosiona los vasos. La liberacion de enzimas y citoquinas inflamatorias produce respuesta inflamatoria local (edema, necrosis) y sistemica (SRIS, fallo multiorganico).",signosYSintomas:{signos:["Signo de Grey-Turner (equimosis en flancos, hemorragia retroperitoneal)","Signo de Cullen (equimosis periumbilical, hemorragia severa)","Fiebre","Taquicardia e hipotension en formas severas","Distension abdominal por ileo paralitico","Ictericia si obstruccion biliar (origen biliar)"],sintomas:["Dolor abdominal epigastrico severo de inicio brusco","Irradiacion en cinturon hacia el dorso","Nauseas y vomitos persistentes","Alivio parcial en posicion fetal","Anorexia"]},clasificacion:{nombre:"Clasificacion de Atlanta 2012",tipos:[{nombre:"Pancreatitis leve",descripcion:"Sin necrosis, sin fallo organico, resolucion en 3-7 dias. Mortalidad < 1%"},{nombre:"Pancreatitis moderada",descripcion:"Fallo organico transitorio (< 48h) o complicaciones locales sin necrosis"},{nombre:"Pancreatitis severa",descripcion:"Fallo organico persistente > 48h (FALLA respiratoria, renal, cardiovascular). Mortalidad 20-40%"}]},diagnostico:{anamnesis:["Inicio y caracteristicas del dolor abdominal","Historia de colelitiasis o ingesta alcoholica","Medicacion previa","Episodios previos"],examenFisico:["Distension abdominal, rigidez epigastrica","Buscar signos de Grey-Turner y Cullen (hemorragia)","Ictericia (origen biliar)","Signos de fallo multiorganico"],pruebas:[{nombre:"Amilasa y lipasa sericas",descripcion:"Amilasa: se eleva a las 2-12h, normaliza en 3-5 dias (poco especifica). Lipasa: mas especifica y persiste mas tiempo (mejor marcador)",valoresReferencia:"Pancreatitis si > 3x el limite superior de la normalidad. Lipasa normal < 60 UI/L",cuidadosEnfermeria:["Muestra venosa estandar","La magnitud de elevacion NO correlaciona con severidad"]},{nombre:"TAC abdominal con contraste (CECT)",descripcion:"Standard de oro para estadificar gravedad, detectar necrosis y complicaciones. Indicado si gravedad incierta o deterioro a las 48-72h",valoresReferencia:"Indice de severidad TC (CTSI): suma de grado de inflamacion (0-4) + necrosis (0-6). CTSI > 6 = severa",cuidadosEnfermeria:["Ayuno","Verificar creatinina antes del contraste","Hidratacion pre y post-contraste"]},{nombre:"Score de Ranson (al ingreso y 48h)",descripcion:"Predice severidad con 11 criterios clinicos y laboratorio",valoresReferencia:"< 3 criterios = leve; 3-5 = moderada; > 5 = grave (mortalidad > 40%)",cuidadosEnfermeria:["Calcular al ingreso y a las 48h","Documentar para escalada del nivel de cuidados si necesario"]}]},tratamientoMedico:{objetivos:["Reposo pancre\xe1tico y ayuno inicial","Resucitacion con fluidos IV agresiva","Control del dolor","Prevenir y tratar complicaciones"],farmacologico:[{nombre:"Solucion de Ringer Lactato",grupo:"Cristaloide IV - resucitacion hidroelectrolitica",mecanismo:"Repone el volumen intravascular perdido por edema retroperitoneal y terceros espacios",dosis:"250-500 mL/h inicialmente; ajustar segun respuesta (diuresis, FC, PA)",cuidadosEnfermeria:["Resucitacion agresiva en primeras 24-48h (evidencia: Ringer Lactato mejor que SF 0.9%)","Monitorizar diuresis > 0.5 mL/kg/h","Balance hidrico estricto","Vigilar sobrecarga de liquidos en pancreatitis severa (edema pulmonar)"]},{nombre:"Morfina / Ketamina IV",grupo:"Analgesicos - control del dolor severo",mecanismo:"Morfina: agonista opiode. Ketamina: antagonista NMDA con efecto analgesico y menor efecto en esfinter de Oddi",dosis:"Morfina: 2-4 mg IV cada 4-6h; Ketamina: 0.1-0.3 mg/kg IV",cuidadosEnfermeria:["El miedo al opiode (espasmo de Oddi) no es clinicamente relevante en dosis analgesicas","Monitorizar FR y SpO2","Tramadol como alternativa de menor potencia"]},{nombre:"Ceftriaxona + Metronidazol (antibioticos)",grupo:"Antibioticoterapia - solo en necrosis infectada o sepsis",mecanismo:"NO deben usarse profilacticamente. Solo indicados en necrosis pancreatica infectada (aislamientos polimicrobianos)",dosis:"Ceftriaxona 2 g IV + Metronidazol 500 mg IV c/8h",cuidadosEnfermeria:["NO administrar antibioticos profilacticamente (no reduce complicaciones infecciosas)","Indicar solo ante signos de infeccion: fiebre persistente > 7-10 dias, deterioro"]}],noFarmacologico:["Ayuno en las primeras 24-48h (reducir la estimulacion pancreatica)","Nutricion enteral precoz (si > 5 dias de ayuno: SNG postpil\xf3rica es preferible a parenteral)","Manejo del dolor multimodal","Endoscopia urgente (CPRE) si coledocolitiasis con colangitis o ictericia obstructiva"],quirurgico:["Necrosectomia (percutanea, endosc\xf3pica o quirurgica) en necrosis infectada","Colecistectomia diferida en pancreatitis biliar leve (previene recurrencias)"]},cuidadosEnfermeria:{valoracion:["Dolor: EVA cada 4h, caracteristicas","Balance hidrico horario y diuresis","PA, FC, FR, temperatura cada 2-4h","Buscar signos de Grey-Turner o Cullen (severidad)","Evaluar signos de fallo organico: diuresis, SpO2, PA","Nauseas y vomitos"],intervenciones:["Ayuno con cuidados de boca frecuentes","Resucitacion hidroelectrolitica IV agresiva","Dos accesos venosos perifericos","Control del dolor con analgesicos IV segun escala","Sonda nasogastrica si vomitos incoercibles","Elevar cabecera 30-45\xb0 para comodidad"],educacionPaciente:["Abstinencia de alcohol si causa alcoholica","Tras recuperacion: colecistectomia si causa biliar (previene recurrencia 50%)","Dieta baja en grasas progresivamente","Signos de recidiva: mismo tipo de dolor epigastrico"],monitorizacion:["Diuresis horaria","PA y FC cada 2-4h","Balance hidrico cada 8h","Amilasa y lipasa seriadas","Funcion renal, electrolitos, glucemia diarios","Signos de complicaciones: fiebre, deterioro clinico"]},npiNanda:[{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable por lesion tisular",caracteristicasDefinitorias:["Dolor epigastrico severo 8-10/10","Posicion antalgica fetal","Diaforesis"],factoresRelacionados:["Inflamacion y autodigestion pancreatica","Liberacion de enzimas proteoliticas"]},{codigo:"00002",nombre:"Desequilibrio nutricional: ingestion inferior a las necesidades",definicion:"Ingestion de nutrientes insuficiente para satisfacer las necesidades metabolicas",caracteristicasDefinitorias:["Ayuno obligado","Nauseas y vomitos","Perdida de peso"],factoresRelacionados:["Ayuno terapeutico","Intolerancia a la via oral","Aumento del catabolismo"]}],npiNic:[{codigo:"1100",nombre:"Manejo de la nutricion",actividades:["Mantener ayuno y sonda nasogastrica si indicado","Iniciar nutricion enteral precoz si > 5 dias","Evaluar progresion de la via oral segun tolerancia","Registrar balance nutricional"]},{codigo:"4130",nombre:"Monitorizacion de liquidos",actividades:["Balance hidrico horario","Peso diario","Monitorizar signos de sobrecarga o hipovolemia","Administrar fluidos segun indicacion"]}],npiNoc:[{codigo:"1605",nombre:"Control del dolor",indicadores:["Dolor referido < 4/10","Paciente en posicion comoda","Sin necesidad de analgesicos de rescate frecuentes"],escala:"1=Nunca demostrado, 2=Raramente, 3=A veces, 4=Frecuentemente, 5=Siempre demostrado"}],complicaciones:["Necrosis pancreatica infectada (mortalidad 30-40%)","Pseudoquiste pancreatico","Fistula pancreatica","Fallo multiorganico (respiratorio, renal, cardiovascular)","Diabetes mellitus secundaria","Insuficiencia pancreatica exocrina (esteatorrea)","Hemorragia retroperitoneal"],criteriosAlarma:["PA sistolica < 90 mmHg o taquicardia persistente","Diuresis < 0.5 mL/kg/h a pesar de fluidos","SpO2 < 94%","Glasgow disminuido","Signos de Grey-Turner o Cullen","Fiebre persistente > 7 dias (necrosis infectada)"],emergencyLevel:"moderado",relatedPathologyIds:["pat_cirrosis","pat_dm2"],isPremium:!1},{id:"pat_eii",nombre:"Enfermedad Inflamatoria Intestinal",bodySystemId:"digestivo",definicion:"Grupo de trastornos inflamatorios cronicos del tracto gastrointestinal de etiologia autoinmune, que incluye principalmente la Enfermedad de Crohn y la Colitis Ulcerosa, con periodos de remision y actividad inflamatoria.",epidemiologia:"Prevalencia creciente: 0.3% en paises desarrollados. 3-5 millones de pacientes en Europa y Norte America. Inicio tipico entre 15-35 a\xf1os.",factoresRiesgo:["Predisposicion genetica (riesgo 10x con familiar afectado)","Tabaquismo (Crohn: aumenta riesgo; CU: factor protector paradojico)","Microbioma intestinal alterado (disbiosis)","Dieta occidental (procesados, bajo en fibra)","Antibioticos en la infancia","Estres psicologico como precipitante de brotes"],fisiopatologia:"En la EII, una respuesta inmune aberrante a la microbiota intestinal normal produce inflamacion cronica. En Crohn, el defecto en la tolerancia inmune produce inflamacion transmural (afecta todas las capas) en cualquier segmento del GI (boca a ano). En CU, la inflamacion se limita a la mucosa del colon, comenzando en el recto y extendiendose proximalmente de forma continua. La activacion de celulas T, macr\xf3fagos y citoquinas (TNF-alfa, IL-6, IL-12/23) perpetua la inflamacion.",signosYSintomas:{signos:["Colitis Ulcerosa: rectorragia y diarrea con moco","Enfermedad de Crohn: dolor abdominal y diarrea sin sangre (frecuente)","Fistulas perianales en Crohn","Masa palpable en FID en Crohn","Manifestaciones extraintestinales: artritis, uveitis, eritema nodoso, colagitis esclerosante"],sintomas:["Diarrea (> 3 deposiciones/dia)","Dolor abdominal tipo colico","Urgencia defecatoria","Tenesmo rectal (CU)","Fatiga intensa","Perdida de peso","Fiebre en brotes"]},clasificacion:{nombre:"Tipos y extension",tipos:[{nombre:"Colitis Ulcerosa proctitis",descripcion:"Limitada al recto. Sintomas leves, sangrado rectal"},{nombre:"CU extensa o pancolitis",descripcion:"Mas alla del angulo esplenico. Sintomas sistemicos frecuentes"},{nombre:"Crohn ileoc\xf3lico",descripcion:"Localizaci\xf3n mas frecuente (45%): ileon terminal + colon derecho"},{nombre:"Crohn fistulizante",descripcion:"Fistulas entre asas, perianales, enterovaginales. Fenotipo agresivo"}]},diagnostico:{anamnesis:["Diarrea cronica, su relacion con sangre y moco","Dolor abdominal y su localizacion","Antecedentes familiares de EII","Historia de fistulas o abscesos perianales (Crohn)"],examenFisico:["Inspeccion perianal (fistulas, fisuras, abscesos en Crohn)","Palpacion abdominal: masa en FID (Crohn)","Signos de desnutricion","Manifestaciones extraintestinales"],pruebas:[{nombre:"Colonoscopia con biopsias",descripcion:"Standard de oro diagnostico y de extension. Caracteristicas endosc\xf3picas e histologicas diferencia Crohn de CU",cuidadosEnfermeria:["Preparacion con polietilenglicol el dia previo","Ayuno 8h previo","Acceso venoso para sedacion","Anestesia rectal si dolor perianal en Crohn"]},{nombre:"Calprotectina fecal",descripcion:"Marcador de inflamacion intestinal; util para monitorizar actividad y predecir recaidas",valoresReferencia:"< 50 mcg/g = remision; 50-200 = gris; > 200 mcg/g = inflamacion activa",cuidadosEnfermeria:["Muestra de heces fresca","No requiere preparacion especial"]},{nombre:"PCR y VSG",descripcion:"Marcadores de inflamacion sistemica; correlacionan con actividad de la enfermedad",cuidadosEnfermeria:["Junto a hemograma y albumina para evaluar actividad y estado nutricional"]}]},tratamientoMedico:{objetivos:["Inducir y mantener la remision cl\xednica y endosc\xf3pica","Prevenir complicaciones y cirugia","Mejorar la calidad de vida"],farmacologico:[{nombre:"Mesalazina (5-ASA)",grupo:"Aminosalicilato - primera linea en CU leve-moderada",mecanismo:"Antiinflamatorio topico intestinal que inhibe la 5-lipoxigenasa y la produccion de leucotrienos en la mucosa colonica",dosis:"2-4 g/dia VO + supositorio rectal 1 g/noche en proctitis",cuidadosEnfermeria:["Formas orales con cubierta ent\xe9rica: no triturar","Recordar la importancia de las formas rectales para proctitis","Vigilar nefrotoxicidad con uso prolongado: creatinina anual"]},{nombre:"Prednisona",grupo:"Corticoide sistemico - induccion de remision en brote moderado-grave",mecanismo:"Potente antiinflamatorio que reduce rapida y eficazmente la inflamacion intestinal activa",dosis:"40-60 mg/dia VO, reduccion gradual 5 mg/semana",cuidadosEnfermeria:["No para mantenimiento (corticodependencia)","Proteccion gastrica con IBP","Suplementar calcio y vitamina D","Monitorizar glucemia, PA, densidad osea a largo plazo"]},{nombre:"Azatioprina / 6-Mercaptopurina",grupo:"Inmunosupresor - mantenimiento de remision",mecanismo:"Inhibe la proliferacion de linfocitos T y B, reduciendo la respuesta inmune inflamatoria",dosis:"Azatioprina 2-2.5 mg/kg/dia VO",cuidadosEnfermeria:["Hemograma semanal en el primer mes, luego mensual (leucopenia)","Hepatotoxicidad: transaminasas mensuales inicialmente","Inicio de efecto lento (3-4 meses)","Fotosensibilidad"]},{nombre:"Infliximab / Adalimumab (anti-TNF)",grupo:"Biologico - anti-TNF alfa - EII moderada/grave refractaria",mecanismo:"Anticuerpo monoclonal que bloquea el TNF-alfa, principal citoquina proinflamatoria en EII",dosis:"Infliximab: 5 mg/kg IV semanas 0, 2, 6, luego cada 8 semanas",cuidadosEnfermeria:["Descartar tuberculosis latente ANTES de iniciar (IGRA/Mantoux)","Vacunas al dia antes de iniciar biologicos","Vigilar infecciones oportunistas durante tratamiento","Reaccion infusional con infliximab: premedicar y monitorizar PA/FC durante infusion"]}],noFarmacologico:["Soporte nutricional enteral (especialmente en Crohn activo)","Dieta baja en residuos en actividad para CU","Manejo del estres psicologico","No fumar (perjudica en Crohn)"],quirurgico:["Colectomia total curativa en CU refractaria o cancer de colon","Reseccion intestinal en Crohn: estenosis, fistulas internas, perforaciones"]},cuidadosEnfermeria:{valoracion:["Numero de deposiciones/dia y presencia de sangre","Dolor abdominal (EVA, localizacion)","Temperatura","Estado nutricional: peso, albumina","Perianal: inspeccion en Crohn","Actividad de la enfermedad: calprotectina, PCR"],intervenciones:["Administrar medicacion segun indicacion","Soporte nutricional si desnutricion","Higiene perianal meticulosa en Crohn con fistulas","Control y registro de deposiciones","Educacion sobre dieta adaptada al brote"],educacionPaciente:["Reconocer signos de brote y cuando consultar","Adherencia al tratamiento de mantenimiento (no suspender en remision)","Necesidad de colonoscopia de control periodica (riesgo de cancer colorrectal)","Vacunaciones necesarias antes de biologicos","Impacto de estres y tabaco en la actividad"],monitorizacion:["Numero y caracteristicas de deposiciones diariamente","Temperatura cada 4-6h en brote","Peso semanal en brote","Hemograma, PCR, calprotectina en brote","Efectos adversos de inmunosupresores y biologicos"]},npiNanda:[{codigo:"00011",nombre:"Estrenimiento",definicion:"Disminucion de la frecuencia normal de evacuacion intestinal con heces duras y dificiles de expulsar",caracteristicasDefinitorias:["Diarrea o heces con sangre (dependiendo del tipo)","Urgencia defecatoria"],factoresRelacionados:["Inflamacion intestinal activa","Alteracion de la motilidad intestinal"]},{codigo:"00002",nombre:"Desequilibrio nutricional: ingestion inferior a las necesidades",definicion:"Ingestion de nutrientes insuficiente para satisfacer las necesidades metabolicas",caracteristicasDefinitorias:["Perdida de peso","Albumina baja","Fatiga"],factoresRelacionados:["Malabsorcion","Anorexia por inflamacion activa","Restrccion de alimentos por dolor"]}],npiNic:[{codigo:"0430",nombre:"Manejo intestinal",actividades:["Registrar numero y caracteristicas de deposiciones","Administrar antidiarreicos y antiinflamatorios segun indicacion","Higiene perianal tras cada deposicion","Evaluar signos de desnutricion"]}],npiNoc:[{codigo:"0501",nombre:"Eliminacion intestinal",indicadores:["Deposiciones < 3/dia en remision","Sin sangre en heces","Sin dolor al defecar"],escala:"1=Gravemente comprometido, 2=Sustancialmente, 3=Moderadamente, 4=Levemente, 5=No comprometido"}],complicaciones:["Megacolon toxico (CU: emergencia, perforacion inminente)","Hemorragia masiva","Estenosis intestinales (Crohn)","Fistulas (Crohn: enteroent\xe9ricas, perianales, enterovaginales)","Cancer colorrectal (mayor riesgo con pancolitis de larga evolucion)","Osteoporosis por corticoides","Anemia cronica"],criteriosAlarma:["Mas de 10 deposiciones sanguinolentas/dia","Fiebre > 38.5\xb0C con distension abdominal (megacolon toxico)","Sangrado rectal masivo con hipotension","Abdomen en tabla (perforacion)"],emergencyLevel:"moderado",relatedPathologyIds:["pat_hemorragia_digestiva","pat_anemia_ferropenica"],isPremium:!0},{id:"pat_hemorragia_digestiva",nombre:"Hemorragia Digestiva",bodySystemId:"digestivo",definicion:"Sangrado originado en cualquier punto del tracto gastrointestinal, desde la boca hasta el ano. La HDA (alta) se origina proximal al angulo de Treitz; la HDB (baja) distal al mismo. Causa frecuente de urgencia medica con potencial gravedad.",epidemiologia:"HDA: incidencia de 100-150/100.000 hab/ano. Mortalidad del 5-15%. Principal causa: ulcera p\xe9ptica (50%). HDB: incidencia de 20-30/100.000 hab/ano. Causa principal: diverticulosis (30-40%) y angiodisplasia.",factoresRiesgo:["Ulcera peptica activa por H. pylori o AINEs","Varices esofagicas en cirrotico","Uso de anticoagulantes y antiagregantes","Cirrosis hepatica","Diverticulosis col\xf3nica","Cancer colorrectal","Edad avanzada"],fisiopatologia:"En HDA no variceal (ulcera peptica): la erosion del vaso por el crecimiento de la ulcera produce sangrado arterial (vasos de hasta 2 mm, como la arteria gastroduodenal). En HDA variceal: la hipertension portal produce varices submucosas esofagicas que se rompen por presiones elevadas. En HDB: la diverticulosis produce sangrado arterial por erosion de la arteria nutricia en el diverticulo. La perdida de sangre activa el sistema simpatico (taquicardia, vasoconstriccion) y desencadena el shock hipovol\xe9mico en casos masivos.",signosYSintomas:{signos:["Hematemesis (vomito con sangre roja o en pozo de cafe) = HDA","Melena (heces negras, fetidas, pastosas) = HDA o HDB proximal","Hematoquecia (sangre roja por recto) = HDB o HDA masiva","Taquicardia, hipotension (sangrado activo)","Palidez cutanea","Diaforesis"],sintomas:["Nauseas y vomitos con sangre","Debilidad y mareos (anemia aguda)","Sensacion de desvanecimiento (presincope)","Dolor epigastrico si ulcera","Puede ser indolora (varices, angiodisplasia)"]},clasificacion:{nombre:"Clasificacion de Forrest (para HDA por ulcera peptica)",tipos:[{nombre:"Forrest Ia",descripcion:"Sangrado arterial activo en chorro. Riesgo de recidiva > 90%. Hemostasia endosc\xf3pica urgente"},{nombre:"Forrest Ib",descripcion:"Sangrado en babeo activo. Riesgo alto. Hemostasia"},{nombre:"Forrest IIa",descripcion:"Vaso visible sin sangrado activo. Riesgo 50%. Hemostasia"},{nombre:"Forrest IIb",descripcion:"Coagulo adherido. Riesgo 30%. Tratamiento medico + endoscopia"},{nombre:"Forrest IIc-III",descripcion:"Base negra / ulcera de base limpia. Riesgo bajo. Tratamiento medico"}]},diagnostico:{anamnesis:["Tipo de sangrado: hematemesis, melena, hematoquecia","Uso de AINEs, aspirina, anticoagulantes","Historia de ulcera peptica, cirrosis, diverticulosis","Cantidad estimada de sangrado"],examenFisico:["Hemograma urgente y signos vitales","Test de inclinacion ortost\xe1tica (hipotension ortost\xe1tica = > 500 mL perdidos)","Tacto rectal: melena vs hematoquecia","Buscar signos de hepatopatia cronica"],pruebas:[{nombre:"Hemograma urgente, coagulacion e ionograma",descripcion:"Evalua gravedad de la anemia, coagulopatia y metabolismo para transfusion y reposicion",valoresReferencia:"Hemoglobina < 7 g/dL = transfusion; Plaquetas < 50.000 en sangrado activo = riesgo",cuidadosEnfermeria:["Extraer URGENTE junto a grupo y factores para reserva de sangre","Repetir cada 4-6h en sangrado activo para monitorizar descenso de Hb"]},{nombre:"Endoscopia digestiva alta urgente (EDA < 24h)",descripcion:"Diagnostica el origen, estadifica el riesgo (Forrest) y permite hemostasia endosc\xf3pica",cuidadosEnfermeria:["Ayuno","Estabilizacion hemodinamica PREVIA (no esperar si inestable sin acceso endosc\xf3pico)","Acceso venoso de grueso calibre","Sonda nasogastrica puede ayudar a lavar el estomago antes","Consentimiento informado si posible"]},{nombre:"Score de Glasgow-Blatchford",descripcion:"Predice la necesidad de intervencion (transfusion, endoscopia hemost\xe1tica) en HDA",valoresReferencia:"Score 0: manejo ambulatorio; > 0: ingreso y endoscopia",cuidadosEnfermeria:["Calcular al ingreso para decidir nivel de cuidados"]}]},tratamientoMedico:{objetivos:["Estabilizacion hemodinamica","Hemostasia endosc\xf3pica del sangrado","Prevenir recidiva"],farmacologico:[{nombre:"Omeprazol 80 mg IV en bolo + perfusion",grupo:"IBP IV en dosis alta - HDA por ulcera peptica",mecanismo:"Reduce la secrecion acida, alcaliniza el estomago, estabiliza el coagulo del vaso sangrante",dosis:"80 mg IV en bolo, luego perfusion 8 mg/h durante 72h (pre y post-endoscopia)",cuidadosEnfermeria:["Administrar INMEDIATAMENTE al ingreso de HDA","Bomba de infusion precisa","Revertir a via oral cuando tolerancia mejore"]},{nombre:"Terlipresina / Somatostatina IV",grupo:"Vasoconstrictor esplacnico - HDA variceal",mecanismo:"Reduce el flujo esplacnico y la presion portal, disminuyendo el sangrado de varices",dosis:"Terlipresina: 2 mg IV cada 4h x 5 dias. Somatostatina/octreotide: bolo + infusion",cuidadosEnfermeria:["Administrar junto a profilaxis antibiotica","Vigilar isquemia (terlipresina es vasoconstrictora)","NO usar en embarazo o cardiopatia isquemica grave"]}],noFarmacologico:["Resucitacion con cristaloides IV y transfusion de GRE si Hb < 7-8 g/dL","Endoscopia hemost\xe1tica (inyeccion de adrenalina, coagulacion, clips hemost\xe1ticos)","Ligadura elastica de varices en HDA variceal","TIPS si hemorragia variceal refractaria"],quirurgico:["Cirugia urgente si endoscopia falla en hemostasia","Cirugia en HDB masiva sin origen identificado por endoscopia ni arteriografia"]},cuidadosEnfermeria:{valoracion:["Signos vitales cada 15-30 min en sangrado activo (taquicardia + hipotension = shock)","Coloracion y diaforesis","Valorar cantidad y aspecto del sangrado (hematemesis, melena)","Diuresis horaria","Nivel de conciencia"],intervenciones:["DOS VIAS VENOSAS PERIFERICAS DE GRUESO CALIBRE (14-16G) URGENTE","Resucitacion con cristaloides IV rapida","Extraer muestras urgentes (hemograma, grupo, coagulacion)","Preparar para endoscopia urgente","Sonda vesical para diuresis horaria","Ayuno absoluto","O2 si taquicardia severa o hipoxia"],educacionPaciente:["Post-sangrado: explicar causa y medidas preventivas (evitar AINEs, tratamiento H. pylori)","Reconocer recidiva: vomito con sangre, heces negras","Abstinencia de alcohol si cirrotico"],monitorizacion:["PA y FC cada 15-30 min en activo, luego cada hora","Hemoglobina seriada cada 4-6h en activo","Diuresis horaria","Deposiciones: numero, aspecto, cantidad","Balance hidrico estricto"]},npiNanda:[{codigo:"00028",nombre:"Riesgo de deficit de volumen de liquidos",definicion:"Vulnerable a sufrir deshidratacion vascular, celular o intracelular",caracteristicasDefinitorias:["Sangrado activo","Hipotension","Taquicardia"],factoresRelacionados:["Perdida activa de sangre por via gastrointestinal"]}],npiNic:[{codigo:"4130",nombre:"Monitorizacion de liquidos",actividades:["Vigilar signos vitales cada 15-30 min en sangrado activo","Administrar fluidos IV segun indicacion","Diuresis horaria","Transfusion segun Hb y estado hemodinamico"]}],npiNoc:[{codigo:"0401",nombre:"Estado circulatorio",indicadores:["PA sistolica > 90 mmHg","FC < 100 lpm","Diuresis > 0.5 mL/kg/h"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Shock hipovolemico","Recidiva hemorragica (20-30% en primeras 72h)","Neumonia aspirativa (si vomito masivo)","Encefalopatia hepatica en cirrotico (por sangre en intestino = amoniaco)","Muerte"],criteriosAlarma:["PA sistolica < 90 mmHg o caida > 30 mmHg","FC > 120 lpm","Hemoglobina < 7 g/dL con sangrado activo","Vomitos masivos con sangre roja","Confusion o perdida de conciencia"],emergencyLevel:"critico",relatedPathologyIds:["pat_ulcera_peptica","pat_cirrosis"],isPremium:!0},{id:"pat_apendicitis",nombre:"Apendicitis Aguda",bodySystemId:"digestivo",definicion:"Inflamacion aguda del apendice vermiforme causada principalmente por obstruccion del lumen apendicular (fecalito, hiperplasia linfoide), con isquemia, infeccion bacteriana y riesgo de perforacion.",epidemiologia:"Incidencia de 100-200/100.000 hab/ano. Causa mas frecuente de abdomen agudo quirurgico en todos los grupos etarios. Riesgo de por vida del 7-8%. Pico de incidencia entre 10-30 a\xf1os.",factoresRiesgo:["Obstruccion apendicular por fecalito o calculos","Hiperplasia linfoide (jovenes, infecciones virales)","Parasitosis","Dieta baja en fibra (mayor retraso del transito)","Antecedentes familiares"],fisiopatologia:"La obstruccion del lumen apendicular impide el drenaje de moco y secreciones. La presion intraluminal aumenta, comprimiendo los vasos linfaticos y luego venosos, produciendo edema de la pared. La isquemia resultante facilita la invasion bacteriana (E. coli, Bacteroides) y la inflamacion progresiva. Si no se trata en 24-72h, el apendice se perfora (necrosis de la pared), produciendo peritonitis localizada (plastron apendicular) o difusa.",signosYSintomas:{signos:["Signo de McBurney: dolor en punto de McBurney (1/3 externo de la linea umbilico-espina iliaca anterior superior)","Signo de Blumberg: dolor de rebote en FID","Signo de Rovsing: dolor en FID al comprimir FII","Defensa muscular en FID","Fiebre (> 37.5\xb0C)","Leucocitosis"],sintomas:["Dolor migratorio: inicio periumbilical que se localiza en FID (6-12h) - signo de Murphy para apendice","Nauseas y vomitos (tras inicio del dolor)","Anorexia","Fiebre moderada","Dificultad para caminar (contractura del psoas si posicion retrocecal)"]},clasificacion:{nombre:"Estadios anatomopatologicos",tipos:[{nombre:"Apendicitis catarral (grado I)",descripcion:"Inflamacion leve, sin exudado. Tratamiento: antibioticos o cirugia"},{nombre:"Apendicitis flegmonosa (grado II)",descripcion:"Inflamacion purulenta, sin perforacion. Cirugia"},{nombre:"Apendicitis gangrenosa (grado III)",descripcion:"Necrosis de la pared, perforacion inminente. Cirugia urgente"},{nombre:"Apendicitis perforada (grado IV)",descripcion:"Perforacion con peritonitis localizada o difusa. Cirugia + antibioticos"}]},diagnostico:{anamnesis:["Inicio y migracion del dolor","Nauseas y vomitos (posterior al dolor)","Anorexia","Fiebre","Diarrea o constipacion"],examenFisico:["Punto de McBurney, Blumberg, Rovsing","Signo del psoas (dolor con extension de cadera derecha)","Defensa o rigidez muscular","Score de Alvarado"],pruebas:[{nombre:"Score de Alvarado",descripcion:"Sistema de puntuacion para diagnostico de apendicitis: Migracion dolor +1, Anorexia +1, Nauseas +1, Sensibilidad FID +2, Dolor rebote +1, Temp >37.3+1, Leucocitosis+2, Desviacion izquierda+1",valoresReferencia:"7-10: alta probabilidad (cirugia); 5-6: probable (TAC o eco); < 5: baja (observacion)",cuidadosEnfermeria:["Calcular al ingreso","Guia para decision de TAC vs cirugia directa"]},{nombre:"Ecografia abdominal",descripcion:"Primer estudio de imagen en ni\xf1os y embarazadas (sin radiacion). Visualiza apendice no compresible > 6mm",cuidadosEnfermeria:["Ayuno","Puede no visualizarse el apendice en adultos obesos o con gas intestinal"]},{nombre:"TAC abdominal con contraste",descripcion:"Alta sensibilidad y especificidad en adultos. Detecta apendice inflamado, periapendicular, plastron",cuidadosEnfermeria:["Contraindicado en embarazo si posible alternativa","Verificar funcion renal antes del contraste"]}]},tratamientoMedico:{objetivos:["Apendectomia quirurgica urgente antes de la perforacion","Antibioticos perioperatorios"],farmacologico:[{nombre:"Cefazolina + Metronidazol (profilaxis antibiotica perioperatoria)",grupo:"Antibioticos perioperatorios",mecanismo:"Reducen riesgo de infeccion quirurgica del sitio; en perforada: tratamiento terapeutico",dosis:"Cefazolina 2 g IV + Metronidazol 500 mg IV, 30 min antes de cirugia",cuidadosEnfermeria:["Administrar en los 30-60 min previos a la incision","Prolongar si apendice perforado (5-7 dias de antibioticos terapeuticos)"]}],noFarmacologico:["Ayuno prequirurgico","Hidratacion IV","Analgesia (no contraindicada antes del diagnostico)"],quirurgico:["Apendectomia laparoscopica (preferida): menor dolor postoperatorio, menor tasa de infeccion","Apendectomia abierta (McBurney o Rocky-Davis) si laparoscopia no disponible o peritonitis difusa","Drenaje de absceso periapendicular si plastron organizado > 3 cm antes de cirugia diferida"]},cuidadosEnfermeria:{valoracion:["Localizacion y caracteristicas del dolor abdominal","Temperatura, taquicardia (peritonitis)","Defensa abdominal","Nauseas y vomitos"],intervenciones:["Ayuno desde el ingreso","Via venosa y fluidoterapia IV","Analgesia: NO se debe negar analgesia (no enmascara el diagnostico con TAC)","Preparar para cirugia urgente","Profilaxis antibiotica peri-operatoria"],educacionPaciente:["Cuidados de la herida laparosc\xf3pica post-cirugia","Signos de infeccion de herida","Actividad fisica progresiva post-alta","Cuando consultar si dolor abdominal post-apendicectomia"],monitorizacion:["Temperatura cada 4-6h","Dolor abdominal cada 2-4h","Leucocitosis seriada si se retrasa la cirugia","Post-cirugia: signos de infeccion y retorno del transito intestinal"]},npiNanda:[{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable por lesion tisular",caracteristicasDefinitorias:["Dolor en FID","Posicion antalgica","Resistencia muscular voluntaria"],factoresRelacionados:["Inflamacion del apendice vermiforme","Distension abdominal"]}],npiNic:[{codigo:"2900",nombre:"Asistencia quirurgica",actividades:["Preparacion preoperatoria completa","Administrar profilaxis antibiotica peri-operatoria","Consentimiento informado","Ayuno documentado"]}],npiNoc:[{codigo:"1605",nombre:"Control del dolor",indicadores:["Dolor postoperatorio < 4/10","Sin dolor de rebote","Analgesia efectiva"],escala:"1=Nunca demostrado, 2=Raramente, 3=A veces, 4=Frecuentemente, 5=Siempre demostrado"}],complicaciones:["Perforacion con peritonitis difusa (si tratamiento tardio)","Absceso periapendicular (plastron)","Sepsis abdominal","Infeccion del sitio quirurgico","Ileo paralitico postoperatorio"],criteriosAlarma:["Dolor abdominal difuso con abdomen en tabla (perforacion)","Fiebre > 39\xb0C con deterioro rapido","Hipotension y taquicardia (sepsis)"],emergencyLevel:"critico",relatedPathologyIds:["pat_obstruccion_intestinal"],isPremium:!1},{id:"pat_obstruccion_intestinal",nombre:"Obstruccion Intestinal",bodySystemId:"digestivo",definicion:"Interrupcion del transito intestinal normal por un obstaculo mecanico (adherencias, hernia, tumor, volvulo) o funcional (ileo paralitico), con acumulacion proximal de gas y liquido que produce distension, dolor, vomitos y ausencia de deposiciones y gases.",epidemiologia:"Causa del 15-20% de las hospitalizaciones por abdomen agudo. La principal causa es las adherencias postquirurgicas (60-70%). Mortalidad del 2-8% con tratamiento precoz.",factoresRiesgo:["Cirugia abdominal previa (adherencias)","Hernias inguinales, umbilicales o incisionales","Cancer colorrectal o de intestino delgado","Volvulo sigmoide o cecal","Intususcepcion","Bezoares o cuerpos extranos"],fisiopatologia:"La obstruccion mecanica impide el avance del contenido intestinal. El intestino proximal al obstaculo se dilata por acumulacion de liquido intestinal (5-10 L/dia) y gas (aerofagia + produccion bacteriana). La distension activa reflejos de vomito, produce depleccion hidroelectrolitica severa (hipokalemia, alcalosis) y compromete la perfusion de la pared intestinal. La isquemia del intestino distendido puede progresar a necrosis (estrangulacion) si no se descomprime.",signosYSintomas:{signos:["Distension abdominal progresiva","Hiperperistaltismo metalico o ausencia de ruidos (segun estadio)","Timpanismo difuso","Defensa abdominal si isquemia","Shock hipovolemico en tardio"],sintomas:["Dolor abdominal tipo colico (obstruccion mecanica)","Vomitos: primero biliosos, luego fecaloideos (intestino delgado alto)","Ausencia de gases y deposiciones (signo cardinal)","Nauseas"]},clasificacion:{nombre:"Clasificacion por mecanismo y localizacion",tipos:[{nombre:"Obstruccion de intestino delgado (OID)",descripcion:"Causa mas frecuente: adherencias. Vomitos precoces, distension moderada"},{nombre:"Obstruccion de intestino grueso (OIG)",descripcion:"Causas: cancer colorrectal, volvulo. Distension pronunciada, vomitos tardios"},{nombre:"Obstruccion con estrangulacion",descripcion:"Compromiso vascular + obstruccion. Urgencia absoluta: isquemia progresa a necrosis"},{nombre:"Ileo paralitico (funcional)",descripcion:"Ausencia de obstruccion mecanica: postoperatorio, peritonitis, hipokalemia"}]},diagnostico:{anamnesis:["Cirugias abdominales previas","Ausencia de gas y deposiciones (tiempo de evolucion)","Inicio y tipo de dolor","Ultima deposicion y flatulencia"],examenFisico:["Distension abdominal","Ruidos intestinales: hiperperistaltismo metalico vs ausencia (tardio)","Timpanismo a la percusion","Buscar hernias y cicatrices quirurgicas"],pruebas:[{nombre:"Radiografia de abdomen de pie y en decubito",descripcion:"Primer estudio: asas distendidas, niveles hidroaereos, signo del intestino en asas de U",cuidadosEnfermeria:["Dos posiciones: decubito supino + bipedestacion o decubito lateral","En bipedestacion: visualiza mejor los niveles hidroaereos"]},{nombre:"TAC abdominal con contraste",descripcion:"Identifica causa, localizacion de la obstruccion, y signos de estrangulacion o isquemia",cuidadosEnfermeria:["No administrar contraste oral en obstruccion (riesgo de aspiracion)","Verificar funcion renal para contraste IV"]}]},tratamientoMedico:{objetivos:["Descompresion intestinal","Resolucion del obstaculo","Correccion hidroelectrolitica"],farmacologico:[{nombre:"Solucion de Ringer Lactato o Suero fisiologico",grupo:"Cristaloide IV - resucitacion hidroelectrolitica",mecanismo:"Repone las perdidas masivas de liquido al tercer espacio (intestino obstruido) y por vomitos",dosis:"500 mL/h inicialmente; ajustar segun diuresis y signos vitales",cuidadosEnfermeria:["Dos vias venosas perifericas de grueso calibre","Monitorizar diuresis horaria","Reponer potasio (hipokalemia por vomitos)"]},{nombre:"Morfina IV",grupo:"Analgesico opioide",mecanismo:"Control del dolor abdominal; NO contraindicado (no enmascara el diagnostico)",dosis:"2-4 mg IV cada 4-6h segun EVA",cuidadosEnfermeria:["Vigilar FR y SpO2","Monitorizar nivel de conciencia"]}],noFarmacologico:["Sonda nasogastrica (SNG) para descompresion gastrica","Ayuno absoluto","Reposo intestinal"],quirurgico:["Cirugia urgente en estrangulacion o isquemia","Cirugia diferida en parciales por adherencias si no mejoran en 24-48h con tratamiento conservador","Colonoscopia descompresiva en volvulo sigmoide no complicado"]},cuidadosEnfermeria:{valoracion:["Auscultar ruidos intestinales cada 4h (volver si ileo paralitico = buen signo post-cirugia)","Medir perimetro abdominal cada 4h (aumento = empeoramiento)","Registrar debito por SNG y caracteristicas","Nauseas y vomitos","Signos de isquemia: fiebre, taquicardia, dolor continuo (no colico)"],intervenciones:["Colocar SNG y verificar posicion (aspiracion g\xe1strica)","Ayuno estricto","Hidratacion IV agresiva con reposicion de electrolitos","Vigilar signos de isquemia y preparar para cirugia urgente si deterioro","Sonda vesical para diuresis horaria"],educacionPaciente:["Post-cirugia: dieta progresiva segun recuperacion del transito","Importancia de la fisioterapia postoperatoria","Reconocer recidiva de sintomas"],monitorizacion:["Ruidos intestinales cada 4-8h","Perimetro abdominal","Debito de SNG","Diuresis horaria","Electrolitos diarios (hipokalemia frecuente)","Signos de isquemia cada turno"]},npiNanda:[{codigo:"00025",nombre:"Exceso de volumen de liquidos al tercer espacio",definicion:"Acumulacion de liquido en un espacio no intercambiable",caracteristicasDefinitorias:["Distension abdominal","Vomitos persistentes","Signos de deshidratacion sistemica"],factoresRelacionados:["Secuestro de liquido en asas intestinales obstruidas"]}],npiNic:[{codigo:"1080",nombre:"Manejo del tubo gastrointestinal",actividades:["Insertar y mantener SNG para descompresion","Registrar debito y caracteristicas","Verificar posicion del tubo periodicamente","Higiene nasal y oral frecuente"]}],npiNoc:[{codigo:"0501",nombre:"Eliminacion intestinal",indicadores:["Retorno del peristaltismo","Eliminacion de gases","Sin distension abdominal"],escala:"1=Gravemente comprometido, 2=Sustancialmente, 3=Moderadamente, 4=Levemente, 5=No comprometido"}],complicaciones:["Estrangulacion con necrosis intestinal","Perforacion y peritonitis","Shock hipovolemico y septico","Fistula enterocutanea post-cirugia","Muerte (2-8%)"],criteriosAlarma:["Fiebre + dolor abdominal continuo (no colico) + defensa muscular (estrangulacion)","Hipotension y taquicardia","Deterioro rapido del estado general"],emergencyLevel:"critico",relatedPathologyIds:["pat_apendicitis"],isPremium:!0},{id:"pat_dm1",nombre:"Diabetes Mellitus Tipo 1",bodySystemId:"endocrino",definicion:"Enfermedad autoinmune cronica caracterizada por la destruccion de las celulas beta del pancreas, produciendo deficiencia absoluta de insulina y dependencia de insulina exogena para sobrevivir y prevenir la cetoacidosis diabetica.",epidemiologia:"Representa el 5-10% de todos los casos de diabetes. Incidencia de 10-15/100.000 ni\xf1os/ano en paises occidentales. Inicio tipico en la infancia o adolescencia, aunque puede ocurrir a cualquier edad.",factoresRiesgo:["Predisposicion genetica (HLA DR3/DR4)","Factores ambientales desencadenantes (virus entericos)","Historia familiar de DM1","Otras enfermedades autoinmunes (tiroides, celiaca)"],fisiopatologia:"La DM1 resulta de la destruccion autoinmune mediada por linfocitos T de las celulas beta de los islotes de Langerhans. Los anticuerpos anti-islotes (ICA), anti-GAD65, anti-IA2 y anti-insulina marcan el proceso autoinmune que precede en meses o a\xf1os a la hiperglucemia clinica. La insulinopenia produce hiperglucemia (ausencia de captacion de glucosa), lipolisis excesiva con produccion de cuerpos cet\xf3nicos y gluconeogenesis hepatica descontrolada.",signosYSintomas:{signos:["Glucemia > 126 mg/dL en ayunas o > 200 mg/dL en cualquier momento","Cetonemia o cetonuria (descompensacion)","Perdida de peso rapida a pesar de polifagia"],sintomas:["Poliuria (diuresis osmotica)","Polidipsia","Polifagia","Perdida de peso","Fatiga","Vision borrosa","En ni\xf1os: enuresis nocturna de nueva aparicion"]},clasificacion:{nombre:"Estadios de la DM1 (ADA 2022)",tipos:[{nombre:"Estadio 1",descripcion:"Autoinmunidad positiva (anticuerpos) sin hiperglucemia. Normoglucemia"},{nombre:"Estadio 2",descripcion:"Autoinmunidad + disglucemia (prediabetes). Asintomatico"},{nombre:"Estadio 3",descripcion:"Inicio clinico con hiperglucemia sintomatica. Diagnostico clasico"}]},diagnostico:{anamnesis:["Inicio agudo de poliuria, polidipsia, polifagia","Perdida de peso","Edad de inicio tipica (infancia/adolescencia)","Historia familiar de DM1"],examenFisico:["Peso y talla con IMC","Evaluar deshidratacion","Aliento cet\xf3sico en descompensacion"],pruebas:[{nombre:"Glucemia en ayunas y HbA1c",descripcion:"Glucemia >= 126 mg/dL en 2 ocasiones o HbA1c >= 6.5% diagnostica DM",valoresReferencia:"Objetivo de tratamiento: HbA1c < 7% (< 6.5% en seleccionados); Glucemia ayunas 80-130 mg/dL; 2h post-prandial < 180 mg/dL",cuidadosEnfermeria:["Ayuno de 8-12h para glucemia basal","HbA1c: no requiere ayuno, refleja glucemia media de los 3 meses previos"]},{nombre:"Anticuerpos anti-GAD65, anti-IA2, anti-insulina",descripcion:"Confirman etiologia autoinmune de la diabetes (DM1 vs DM2)",cuidadosEnfermeria:["Muestra venosa estandar","Resultado tarda 1-2 semanas; no condiciona el tratamiento inicial"]},{nombre:"Cetonemia (cuerpos cetonicos en sangre)",descripcion:"Beta-hidroxibutirato: rapido y cuantitativo. Diagnostica cetoacidosis",valoresReferencia:"< 0.6 mmol/L normal; 0.6-1.5 riesgo; > 3 cetoacidosis",cuidadosEnfermeria:["Medicion en lanceta (glucometro que mide cetones)","En todo diabetico tipo 1 con hiperglucemia > 250 mg/dL o sintomas"]}]},tratamientoMedico:{objetivos:["Control glucemico con HbA1c objetivo < 7%","Prevenir hipoglucemias severas","Prevenir complicaciones microvasculares y macrovasculares"],farmacologico:[{nombre:"Insulina glargina (basal)",grupo:"Insulina analogica de accion prolongada",mecanismo:"Cubre las necesidades basales de insulina durante 24h con perfil sin pico, mimificando la secrecion basal del pancreas normal",dosis:"0.2-0.4 UI/kg/dia SC en dosis unica, ajustar segun glucemia basal",cuidadosEnfermeria:["Administrar a la MISMA HORA cada dia (cualquier hora, consistente)","Rotar zonas de inyeccion (abdomen, muslo, brazo, gluteo)","No agitar (solo glargina: no mezclar con otras insulinas)","Conservar en nevera hasta abrir, luego temperatura ambiente max 28 dias"]},{nombre:"Insulina asparta/lispro (prandial)",grupo:"Insulina analogica de accion ultra-rapida",mecanismo:"Cubre el pico de glucosa postprandial con inicio rapido (10-15 min) y duracion 3-4h",dosis:"0.1-0.2 UI/kg por comida o 1 UI por 15 g de carbohidratos (conteo de CH)",cuidadosEnfermeria:["Administrar 10-15 min antes de comer o inmediatamente antes","Vigilar que el paciente vaya a comer despues (hipoglucemia si no come)","Refrigerar hasta abrir, luego temperatura ambiente max 28 dias"]},{nombre:"Glucagon inyectable (hipoglucemia grave)",grupo:"Antagonista de insulina - emergencia hipoglucemia",mecanismo:"Estimula la glucogenolisis hepatica, elevando la glucemia en paciente inconsciente",dosis:"1 mg IM o SC (adultos); 0.5 mg en < 25 kg",cuidadosEnfermeria:["Kit de glucagon disponible en casa del paciente y colegio/trabajo","Ense\xf1ar a familiares la tecnica de administracion","Girar al paciente lateral post-administracion (riesgo de vomito)"]}],noFarmacologico:["Automonitoreo de glucemia capilar (4-8 veces/dia o sensor continuo de glucosa)","Conteo de carbohidratos para ajuste de insulina prandial","Actividad fisica adaptada con ajuste de insulina y carbohidratos","Educacion diabetologica estructurada"],quirurgico:["Trasplante pancreatico (curaci\xf3n definitiva, pero riesgo de inmunosupresion cronica)","Trasplante de islotes pancreatticos (experimental)"]},cuidadosEnfermeria:{valoracion:["Glucemia capilar antes de cada comida y a las 2h post-prandial","Signos de hipoglucemia: diaforesis, temblor, confusion, taquicardia","Signos de hiperglucemia: poliuria, polidipsia, letargo","Tecnica de insulinoterapia y sitios de inyeccion (lipohipertrofias)","Pie diabetico en pacientes cronicos"],intervenciones:["Administrar insulina en dosis y tipo correctos y a la hora indicada","Verificar que el paciente va a comer tras insulina prandial","Tratamiento de hipoglucemia: regla de los 15 (15 g CHO + 15 min + recontrol)","Educacion continua en conteo de carbohidratos","Rotar sitios de inyeccion documentando"],educacionPaciente:["Insulinoterapia: tipos, dosis, conservacion, tecnica de inyeccion","Automonitoreo de glucemia capilar y significado de los valores","Tratamiento de hipoglucemia (Regla 15-15)","Manejo en dias de enfermedad","Cuidado de los pies","Identificacion medica de diabetico insulinodependiente"],monitorizacion:["Glucemia capilar cada 4h en hospitalizados o segun indicacion","HbA1c cada 3 meses","Microalbuminuria anual","Fondo de ojo anual","Perfil lipidico anual","PA en cada visita"]},npiNanda:[{codigo:"00179",nombre:"Riesgo de nivel de glucemia inestable",definicion:"Vulnerable a una variacion en los rangos normales del nivel serico de glucosa que puede comprometer la salud",caracteristicasDefinitorias:["Hiperglucemia o hipoglucemia frecuentes","HbA1c fuera del objetivo"],factoresRelacionados:["Deficiencia absoluta de insulina","Inadecuada administracion de insulina","Alimentacion variable"]}],npiNic:[{codigo:"2130",nombre:"Manejo de la hipoglucemia",actividades:["Monitorizar glucemia antes de comidas","Administrar 15 g de CH ante glucemia < 70 mg/dL","Repetir glucemia a los 15 min","Glucagon si inconsciente","Identificar causa y modificar dosis futura"]},{codigo:"5614",nombre:"Educacion: dieta prescrita",actividades:["Ense\xf1ar conteo de carbohidratos","Relacion carbohidratos-insulina personalizada","Listado de alimentos y sus equivalencias en CHO"]}],npiNoc:[{codigo:"2300",nombre:"Nivel de glucemia",indicadores:["Glucemia preprandial 80-130 mg/dL","Glucemia postprandial < 180 mg/dL","HbA1c < 7%"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Cetoacidosis diabetica (emergencia)","Hipoglucemia severa con perdida de conciencia","Retinopatia diabetica (ceguera)","Nefropatia diabetica (insuficiencia renal)","Neuropatia periferica y autonomica","Pie diabetico con amputaciones","Macroangiopatia (IAM, ACV)","Lipodistrofia por inyecciones"],criteriosAlarma:["Glucemia < 54 mg/dL con sintomas o < 70 mg/dL sin sintomas (hipoglucemia)","Glucemia > 300 mg/dL","Cetonemia > 1.5 mmol/L","Vomitos con incapacidad de comer (cetoacidosis inminente)","Confusion o perdida de conciencia"],emergencyLevel:"leve",relatedPathologyIds:["pat_cetoacidosis","pat_dm2"],isPremium:!1},{id:"pat_dm2",nombre:"Diabetes Mellitus Tipo 2",bodySystemId:"endocrino",definicion:"Trastorno metabolico cronico progresivo caracterizado por hiperglucemia resultante de resistencia periferica a la insulina combinada con deficiencia relativa y progresiva de secrecion de insulina por las celulas beta pancre\xe1ticas.",epidemiologia:"Pandemia global: 537 millones de adultos con diabetes en 2021 (IDF). Representa el 90-95% de todos los casos de diabetes. Prevalencia en Argentina del 12.7%. Incremento del 16% desde 2014.",factoresRiesgo:["Obesidad (central/visceral es el principal factor modificable)","Sedentarismo","Historia familiar de DM2","Edad > 45 a\xf1os","Prediabetes previa","Hipertension arterial","Dislipemia","Diabetes gestacional previa","Sindrome de ovario poliquistico","Grupos etnicos de alto riesgo"],fisiopatologia:"La resistencia a la insulina en musculo e higado reduce la captacion de glucosa postprandial y aumenta la gluconeogenesis hepatica. Las celulas beta intentan compensar hipersecretando insulina, pero con el tiempo la demanda cronicacaga supera la capacidad beta, produciendo deficiencia relativa de insulina. El adipocito visceral produce adipoquinas proinflamatorias (TNF-alfa, IL-6, resistina) que perpetuan la resistencia. A diferencia de la DM1, no hay destruccion autoinmune sino agotamiento funcional progresivo.",signosYSintomas:{signos:["Glucemia en ayunas >= 126 mg/dL en dos ocasiones","Glucemia 2h postSOGT >= 200 mg/dL","HbA1c >= 6.5%","Acantosis nigricans (resistencia severa a la insulina)","Retinopatia al diagnostico (puede llevar a\xf1os asintomatico)"],sintomas:["Frecuentemente asintomatica (diagnostico casual)","Poliuria y polidipsia leves","Fatiga","Infecciones frecuentes (candidiasis, ITU)","Vision borrosa fluctuante","Cicatrizacion lenta de heridas"]},clasificacion:{nombre:"Clasificacion por control glucemico (HbA1c)",tipos:[{nombre:"Controlada",descripcion:"HbA1c < 7% (objetivo general). Algunas complicaciones pueden prevenirse"},{nombre:"Parcialmente controlada",descripcion:"HbA1c 7-8%. Riesgo moderado de complicaciones"},{nombre:"Mal controlada",descripcion:"HbA1c > 8-9%. Alto riesgo de complicaciones micro y macrovasculares"},{nombre:"Estado hiperosmolar hiperglucemico (EHH)",descripcion:"Glucemia > 600 mg/dL, osmolaridad > 320, deshidratacion severa sin cetosis"}]},diagnostico:{anamnesis:["Historia de sintomas diabeticos o hallazgo casual","Factores de riesgo presentes","Historia familiar","Medicacion que eleva la glucemia (corticoides, tiazidas)","Complicaciones ya presentes"],examenFisico:["Peso, talla, IMC, perimetro abdominal","PA (HTA frecuente)","Examen de los pies","Fondo de ojo si posible"],pruebas:[{nombre:"Glucemia en ayunas + HbA1c",descripcion:"Diagnostico y seguimiento del control metabolico",valoresReferencia:"HbA1c < 5.7% normal; 5.7-6.4% prediabetes; >= 6.5% DM. Objetivo terapeutico HbA1c < 7%",cuidadosEnfermeria:["Ayuno de 8-12h para glucemia basal","HbA1c: extraer en cualquier momento, refleja ultimos 3 meses"]},{nombre:"Perfil lipidico, creatinina, microalbuminuria",descripcion:"Evaluacion del riesgo cardiovascular y da\xf1o renal en DM2",valoresReferencia:"Objetivo DM2: LDL < 70 mg/dL con ECV o < 100 sin ECV; TFG > 60; albumina/creatinina < 30 mg/g",cuidadosEnfermeria:["Extraer en ayunas anualmente","Microalbuminuria en orina de ma\xf1ana (relacion albumina/creatinina)"]}]},tratamientoMedico:{objetivos:["HbA1c < 7% (individualizar: < 6.5% si joven sin complicaciones; < 8% si anciano o complicaciones severas)","Reducir riesgo cardiovascular (principal causa de muerte)","Proteccion renal y retiniana"],farmacologico:[{nombre:"Metformina",grupo:"Biguanida - primera linea universal en DM2",mecanismo:"Reduce gluconeogenesis hepatica y mejora la sensibilidad periferica a la insulina; no produce hipoglucemia",dosis:"500 mg c/12h con comidas, aumentar hasta 1000 mg c/12h (max 3 g/dia)",cuidadosEnfermeria:["Administrar con comidas para reducir efectos gastrointestinales (nauseas, diarrea)","Suspender 48h antes de contrastes yodados IV o cirugia mayor","Contraindicada si TFG < 30 mL/min","Riesgo de acidosis lactica en insuficiencia renal severa (muy raro)"]},{nombre:"Empagliflozin / Dapagliflozin (iSGLT2)",grupo:"Inhibidor del cotransportador sodio-glucosa tipo 2 - con beneficio cardiovascular y renal",mecanismo:"Inhibe la reabsorcion de glucosa en tubulo proximal renal, eliminandola en orina; reduce PA y peso",dosis:"Empagliflozin 10-25 mg/dia; Dapagliflozin 10 mg/dia",cuidadosEnfermeria:["Vigilar infecciones genitales (candidosis vulvovaginal/balanopostitis por glucosuria)","Vigilar infecciones urinarias","Hidratacion adecuada (riesgo de hipotension en ancianos)","Suspender antes de cirugia o ayuno prolongado (cetoacidosis eugluc\xe9mica rara)"]},{nombre:"Semaglutide / Liraglutide (aGLP-1)",grupo:"Agonista del receptor GLP-1 - con beneficio cardiovascular y perdida de peso",mecanismo:"Estimula secrecion de insulina glucosa-dependiente, inhibe glucagon, retarda vaciamiento gastrico, reduce apetito",dosis:"Semaglutide SC 0.25 mg/semana \u2192 0.5 mg \u2192 1 mg segun respuesta",cuidadosEnfermeria:["Nauseas frecuentes al inicio: escalar la dosis lentamente","Refrigerar hasta primer uso","Administrar el mismo dia cada semana (SC en abdomen, muslo o brazo)","Contraindicado en cancer medular de tiroides o MEN2"]},{nombre:"Insulina NPH o glargina (en DM2 avanzada)",grupo:"Insulina - cuando el tratamiento oral no alcanza el objetivo",mecanismo:"Suple la deficiencia progresiva de celulas beta en DM2 avanzada",dosis:"Insulina basal: 0.1-0.2 UI/kg/noche; ajustar 2 UI cada 3 dias hasta glucemia basal 80-130 mg/dL",cuidadosEnfermeria:["Educar sobre tecnica de inyeccion SC","Riesgos de hipoglucemia","Rotacion de zonas de inyeccion","Ajuste de dosis basal segun glucemia matutina"]}],noFarmacologico:["Modificacion de estilo de vida: piedra angular del tratamiento","Dieta: reduccion de CHO refinados, grasas saturadas; aumento de fibra","Actividad fisica: 150 min/semana de ejercicio aerobico moderado","Perdida de peso 5-10% si sobrepeso (mejora dramaticamente la glucemia)","Automonitoreo de glucemia capilar"],quirurgico:["Cirugia bariatrica (manga gastrica, bypass): remision de DM2 en el 60-80% de casos obesos; indicada si IMC > 35 con DM2 mal controlada"]},cuidadosEnfermeria:{valoracion:["Glucemia capilar en ayunas y 2h post-prandial","Peso, IMC, perimetro abdominal","PA en cada consulta","Examen de los pies en cada visita (Monofilamento, pulsos, temperatura)","HbA1c cada 3 meses hasta estabilizacion, luego cada 6 meses"],intervenciones:["Administrar antidiabeticos en horarios correctos (metformina con comidas)","Educar sobre automonitoreo glucemico","Plan de alimentacion adaptado y conteo de CHO basico","Educacion sobre cuidado de los pies y calzado adecuado","Derivar a podologia si lesiones en pie"],educacionPaciente:["Importancia del automonitoreo y como interpretar los resultados","Plan de alimentacion adaptado (no prohibir alimentos, reducir porciones CHO)","Actividad fisica: beneficios y precauciones","Cuidado de los pies: revision diaria, calzado adecuado","Reconocer hipoglucemia y como tratarla","No suspender medicacion sin consultar al medico"],monitorizacion:["Glucemia capilar segun pauta medica","HbA1c cada 3-6 meses","Creatinina, microalbuminuria anual","Perfil lipidico anual","Fondo de ojo anual","PA en cada consulta","Pie diabetico en cada consulta"]},npiNanda:[{codigo:"00179",nombre:"Riesgo de nivel de glucemia inestable",definicion:"Vulnerable a una variacion en los rangos normales del nivel serico de glucosa",caracteristicasDefinitorias:["HbA1c fuera de objetivo","Glucemias postprandiales elevadas"],factoresRelacionados:["Resistencia a la insulina","Deficit relativo de insulina","Inadecuada adherencia a dieta y medicacion"]},{codigo:"00078",nombre:"Gestion de salud ineficaz",definicion:"Patron inadecuado de regulacion e integracion del regimen terapeutico",caracteristicasDefinitorias:["No adherencia a dieta","Omision de medicacion","HbA1c elevada"],factoresRelacionados:["Complejidad del tratamiento","Conocimiento deficiente","Factores economicos"]}],npiNic:[{codigo:"2120",nombre:"Manejo de la hiperglucemia",actividades:["Monitorizar glucemia segun pauta","Administrar hipoglucemiantes e insulina segun indicacion","Educar sobre dieta y ejercicio","Identificar episodios de hiperglucemia y sus causas"]},{codigo:"5614",nombre:"Educacion: dieta prescrita",actividades:["Educacion sobre indice glucemico","Distribucion de carbohidratos en las comidas","Lectura de etiquetas nutricionales","Alternativas saludables a alimentos con alto IG"]}],npiNoc:[{codigo:"2300",nombre:"Nivel de glucemia",indicadores:["HbA1c < 7%","Glucemia preprandial 80-130 mg/dL","Glucemia 2h post-prandial < 180 mg/dL"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["IAM y ACV (principal causa de mortalidad en DM2)","Nefropatia diabetica (insuficiencia renal)","Retinopatia diabetica (ceguera)","Neuropatia periferica","Pie diabetico con amputacion","Estado hiperosmolar hiperglucemico (EHH)","Hipoglucemia por medicacion"],criteriosAlarma:["Glucemia > 400 mg/dL","Confucion o deterioro del estado de conciencia","Poliuria extrema con deshidratacion severa","Infeccion en pie diabetico con celulitis extensa o gangrena"],emergencyLevel:"leve",relatedPathologyIds:["pat_dm1","pat_cetoacidosis","pat_hta","pat_irc"],isPremium:!1},{id:"pat_hipotiroidismo",nombre:"Hipotiroidismo",bodySystemId:"endocrino",definicion:"Sindrome clinico producido por la deficiencia de hormonas tiroideas (T3, T4), que enlentece el metabolismo basal y los procesos fisiologicos. La causa mas frecuente en el mundo desarrollado es la tiroiditis de Hashimoto (autoinmune).",epidemiologia:"Prevalencia del 4-10% en la poblacion general, con predominio femenino (5:1). Hasta el 10% de las mujeres mayores de 65 a\xf1os. Hipotiroidismo subcl\xednico (TSH elevada con T4L normal) hasta el 15%.",factoresRiesgo:["Sexo femenino","Edad avanzada","Historia familiar de enfermedad tiroidea autoinmune","Otras enfermedades autoinmunes (DM1, LES)","Tratamiento previo con I131 o cirugia tiroidea","Medicacion: amiodarona, litio","Deficit de yodo (en paises en desarrollo)"],fisiopatologia:"En la tiroiditis de Hashimoto, anticuerpos anti-peroxidasa tiroidea (anti-TPO) y anti-tiroglobulina atacan la glandula tiroidea, produciendo inflamacion cronica y destruccion progresiva del tejido funcionante. La reduccion de T4 libre reduce el feed-back negativo sobre la hipofisis, elevando la TSH (hipotiroidismo primario). La deficiencia de T3 y T4 enlentece los procesos metabolicos, reduce el gasto cardiaco, altera el metabolismo lipidico (hipercolesterolemia) y produce acumulacion de mucopolisacaridos en el intersticio (mixedema).",signosYSintomas:{signos:["Piel seca, fria, palida y engrosada","Bradicardia","Reflexos osteotendinosos lentos (retardo de la fase de relajacion)","Edema facial y periorbitario","Macroglosia","Bocio (tiroiditis de Hashimoto)","Derrame pericardico y pleural en severo"],sintomas:["Fatiga y astenia intensa","Intolerancia al frio","Aumento de peso sin cambios dietarios","Constipacion cronica","Piel seca y caida del cabello","Voz grave y disfon\xeda","Menorragia (mujer)","Depresion y deterioro cognitivo"]},clasificacion:{nombre:"Clasificacion por grado",tipos:[{nombre:"Hipotiroidismo subcl\xednico",descripcion:"TSH elevada con T4L normal. Generalmente asintomatico. Tratamiento controversial"},{nombre:"Hipotiroidismo clinico (manifiesto)",descripcion:"TSH elevada con T4L baja. Sintomas presentes. Tratamiento indicado"},{nombre:"Coma mixedematoso",descripcion:"Hipotiroidismo severo con: hipotermia, bradicardia, confusion, hipoventilacion. Mortalidad > 20%"}]},diagnostico:{anamnesis:["Sintomas de enlentecimiento metabolico","Historia de enfermedades tiroideas o tratamientos","Medicacion tiroidea: amiodarona, litio","Historia familiar","Embarazo o post-parto (tiroiditis post-parto)"],examenFisico:["Palpacion del tiroides","FC (bradicardia)","Reflejos osteotendinosos","Piel y mucosas","Peso y edemas"],pruebas:[{nombre:"TSH (primera linea) + T4 libre",descripcion:"TSH elevada + T4L baja = hipotiroidismo primario confirmado. TSH normal + T4L baja = hipotiroidismo central (hipofisario, raro)",valoresReferencia:"TSH: 0.4-4.0 mUI/L normal. T4L: 0.8-1.8 ng/dL. Hipotiroidismo: TSH > 4.0 + T4L < 0.8",cuidadosEnfermeria:["No requiere ayuno","Extraer antes de tomar la levotiroxina del dia (si ya en tratamiento, la T4L puede estar elevada artificialmente)"]},{nombre:"Anticuerpos anti-TPO y anti-tiroglobulina",descripcion:"Confirman etiologia autoinmune (Hashimoto); positivos en > 90% de los casos",cuidadosEnfermeria:["Muestra venosa estandar","Resultado no modifica el tratamiento inicial"]}]},tratamientoMedico:{objetivos:["Normalizar la TSH (objetivo 0.5-2.5 mUI/L en la mayoria)","Aliviar sintomas","Prevenir coma mixedematoso"],farmacologico:[{nombre:"Levotiroxina sodica (LT4)",grupo:"Hormona tiroidea sintetica - reposicion hormonal",mecanismo:"Sustituto exogeno de la T4 natural; se convierte perifericamente en T3 activa",dosis:"1.6 mcg/kg/dia; iniciar 25-50 mcg/dia en ancianos/cardiacos, ajustar cada 6-8 semanas",cuidadosEnfermeria:["Administrar en AYUNAS, 30-60 min antes del desayuno","Separar 4h de calcio, hierro, anti\xe1cidos (reducen absorcion)","No mezclar con soja o fibra (reducen absorcion)","TSH de control a las 6-8 semanas de cada ajuste de dosis","En cardiaco: iniciar con dosis muy baja (12.5-25 mcg) y escalar lento (riesgo de angina)"]}],noFarmacologico:["No requiere modificacion de dieta especifica","Si bocio por deficit de yodo: sal yodada"],quirurgico:[]},cuidadosEnfermeria:{valoracion:["FC y PA (bradicardia e hipotension en severo)","Temperatura (hipotermia en grave)","Estado de conciencia","Edemas y piel","Constipacion: numero de deposiciones","Peso semanal"],intervenciones:["Administrar levotiroxina en ayunas segun indicacion","Calentar al paciente si hipotermia","Prevenir caidas (debilidad, edema)","Estimular la eliminacion intestinal (constipacion)","En coma mixedematoso: UCI, levotiroxina IV, glucocorticoides"],educacionPaciente:["Tomar levotiroxina siempre en ayunas y a la misma hora","Separar de calcio, hierro y anti\xe1cidos","Tratamiento de por vida: no suspender aunque se sienta bien","TSH de control regular (cada 6-12 meses cuando estable)","Informar al medico si hay cambio de marca (diferente biodisponibilidad)"],monitorizacion:["TSH a las 6-8 semanas de inicio o cambio de dosis","FC y PA en cada visita","Perfil lipidico (hipercolesterolemia mejora con tratamiento)","Peso en cada visita"]},npiNanda:[{codigo:"00093",nombre:"Fatiga",definicion:"Sensacion abrumadora y sostenida de agotamiento y disminucion de la capacidad para realizar actividades fisicas y mentales",caracteristicasDefinitorias:["Agotamiento extremo","Incapacidad para mantener actividades habituales","Letargo"],factoresRelacionados:["Deficit de hormonas tiroideas","Alteracion del metabolismo basal"]}],npiNic:[{codigo:"2380",nombre:"Manejo de la medicacion",actividades:["Ense\xf1ar administracion correcta de levotiroxina (ayunas, interacciones)","Importancia de no suspender el tratamiento","Control de TSH periodico"]}],npiNoc:[{codigo:"0005",nombre:"Tolerancia a la actividad",indicadores:["FC en rango normal con actividad","Fatiga reducida","Energia para actividades diarias"],escala:"1=Gravemente comprometido, 2=Sustancialmente, 3=Moderadamente, 4=Levemente, 5=No comprometido"}],complicaciones:["Coma mixedematoso (hipotermia, bradicardia, hipoventilacion, coma)","Cardiopatia por hipotiroidismo: bradicardia, derrame pericardico, IC","Hipercolesterolemia con riesgo cardiovascular","Sindrome del tunel carpiano","Infertilidad y abortos espontaneos","Neuropatia periferica"],criteriosAlarma:["Temperatura < 35\xb0C (hipotermia)","Glasgow disminuido","FC < 40 lpm","Hipoventilacion (hipercapnia)","Hiponatremia severa"],emergencyLevel:"leve",relatedPathologyIds:["pat_hipertiroidismo","pat_fa","pat_dm2"],isPremium:!1},{id:"pat_hipertiroidismo",nombre:"Hipertiroidismo",bodySystemId:"endocrino",definicion:"Sindrome clinico producido por exceso de hormonas tiroideas (T3, T4) que acelera el metabolismo basal. La causa mas frecuente es la enfermedad de Graves-Basedow (autoinmune), seguida del bocio multinodular toxico.",epidemiologia:"Prevalencia del 0.5-1% en la poblacion general. Predominio femenino 7:1. Enfermedad de Graves: causa del 70-80% del hipertiroidismo.",factoresRiesgo:["Sexo femenino","Historia familiar de enfermedad de Graves","Otras enfermedades autoinmunes","Estres fisico o psicologico intenso","Tabaquismo (riesgo de oftalmopatia en Graves)","Exceso de yodo (medicamentos, contrastes)","Amiodarona"],fisiopatologia:"En la enfermedad de Graves, los anticuerpos TRAb (anti-receptor de TSH) actuan como agonistas del receptor de TSH, estimulando la produccion de T3 y T4 sin regulacion. En el bocio multinodular toxico, nodulos tiroideos autonomos producen hormona en exceso independientemente de la TSH. El exceso de T3/T4 aumenta el metabolismo basal, la frecuencia cardiaca, la motilidad intestinal y la actividad simpaticomimetica.",signosYSintomas:{signos:["Bocio difuso (Graves) o multinodular","Exoftalmos (oftalmopatia de Graves)","Taquicardia o fibrilacion auricular","Piel caliente, humeda, con temblor fino","Reflejo osteotendinoso rapido (hiperreflexia)","Mixedema pretibial (Graves)"],sintomas:["Palpitaciones y taquicardia","Perdida de peso con aumento del apetito","Nerviosismo, irritabilidad, insomnio","Intolerancia al calor","Diarrea o deposiciones frecuentes","Debilidad muscular proximal","Oligomenorrea o amenorrea"]},clasificacion:{nombre:"Clasificacion por causa y severidad",tipos:[{nombre:"Enfermedad de Graves",descripcion:"Anticuerpos TRAb estimulantes. Bocio difuso, exoftalmos, mixedema pretibial"},{nombre:"Bocio multinodular toxico",descripcion:"Nodulos autonomos, comun en adultos mayores"},{nombre:"Adenoma toxico solitario",descripcion:"Nodulo autonomo unico hiperfuncionante"},{nombre:"Tormenta tiroidea",descripcion:"Hipertiroidismo extremo con fallo multiorganico. Mortalidad 20-30%."}]},diagnostico:{anamnesis:["Sintomas de aceleracion metabolica","Palpitaciones y perdida de peso","Historia familiar de Graves","Amiodarona u otros medicamentos yodados"],examenFisico:["Bocio: tamano, consistencia, soplo","Exoftalmos (proptosis) y signos oculares en Graves","Taquicardia/FA","Temblor fino en manos","Mixedema pretibial"],pruebas:[{nombre:"TSH suprimida + T4 libre y T3 libre elevadas",descripcion:"TSH < 0.1 con T4L y T3L elevadas confirma hipertiroidismo manifiesto",valoresReferencia:"TSH < 0.1 mUI/L; T4L > 1.8 ng/dL; T3L > 4 pg/mL",cuidadosEnfermeria:["No requiere ayuno","Resultado orienta causa y tratamiento"]},{nombre:"Anticuerpos TRAb (Ac anti-receptor de TSH)",descripcion:"Confirman enfermedad de Graves; positivos en > 95% de casos",cuidadosEnfermeria:["Muestra venosa estandar","Su negativizacion indica remision con tratamiento antitiroideos"]}]},tratamientoMedico:{objetivos:["Controlar el exceso de hormona tiroidea","Tratar la causa (especialmente en Graves)","Prevenir tormenta tiroidea"],farmacologico:[{nombre:"Metimazol / Propiltiouracilo (PTU)",grupo:"Antitiroideos - frenadores de la sintesis de hormonas tiroideas",mecanismo:"Inhiben la peroxidasa tiroidea, bloqueando la organificacion del yodo y la sintesis de T3/T4. PTU ademas bloquea la conversion periferica de T4 a T3",dosis:"Metimazol: 10-40 mg/dia. PTU: 100-400 mg c/8h",cuidadosEnfermeria:["Agranulocitosis: vigilar fiebre y faringitis (suspender y hemograma urgente)","Funcion hepatica: hepatotoxicidad especialmente con PTU","Erupcion cutanea: efecto adverso frecuente","PTU es el de eleccion en el primer trimestre del embarazo"]},{nombre:"Propranolol",grupo:"Betabloqueante - control sintomatico",mecanismo:"Reduce los efectos simpaticos del exceso de hormona tiroidea: taquicardia, temblor, ansiedad",dosis:"10-40 mg c/6-8h VO",cuidadosEnfermeria:["Controlar FC antes de administrar","Alivio sintomatico rapido mientras los antitiroideos hacen efecto (6-8 semanas)","No usar en asmaticos"]}],noFarmacologico:["Restriccion de actividad en fase aguda","Evitar yodo excesivo en dieta (mariscos, sal yodada en exceso)"],quirurgico:["Tiroidectomia total o subtotal: si bocio grande, sospecha de malignidad, embarazo 2do trimestre","Iodo radioactivo (I131): de eleccion en adultos con Graves o bocio multinodular toxico (destruccion selectiva del tejido tiroideo)"]},cuidadosEnfermeria:{valoracion:["FC y PA (taquicardia, HTA)","Temperatura","Peso (perdida de peso)","Nivel de ansiedad y nerviosismo","Oftalmopatia: enrojecimiento, proptosis, fotofobia"],intervenciones:["Ambiente tranquilo y fresco","Administrar antitiroideos y betabloqueantes segun indicacion","Cuidados oculares en exoftalmos (lagrimas artificiales, parches nocturnos)","Soporte nutricional: dieta hipercalorica por hipermetabolismo","Reposo relativo"],educacionPaciente:["Tomar antitiroideos a horarios exactos","Reportar urgente: fiebre, dolor de garganta, ictericia (agranulocitosis, hepatitis)","Uso de gafas de sol y lagrimas artificiales en oftalmopatia","Evitar exceso de yodo en la dieta","Controles periodicos de TSH, T4L y TRAb"],monitorizacion:["FC y PA cada 4-6h en fase activa","Peso diario","Temperatura (tormenta tiroidea: fiebre > 40\xb0C + taquicardia extrema)","TSH y T4L cada 4-6 semanas en tratamiento","Hemograma ante fiebre o faringitis (agranulocitosis)"]},npiNanda:[{codigo:"00029",nombre:"Disminucion del gasto cardiaco",definicion:"Cantidad insuficiente de sangre bombeada por el corazon",caracteristicasDefinitorias:["Taquicardia","Palpitaciones","Fibrilacion auricular"],factoresRelacionados:["Exceso de hormonas tiroideas con efecto cronotropo e inotropo positivo"]}],npiNic:[{codigo:"2080",nombre:"Manejo de la terapia de reemplazo hormonal",actividades:["Administrar antitiroideos segun indicacion","Monitorizar TSH y T4L periodicamente","Vigilar efectos adversos (agranulocitosis)"]}],npiNoc:[{codigo:"0400",nombre:"Efectividad de la bomba cardiaca",indicadores:["FC 60-100 lpm","Sin fibrilacion auricular","Sin palpitaciones"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Tormenta tiroidea (emergencia, mortalidad 20-30%)","Fibrilacion auricular y ACV embolico","Osteoporosis por hipercortisolismo tiroideo","Oftalmopatia severa (perdida de vision)","Insuficiencia cardiaca de alto gasto","Hipotiroidismo post-tratamiento (especialmente post-I131)"],criteriosAlarma:["FC > 150 lpm o FA de nuevo inicio","Temperatura > 39\xb0C + taquicardia extrema (tormenta tiroidea)","Fiebre + faringitis (agranulocitosis por antitiroideos)","Proptosis ocular severa con quemosis","Confusion o agitacion extrema"],emergencyLevel:"moderado",relatedPathologyIds:["pat_hipotiroidismo","pat_fa"],isPremium:!0},{id:"pat_cetoacidosis",nombre:"Cetoacidosis Diabetica",bodySystemId:"endocrino",definicion:"Emergencia metabolica de la diabetes mellitus, principalmente tipo 1, caracterizada por la triada: hiperglucemia (> 250 mg/dL), acidosis metabolica (pH < 7.30) y cetosis/cetonemia, producida por deficiencia absoluta o relativa de insulina con exceso de hormonas contrarreguladoras.",epidemiologia:"Incidencia de 4-8 episodios/1000 pacientes con DM1/ano. Mortalidad < 1% con tratamiento adecuado. Principal causa de muerte en ni\xf1os y jovenes con DM1. Precipitante mas frecuente: infeccion (40%), omision de insulina (25%).",factoresRiesgo:["Omision de insulina o dosis insuficiente","Infeccion (precipitante mas frecuente)","IAM, ACV, pancreatitis (estres fisiologico)","Debut de DM1 (primera manifestacion)","Uso de cocaina o alcohol","Glucocorticoides en altas dosis","iSGLT2 en DM2 (cetoacidosis eugluc\xe9mica)"],fisiopatologia:"La deficiencia absoluta de insulina permite: 1) Hiperglucemia por gluconeogenesis hepatica sin freno y falta de captacion periferica. 2) Lipolisis sin freno de tejido graso, produciendo acidos grasos libres que el higado convierte en cuerpos cetonicos (beta-hidroxibutirato, acetoacetato). 3) Los cuerpos cetonicos (acidos fuertes) producen acidosis metabolica con anion gap elevado. La hiperglucemia produce diuresis osmotica con perdida de electrolitos (K+, Na+, Cl-).",signosYSintomas:{signos:["Respiracion de Kussmaul (respiracion rapida, profunda, caracteristica)","Aliento cet\xf3sico (olor a fruta o acetona)","Deshidratacion (mucosas secas, turgencia reducida)","Taquicardia e hipotension","Obnubilacion en casos graves"],sintomas:["Nauseas y vomitos","Dolor abdominal difuso (puede simular abdomen agudo)","Poliuria y polidipsia","Debilidad extrema","Confusion en acidosis grave (pH < 7.0)"]},clasificacion:{nombre:"Clasificacion por severidad",tipos:[{nombre:"CAD leve",descripcion:"Glucemia > 250, pH 7.25-7.30, bicarbonato 15-18, consciente"},{nombre:"CAD moderada",descripcion:"pH 7.00-7.24, bicarbonato 10-15, somnolencia"},{nombre:"CAD grave",descripcion:"pH < 7.0, bicarbonato < 10, estupor/coma, anion gap > 20"}]},diagnostico:{anamnesis:["Diabetico tipo 1 conocido (o debut)","Infeccion reciente","Omision de insulina","Vomitos que impiden comer"],examenFisico:["Signos de deshidratacion","Kussmaul","Nivel de conciencia","Buscar foco infeccioso desencadenante"],pruebas:[{nombre:"Gasometria arterial o venosa",descripcion:"pH < 7.30 + bicarbonato < 18 confirman acidosis. Anion gap = Na - (Cl + HCO3) > 12 mEq/L",valoresReferencia:"pH normal 7.35-7.45; HCO3 22-26; Anion gap normal 8-12 mEq/L",cuidadosEnfermeria:["Gasometria venosa es suficiente para monitoreo (correlaciona bien con pH arterial)","Extraer junto a ionograma para calcular anion gap"]},{nombre:"Glucemia capilar + cetonemia",descripcion:"Glucemia > 250 mg/dL + cetonemia > 3 mmol/L = CAD. Cetonemia es el mejor marcador de resolucion",valoresReferencia:"Cetonemia < 0.6 = normal; > 3.0 = CAD activa",cuidadosEnfermeria:["Glucemia capilar cada hora en la insulinoterapia","Cetonemia cada 2-4h para monitorizar resolucion"]},{nombre:"Potasio serico",descripcion:"CRITICO: la insulinoterapia desplaza K+ al interior celular, produciendo hipopotasemia grave",valoresReferencia:"Normal 3.5-5.0 mEq/L. En CAD puede estar falsamente normal o alto al inicio por acidosis",cuidadosEnfermeria:["NO iniciar insulina hasta potasio > 3.3 mEq/L","Reposicion de potasio ANTES de insulina si K < 3.5","Monitorizar K+ cada 1-2h en primeras horas"]}]},tratamientoMedico:{objetivos:["Resolucion de la cetosis y acidosis","Normalizacion de la glucemia de forma gradual","Identificar y tratar el factor precipitante"],farmacologico:[{nombre:"Insulina regular IV en perfusion",grupo:"Insulina de accion rapida IV - tratamiento especifico de CAD",mecanismo:"Suprime la lipolisis y la cetogenesis; permite la captacion de glucosa; revierte la acidosis",dosis:"0.1 UI/kg/h en perfusion continua IV (no se recomienda bolo inicial segun guias actuales)",cuidadosEnfermeria:["Preparar: 50 UI insulina regular en 500 mL SF = 0.1 UI/mL","Glucemia HORARIA: reducir glucemia no mas de 50-75 mg/dL/h","NO bajar glucemia a < 200 hasta que cetonemia < 0.6","Al llegar a 200: agregar glucosa 5% + reducir infusion de insulina","Riesgo de hipopotasemia: potasio cada 1-2h"]},{nombre:"Solucion salina fisiologica 0.9%",grupo:"Cristaloide - resucitacion hidroelectrolitica",mecanismo:"Repone el volumen circulante perdido por diuresis osmotica severa",dosis:"Primeras 2h: 1000 mL/h o segun estado hemodinamico; luego 500 mL/h; reducir a 250 mL/h segun respuesta",cuidadosEnfermeria:["Resucitacion vigorosa en primeras 2h","Monitorizar diuresis cada hora (objetivo > 0.5 mL/kg/h)","Vigilar sobrecarga de liquidos en cardiaco o renal"]},{nombre:"Cloruro de potasio (KCl)",grupo:"Electrolito - reposicion de potasio",mecanismo:"Repone el deficit de potasio que se desarrolla con la insulinoterapia",dosis:"Si K+ 3.3-5.0: agregar 20-40 mEq/L de suero. Si K < 3.3: SUSPENDER INSULINA y reponer 40-60 mEq/h",cuidadosEnfermeria:["NUNCA IV DIRECTO (mortal)","Diluir y administrar por bomba de perfusion","ECG continuo para detectar hiperpotasemia o hipopotasemia","Potasio cada 1-2h en primeras horas"]}],noFarmacologico:["Ayuno y sonda nasogastrica si vomitos o nivel de conciencia reducido","Cateter urinario para diuresis horaria","Tratar factor precipitante (antibioticos si infeccion)"],quirurgico:[]},cuidadosEnfermeria:{valoracion:["Glucemia capilar horaria","Diuresis horaria rigurosa","Balance hidrico cada hora en primeras horas","Nivel de conciencia (Glasgow) cada 1-2h","Signos vitales cada 30-60 min","Signos de edema cerebral en ni\xf1os (cefalea, bradicardia, PA alta)"],intervenciones:["Dos vias venosas perifericas de grueso calibre + via para insulina IV exclusiva","Sonda vesical para diuresis horaria","Preparar y administrar insulina IV segun protocolo","Reposicion agresiva de liquidos IV segun protocolo","Reposicion de potasio segun valores seriados","Monitorizar ECG por alteraciones electroliticas"],educacionPaciente:["Nunca suspender la insulina durante una infeccion o enfermedad","Protocolo de dias de enfermedad: mas glucemias, mas cetonas, hidratar","Cetonemia: cuando medir y que significa","Cuando acudir a urgencias: vomitos repetidos, glucemia > 300 pese a insulina, cetones altos"],monitorizacion:["Glucemia capilar HORARIA","Cetonemia cada 2-4h","Electrolitos cada 2h primeras 8h","Gasometria cada 4-6h","Diuresis horaria","Glasgow horario","ECG continuo"]},npiNanda:[{codigo:"00028",nombre:"Riesgo de deficit de volumen de liquidos",definicion:"Vulnerable a sufrir deshidratacion vascular, celular o intracelular",caracteristicasDefinitorias:["Poliuria osmotica","Vomitos","Deshidratacion clinica"],factoresRelacionados:["Diuresis osmotica por hiperglucemia","Vomitos incoercibles"]},{codigo:"00195",nombre:"Riesgo de desequilibrio electrolitico",definicion:"Vulnerable a cambios en los niveles de electrolitos sericos",caracteristicasDefinitorias:["Hipopotasemia inducida por insulina","Perdida de electrolitos por diuresis"],factoresRelacionados:["Insulinoterapia intensiva","Diuresis osmotica","Acidosis metabolica"]}],npiNic:[{codigo:"2130",nombre:"Manejo de la hipoglucemia",actividades:["Glucemia horaria estricta","Detectar descenso rapido de glucemia","Ajustar infusion de insulina segun protocolo","Agregar glucosa cuando glucemia < 200 mg/dL"]},{codigo:"4130",nombre:"Monitorizacion de liquidos",actividades:["Diuresis horaria rigurosa","Balance hidrico cada hora","Electrolitos seriados cada 1-2h","Reposicion de potasio segun valores"]}],npiNoc:[{codigo:"0601",nombre:"Equilibrio hidroelectrolitico",indicadores:["Potasio 3.5-5.0 mEq/L","Glucemia < 200 mg/dL","pH > 7.30","Cetonemia < 0.6"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Edema cerebral (principalmente en ni\xf1os, mortal)","Hipopotasemia grave durante tratamiento (arritmias)","Hipoglucemia por sobredosis de insulina","Hipofosfatemia","Trombosis venosa profunda (deshidratacion)","Muerte"],criteriosAlarma:["K+ < 3.0 o > 6.0 mEq/L","pH < 7.0 o deterioro rapido","Glasgow disminuido o deterioro subito (edema cerebral)","Glucemia < 60 mg/dL","Diuresis < 30 mL/h pese a resucitacion"],emergencyLevel:"critico",relatedPathologyIds:["pat_dm1","pat_dm2"],isPremium:!0},{id:"pat_addison",nombre:"Enfermedad de Addison",bodySystemId:"endocrino",definicion:"Insuficiencia suprarrenal primaria cronica por destruccion de la corteza suprarrenal (autoinmune en el 70-90%), produciendo deficit de glucocorticoides (cortisol), mineralocorticoides (aldosterona) y andr\xf3genos suprarrenales.",epidemiologia:"Prevalencia de 1-2/10.000 personas. Causa autoinmune en > 70% en paises desarrollados. La crisis suprarrenal (emergencia) puede ser la forma de presentacion en casos no diagnosticados.",factoresRiesgo:["Enfermedades autoinmunes previas (tiroiditis, DM1, LES)","Historia familiar de Addison autoinmune","Infecciones (tuberculosis, CMV en VIH)","Anticoagulacion (hemorragia suprarrenal)","Metastasis suprarrenales (pulmon, mama)"],fisiopatologia:"La destruccion de la corteza suprarrenal reduce la produccion de cortisol (esencial para la homeostasis del estres, gluconeogenesis, respuesta inflamatoria) y aldosterona (esencial para retencion de sodio y excrecion de potasio). La perdida de cortisol elimina el freno sobre la hipofisis, elevando ACTH y MSH, produciendo la hiperpigmentacion caracteristica. La aldosterona baja produce hiponatremia, hiperpotasemia, hipotension y crisis de deplecion salina en situaciones de estres.",signosYSintomas:{signos:["Hiperpigmentacion de piel y mucosas (pliegues, cicatrices, ar\xe9olas, mucosa oral)","Hipotension ortost\xe1tica","Hiperpotasemia e hiponatremia en anal\xedtica","Hipoglucemia en ayunas","Perdida de vello pubico y axilar (androgenos)"],sintomas:["Fatiga y debilidad extrema (astenia)","Perdida de peso y anorexia","Nauseas, vomitos y dolor abdominal","Deseo de sal (por perdida de aldosterona)","Mareos e hipotension","Depresion y irritabilidad"]},clasificacion:{nombre:"Tipos de insuficiencia suprarrenal",tipos:[{nombre:"ISR primaria (Addison)",descripcion:"Destruccion de la corteza suprarrenal. ACTH elevada. Hiperpigmentacion. Deficit de cortisol + aldosterona"},{nombre:"ISR secundaria",descripcion:"Deficit de ACTH hipofisario. Sin hiperpigmentacion. Solo deficit de cortisol (aldosterona conservada)"},{nombre:"Crisis suprarrenal (Addison agudo)",descripcion:"Insuficiencia suprarrenal aguda: hipotension, hiponatremia severa, hipoglucemia, shock. EMERGENCIA"}]},diagnostico:{anamnesis:["Fatiga cronica, perdida de peso, hipotension","Historia de enfermedades autoinmunes","Uso de corticoides previos y suspension brusca (ISR secundaria)","Infecciones recurrentes"],examenFisico:["Hiperpigmentacion caracteristica","PA (hipotension ortost\xe1tica)","Peso","Signos de deshidratacion"],pruebas:[{nombre:"Cortisol basal (ma\xf1ana, 8 AM) + ACTH",descripcion:"Cortisol < 3 mcg/dL confirma ISR. Cortisol > 18 descarta ISR. ACTH elevada en ISR primaria",valoresReferencia:"Cortisol 8 AM normal > 18 mcg/dL. ACTH normal 10-50 pg/mL",cuidadosEnfermeria:["Extraer a las 8 AM (pico diurno de cortisol)","Manejar la muestra rapidamente (degradacion rapida)"]},{nombre:"Test de estimulacion con Synacthen (ACTH sintetica)",descripcion:"250 mcg de ACTH IV/IM; cortisol a los 30 y 60 min. Normal si cortisol > 18 mcg/dL",cuidadosEnfermeria:["Extraer cortisol basal, inyectar Synacthen y re-extraer a 30 y 60 min","No suspender hidrocortisona el dia del test (interferencia)"]}]},tratamientoMedico:{objetivos:["Reposicion de cortisol y aldosterona de por vida","Educacion del paciente sobre ajuste de dosis en situaciones de estres","Prevencion y tratamiento de la crisis suprarrenal"],farmacologico:[{nombre:"Hidrocortisona",grupo:"Glucocorticoide - reposicion de cortisol",mecanismo:"Reemplaza el cortisol deficiente con perfil de dosificacion que imita el ritmo circadiano natural",dosis:"15-25 mg/dia VO en 2-3 dosis: mayor dosis por la ma\xf1ana (10-15 mg al despertar + 5-10 mg al mediodia)",cuidadosEnfermeria:["Tomar la primera dosis AL DESPERTAR para imitar ritmo fisiologico","Regla de dosis de estres: doblar o triplicar la dosis ante enfermedad, trauma, cirugia","En cirugia o procedimiento con anestesia: hidrocortisona 100 mg IV peri-operatorio","Nunca suspender abruptamente"]},{nombre:"Fludrocortisona",grupo:"Mineralocorticoide - reposicion de aldosterona",mecanismo:"Reemplaza la aldosterona: retiene sodio, excreta potasio, mantiene la PA",dosis:"0.05-0.15 mg/dia VO en dosis unica",cuidadosEnfermeria:["Monitorizar PA y electrolitos","Ajustar con cambios de temperatura (mas en calor por mayor perdida de sodio por sudor)"]},{nombre:"Hidrocortisona 100 mg IV (crisis suprarrenal)",grupo:"Glucocorticoide IV de emergencia",mecanismo:"Dosis suprafisiologica que resuelve rapidamente la crisis suprarrenal aguda",dosis:"100 mg IV en bolo, luego 100-200 mg en perfusion continua/24h o 50 mg IV c/6h",cuidadosEnfermeria:["Administrar INMEDIATAMENTE ante crisis (no esperar diagnostico)","Luego solucion salina IV 1 L en la primera hora","Vigilar hipoglucemia durante la crisis","Transicion a via oral cuando clinica mejore"]}],noFarmacologico:["Dieta con sal adecuada (no restringir)","Educacion exhaustiva sobre la regla de dosis de estres","Identificacion medica de urgencia (pulsera, tarjeta)"],quirurgico:[]},cuidadosEnfermeria:{valoracion:["PA ortostatica (hipotension es un signo guia)","Glucemia (hipoglucemia frecuente)","Ionograma (hiponatremia, hiperpotasemia)","Signos de crisis: hipotension, confusion, fiebre","Adherencia al tratamiento sustitutivo"],intervenciones:["Administrar hidrocortisona y fludrocortisona segun indicacion","Crisis suprarrenal: hidrocortisona IV + SF IV URGENTE","Identificar factor precipitante de la crisis","Vigilar hipoglucemia"],educacionPaciente:["Regla de dosis de estres: doblar dosis ante enfermedad febril leve, triplicar ante enfermedad severa","Nunca suspender el tratamiento","Llevar SIEMPRE jeringa precargada de hidrocortisona de emergencia","Pulsera de alerta medica","Informar a medicos, dentistas, etc. de la enfermedad antes de cualquier procedimiento"],monitorizacion:["PA en cada consulta y ortostatica","Ionograma mensual hasta estabilizacion","Glucemia en situaciones de estres o enfermedad","Peso y signos de sobre o infratratamiento corticoide"]},npiNanda:[{codigo:"00028",nombre:"Riesgo de deficit de volumen de liquidos",definicion:"Vulnerable a sufrir deshidratacion",caracteristicasDefinitorias:["Hipotension ortost\xe1tica","Hiponatremia"],factoresRelacionados:["Deficit de aldosterona","Perdida de sodio y agua"]}],npiNic:[{codigo:"2080",nombre:"Manejo de la terapia de reemplazo hormonal",actividades:["Administrar hidrocortisona y fludrocortisona segun indicacion","Educar sobre regla de dosis de estres","Monitorizar PA y electrolitos"]}],npiNoc:[{codigo:"0401",nombre:"Estado circulatorio",indicadores:["PA sistolica > 100 mmHg","Sin hipotension ortost\xe1tica","Sodio y potasio en rango normal"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Crisis suprarrenal (shock, mortalidad sin tratamiento)","Hipoglucemia severa","Osteoporosis por tratamiento corticoide a largo plazo","Infecciones oportunistas por insuficiencia inmune relativa"],criteriosAlarma:["Hipotension sistolica < 90 mmHg","Confusion o deterioro del nivel de conciencia","Fiebre > 38.5\xb0C (infeccion que puede precipitar crisis)","Hiponatremia < 125 mEq/L","Hipoglucemia < 50 mg/dL"],emergencyLevel:"moderado",relatedPathologyIds:["pat_hipotiroidismo","pat_dm1"],isPremium:!0},{id:"pat_irc",nombre:"Insuficiencia Renal Cronica",bodySystemId:"renal_urinario",definicion:"Perdida progresiva e irreversible de la funcion renal (TFG < 60 mL/min/1.73m2 durante mas de 3 meses) con o sin lesion renal, produciendo retencion de metabolitos nitrogenados, alteraciones hidroelectroliticas y endocrinas.",epidemiologia:"Prevalencia del 10-13% en la poblacion adulta mundial. En estadio 5 (dialisis): 0.1%. Causa principal de dialisis: diabetes mellitus (40%) e hipertension arterial (25%). Mortalidad cardiovascular aumentada 10-30x respecto a la poblacion general.",factoresRiesgo:["Diabetes mellitus tipo 2 (principal causa)","Hipertension arterial","Enfermedad cardiovascular establecida","Obesidad","Historia familiar de enfermedad renal","Edad avanzada","Nefrotoxicos: AINEs, aminoglucosidos, contrastes","Enfermedad autoinmune (LES, vasculitis)"],fisiopatologia:"La perdida de nefronas por la enfermedad subyacente activa mecanismos compensadores: hiperfiltacion de las nefronas restantes que, con el tiempo, produce glomeruloesclerosis focal y progresion. El SRAA se activa, produciendo HTA y da\xf1o adicional. La perdida de funcion renal produce: retencion de uratos, fosfatos y otras toxinas uremicas; alteracion del metabolismo del calcio y fosforo (hiperparatiroidismo secundario); deficit de eritropoyetina (anemia normo-cromica normo-citica); acidosis metabolica.",signosYSintomas:{signos:["Hipertension arterial de dificil control","Anemia normocitica (palidez)","Edema perimaleolar bilateral","Retension de liquidos","Prurito (uremia)","Pericarditis ur\xe9mica en estadio 5","Aliento ur\xe9mico"],sintomas:["Fatiga y debilidad creciente","Nauseas y anorexia (uremia)","Prurito generalizado","Calambres musculares","Oliguria en estadios avanzados","Insomnio y sindrome de piernas inquietas","Confusion ur\xe9mica en fase terminal"]},clasificacion:{nombre:"Estadios KDIGO segun TFG",tipos:[{nombre:"G1 - Normal o alta",descripcion:"TFG >= 90 con marcadores de lesion renal. Sin sintomas"},{nombre:"G2 - Ligeramente reducida",descripcion:"TFG 60-89 con marcadores de lesion renal"},{nombre:"G3a/b - Moderadamente reducida",descripcion:"TFG 30-59. Inicio de complicaciones metabolicas"},{nombre:"G4 - Gravemente reducida",descripcion:"TFG 15-29. Preparacion para terapia renal sustitutiva"},{nombre:"G5 - Fallo renal (estadio 5)",descripcion:"TFG < 15. Dialisis o trasplante necesarios"}]},diagnostico:{anamnesis:["Diabetes o HTA de larga evolucion","Historia familiar de enfermedad renal","Uso de nefrotoxicos (AINEs cronicos)","Episodios previos de insuficiencia renal aguda"],examenFisico:["PA (HTA)","Edemas","Soplo renal (estenosis arteria renal)","Fundoscopia (retinopatia hipertensiva/diabetica)"],pruebas:[{nombre:"Creatinina serica y calculo de TFG (CKD-EPI)",descripcion:"TFG estimada por la formula CKD-EPI a partir de creatinina, edad y sexo",valoresReferencia:"TFG > 90 = normal; 60-89 = leve reduccion; 30-59 = moderada; < 30 = grave; < 15 = fallo renal",cuidadosEnfermeria:["No requiere ayuno especial","La creatinina sola no refleja bien la TFG en ancianos o caquecticos"]},{nombre:"Relacion albumina/creatinina en orina",descripcion:"Marcador de lesion glomerular (albuminuria). Se usa junto a la TFG para estadificar IRC",valoresReferencia:"< 30 mg/g = normal; 30-300 = microalbuminuria (A2); > 300 = macroalbuminuria (A3)",cuidadosEnfermeria:["Primera orina de la ma\xf1ana (muestra puntual)","Evitar despues de ejercicio intenso o infeccion urinaria (eleva falsamente)"]},{nombre:"Electrolitos, calcio, fosforo, PTH, hemograma",descripcion:"Detecta complicaciones metabolicas de la IRC: hiperpotasemia, hiperfosfatemia, hipocalcemia, HPT2, anemia",cuidadosEnfermeria:["Extraer en ayunas","PTH: manejar en frio","En estadio G4-G5: monitorizar mensualmente"]}]},tratamientoMedico:{objetivos:["Frenar la progresion de la IRC","Tratar complicaciones (anemia, HTA, HPT2)","Preparacion para terapia renal sustitutiva"],farmacologico:[{nombre:"IECA / ARA-II (Ramipril, Losartan)",grupo:"Nefroprotectores - reducen la hiperfiltacion y proteinuria",mecanismo:"Reducen la presion intraglomerular dilantando la arteriola eferente, reduciendo proteinuria y progresion de la IRC",dosis:"Ramipril 5-10 mg/dia; Losartan 50-100 mg/dia",cuidadosEnfermeria:["Monitorizar creatinina y potasio tras inicio (aumento de creatinina < 30% es aceptable)","Hiperpotasemia: contraindicado con K+ > 5.5","Suspender si hiperpotasemia o caida de TFG > 30% en 4 semanas"]},{nombre:"Eritropoyetina recombinante (EPO)",grupo:"Factor estimulante de eritropoyesis - tratamiento de anemia renal",mecanismo:"Estimula la eritropoyesis en medula osea; suple el deficit de EPO endogena por fallo renal",dosis:"Epoetina alfa: 50-150 UI/kg SC 3 veces/semana; ajustar segun Hb",cuidadosEnfermeria:["Objetivo de Hb: 10-11.5 g/dL (no > 12 por riesgo cardiovascular)","Verificar ferritina > 200 ng/mL y saturacion de transferrina > 20% antes de EPO","Hipertension: efecto adverso frecuente","Trombosis de la fistula en dializado"]},{nombre:"Sevelamer / Carbonato de calcio",grupo:"Quelante de fosforo - hiperfosfatemia renal",mecanismo:"Se une al fosforo de los alimentos en el intestino, impidiendo su absorcion",dosis:"Sevelamer 800-1600 mg con cada comida",cuidadosEnfermeria:["Administrar CON LAS COMIDAS (accion en el intestino)","No triturar comprimidos de sevelamer","Carbonato de calcio: preferible si hay hipofosfatemia concomitante pero aumenta el calcio"]},{nombre:"Bicarbonato sodico",grupo:"Alcalinizante - acidosis metabolica de IRC",mecanismo:"Repone el bicarbonato perdido por el ri\xf1on insuficiente, corrigiendo la acidosis metabolica",dosis:"500-1000 mg c/8-12h VO (ajustar segun HCO3 serico)",cuidadosEnfermeria:["Objetivo: HCO3 > 22 mEq/L","La acidosis acelera la progresion de la IRC y la desmineralizacion osea"]}],noFarmacologico:["Dieta hipoprot\xe9ica moderada (0.6-0.8 g/kg/dia en no dialiticos)","Restriccion de potasio y fosforo segun niveles","Restriccion de sodio < 2 g/dia si HTA o edemas","Control estricto de HTA (PA < 130/80)","Control glucemico optimo en diabeticos","Acceso vascular: preservar venas del brazo no dominante para futuras fistulas"],quirurgico:["Fistula arteriovenosa (FAV) para hemodialisis (crear cuando TFG < 25 mL/min)","Trasplante renal: mejor tratamiento para calidad de vida y supervivencia en IRC G5"]},cuidadosEnfermeria:{valoracion:["PA en cada consulta (objetivo < 130/80)","Peso diario (retencion hidrica)","Balance hidrico","Diuresis: si oliguria o anuria","Signos de uremia: prurito, nauseas, confusion","Signos de sobrecarga hidrica: edemas, disnea","Evaluar acceso vascular en dialiticos"],intervenciones:["Administrar medicacion segun indicacion","Restriccion de liquidos segun diuresis residual","Cuidados del acceso vascular (fistula o cateter de dialisis)","Dieta adaptada (baja en K, P, Na, proteinas)","Educacion para el autocuidado"],educacionPaciente:["Dieta renal: alimentos ricos en K, P y Na que deben restringirse","Control de la PA domiciliaria","Importancia del seguimiento regular","Opciones de terapia renal sustitutiva (hemodialisis, dialisis peritoneal, trasplante)","Cuidado de la fistula arteriovenosa (no sacar sangre, no tomar la PA en ese brazo)"],monitorizacion:["TFG seriada (cada 3-6 meses en G3-G4, mensual en G5)","Potasio, fosforo, calcio, PTH segun estadio","Hb y ferritina mensual en tratamiento con EPO","PA en cada visita","Proteinuria en orina"]},npiNanda:[{codigo:"00025",nombre:"Exceso de volumen de liquidos",definicion:"Aumento de la retencion de liquidos isotonicos",caracteristicasDefinitorias:["Edema bilateral","HTA","Disnea","Aumento de peso"],factoresRelacionados:["Incapacidad renal para excretar agua y sodio","Reduccion de diuresis"]},{codigo:"00002",nombre:"Desequilibrio nutricional: ingestion inferior a las necesidades",definicion:"Ingestion de nutrientes insuficiente para satisfacer las necesidades metabolicas",caracteristicasDefinitorias:["Anorexia","Nauseas por uremia","Perdida de peso"],factoresRelacionados:["Toxinas uremicas que reducen el apetito","Restriccion dietetica"]}],npiNic:[{codigo:"4120",nombre:"Manejo de liquidos",actividades:["Restriccion hidrica segun diuresis","Peso diario","Balance hidrico","Monitorizar edemas y PA","Dieta restricta en sodio"]},{codigo:"4210",nombre:"Manejo del acceso de dialisis",actividades:["Auscultacion de fr\xe9mito en FAV en cada turno","No tomar PA ni punciones en brazo con FAV","Cuidados del sitio de insercion de cateter","Educar sobre cuidados de la FAV"]}],npiNoc:[{codigo:"0601",nombre:"Equilibrio hidrico",indicadores:["Peso estable","PA controlada","Sin edemas severos","Electrolitos en rango"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Hiperpotasemia (arritmias ventriculares, paro cardiaco)","Encefalopatia ur\xe9mica","Pericarditis ur\xe9mica","Edema agudo de pulmon","Hiperparatiroidismo secundario (osteodistrofia renal)","Anemia severa","Muerte sin terapia renal sustitutiva en G5"],criteriosAlarma:["K+ > 6.0 mEq/L","TFG < 15 mL/min sin dialisis programada","Disnea por sobrecarga hidrica","Confusion o deterioro neurol\xf3gico (uremia)","Pericarditis ur\xe9mica"],emergencyLevel:"moderado",relatedPathologyIds:["pat_dm2","pat_hta","pat_icc"],isPremium:!1},{id:"pat_ira_renal",nombre:"Insuficiencia Renal Aguda",bodySystemId:"renal_urinario",definicion:"Reduccion rapida (horas a dias) de la funcion renal, definida por el aumento de creatinina serica >= 0.3 mg/dL en 48h o >= 1.5x el valor basal en 7 dias, con posible oliguria o anuria. Frecuentemente reversible si se trata la causa.",epidemiologia:"Incidencia del 13-18% en pacientes hospitalizados, 30-60% en UCI. Mortalidad del 10-80% segun el contexto clinico (1-3% en casos aislados vs 50-80% con fallo multiorganico en UCI).",factoresRiesgo:["Sepsis (primera causa de IRA en UCI)","Hipovolemia (hemorragia, deshidratacion, quemaduras)","ICC descompensada","Nefrotoxicos: AINEs, aminoglucosidos, contraste yodado, cisplatino","Cirugia cardiaca mayor o vascular","IRC preexistente","Edad avanzada","Mieloma multiple (cadenas ligeras)"],fisiopatologia:"La IRA se clasifica por mecanismo: prerrenal (hipoperfusion renal sin lesion estructural: sepsis, hipovolemia, IC), intrarrenal (lesion del par\xe9nquima: necrosis tubular aguda, glomerulonefritis, nefritis intersticial) y posrenal (obstruccion urinaria: prostata, tumor, litiasis bilateral). La necrosis tubular aguda (NTA) por isquemia o nefrotoxinas es la forma mas comun de IRA intrarrenal hospitalaria. La isquemia produce necrosis del tubulo proximal, con debriscelulares que obstruyen la luz tubular y aumentan la presion intraglomerular.",signosYSintomas:{signos:["Aumento rapido de creatinina","Oliguria (< 0.5 mL/kg/h) o anuria","Edema generalizado por retencion hidrica","Hiperpotasemia en ECG: ondas T picudas","Signos de causa desencadenante (sepsis, IC)"],sintomas:["Disminucion de la diuresis","Nauseas y vomitos (uremia aguda)","Confusion si uremia avanzada","Edemas","Disnea si sobrecarga hidrica"]},clasificacion:{nombre:"Estadificacion KDIGO (Cr + diuresis)",tipos:[{nombre:"IRA estadio 1",descripcion:"Cr 1.5-1.9x basal o aumento >= 0.3 mg/dL; diuresis < 0.5 mL/kg/h por 6-12h"},{nombre:"IRA estadio 2",descripcion:"Cr 2.0-2.9x basal; diuresis < 0.5 mL/kg/h por > 12h"},{nombre:"IRA estadio 3",descripcion:"Cr > 3x basal o > 4 mg/dL; diuresis < 0.3 mL/kg/h por > 24h o anuria > 12h"}]},diagnostico:{anamnesis:["Exposicion a nefrotoxicos","Hipovolemia reciente","Sepsis u otras infecciones","Sintomas urinarios obstructivos"],examenFisico:["Estado de hidratacion: mucosas, turgencia, PA ortostatica","Signos de IC","Buscar globo vesical (retencion urinaria)"],pruebas:[{nombre:"Creatinina y urea seriadas",descripcion:"Monitoriza la velocidad de deterioro y la respuesta al tratamiento",cuidadosEnfermeria:["En IRA en UCI: extraer cada 6-12h","Calcular ratio urea/creatinina: > 20 sugiere prerrenal"]},{nombre:"Ecografia renal urgente",descripcion:"Descarta obstruccion (hidronefrosis) y evalua tamano renal (ri\xf1ones peque\xf1os = IRC subyacente)",cuidadosEnfermeria:["Realizacion urgente si oliguria inexplicada","No requiere preparacion en urgencia"]},{nombre:"Ionograma con potasio, ECG",descripcion:"Hiperpotasemia es la principal complicacion aguda de la IRA que amenaza la vida",valoresReferencia:"K+ > 6.5 con cambios ECG (T picudas, QRS ancho) = emergencia",cuidadosEnfermeria:["ECG inmediato si K+ > 5.5","Gluconato calcico IV INMEDIATO si K+ > 6.5 con cambios ECG"]}]},tratamientoMedico:{objetivos:["Tratar la causa","Mantener perfusion renal y diuresis","Corregir complicaciones metabolicas urgentes"],farmacologico:[{nombre:"Furosemida IV",grupo:"Diuretico de asa - si sobrecarga hidrica en IRA",mecanismo:"Promueve diuresis si hay respuesta renal residual; NO revierte la IRA pero ayuda al manejo de liquidos",dosis:"40-200 mg IV en bolo; si no responde: infusion 20-40 mg/h",cuidadosEnfermeria:["No usar para convertir oliguria en no oliguria (no mejora pronostico)","Solo indicada si sobrecarga hidrica real","Monitorizar respuesta diuretica horaria"]},{nombre:"Gluconato de calcio IV (hiperpotasemia con cambios ECG)",grupo:"Cardioprotector urgente - hiperpotasemia grave",mecanismo:"Estabiliza la membrana cardiaca sin bajar el potasio; efecto en 1-3 minutos, dura 30-60 minutos",dosis:"10 mL de gluconato calcico al 10% IV en 3-5 minutos, bajo monitorizacion ECG",cuidadosEnfermeria:["Administrar bajo monitorizacion ECG continua","Efecto temporal: luego usar medidas que bajan el K+","No mezclar con bicarbonato (precipita)"]}],noFarmacologico:["Restaurar la perfusion renal (fluidos IV en prerrenal, corregir IC)","Suspender todos los nefrotoxicos","Ajustar dosis de todos los medicamentos a la TFG actual","Dialisis si: hiperpotasemia refractaria, acidosis grave, sobrecarga hidrica refractaria, uremia sintomatica"],quirurgico:["Desobstruccion urgente en IRA posrenal (sonda vesical, nefrostomia percutanea, ureteroscopia)"]},cuidadosEnfermeria:{valoracion:["Diuresis HORARIA (registro estricto)","Balance hidrico cada hora en IRA grave","PA, FC, temperatura cada 1-4h","Peso diario","Signos de hiperpotasemia: ECG, calambres, debilidad muscular","Signos de sobrecarga hidrica: edemas, crepitantes"],intervenciones:["Sonda vesical para diuresis horaria rigurosa","Suspender todos los nefrotoxicos identificados","Administrar fluidos segun indicacion para restaurar perfusion","ECG urgente si K+ > 5.5","Preparar y administrar gluconato calcico si hiperpotasemia severa"],educacionPaciente:["Post-IRA: evitar AINEs, aminoglucosidos y contrastes sin indicacion imperativa","Seguimiento nefrologico post-alta","Hidratacion adecuada en periodos de enfermedad"],monitorizacion:["Diuresis horaria","Creatinina seriada cada 6-12h en IRA activa","Potasio seriado (cada 4-6h si K+ > 5.0)","ECG si hiperpotasemia","Balance hidrico horario en IRA grave"]},npiNanda:[{codigo:"00195",nombre:"Riesgo de desequilibrio electrolitico",definicion:"Vulnerable a cambios en los niveles de electrolitos sericos",caracteristicasDefinitorias:["Oliguria con retencion de potasio","Acidosis metabolica"],factoresRelacionados:["Perdida de funcion renal para excretar electrolitos","Nefrotoxicidad"]}],npiNic:[{codigo:"4120",nombre:"Manejo de liquidos",actividades:["Diuresis horaria rigurosa","Balance hidrico horario","Administrar fluidos segun perfusion renal","Monitorizar peso diario","ECG ante hiperpotasemia"]}],npiNoc:[{codigo:"0601",nombre:"Equilibrio hidrico",indicadores:["Diuresis > 0.5 mL/kg/h","Creatinina en descenso","Potasio 3.5-5.0 mEq/L"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Hiperpotasemia con arritmias letales","Acidosis metabolica severa","Sobrecarga hidrica con EAP","Encefalopatia ur\xe9mica","Infecciones oportunistas","Cronificacion (IRC en 10-30%)","Muerte"],criteriosAlarma:["K+ > 6.5 mEq/L con cambios ECG","Anuria > 12h","Disnea severa por sobrecarga hidrica","Confusion por uremia","pH < 7.2"],emergencyLevel:"critico",relatedPathologyIds:["pat_irc","pat_sepsis"],isPremium:!1},{id:"pat_itu",nombre:"Infeccion del Tracto Urinario",bodySystemId:"renal_urinario",definicion:"Presencia de microorganismos patogenos en el tracto urinario (vejiga, ri\xf1on, uretra o prostata) con respuesta inflamatoria, desde la cistitis no complicada hasta la pielonefritis y urosepsis.",epidemiologia:"Causa de infeccion bacteriana mas frecuente en la consulta ambulatoria. Prevalencia mayor en mujeres jovenes (50% de las mujeres tienen al menos una ITU en su vida). E. coli es el agente causal en el 80-85% de los casos.",factoresRiesgo:["Sexo femenino (uretra corta)","Actividad sexual","Uso de diafragma o espermicidas","Embarazo","Obstruccion urologica (litiasis, prostata)","Cateterizacion urinaria","Diabetes mellitus","Menopausia (perdida de estrogenos)","Inmunosupresion"],fisiopatologia:"Los microorganismos (principalmente E. coli de la flora fecal) ascienden desde la uretra hacia la vejiga. Los pilis de E. coli se adhieren a los receptores uroteliales, eludiendo el flujo de la miccion como mecanismo de defensa. La respuesta inflamatoria produce los sintomas de cistitis. En la pielonefritis, los germenes ascienden a la pelvis renal y par\xe9nquima, produciendo inflamacion y potencial bacteriemia. El reflujo vesicoureteral favorece la ascension.",signosYSintomas:{signos:["Piuria en el sedimento de orina (> 5 leucocitos/campo)","Bacteriuria significativa (> 100.000 UFC/mL en cultivo)","Fiebre > 38\xb0C solo en pielonefritis o urosepsis","Pu\xf1opercusion lumbar positiva (pielonefritis)","Hematuria macro o microcopica"],sintomas:["Cistitis: disuria, polaquiuria, urgencia miccional, hematuria terminal","Pielonefritis: fiebre alta, escalofrios, dolor lumbar, nauseas/vomitos + sintomas de cistitis","Prostatitis: dolor perineal, fiebre, sintomas urinarios obstructivos"]},clasificacion:{nombre:"Clasificacion por localizacion y complicacion",tipos:[{nombre:"Cistitis no complicada",descripcion:"Mujer joven, no embarazada, sin factores de riesgo. Tratamiento corto (3 dias)"},{nombre:"Cistitis complicada",descripcion:"Con factores complicantes: hombre, embarazo, diabetes, cateter, obstruccion"},{nombre:"Pielonefritis aguda",descripcion:"Infeccion del par\xe9nquima renal. Fiebre, dolor lumbar. Tratamiento 7-14 dias"},{nombre:"Bacteriuria asintomatica",descripcion:"Cultivo positivo sin sintomas. No tratar salvo embarazo o cirugia urologica"}]},diagnostico:{anamnesis:["Sintomas de cistitis o pielonefritis","Inicio de sintomas","ITUs previas y tratamientos","Cateter urinario","Factores de riesgo"],examenFisico:["Pu\xf1opercusion lumbar (positiva en pielonefritis)","Signos vitales y temperatura","En hombre: tacto rectal para prostatitis"],pruebas:[{nombre:"Tira reactiva de orina",descripcion:"Leucocitos y nitritos positivos sugieren ITU. Rapida, de baja especificidad. Nitritos positivos son mas especificos (bacterias gramnegativas)",cuidadosEnfermeria:["Primera orina de la ma\xf1ana o la mas concentrada (minimo 4h sin orinar)","Tecnica aseptica de recogida (limpiar genitales, chorro medio)","Resultado en 2 minutos"]},{nombre:"Urocultivo con antibiograma",descripcion:"Confirma la ITU, identifica el agente causal y su perfil de resistencia",valoresReferencia:"> 100.000 UFC/mL de un urogermen diagnostica ITU. > 1000 UFC/mL en muestra por sondaje o puncion suprapubica",cuidadosEnfermeria:["Tecnica aseptica: higiene genitales, chorro medio, frasco esteril","Obtener ANTES de antibioticos","Conservar refrigerado max 4h hasta procesar"]}]},tratamientoMedico:{objetivos:["Erradicacion del microorganismo","Alivio de sintomas","Prevenir recurrencias"],farmacologico:[{nombre:"Fosfomicina trometamol",grupo:"Antibiotico - primera linea en cistitis no complicada",mecanismo:"Inhibe la sintesis de peptidoglicano bacteriano; excelente perfil frente a E. coli y ESBL",dosis:"3 g en dosis unica VO",cuidadosEnfermeria:["Una sola dosis (mejora adherencia)","Disolver en agua y tomar con el estomago semivacio","Antibiotico de primera linea por baja tasa de resistencias en Argentina"]},{nombre:"Ceftriaxona IV",grupo:"Cefalosporina 3a generacion - pielonefritis o urosepsis",mecanismo:"Antibiotico bactericida de amplio espectro IV para casos hospitalizados",dosis:"1-2 g IV/dia",cuidadosEnfermeria:["Administrar despues de obtener urocultivo y hemocultivos","Pasar a VO cuando mejore la clinica (step-down)"]},{nombre:"Ciprofloxacino VO",grupo:"Fluoroquinolona - pielonefritis leve-moderada ambulatoria",mecanismo:"Inhibidor de DNA girasa bacteriana; alta penetracion en tejido renal",dosis:"500 mg c/12h VO x 7 dias",cuidadosEnfermeria:["Reservar para pielonefritis (no usar para cistitis: desarrollo de resistencias)","Evitar en embarazo","Monitorizar tendencia al alargamiento del QT"]}],noFarmacologico:["Hidratacion abundante (diluye bacterias)","Higiene intima adecuada (limpiar de adelante hacia atras en mujeres)","Miccion post-coito","Evitar espermicidas si recurrencias frecuentes"],quirurgico:["Drenaje de absceso renal","Desobstruccion urgente en pielonefritis obstructiva (emergencia)"]},cuidadosEnfermeria:{valoracion:["Temperatura cada 4h en pielonefritis","Signos vitales (taquicardia, hipotension = urosepsis)","Caracteristicas de la diuresis (disuria, color, olor)","Balance hidrico","Dolor lumbar (EVA)"],intervenciones:["Hidratacion oral o IV abundante","Administrar antibioticos en tiempo exacto","Recogida correcta de urocultivo (tecnica aseptica)","Cuidados del cateter urinario si presente","Educacion sobre higiene"],educacionPaciente:["Hidratacion abundante (2-3 L de agua/dia)","Higiene intima correcta: limpiar de adelante hacia atras","Miccion post-coito","Completar el ciclo antibiotico aunque mejoren los sintomas","Cuando consultar: fiebre alta, deterioro, persistencia de sintomas > 2 dias de antibiotico"],monitorizacion:["Temperatura cada 4-6h en pielonefritis","Sintomas de cistitis a los 2-3 dias (mejoria)","Urocultivo de control post-tratamiento si recurrencias frecuentes o embarazo","Signos de sepsis (sepsis urinaria = urosepsis)"]},npiNanda:[{codigo:"00019",nombre:"Incontinencia urinaria de urgencia",definicion:"Perdida involuntaria de orina asociada a una sensacion de urgencia miccional intensa",caracteristicasDefinitorias:["Urgencia miccional","Polaquiuria","Nicturia"],factoresRelacionados:["Inflamacion vesical por ITU","Irritacion del detrusor"]},{codigo:"00007",nombre:"Hipertermia",definicion:"Temperatura corporal central superior a la normal",caracteristicasDefinitorias:["Temperatura > 38\xb0C","Escalofrios","Diaforesis"],factoresRelacionados:["Proceso infeccioso renal o vesical"]}],npiNic:[{codigo:"0590",nombre:"Manejo de la eliminacion urinaria",actividades:["Fomentar la hidratacion","Registrar caracteristicas de la orina","Educacion sobre higiene intima","Tecnica aseptica de recogida de urocultivo"]}],npiNoc:[{codigo:"0503",nombre:"Eliminacion urinaria",indicadores:["Sin disuria","Frecuencia miccional normal","Sin hematuria","Sin urgencia miccional"],escala:"1=Gravemente comprometido, 2=Sustancialmente, 3=Moderadamente, 4=Levemente, 5=No comprometido"}],complicaciones:["Urosepsis (pielonefritis que progresa a sepsis bacteriemica)","Absceso renal o perinefretico","Insuficiencia renal aguda por pielonefritis grave","Pielonefritis xantogranulomatosa","ITU de repeticion (> 3/ano en mujeres)"],criteriosAlarma:["Fiebre > 38.5\xb0C + dolor lumbar (pielonefritis)","Hipotension o taquicardia (sepsis urinaria)","Ausencia de mejoria a las 48-72h de antibiotico correcto","Signos de obstruccion urinaria"],emergencyLevel:"leve",relatedPathologyIds:["pat_irc","pat_litiasis"],isPremium:!1},{id:"pat_litiasis",nombre:"Litiasis Renal",bodySystemId:"renal_urinario",definicion:"Formacion de calculos en el tracto urinario (ri\xf1on, ureter, vejiga, uretra) por precipitacion y cristalizacion de solutos en la orina, produciendo colico nefritico y posibles complicaciones obstructivas e infecciosas.",epidemiologia:"Prevalencia del 5-15% en la poblacion adulta. Recurrencia del 50% a los 10 a\xf1os. Causa del 5% de todas las hospitalizaciones por dolor abdominal. Predominio masculino (2:1). Calculo de oxalato calcico (70-80% de los casos).",factoresRiesgo:["Deshidratacion cronica (ingesta baja de agua)","Dieta hipercalcica, hiperuricos\xfarica, hiperoxal\xfarica","Hiperparatiroidismo primario","Acidosis tubular renal","Infecciones urinarias por germenes ureasa positivos (calculos de estruvita)","Historia familiar de litiasis","Obesidad y sindrome metabolico","Gota"],fisiopatologia:"La cristalizacion en orina ocurre cuando la concentracion de solutos supera el producto de solubilidad en orina. Los cristales nuclean, crecen y se agregan formando calculos. El calcio y el oxalato son los precursores mas frecuentes. La obstruccion del ureter por un calculo produce hiperperistalsis ureteral y distension de la capsula renal, generando el dolor severo del colico nefritico. La obstruccion prolongada puede causar IRA obstructiva.",signosYSintomas:{signos:["Hematuria micro o macroscopica (70-90% de casos)","Pu\xf1opercusion positiva en el lado afectado","Agitacion psicomotriz (incapacidad para estar quieto, diferencia del abdomen agudo)","Nauseas y vomitos reflejos"],sintomas:["Dolor lumbar o en flanco de inicio brusco, tipo colico, irradiacion a FII/FID, ingle, test\xedculo o labios mayores","Hematuria terminal","Urgencia miccional si el calculo esta en la union ureterovesical","Escalofrios y fiebre si hay infeccion asociada (urgencia: obstruccion infectada)"]},clasificacion:{nombre:"Clasificacion por composicion",tipos:[{nombre:"Oxalato calcico (70-80%)",descripcion:"Mas frecuente. Radioopaco. Causa: hipercalciuria, hiperoxaluria"},{nombre:"Acido urico (5-10%)",descripcion:"Radiotransparente (no visible en Rx). Orina acida. Gota, diabetes, obesidad"},{nombre:"Estruvita (fosfato amoniomagnesico) (5-15%)",descripcion:"Infeccion por germenes ureasa positivos (Proteus, Klebsiella). Calculos coraliformes"},{nombre:"Cistina (1%)",descripcion:"Cistinuria hereditaria. Inicio en la infancia"}]},diagnostico:{anamnesis:["Inicio y caracteristicas del dolor (colico)","Hematuria","Historia previa de litiasis","Antecedentes familiares","Ingesta hidrica habitual"],examenFisico:["Agitacion del paciente (diferencia del abdomen agudo)","Pu\xf1opercusion lumbar positiva","Buscar fiebre (obstruccion infectada = emergencia)"],pruebas:[{nombre:"Urotac (TAC abdominal sin contraste de baja dosis)",descripcion:"Estudio de eleccion. Alta sensibilidad (>95%) para detectar calculos de cualquier composicion",cuidadosEnfermeria:["No requiere contraste ni preparacion especial","Minimamente invasivo, rapido","Resultado inmediato en urgencias"]},{nombre:"Sedimento urinario y urocultivo",descripcion:"Confirma hematuria y descarta ITU asociada. Piuria + hematuria + fiebre = obstruccion infectada (emergencia)",cuidadosEnfermeria:["Tecnica aseptica de recogida","Urocultivo ANTES de antibioticos si hay sospecha de infeccion"]}]},tratamientoMedico:{objetivos:["Alivio del dolor","Expulsion del calculo o extraccion si no expulsa","Prevenir recurrencias"],farmacologico:[{nombre:"Ketorolac + Metamizol IV",grupo:"AINEs + analgesico no opiode - dolor del colico nefritico",mecanismo:"Ketorolac: inhibe COX y reduce edema inflamatorio ureteral. Metamizol: analgesico y espasmolitico",dosis:"Ketorolac 30 mg IV; Metamizol 1-2 g IV en 250 mL SF en 20 min",cuidadosEnfermeria:["Son los analgesicos mas eficaces en el colico nefritico","AINEs contraindicados en IRC severa","Monitorizar PA y funcion renal post-dosis"]},{nombre:"Tamsulosina",grupo:"Alfabloqueante - expulsion del calculo ureteral distal",mecanismo:"Relaja el musculo liso del ureter distal, facilitando el paso espontaneo del calculo",dosis:"0.4 mg/dia VO hasta expulsion del calculo",cuidadosEnfermeria:["Hipotension ortost\xe1tica: tomar acostado la primera dosis","Usar para calculos uretrales < 10 mm","Advertir sobre posible hipotension al levantarse"]}],noFarmacologico:["Hidratacion abundante (facilita expulsion)","Filtracion de la orina para recuperar el calculo (analisis de composicion)","Calor local en el flanco para alivio del dolor"],quirurgico:["Litotricia extracorporea por ondas de choque (LEOC): calculos < 2 cm renal o ureter proximal","Ureteroscopia con laser (Holmium): calculos ureterales","Nefrolitotomia percutanea: calculos renales grandes > 2 cm o coraliformes"]},cuidadosEnfermeria:{valoracion:["Intensidad del dolor (EVA)","Temperatura (obstruccion infectada = urgencia)","Caracteristicas de la orina (hematuria, espesura)","Nauseas y vomitos","Estado de hidratacion"],intervenciones:["Administrar analgesicos IV urgentes","Hidratacion oral o IV abundante si tolera","Filtrar la orina con tamiz para recuperar el calculo","Control de temperatura: si fiebre + obstruccion = descompresion urgente","Ambiente tranquilo y alivio del dolor para reducir ansiedad"],educacionPaciente:["Ingesta hidrica minima de 2-3 L/dia","Dieta segun tipo de calculo (baja en oxalato en oxalato calcico; baja en purinas en acido urico)","Reconocer signos de obstruccion infectada: fiebre + dolor lumbar + escalofrios"],monitorizacion:["Temperatura horaria si hay sospecha de infeccion","Intensidad del dolor (EVA) cada 2h","Diuresis y hematuria","Filtrar orina para recuperar el calculo"]},npiNanda:[{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable por lesion tisular real",caracteristicasDefinitorias:["Dolor lumbar intenso 9-10/10","Agitacion psicomotriz","Nauseas y vomitos"],factoresRelacionados:["Distension de la capsula renal por obstruccion","Espasmo del ureter por el calculo"]}],npiNic:[{codigo:"1400",nombre:"Manejo del dolor",actividades:["Administrar analgesicos IV urgentes (ketorolac, metamizol)","Aplicar calor local en el flanco","Monitorizar respuesta al tratamiento cada 30 min","Posicion comoda (deambulacion puede facilitar expulsion)"]}],npiNoc:[{codigo:"1605",nombre:"Control del dolor",indicadores:["Dolor < 4/10","Paciente tranquilo","Sin nauseas persistentes"],escala:"1=Nunca demostrado, 2=Raramente, 3=A veces, 4=Frecuentemente, 5=Siempre demostrado"}],complicaciones:["Obstruccion ureteral infectada (pielonefritis obstructiva = emergencia urologica)","IRA obstructiva bilateral o en ri\xf1on unico","Pionefrosis","Recurrencia (50% a 10 a\xf1os sin prevencion)"],criteriosAlarma:["Fiebre > 38\xb0C con dolor lumbar (obstruccion infectada - EMERGENCIA)","Oliguria o anuria","Dolor refractario al tratamiento","Calculo > 1 cm (baja probabilidad de expulsion espontanea)"],emergencyLevel:"moderado",relatedPathologyIds:["pat_itu","pat_ira_renal"],isPremium:!0},{id:"pat_sindrome_nefrotico",nombre:"Sindrome Nefrotico",bodySystemId:"renal_urinario",definicion:"Sindrome clinico caracterizado por proteinuria masiva (> 3.5 g/24h en adultos), hipoalbuminemia (< 3 g/dL), edemas generalizados e hiperlipidemia, causado por lesion de la barrera de filtracion glomerular.",epidemiologia:"Incidencia de 3/100.000 ni\xf1os y 3/100.000 adultos/ano. En ni\xf1os: causa mas frecuente es la enfermedad de cambios minimos (80%); en adultos: nefropatia membranosa y GESF son mas comunes.",factoresRiesgo:["Diabetes mellitus (nefropatia diabetica, causa mas frecuente en adultos)","LES (nefritis lupica)","Amiloidosis","Mieloma multiple","Infeccion por VIH, hepatitis B/C","Medicamentos: AINEs, oro, penicilamina","Idiopatico (enfermedad de cambios minimos)"],fisiopatologia:"La lesion de la barrera glomerular (fusion de los pedicelos podocitarios o deposito de inmunocomplejos en la membrana basal) permite el paso de proteinas de alto peso molecular (albumina, IgG) a la orina. La perdida masiva de albumina produce hipoalbuminemia, reduciendo la presion oncotica plasmatica y causando desplazamiento de liquido al intersticio (edema). La hipovolemia relativa activa el SRAA, produciendo mayor retencion de sodio y agua. La hiperlipidemia resulta del aumento de la sintesis hepatica de lipoproteinas.",signosYSintomas:{signos:["Edema en anasarca (generalizado: facial, periorbitario, ascitis, derrames pleurales)","Albumina serica < 3 g/dL","Proteinuria en la tira reactiva: +++ o ++++","Hiperlipidemia (colesterol > 300 mg/dL)","Lipiduria (cuerpos ovales grasos en sedimento)"],sintomas:["Edema que inicia en pararpados por la ma\xf1ana y piernas al final del dia","Espuma en la orina (proteinuria)","Fatiga","Ganancia rapida de peso por retencion hidrica"]},clasificacion:{nombre:"Clasificacion por histologia (biopsia renal)",tipos:[{nombre:"Enfermedad de cambios minimos (ECM)",descripcion:"Ninos, buena respuesta a corticoides, pronostico benigno"},{nombre:"Glomeruloesclerosis focal y segmentaria (GESF)",descripcion:"Adultos jovenes, menor respuesta a corticoides, progresion a IRC frecuente"},{nombre:"Nefropatia membranosa",descripcion:"Adulto medio, asociado a cancer, infeccion, autoinmune (anti-PLA2R)"},{nombre:"Nefropatia diabetica",descripcion:"En diabeticos evolucionados. Progresion a IRC si no tratada"}]},diagnostico:{anamnesis:["Inicio del edema","Diabetes, LES, cancer previo","Medicacion (AINEs)","Espuma en la orina"],examenFisico:["Evaluar edemas (godet, localizacion)","Buscar ascitis y derrames pleurales","PA (puede haber hipotension por hipoalbuminemia)"],pruebas:[{nombre:"Proteinuria en orina de 24h o relacion prot/creat",descripcion:"Proteinuria > 3.5 g/24h o relacion prot/creat > 3.5 mg/mg confirma SN",cuidadosEnfermeria:["Recogida correcta de orina de 24h (desde la 2a miccion del dia hasta la 1a del dia siguiente)","Refrigerar muestra durante la recogida","Anotar diuresis total del dia"]},{nombre:"Biopsia renal",descripcion:"Permite diagnostico histologico exacto que guia el tratamiento especifico",cuidadosEnfermeria:["Reposo absoluto 24h post-biopsia (riesgo de hemorragia)","Monitorizar orina post-biopsia (hematuria)","PA y diuresis cada 1h en las primeras 4h","Avisar si hematuria macroscopica o dolor lumbar persistente"]}]},tratamientoMedico:{objetivos:["Reducir la proteinuria","Tratar la causa subyacente","Controlar edemas y complicaciones"],farmacologico:[{nombre:"Prednisona",grupo:"Corticoide - ECM y GESF",mecanismo:"Reduce la inflamacion glomerular y estabiliza los pedicelos podocitarios",dosis:"1 mg/kg/dia (max 80 mg) x 4-8 semanas, luego reduccion gradual",cuidadosEnfermeria:["Efectos adversos: hiperglucemia, HTA, osteoporosis, infecciones oportunistas","Proteccion gastrica y suplementacion de calcio + vitamina D","Hemograma y glucemia en seguimiento"]},{nombre:"IECA / ARA-II",grupo:"Nefroprotectores - reduccion de proteinuria",mecanismo:"Reducen la presion intraglomerular y la proteinuria en todos los tipos de SN",dosis:"Enalapril 5-20 mg/dia o Losartan 50-100 mg/dia",cuidadosEnfermeria:["Monitorizar creatinina y potasio","Primera linea en nefropatia diabetica independientemente de la PA"]},{nombre:"Furosemida VO/IV",grupo:"Diuretico - control de edemas en SN",mecanismo:"Aumenta la diuresis para movilizar los edemas",dosis:"40-240 mg/dia segun respuesta",cuidadosEnfermeria:["Equilibrio: reducir edema sin producir hipovolemia (peligrosa en SN por hipoalbuminemia)","Peso diario; no perder mas de 500-1000 g/dia","Electrolitos seriados"]}],noFarmacologico:["Restriccion de sodio (< 2 g/dia)","Restriccion moderada de proteinas (0.8-1 g/kg/dia)","Movilizacion para prevenir trombosis"],quirurgico:[]},cuidadosEnfermeria:{valoracion:["Peso diario en ayunas (retencion hidrica)","Evaluar edemas: localizacion, godet, grado","Perimetro abdominal si ascitis","PA (hipotension en hipoalbuminemia severa)","Balance hidrico","Albumina serica"],intervenciones:["Dieta hiposodica y normoprot\xe9ica","Diureticos segun indicacion","Peso diario","Cuidados de la piel en edemas severos (riesgo de UPP)","Movilizacion y medias de compresion (riesgo de trombosis por hipercoagulabilidad)"],educacionPaciente:["Dieta hiposodica: alimentos con alto contenido en sodio","Restriccion de liquidos si edemas severos","Importancia de la biopsia renal para diagnostico exacto","Signos de trombosis (dolor, edema unilateral)"],monitorizacion:["Peso diario","Proteinas en orina periodicamente","Albumina serica mensual","Lipidograma","Signos de trombosis (SN produce hipercoagulabilidad)"]},npiNanda:[{codigo:"00025",nombre:"Exceso de volumen de liquidos",definicion:"Aumento de la retencion de liquidos isotonicos",caracteristicasDefinitorias:["Edema en anasarca","Albumina baja","Aumento de peso rapido"],factoresRelacionados:["Hipoalbuminemia por perdida masiva de proteinas en orina","Activacion del SRAA secundaria"]}],npiNic:[{codigo:"4120",nombre:"Manejo de liquidos",actividades:["Peso diario","Restriccion de sodio","Administrar diureticos y monitorizar respuesta","Evaluar integridad de la piel en areas de edema"]}],npiNoc:[{codigo:"0601",nombre:"Equilibrio hidrico",indicadores:["Peso estable o en descenso por movilizacion de edemas","Albumina en mejoria","Sin edema severo"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Tromboembolismo (perdida de antitrombina III y proteinas C/S en orina)","Infecciones (perdida de inmunoglobulinas en orina)","IRA por hipovolemia relativa (sobrediuresis)","Progresion a IRC","Arteriosclerosis acelerada por hiperlipidemia cronica"],criteriosAlarma:["Trombosis venosa profunda o TEP","Infeccion grave (neumococo por perdida de IgG)","Hipotension por sobrediuresis o hipoalbuminemia severa"],emergencyLevel:"moderado",relatedPathologyIds:["pat_irc","pat_dm2","pat_lupus","pat_tvp"],isPremium:!0},{id:"pat_glomerulonefritis",nombre:"Glomerulonefritis",bodySystemId:"renal_urinario",definicion:"Inflamacion de los glom\xe9rulos renales, generalmente de mecanismo inmunologico, que produce proteinuria, hematuria, hipertension e insuficiencia renal de grado variable. Puede ser aguda (post-infecciosa) o cronica (lupica, IgA, ANCA).",epidemiologia:"Causa del 10-15% de los casos de IRC en dialisis. La nefropatia IgA es la forma primaria mas frecuente en el mundo. La GN postinfecciosa es la causa mas comun de hematuria macroscopica en ni\xf1os.",factoresRiesgo:["Infeccion estreptococica previa (GN postinfecciosa)","LES (nefritis lupica)","Vasculitis sist\xe9mica (ANCA)","Endocarditis bacteriana","Hepatitis B y C (crioglobulinemia)"],fisiopatologia:"Los mecanismos inmunologicos mas frecuentes son: 1) Deposito de inmunocomplejos (antigenoanticuerpo) en el mesangio o membrana basal glomerular que activan el complemento, atrayendo neutrofilos que lesionan el glom\xe9rulo. 2) Anticuerpos contra ant\xedgenos de la membrana basal (enfermedad anti-MBG). 3) Vasculitis pauci-inmune mediada por ANCA. La inflamacion glomerular produce proteinuria, hematuria (paso de eritrocitos deformados por el glom\xe9rulo danado) e insuficiencia renal.",signosYSintomas:{signos:["Hematuria con eritrocitos dismorficos en sedimento","Cilindruria (cilindros hem\xe1ticos = sello de la GN)","Proteinuria variable (no masiva en GN nefritica)","Hipertension arterial","Oliguria en formas graves"],sintomas:["Orina color cola (hematuria glomerular)","Edemas (principalmente facial, matutino)","Oliguria","Cefalea por HTA","Sintomas de la causa subyacente (LES, infeccion)"]},clasificacion:{nombre:"Clasificacion por sindrome clinico",tipos:[{nombre:"Sindrome nefritico agudo",descripcion:"Hematuria, proteinuria < 3.5 g, HTA, oliguria, ARA. GN post-estreptococica, lupica"},{nombre:"GNRP (Rapida Progresion)",descripcion:"IRA severa en dias/semanas con proliferacion extracapilar. ANCA, anti-MBG, pauci-inmune"},{nombre:"Nefropatia IgA (Berger)",descripcion:"Hematuria episodica post-infeccion, adultos jovenes. Progresion variable"}]},diagnostico:{anamnesis:["Infeccion reciente (faringitis, impetigo) 1-3 semanas antes","LES, vasculitis, hepatitis conocida","Orina color cola"],examenFisico:["PA","Edemas faciales y generalizados","Signos de enfermedad sist\xe9mica subyacente"],pruebas:[{nombre:"Sedimento urinario con microscop\xeda",descripcion:"Eritrocitos dismorficos y cilindros hem\xe1ticos son el sello de la GN activa",cuidadosEnfermeria:["Primera orina de la ma\xf1ana para mayor concentracion de cilindros","Procesar en < 2h de la recogida"]},{nombre:"Complemento C3 y C4, ANCA, anti-DNA, anti-MBG",descripcion:"Estudios inmunologicos para identificar la causa de la GN",cuidadosEnfermeria:["Muestra venosa estandar","Orientan el diagnostico diferencial y el tratamiento especifico"]},{nombre:"Biopsia renal",descripcion:"Definitiva para clasificar la GN y guiar el tratamiento",cuidadosEnfermeria:["Reposo absoluto post-biopsia","Monitorizar hematuria post-biopsia"]}]},tratamientoMedico:{objetivos:["Tratar la causa o suprimir el proceso autoinmune","Proteger la funcion renal residual","Control de HTA y proteinuria"],farmacologico:[{nombre:"Prednisona + Ciclofosfamida",grupo:"Corticoide + inmunosupresor - GNRP activa, vasculitis ANCA",mecanismo:"Inmunosupresion intensa para frenar la destruccion glomerular",dosis:"Prednisona 1 mg/kg/dia + Ciclofosfamida 2 mg/kg/dia o pulsos IV",cuidadosEnfermeria:["Cistitis hemorragica con ciclofosfamida: hiperhidratacion y MESNA","Riesgo de infecciones oportunistas","Monitorizar hemograma por leucopenia"]},{nombre:"Penicilina V (GN post-estreptococica)",grupo:"Antibiotico - erradicacion del estreptococo",mecanismo:"Elimina el foco infeccioso estreptococico que desencadena el proceso inmune",dosis:"500 mg c/8-12h x 10 dias",cuidadosEnfermeria:["No mejora la GN ya establecida pero prevee reinfeccion","Solicitar cultivo faringeo o ASTO antes de iniciar"]}],noFarmacologico:["Restriccion de proteinas, sodio y potasio segun funcion renal","Control estricto de la PA (IECA/ARA-II como primera linea)"],quirurgico:[]},cuidadosEnfermeria:{valoracion:["PA en cada turno (HTA frecuente)","Sedimento urinario: hematuria y proteinuria","Diuresis y balance hidrico","Edemas","Creatinina seriada"],intervenciones:["Control de HTA con antihipertensivos","Restriccion de sodio y potasio","Administrar inmunosupresores segun indicacion"],educacionPaciente:["Importancia del seguimiento regular para detectar progresion a IRC","Control de HTA domiciliario","Restriccion dietetica"],monitorizacion:["PA diaria","Proteinuria y hematuria seriadas","Creatinina mensual","Efectos adversos de inmunosupresores"]},npiNanda:[{codigo:"00025",nombre:"Exceso de volumen de liquidos",definicion:"Aumento de la retencion de liquidos",caracteristicasDefinitorias:["Edemas","HTA","Oliguria"],factoresRelacionados:["Reduccion de la TFG por inflamacion glomerular","Retencion de sodio y agua"]}],npiNic:[{codigo:"4120",nombre:"Manejo de liquidos",actividades:["Balance hidrico","Restriccion de sodio","Administrar antihipertensivos","Monitorizar creatinina y sedimento"]}],npiNoc:[{codigo:"0603",nombre:"Severidad de la sobrecarga de liquidos",indicadores:["Edemas reducidos","PA controlada","Creatinina estable o mejorando"],escala:"1=Grave, 2=Sustancial, 3=Moderada, 4=Leve, 5=Sin desviacion"}],complicaciones:["GNRP con progresion a IRC en semanas","IRC cronica","Hipertension arterial severa de dificil control","Sindrome nefrotico en formas membranosas"],criteriosAlarma:["Deterioro rapido de la funcion renal (creatinina x2 en dias)","HTA severa > 180/110 mmHg","Oliguria o anuria progresiva","Hemoptisis (sindrome de Goodpasture: GN anti-MBG + hemorragia pulmonar)"],emergencyLevel:"moderado",relatedPathologyIds:["pat_irc","pat_lupus","pat_sindrome_nefrotico"],isPremium:!0},{id:"pat_fractura_cadera",nombre:"Fractura de Cadera",bodySystemId:"musculoesqueletico",definicion:"Soluci\xf3n de continuidad del extremo proximal del f\xe9mur, frecuente en adultos mayores con osteoporosis. Incluye fracturas de cuello femoral y pertrocant\xe9reas. Alta morbimortalidad en ancianos.",epidemiologia:"",factoresRiesgo:[],fisiopatologia:"La fractura ocurre generalmente por traumatismo de baja energ\xeda sobre hueso osteopor\xf3tico. En el cuello femoral, la interrupci\xf3n del aporte vascular (arteria circunfleja femoral) puede causar necrosis avascular de la cabeza femoral. El proceso inflamatorio local, el dolor intenso y la inmovilizaci\xf3n prolongada desencadenan un s\xedndrome de inmovilizaci\xf3n con m\xfaltiples complicaciones sist\xe9micas: trombosis venosa profunda, embolia pulmonar, neumon\xeda hipost\xe1tica, \xfalceras por presi\xf3n, deterioro cognitivo e infecci\xf3n urinaria.",signosYSintomas:{signos:["Dolor intenso en cadera y regi\xf3n inguinal","Imposibilidad de deambulaci\xf3n o carga de peso","Rotaci\xf3n externa y acortamiento del miembro afectado","Equimosis en regi\xf3n trocant\xe9rea (fracturas pertrocant\xe9reas)","Impotencia funcional del miembro inferior","Signos de shock (hemorragia de 1-2L en fracturas pertrocant\xe9reas)","Deterioro del nivel de conciencia","Dolor tor\xe1cico (embolia pulmonar post-fractura)","Signos de trombosis venosa profunda","Fiebre elevada (infecci\xf3n)"],sintomas:["Dolor a la palpaci\xf3n del troc\xe1nter mayor","Hipotensi\xf3n por dolor o hemorragia","Signos de shock hipovol\xe9mico en fracturas pertrocant\xe9reas","Edema local","Acortamiento aparente del miembro"]},diagnostico:{anamnesis:["Cl\xednica compatible m\xe1s radiograf\xeda de cadera AP y axial","RMN si sospecha fractura oculta con radiograf\xeda normal","TC para clasificaci\xf3n y planificaci\xf3n quir\xfargica","Clasificaci\xf3n Garden (cuello femoral) o Evans (pertrocant\xe9rea)"],examenFisico:[],pruebas:[{nombre:"Hemograma (anemia por hemorragia)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Coagulaci\xf3n (preoperatorio)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Bioqu\xedmica con funci\xf3n renal",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Electrocardiograma y ecocardiograma preoperatorio",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Rx t\xf3rax",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Densitometr\xeda \xf3sea (DXA) post-agudo para valorar osteoporosis",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Gammagraf\xeda \xf3sea si sospecha fractura de estr\xe9s",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]}]},tratamientoMedico:{objetivos:[],farmacologico:[{nombre:"Morfina",grupo:"Agonista opioide mu",mecanismo:"Agonista opioide mu que inhibe la transmisi\xf3n del dolor a nivel central y espinal",dosis:"2-4 mg IV cada 4 horas seg\xfan escala de dolor (EVA >5), titular cuidadosamente en ancianos",cuidadosEnfermeria:["Monitorizar FR antes y despu\xe9s de cada dosis (no administrar si FR <12/min)","Tener naloxona disponible como ant\xeddoto","Valorar sedaci\xf3n con escala de Ramsay","Monitorizar diuresis (retenci\xf3n urinaria)","Rotar puntos de inyecci\xf3n si v\xeda SC","Vigilar signos de obstipaci\xf3n intestinal"]},{nombre:"Enoxaparina",grupo:"Heparina de bajo",mecanismo:"Heparina de bajo peso molecular que inhibe el factor Xa y la trombina, previniendo la formaci\xf3n de trombos",dosis:"40 mg SC cada 24h (profilaxis), iniciar 12h postoperatorio. Ajustar si ClCr <30 mL/min",cuidadosEnfermeria:["Administrar en zona periumbilical, alternando lados","No aspirar antes de inyectar ni friccionar despu\xe9s","Vigilar signos de sangrado (hematuria, melena, hematomas)","Monitorizar plaquetas cada 2-3 d\xedas","Verificar funci\xf3n renal antes de cada dosis en ancianos","No administrar IM nunca"]},{nombre:"\xc1cido Zoledr\xf3nico",grupo:"Bisfosfonato que inhibe",mecanismo:"Bisfosfonato que inhibe la resorci\xf3n \xf3sea mediada por osteoclastos, reduciendo el riesgo de fracturas futuras",dosis:"5 mg IV en infusi\xf3n \xfanica anual (iniciar \u22652 semanas post-fractura)",cuidadosEnfermeria:["Asegurar hidrataci\xf3n adecuada antes y despu\xe9s de infusi\xf3n","Administrar en 15 minutos m\xednimo con SF 100 mL","Verificar calcemia y funci\xf3n renal antes de administrar","Informar sobre s\xedndrome pseudogripal (pretratar con paracetamol)","Verificar que ClCr >35 mL/min antes de administrar","Contraindicado si hipocalcemia"]},{nombre:"Paracetamol",grupo:"Analg\xe9sico y antipir\xe9tico",mecanismo:"Analg\xe9sico y antipir\xe9tico con mecanismo central (inhibici\xf3n COX central), sin efecto antiinflamatorio perif\xe9rico significativo",dosis:"1 g IV/VO cada 6-8 horas (m\xe1x 4 g/d\xeda). Reducir a 500 mg si peso <50 kg o hepatopat\xeda",cuidadosEnfermeria:["Administrar IV en 15 minutos","Vigilar funci\xf3n hep\xe1tica en tratamiento prolongado","Calcular dosis total diaria si el paciente toma otros medicamentos con paracetamol","Valorar eficacia con EVA 30 min postadministraci\xf3n","Ajustar dosis en hepatopat\xeda severa"]}],noFarmacologico:["Cirug\xeda precoz (<48h): osteos\xedntesis o artroplastia seg\xfan tipo de fractura y estado del paciente","Inmovilizaci\xf3n en tracci\xf3n cut\xe1nea como medida temporal preoperatoria","Movilizaci\xf3n precoz postoperatoria para prevenir complicaciones","Fisioterapia intensiva desde el primer d\xeda postoperatorio","Ortesis y ayudas t\xe9cnicas para la deambulaci\xf3n"]},cuidadosEnfermeria:{valoracion:["Valorar intensidad del dolor con EVA o escala verbal (adaptar si deterioro cognitivo)","Monitorizar constantes vitales (PA, FC, FR, T\xaa, SatO2)","Valorar estado neurovascular del miembro: color, temperatura, pulso distal, sensibilidad, movilidad","Evaluar estado de hidrataci\xf3n y diuresis","Valorar estado cognitivo basal y detectar delirium","Registrar posici\xf3n y alineamiento del miembro afectado","Valorar riesgo de \xfalceras por presi\xf3n (escala Braden)"],intervenciones:["Determinar la ubicaci\xf3n, caracter\xedsticas, calidad e intensidad del dolor antes de administrar analg\xe9sicos","Administrar analg\xe9sicos pautados y evaluar su eficacia con EVA","Monitorizar signos vitales antes y despu\xe9s de administrar opi\xe1ceos","Utilizar analgesia multimodal (paracetamol + AINE + opioide si es necesario)","Documentar respuesta al tratamiento analg\xe9sico","Mantener alineaci\xf3n corporal correcta con almohadas entre rodillas","Realizar cambios posturales cada 2 horas para prevenir \xfalceras por presi\xf3n","No superar los 90\xb0 de flexi\xf3n de cadera postoperatoria","Evitar rotaci\xf3n interna y aducci\xf3n del miembro operado","Usar colch\xf3n antiescaras para reducir presi\xf3n en zonas de riesgo","Vigilar signos de infecci\xf3n de la herida quir\xfargica (eritema, calor, edema, exudado)","Realizar curas con t\xe9cnica est\xe9ril","Monitorizar temperatura corporal","Administrar profilaxis antibi\xf3tica pautada en per\xedodo perioperatorio","Fomentar higiene de manos al paciente y familiares"],educacionPaciente:["Explicar restricciones de movimiento postoperatorio (no flexi\xf3n >90\xb0, no cruzar piernas)","Ense\xf1ar ejercicios de respiraci\xf3n profunda y tos para prevenir neumon\xeda","Instruir sobre uso correcto de andador o muletas","Informar sobre signos de alarma de TVP (dolor/edema en pantorrilla) y TEP (disnea, dolor tor\xe1cico)","Educar sobre prevenci\xf3n de ca\xeddas en el domicilio","Explicar importancia del tratamiento de la osteoporosis","Informar sobre el programa de rehabilitaci\xf3n y su importancia"],monitorizacion:[]},npiNanda:[{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable ocasionada por una lesi\xf3n tisular real o potencial",caracteristicasDefinitorias:["Informe verbal de dolor EVA >7","Posici\xf3n anti\xe1lgica","Taquicardia","Diaforesis"],factoresRelacionados:["Fractura \xf3sea","Espasmo muscular","Inflamaci\xf3n"]},{codigo:"00085",nombre:"Deterioro de la movilidad f\xedsica",definicion:"Limitaci\xf3n del movimiento f\xedsico independiente e intencionado del cuerpo",caracteristicasDefinitorias:["Incapacidad de deambulaci\xf3n","Disminuci\xf3n del rango de movimiento","Inestabilidad postural"],factoresRelacionados:["Fractura de cadera","Dolor","Tratamiento quir\xfargico"]},{codigo:"00047",nombre:"Riesgo de deterioro de la integridad cut\xe1nea",definicion:"Riesgo de que la piel sea afectada de forma adversa",caracteristicasDefinitorias:[],factoresRelacionados:["Inmovilizaci\xf3n","Edad avanzada","Malnutrici\xf3n","Humedad"]}],npiNic:[{codigo:"2210",nombre:"Administraci\xf3n de analg\xe9sicos",actividades:["Determinar la ubicaci\xf3n, caracter\xedsticas, calidad e intensidad del dolor antes de administrar analg\xe9sicos","Administrar analg\xe9sicos pautados y evaluar su eficacia con EVA","Monitorizar signos vitales antes y despu\xe9s de administrar opi\xe1ceos","Utilizar analgesia multimodal (paracetamol + AINE + opioide si es necesario)","Documentar respuesta al tratamiento analg\xe9sico"]},{codigo:"0840",nombre:"Cambio de posici\xf3n",actividades:["Mantener alineaci\xf3n corporal correcta con almohadas entre rodillas","Realizar cambios posturales cada 2 horas para prevenir \xfalceras por presi\xf3n","No superar los 90\xb0 de flexi\xf3n de cadera postoperatoria","Evitar rotaci\xf3n interna y aducci\xf3n del miembro operado","Usar colch\xf3n antiescaras para reducir presi\xf3n en zonas de riesgo"]},{codigo:"6540",nombre:"Control de infecciones",actividades:["Vigilar signos de infecci\xf3n de la herida quir\xfargica (eritema, calor, edema, exudado)","Realizar curas con t\xe9cnica est\xe9ril","Monitorizar temperatura corporal","Administrar profilaxis antibi\xf3tica pautada en per\xedodo perioperatorio","Fomentar higiene de manos al paciente y familiares"]}],npiNoc:[{codigo:"2102",nombre:"Nivel del dolor",indicadores:["Dolor referido","Expresiones faciales de dolor","Frecuencia card\xedaca"],escala:"Reducir dolor a EVA \u22643 en 24-48h postoperatorio"},{codigo:"0200",nombre:"Ambular",indicadores:["Distancia de deambulaci\xf3n","Marcha con ayuda t\xe9cnica","Subir escaleras"],escala:"Deambulaci\xf3n con andador a los 2-3 d\xedas postoperatorios"}],complicaciones:["Trombosis venosa profunda y embolia pulmonar","Infecci\xf3n de herida quir\xfargica / artritis s\xe9ptica","Necrosis avascular de la cabeza femoral (fracturas de cuello femoral)","Luxaci\xf3n de pr\xf3tesis","Delirium postoperatorio","Neumon\xeda por aspiraci\xf3n o hipost\xe1tica","\xdalceras por presi\xf3n","S\xedndrome de inmovilizaci\xf3n","Deterioro funcional permanente"],criteriosAlarma:["Signos de shock (hemorragia de 1-2L en fracturas pertrocant\xe9reas)","Deterioro del nivel de conciencia","Dolor tor\xe1cico (embolia pulmonar post-fractura)","Signos de trombosis venosa profunda","Fiebre elevada (infecci\xf3n)"],emergencyLevel:"moderado",relatedPathologyIds:[],isPremium:!1},{id:"pat_osteoporosis",nombre:"Osteoporosis",bodySystemId:"musculoesqueletico",definicion:"Enfermedad esquel\xe9tica sist\xe9mica caracterizada por baja densidad mineral \xf3sea y deterioro de la microarquitectura del tejido \xf3seo, con el consiguiente aumento de la fragilidad \xf3sea y la susceptibilidad a fracturas.",epidemiologia:"",factoresRiesgo:[],fisiopatologia:"El hueso es un tejido din\xe1mico en constante remodelaci\xf3n mediante el acoplamiento entre osteoblastos (formaci\xf3n) y osteoclastos (resorci\xf3n). En la osteoporosis, este equilibrio se rompe a favor de la resorci\xf3n. En mujeres postmenop\xe1usicas, la ca\xedda de estr\xf3genos aumenta la expresi\xf3n de RANKL, que activa los osteoclastos. En la osteoporosis senil, la disminuci\xf3n de IGF-1, testosterona y vitamina D, junto al aumento de PTH secundaria, aceleran la p\xe9rdida \xf3sea. El resultado es un hueso con menor masa y microarquitectura deteriorada, que fractura ante traumatismos m\xednimos (fracturas por fragilidad).",signosYSintomas:{signos:["Asintom\xe1tica hasta que ocurre una fractura","Fractura de mu\xf1eca (Colles) ante traumatismo m\xednimo","Fractura vertebral (dolor dorsolumbar agudo, p\xe9rdida de talla)","Fractura de cadera ante ca\xedda","Cifosis dorsal progresiva (joroba de viuda)","Fractura vertebral con compresi\xf3n medular (urgencia neuroquir\xfargica)","Fractura de cadera (alta morbimortalidad en ancianos)","P\xe9rdida de talla s\xfabita (fractura vertebral aguda)","Dolor dorsal agudo intenso en paciente con factores de riesgo"],sintomas:["P\xe9rdida de talla >4 cm respecto a talla de adulto joven","Dolor cr\xf3nico dorsal o lumbar","Sensaci\xf3n de fatiga","Dificultad respiratoria si hay fracturas vertebrales m\xfaltiples","Distensi\xf3n abdominal por compresi\xf3n abdominal por cifoescoliosis"]},diagnostico:{anamnesis:["Densitometr\xeda \xf3sea (DXA): T-score \u2264-2.5 en columna lumbar o cadera (OMS)","Fractura por fragilidad (diagn\xf3stico cl\xednico aunque T-score >-2.5)","Osteopenia: T-score entre -1.0 y -2.5","FRAX: herramienta de evaluaci\xf3n del riesgo de fractura a 10 a\xf1os"],examenFisico:[],pruebas:[{nombre:"DXA de columna lumbar (L1-L4) y cadera total/cuello femoral",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Radiograf\xedas de columna tor\xe1cica y lumbar (fracturas vertebrales)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Calcemia, f\xf3sforo, fosfatasa alcalina, PTH",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Vitamina D (25-OH-D3)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Funci\xf3n renal y hep\xe1tica",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Hemograma y VSG",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Cortisol urinario y TSH (osteoporosis secundaria)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Proteinograma (mieloma m\xfaltiple)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Marcadores de remodelado \xf3seo: CTX, P1NP",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]}]},tratamientoMedico:{objetivos:[],farmacologico:[{nombre:"Alendronato",grupo:"Bisfosfonato que se",mecanismo:"Bisfosfonato que se une a la hidroxiapatita \xf3sea e inhibe la actividad de los osteoclastos, reduciendo la resorci\xf3n \xf3sea",dosis:"70 mg VO semanal (o 10 mg diario). Tomar en ayunas con 200 mL agua, permanecer erguido 30 min",cuidadosEnfermeria:["Instruir al paciente: tomar con agua abundante en ayunas, no acostarse 30-60 minutos","Vigilar s\xedntomas esof\xe1gicos (disfagia, odinofagia, pirosis)","Asegurar aporte adecuado de calcio y vitamina D","Informar sobre la necesidad de revisi\xf3n dental antes de iniciar tratamiento","Educaci\xf3n sobre signos de fractura at\xedpica de f\xe9mur (dolor en muslo)","Contraindicado si ClCr <35 mL/min o hipocalcemia no corregida"]},{nombre:"Calcio + Vitamina D",grupo:"Calcio: mineral esencial",mecanismo:"Calcio: mineral esencial para la mineralizaci\xf3n \xf3sea. Vitamina D3: facilita la absorci\xf3n intestinal de calcio y la mineralizaci\xf3n \xf3sea; regula el metabolismo fosfoc\xe1lcico",dosis:"Calcio 1000-1200 mg/d\xeda VO (en 2-3 tomas con comidas) + Vitamina D3 800-2000 UI/d\xeda. Ajustar seg\xfan niveles de 25-OH-D3",cuidadosEnfermeria:["Administrar calcio con comidas para mejorar absorci\xf3n","Separar el calcio del hierro y quinolonas al menos 2 horas","Monitorizar calcemia y calciuria en tratamiento largo","Vigilar s\xedntomas de hipercalcemia (poliuria, estre\xf1imiento, confusi\xf3n)","Recomendar fuentes diet\xe9ticas de calcio adem\xe1s del suplemento","Verificar niveles de 25-OH-D3 para ajustar dosis"]},{nombre:"Denosumab",grupo:"Anticuerpo monoclonal anti-RANKL",mecanismo:"Anticuerpo monoclonal anti-RANKL que inhibe la diferenciaci\xf3n y activaci\xf3n de osteoclastos, reduciendo la resorci\xf3n \xf3sea",dosis:"60 mg SC cada 6 meses. No requiere ajuste en insuficiencia renal (alternativa a bisfosfonatos en IRC)",cuidadosEnfermeria:["Verificar calcemia antes de cada inyecci\xf3n","Asegurar suplementaci\xf3n adecuada de calcio y vitamina D","Vigilar signos de infecci\xf3n","Advertir sobre efecto rebote: NO suspender sin pasar a otro antirresortivo","Administrar en zona del muslo, abdomen o parte posterior del brazo","Guardar en nevera (2-8\xb0C), sacar 30 min antes de administrar"]}],noFarmacologico:["Ejercicio f\xedsico con carga de peso (caminar, danza) 30 min/d\xeda m\xednimo","Ejercicio de resistencia y equilibrio para reducir ca\xeddas","Dieta rica en calcio (l\xe1cteos, legumbres, vegetales de hoja verde)","Exposici\xf3n solar moderada para s\xedntesis de vitamina D","Abandono del tabaco y reducci\xf3n de alcohol","Prevenci\xf3n de ca\xeddas: adaptaci\xf3n del domicilio, calzado adecuado","Evitar sedentarismo prolongado","Protectores de cadera en pacientes con alto riesgo de fractura"]},cuidadosEnfermeria:{valoracion:["Identificar factores de riesgo: edad, sexo, menopausia, corticoides, tabaco, alcohol","Valorar historial de fracturas previas","Evaluar riesgo de ca\xeddas (Tinetti, Downton)","Registrar medicaci\xf3n actual (corticoides, antiepil\xe9pticos, IBP)","Valorar ingesta de calcio y vitamina D en la dieta","Evaluar nivel de actividad f\xedsica","Valorar dolor y limitaci\xf3n funcional"],intervenciones:["Identificar factores de riesgo de ca\xedda: polifarmacia, hipotensi\xf3n ortost\xe1tica, alteraci\xf3n visual","Adaptar el entorno: eliminar alfombras, instalar pasamanos, mejorar iluminaci\xf3n","Recomendar calzado antideslizante y de sujeci\xf3n","Ense\xf1ar t\xe9cnicas de levantamiento seguro desde la cama","Valorar necesidad de ayudas t\xe9cnicas (bast\xf3n, andador)","Supervisar el uso de medicamentos que aumentan riesgo de ca\xeddas (benzodiacepinas, antihipertensivos)","Explicar la fisiopatolog\xeda de la osteoporosis en t\xe9rminos comprensibles","Ense\xf1ar sobre la importancia del calcio y la vitamina D","Instruir sobre ejercicio f\xedsico adaptado a la edad y condici\xf3n","Educar sobre t\xe9cnica correcta de administraci\xf3n de bisfosfonatos (posici\xf3n, ayunas)","Informar sobre signos de fractura vertebral aguda y cu\xe1ndo consultar","Evaluar ingesta diet\xe9tica de calcio (objetivo: 1000-1200 mg/d\xeda de fuentes diet\xe9ticas)","Recomendar alimentos ricos en calcio: l\xe1cteos, sardinas, legumbres, br\xf3coli","Evaluar exposici\xf3n solar y recomendar estrategias para optimizar s\xedntesis de vitamina D","Desaconsejar dietas hiperproteicas e hipers\xf3dicas que aumentan calciuria","Recomendar reducci\xf3n de cafe\xedna y alcohol"],educacionPaciente:["Explicar qu\xe9 es la osteoporosis: 'hueso poroso' con mayor riesgo de fracturas","Insistir en la toma correcta de bisfosfonatos (ayunas, agua abundante, erguido 30 min)","Educar sobre fuentes diet\xe9ticas de calcio y vitamina D","Recomendar programa de ejercicio f\xedsico regular adaptado","Ense\xf1ar medidas de prevenci\xf3n de ca\xeddas en el hogar","Informar sobre la importancia del seguimiento con DXA cada 2-3 a\xf1os","Advertir sobre efectos secundarios del tratamiento y cu\xe1ndo consultar"],monitorizacion:[]},npiNanda:[{codigo:"00155",nombre:"Riesgo de ca\xeddas",definicion:"Vulnerable a sufrir una ca\xedda que puede causar da\xf1o f\xedsico",caracteristicasDefinitorias:[],factoresRelacionados:["Osteoporosis","Edad avanzada","Alteraci\xf3n del equilibrio","Polifarmacia"]},{codigo:"00035",nombre:"Riesgo de lesi\xf3n",definicion:"Vulnerable a sufrir una lesi\xf3n como resultado de la interacci\xf3n de condiciones ambientales con los recursos adaptativos y defensivos de la persona",caracteristicasDefinitorias:[],factoresRelacionados:["Fragilidad \xf3sea","Osteoporosis"]},{codigo:"00126",nombre:"Conocimientos deficientes",definicion:"Ausencia o deficiencia de informaci\xf3n cognitiva relacionada con un tema espec\xedfico",caracteristicasDefinitorias:["Verbalizaci\xf3n de problemas","Comportamiento inadecuado","Incumplimiento terap\xe9utico"],factoresRelacionados:["Falta de informaci\xf3n sobre la osteoporosis y su tratamiento"]}],npiNic:[{codigo:"6490",nombre:"Prevenci\xf3n de ca\xeddas",actividades:["Identificar factores de riesgo de ca\xedda: polifarmacia, hipotensi\xf3n ortost\xe1tica, alteraci\xf3n visual","Adaptar el entorno: eliminar alfombras, instalar pasamanos, mejorar iluminaci\xf3n","Recomendar calzado antideslizante y de sujeci\xf3n","Ense\xf1ar t\xe9cnicas de levantamiento seguro desde la cama","Valorar necesidad de ayudas t\xe9cnicas (bast\xf3n, andador)","Supervisar el uso de medicamentos que aumentan riesgo de ca\xeddas (benzodiacepinas, antihipertensivos)"]},{codigo:"5602",nombre:"Ense\xf1anza: proceso de la enfermedad",actividades:["Explicar la fisiopatolog\xeda de la osteoporosis en t\xe9rminos comprensibles","Ense\xf1ar sobre la importancia del calcio y la vitamina D","Instruir sobre ejercicio f\xedsico adaptado a la edad y condici\xf3n","Educar sobre t\xe9cnica correcta de administraci\xf3n de bisfosfonatos (posici\xf3n, ayunas)","Informar sobre signos de fractura vertebral aguda y cu\xe1ndo consultar"]},{codigo:"1120",nombre:"Terapia nutricional",actividades:["Evaluar ingesta diet\xe9tica de calcio (objetivo: 1000-1200 mg/d\xeda de fuentes diet\xe9ticas)","Recomendar alimentos ricos en calcio: l\xe1cteos, sardinas, legumbres, br\xf3coli","Evaluar exposici\xf3n solar y recomendar estrategias para optimizar s\xedntesis de vitamina D","Desaconsejar dietas hiperproteicas e hipers\xf3dicas que aumentan calciuria","Recomendar reducci\xf3n de cafe\xedna y alcohol"]}],npiNoc:[{codigo:"1909",nombre:"Conducta de prevenci\xf3n de ca\xeddas",indicadores:["Uso de calzado adecuado","Eliminaci\xf3n de riesgos del hogar","Uso de ayudas para la movilidad"],escala:"Implementaci\xf3n de medidas de prevenci\xf3n de ca\xeddas en el domicilio en 1 mes"},{codigo:"1805",nombre:"Conocimiento: conducta sanitaria",indicadores:["Descripci\xf3n de la enfermedad","Adherencia al tratamiento farmacol\xf3gico","Pr\xe1ctica de ejercicio regular"],escala:"Verbalizaci\xf3n correcta del plan terap\xe9utico en 2 semanas"}],complicaciones:["Fractura vertebral por compresi\xf3n (la m\xe1s frecuente)","Fractura de cadera (mayor morbimortalidad)","Fractura de Colles (mu\xf1eca)","Cifosis progresiva con restricci\xf3n respiratoria","S\xedndrome de dolor cr\xf3nico","Dependencia funcional y aislamiento social","Esofagitis por bisfosfonatos (si mala t\xe9cnica de administraci\xf3n)","Osteonecrosis de mand\xedbula (rara, por bisfosfonatos/denosumab)"],criteriosAlarma:["Fractura vertebral con compresi\xf3n medular (urgencia neuroquir\xfargica)","Fractura de cadera (alta morbimortalidad en ancianos)","P\xe9rdida de talla s\xfabita (fractura vertebral aguda)","Dolor dorsal agudo intenso en paciente con factores de riesgo"],emergencyLevel:"leve",relatedPathologyIds:[],isPremium:!1},{id:"pat_artritis_reumatoide",nombre:"Artritis Reumatoide",bodySystemId:"musculoesqueletico",definicion:"Enfermedad autoinmune sist\xe9mica cr\xf3nica caracterizada por sinovitis proliferativa que afecta principalmente articulaciones perif\xe9ricas de forma sim\xe9trica, con potencial para causar destrucci\xf3n articular, discapacidad y manifestaciones extraarticulares.",epidemiologia:"",factoresRiesgo:[],fisiopatologia:"La AR es una enfermedad de la sinovial mediada por c\xe9lulas T autorreactivas que reconocen ant\xedgenos articulares (p\xe9ptidos citrulinados). La activaci\xf3n de linfocitos T CD4+ lleva a la liberaci\xf3n de citocinas proinflamatorias (TNF-alfa, IL-1, IL-6, IL-17) que activan sinoviocitos y macr\xf3fagos. Se forma el pannus: tejido sinovial hiperpl\xe1sico altamente vascularizado que invade el cart\xedlago articular y el hueso subcondral, destruy\xe9ndolos mediante metaloproteinasas. El Factor Reumatoide (FR) y los Anticuerpos Anti-P\xe9ptidos Citrulinados (ACPA/anti-CCP) contribuyen a la inflamaci\xf3n mediada por inmunocomplejos.",signosYSintomas:{signos:["Artritis sim\xe9trica de peque\xf1as articulaciones (MCF, IFP, mu\xf1ecas)","Rigidez matutina >1 hora","Tumefacci\xf3n y dolor articular","Calor local en articulaciones afectadas","Limitaci\xf3n del rango de movimiento","Subluxaci\xf3n atlantoaxoidea (rigidez o dolor cervical con mielopat\xeda)","Pericarditis o pleures\xeda","Vasculitis con \xfalceras cut\xe1neas","Escleritis","Infecci\xf3n articular (artritis s\xe9ptica sobre AR)","S\xedntomas de compresi\xf3n medular"],sintomas:["N\xf3dulos reumatoides subcut\xe1neos","Fatiga intensa","Fiebre de bajo grado","P\xe9rdida de peso","Anemia normoc\xedtica normocr\xf3mica","S\xedndrome de Sj\xf6gren secundario (xerostom\xeda, xeroftalmia)","Vasculitis reumatoide (rara)"]},diagnostico:{anamnesis:["Criterios ACR/EULAR 2010: puntuaci\xf3n \u22656/10","Afectaci\xf3n articular: 1 articulaci\xf3n grande (0), 2-10 grandes (1), 1-3 peque\xf1as (2), 4-10 peque\xf1as (3), >10 (5)","Serolog\xeda: FR-/ACPA- bajo t\xedtulo (2), alto t\xedtulo (3)","Reactantes de fase aguda: VSG/PCR normales (0), anormales (1)","Duraci\xf3n: <6 semanas (0), \u22656 semanas (1)"],examenFisico:[],pruebas:[{nombre:"FR (Factor Reumatoide): positivo en 70-80%",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Anti-CCP (ACPA): alta especificidad (95%), puede ser positivo a\xf1os antes",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"PCR y VSG (actividad inflamatoria)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Hemograma: anemia, leucocitosis, trombocitosis en brote",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Funci\xf3n renal y hep\xe1tica (antes de iniciar FAMEs)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Radiograf\xedas de manos y pies: erosiones, osteopenia periarticular",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Ecograf\xeda articular con doppler: detecci\xf3n precoz de sinovitis",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"RMN: valoraci\xf3n de erosiones y da\xf1o temprano",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"PPD/IGRA y serolog\xeda hepatitis B y C (antes de biol\xf3gicos)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]}]},tratamientoMedico:{objetivos:[],farmacologico:[{nombre:"Metotrexato",grupo:"FAME (F\xe1rmaco Antirreum\xe1tico",mecanismo:"FAME (F\xe1rmaco Antirreum\xe1tico Modificador de la Enfermedad) convencional. Inhibidor de dihidrofolato reductasa que reduce la s\xedntesis de purinas y pirimidinas. En AR: inhibe la proliferaci\xf3n linfocitaria y la producci\xf3n de citocinas proinflamatorias",dosis:"7.5-25 mg VO o SC una vez por semana. Iniciar con 7.5-10 mg y aumentar mensualmente. Suplementar \xe1cido f\xf3lico 5 mg/semana (24h despu\xe9s del MTX)",cuidadosEnfermeria:["Administrar siempre el mismo d\xeda de la semana (evitar errores de dosis diaria)","Verificar hemograma y funci\xf3n hep\xe1tica antes de iniciar y peri\xf3dicamente","Asegurar suplementaci\xf3n con \xe1cido f\xf3lico 5 mg (no el mismo d\xeda que MTX)","Vigilar s\xedntomas de toxicidad hep\xe1tica (ictericia, n\xe1useas persistentes)","Vigilar s\xedntomas respiratorios (tos, disnea: posible neumonitis)","Instruir sobre evitar embarazo (hombres y mujeres) durante tratamiento y 3-6 meses despu\xe9s","Evitar alcohol durante el tratamiento","No administrar AINE junto a MTX (aumenta toxicidad)"]},{nombre:"Adalimumab",grupo:"Anticuerpo monoclonal humano",mecanismo:"Anticuerpo monoclonal humano anti-TNF-alfa que neutraliza el TNF soluble y unido a membrana, bloqueando la cascada inflamatoria mediada por TNF",dosis:"40 mg SC cada 2 semanas. Habitualmente en combinaci\xf3n con metotrexato",cuidadosEnfermeria:["Descartar tuberculosis latente (Mantoux/IGRA) y hepatitis B antes de iniciar","Vigilar signos de infecci\xf3n en cada visita (fiebre, s\xedntomas respiratorios, urinarios)","Instruir al paciente sobre c\xf3mo autoadministrarse la inyecci\xf3n SC","Guardar en nevera 2-8\xb0C, sacar 30 min antes de administrar","Suspender si infecci\xf3n grave o cirug\xeda mayor","No administrar vacunas vivas durante el tratamiento","Vigilar signos de insuficiencia card\xedaca descompensada"]},{nombre:"Prednisona",grupo:"Glucocorticoide que inhibe",mecanismo:"Glucocorticoide que inhibe la fosfolipasa A2 (reduciendo prostaglandinas y leucotrienos), suprime la expresi\xf3n de citocinas proinflamatorias y reduce la migraci\xf3n de leucocitos",dosis:"Brotes agudos: 5-20 mg/d\xeda VO durante 1-4 semanas con reducci\xf3n progresiva. Puente hasta efecto de FAMEs: 5-10 mg/d\xeda (no superar 6 meses)",cuidadosEnfermeria:["Tomar con desayuno (ritmo circadiano) para reducir insomnio","Monitorizar glucemia, PA y peso peri\xf3dicamente","Iniciar profilaxis de osteoporosis (calcio + vitamina D + bisfosfonato si dosis alta >3 meses)","No suspender bruscamente (riesgo de insuficiencia suprarrenal)","Vigilar signos de infecci\xf3n (puede estar enmascarados)","Usar la dosis m\xednima eficaz el menor tiempo posible"]}],noFarmacologico:["Reposo articular durante brotes agudos intensos","Fisioterapia: ejercicios de fortalecimiento y rango de movimiento","Terapia ocupacional: adaptaci\xf3n de actividades y dispositivos de asistencia","Ortesis: f\xe9rulas de reposo nocturno para mu\xf1ecas y manos","Termoterapia: calor seco en rigidez matutina, fr\xedo en brotes agudos","Control del peso corporal","Educaci\xf3n articular (protecci\xf3n articular)","Apoyo psicol\xf3gico (impacto en calidad de vida)"]},cuidadosEnfermeria:{valoracion:["Evaluar n\xfamero de articulaciones dolorosas y tumefactas (DAS28)","Valorar rigidez matutina en duraci\xf3n (minutos)","Evaluar funci\xf3n articular y capacidad funcional (HAQ)","Monitorizar constantes vitales y temperatura","Valorar dolor con EVA y su impacto en actividades diarias","Revisar adherencia al tratamiento farmacol\xf3gico","Valorar efectos adversos de medicamentos actuales","Evaluar estado nutricional y peso"],intervenciones:["Aplicar calor seco por las ma\xf1anas (ducha caliente, guantes t\xe9rmicos) para reducir rigidez matutina","Aplicar fr\xedo local durante los brotes agudos para reducir la inflamaci\xf3n","Administrar analg\xe9sicos pautados antes de actividades que generan dolor","Valorar dolor con EVA antes y despu\xe9s de intervenciones","Ense\xf1ar t\xe9cnicas de relajaci\xf3n y distracci\xf3n","Realizar movilizaciones pasivas y activo-asistidas en articulaciones afectadas","Recomendar ejercicio en agua (hidroterapia) para reducir carga articular","Ense\xf1ar ejercicios de rango de movimiento para realizar en domicilio","Instruir sobre el uso de f\xe9rulas de reposo nocturno para mu\xf1ecas","Coordinar con fisioterapeuta el programa de rehabilitaci\xf3n","Verificar hemograma y funci\xf3n hep\xe1tica antes de administrar metotrexato","Recordar al paciente que el metotrexato se administra una vez por semana (riesgo de confusi\xf3n)","Asegurarse de que el \xe1cido f\xf3lico se administra en un d\xeda diferente al metotrexato","Instruir sobre la t\xe9cnica de autoinyecci\xf3n de f\xe1rmacos biol\xf3gicos","Registrar y monitorizar efectos adversos de cada medicaci\xf3n"],educacionPaciente:["Explicar la naturaleza cr\xf3nica de la AR y la importancia del tratamiento continuo","Ense\xf1ar t\xe9cnicas de protecci\xf3n articular: evitar posiciones viciosas, usar utensilios adaptados","Instruir sobre la importancia de la ducha caliente matutina para reducir rigidez","Educar sobre signos de infecci\xf3n y cu\xe1ndo suspender los FAMEs o biol\xf3gicos","Informar sobre la importancia de las anal\xedticas de control peri\xf3dicas","Recomendar vacunaci\xf3n (gripe anual, neumococo, hepatitis B) antes de iniciar biol\xf3gicos","Insistir en NO suspender el tratamiento durante los periodos de remisi\xf3n"],monitorizacion:[]},npiNanda:[{codigo:"00132",nombre:"Dolor agudo/cr\xf3nico",definicion:"Experiencia sensitiva y emocional desagradable asociada a la inflamaci\xf3n articular",caracteristicasDefinitorias:["Dolor articular sim\xe9trico","Rigidez matutina >1h","Articulaciones tumefactas y calientes"],factoresRelacionados:["Sinovitis","Destrucci\xf3n articular","Inflamaci\xf3n cr\xf3nica"]},{codigo:"00085",nombre:"Deterioro de la movilidad f\xedsica",definicion:"Limitaci\xf3n del movimiento f\xedsico independiente e intencionado del cuerpo",caracteristicasDefinitorias:["Limitaci\xf3n del rango de movimiento","Dificultad para actividades finas de la mano","Marcha alterada"],factoresRelacionados:["Dolor articular","Inflamaci\xf3n","Deformidades articulares"]},{codigo:"00093",nombre:"Fatiga",definicion:"Sensaci\xf3n abrumadora y sostenida de agotamiento y disminuci\xf3n de la capacidad para el trabajo f\xedsico y mental al nivel habitual",caracteristicasDefinitorias:["Cansancio intenso","Incapacidad para mantener el nivel habitual de actividad","Falta de energ\xeda"],factoresRelacionados:["Proceso inflamatorio cr\xf3nico","Anemia","Dolor","Medicaci\xf3n"]}],npiNic:[{codigo:"1400",nombre:"Manejo del dolor",actividades:["Aplicar calor seco por las ma\xf1anas (ducha caliente, guantes t\xe9rmicos) para reducir rigidez matutina","Aplicar fr\xedo local durante los brotes agudos para reducir la inflamaci\xf3n","Administrar analg\xe9sicos pautados antes de actividades que generan dolor","Valorar dolor con EVA antes y despu\xe9s de intervenciones","Ense\xf1ar t\xe9cnicas de relajaci\xf3n y distracci\xf3n"]},{codigo:"0224",nombre:"Terapia de ejercicios: movilidad articular",actividades:["Realizar movilizaciones pasivas y activo-asistidas en articulaciones afectadas","Recomendar ejercicio en agua (hidroterapia) para reducir carga articular","Ense\xf1ar ejercicios de rango de movimiento para realizar en domicilio","Instruir sobre el uso de f\xe9rulas de reposo nocturno para mu\xf1ecas","Coordinar con fisioterapeuta el programa de rehabilitaci\xf3n"]},{codigo:"2300",nombre:"Administraci\xf3n de medicaci\xf3n",actividades:["Verificar hemograma y funci\xf3n hep\xe1tica antes de administrar metotrexato","Recordar al paciente que el metotrexato se administra una vez por semana (riesgo de confusi\xf3n)","Asegurarse de que el \xe1cido f\xf3lico se administra en un d\xeda diferente al metotrexato","Instruir sobre la t\xe9cnica de autoinyecci\xf3n de f\xe1rmacos biol\xf3gicos","Registrar y monitorizar efectos adversos de cada medicaci\xf3n"]}],npiNoc:[{codigo:"2102",nombre:"Nivel del dolor",indicadores:["Dolor referido","Duraci\xf3n de la rigidez matutina","N\xfamero de articulaciones dolorosas"],escala:"Reducci\xf3n del DAS28 a valores de baja actividad (<3.2) en 3-6 meses"},{codigo:"0208",nombre:"Movilidad",indicadores:["Mantenimiento de la posici\xf3n corporal","Movimiento muscular","Realizaci\xf3n de AVD"],escala:"Mantener o mejorar la funci\xf3n articular (HAQ \u22641) en 6 meses"}],complicaciones:["Destrucci\xf3n articular con deformidades (desviaci\xf3n cubital, cuello de cisne, boutonni\xe8re)","Subluxaci\xf3n atlantoaxoidea con mielopat\xeda","Vasculitis reumatoide","Afectaci\xf3n pulmonar (fibrosis, neumonitis por MTX)","Infecciones oportunistas por inmunosupresi\xf3n","Amiloidosis secundaria (complicaci\xf3n tard\xeda)","S\xedndrome de Felty (neutropenia + esplenomegalia)","Mayor riesgo cardiovascular","Osteoporosis secundaria (por corticoides o inmovilidad)"],criteriosAlarma:["Subluxaci\xf3n atlantoaxoidea (rigidez o dolor cervical con mielopat\xeda)","Pericarditis o pleures\xeda","Vasculitis con \xfalceras cut\xe1neas","Escleritis","Infecci\xf3n articular (artritis s\xe9ptica sobre AR)","S\xedntomas de compresi\xf3n medular"],emergencyLevel:"moderado",relatedPathologyIds:[],isPremium:!1},{id:"pat_hernia_discal",nombre:"Hernia Discal",bodySystemId:"musculoesqueletico",definicion:"Protrusi\xf3n o extrusi\xf3n del n\xfacleo pulposo a trav\xe9s del anillo fibroso del disco intervertebral, que puede comprimir las ra\xedces nerviosas o la m\xe9dula espinal. La localizaci\xf3n m\xe1s frecuente es L4-L5 y L5-S1 en columna lumbar, y C5-C6 en columna cervical.",epidemiologia:"",factoresRiesgo:[],fisiopatologia:"El disco intervertebral act\xfaa como amortiguador entre los cuerpos vertebrales. Con el envejecimiento o microtraumatismos repetidos, el anillo fibroso se debilita y el n\xfacleo pulposo (rico en proteoglicanos hidr\xf3filos) puede herniarse. La compresi\xf3n mec\xe1nica de la ra\xedz nerviosa, junto a la inflamaci\xf3n qu\xedmica local (fosfolipasa A2, citocinas), provoca dolor radicular. La compresi\xf3n de la m\xe9dula espinal (en hernias cervicales o dorsales grandes) puede causar mielopat\xeda. El s\xedndrome de la cola de caballo ocurre cuando la compresi\xf3n de las ra\xedces L2-S5 produce incontinencia y anestesia en silla de montar.",signosYSintomas:{signos:["Dolor lumbar o cervical que se irradia por el dermatoma correspondiente (ci\xe1tica en L4-L5, L5-S1)","Parestesias (hormigueo, acorchamiento) en miembro afectado","D\xe9ficit neurol\xf3gico: debilidad muscular, hiporreflexia","Maniobra de Las\xe8gue positiva (hernia lumbar): dolor al elevar la pierna extendida","Agravamiento del dolor con tos, estornudo o valsalva","S\xedndrome de cola de caballo: incontinencia vesical/intestinal, anestesia en silla de montar (URGENCIA QUIR\xdaRGICA)","D\xe9ficit neurol\xf3gico progresivo (debilidad r\xe1pidamente creciente)","Mielopat\xeda cervical: torpeza en manos, marcha esp\xe1stica","Fiebre + dolor intenso (espondilodiscitis)","P\xe9rdida de peso + dolor (descartar neoplasia)"],sintomas:["Rigidez paravertebral y contractura muscular","Escoliosis ant\xe1lgica","Limitaci\xf3n del rango de movimiento vertebral","Dolor nocturno que impide el descanso","Dificultad para caminar o mantenerse erguido"]},diagnostico:{anamnesis:["Cl\xednica radicular compatible con nivel de hernia sospechado","RMN de columna (gold standard): visualiza hernia, su relaci\xf3n con ra\xedces y m\xe9dula","TC columna: \xfatil cuando hay contraindicaci\xf3n para RMN o valoraci\xf3n \xf3sea","Electroneurograf\xeda/EMG: confirma el nivel de afectaci\xf3n radicular"],examenFisico:[],pruebas:[{nombre:"RMN columna lumbosacra o cervical seg\xfan cl\xednica",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Radiograf\xedas de columna (hernia no visible pero descarta fracturas, espondilolistesis)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"TC mielograf\xeda si contraindicada RMN",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Hemograma, VSG, PCR (descartar proceso infeccioso o neopl\xe1sico)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"PSA en hombres >50 a\xf1os (met\xe1stasis prost\xe1ticas)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Estudio electrofisiol\xf3gico en casos dudosos",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]}]},tratamientoMedico:{objetivos:[],farmacologico:[{nombre:"Ibuprofeno",grupo:"AINE inhibidor no",mecanismo:"AINE inhibidor no selectivo de COX-1 y COX-2 que reduce la s\xedntesis de prostaglandinas, disminuyendo el dolor y la inflamaci\xf3n local",dosis:"400-600 mg VO cada 8 horas con alimentos, m\xe1ximo 2 semanas. Usar IBP de protecci\xf3n g\xe1strica",cuidadosEnfermeria:["Administrar con alimentos o leche para reducir irritaci\xf3n g\xe1strica","Vigilar signos de hemorragia digestiva (melenas, v\xf3mitos con sangre)","Monitorizar funci\xf3n renal y PA en tratamiento prolongado","Verificar contraindicaciones: insuficiencia renal, cardiopat\xeda, embarazo","Asegurarse de uso concomitante de IBP (omeprazol)","Evitar en pacientes con asma aspirinosa"]},{nombre:"Pregabalina",grupo:"Ligando de la",mecanismo:"Ligando de la subunidad alfa-2-delta de canales de calcio voltaje-dependientes, que reduce la liberaci\xf3n de neurotransmisores excitadores, disminuyendo el dolor neurop\xe1tico",dosis:"75-150 mg VO cada 12 horas, iniciar con 75 mg y aumentar gradualmente seg\xfan respuesta y tolerancia",cuidadosEnfermeria:["Iniciar con dosis bajas y aumentar gradualmente","Advertir sobre riesgo de conducci\xf3n de veh\xedculos (somnolencia, mareo)","Monitorizar edemas perif\xe9ricos","No suspender bruscamente (reducci\xf3n gradual)","Ajustar dosis en insuficiencia renal (aclaramiento de creatinina)","Vigilar deterioro cognitivo en ancianos"]},{nombre:"Dexametasona",grupo:"Corticoide potente que",mecanismo:"Corticoide potente que reduce el edema perirradicular y la inflamaci\xf3n qu\xedmica local, aliviando la compresi\xf3n nerviosa",dosis:"Dosis \xfanica IM: 8-12 mg IM. O pauta oral: 6 mg/d\xeda con reducci\xf3n progresiva en 5-7 d\xedas",cuidadosEnfermeria:["Monitorizar glucemia especialmente en pacientes diab\xe9ticos","Administrar con protecci\xf3n g\xe1strica si se dan varios d\xedas","Vigilar signos de infecci\xf3n (pueden estar enmascarados)","Informar sobre posible insomnio o euforia transitoria","No suspender bruscamente si se administra m\xe1s de 1 semana"]}],noFarmacologico:["Reposo relativo 1-3 d\xedas (no reposo absoluto prolongado, empeora pron\xf3stico)","Fisioterapia: programa de estabilizaci\xf3n lumbar, tracci\xf3n cuando indicada","Infiltraciones epidurales de corticosteroides (imagen guiada)","Termoterapia: calor superficial para alivio de contractura muscular","Cirug\xeda (microdiscectom\xeda): indicada en s\xedndrome de cola de caballo, d\xe9ficit neurol\xf3gico progresivo o fracaso de tratamiento conservador >6-12 semanas"]},cuidadosEnfermeria:{valoracion:["Valorar dolor con EVA y distribuci\xf3n radicular","Evaluar fuerza muscular en miembros afectados (escala 0-5 del MRC)","Verificar reflejos osteotendinosos (rotuliano, aqu\xedleo)","Evaluar sensibilidad t\xe1ctil y dolorosa en dermatoma afectado","Valorar control de esf\xednteres vesical e intestinal","Detectar s\xedndrome de cola de caballo (URGENCIA): anestesia perineal, incontinencia","Evaluar postura y marcha","Valorar impacto en actividades de la vida diaria"],intervenciones:["Posicionar al paciente en dec\xfabito lateral con caderas y rodillas flexionadas para reducir presi\xf3n discal","Aplicar calor superficial local para aliviar contractura paravertebral","Administrar analg\xe9sicos pautados y valorar su efectividad","Ense\xf1ar higiene postural y mec\xe1nica corporal correcta","Instruir sobre posturas de alivio del dolor (posici\xf3n de Williams en hernias lumbares)","Ense\xf1ar t\xe9cnica de levantamiento de cama con rotaci\xf3n en bloque (log-roll)","Indicar que al levantarse de la cama primero gire de lado, luego incorpore el tronco","Ense\xf1ar a no flexionar el tronco al recoger objetos del suelo (doblar rodillas)","Recomendar colch\xf3n firme (no duro) que mantenga la alineaci\xf3n vertebral","Verificar posici\xf3n neutra de columna durante el reposo","Evaluar fuerza muscular diariamente en miembros afectados","Detectar precozmente signos de s\xedndrome de cola de caballo: anestesia en silla de montar, incontinencia (requiere intervenci\xf3n urgente)","Vigilar progresi\xf3n del d\xe9ficit neurol\xf3gico","Documentar cambios en la exploraci\xf3n neurol\xf3gica","Alertar al m\xe9dico ante deterioro neurol\xf3gico agudo"],educacionPaciente:["Ense\xf1ar higiene postural: no flexionar el tronco, doblar rodillas para recoger objetos","Instruir sobre la t\xe9cnica correcta para levantarse de la cama (rotaci\xf3n en bloque)","Explicar que el reposo absoluto prolongado empeora el pron\xf3stico (caminar despacio es beneficioso)","Advertir sobre signos de alarma del s\xedndrome de cola de caballo y cu\xe1ndo acudir a urgencias","Explicar el programa de ejercicios de estabilizaci\xf3n lumbar a realizar en casa","Informar que la mayor\xeda de hernias discales mejoran con tratamiento conservador en 6-12 semanas","Recomendar reducci\xf3n de peso si existe sobrepeso"],monitorizacion:[]},npiNanda:[{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable asociada a la compresi\xf3n radicular",caracteristicasDefinitorias:["Dolor irradiado al miembro","Signo de Las\xe8gue positivo","Postura anti\xe1lgica"],factoresRelacionados:["Compresi\xf3n de ra\xedz nerviosa","Inflamaci\xf3n perirradicular","Espasmo muscular"]},{codigo:"00085",nombre:"Deterioro de la movilidad f\xedsica",definicion:"Limitaci\xf3n del movimiento f\xedsico independiente e intencionado del cuerpo",caracteristicasDefinitorias:["Limitaci\xf3n para caminar","Incapacidad para flexionar la columna","Marcha anti\xe1lgica"],factoresRelacionados:["Dolor","Deficit neurol\xf3gico","Contractura muscular"]},{codigo:"00044",nombre:"Deterioro de la integridad tisular",definicion:"Da\xf1o en la membrana mucosa, c\xf3rnea, sistema tegumentario, fascia muscular, m\xfasculo, tend\xf3n, hueso, cart\xedlago, c\xe1psula articular o ligamento",caracteristicasDefinitorias:["Parestesias","D\xe9ficit sensorial","Debilidad muscular"],factoresRelacionados:["Compresi\xf3n del tejido nervioso"]}],npiNic:[{codigo:"1400",nombre:"Manejo del dolor",actividades:["Posicionar al paciente en dec\xfabito lateral con caderas y rodillas flexionadas para reducir presi\xf3n discal","Aplicar calor superficial local para aliviar contractura paravertebral","Administrar analg\xe9sicos pautados y valorar su efectividad","Ense\xf1ar higiene postural y mec\xe1nica corporal correcta","Instruir sobre posturas de alivio del dolor (posici\xf3n de Williams en hernias lumbares)"]},{codigo:"0840",nombre:"Cambio de posici\xf3n",actividades:["Ense\xf1ar t\xe9cnica de levantamiento de cama con rotaci\xf3n en bloque (log-roll)","Indicar que al levantarse de la cama primero gire de lado, luego incorpore el tronco","Ense\xf1ar a no flexionar el tronco al recoger objetos del suelo (doblar rodillas)","Recomendar colch\xf3n firme (no duro) que mantenga la alineaci\xf3n vertebral","Verificar posici\xf3n neutra de columna durante el reposo"]},{codigo:"2620",nombre:"Monitorizaci\xf3n neurol\xf3gica",actividades:["Evaluar fuerza muscular diariamente en miembros afectados","Detectar precozmente signos de s\xedndrome de cola de caballo: anestesia en silla de montar, incontinencia (requiere intervenci\xf3n urgente)","Vigilar progresi\xf3n del d\xe9ficit neurol\xf3gico","Documentar cambios en la exploraci\xf3n neurol\xf3gica","Alertar al m\xe9dico ante deterioro neurol\xf3gico agudo"]}],npiNoc:[{codigo:"2102",nombre:"Nivel del dolor",indicadores:["Dolor referido en reposo","Dolor al movimiento","Irradiaci\xf3n radicular"],escala:"Reducci\xf3n del dolor a EVA \u22644 en reposo en 1-2 semanas con tratamiento conservador"},{codigo:"0916",nombre:"Estado neurol\xf3gico: sensitivo-motor perif\xe9rico",indicadores:["Fuerza muscular distal","Sensibilidad t\xe1ctil y dolorosa","Reflejos osteotendinosos"],escala:"Mantenimiento o mejor\xeda del estado neurol\xf3gico sin progresi\xf3n del d\xe9ficit"}],complicaciones:["S\xedndrome de cola de caballo (urgencia neuroquir\xfargica)","D\xe9ficit neurol\xf3gico permanente","Dolor cr\xf3nico","Dependencia funcional","Estenosis de canal lumbar secundaria","Complicaciones postquir\xfargicas: infecci\xf3n, f\xedstula de LCR, fibrosis epidural","S\xedndrome postlaminectom\xeda (dolor cr\xf3nico tras cirug\xeda)"],criteriosAlarma:["S\xedndrome de cola de caballo: incontinencia vesical/intestinal, anestesia en silla de montar (URGENCIA QUIR\xdaRGICA)","D\xe9ficit neurol\xf3gico progresivo (debilidad r\xe1pidamente creciente)","Mielopat\xeda cervical: torpeza en manos, marcha esp\xe1stica","Fiebre + dolor intenso (espondilodiscitis)","P\xe9rdida de peso + dolor (descartar neoplasia)"],emergencyLevel:"moderado",relatedPathologyIds:[],isPremium:!0},{id:"pat_osteomielitis",nombre:"Osteomielitis",bodySystemId:"musculoesqueletico",definicion:"Infecci\xf3n del tejido \xf3seo, que puede ser aguda o cr\xf3nica. En ni\xf1os predomina la forma hemat\xf3gena (Staphylococcus aureus). En adultos frecuentemente asociada a traumatismos, cirug\xedas o \xfalceras por presi\xf3n. Requiere tratamiento antibi\xf3tico prolongado y frecuentemente cirug\xeda.",epidemiologia:"",factoresRiesgo:[],fisiopatologia:"En la osteomielitis hemat\xf3gena, las bacterias llegan al hueso por v\xeda sangu\xednea, asentando preferentemente en la met\xe1fisis (\xe1rea de mayor flujo sangu\xedneo y menor actividad fagoc\xedtica). La respuesta inflamatoria produce edema intra\xf3seo que comprime los vasos, generando isquemia y necrosis \xf3sea (secuestro). La infecci\xf3n puede formar abscesos subperi\xf3sticos que elevan el periostio, comprometiendo la vascularizaci\xf3n cortical. En la forma cr\xf3nica, el hueso necr\xf3tico (secuestro) act\xfaa como cuerpo extra\xf1o que perpet\xfaa la infecci\xf3n, con formaci\xf3n de hueso reactivo perif\xe9rico (involucrum) y trayectos fistulosos.",signosYSintomas:{signos:["Dolor intenso localizado en el hueso afectado","Calor, rubor y edema sobre el \xe1rea \xf3sea","Fiebre alta (aguda) o febr\xedcula intermitente (cr\xf3nica)","Impotencia funcional del miembro afectado","Trayectos fistulosos con exudado purulento (forma cr\xf3nica)","Sepsis con inestabilidad hemodin\xe1mica","Artritis s\xe9ptica concomitante (emergencia)","Absceso epidural con mielopat\xeda (osteomielitis vertebral)","Progresi\xf3n r\xe1pida a shock s\xe9ptico","Fallo multiorg\xe1nico"],sintomas:["Bacteriemia con afectaci\xf3n del estado general","Leucocitosis con neutrofilia","Elevaci\xf3n de PCR y VSG","Linfadenopat\xeda regional","Eritema cut\xe1neo sobre zona afectada"]},diagnostico:{anamnesis:["Cl\xednica compatible + hallazgos de imagen","Cultivo de tejido \xf3seo o hemocultivo positivo","Histolog\xeda compatible con infecci\xf3n \xf3sea"],examenFisico:[],pruebas:[{nombre:"RMN (gold standard para osteomielitis temprana): edema medular, captaci\xf3n de contraste",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"TC \xf3sea: destrucci\xf3n cortical, secuestros, involucrum",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Gammagraf\xeda \xf3sea con Tc-99m: \xfatil cuando RMN no disponible",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Hemocultivos (2 series antes de antibi\xf3ticos)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Biopsia \xf3sea con gu\xeda radiol\xf3gica o intraoperatoria (muestra de elecci\xf3n)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Hemograma: leucocitosis con neutrofilia",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"PCR, VSG (seguimiento de respuesta al tratamiento)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Procalcitonina (marcador de sepsis bacteriana)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Radiograf\xeda \xf3sea (normal en primeras 2 semanas)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]}]},tratamientoMedico:{objetivos:[],farmacologico:[{nombre:"Cloxacilina",grupo:"Penicilina semisint\xe9tica resistente",mecanismo:"Penicilina semisint\xe9tica resistente a penicilinasas estafiloc\xf3cicas, act\xfaa inhibiendo la s\xedntesis de pared celular bacteriana mediante la uni\xf3n a prote\xednas de uni\xf3n a penicilinas (PBP)",dosis:"2 g IV cada 4-6 horas (12 g/d\xeda en adultos). Tratamiento IV m\xednimo 4-6 semanas; paso a oral seg\xfan respuesta cl\xednica y tolerancia",cuidadosEnfermeria:["Preguntar antecedentes de alergia a penicilinas antes de administrar","Reconstituir y diluir correctamente para infusi\xf3n IV (verificar compatibilidad)","Monitorizar funci\xf3n hep\xe1tica y renal peri\xf3dicamente","Vigilar signos de flebitis en punto de inserci\xf3n del cat\xe9ter IV","Controlar temperatura y evoluci\xf3n de marcadores inflamatorios","Vigilar s\xedntomas de colitis por C. difficile (diarrea, dolor abdominal)"]},{nombre:"Vancomicina",grupo:"Glucop\xe9ptido que inhibe",mecanismo:"Glucop\xe9ptido que inhibe la s\xedntesis de pared celular bacteriana uni\xe9ndose al dip\xe9ptido D-Ala-D-Ala de los precursores del peptidoglicano. Activo contra MRSA y enterococos",dosis:"15-20 mg/kg IV cada 8-12 horas, ajustando para mantener \xe1rea bajo la curva (AUC/MIC 400-600). Guiada por niveles plasm\xe1ticos (monitorizaci\xf3n farmacocin\xe9tica)",cuidadosEnfermeria:["Infundir siempre lentamente (m\xednimo 60 minutos por gramo) para evitar s\xedndrome del hombre rojo","Monitorizar funci\xf3n renal (creatinina, urea) diariamente","Solicitar niveles plasm\xe1ticos seg\xfan protocolo (PK/PD monitoring)","Vigilar s\xedntomas de ototoxicidad: tinitus, hipoacusia","Evitar f\xe1rmacos nefrot\xf3xicos concomitantes (aminogluc\xf3sidos, AINE)","Verificar v\xeda IV permeable y sin signos de extravasaci\xf3n"]},{nombre:"Rifampicina",grupo:"Inhibidor de la",mecanismo:"Inhibidor de la ARN polimerasa bacteriana dependiente de ADN, con excelente penetraci\xf3n \xf3sea y capacidad de eliminar bacterias en biofilm (importante en infecci\xf3n sobre implantes)",dosis:"300-600 mg VO cada 12 horas (en combinaci\xf3n con otro antibi\xf3tico activo, NUNCA en monoterapia por riesgo de resistencias). Administrar en ayunas",cuidadosEnfermeria:["NUNCA administrar en monoterapia (r\xe1pida aparici\xf3n de resistencias)","Advertir al paciente sobre coloraci\xf3n naranja de fluidos corporales (normal, no preocupante)","Monitorizar transaminasas hep\xe1ticas","Verificar interacciones medicamentosas (warfarina, anticonceptivos, antirretrovirales)","Administrar en ayunas para mejor absorci\xf3n","Verificar que el paciente lleva anticonceptivos adicionales si toma anticonceptivos hormonales"]}],noFarmacologico:["Desbridamiento quir\xfargico: eliminar tejido \xf3seo necr\xf3tico (secuestros) y biofilm bacteriano","Instauraci\xf3n de sistemas de irrigaci\xf3n-lavado local (osteomielitis cr\xf3nica)","Injertos \xf3seos o colgajos musculares para rellenar cavidades \xf3seas","Inmovilizaci\xf3n del miembro afectado con f\xe9rula o fijador externo","Terapia de presi\xf3n negativa (VAC) en heridas abiertas","C\xe1mara hiperb\xe1rica (coadyuvante en casos seleccionados)","Manejo de la enfermedad de base (diabetes, vasculopat\xeda)"]},cuidadosEnfermeria:{valoracion:["Monitorizar signos vitales: temperatura, FC, PA, FR (signos de sepsis)","Valorar dolor con EVA y su localizaci\xf3n","Evaluar aspecto de la herida o trayecto fistuloso: exudado, olor, signos de progresi\xf3n","Valorar estado neurovascular del miembro: color, temperatura, pulso distal, capillar","Monitorizar resultados anal\xedticos: PCR, VSG, hemograma, funci\xf3n renal","Valorar estado nutricional (hipercatabolismo en infecci\xf3n cr\xf3nica)","Verificar permeabilidad del acceso venoso y signos de flebitis"],intervenciones:["Realizar curas con t\xe9cnica est\xe9ril seg\xfan protocolo institucional","Documentar caracter\xedsticas del exudado: color, consistencia, cantidad, olor","Tomar muestras de exudado para cultivo cuando se indique","Aplicar ap\xf3sitos apropiados seg\xfan tipo de herida (absorbentes si exudado abundante)","Vigilar signos de extensi\xf3n de la infecci\xf3n o cambios en la herida","Mantener t\xe9cnica as\xe9ptica estricta en manipulaci\xf3n de heridas y cat\xe9teres","Administrar antibi\xf3ticos puntualmente en los horarios pautados","Monitorizar cultivos y sensibilidades para ajuste antibi\xf3tico","Vigilar signos de sepsis (fiebre, taquicardia, hipotensi\xf3n, confusi\xf3n)","Educar al paciente y familia sobre medidas de prevenci\xf3n de infecci\xf3n cruzada","Valorar estado nutricional (IMC, alb\xfamina, prealb\xfamina)","Asegurar ingesta proteica adecuada para cicatrizaci\xf3n y funci\xf3n inmune","Solicitar valoraci\xf3n por diet\xe9tica en infecci\xf3n cr\xf3nica con malnutrici\xf3n","Monitorizar peso semanal","Suplementar con vitaminas y zinc si hay d\xe9ficit"],educacionPaciente:["Explicar la necesidad de completar el ciclo antibi\xf3tico completo (4-6 semanas m\xednimo)","Instruir sobre signos de alarma que requieren consulta urgente: fiebre alta, deterioro del estado general","Ense\xf1ar t\xe9cnica de cura de heridas para realizarla en domicilio si est\xe1 indicado","Informar sobre la importancia del control gluc\xe9mico en pacientes diab\xe9ticos para la cicatrizaci\xf3n","Explicar la necesidad de seguimiento con RMN o gammagraf\xeda para verificar respuesta","Instruir sobre la protecci\xf3n del miembro afectado y limitaciones de carga"],monitorizacion:[]},npiNanda:[{codigo:"00004",nombre:"Riesgo de infecci\xf3n",definicion:"Vulnerable a una invasi\xf3n y multiplicaci\xf3n de organismos pat\xf3genos",caracteristicasDefinitorias:[],factoresRelacionados:["Osteomielitis activa","Cat\xe9ter IV","Intervenci\xf3n quir\xfargica","Inmunosupresi\xf3n"]},{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable causada por la infecci\xf3n \xf3sea",caracteristicasDefinitorias:["Dolor intenso localizado","Impotencia funcional","Fiebre"],factoresRelacionados:["Inflamaci\xf3n \xf3sea","Presi\xf3n intra\xf3sea elevada","Absceso"]},{codigo:"00047",nombre:"Riesgo de deterioro de la integridad cut\xe1nea",definicion:"Vulnerable a alteraci\xf3n en la epidermis y/o dermis",caracteristicasDefinitorias:[],factoresRelacionados:["Infecci\xf3n \xf3sea cr\xf3nica","F\xedstulas","Inmovilizaci\xf3n"]}],npiNic:[{codigo:"3660",nombre:"Cuidados de las heridas",actividades:["Realizar curas con t\xe9cnica est\xe9ril seg\xfan protocolo institucional","Documentar caracter\xedsticas del exudado: color, consistencia, cantidad, olor","Tomar muestras de exudado para cultivo cuando se indique","Aplicar ap\xf3sitos apropiados seg\xfan tipo de herida (absorbentes si exudado abundante)","Vigilar signos de extensi\xf3n de la infecci\xf3n o cambios en la herida"]},{codigo:"6540",nombre:"Control de infecciones",actividades:["Mantener t\xe9cnica as\xe9ptica estricta en manipulaci\xf3n de heridas y cat\xe9teres","Administrar antibi\xf3ticos puntualmente en los horarios pautados","Monitorizar cultivos y sensibilidades para ajuste antibi\xf3tico","Vigilar signos de sepsis (fiebre, taquicardia, hipotensi\xf3n, confusi\xf3n)","Educar al paciente y familia sobre medidas de prevenci\xf3n de infecci\xf3n cruzada"]},{codigo:"1200",nombre:"Administraci\xf3n de nutrici\xf3n enteral total",actividades:["Valorar estado nutricional (IMC, alb\xfamina, prealb\xfamina)","Asegurar ingesta proteica adecuada para cicatrizaci\xf3n y funci\xf3n inmune","Solicitar valoraci\xf3n por diet\xe9tica en infecci\xf3n cr\xf3nica con malnutrici\xf3n","Monitorizar peso semanal","Suplementar con vitaminas y zinc si hay d\xe9ficit"]}],npiNoc:[{codigo:"0702",nombre:"Estado inmune",indicadores:["Temperatura corporal normal","Leucocitos en rango normal","PCR en descenso"],escala:"Afebril con normalizaci\xf3n de marcadores inflamatorios en 2-4 semanas de tratamiento"},{codigo:"1103",nombre:"Curaci\xf3n de la herida: por primera intenci\xf3n",indicadores:["Resoluci\xf3n del eritema","Ausencia de exudado purulento","Cierre de la herida"],escala:"Herida limpia sin signos de infecci\xf3n activa en 4-6 semanas"}],complicaciones:["Osteomielitis cr\xf3nica con recurrencias","Sepsis y shock s\xe9ptico","Artritis s\xe9ptica contigua","Fractura patol\xf3gica en hueso debilitado","F\xedstulas persistentes","Amiloidosis secundaria (infecci\xf3n cr\xf3nica)","Carcinoma escamoso en f\xedstula cr\xf3nica (muy raro, largo tiempo)","Anemia de enfermedad cr\xf3nica"],criteriosAlarma:["Sepsis con inestabilidad hemodin\xe1mica","Artritis s\xe9ptica concomitante (emergencia)","Absceso epidural con mielopat\xeda (osteomielitis vertebral)","Progresi\xf3n r\xe1pida a shock s\xe9ptico","Fallo multiorg\xe1nico"],emergencyLevel:"moderado",relatedPathologyIds:[],isPremium:!0},{id:"pat_anemia_ferropenica",nombre:"Anemia Ferrop\xe9nica",bodySystemId:"hematologico",definicion:"Anemia por d\xe9ficit de hierro, causa m\xe1s frecuente de anemia a nivel mundial. El d\xe9ficit de hierro reduce la s\xedntesis de hemoglobina, produciendo eritrocitos microc\xedticos e hipocr\xf3micos. Causas principales: hemorragias cr\xf3nicas, malabsorci\xf3n, aumento de requerimientos (embarazo, crecimiento).",epidemiologia:"",factoresRiesgo:[],fisiopatologia:"El hierro es cofactor esencial para la s\xedntesis del grupo hemo de la hemoglobina. El d\xe9ficit progresa en tres etapas: 1) Depleci\xf3n de dep\xf3sitos (ferritina baja, sin anemia), 2) Eritropoyesis deficiente (saturaci\xf3n transferrina baja, sin anemia), 3) Anemia ferrop\xe9nica franca (Hb baja, microcitosis, hipocrom\xeda). La hepcidina, regulador hormonal del metabolismo del hierro, aumenta en inflamaci\xf3n y bloquea la absorci\xf3n intestinal y la liberaci\xf3n de hierro desde los macr\xf3fagos (anemia de enfermedad cr\xf3nica, diferente a la ferrop\xe9nica).",signosYSintomas:{signos:["Palidez cut\xe1neo-mucosa","Astenia y fatigabilidad f\xe1cil","Disnea de esfuerzo","Palpitaciones","Mareo e intolerancia ortost\xe1tica","Hemoglobina <7 g/dL con compromiso hemodin\xe1mico","Anemia aguda por hemorragia activa","S\xedncope o pres\xedncope","Angina de pecho en paciente coronario (anemia = descompensaci\xf3n card\xedaca)","Signos de sangrado activo (melenas, hematoquecia, metrorragia)","Anemia ferrop\xe9nica en hombre adulto o mujer postmenop\xe1usica (descartar neoplasia de colon)"],sintomas:["Cefalea","Taquicardia compensadora","Soplo funcional sist\xf3lico","Frialdad de extremidades","Glositis (lengua depapilada)","Queilitis angular (fisuras en comisuras labiales)","Coiloniquia (u\xf1as c\xf3ncavas en forma de cuchara)","Pica (apetencia por arcilla, hielo: pagofagia)"]},diagnostico:{anamnesis:["Hemoglobina <12 g/dL en mujeres, <13 g/dL en hombres","Ferritina s\xe9rica <12-15 ng/mL (dep\xf3sitos agotados)","Saturaci\xf3n de transferrina <16%","VCM <80 fL (microcitosis)","HCM <27 pg (hipocrom\xeda)"],examenFisico:[],pruebas:[{nombre:"Hemograma completo con reticulocitos",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Hierro s\xe9rico, capacidad de fijaci\xf3n de hierro (TIBC), ferritina",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Saturaci\xf3n de transferrina",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"PCR (ferritina se eleva en inflamaci\xf3n, puede ser falso normal)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Frotis de sangre perif\xe9rica (microcitosis, anulocitos)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Sangre oculta en heces (b\xfasqueda de hemorragia digestiva oculta)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Gastroscopia y colonoscopia en adultos (descartar neoplasia)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Funci\xf3n tiroidea (hipotiroidismo causa anemia)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Vitamina B12 y \xe1cido f\xf3lico (para diagn\xf3stico diferencial)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]}]},tratamientoMedico:{objetivos:[],farmacologico:[{nombre:"Sulfato Ferroso",grupo:"Sales ferrosas (Fe2+)",mecanismo:"Sales ferrosas (Fe2+) para sustituci\xf3n del hierro deficitario. El Fe2+ se absorbe mejor que el Fe3+ en el intestino delgado proximal. La vitamina C mejora la absorci\xf3n al mantener el hierro en estado ferroso",dosis:"200 mg (65 mg de hierro elemental) VO 2-3 veces al d\xeda en ayunas. Tratamiento 3-6 meses (2-4 semanas para normalizar Hb + 3-4 meses para reponer dep\xf3sitos)",cuidadosEnfermeria:["Administrar en ayunas o 30 min antes de comidas para mejor absorci\xf3n","Si intolerancia digestiva, administrar con alimentos (reduce absorci\xf3n ~40%)","Acompa\xf1ar con zumo de vitamina C para aumentar absorci\xf3n","Evitar con l\xe1cteos, te, caf\xe9 (quelantes que bloquean absorci\xf3n)","Separar 2-4 horas de calcio, anti\xe1cidos, quinolonas, tetraciclinas","Advertir sobre heces negras (normal, no preocupante)","Informar sobre posible estre\xf1imiento (aumentar fibra e hidrataci\xf3n)"]},{nombre:"Hierro Sacarosa IV",grupo:"Complejo de hierro",mecanismo:"Complejo de hierro para administraci\xf3n intravenosa que repone los dep\xf3sitos de hierro directamente al sistema reticuloendotelial, sin las limitaciones de absorci\xf3n oral",dosis:"200 mg IV en 250 mL SF en 30 min, 2-3 veces por semana. Dosis total calculada por f\xf3rmula de Ganzoni: d\xe9ficit de hierro (mg) = peso (kg) \xd7 [Hb diana - Hb actual] \xd7 2.4 + 500",cuidadosEnfermeria:["Administrar primera dosis de prueba (25 mg en 15 min) y observar 30 min por reacciones","Mantener al paciente en posici\xf3n semirecostada durante infusi\xf3n","Tener disponible adrenalina, antihistam\xednicos y glucocorticoides ante reacciones","No administrar si infecci\xf3n activa (riesgo de bacteremia por hierro libre)","Vigilar signos de extravasaci\xf3n (puede causar mancha cut\xe1nea oscura permanente)","Monitorizar PA durante la infusi\xf3n"]}],noFarmacologico:["Dieta rica en hierro hemo (carnes rojas, pollo, pescado azul) y hierro no hemo (legumbres, vegetales de hoja oscura, cereales enriquecidos)","Favorecer combinaci\xf3n con vitamina C en las comidas","Evitar inhibidores de absorci\xf3n en las comidas principales: t\xe9, caf\xe9, calcio","Tratar la causa subyacente: erradicaci\xf3n de H. pylori, tratamiento de menorragia, detecci\xf3n de hemorragia digestiva oculta"]},cuidadosEnfermeria:{valoracion:["Valorar s\xedntomas an\xe9micos: astenia, disnea, palpitaciones","Monitorizar constantes vitales: FC (taquicardia compensadora), PA, FR","Evaluar palidez en conjuntivas, palmas y mucosas","Valorar tolerancia al esfuerzo","Indagar sobre posibles focos de sangrado: hemorragia menstrual, heces negras/rojas","Evaluar dieta e ingesta de hierro","Valorar cumplimiento terap\xe9utico y efectos adversos del suplemento oral"],intervenciones:["Evaluar ingesta diaria de hierro diet\xe9tico","Orientar sobre alimentos ricos en hierro hemo (mejor absorbido): carnes rojas, pollo, pescado","Ense\xf1ar combinaci\xf3n de hierro no hemo con vitamina C para mejorar absorci\xf3n","Explicar los alimentos que inhiben la absorci\xf3n de hierro","Solicitar valoraci\xf3n nutricional especializada si es necesario","Ense\xf1ar la correcta administraci\xf3n del suplemento de hierro oral","Informar sobre los efectos adversos esperados (heces negras, posible estre\xf1imiento)","Enfatizar la importancia de mantener el tratamiento el tiempo completo prescrito","Monitorizar anal\xedticas de control (Hb, ferritina) para evaluar respuesta","Preparar y administrar el hierro IV con protocolo de seguridad","Programar per\xedodos de actividad y descanso alternados","Adaptar actividades a la tolerancia real del paciente","Orientar sobre t\xe9cnicas de ahorro de energ\xeda para AVD","Instruir para que solicite ayuda ante tareas que provoquen excesiva disnea"],educacionPaciente:["Explicar que las heces negras son normales con el hierro oral (no es sangre)","Ense\xf1ar a tomar el hierro correctamente: en ayunas, con vitamina C, sin l\xe1cteos ni t\xe9","Explicar que el tratamiento dura 3-6 meses, no solo hasta sentirse mejor","Ense\xf1ar alimentos ricos en hierro para la dieta diaria","Instruir sobre signos de sangrado que requieren consulta urgente","Explicar la necesidad de endoscopia en algunos casos para buscar la causa"],monitorizacion:[]},npiNanda:[{codigo:"00093",nombre:"Fatiga",definicion:"Sensaci\xf3n abrumadora y sostenida de agotamiento y disminuci\xf3n de la capacidad para el trabajo f\xedsico y mental",caracteristicasDefinitorias:["Cansancio extremo","Incapacidad para mantener actividades habituales","Letargia"],factoresRelacionados:["Anemia ferrop\xe9nica","Reducci\xf3n del transporte de ox\xedgeno","Malnutrici\xf3n"]},{codigo:"00126",nombre:"Conocimientos deficientes",definicion:"Ausencia o deficiencia de informaci\xf3n cognitiva relacionada con el tratamiento de la anemia",caracteristicasDefinitorias:["Incumplimiento terap\xe9utico","Preguntas frecuentes","Administraci\xf3n incorrecta del hierro"],factoresRelacionados:["Falta de exposici\xf3n a informaci\xf3n"]},{codigo:"00002",nombre:"Desequilibrio nutricional: ingesta inferior a las necesidades",definicion:"Ingesta de nutrientes insuficiente para satisfacer las necesidades metab\xf3licas",caracteristicasDefinitorias:["Ferritina baja","Ingesta insuficiente de hierro","Palidez mucosas"],factoresRelacionados:["Dieta deficiente en hierro","Malabsorci\xf3n"]}],npiNic:[{codigo:"1100",nombre:"Manejo de la nutrici\xf3n",actividades:["Evaluar ingesta diaria de hierro diet\xe9tico","Orientar sobre alimentos ricos en hierro hemo (mejor absorbido): carnes rojas, pollo, pescado","Ense\xf1ar combinaci\xf3n de hierro no hemo con vitamina C para mejorar absorci\xf3n","Explicar los alimentos que inhiben la absorci\xf3n de hierro","Solicitar valoraci\xf3n nutricional especializada si es necesario"]},{codigo:"2300",nombre:"Administraci\xf3n de medicaci\xf3n",actividades:["Ense\xf1ar la correcta administraci\xf3n del suplemento de hierro oral","Informar sobre los efectos adversos esperados (heces negras, posible estre\xf1imiento)","Enfatizar la importancia de mantener el tratamiento el tiempo completo prescrito","Monitorizar anal\xedticas de control (Hb, ferritina) para evaluar respuesta","Preparar y administrar el hierro IV con protocolo de seguridad"]},{codigo:"0180",nombre:"Manejo de la energ\xeda",actividades:["Programar per\xedodos de actividad y descanso alternados","Adaptar actividades a la tolerancia real del paciente","Orientar sobre t\xe9cnicas de ahorro de energ\xeda para AVD","Instruir para que solicite ayuda ante tareas que provoquen excesiva disnea"]}],npiNoc:[{codigo:"0413",nombre:"Severidad de la p\xe9rdida de sangre",indicadores:["Hemoglobina","Hematocrito","Frecuencia card\xedaca"],escala:"Hemoglobina >12 g/dL en mujeres, >13 g/dL en hombres en 4-8 semanas de tratamiento"},{codigo:"1854",nombre:"Conocimiento: dieta saludable",indicadores:["Descripci\xf3n de alimentos ricos en hierro","Descripci\xf3n de inhibidores de absorci\xf3n","Planificaci\xf3n de men\xfas adecuados"],escala:"Verbalizaci\xf3n de dieta equilibrada rica en hierro al alta"}],complicaciones:["Compromiso hemodin\xe1mico por anemia grave","Descompensaci\xf3n card\xedaca en cardi\xf3patas","Retraso del crecimiento y desarrollo en ni\xf1os","Bajo peso al nacer si anemia gestacional grave","Intolerancia al hierro oral con incumplimiento","Neoplasia subyacente no diagnosticada"],criteriosAlarma:["Hemoglobina <7 g/dL con compromiso hemodin\xe1mico","Anemia aguda por hemorragia activa","S\xedncope o pres\xedncope","Angina de pecho en paciente coronario (anemia = descompensaci\xf3n card\xedaca)","Signos de sangrado activo (melenas, hematoquecia, metrorragia)","Anemia ferrop\xe9nica en hombre adulto o mujer postmenop\xe1usica (descartar neoplasia de colon)"],emergencyLevel:"leve",relatedPathologyIds:[],isPremium:!1},{id:"pat_leucemia",nombre:"Leucemia Aguda",bodySystemId:"hematologico",definicion:"Neoplasia maligna de c\xe9lulas hematopoy\xe9ticas caracterizada por la proliferaci\xf3n clonal de c\xe9lulas inmaduras (blastos) en la m\xe9dula \xf3sea y sangre perif\xe9rica. Se divide en leucemia mieloide aguda (LMA) y leucemia linfobl\xe1stica aguda (LLA). Requiere tratamiento de quimioterapia intensiva urgente.",epidemiologia:"",factoresRiesgo:[],fisiopatologia:"Las leucemias agudas resultan de mutaciones adquiridas en c\xe9lulas progenitoras hematopoy\xe9ticas que bloquean la diferenciaci\xf3n y promueven la proliferaci\xf3n ilimitada. Los blastos leuc\xe9micos acumulados en la m\xe9dula \xf3sea desplazan a las c\xe9lulas normales, causando pancitopenia (anemia, neutropenia, trombocitopenia). En la LMA, las translocaciones m\xe1s frecuentes son t(15;17) (LPA, sensible a ATRA), t(8;21) y inv(16). En la LLA, la t(9;22) (Ph+) indica peor pron\xf3stico. La infiltraci\xf3n extramedular puede afectar SNC, test\xedculos, ganglios y bazo.",signosYSintomas:{signos:["S\xedndrome an\xe9mico: palidez, astenia, disnea","S\xedndrome hemorr\xe1gico: petequias, equimosis, epistaxis, sangrado gingival","S\xedndrome infeccioso: fiebre, infecciones frecuentes (neutropenia)","Esplenomegalia y hepatomegalia","Adenopat\xedas (m\xe1s marcadas en LLA)","Leucemia promieloc\xedtica aguda (LPA): CID con sangrado masivo (EMERGENCIA, iniciar ATRA inmediatamente)","S\xedndrome de lisis tumoral (tras quimioterapia)","Leucostasis con leucocitos >100,000/\u03bcL (trombos de blastos en microvasculatura)","Neutropenia febril grave con sepsis","Hemorragia cerebral por trombocitopenia severa","Compresi\xf3n medular por masa extramedular"],sintomas:["Dolores \xf3seos (LLA en ni\xf1os)","S\xedntomas de hiperviscosidad (cefalea, tinnitus, visi\xf3n borrosa) con leucocitosis extrema","Infiltraci\xf3n de enc\xedas (LMA monoc\xedtica)","S\xedntomas del SNC: cefalea, convulsiones, par\xe1lisis de pares craneales","Masa mediast\xednica (LLA-T)","Fiebre sin foco infeccioso"]},diagnostico:{anamnesis:["\u226520% de blastos en m\xe9dula \xf3sea o sangre perif\xe9rica (criterio OMS)","Inmunofenotipificaci\xf3n por citometr\xeda de flujo (LMA vs LLA, subtipo)","Citogen\xe9tica y molecular (definici\xf3n del subtipo y pron\xf3stico)","En LPA: presencia de gen PML/RARA por FISH o RT-PCR"],examenFisico:[],pruebas:[{nombre:"Hemograma completo con diferencial (blastos en sangre perif\xe9rica)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Aspirado y biopsia de m\xe9dula \xf3sea (diagn\xf3stico definitivo)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Inmunofenotipificaci\xf3n (citometr\xeda de flujo)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Citogen\xe9tica convencional y FISH",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Biolog\xeda molecular: mutaciones FLT3, NPM1, IDH1/2 (LMA), BCR-ABL (LLA-Ph+)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"LDH (marcador de masa tumoral)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Coagulaci\xf3n completa (CID en LPA)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Bioqu\xedmica: urato, potasio, fosfato, creatinina (s\xedndrome de lisis tumoral)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"PL para an\xe1lisis de LCR (LLA)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Serolog\xedas: VHB, VHC, VIH (previo a quimioterapia)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]}]},tratamientoMedico:{objetivos:[],farmacologico:[{nombre:"Citarabina (Ara-C)",grupo:"Antimetabolito an\xe1logo de",mecanismo:"Antimetabolito an\xe1logo de la deoxicitidina que se incorpora al ADN inhibiendo la ADN polimerasa, bloqueando la s\xedntesis de ADN y causando apoptosis de c\xe9lulas en proliferaci\xf3n r\xe1pida",dosis:"Inducci\xf3n LMA: 100-200 mg/m2/d\xeda en infusi\xf3n continua 24h \xd7 7 d\xedas (protocolo 7+3). Dosis altas (HiDAC): 3 g/m2 IV en 3h cada 12h en consolidaci\xf3n",cuidadosEnfermeria:["Monitorizar hemograma diariamente durante la inducci\xf3n","Lavados orales frecuentes para prevenir mucositis","Con HiDAC: instalar colirios de dexametasona profil\xe1cticos para conjuntivitis","Vigilar signos neurol\xf3gicos durante HiDAC (ataxia, disartria: suspender y avisar)","Asegurar antiem\xe9ticos pautados 30 min antes de cada infusi\xf3n","Registrar temperatura cada 4-6 horas (neutropenia febril = emergencia)"]},{nombre:"Daunorrubicina",grupo:"Antraciclina que intercala",mecanismo:"Antraciclina que intercala en el ADN, inhibe la topoisomerasa II y genera radicales libres que producen roturas del ADN bicatenario. Forma parte del protocolo est\xe1ndar de inducci\xf3n de LMA (7+3)",dosis:"60-90 mg/m2 IV d\xedas 1, 2 y 3 del protocolo de inducci\xf3n (protocolo 7+3)",cuidadosEnfermeria:["Controlar fracci\xf3n de eyecci\xf3n (ecocardiograma) antes de iniciar y peri\xf3dicamente","Verificar SIEMPRE permeabilidad de la vena central antes de administrar (es vesicante)","Vigilar signos de extravasaci\xf3n (necrosis tisular grave)","Advertir sobre coloraci\xf3n roja de la orina (normal, no hematuria)","Monitorizar ECG: prolongaci\xf3n QT","Asegurar antiem\xe9ticos profil\xe1cticos"]},{nombre:"ATRA (\xc1cido All-Trans Retinoico)",grupo:"En LPA (t(15;17)/PML-RARA):",mecanismo:"En LPA (t(15;17)/PML-RARA): el ATRA se une a la prote\xedna de fusi\xf3n PML-RARA y restaura la diferenciaci\xf3n de los promielocitos a granulocitos maduros, eliminando el bloqueo maligno",dosis:"45 mg/m2/d\xeda VO en 2 dosis (espec\xedfico para LPA). Mantener hasta remisi\xf3n completa o 90 d\xedas",cuidadosEnfermeria:["VIGILAR DIARIAMENTE el s\xedndrome de diferenciaci\xf3n: fiebre inexplicable + leucocitosis + disnea + edemas + derrame pleural (suspender ATRA y administrar dexametasona IV urgente)","Monitorizar leucocitosis frecuentemente (riesgo de leucostasis)","Controlar triglic\xe9ridos semanalmente","Contraindicado en embarazo: asegurar anticoncepci\xf3n efectiva","Vigilar cefalea intensa (posible hipertensi\xf3n intracraneal)","Informar sobre sequedad de piel y pedir hidrataci\xf3n"]}],noFarmacologico:["Trasplante alog\xe9nico de progenitores hematopoy\xe9ticos (TPH) en enfermedad de alto riesgo en remisi\xf3n","Prevenci\xf3n de s\xedndrome de lisis tumoral: hiperhidrataci\xf3n IV, alopurinol/rasburicasa previo a quimioterapia","Transfusiones de hemat\xedes si Hb <7-8 g/dL o s\xedntomas","Transfusi\xf3n de plaquetas si <10,000/\u03bcL o sangrado activo","Aislamiento protector (neutropenia: habitaci\xf3n individual, dieta sin alimentos crudos)","Profilaxis de infecciones f\xfangicas y virales (fluconazol, aciclovir)","Cat\xe9ter venoso central (Hickman) para administraci\xf3n de quimioterapia"]},cuidadosEnfermeria:{valoracion:["Monitorizar hemograma diariamente: Hb, plaquetas, neutr\xf3filos","Registrar temperatura cada 4-6 h (neutropenia febril si T\xaa >38\xb0C + neutr\xf3filos <500/\u03bcL)","Valorar signos de sangrado: petequias, equimosis, hematuria, melenas","Vigilar mucositis oral (escala OMS)","Evaluar estado neurol\xf3gico: confusi\xf3n, cefalea, signos men\xedngeos","Monitorizar constantes vitales (FC, PA, FR, SatO2)","Valorar dolor con EVA","Controlar diuresis y balance h\xeddrico","Vigilar signos de infecci\xf3n del cat\xe9ter venoso central"],intervenciones:["Higiene de manos estricta y uso de guantes en todo procedimiento","Mantener aislamiento de protecci\xf3n (habitaci\xf3n individual con filtro HEPA si disponible)","Monitorizar temperatura cada 4-6h: si T\xaa >38\xb0C con neutr\xf3filos <500/\u03bcL \u2192 hemocultivos y antibi\xf3ticos de amplio espectro INMEDIATAMENTE (no demorar >1h)","Evitar flores, plantas, frutas sin pelar y alimentos crudos en habitaci\xf3n","Vigilar CVC: cambio de ap\xf3sito con t\xe9cnica est\xe9ril, inspecci\xf3n diaria","No colocar SNG, supositorios ni temperaturas rectales (riesgo de bacteremia)","Verificar plaquetas diariamente, transfundir si <10,000/\u03bcL o sangrado activo","Usar esponja suave o bastoncillo para higiene oral (no cepillo duro)","Evitar inyecciones IM y venopunciones innecesarias (usar CVC)","Aplicar presi\xf3n 10-15 min en puntos de venopunci\xf3n","Instruir al paciente para no sonarse con fuerza ni rascarse","Vigilar petequias, equimosis, sangrado mucosas y hematuria","Vigilar mucositis oral con escala OMS","Realizar enjuagues con colutorio bicarbonato o hexetidina cada 4-6h","No usar cepillo dental si plaquetas <20,000/\u03bcL","Aplicar lubricantes labiales para sequedad","Registrar grado de mucositis y su evoluci\xf3n diariamente"],educacionPaciente:["Explicar la importancia de la higiene de manos y las medidas de aislamiento","Instruir para informar INMEDIATAMENTE de cualquier fiebre (urgencia hematol\xf3gica)","Ense\xf1ar a reconocer signos de sangrado","Explicar la dieta de neutropenia: sin alimentos crudos, no flores ni plantas","Preparar psicol\xf3gicamente sobre la ca\xedda del cabello (alopecia temporal)","Informar sobre el proceso de recuperaci\xf3n medular (nadir y recuperaci\xf3n)","Ofrecer apoyo emocional y recursos de psicooncolog\xeda"],monitorizacion:[]},npiNanda:[{codigo:"00004",nombre:"Riesgo de infecci\xf3n",definicion:"Vulnerable a una invasi\xf3n y multiplicaci\xf3n de organismos pat\xf3genos, como consecuencia de la neutropenia por quimioterapia",caracteristicasDefinitorias:[],factoresRelacionados:["Neutropenia severa","Mucosas alteradas","Cat\xe9ter venoso central","Inmunosupresi\xf3n"]},{codigo:"00206",nombre:"Riesgo de sangrado",definicion:"Vulnerable a una disminuci\xf3n del volumen sangu\xedneo, lo que puede comprometer la salud",caracteristicasDefinitorias:[],factoresRelacionados:["Trombocitopenia","Coagulaci\xf3n intravascular diseminada (LPA)","Mucositis"]},{codigo:"00093",nombre:"Fatiga",definicion:"Sensaci\xf3n abrumadora y sostenida de agotamiento",caracteristicasDefinitorias:["Agotamiento intenso","Incapacidad para realizar AVD","Postraci\xf3n"],factoresRelacionados:["Anemia","Quimioterapia","Proceso maligno"]}],npiNic:[{codigo:"6550",nombre:"Protecci\xf3n contra las infecciones",actividades:["Higiene de manos estricta y uso de guantes en todo procedimiento","Mantener aislamiento de protecci\xf3n (habitaci\xf3n individual con filtro HEPA si disponible)","Monitorizar temperatura cada 4-6h: si T\xaa >38\xb0C con neutr\xf3filos <500/\u03bcL \u2192 hemocultivos y antibi\xf3ticos de amplio espectro INMEDIATAMENTE (no demorar >1h)","Evitar flores, plantas, frutas sin pelar y alimentos crudos en habitaci\xf3n","Vigilar CVC: cambio de ap\xf3sito con t\xe9cnica est\xe9ril, inspecci\xf3n diaria","No colocar SNG, supositorios ni temperaturas rectales (riesgo de bacteremia)"]},{codigo:"4010",nombre:"Precauciones ante hemorragias",actividades:["Verificar plaquetas diariamente, transfundir si <10,000/\u03bcL o sangrado activo","Usar esponja suave o bastoncillo para higiene oral (no cepillo duro)","Evitar inyecciones IM y venopunciones innecesarias (usar CVC)","Aplicar presi\xf3n 10-15 min en puntos de venopunci\xf3n","Instruir al paciente para no sonarse con fuerza ni rascarse","Vigilar petequias, equimosis, sangrado mucosas y hematuria"]},{codigo:"1750",nombre:"Cuidado perineal",actividades:["Vigilar mucositis oral con escala OMS","Realizar enjuagues con colutorio bicarbonato o hexetidina cada 4-6h","No usar cepillo dental si plaquetas <20,000/\u03bcL","Aplicar lubricantes labiales para sequedad","Registrar grado de mucositis y su evoluci\xf3n diariamente"]}],npiNoc:[{codigo:"0702",nombre:"Estado inmune",indicadores:["Recuento de neutr\xf3filos","Ausencia de signos de infecci\xf3n","Temperatura corporal"],escala:"Neutr\xf3filos >500/\u03bcL con ausencia de infecci\xf3n activa al finalizar el nadir"},{codigo:"1902",nombre:"Control del riesgo",indicadores:["Supervisi\xf3n del estado de salud","Conductas de protecci\xf3n","Control de la dieta"],escala:"El paciente identifica signos de alarma (fiebre, sangrado) y act\xfaa correctamente"}],complicaciones:["Neutropenia febril y sepsis","Hemorragia grave (cerebral, digestiva)","CID (especialmente en LPA)","S\xedndrome de lisis tumoral","S\xedndrome de diferenciaci\xf3n (ATRA en LPA)","Leucostasis","Reca\xedda de la leucemia","Cardiotoxicidad por antraciclinas","Mucositis grave con malnutrici\xf3n"],criteriosAlarma:["Leucemia promieloc\xedtica aguda (LPA): CID con sangrado masivo (EMERGENCIA, iniciar ATRA inmediatamente)","S\xedndrome de lisis tumoral (tras quimioterapia)","Leucostasis con leucocitos >100,000/\u03bcL (trombos de blastos en microvasculatura)","Neutropenia febril grave con sepsis","Hemorragia cerebral por trombocitopenia severa","Compresi\xf3n medular por masa extramedular"],emergencyLevel:"critico",relatedPathologyIds:[],isPremium:!1},{id:"pat_hemofilia",nombre:"Hemofilia",bodySystemId:"hematologico",definicion:"Coagulopat\xeda hereditaria ligada al cromosoma X caracterizada por d\xe9ficit de factor VIII (Hemofilia A) o factor IX (Hemofilia B). Se manifiesta por episodios de hemorragia espont\xe1nea o tras traumatismos m\xednimos, especialmente en articulaciones (hemartrosis) y m\xfasculos.",epidemiologia:"",factoresRiesgo:[],fisiopatologia:"Los factores VIII y IX son componentes esenciales de la v\xeda intr\xednseca de la coagulaci\xf3n. El factor VIII act\xfaa como cofactor del factor IXa en el complejo tenasa, que activa el factor X. Sin factor VIII o IX funcional, la amplificaci\xf3n de la trombina es insuficiente para generar un co\xe1gulo firme. La hemostasia primaria (plaquetas) es normal, por lo que el sangrado es diferido (no inmediato) y profundo (hematomas, hemartrosis) en lugar de superficial (petequias, purpura). La hemartrosis repetida causa sinovitis cr\xf3nica, destrucci\xf3n articular (artropat\xeda hemof\xedlica) y discapacidad progresiva.",signosYSintomas:{signos:["Hemartrosis: articulaciones calientes, tumefactas y dolorosas (rodilla, codo, tobillo m\xe1s frecuentes)","Hematomas musculares profundos","Sangrado prolongado ante traumatismos, heridas o procedimientos","Hemorragia tras circuncisi\xf3n o extracci\xf3n dental","Epistaxis y sangrado gingival prolongados","Hemorragia intracraneal (cefalea s\xfabita, alteraci\xf3n del nivel de conciencia)","Hematoma retroperitoneal o de psoas iliaco (dolor abdominal severo/inguinal)","Hematoma de cuello que compromete v\xeda a\xe9rea (estridor)","Hematoma que comprime nervios perif\xe9ricos (s\xedndrome compartimental)","Hemorragia digestiva grave"],sintomas:["Artropat\xeda hemof\xedlica cr\xf3nica (articulaciones en diana)","Hematurias","Hematomas intramusculares que comprimen estructuras vasculonerviosas","Pseudotumores hemof\xedlicos (hematomas encapsulados cr\xf3nicos)"]},diagnostico:{anamnesis:["Hemofilia A: TTPA prolongado, tiempo de protrombina normal, actividad del factor VIII <1% (grave), 1-5% (moderada), 5-40% (leve)","Hemofilia B: TTPA prolongado, actividad del factor IX reducida","Historia familiar de herencia ligada al X (madre portadora, varones afectados)","Test de mezcla: correcci\xf3n del TTPA con plasma normal (confirma deficiencia de factor)"],examenFisico:[],pruebas:[{nombre:"TTPA (tiempo de tromboplastina parcial activado): prolongado",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"TP (tiempo de protrombina): normal",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Tiempo de hemorragia: normal",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Recuento plaquetario: normal",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Actividad espec\xedfica del factor VIII y IX",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Detecci\xf3n de inhibidores del factor (anticuerpos): Bethesda units",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Test gen\xe9tico para identificar la mutaci\xf3n familiar",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Diagn\xf3stico prenatal: vellosidades cori\xf3nicas o amniocentesis",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]}]},tratamientoMedico:{objetivos:[],farmacologico:[{nombre:"Factor VIII Recombinante",grupo:"Reposici\xf3n del factor",mecanismo:"Reposici\xf3n del factor VIII deficitario para restaurar la cascada de coagulaci\xf3n y generar hemostasia adecuada. Los productos recombinantes tienen menor riesgo infeccioso que los derivados de plasma",dosis:"Episodio leve (articulaci\xf3n): 20-30 UI/kg IV. Episodio moderado (m\xfasculo): 30-50 UI/kg. Sangrado grave/cirug\xeda: 50 UI/kg, luego infusi\xf3n continua o bolos cada 8-12h para mantener nivel >80%. Profilaxis primaria: 25-40 UI/kg 3 veces/semana",cuidadosEnfermeria:["Administrar lentamente IV (no m\xe1s de 10 mL/min) para reducir efectos adversos","Monitorizar frecuencia card\xedaca y PA durante la infusi\xf3n","Verificar la actividad del factor a las 15 min post-infusi\xf3n para confirmar recuperaci\xf3n esperada","Sospecha de inhibidor si el sangrado no responde a las dosis habituales \u2192 notificar","Registrar lote y n\xfamero de producto para farmacovigilancia","Ense\xf1ar al paciente la autoinfusi\xf3n domiciliaria"]},{nombre:"Emicizumab",grupo:"Anticuerpo biespec\xedfico que",mecanismo:"Anticuerpo biespec\xedfico que une el factor IXa y el factor X, actuando como sustituto del factor VIIIa y permitiendo la activaci\xf3n del factor X independientemente del factor VIII",dosis:"Dosis de carga: 3 mg/kg SC semanal \xd7 4 semanas. Mantenimiento: 1.5 mg/kg SC semanal, o 3 mg/kg quincenal, o 6 mg/kg mensual",cuidadosEnfermeria:["NO combinar con CCPa (FEIBA) \u2192 microangiopat\xeda tromb\xf3tica grave","Instruir sobre autoinyecci\xf3n SC semanal/quincenal","Vigilar signos de trombosis (dolor, edema en miembros)","Rotar puntos de inyecci\xf3n","Educar que el TTPA estar\xe1 prolongado con emicizumab (no refleja estado real de coagulaci\xf3n)"]},{nombre:"Desmopresina (DDAVP)",grupo:"An\xe1logo de vasopresina",mecanismo:"An\xe1logo de vasopresina que libera el factor VIII y el factor von Willebrand almacenados en el endotelio vascular, aumentando sus niveles plasm\xe1ticos 2-4 veces. Solo \xfatil en hemofilia A leve",dosis:"0.3 mcg/kg IV en 30 min diluido en 50 mL SF, o 300 mcg intranasal. Solo en hemofilia A leve con respuesta documentada",cuidadosEnfermeria:["Solo usar si hay respuesta documentada previa (test de respuesta a DDAVP)","Monitorizar PA y FC durante la infusi\xf3n","Restringir l\xedquidos 24h post-administraci\xf3n (riesgo hiponatremia)","Controlar natremia si se usa en ni\xf1os o ancianos","M\xe1ximo 2-3 dosis en episodio agudo (taquifilaxia)","Contraindicado en hemofilia grave y B"]}],noFarmacologico:["Profilaxis primaria: factor de reposici\xf3n desde los primeros episodios de sangrado o antes (en ni\xf1os)","RICE ante hemartrosis: Reposo, Hielo, Compresi\xf3n, Elevaci\xf3n","Fisioterapia entre episodios para fortalecer la musculatura articular","Ortesis y f\xe9rulas en articulaciones en diana","Cirug\xeda ortop\xe9dica (sinovectom\xeda, artroplastia) en artropat\xeda avanzada","Terapia g\xe9nica: vectores AAV para hemofilia A y B (aprobada EMA/FDA 2022-2023)"]},cuidadosEnfermeria:{valoracion:["Valorar dolor articular y evaluar la articulaci\xf3n (temperatura, tama\xf1o, rango de movimiento)","Monitorizar signos vitales","Evaluar sangrado activo: localizaci\xf3n, cantidad, tiempo de inicio","Verificar si tiene inhibidores documentados (resistencia al factor)","Evaluar el acceso venoso (muchos pacientes tienen CVP o puerto-a-cath)","Valorar estado neurol\xf3gico si hay cefalea o traumatismo craneal","Evaluar cumplimiento de la profilaxis domiciliaria"],intervenciones:["Aplicar RICE inmediatamente en hemartrosis: reposo, hielo (protegido 20 min), compresi\xf3n y elevaci\xf3n","Administrar el factor deficitario lo antes posible ante un episodio de sangrado (< 2h = golden time)","Evitar inyecciones IM (alternativa: SC o IV)","No administrar AAS o AINE (inhiben la agregaci\xf3n plaquetaria)","Usar SOLO paracetamol o tramadol para analgesia","Aplicar presi\xf3n prolongada (15-20 min) en puntos de venopunci\xf3n","Preparar el factor de reposici\xf3n correctamente (reconstituir con el diluyente provisto)","Administrar el factor lentamente IV (no superar 10 mL/min)","Monitorizar la respuesta cl\xednica (cese del sangrado, reducci\xf3n del dolor articular)","Registrar el lote del producto y la actividad del factor pre y post-infusi\xf3n","Ense\xf1ar a pacientes y familias la autoinfusi\xf3n domiciliaria","Educar sobre reconocimiento precoz de hemartrosis y la importancia del tratamiento inmediato","Ense\xf1ar t\xe9cnica de autoinyecci\xf3n del factor de reposici\xf3n","Instruir para llevar siempre el factor de emergencia y tarjeta de hemofilia","Recomendar actividades f\xedsicas permitidas (nataci\xf3n, ciclismo) y contraindicadas (deportes de contacto)","Educar sobre informar siempre la hemofilia ante cualquier procedimiento m\xe9dico"],educacionPaciente:["Ense\xf1ar a reconocer precozmente una hemartrosis (sensaci\xf3n de calor, tensi\xf3n, antes del dolor intenso)","Insistir en tratar INMEDIATAMENTE con el factor (golden time <2h = mejor pron\xf3stico articular)","Instruir sobre RICE y cu\xe1ndo acudir a urgencias","Explicar actividades deportivas permitidas y a evitar","Ense\xf1ar que deben informar a cualquier m\xe9dico o dentista de su hemofilia","Advertir sobre medicamentos contraindicados: AAS, AINE, anticoagulantes","Contactar con la asociaci\xf3n de hemofilia para apoyo y recursos"],monitorizacion:[]},npiNanda:[{codigo:"00206",nombre:"Riesgo de sangrado",definicion:"Vulnerable a una disminuci\xf3n del volumen sangu\xedneo, lo que puede comprometer la salud",caracteristicasDefinitorias:[],factoresRelacionados:["D\xe9ficit de factor de coagulaci\xf3n","Traumatismo","Procedimientos invasivos"]},{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable causada por la hemartrosis",caracteristicasDefinitorias:["Articulaci\xf3n caliente y tumefacta","Dolor intenso al movimiento","Posici\xf3n ant\xe1lgica"],factoresRelacionados:["Hemartrosis","Distensi\xf3n de la c\xe1psula articular","Hematoma"]},{codigo:"00085",nombre:"Deterioro de la movilidad f\xedsica",definicion:"Limitaci\xf3n del movimiento f\xedsico independiente e intencionado del cuerpo",caracteristicasDefinitorias:["Limitaci\xf3n del rango de movimiento articular","Articulaciones en diana deformadas"],factoresRelacionados:["Artropat\xeda hemof\xedlica","Hemartrosis aguda","Dolor"]}],npiNic:[{codigo:"4010",nombre:"Precauciones ante hemorragias",actividades:["Aplicar RICE inmediatamente en hemartrosis: reposo, hielo (protegido 20 min), compresi\xf3n y elevaci\xf3n","Administrar el factor deficitario lo antes posible ante un episodio de sangrado (< 2h = golden time)","Evitar inyecciones IM (alternativa: SC o IV)","No administrar AAS o AINE (inhiben la agregaci\xf3n plaquetaria)","Usar SOLO paracetamol o tramadol para analgesia","Aplicar presi\xf3n prolongada (15-20 min) en puntos de venopunci\xf3n"]},{codigo:"2300",nombre:"Administraci\xf3n de medicaci\xf3n",actividades:["Preparar el factor de reposici\xf3n correctamente (reconstituir con el diluyente provisto)","Administrar el factor lentamente IV (no superar 10 mL/min)","Monitorizar la respuesta cl\xednica (cese del sangrado, reducci\xf3n del dolor articular)","Registrar el lote del producto y la actividad del factor pre y post-infusi\xf3n","Ense\xf1ar a pacientes y familias la autoinfusi\xf3n domiciliaria"]},{codigo:"5510",nombre:"Educaci\xf3n para la salud",actividades:["Educar sobre reconocimiento precoz de hemartrosis y la importancia del tratamiento inmediato","Ense\xf1ar t\xe9cnica de autoinyecci\xf3n del factor de reposici\xf3n","Instruir para llevar siempre el factor de emergencia y tarjeta de hemofilia","Recomendar actividades f\xedsicas permitidas (nataci\xf3n, ciclismo) y contraindicadas (deportes de contacto)","Educar sobre informar siempre la hemofilia ante cualquier procedimiento m\xe9dico"]}],npiNoc:[{codigo:"0413",nombre:"Severidad de la p\xe9rdida de sangre",indicadores:["P\xe9rdida de sangre visible","Hematoma","Dolor articular"],escala:"Cese del sangrado en menos de 2 horas post-administraci\xf3n de factor"},{codigo:"1805",nombre:"Conocimiento: conducta sanitaria",indicadores:["Reconocimiento de signos de hemorragia","Uso correcto del factor domiciliario","Conocimiento de precauciones"],escala:"Paciente o familia capaz de autoadministrar el factor y reconocer emergencias"}],complicaciones:["Artropat\xeda hemof\xedlica con discapacidad funcional grave","Desarrollo de inhibidores (anticuerpos contra el factor)","Hemorragia intracraneal (principal causa de muerte)","S\xedndrome compartimental por hematoma muscular","Pseudotumor hemof\xedlico","Infecci\xf3n por VIH o VHC (transfusiones pre-1985, hoy muy raro con productos modernos)"],criteriosAlarma:["Hemorragia intracraneal (cefalea s\xfabita, alteraci\xf3n del nivel de conciencia)","Hematoma retroperitoneal o de psoas iliaco (dolor abdominal severo/inguinal)","Hematoma de cuello que compromete v\xeda a\xe9rea (estridor)","Hematoma que comprime nervios perif\xe9ricos (s\xedndrome compartimental)","Hemorragia digestiva grave"],emergencyLevel:"moderado",relatedPathologyIds:[],isPremium:!1},{id:"pat_linfoma",nombre:"Linfoma",bodySystemId:"hematologico",definicion:"Neoplasias malignas del sistema linfoide que se originan en linfocitos B, T o NK. Se clasifican en Linfoma de Hodgkin (LH) y Linfoma No Hodgkin (LNH). El LH predomina en adultos j\xf3venes; el LNH es m\xe1s heterog\xe9neo y frecuente en mayores.",epidemiologia:"",factoresRiesgo:[],fisiopatologia:"En el LH, las c\xe9lulas de Reed-Sternberg (linfocitos B gigantes multinucleados) liberan citocinas que crean un microambiente inflamatorio con eosin\xf3filos, neutr\xf3filos y c\xe9lulas T. En el LNH, la clonalidad linfocitaria aberrante (translocaciones como t(14;18) en LNH folicular con sobreexpresi\xf3n de BCL-2 o t(8;14) en LNH Burkitt con c-MYC) impide la apoptosis y promueve proliferaci\xf3n. El LNH difuso de c\xe9lulas B grandes (DLBCL) es el m\xe1s frecuente. La infiltraci\xf3n de ganglios y \xf3rganos (bazo, h\xedgado, m\xe9dula \xf3sea) determina el estadio y el pron\xf3stico.",signosYSintomas:{signos:["Adenopat\xedas no dolorosas (cervicales en LH, generalizadas en LNH agresivo)","S\xedntomas B: fiebre >38\xb0C sin foco, sudoraci\xf3n nocturna empapante, p\xe9rdida de peso >10% en 6 meses","Prurito generalizado intenso (LH)","Esplenomegalia y hepatomegalia","Fatigabilidad y astenia","S\xedndrome de vena cava superior (edema en esclavina, cianosis, ingurgitaci\xf3n yugular)","Compresi\xf3n medular por masa epidural","S\xedndrome de lisis tumoral (LNH de alto grado)","Deterioro neurol\xf3gico por infiltraci\xf3n SNC","Obstrucci\xf3n de la v\xeda a\xe9rea por masa mediast\xednica"],sintomas:["Anemia normoc\xedtica normocr\xf3mica","Masa mediast\xednica (LH nodular esclerosis, LNH-T mediast\xednico)","S\xedntomas de compresi\xf3n (s\xedndrome de vena cava superior)","Dolor al consumo de alcohol en adenopat\xedas (patognom\xf3nico del LH)","Afectaci\xf3n extranodal: piel, SNC, test\xedculos, hueso (LNH agresivo)"]},diagnostico:{anamnesis:["Biopsia ganglionar excisional (gold standard): arquitectura preservada o no, c\xe9lulas de Reed-Sternberg","Inmunohistoqu\xedmica: CD30+, CD15+ en LH cl\xe1sico; CD20+ en LNH-B","PET-TC con FDG: estadificaci\xf3n y evaluaci\xf3n de respuesta al tratamiento","Biopsia de m\xe9dula \xf3sea para estadificaci\xf3n"],examenFisico:[],pruebas:[{nombre:"Hemograma: anemia, linfocitosis (LNH indolente)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"LDH y beta-2 microglobulina (marcadores de masa tumoral y pron\xf3stico)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"VSG, PCR",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Bioqu\xedmica con funci\xf3n renal y hep\xe1tica",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"TC de t\xf3rax, abdomen y pelvis o PET-TC",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Biopsia de m\xe9dula \xf3sea",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"FISH y citogen\xe9tica en muestra ganglionar",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Serolog\xedas: VHB, VHC, VIH, EBV",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Punci\xf3n lumbar si sospecha afectaci\xf3n SNC (LNH de alto riesgo)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]}]},tratamientoMedico:{objetivos:[],farmacologico:[{nombre:"R-CHOP (Rituximab + Ciclofosfamida + Doxorrubicina + Vincristina + Prednisona)",grupo:"Rituximab: anti-CD20 que",mecanismo:"Rituximab: anti-CD20 que lisa c\xe9lulas B por ADCC y complemento. Ciclofosfamida: alquilante que da\xf1a el ADN. Doxorrubicina: antraciclina que inhibe topoisomerasa II. Vincristina: alcaloide del vinca que inhibe la polimerizaci\xf3n de tubulina (antimit\xf3tico). Prednisona: glucocorticoide que induce apoptosis linfocitaria",dosis:"Ciclos de 21 d\xedas, 6-8 ciclos para DLBCL. Rituximab 375 mg/m2 D1, ciclofosfamida 750 mg/m2 D1, doxorrubicina 50 mg/m2 D1, vincristina 1.4 mg/m2 D1 (m\xe1x 2mg), prednisona 100 mg/d\xeda D1-5",cuidadosEnfermeria:["Premedicar rituximab con paracetamol + antihistam\xednico (reacciones infusionales)","Iniciar rituximab a velocidad baja (50 mg/h), aumentar progresivamente","Vigilar signos de reacci\xf3n infusional: escalofr\xedos, fiebre, hipotensi\xf3n, broncospasmo","Hidratar abundantemente antes y despu\xe9s de ciclofosfamida (prevenir cistitis hemorr\xe1gica)","Administrar MESNA junto a ciclofosfamida si dosis alta","Vigilar neurotoxicidad por vincristina: parestesias, estre\xf1imiento (\xedleo paral\xedtico)","Monitorizar hemograma post-ciclo (nadir: d\xeda 10-14)"]},{nombre:"ABVD (Adriamicina + Bleomicina + Vinblastina + Dacarbazina)",grupo:"R\xe9gimen est\xe1ndar para",mecanismo:"R\xe9gimen est\xe1ndar para Linfoma de Hodgkin. Adriamicina (antraciclina), bleomicina (induce roturas en ADN por radicales libres), vinblastina (antimit\xf3tico), dacarbazina (alquilante). Sinergia entre agentes con diferentes mecanismos",dosis:"Ciclos de 28 d\xedas, d\xedas 1 y 15. Adriamicina 25 mg/m2, bleomicina 10 UI/m2, vinblastina 6 mg/m2, dacarbazina 375 mg/m2",cuidadosEnfermeria:["NUNCA administrar ox\xedgeno al 100% si el paciente recibi\xf3 bleomicina (potencia la toxicidad pulmonar)","Monitorizar funci\xf3n respiratoria: DLCO, espirometr\xeda peri\xf3dica durante tratamiento","Observar s\xedntomas pulmonares: tos seca, disnea \u2192 notificar, puede ser pneumonitis por bleomicina","Controlar funci\xf3n card\xedaca (fracci\xf3n de eyecci\xf3n) antes y durante el tratamiento","Antiem\xe9ticos potentes antes de dacarbazina (altamente emetog\xe9nica)","Registrar dosis acumulada de adriamicina (m\xe1x 550 mg/m2 de vida)"]}],noFarmacologico:["Radioterapia: complementaria en LH localizado (campo involucrado post-QT)","Trasplante aut\xf3logo de progenitores hematopoy\xe9ticos (rescate en reca\xedda)","Trasplante alog\xe9nico (LNH de alto riesgo refractario)","Profilaxis de s\xedndrome de lisis tumoral en LNH agresivo antes de iniciar QT","Criopreservaci\xf3n de gametos antes de quimioterapia gonadot\xf3xica (fertilidad)"]},cuidadosEnfermeria:{valoracion:["Monitorizar hemograma post-ciclo (especialmente d\xedas 10-14, nadir neutrop\xe9nico)","Valorar signos de toxicidad espec\xedfica de cada agente (pulm\xf3n, coraz\xf3n, nervios)","Controlar temperatura cada 4-6h en per\xedodo de nadir","Evaluar n\xe1useas y v\xf3mitos post-quimioterapia","Valorar mucositis oral","Monitorizar funci\xf3n renal y urato (s\xedndrome de lisis)","Valorar estado emocional y psicol\xf3gico del paciente"],intervenciones:["Monitorizar temperatura y signos de infecci\xf3n en per\xedodo de nadir (d\xedas 10-14 post-ciclo)","Higiene de manos estricta y medidas de barrera","Administrar G-CSF (filgrastim) si est\xe1 pautado para reducir el per\xedodo de neutropenia","Neutropenia febril \u2192 hemocultivos INMEDIATOS + antibi\xf3ticos de amplio espectro en <1h","Educaci\xf3n sobre dieta de neutropenia y evitar contactos con personas enfermas","Administrar antiem\xe9ticos profil\xe1cticos antes de la quimioterapia (ondansetr\xf3n + dexametasona + aprepitant si QT muy emetog\xe9nica)","Continuar antiem\xe9ticos pautados los d\xedas posteriores (n\xe1useas tard\xedas)","Recomendar comidas peque\xf1as y frecuentes, evitar olores fuertes","Controlar balance h\xeddrico si v\xf3mitos persistentes","Registrar gravedad de n\xe1useas con escala CTCAE","Escuchar activamente las preocupaciones del paciente sobre el diagn\xf3stico y tratamiento","Informar de forma honesta y comprensible sobre el plan terap\xe9utico","Ofrecer recursos de psicooncolog\xeda","Facilitar el contacto con grupos de apoyo de linfoma","Valorar el estado emocional en cada visita de tratamiento"],educacionPaciente:["Explicar el plan de tratamiento y el n\xfamero de ciclos previstos","Informar sobre el nadir (momento de mayor riesgo infeccioso 10-14 d\xedas post-ciclo)","Instruir para medir temperatura en domicilio y acudir a urgencias si >38\xb0C","Preparar para la alopecia temporal (opciones: peluca, pa\xf1uelo)","Informar sobre la posibilidad de conservar gametos antes del tratamiento","Recomendar no vacunarse con vacunas vivas durante el tratamiento","Explicar la importancia de las revisiones post-tratamiento (seguimiento de remisi\xf3n)"],monitorizacion:[]},npiNanda:[{codigo:"00004",nombre:"Riesgo de infecci\xf3n",definicion:"Vulnerable a una invasi\xf3n y multiplicaci\xf3n de organismos pat\xf3genos por neutropenia inducida por quimioterapia",caracteristicasDefinitorias:[],factoresRelacionados:["Neutropenia","Inmunosupresi\xf3n por quimioterapia","Cat\xe9ter venoso central"]},{codigo:"00093",nombre:"Fatiga",definicion:"Sensaci\xf3n abrumadora y sostenida de agotamiento",caracteristicasDefinitorias:["Agotamiento intenso","Incapacidad funcional","Somnolencia excesiva"],factoresRelacionados:["Proceso neopl\xe1sico","Quimioterapia","Anemia"]},{codigo:"00134",nombre:"N\xe1useas",definicion:"Fen\xf3meno subjetivo desagradable de oleadas en la parte posterior de la garganta y el est\xf3mago",caracteristicasDefinitorias:["N\xe1useas referidas","V\xf3mitos","Hiporexia"],factoresRelacionados:["Agentes quimioter\xe1picos emetog\xe9nicos","Ansiedad"]}],npiNic:[{codigo:"6550",nombre:"Protecci\xf3n contra las infecciones",actividades:["Monitorizar temperatura y signos de infecci\xf3n en per\xedodo de nadir (d\xedas 10-14 post-ciclo)","Higiene de manos estricta y medidas de barrera","Administrar G-CSF (filgrastim) si est\xe1 pautado para reducir el per\xedodo de neutropenia","Neutropenia febril \u2192 hemocultivos INMEDIATOS + antibi\xf3ticos de amplio espectro en <1h","Educaci\xf3n sobre dieta de neutropenia y evitar contactos con personas enfermas"]},{codigo:"1450",nombre:"Manejo de las n\xe1useas",actividades:["Administrar antiem\xe9ticos profil\xe1cticos antes de la quimioterapia (ondansetr\xf3n + dexametasona + aprepitant si QT muy emetog\xe9nica)","Continuar antiem\xe9ticos pautados los d\xedas posteriores (n\xe1useas tard\xedas)","Recomendar comidas peque\xf1as y frecuentes, evitar olores fuertes","Controlar balance h\xeddrico si v\xf3mitos persistentes","Registrar gravedad de n\xe1useas con escala CTCAE"]},{codigo:"5270",nombre:"Apoyo emocional",actividades:["Escuchar activamente las preocupaciones del paciente sobre el diagn\xf3stico y tratamiento","Informar de forma honesta y comprensible sobre el plan terap\xe9utico","Ofrecer recursos de psicooncolog\xeda","Facilitar el contacto con grupos de apoyo de linfoma","Valorar el estado emocional en cada visita de tratamiento"]}],npiNoc:[{codigo:"0702",nombre:"Estado inmune",indicadores:["Neutr\xf3filos >1000/\u03bcL","Ausencia de infecci\xf3n","Temperatura normal"],escala:"Recuperaci\xf3n del nadir sin infecci\xf3n grave en cada ciclo de quimioterapia"},{codigo:"1008",nombre:"Estado nutricional: ingesti\xf3n alimentaria y de l\xedquidos",indicadores:["Ingesta cal\xf3rica adecuada","Ingesta h\xeddrica suficiente","Peso estable"],escala:"Mantener peso y estado nutricional durante el tratamiento"}],complicaciones:["Neutropenia febril y sepsis","Toxicidad pulmonar por bleomicina","Cardiotoxicidad por antraciclinas","S\xedndrome de lisis tumoral","Neuropat\xeda perif\xe9rica por vincristina/vinblastina","Infertilidad post-tratamiento","Neoplasia secundaria (leucemia mieloide, tumores s\xf3lidos)","Reca\xedda refractaria"],criteriosAlarma:["S\xedndrome de vena cava superior (edema en esclavina, cianosis, ingurgitaci\xf3n yugular)","Compresi\xf3n medular por masa epidural","S\xedndrome de lisis tumoral (LNH de alto grado)","Deterioro neurol\xf3gico por infiltraci\xf3n SNC","Obstrucci\xf3n de la v\xeda a\xe9rea por masa mediast\xednica"],emergencyLevel:"moderado",relatedPathologyIds:[],isPremium:!0},{id:"pat_cid",nombre:"Coagulaci\xf3n Intravascular Diseminada (CID)",bodySystemId:"hematologico",definicion:"S\xedndrome cl\xednico caracterizado por la activaci\xf3n sist\xe9mica de la coagulaci\xf3n que lleva al consumo de factores de coagulaci\xf3n y plaquetas, con formaci\xf3n de microtrombos y simult\xe1neamente tendencia hemorr\xe1gica. Siempre secundario a una enfermedad de base grave.",epidemiologia:"",factoresRiesgo:[],fisiopatologia:"La CID es una respuesta fisiopatol\xf3gica a diversas condiciones (sepsis, traumatismo grave, LPA, abruptio placentae, mordedura de serpiente). El desencadenante activa la v\xeda extr\xednseca masivamente mediante Factor Tisular (FT), generando trombina sist\xe9mica. La trombina convierte el fibrin\xf3geno en fibrina, formando microtrombos en la microvasculatura (isquemia de \xf3rganos). Simult\xe1neamente, el consumo masivo de factores (V, VIII, fibrin\xf3geno) y plaquetas, junto a la activaci\xf3n de la fibrin\xf3lisis (plasmina), resulta en incapacidad de hemostasia con hemorragia parad\xf3jica. Es un c\xedrculo vicioso de coagulaci\xf3n y hemorragia.",signosYSintomas:{signos:["Hemorragia simult\xe1nea en m\xfaltiples sitios: piel, puntos de venopunci\xf3n, mucosas","Petequias y equimosis extensas (trombocitopenia)","Sangrado difuso en heridas quir\xfargicas, SNG, cat\xe9teres","Signos de isquemia de \xf3rganos por microtrombos: deterioro renal, hep\xe1tico, neurol\xf3gico","Necrosis cut\xe1nea y gangrena perif\xe9rica (microtrombos en vasos distales)","Hemorragia masiva con inestabilidad hemodin\xe1mica","Fallo multiorg\xe1nico: FRA, IHA, SDRA","Necrosis cortical bilateral (FRA irreversible)","Hemorragia intracraneal","Shock hemorr\xe1gico"],sintomas:["Fiebre (proceso de base: sepsis)","Hemoptisis y hematurias","Epistaxis incoercible","Hemorragia digestiva","Deterioro del nivel de conciencia (microtrombos cerebrales)"]},diagnostico:{anamnesis:["Score CID de la ISTH \u22655 puntos (covert CID <5): plaquetas, d\xedmero D, TP, fibrin\xf3geno","Plaquetas <100,000/\u03bcL (2 pts), 100,000-<150,000 (1 pt)","D\xedmero D: elevaci\xf3n moderada (2 pts), elevaci\xf3n marcada (3 pts)","TP prolongado: 3-6 seg (1 pt), >6 seg (2 pts)","Fibrin\xf3geno <1 g/L (1 pt)"],examenFisico:[],pruebas:[{nombre:"Hemograma: trombocitopenia progresiva, anemia microangiop\xe1tica (esquistocitos en frotis)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"TP y TTPA: prolongados",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Fibrin\xf3geno: reducido (consumo)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"D\xedmero D: muy elevado (fibrin\xf3lisis activa)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Tiempo de trombina",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Productos de degradaci\xf3n del fibrin\xf3geno (PDF)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Frotis de sangre perif\xe9rica: esquistocitos (signos de hem\xf3lisis microangiop\xe1tica)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Bioqu\xedmica: creatinina, bilirrubina (afectaci\xf3n de \xf3rganos)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Prueba de sangrado activo: observar si la sangre en tubo coagula",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]}]},tratamientoMedico:{objetivos:[],farmacologico:[{nombre:"Plasma Fresco Congelado (PFC)",grupo:"Contiene todos los",mecanismo:"Contiene todos los factores de coagulaci\xf3n y anticoagulantes naturales (prote\xedna C, S, antitrombina). Repone los factores consumidos en la CID. Volumen 10-20 mL/kg por transfusi\xf3n",dosis:"10-20 mL/kg IV. Repetir seg\xfan coagulaci\xf3n, habitualmente cada 6-8h si hay sangrado activo con TP/TTPA >1.5 veces del control",cuidadosEnfermeria:["Verificar compatibilidad de grupo sangu\xedneo (ABO) antes de transfundir","Descongelar adecuadamente en ba\xf1o de agua a 37\xb0C (no microondas)","Administrar dentro de las 6h post-descongelaci\xf3n","Vigilar signos de reacci\xf3n transfusional: fiebre, escalofr\xedos, hipotensi\xf3n, disnea (TRALI)","Monitorizar balance h\xeddrico (riesgo de sobrecarga en card\xedacos/nefr\xf3ticos)","Controlar TP/TTPA antes y despu\xe9s de la transfusi\xf3n"]},{nombre:"Concentrado de Plaquetas",grupo:"Reposici\xf3n de plaquetas",mecanismo:"Reposici\xf3n de plaquetas consumidas en la CID para restaurar la hemostasia primaria",dosis:"1 pool de plaquetas (pool de 4 donantes) o 1 af\xe9resis si plaquetas <30,000/\u03bcL con sangrado activo, o <50,000/\u03bcL antes de procedimiento invasivo",cuidadosEnfermeria:["Transfundir dentro de las 4h de apertura de la bolsa","Administrar a trav\xe9s de filtro espec\xedfico","Verificar recuento plaquetario pre y 1h post-transfusi\xf3n","Agitar suavemente la bolsa antes de transfundir","Vigilar signos de reacci\xf3n transfusional","En CID activa: transfundir plaquetas solo con sangrado activo, no profil\xe1cticamente"]},{nombre:"Heparina S\xf3dica",grupo:"Inhibidor de la",mecanismo:"Inhibidor de la trombina y del factor Xa mediante activaci\xf3n de antitrombina III. En CID: interrumpe el ciclo de formaci\xf3n de trombina que perpet\xfaa el consumo de factores. Controversial, usar en CID con predominio tromb\xf3tico (trombosis venosas, necrosis acra, purpura fulminans)",dosis:"Dosis bajas: 5-10 UI/kg/h en infusi\xf3n continua. Solo si fibrin\xf3geno >1 g/L y no hay sangrado activo grave",cuidadosEnfermeria:["Monitorizar TTPA cada 4-6h (objetivo: 1.5-2.5 veces el control si se usa anticoagulaci\xf3n)","Vigilar activamente signos de sangrado en CID hemorr\xe1gica","Controlar plaquetas cada 2-3 d\xedas (HIT)","Preparar protamina como ant\xeddoto","NO usar heparina en CID post-trauma o postparto con sangrado activo"]}],noFarmacologico:["TRATAMIENTO DE LA CAUSA SUBYACENTE: es la medida m\xe1s importante (antibi\xf3ticos en sepsis, ATRA en LPA, extracci\xf3n del producto de la concepci\xf3n en abruptio placentae)","Soporte hemodin\xe1mico: fluidoterapia, vasopresores si shock","Soporte ventilatorio si SDRA","Di\xe1lisis si FRA grave","Monitorizaci\xf3n continua en UCI","Crioprecipitados si fibrin\xf3geno <1.5 g/L (contienen fibrin\xf3geno concentrado, factor VIII, vWF)"]},cuidadosEnfermeria:{valoracion:["Monitorizaci\xf3n continua de constantes: PA, FC, FR, SatO2, temperatura","Vigilar sangrado activo: inspeccionar todos los puntos de venopunci\xf3n, heridas, mucosas","Monitorizar diuresis horaria (isquemia renal por microtrombos)","Valorar nivel de conciencia y signos neurol\xf3gicos (isquemia cerebral)","Controlar resultados anal\xedticos: hemograma, coagulaci\xf3n, fibrin\xf3geno, d\xedmero D seriado","Monitorizar balance h\xeddrico estricto","Valorar color y temperatura de extremidades (isquemia distal)"],intervenciones:["Minimizar el n\xfamero de punciones venosas (usar cat\xe9ter central para extracciones y perfusiones)","Aplicar presi\xf3n manual en todos los puntos de punci\xf3n durante 15-20 minutos","Evitar inyecciones IM en cualquier caso","No usar supositorios ni sondas rectales (riesgo de sangrado rectal)","Utilizar ap\xf3sitos compresivos en heridas quir\xfargicas","Documentar todos los focos de sangrado: localizaci\xf3n, cantidad, evoluci\xf3n","Verificar compatibilidad de grupo y Rh antes de cada transfusi\xf3n","Administrar PFC/plaquetas con el paciente monitorizado (PA, FC, SatO2)","Iniciar las transfusiones lentamente y observar los primeros 15 minutos","Documentar cada producto transfundido con n\xfamero de lote, fecha y hora","Controlar coagulaci\xf3n y hemograma post-transfusi\xf3n para evaluar eficacia","Suspender transfusi\xf3n y notificar ante cualquier reacci\xf3n adversa","Inspeccionar piel cada 2-4h: petequias, equimosis nuevas, necrosis acra","Evaluar color, temperatura y pulso en extremidades (isquemia distal)","Documentar la extensi\xf3n de las lesiones hemorr\xe1gicas cut\xe1neas","Proteger la piel de presi\xf3n (colch\xf3n antiescaras, cambios posturales)","Notificar deterioro: nuevas necrosis cut\xe1neas, cambios en color de extremidades"],educacionPaciente:["Explicar a la familia la gravedad de la situaci\xf3n y los procedimientos en curso (UCI)","Informar sobre la necesidad de m\xfaltiples transfusiones y an\xe1lisis frecuentes","Explicar los signos de alarma espec\xedficos que deben comunicar al personal","Preparar a la familia para el posible deterioro progresivo","Ofrecer apoyo psicol\xf3gico a la familia durante la fase aguda"],monitorizacion:[]},npiNanda:[{codigo:"00206",nombre:"Riesgo de sangrado",definicion:"Vulnerable a una disminuci\xf3n del volumen sangu\xedneo por coagulopat\xeda de consumo",caracteristicasDefinitorias:[],factoresRelacionados:["Consumo de factores de coagulaci\xf3n y plaquetas","Fibrin\xf3lisis secundaria"]},{codigo:"00005",nombre:"Riesgo de desequilibrio de la temperatura corporal",definicion:"Vulnerable a no mantener la temperatura corporal dentro de los par\xe1metros normales",caracteristicasDefinitorias:[],factoresRelacionados:["Inestabilidad hemodin\xe1mica","Sepsis subyacente"]},{codigo:"00033",nombre:"Deterioro de la ventilaci\xf3n espont\xe1nea",definicion:"Disminuci\xf3n de las reservas energ\xe9ticas que resulta en la incapacidad del individuo para mantener la respiraci\xf3n adecuada",caracteristicasDefinitorias:["Disnea progresiva","Hipoxemia","Taquipnea"],factoresRelacionados:["SDRA por microtrombos pulmonares","Hemorragia pulmonar"]}],npiNic:[{codigo:"4010",nombre:"Precauciones ante hemorragias",actividades:["Minimizar el n\xfamero de punciones venosas (usar cat\xe9ter central para extracciones y perfusiones)","Aplicar presi\xf3n manual en todos los puntos de punci\xf3n durante 15-20 minutos","Evitar inyecciones IM en cualquier caso","No usar supositorios ni sondas rectales (riesgo de sangrado rectal)","Utilizar ap\xf3sitos compresivos en heridas quir\xfargicas","Documentar todos los focos de sangrado: localizaci\xf3n, cantidad, evoluci\xf3n"]},{codigo:"4030",nombre:"Administraci\xf3n de hemoderivados",actividades:["Verificar compatibilidad de grupo y Rh antes de cada transfusi\xf3n","Administrar PFC/plaquetas con el paciente monitorizado (PA, FC, SatO2)","Iniciar las transfusiones lentamente y observar los primeros 15 minutos","Documentar cada producto transfundido con n\xfamero de lote, fecha y hora","Controlar coagulaci\xf3n y hemograma post-transfusi\xf3n para evaluar eficacia","Suspender transfusi\xf3n y notificar ante cualquier reacci\xf3n adversa"]},{codigo:"3580",nombre:"Vigilancia de la piel",actividades:["Inspeccionar piel cada 2-4h: petequias, equimosis nuevas, necrosis acra","Evaluar color, temperatura y pulso en extremidades (isquemia distal)","Documentar la extensi\xf3n de las lesiones hemorr\xe1gicas cut\xe1neas","Proteger la piel de presi\xf3n (colch\xf3n antiescaras, cambios posturales)","Notificar deterioro: nuevas necrosis cut\xe1neas, cambios en color de extremidades"]}],npiNoc:[{codigo:"0413",nombre:"Severidad de la p\xe9rdida de sangre",indicadores:["P\xe9rdida de sangre visible","Hemoglobina","Plaquetas","Fibrin\xf3geno"],escala:"Estabilizaci\xf3n de la coagulaci\xf3n con fibrin\xf3geno >1.5 g/L y cese del sangrado activo"},{codigo:"0601",nombre:"Equilibrio h\xeddrico",indicadores:["Presi\xf3n arterial estable","Diuresis adecuada >0.5 mL/kg/h","Sin signos de edema o hipovolemia"],escala:"Mantenimiento del equilibrio hemodin\xe1mico sin sobrecarga ni hipovolemia"}],complicaciones:["Shock hemorr\xe1gico","Fallo multiorg\xe1nico (renal, hep\xe1tico, pulmonar, cerebral)","SDRA","FRA por necrosis tubular isqu\xe9mica","Necrosis cut\xe1nea y gangrena de extremidades","Hemorragia intracraneal","Muerte (mortalidad 30-80% seg\xfan la causa)"],criteriosAlarma:["Hemorragia masiva con inestabilidad hemodin\xe1mica","Fallo multiorg\xe1nico: FRA, IHA, SDRA","Necrosis cortical bilateral (FRA irreversible)","Hemorragia intracraneal","Shock hemorr\xe1gico"],emergencyLevel:"critico",relatedPathologyIds:[],isPremium:!0},{id:"pat_vih",nombre:"VIH/SIDA",bodySystemId:"inmunologico",definicion:"Infecci\xf3n por el Virus de la Inmunodeficiencia Humana (VIH) que destruye progresivamente los linfocitos T CD4+, llevando al S\xedndrome de Inmunodeficiencia Adquirida (SIDA), definido por CD4 <200 c\xe9lulas/\u03bcL o por la presencia de enfermedades oportunistas definitorias de SIDA.",epidemiologia:"",factoresRiesgo:[],fisiopatologia:"El VIH (retrovirus) infecta preferentemente linfocitos T CD4+ (receptor CD4 + correceptor CCR5 o CXCR4), macr\xf3fagos y c\xe9lulas dendr\xedticas. El virus se integra en el genoma del hu\xe9sped como provirus. La transcriptasa inversa (RT) copia el ARN viral a ADN, que la integrasa inserta en el cromosoma celular. La activaci\xf3n celular induce la producci\xf3n de nuevos viriones que usan la proteasa viral para madurar. La depleci\xf3n progresiva de CD4+ deteriora la inmunidad celular, permitiendo infecciones oportunistas y neoplasias. Sin tratamiento: fase aguda \u2192 latencia cl\xednica (a\xf1os) \u2192 SIDA.",signosYSintomas:{signos:["Infecci\xf3n aguda (s\xedndrome retroviral agudo): fiebre, faringitis, exantema, linfadenopat\xedas, mialgias (2-6 semanas post-exposici\xf3n)","Fase cr\xf3nica: linfadenopat\xedas generalizadas persistentes","SIDA: neumon\xeda por Pneumocystis jirovecii (PCP), toxoplasmosis cerebral, candidiasis esof\xe1gica, CMV","P\xe9rdida de peso >10% sin causa aparente","Diarrea cr\xf3nica","CD4 <50 c\xe9lulas/\u03bcL (riesgo de CMV, MAI, criptococo)","Cefalea + fiebre + rigidez de nuca (meningitis criptoc\xf3cica)","Disnea + fiebre + hipoxia (PCP)","Focalidad neurol\xf3gica + cefalea (toxoplasmosis o linfoma cerebral)","Carga viral detectable en paciente en TAR (resistencia/incumplimiento)"],sintomas:["Dermatitis seborreica, psoriasis","Leucoplasia oral vellosa (EBV)","Sarcoma de Kaposi (HHV-8)","Linfoma no Hodgkin","Neuropat\xeda perif\xe9rica","Encefalopat\xeda por VIH (demencia)"]},diagnostico:{anamnesis:["ELISA de cuarta generaci\xf3n (Ag p24 + Ac): alta sensibilidad","Western blot o inmunofluorescencia confirmatoria","ARN viral (carga viral) por PCR: confirma precozmente y monitoriza tratamiento","SIDA: CD4 <200/\u03bcL o enfermedad definitoria de SIDA seg\xfan criterios CDC"],examenFisico:[],pruebas:[{nombre:"Recuento de CD4+ y CD8+ (estadificaci\xf3n y riesgo oportunistas)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Carga viral plasm\xe1tica (ARN-VIH) cuantitativa",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Hemograma (anemia, leucopenia, trombocitopenia)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Bioqu\xedmica completa (funci\xf3n renal, hep\xe1tica, perfil lip\xeddico)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Serolog\xedas: hepatitis B (coinfecci\xf3n frecuente), hepatitis C, s\xedfilis, toxoplasma, CMV",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"PPD/IGRA (tuberculosis latente)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Radiograf\xeda de t\xf3rax",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Test de resistencias genot\xedpicas (antes de iniciar TAR o ante fracaso virol\xf3gico)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Fundoscopia si CD4 <50/\u03bcL (CMV retiniano)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]}]},tratamientoMedico:{objetivos:[],farmacologico:[{nombre:"Bictegravir/Tenofovir alafenamida/Emtricitabina (Biktarvy)",grupo:"R\xe9gimen de comprimido",mecanismo:"R\xe9gimen de comprimido \xfanico que combina: Bictegravir (inhibidor de integrasa, bloquea la integraci\xf3n del ADN viral); Tenofovir alafenamida (TAF, an\xe1logo nucleot\xeddico de adenosina que inhibe la transcriptasa inversa); Emtricitabina (FTC, an\xe1logo de citidina inhibidor de la transcriptasa inversa)",dosis:"1 comprimido VO cada 24 horas con o sin alimentos. R\xe9gimen de primera l\xednea recomendado por alta barrera gen\xe9tica a resistencias y excelente perfil de tolerabilidad",cuidadosEnfermeria:["Reforzar la adherencia: la toma diaria es fundamental (resistencias con >95% adherencia requerida)","Explicar que las molestias gastrointestinales iniciales suelen resolverse en 2-4 semanas","Monitorizar funci\xf3n renal y densidad \xf3sea peri\xf3dicamente","Verificar interacciones: anti\xe1cidos reducen absorci\xf3n de bictegravir (separar 2h)","Realizar carga viral y CD4 a los 3 meses para verificar respuesta","Recordar que el paciente en TAR efectivo (carga indetectable) NO transmite el VIH (U=U)"]},{nombre:"Cotrimoxazol (TMP/SMX)",grupo:"Profilaxis primaria de",mecanismo:"Profilaxis primaria de PCP (Pneumocystis jirovecii) y toxoplasmosis en pacientes con CD4 <200/\u03bcL. Combinaci\xf3n sin\xe9rgica: trimetoprim inhibe dihidrofolato reductasa, sulfametoxazol inhibe s\xedntesis de dihidrofolato",dosis:"Profilaxis: 1 comprimido forte (800/160 mg) VO 3 veces/semana o 1 comprimido simple diario. Tratamiento de PCP: 15-20 mg/kg/d\xeda de trimetoprim IV o VO durante 21 d\xedas",cuidadosEnfermeria:["Vigilar aparici\xf3n de exantema (suspender si Stevens-Johnson: ampollas, mucosas afectadas)","Hidrataci\xf3n adecuada para evitar cristaluria","Monitorizar hemograma y funci\xf3n renal","Informar sobre protecci\xf3n solar (fototoxicidad)","Suspender profilaxis cuando CD4 >200/\u03bcL durante >3 meses con TAR efectivo"]},{nombre:"Cabotegravir + Rilpivirina inyectables",grupo:"R\xe9gimen inyectable de",mecanismo:"R\xe9gimen inyectable de larga duraci\xf3n para sustituci\xf3n de TAR oral. Cabotegravir (inhibidor de integrasa de acci\xf3n prolongada) + Rilpivirina (inhibidor no nucleos\xeddico de la transcriptasa inversa). Permite un ciclo mensual o bimensual en lugar de comprimido diario",dosis:"Dosis de carga oral 1 mes. Luego inyecci\xf3n IM de cabotegravir 600 mg + rilpivirina 900 mg mensual, o cabotegravir 600 mg + rilpivirina 1200 mg bimensual (cu\xe1driceps o gl\xfateo)",cuidadosEnfermeria:["Alternar zonas de inyecci\xf3n: gl\xfateo derecho/izquierdo o cu\xe1driceps","Administrar la inyecci\xf3n IM profunda (m\xfasculo amplio) con aguja de longitud adecuada","Sactualizar carga viral antes de cada ciclo para verificar supresi\xf3n","Adherencia a las citas de inyecci\xf3n es cr\xedtica (resistencia si se pierde la cobertura)","Informar al paciente que puede sentir induraci\xf3n local semanas post-inyecci\xf3n (normal)"]}],noFarmacologico:["Consejer\xeda sobre transmisi\xf3n y prevenci\xf3n (preservativo, PrEP para parejas)","Apoyo psicosocial y grupos de pares","Vacunaci\xf3n: gripe anual, neumococo, hepatitis A y B, HPV (seg\xfan estadio CD4)","Cribado de comorbilidades: ITS, TBC, hepatitis, neoplasias","Nutrici\xf3n equilibrada y ejercicio f\xedsico regular","Abandono de tabaco y alcohol"]},cuidadosEnfermeria:{valoracion:["Valorar CD4 actual y carga viral para estratificar riesgo de oportunistas","Evaluar adherencia al TAR (estrategias de adherencia, barreras)","Valorar presencia de infecciones oportunistas: fiebre, tos, cefalea, diarrea","Evaluar estado nutricional y peso","Valorar estado emocional: depresi\xf3n, ansiedad, estigma","Revisar medicaci\xf3n actual: posibles interacciones con el TAR","Evaluar red de apoyo social"],intervenciones:["Evaluar el estado nutricional peri\xf3dicamente (peso, IMC, alb\xfamina)","Fomentar ingesta cal\xf3rico-proteica adecuada, especialmente en SIDA con caquexia","Educaci\xf3n sobre seguridad alimentaria: evitar alimentos crudos si CD4 <200/\u03bcL (toxoplasma, salmonella)","Coordinar con nutricionista si p\xe9rdida de peso >10%","Monitorizar efectos adversos del TAR sobre el metabolismo (dislipemia, redistribuci\xf3n grasa)","Explicar la importancia de la adherencia perfecta al TAR para evitar resistencias","Reforzar la toma diaria con estrategias: alarmas, pastillero, vinculaci\xf3n a h\xe1bitos","Informar sobre los efectos secundarios m\xe1s frecuentes y c\xf3mo manejarlos","Explicar que con carga viral indetectable no se transmite el virus (U=U)","Resolver dudas sobre interacciones con otros medicamentos","Crear un ambiente de confianza, sin juicios, para que el paciente se exprese libremente","Abordar el estigma y sus efectos sobre la adherencia y la calidad de vida","Conectar con grupos de apoyo de personas con VIH","Evaluar y tratar la depresi\xf3n (muy frecuente en VIH)","Implicar a la pareja/familia si el paciente lo desea"],educacionPaciente:["Explicar que el VIH es una enfermedad cr\xf3nica manejable con tratamiento, no una sentencia","Insistir en la adherencia perfecta al TAR: 1 comprimido diario = carga indetectable = no transmisi\xf3n","Explicar U=U: Undetectable = Untransmittable (carga viral indetectable no transmite el VIH)","Educar sobre pr\xe1cticas de sexo seguro y uso del preservativo","Informar sobre la PrEP para parejas negativas","Ense\xf1ar signos de alarma de infecciones oportunistas","Informar sobre los derechos legales del paciente con VIH (confidencialidad)"],monitorizacion:[]},npiNanda:[{codigo:"00004",nombre:"Riesgo de infecci\xf3n",definicion:"Vulnerable a una invasi\xf3n y multiplicaci\xf3n de organismos pat\xf3genos por inmunodeficiencia celular",caracteristicasDefinitorias:[],factoresRelacionados:["CD4 <200/\u03bcL","Inmunodeficiencia por VIH","Mala adherencia al TAR"]},{codigo:"00099",nombre:"Mantenimiento ineficaz de la salud",definicion:"Incapacidad de identificar, gestionar o buscar ayuda para mantener la salud",caracteristicasDefinitorias:["Incumplimiento del TAR","Falta de asistencia a controles","Conductas de riesgo persistentes"],factoresRelacionados:["Falta de conocimientos sobre la enfermedad","Estigma social","Barreras de acceso al sistema sanitario"]},{codigo:"00053",nombre:"Aislamiento social",definicion:"Soledad experimentada por el individuo y percibida como impuesta por otros y como estado negativo",caracteristicasDefinitorias:["Verbalizaci\xf3n de sentirse diferente","Retraimiento","Evitaci\xf3n de relaciones sociales"],factoresRelacionados:["Estigma asociado al VIH","Miedo al rechazo","Discriminaci\xf3n"]}],npiNic:[{codigo:"5246",nombre:"Asesoramiento nutricional",actividades:["Evaluar el estado nutricional peri\xf3dicamente (peso, IMC, alb\xfamina)","Fomentar ingesta cal\xf3rico-proteica adecuada, especialmente en SIDA con caquexia","Educaci\xf3n sobre seguridad alimentaria: evitar alimentos crudos si CD4 <200/\u03bcL (toxoplasma, salmonella)","Coordinar con nutricionista si p\xe9rdida de peso >10%","Monitorizar efectos adversos del TAR sobre el metabolismo (dislipemia, redistribuci\xf3n grasa)"]},{codigo:"5616",nombre:"Ense\xf1anza: medicamentos prescritos",actividades:["Explicar la importancia de la adherencia perfecta al TAR para evitar resistencias","Reforzar la toma diaria con estrategias: alarmas, pastillero, vinculaci\xf3n a h\xe1bitos","Informar sobre los efectos secundarios m\xe1s frecuentes y c\xf3mo manejarlos","Explicar que con carga viral indetectable no se transmite el virus (U=U)","Resolver dudas sobre interacciones con otros medicamentos"]},{codigo:"5270",nombre:"Apoyo emocional",actividades:["Crear un ambiente de confianza, sin juicios, para que el paciente se exprese libremente","Abordar el estigma y sus efectos sobre la adherencia y la calidad de vida","Conectar con grupos de apoyo de personas con VIH","Evaluar y tratar la depresi\xf3n (muy frecuente en VIH)","Implicar a la pareja/familia si el paciente lo desea"]}],npiNoc:[{codigo:"0702",nombre:"Estado inmune",indicadores:["CD4 en aumento o estable","Carga viral indetectable","Ausencia de infecciones oportunistas"],escala:"Carga viral indetectable (<50 copias/mL) a los 6 meses de TAR y CD4 >200/\u03bcL"},{codigo:"1601",nombre:"Conducta de cumplimiento",indicadores:["Toma regular de medicaci\xf3n","Asistencia a controles","Reducci\xf3n de conductas de riesgo"],escala:"Adherencia >95% al TAR verificada en cada visita de control"}],complicaciones:["Infecciones oportunistas: PCP, toxoplasmosis, criptococosis, CMV, MAI","Neoplasias definitorias de SIDA: sarcoma de Kaposi, linfoma no Hodgkin","Encefalopat\xeda por VIH","S\xedndrome de reconstituci\xf3n inmune (SIRI) al iniciar TAR","Hepatotoxicidad, nefrotoxicidad por TAR","Coinfecci\xf3n tuberculosa","Hepatitis C: cirrosis acelerada en coinfecci\xf3n VIH/VHC"],criteriosAlarma:["CD4 <50 c\xe9lulas/\u03bcL (riesgo de CMV, MAI, criptococo)","Cefalea + fiebre + rigidez de nuca (meningitis criptoc\xf3cica)","Disnea + fiebre + hipoxia (PCP)","Focalidad neurol\xf3gica + cefalea (toxoplasmosis o linfoma cerebral)","Carga viral detectable en paciente en TAR (resistencia/incumplimiento)"],emergencyLevel:"moderado",relatedPathologyIds:[],isPremium:!1},{id:"pat_lupus",nombre:"Lupus Eritematoso Sist\xe9mico (LES)",bodySystemId:"inmunologico",definicion:"Enfermedad autoinmune sist\xe9mica caracterizada por la producci\xf3n de autoanticuerpos contra componentes nucleares (ANA, anti-dsDNA) y formaci\xf3n de inmunocomplejos que causan inflamaci\xf3n en m\xfaltiples \xf3rganos: piel, ri\xf1ones, articulaciones, SNC, coraz\xf3n y pulmones. Cursa en brotes y remisiones.",epidemiologia:"",factoresRiesgo:[],fisiopatologia:"La deficiente eliminaci\xf3n de material apopt\xf3tico (nucleosomas, ARN) expone autoant\xedgenos nucleares al sistema inmune. Los linfocitos B autorreactivos, con ayuda de c\xe9lulas T cooperadoras (Th1/Th17), producen autoanticuerpos: ANA (antinucleares), anti-dsDNA (espec\xedficos de LES, correlacionan con nefritis l\xfapica), anti-Sm. Los inmunocomplejos se depositan en los tejidos, activando el complemento (C3, C4 bajos en brote). La inflamaci\xf3n resultante da\xf1a los \xf3rganos diana: glomerulonefritis membranosa o proliferativa (nefritis l\xfapica), serositis, artritis, vasculitis cut\xe1nea.",signosYSintomas:{signos:["Eritema malar en mariposa (mejillas y puente nasal, respeta surcos nasogenianos)","Fotosensibilidad","Artritis no erosiva sim\xe9trica","Nefritis l\xfapica (proteinuria, hematuria, cilindruria)","Serositis: pleuritis o pericarditis","Brote de nefritis l\xfapica grave: hematuria macrosc\xf3pica, deterioro de funci\xf3n renal","Lupus neuropsiqui\xe1trico: convulsiones, psicosis, ictus","S\xedndrome antifosfol\xedpido asociado: trombosis arterial/venosa, p\xe9rdidas fetales","Pancitopenia grave (aplasia medular l\xfapica rara)","Hemorragia pulmonar alveolar (urgencia)"],sintomas:["\xdalceras orales indoloras","Alopecia no cicatricial","Leucopenia, linfopenia, trombocitopenia","Anemia hemol\xedtica autoinmune","Fen\xf3meno de Raynaud","Psicosis o convulsiones l\xfapicas","Eritema discoide (cicatricial)"]},diagnostico:{anamnesis:["Criterios EULAR/ACR 2019: puntuaci\xf3n \u226510 puntos con ANA positivo como criterio de entrada","Dominio constitucional: fiebre (2 pts)","Dominio hematol\xf3gico: leucopenia (3), trombocitopenia (4), anemia hemol\xedtica (4)","Dominio neuropsiqui\xe1trico: convulsiones (5), psicosis (3)","Dominio mucocut\xe1neo: alopecia (2), \xfalceras orales (2), eritema malar (4), lupus discoide (4)","Dominio seroso: pleuritis (5), pericarditis (6)","Dominio musculoesquel\xe9tico: sinovitis \u22652 articulaciones (6)","Dominio renal: proteinuria >0.5 g/24h (4), biopsia clase III o IV (8), clase V (4)","Anticuerpos: anti-dsDNA (6), anti-Sm (6), antifosfol\xedpidos (2), complemento bajo (3)"],examenFisico:[],pruebas:[{nombre:"ANA (cribado: casi 100% sensibilidad, baja especificidad)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Anti-dsDNA (alta especificidad, correlaciona con actividad renal)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Anti-Sm (espec\xedfico pero poco sensible)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Complemento C3 y C4 (bajos en brote activo)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Anticuerpos antifosfol\xedpidos: anti-cardiolipina, anti-beta2GPI, anticoagulante l\xfapico",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Hemograma, funci\xf3n renal y hep\xe1tica",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Sedimento urinario y proteinuria en orina de 24h",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Biopsia renal (clasificaci\xf3n ISN/RPS de nefritis l\xfapica: I-VI)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Anti-Ro, anti-La (lupus neonatal)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"\xcdndice de actividad SLEDAI",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]}]},tratamientoMedico:{objetivos:[],farmacologico:[{nombre:"Hidroxicloroquina",grupo:"Antipal\xfadico que inhibe",mecanismo:"Antipal\xfadico que inhibe la activaci\xf3n de c\xe9lulas dendr\xedticas plasmocitoides via receptores TLR7/TLR9, reduciendo la producci\xf3n de interfer\xf3n alfa y la activaci\xf3n del sistema inmune. Es el pilar del tratamiento en TODOS los pacientes con LES",dosis:"200-400 mg/d\xeda VO (m\xe1ximo 5 mg/kg/d\xeda de peso ideal para minimizar toxicidad retiniana). Tratamiento indefinido en la mayor\xeda de pacientes",cuidadosEnfermeria:["Asegurar examen oftalmol\xf3gico basal y anual despu\xe9s de 5 a\xf1os de tratamiento (OCT de alta resoluci\xf3n)","Monitorizar ECG en pacientes con cardiopat\xeda de base","Vigilar hipoglucemia en pacientes diab\xe9ticos tratados con insulina","Insistir en que NO se suspenda en el embarazo (protege contra brotes y nefritis l\xfapica neonatal)","Explicar que el efecto terap\xe9utico se inicia a las 2-6 semanas de tratamiento"]},{nombre:"Micofenolato Mofetilo",grupo:"Inhibidor de la",mecanismo:"Inhibidor de la inosina monofosfato deshidrogenasa (IMPDH), enzima limitante en la s\xedntesis de purinas de novo en linfocitos. Inhibe selectivamente la proliferaci\xf3n de linfocitos T y B sin afectar otras c\xe9lulas que tienen v\xedas alternativas",dosis:"500 mg-3 g/d\xeda VO en 2 tomas. Dosis de mantenimiento en nefritis l\xfapica clase III-V: 2-3 g/d\xeda",cuidadosEnfermeria:["Administrar con alimentos para reducir intolerancia gastrointestinal","Monitorizar hemograma peri\xf3dicamente","Contraindicado en embarazo: anticoncepci\xf3n efectiva OBLIGATORIA (suspender 6 semanas antes de intentar embarazo)","Vigilar signos de infecci\xf3n (paciente inmunosuprimido)","No triturar los comprimidos (riesgo de exposici\xf3n teratog\xe9nica para personal)"]},{nombre:"Belimumab",grupo:"Anticuerpo monoclonal anti-BLyS",mecanismo:"Anticuerpo monoclonal anti-BLyS (estimulador de linfocitos B) que reduce la supervivencia de c\xe9lulas B autorreactivas. Primer biol\xf3gico aprobado espec\xedficamente para LES en >50 a\xf1os",dosis:"10 mg/kg IV cada 2 semanas \xd7 3 dosis de carga, luego mensual. O 200 mg SC semanal",cuidadosEnfermeria:["Premedicar antes de la infusi\xf3n IV: antihistam\xednico + paracetamol","Infundir IV en 1 hora, observar 1h post-infusi\xf3n por reacciones tard\xedas","Evaluar estado emocional en cada visita (riesgo de depresi\xf3n/suicidio con belimumab)","No administrar en lupus neuropsiqui\xe1trico activo o nefritis grave (poca evidencia)","Contraindicado en embarazo","Vigilar infecciones urinarias y respiratorias frecuentes"]}],noFarmacologico:["Fotoprotecci\xf3n estricta: protector solar SPF 50+ diario, evitar exposici\xf3n solar directa","Evitar desencadenantes de brotes: infecciones, estr\xe9s, rayos UV","Vacunaci\xf3n actualizada (excepto vacunas vivas con inmunosupresores)","Anticoncepci\xf3n segura (anticonceptivos con estr\xf3genos pueden desencadenar brotes)","Monitorizaci\xf3n estrecha del embarazo (riesgo de preeclampsia, RCIU, p\xe9rdidas fetales)"]},cuidadosEnfermeria:{valoracion:["Evaluar actividad del lupus: SLEDAI (\xedndice de actividad de 24 \xedtems)","Valorar funci\xf3n renal: proteinuria, creatinina, sedimento urinario","Monitorizar constantes vitales y tensi\xf3n arterial","Evaluar lesiones cut\xe1neas: eritema malar, \xfalceras orales, alopecia","Valorar dolor articular y funcionalidad","Revisar complemento (C3, C4) y anti-dsDNA (marcadores de brote)","Evaluar estado emocional (alta prevalencia de depresi\xf3n en LES)"],intervenciones:["Instruir sobre el uso diario de fotoprotector SPF 50+ en zonas expuestas","Recomendar ropa protectora y evitar exposici\xf3n solar entre 10:00-17:00h","Evaluar lesiones cut\xe1neas (eritema malar, vasculitis, \xfalceras)","Ense\xf1ar cuidados de higiene oral para minimizar \xfalceras orales","Vigilar signos de infecci\xf3n en zonas de piel alterada","Monitorizar diuresis, edemas y PA en nefritis l\xfapica","Registrar peso diario para detectar retenci\xf3n h\xeddrica","Controlar proteinuria en orina de 24h o cociente alb\xfamina/creatinina","Restricci\xf3n de sodio y prote\xednas si hay nefritis activa y edemas","Verificar funci\xf3n renal antes de cada ciclo de inmunosupresor","Educar sobre desencadenantes de brotes: sol, infecciones, estr\xe9s, ciertos f\xe1rmacos","Explicar la importancia de la fotoprotecci\xf3n permanente","Instruir sobre signos de brote que deben motivar consulta urgente","Educar sobre anticoncepci\xf3n segura (pildora con estr\xf3genos contraindicada en SAF)","Informar sobre la planificaci\xf3n del embarazo con el reumat\xf3logo"],educacionPaciente:["Explicar que el LES es una enfermedad cr\xf3nica que se puede controlar pero requiere seguimiento de por vida","Insistir en la fotoprotecci\xf3n como medida de prevenci\xf3n de brotes (no solo est\xe9tica)","Ense\xf1ar a reconocer s\xedntomas de brote (empeoramiento de lesiones cut\xe1neas, dolor articular, fiebre, edemas)","Explicar la teratogenicidad de algunos f\xe1rmacos y la importancia de planificar el embarazo","Informar sobre los grupos de apoyo de lupus","Recomendar vacunaci\xf3n actualizada: gripe anual, neumococo, hepatitis B"],monitorizacion:[]},npiNanda:[{codigo:"00004",nombre:"Riesgo de infecci\xf3n",definicion:"Vulnerable a infecciones por inmunosupresi\xf3n farmacol\xf3gica y propia de la enfermedad",caracteristicasDefinitorias:[],factoresRelacionados:["Inmunosupresores (micofenolato, corticoides)","Complemento bajo","Nefropat\xeda l\xfapica"]},{codigo:"00047",nombre:"Riesgo de deterioro de la integridad cut\xe1nea",definicion:"Riesgo de que la piel sea afectada de forma adversa",caracteristicasDefinitorias:[],factoresRelacionados:["Fotosensibilidad","Vasculitis cut\xe1nea","Corticoides"]},{codigo:"00051",nombre:"Deterioro de la comunicaci\xf3n verbal",definicion:"Disminuci\xf3n, retraso o ausencia de la capacidad para recibir, procesar, transmitir o usar un sistema de s\xedmbolos",caracteristicasDefinitorias:["Desorientaci\xf3n","Dificultad para expresarse","Comportamiento inapropiado"],factoresRelacionados:["Lupus neuropsiqui\xe1trico","Confusi\xf3n"]}],npiNic:[{codigo:"3584",nombre:"Cuidado de la piel: tratamiento t\xf3pico",actividades:["Instruir sobre el uso diario de fotoprotector SPF 50+ en zonas expuestas","Recomendar ropa protectora y evitar exposici\xf3n solar entre 10:00-17:00h","Evaluar lesiones cut\xe1neas (eritema malar, vasculitis, \xfalceras)","Ense\xf1ar cuidados de higiene oral para minimizar \xfalceras orales","Vigilar signos de infecci\xf3n en zonas de piel alterada"]},{codigo:"4120",nombre:"Manejo de l\xedquidos",actividades:["Monitorizar diuresis, edemas y PA en nefritis l\xfapica","Registrar peso diario para detectar retenci\xf3n h\xeddrica","Controlar proteinuria en orina de 24h o cociente alb\xfamina/creatinina","Restricci\xf3n de sodio y prote\xednas si hay nefritis activa y edemas","Verificar funci\xf3n renal antes de cada ciclo de inmunosupresor"]},{codigo:"5510",nombre:"Educaci\xf3n para la salud",actividades:["Educar sobre desencadenantes de brotes: sol, infecciones, estr\xe9s, ciertos f\xe1rmacos","Explicar la importancia de la fotoprotecci\xf3n permanente","Instruir sobre signos de brote que deben motivar consulta urgente","Educar sobre anticoncepci\xf3n segura (pildora con estr\xf3genos contraindicada en SAF)","Informar sobre la planificaci\xf3n del embarazo con el reumat\xf3logo"]}],npiNoc:[{codigo:"0702",nombre:"Estado inmune",indicadores:["SLEDAI en valores bajos","Complemento en rango normal","Anti-dsDNA en descenso","Proteinuria controlada"],escala:"SLEDAI <4 puntos (remisi\xf3n o baja actividad) con tratamiento mantenido"},{codigo:"1101",nombre:"Integridad tisular: piel y membranas mucosas",indicadores:["Ausencia de eritema malar activo","Sin \xfalceras orales","Sin vasculitis activa"],escala:"Resoluci\xf3n de las lesiones cut\xe1neas y mucosas en el brote en 4-8 semanas"}],complicaciones:["Nefritis l\xfapica con insuficiencia renal progresiva","S\xedndrome antifosfol\xedpido con trombosis o p\xe9rdidas fetales","Lupus neuropsiqui\xe1trico: psicosis, ictus, mielopat\xeda","Serositis grave: pericarditis constrictiva, pleures\xeda recurrente","Endocarditis de Libman-Sacks","Mayor riesgo cardiovascular (enfermedad coronaria prematura)","Infecciones graves por inmunosupresi\xf3n"],criteriosAlarma:["Brote de nefritis l\xfapica grave: hematuria macrosc\xf3pica, deterioro de funci\xf3n renal","Lupus neuropsiqui\xe1trico: convulsiones, psicosis, ictus","S\xedndrome antifosfol\xedpido asociado: trombosis arterial/venosa, p\xe9rdidas fetales","Pancitopenia grave (aplasia medular l\xfapica rara)","Hemorragia pulmonar alveolar (urgencia)"],emergencyLevel:"moderado",relatedPathologyIds:[],isPremium:!1},{id:"pat_anafilaxia",nombre:"Anafilaxia",bodySystemId:"inmunologico",definicion:"Reacci\xf3n al\xe9rgica sist\xe9mica grave, de inicio r\xe1pido, potencialmente mortal, mediada por IgE o no IgE (anafilactoide). Se produce por exposici\xf3n a al\xe9rgenos (alimentos, f\xe1rmacos, l\xe1tex, veneno de insectos) con liberaci\xf3n masiva de mediadores de mastocitos y bas\xf3filos. Requiere adrenalina intramuscular INMEDIATA.",epidemiologia:"",factoresRiesgo:[],fisiopatologia:"En la anafilaxia IgE-mediada, el al\xe9rgeno se une a IgE espec\xedfica unida a mastocitos y bas\xf3filos sensitizados. La bridging de receptores Fc-\u03b5RI desencadena degranulaci\xf3n con liberaci\xf3n masiva de histamina, triptasa, leucotrienos, prostaglandinas y PAF. Estos mediadores producen: vasodilataci\xf3n sist\xe9mica (hipotensi\xf3n), aumento de la permeabilidad vascular (angioedema, urticaria), broncoespasmo y aumento de secreciones. La histamina y leucotrienos producen la respuesta bif\xe1sica (recidiva 4-12h despu\xe9s de la aparici\xf3n inicial). El shock anafil\xe1ctico resulta de la redistribuci\xf3n del volumen intravascular y la vasodilataci\xf3n.",signosYSintomas:{signos:["Urticaria generalizada, angioedema","Broncoespasmo: sibilancias, disnea, estridor lar\xedngeo","Hipotensi\xf3n arterial, taquicardia","Edema de glotis: afon\xeda, estridor, disnea severa (compromete v\xeda a\xe9rea)","S\xedncope o p\xe9rdida de conciencia","Estridor lar\xedngeo (edema de glotis): inminente parada respiratoria","SatO2 <90% con broncoespasmo severo","TA sist\xf3lica <90 mmHg o ca\xedda >30% del basal (shock anafil\xe1ctico)","P\xe9rdida de conciencia","Paro cardiorrespiratorio por anafilaxia"],sintomas:["Prurito generalizado intenso","Eritema difuso","N\xe1useas, v\xf3mitos, dolor abdominal (histamina intestinal)","Rinitis, conjuntivitis","Sensaci\xf3n de muerte inminente","Cefalea puls\xe1til"]},diagnostico:{anamnesis:["Diagn\xf3stico cl\xednico: inicio agudo tras exposici\xf3n a al\xe9rgeno probable + afectaci\xf3n cut\xe1nea O mucosas + compromiso respiratorio O hipotensi\xf3n","Criterio 1: Inicio agudo con afectaci\xf3n cut\xe1nea/mucosa + compromiso respiratorio o hipotensi\xf3n","Criterio 2: Dos o m\xe1s de los siguientes tras exposici\xf3n probable: piel/mucosas, respiratorio, hipotensi\xf3n, s\xedntomas gastrointestinales","Criterio 3: Hipotensi\xf3n tras exposici\xf3n a al\xe9rgeno conocido"],examenFisico:[],pruebas:[{nombre:"Triptasa s\xe9rica (m\xe1stocitos): muestra en el momento agudo y a las 2h y 24h post-episodio",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Histamina plasm\xe1tica (valor limitado por vida media corta)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"IgE total y espec\xedfica al al\xe9rgeno sospechoso (estudio post-agudo)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Prick test e intradermorreacci\xf3n (pruebas cut\xe1neas de alergia, post-agudo)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Hemograma, bioqu\xedmica (acidosis en shock)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Gasometr\xeda arterial (hipoxemia, hipercapnia en broncoespasmo grave)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]}]},tratamientoMedico:{objetivos:[],farmacologico:[{nombre:"Adrenalina (Epinefrina)",grupo:"TRATAMIENTO DE PRIMERA",mecanismo:"TRATAMIENTO DE PRIMERA L\xcdNEA. Agonista adren\xe9rgico alfa y beta: vasoconstricci\xf3n alfa1 (revierte hipotensi\xf3n y angioedema), broncodilataci\xf3n beta2 (revierte broncoespasmo), efecto cronotr\xf3pico e inotr\xf3pico beta1 (aumenta gasto card\xedaco). Inhibe la liberaci\xf3n de mediadores de mastocitos",dosis:"ADULTOS: 0.5 mg (0.5 mL de la diluci\xf3n 1:1000) IM en cara anterolateral del muslo. NI\xd1OS: 0.01 mg/kg IM (m\xe1x 0.5 mg). Repetir cada 5-15 minutos si no mejora. IV: solo en shock o parada card\xedaca, 0.1 mg diluido en 10 mL de SF",cuidadosEnfermeria:["ADMINISTRAR INMEDIATAMENTE sin demora en el muslo (cara anterolateral) con auto-inyector o jeringa","No usar la v\xeda SC: la absorci\xf3n es m\xe1s lenta e impredecible que la IM","Administrar IM en muslo incluso sobre la ropa si es necesario (urgencia extrema)","Monitorizar ECG y PA continua tras la adrenalina IV","Preparar segunda dosis para posible reacci\xf3n bif\xe1sica","Colocar al paciente en dec\xfabito supino con piernas elevadas si hipotensi\xf3n (no sentar si disnea)"]},{nombre:"Difenhidramina",grupo:"Antihistam\xednico H1 que",mecanismo:"Antihistam\xednico H1 que bloquea los receptores de histamina, reduciendo urticaria, prurito y angioedema. COMPLEMENTO de la adrenalina, NUNCA sustituto. NO revierte el broncoespasmo ni la hipotensi\xf3n",dosis:"25-50 mg IV/IM lento. Repetir cada 4-6h si es necesario",cuidadosEnfermeria:["Siempre como COMPLEMENTO a la adrenalina, NUNCA como alternativa","Administrar IV lentamente (riesgo de hipotensi\xf3n si se da r\xe1pido)","Advertir sobre sedaci\xf3n (no conducir)","Vigilar retenci\xf3n urinaria en hombres con hipertrofia prost\xe1tica","Combinar con antihistam\xednico H2 (ranitidina 150 mg VO) para mayor eficacia"]},{nombre:"Metilprednisolona",grupo:"Glucocorticoide de acci\xf3n",mecanismo:"Glucocorticoide de acci\xf3n intermedia que inhibe la fase tard\xeda de la respuesta al\xe9rgica y reduce el riesgo de reacci\xf3n bif\xe1sica (recidiva de la anafilaxia 4-12h despu\xe9s). Inicio de acci\xf3n lento (4-6h), no \xfatil para la fase aguda",dosis:"1-2 mg/kg IV (hasta 125 mg). Seguir con prednisona oral 0.5-1 mg/kg/d\xeda \xd7 3-5 d\xedas",cuidadosEnfermeria:["Administrar DESPU\xc9S de la adrenalina (no como primera medida)","Monitorizar glucemia especialmente en diab\xe9ticos","Informar sobre posible insomnio con la pauta de corticoides orales","Asegurar que el paciente completa la pauta oral al alta para prevenir reacci\xf3n bif\xe1sica","No es sustituto de la adrenalina en el tratamiento agudo"]}],noFarmacologico:["Retirar el agente causal si es posible (parar infusi\xf3n IV, extraer aguij\xf3n de abeja)","Posici\xf3n: dec\xfabito supino con piernas elevadas si hipotensi\xf3n; semiincorporado si disnea severa","Ox\xedgeno a alto flujo (mascarilla con reservorio 10-15 L/min)","Acceso venoso perif\xe9rico (o IO si no es posible) e infusi\xf3n r\xe1pida de suero salino (500-1000 mL en bolus si hipotensi\xf3n)","Monitorizaci\xf3n continua: ECG, SatO2, PA","Intubaci\xf3n orotraqueal si edema de glotis con fracaso de adrenalina (cricotiroidotom\xeda si imposible intubaci\xf3n)","Alta con auto-inyector de adrenalina (EpiPen) y remisi\xf3n a alergia","Observaci\xf3n m\xednima 4-6h tras la reacci\xf3n (riesgo de recidiva bif\xe1sica)"]},cuidadosEnfermeria:{valoracion:["Valorar URGENTEMENTE: nivel de conciencia, v\xeda a\xe9rea, respiraci\xf3n, circulaci\xf3n (ABCs)","Monitorizar PA, FC, FR, SatO2 continuamente","Identificar el agente causal si es posible","Evaluar extensi\xf3n y gravedad de la urticaria/angioedema","Valorar grado de broncoespasmo (auscultar)","Identificar antecedentes de anafilaxia previa y medicaci\xf3n habitual"],intervenciones:["Administrar ADRENALINA 0.5 mg IM en muslo INMEDIATAMENTE (primera medida absoluta)","Llamar al equipo de emergencias (c\xf3digo de parada si hay p\xe9rdida de conciencia)","Retirar el agente causal (parar infusi\xf3n IV, retirar aguij\xf3n)","Colocar al paciente en posici\xf3n adecuada: supino + piernas elevadas si shock; semiincorporado si disnea","Administrar O2 alto flujo por mascarilla con reservorio","Canalizar v\xeda IV y comenzar suero fisiol\xf3gico en bolus","Mantener v\xeda a\xe9rea permeable: posici\xf3n correcta, aspiraci\xf3n si necesario","Preparar material de intubaci\xf3n orotraqueal y cricotiroidotom\xeda (edema de glotis refractario)","Monitorizar SatO2 continuamente","Administrar broncodilatador nebulizado (salbutamol 2.5-5 mg) si broncoespasmo persistente","Documentar evoluci\xf3n de la v\xeda a\xe9rea cada 5-15 minutos","Ense\xf1ar al alta el uso del auto-inyector de adrenalina (EpiPen)","Explicar c\xf3mo reconocer s\xedntomas de anafilaxia y actuar inmediatamente","Instruir sobre evitaci\xf3n del al\xe9rgeno identificado","Informar sobre la necesidad de observaci\xf3n 4-6h tras el episodio (bif\xe1sica)","Derivar a consulta de alergia para estudio definitivo y plan de acci\xf3n escrito"],educacionPaciente:["Ense\xf1ar a usar el auto-inyector de adrenalina (EpiPen): instrucci\xf3n pr\xe1ctica con device de entrenamiento","Explicar cu\xe1ndo usar el EpiPen: s\xedntomas de anafilaxia (no solo urticaria)","Instruir que despu\xe9s de usar el EpiPen SIEMPRE ir a urgencias (puede haber reacci\xf3n bif\xe1sica)","Ense\xf1ar a leer etiquetas de alimentos para identificar el al\xe9rgeno","Recomendar usar pulsera de alerta m\xe9dica (al\xe9rgico a XXX)","Explicar que debe llevar SIEMPRE el EpiPen (no solo en viajes)","Derivar a consulta de alergia para inmunoterapia si est\xe1 indicada"],monitorizacion:[]},npiNanda:[{codigo:"00033",nombre:"Deterioro de la ventilaci\xf3n espont\xe1nea",definicion:"Disminuci\xf3n de las reservas energ\xe9ticas que resulta en la incapacidad del individuo para mantener la respiraci\xf3n adecuada",caracteristicasDefinitorias:["Disnea severa","Estridor","Hipoxemia","SatO2 <90%"],factoresRelacionados:["Broncoespasmo grave","Edema de glotis","Angioedema lar\xedngeo"]},{codigo:"00029",nombre:"Disminuci\xf3n del gasto card\xedaco",definicion:"Cantidad de sangre bombeada por el coraz\xf3n en 1 minuto que es inadecuada para satisfacer las demandas metab\xf3licas del cuerpo",caracteristicasDefinitorias:["Hipotensi\xf3n","Taquicardia","Palidez","Diaforesis"],factoresRelacionados:["Vasodilataci\xf3n masiva","Hipovolemia relativa por extravasaci\xf3n"]},{codigo:"00004",nombre:"Riesgo de infecci\xf3n",definicion:"Riesgo de reacci\xf3n bif\xe1sica tard\xeda",caracteristicasDefinitorias:[],factoresRelacionados:["Reacci\xf3n anafil\xe1ctica con riesgo de recidiva"]}],npiNic:[{codigo:"6200",nombre:"Cuidados de urgencia",actividades:["Administrar ADRENALINA 0.5 mg IM en muslo INMEDIATAMENTE (primera medida absoluta)","Llamar al equipo de emergencias (c\xf3digo de parada si hay p\xe9rdida de conciencia)","Retirar el agente causal (parar infusi\xf3n IV, retirar aguij\xf3n)","Colocar al paciente en posici\xf3n adecuada: supino + piernas elevadas si shock; semiincorporado si disnea","Administrar O2 alto flujo por mascarilla con reservorio","Canalizar v\xeda IV y comenzar suero fisiol\xf3gico en bolus"]},{codigo:"3140",nombre:"Manejo de la v\xeda a\xe9rea",actividades:["Mantener v\xeda a\xe9rea permeable: posici\xf3n correcta, aspiraci\xf3n si necesario","Preparar material de intubaci\xf3n orotraqueal y cricotiroidotom\xeda (edema de glotis refractario)","Monitorizar SatO2 continuamente","Administrar broncodilatador nebulizado (salbutamol 2.5-5 mg) si broncoespasmo persistente","Documentar evoluci\xf3n de la v\xeda a\xe9rea cada 5-15 minutos"]},{codigo:"5510",nombre:"Educaci\xf3n para la salud",actividades:["Ense\xf1ar al alta el uso del auto-inyector de adrenalina (EpiPen)","Explicar c\xf3mo reconocer s\xedntomas de anafilaxia y actuar inmediatamente","Instruir sobre evitaci\xf3n del al\xe9rgeno identificado","Informar sobre la necesidad de observaci\xf3n 4-6h tras el episodio (bif\xe1sica)","Derivar a consulta de alergia para estudio definitivo y plan de acci\xf3n escrito"]}],npiNoc:[{codigo:"0402",nombre:"Estado respiratorio: intercambio gaseoso",indicadores:["SatO2 >95%","FR en rango normal","Ausencia de estridor y sibilancias"],escala:"Resoluci\xf3n del broncoespasmo y compromiso respiratorio en menos de 30 minutos con adrenalina"},{codigo:"0401",nombre:"Estado circulatorio",indicadores:["PA sist\xf3lica >90 mmHg","FC <100 lpm","Consciencia mantenida"],escala:"Estabilizaci\xf3n hemodin\xe1mica (PA >90 mmHg) en 15-30 minutos"}],complicaciones:["Parada cardiorrespiratoria","Edema de glotis con asfixia","Shock irreversible","Da\xf1o cerebral hip\xf3xico","Reacci\xf3n bif\xe1sica (recidiva 4-12h despu\xe9s)","Arritmias card\xedacas por hipoxia o adrenalina IV","Insuficiencia renal aguda por hipoperfusi\xf3n"],criteriosAlarma:["Estridor lar\xedngeo (edema de glotis): inminente parada respiratoria","SatO2 <90% con broncoespasmo severo","TA sist\xf3lica <90 mmHg o ca\xedda >30% del basal (shock anafil\xe1ctico)","P\xe9rdida de conciencia","Paro cardiorrespiratorio por anafilaxia"],emergencyLevel:"critico",relatedPathologyIds:[],isPremium:!1},{id:"pat_esclerosis_multiple",nombre:"Esclerosis M\xfaltiple",bodySystemId:"inmunologico",definicion:"Enfermedad autoinmune desmielinizante del sistema nervioso central caracterizada por la inflamaci\xf3n y destrucci\xf3n de la vaina de mielina en cerebro y m\xe9dula espinal. La forma m\xe1s frecuente es la recurrente-remitente (EMRR). Causa principal de discapacidad neurol\xf3gica en adultos j\xf3venes.",epidemiologia:"",factoresRiesgo:[],fisiopatologia:"Los linfocitos T autorreactivos (CD4+ Th1 y Th17) cruzan la barrera hematoencef\xe1lica, reconocen ant\xedgenos de mielina (MBP, PLP, MOG) y desencadenan una respuesta inflamatoria con activaci\xf3n de macr\xf3fagos y microgl\xeda. La desmielinizaci\xf3n destruye la vaina de mielina, que permite la conducci\xf3n saltatoria del impulso nervioso. La p\xe9rdida de mielina produce bloqueo de conducci\xf3n (s\xedntomas agudos del brote). Si la inflamaci\xf3n se resuelve, la remielinizaci\xf3n parcial puede restaurar la funci\xf3n (remisi\xf3n). Con el tiempo, la degeneraci\xf3n axonal acumulada lleva a discapacidad progresiva irreversible.",signosYSintomas:{signos:["Neuritis \xf3ptica: p\xe9rdida visual monocular, dolor retroocular al mover el ojo","S\xedntomas de disfunci\xf3n del tronco encef\xe1lico: diplop\xeda, disartria, v\xe9rtigo","S\xedndrome piramidal: espasticidad, hiperreflexia, signo de Babinski","S\xedndrome cerebeloso: ataxia, dismetr\xeda, temblor de intenci\xf3n","S\xedntomas medulares: parestesias, paraparesia, disfunci\xf3n vesical","Brote grave con paraplejia o p\xe9rdida visual severa (requiere metilprednisolona IV urgente)","Disfagia y alteraci\xf3n del nivel de conciencia (brote de tronco severo)","Fiebre + empeoramiento neurol\xf3gico (pseudobrote por infecci\xf3n: tratar infecci\xf3n, no corticoides)","Progresi\xf3n r\xe1pida de la discapacidad"],sintomas:["Fatiga (s\xedntoma m\xe1s frecuente e incapacitante)","Trastornos cognitivos: memoria, concentraci\xf3n","Dolor neurop\xe1tico","Depresi\xf3n y ansiedad","Disfunci\xf3n sexual","Fen\xf3meno de Uhthoff (empeoramiento con el calor o fiebre)","Signo de Lhermitte (corriente el\xe9ctrica por la espalda al flexionar el cuello)"]},diagnostico:{anamnesis:["Criterios de McDonald 2017: diseminaci\xf3n en espacio (DIS) y diseminaci\xf3n en tiempo (DIT)","RMN cerebral y medular: lesiones desmielinizantes en sustancia blanca (periventriculares, yuxtacorticales, infratentoriales, medulares)","Bandas oligoclonales en LCR (90-95% de los casos)","Potenciales evocados: prolongaci\xf3n de la latencia (desmielinizaci\xf3n subcl\xednica)"],examenFisico:[],pruebas:[{nombre:"RMN cerebral con gadolinio (lesiones captantes = activas, T2/FLAIR = totales)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"RMN medular (lesiones medulares en brotes)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Punci\xf3n lumbar: bandas oligoclonales IgG, \xedndice IgG elevado",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Potenciales evocados visuales, auditivos y somatosensitivos",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Anticuerpos anti-MOG y anti-AQP4 (NMOSD: espectro de neuromielitis \xf3ptica, diferente a EM)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Hemograma, bioqu\xedmica, vitamina B12, funci\xf3n tiroidea (descartar otras causas)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]}]},tratamientoMedico:{objetivos:[],farmacologico:[{nombre:"Metilprednisolona IV (tratamiento del brote)",grupo:"Glucocorticoide que reduce",mecanismo:"Glucocorticoide que reduce r\xe1pidamente la inflamaci\xf3n en las lesiones activas de EM, acelerando la recuperaci\xf3n del brote. NO cambia el curso de la enfermedad a largo plazo ni previene nuevos brotes",dosis:"1 g/d\xeda IV en 3-5 d\xedas consecutivos (500 mg-2 g/d\xeda seg\xfan protocolo). No requiere reducci\xf3n gradual posterior en la mayor\xeda de los casos",cuidadosEnfermeria:["Administrar por las ma\xf1anas para reducir el insomnio nocturno","Monitorizar glucemia especialmente en diab\xe9ticos","Infundir en 1-2 horas (dosis de 1 g en 250-500 mL SF en 1h)","Vigilar PA y FC durante la infusi\xf3n","Controlar potasio s\xe9rico (hipopotasemia con pulsos de corticoides)","Tratar el pseudobrote por infecci\xf3n con antibi\xf3ticos, NO con corticoides"]},{nombre:"Natalizumab",grupo:"Anticuerpo monoclonal anti-alfa4-integrina",mecanismo:"Anticuerpo monoclonal anti-alfa4-integrina que impide la migraci\xf3n de linfocitos T desde la sangre al SNC, bloqueando la transmigraci\xf3n a trav\xe9s de la barrera hematoencef\xe1lica. Alta eficacia en EMRR activa",dosis:"300 mg IV en infusi\xf3n de 1h cada 4 semanas",cuidadosEnfermeria:["Verificar anticuerpos anti-JC antes de cada a\xf1o (riesgo de LMP si anti-JC+ y >24 meses de tratamiento)","Observar al paciente 1 hora post-infusi\xf3n por reacciones infusionales","Vigilar s\xedntomas neurol\xf3gicos nuevos o inusuales (posible LMP: d\xe9ficit cognitivo progresivo, hemiparesia)","NO usar si hay inmunosupresores concomitantes (aumenta riesgo de LMP)","En caso de suspensi\xf3n: monitorizar recurrencia de actividad (s\xedndrome de rebote)"]},{nombre:"Fumarato de Dimetilo",grupo:"Activa la v\xeda",mecanismo:"Activa la v\xeda Nrf2 que regula la respuesta antioxidante y tiene efectos inmunomoduladores. Reduce la inflamaci\xf3n y puede tener propiedades neuroprotectoras. F\xe1rmaco oral de eficacia moderada-alta",dosis:"120 mg VO 2 veces/d\xeda \xd7 7 d\xedas (dosis inicial). Luego 240 mg VO 2 veces/d\xeda (mantenimiento). Tomar con alimentos para reducir rubor",cuidadosEnfermeria:["Tomar siempre con alimentos (reduce rubor y GI)","Tomar 325 mg de aspirina 30 min antes mejora el rubor","Informar que el rubor es temporal y suele mejorar en 4-6 semanas","Monitorizar hemograma con linfocitos cada 3-6 meses","Suspender si linfocitos <0.5 \xd7 10^9/L prolongados (riesgo de LMP)"]}],noFarmacologico:["Fisioterapia neurol\xf3gica: ejercicios de equilibrio, fuerza, coordinaci\xf3n","Logopedia: disfagia, disartria","Terapia ocupacional: adaptaci\xf3n de actividades y entorno","Manejo de espasticidad: fisioterapia, baclofeno oral o intratecal","Rehabilitaci\xf3n vesical (cateterismo intermitente limpio si retenci\xf3n urinaria)","Evitar calor excesivo (fen\xf3meno de Uhthoff)","Apoyo psicol\xf3gico y grupos de apoyo"]},cuidadosEnfermeria:{valoracion:["Evaluar funci\xf3n neurol\xf3gica con EDSS (Escala de Discapacidad de Kurtzke)","Valorar fatiga con escala FSS (Fatigue Severity Scale)","Evaluar funci\xf3n vesical: frecuencia, urgencia, incontinencia, retenci\xf3n","Valorar espasticidad y dolor neurop\xe1tico","Evaluar estado emocional: depresi\xf3n (muy frecuente en EM)","Revisar adherencia al tratamiento modificador de la enfermedad (TME)","Evaluar riesgo de ca\xeddas (ataxia, espasticidad, debilidad)"],intervenciones:["Ense\xf1ar t\xe9cnicas de ahorro de energ\xeda: planificar actividades importantes en horas de mayor energ\xeda","Distribuir las actividades a lo largo del d\xeda con per\xedodos de descanso","Evitar el calor excesivo (fen\xf3meno de Uhthoff: ba\xf1o fr\xedo si empeoramiento por calor)","Fomentar el sue\xf1o de calidad (valorar trastornos del sue\xf1o)","Evaluar la fatiga con FSS en cada visita","Evaluar el tipo de disfunci\xf3n vesical (vejiga esp\xe1stica vs. fl\xe1ccida)","Ense\xf1ar cateterismo intermitente limpio (CIL) si hay retenci\xf3n urinaria","Programar micciones regulares cada 2-3h para vejiga esp\xe1stica","Vigilar infecciones urinarias (alta prevalencia en EM)","Coordinar con urolog\xeda para urodinamia si disfunci\xf3n grave","Evaluar depresi\xf3n y ansiedad en cada visita (prevalencia >50% en EM)","Derivar a psicolog\xeda o psiquiatr\xeda si hay depresi\xf3n moderada-grave","Conectar con grupos de apoyo de EM (asociaciones de pacientes)","Implicar a la familia en el proceso de adaptaci\xf3n","Abordar el impacto de la enfermedad en la vida laboral, sexual y social"],educacionPaciente:["Explicar el curso de la enfermedad (brotes y remisiones) y la importancia del TME para prevenir brotes","Ense\xf1ar a reconocer s\xedntomas de brote y cu\xe1ndo acudir (inicio de s\xedntomas nuevos o empeoramiento >24h)","Instruir sobre el fen\xf3meno de Uhthoff: refrescar el cuerpo para manejar empeoramiento por calor","Educar sobre t\xe9cnica de cateterismo intermitente limpio si hay disfunci\xf3n vesical","Recomendar ejercicio f\xedsico adaptado (nataci\xf3n, yoga, fisioterapia)","Informar sobre los recursos de la Asociaci\xf3n de EM para apoyo y rehabilitaci\xf3n"],monitorizacion:[]},npiNanda:[{codigo:"00085",nombre:"Deterioro de la movilidad f\xedsica",definicion:"Limitaci\xf3n del movimiento f\xedsico independiente e intencionado del cuerpo",caracteristicasDefinitorias:["Limitaci\xf3n de la marcha","Inestabilidad postural","Incapacidad para realizar AVD"],factoresRelacionados:["Espasticidad","Ataxia cerebelosa","Debilidad por desmielinizaci\xf3n","Fatiga"]},{codigo:"00093",nombre:"Fatiga",definicion:"Sensaci\xf3n abrumadora y sostenida de agotamiento",caracteristicasDefinitorias:["FSS >36","Agotamiento desproporcionado al esfuerzo","Empeoramiento con el calor"],factoresRelacionados:["Desmielinizaci\xf3n","Trastorno del sue\xf1o","Depresi\xf3n asociada"]},{codigo:"00016",nombre:"Deterioro de la eliminaci\xf3n urinaria",definicion:"Disfunci\xf3n en la eliminaci\xf3n urinaria",caracteristicasDefinitorias:["Urgencia miccional","Incontinencia urinaria","Retenci\xf3n urinaria"],factoresRelacionados:["Lesiones medulares desmielinizantes","Vejiga neur\xf3gena"]}],npiNic:[{codigo:"0180",nombre:"Manejo de la energ\xeda",actividades:["Ense\xf1ar t\xe9cnicas de ahorro de energ\xeda: planificar actividades importantes en horas de mayor energ\xeda","Distribuir las actividades a lo largo del d\xeda con per\xedodos de descanso","Evitar el calor excesivo (fen\xf3meno de Uhthoff: ba\xf1o fr\xedo si empeoramiento por calor)","Fomentar el sue\xf1o de calidad (valorar trastornos del sue\xf1o)","Evaluar la fatiga con FSS en cada visita"]},{codigo:"0590",nombre:"Manejo de la eliminaci\xf3n urinaria",actividades:["Evaluar el tipo de disfunci\xf3n vesical (vejiga esp\xe1stica vs. fl\xe1ccida)","Ense\xf1ar cateterismo intermitente limpio (CIL) si hay retenci\xf3n urinaria","Programar micciones regulares cada 2-3h para vejiga esp\xe1stica","Vigilar infecciones urinarias (alta prevalencia en EM)","Coordinar con urolog\xeda para urodinamia si disfunci\xf3n grave"]},{codigo:"5270",nombre:"Apoyo emocional",actividades:["Evaluar depresi\xf3n y ansiedad en cada visita (prevalencia >50% en EM)","Derivar a psicolog\xeda o psiquiatr\xeda si hay depresi\xf3n moderada-grave","Conectar con grupos de apoyo de EM (asociaciones de pacientes)","Implicar a la familia en el proceso de adaptaci\xf3n","Abordar el impacto de la enfermedad en la vida laboral, sexual y social"]}],npiNoc:[{codigo:"0208",nombre:"Movilidad",indicadores:["Mantenimiento de la marcha","Equilibrio","Traslados seguros"],escala:"Mantenimiento de la capacidad de marcha (EDSS <6) con rehabilitaci\xf3n y TME"},{codigo:"0300",nombre:"Autocuidados: actividades de la vida diaria (AVD)",indicadores:["Alimentaci\xf3n independiente","Higiene personal","Vestido"],escala:"Mantenimiento de la autonom\xeda en AVD b\xe1sicas con adaptaciones"}],complicaciones:["Discapacidad neurol\xf3gica progresiva (conversi\xf3n a EMSP: secundaria progresiva)","Infecciones urinarias recurrentes (vejiga neur\xf3gena)","\xdalceras por presi\xf3n (discapacidad avanzada)","Depresi\xf3n y suicidio (riesgo aumentado en EM)","Leucoencefalopat\xeda multifocal progresiva (LMP) por natalizumab","Disfagia con aspiraci\xf3n (brotes de tronco)","Dependencia funcional completa en EM progresiva avanzada"],criteriosAlarma:["Brote grave con paraplejia o p\xe9rdida visual severa (requiere metilprednisolona IV urgente)","Disfagia y alteraci\xf3n del nivel de conciencia (brote de tronco severo)","Fiebre + empeoramiento neurol\xf3gico (pseudobrote por infecci\xf3n: tratar infecci\xf3n, no corticoides)","Progresi\xf3n r\xe1pida de la discapacidad"],emergencyLevel:"moderado",relatedPathologyIds:[],isPremium:!0},{id:"pat_sindrome_sjogren",nombre:"S\xedndrome de Sj\xf6gren",bodySystemId:"inmunologico",definicion:"Enfermedad autoinmune sist\xe9mica caracterizada por la infiltraci\xf3n linfocitaria de las gl\xe1ndulas exocrinas (salivales y lagrimales), causando xerostom\xeda y xeroftalmia (s\xedndrome seco). Puede ser primario o secundario a otras enfermedades autoinmunes (AR, LES).",epidemiologia:"",factoresRiesgo:[],fisiopatologia:"Los linfocitos T CD4+ (y B) infiltran las gl\xe1ndulas exocrinas, liberando citocinas (IFN-gamma, TNF) que da\xf1an el par\xe9nquima glandular y reducen la secreci\xf3n de saliva y l\xe1grimas. Los autoanticuerpos anti-Ro (SS-A) y anti-La (SS-B) son marcadores serol\xf3gicos caracter\xedsticos. La xerostom\xeda facilita caries dental y candidiasis oral. La xeroftalmia causa queratoconjuntivitis seca con da\xf1o corneal. La afectaci\xf3n extraglandular incluye artritis, neuropat\xeda perif\xe9rica, vasculitis cut\xe1nea, y en casos graves: linfoma MALT.",signosYSintomas:{signos:["Xerostom\xeda: boca seca, dificultad para masticar y hablar, necesidad de beber agua frecuentemente","Xeroftalmia (queratoconjuntivitis seca): ojos secos, sensaci\xf3n de arenilla, lagrimeo parad\xf3jico","Parotidomegalia recurrente","Artralgia/artritis no erosiva","Fatiga intensa","Crioglobulinemia con vasculitis sist\xe9mica","Linfoma MALT (transformaci\xf3n maligna, riesgo 5-10% en Sj\xf6gren primario)","Mielitis transversa o neuritis \xf3ptica (afectaci\xf3n del SNC)","Afectaci\xf3n pulmonar intersticial","Lupus neonatal si anti-Ro positivo en embarazada (bloqueo card\xedaco fetal)"],sintomas:["Sequedad nasal, traqueal, vaginal","Disfagia (falta de saliva)","Neuropat\xeda perif\xe9rica: adormecimiento en manos y pies","Vasculitis cut\xe1nea: purpura palpable","Fen\xf3meno de Raynaud","Acidosis tubular renal (afectaci\xf3n renal)","Caries dental masiva y precoz"]},diagnostico:{anamnesis:["Criterios ACR/EULAR 2016: puntuaci\xf3n \u22654","Biopsia de gl\xe1ndula salival menor: infiltrado linfoc\xedtico focal \u22651 foco/4 mm2 (3 pts)","Anti-Ro/SSA positivo (3 pts)","Tinci\xf3n de rosa de Bengala o fluoresce\xedna: queratoconjuntivitis seca (1 pt)","Flujo salival: <0.1 mL/min en reposo (1 pt)","Test de Schirmer: <5 mm en 5 min (1 pt)"],examenFisico:[],pruebas:[{nombre:"ANA, anti-Ro (SSA) y anti-La (SSB)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Factor reumatoide (positivo en 50-75%)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Electroforesis de prote\xednas: hipergammaglobulinemia",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Hemograma: leucopenia, anemia normoc\xedtica",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Crioglobulinas (si vasculitis)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Test de Schirmer (l\xe1grimas) y flujo salival basal",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Sialometr\xeda y ecograf\xeda de gl\xe1ndulas salivales",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Biopsia de gl\xe1ndula salival menor (labio inferior)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Funci\xf3n renal (afectaci\xf3n tubular)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Electromiograf\xeda si sospecha de neuropat\xeda",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]}]},tratamientoMedico:{objetivos:[],farmacologico:[{nombre:"L\xe1grimas Artificiales (Hialuronato de Sodio)",grupo:"Sustituto de la",mecanismo:"Sustituto de la pel\xedcula lagrimal que lubrica la superficie ocular, reduce la fricci\xf3n corneal y alivia los s\xedntomas de la queratoconjuntivitis seca. El hialuronato de sodio tiene propiedades viscoel\xe1sticas que retienen la humedad m\xe1s tiempo",dosis:"1-2 gotas en cada ojo 4-8 veces al d\xeda seg\xfan s\xedntomas. Sin conservantes si se usan >4 veces/d\xeda",cuidadosEnfermeria:["Recomendar colirios sin conservantes si uso >4 veces/d\xeda (benzalconio da\xf1a la c\xf3rnea)","Ense\xf1ar t\xe9cnica correcta de instilaci\xf3n: tirar del p\xe1rpado inferior, mirar hacia arriba","No tocar la punta del frasco para evitar contaminaci\xf3n","Recomendar gafas de sol o c\xe1maras h\xfamedas en ambientes secos o con viento","Indicar que humidificadores en casa mejoran el ambiente"]},{nombre:"Pilocarpina",grupo:"Agonista colin\xe9rgico musca\u0155\xednico",mecanismo:"Agonista colin\xe9rgico musca\u0155\xednico (M1, M3) que estimula la secreci\xf3n de gl\xe1ndulas exocrinas (saliva, l\xe1grimas), mejorando la xerostom\xeda y xeroftalmia en pacientes con funci\xf3n glandular residual",dosis:"5 mg VO 3-4 veces al d\xeda con alimentos. Inicio de efecto: 20-60 min. Duraci\xf3n: 2-4h",cuidadosEnfermeria:["Advertir sobre la sudoraci\xf3n (es el efecto farmacol\xf3gico esperado)","Contraindicado en glaucoma de \xe1ngulo cerrado, asma activa, cardiopat\xeda con alteraciones de la conducci\xf3n","Evaluar eficacia: preguntrar sobre mejor\xeda de sequedad oral y ocular","Vigilar s\xedntomas colin\xe9rgicos excesivos: bradicardia, hipotensi\xf3n, broncoespasmo","Tomar con alimentos para reducir n\xe1useas"]},{nombre:"Hidroxicloroquina",grupo:"Antipal\xfadico con propiedades",mecanismo:"Antipal\xfadico con propiedades inmunomoduladoras (ver LES). En Sj\xf6gren mejora las artralgias, la fatiga y puede reducir la actividad inmune. Evidencia moderada para s\xedntomas sist\xe9micos",dosis:"200-400 mg/d\xeda VO (m\xe1x 5 mg/kg/d\xeda de peso ideal)",cuidadosEnfermeria:["Control oftalmol\xf3gico anual tras 5 a\xf1os de tratamiento (OCT)","Verificar ECG en pacientes con cardiopat\xeda de base","Informar sobre inicio lento de acci\xf3n (6-12 semanas para ver efecto en s\xedntomas sist\xe9micos)","No suspender sin consultar al m\xe9dico (reca\xedda de s\xedntomas sist\xe9micos)"]}],noFarmacologico:["Higiene dental estricta: cepillado despu\xe9s de cada comida, fluoruro t\xf3pico, revisiones frecuentes","Estimulaci\xf3n de la salivaci\xf3n: chicles o caramelos sin az\xfacar (xilitol), agua frecuente","Humidificaci\xf3n del ambiente dom\xe9stico","Lubricantes vaginales para sequedad vaginal","Evitar f\xe1rmacos que causan sequedad: anticolin\xe9rgicos, antihistam\xednicos sedantes, antidepresivos tric\xedclicos","Protecci\xf3n ocular: gafas de sol, evitar ambiente con aire acondicionado fuerte"]},cuidadosEnfermeria:{valoracion:["Evaluar grado de xerostom\xeda y xeroftalmia (escalas ESSPRI)","Inspeccionar cavidad oral: caries, candidiasis, sequedad de mucosas","Valorar queratoconjuntivitis (enrojecimiento, sensaci\xf3n de cuerpo extra\xf1o, lagrimeo)","Evaluar artralgia y fatiga","Revisar anticuerpos anti-Ro/La y funci\xf3n renal","Valorar s\xedntomas de afectaci\xf3n extraglandular: neuropat\xeda, vasculitis","Evaluar higiene dental e impacto de la sequedad"],intervenciones:["Instruir sobre higiene dental meticulosa: cepillado con pasta fluorada despu\xe9s de cada comida","Recomendar enjuagues con fl\xfaor t\xf3pico diarios","Recomendar revisiones dentales cada 3-4 meses (caries acelerada en Sj\xf6gren)","Informar sobre el uso de chicles de xilitol sin az\xfacar para estimular la salivaci\xf3n","Vigilar signos de candidiasis oral (placa blanquecina, ardor) \u2192 tratar con nistatina","Ense\xf1ar la t\xe9cnica correcta de instilaci\xf3n de l\xe1grimas artificiales","Recomendar el uso de gafas de sol con protecci\xf3n lateral","Indicar el uso de humidificadores en casa","Remitir a oftalmolog\xeda para valoraci\xf3n de tapones lagrimales si s\xedntomas graves","Vigilar signos de ulceraci\xf3n corneal (dolor intenso, fotofobia, p\xe9rdida visual: urgencia oftalmol\xf3gica)","Educar sobre los s\xedntomas de alarma de linfoma (aumento r\xe1pido de par\xf3tida, adenopat\xedas)","Informar sobre la importancia del seguimiento por reumatolog\xeda y oftalmolog\xeda","Explicar el riesgo de lupus neonatal en embarazadas con anti-Ro positivo","Recomendar evitar f\xe1rmacos que agravan la sequedad","Ense\xf1ar autocuidados para la sequedad vaginal si procede (lubricantes)"],educacionPaciente:["Explicar la naturaleza cr\xf3nica del Sj\xf6gren y la importancia del seguimiento peri\xf3dico","Enfatizar la higiene dental estricta para prevenir caries acelerada","Ense\xf1ar t\xe9cnica de instilaci\xf3n de colirios y cu\xe1ndo usar cada tipo","Informar sobre las medidas de hidrataci\xf3n: agua frecuente, humidificadores, chicles de xilitol","Educar sobre s\xedntomas de linfoma (adenopat\xedas que crecen r\xe1pido) y cu\xe1ndo consultar urgente","Advertir a mujeres en edad f\xe9rtil con anti-Ro sobre el riesgo de lupus neonatal (bloqueo card\xedaco)"],monitorizacion:[]},npiNanda:[{codigo:"00048",nombre:"Deterioro de la dentici\xf3n",definicion:"Alteraci\xf3n en los dientes y estructuras de soporte",caracteristicasDefinitorias:["Caries m\xfaltiples","P\xe9rdida de esmalte","Dolor dental"],factoresRelacionados:["Xerostom\xeda (falta de efecto tamponador y antibacteriano de la saliva)","Enfermedad cr\xf3nica"]},{codigo:"00093",nombre:"Fatiga",definicion:"Sensaci\xf3n abrumadora y sostenida de agotamiento",caracteristicasDefinitorias:["Agotamiento cr\xf3nico","Incapacidad para actividades habituales"],factoresRelacionados:["Enfermedad autoinmune cr\xf3nica","Anemia","Dolor cr\xf3nico"]},{codigo:"00047",nombre:"Riesgo de deterioro de la integridad cut\xe1nea",definicion:"Riesgo de que la piel sea afectada adversamente",caracteristicasDefinitorias:[],factoresRelacionados:["Vasculitis cut\xe1nea","Sequedad de piel y mucosas"]}],npiNic:[{codigo:"1710",nombre:"Mantenimiento de la salud bucal",actividades:["Instruir sobre higiene dental meticulosa: cepillado con pasta fluorada despu\xe9s de cada comida","Recomendar enjuagues con fl\xfaor t\xf3pico diarios","Recomendar revisiones dentales cada 3-4 meses (caries acelerada en Sj\xf6gren)","Informar sobre el uso de chicles de xilitol sin az\xfacar para estimular la salivaci\xf3n","Vigilar signos de candidiasis oral (placa blanquecina, ardor) \u2192 tratar con nistatina"]},{codigo:"1680",nombre:"Mantenimiento de los ojos",actividades:["Ense\xf1ar la t\xe9cnica correcta de instilaci\xf3n de l\xe1grimas artificiales","Recomendar el uso de gafas de sol con protecci\xf3n lateral","Indicar el uso de humidificadores en casa","Remitir a oftalmolog\xeda para valoraci\xf3n de tapones lagrimales si s\xedntomas graves","Vigilar signos de ulceraci\xf3n corneal (dolor intenso, fotofobia, p\xe9rdida visual: urgencia oftalmol\xf3gica)"]},{codigo:"5510",nombre:"Educaci\xf3n para la salud",actividades:["Educar sobre los s\xedntomas de alarma de linfoma (aumento r\xe1pido de par\xf3tida, adenopat\xedas)","Informar sobre la importancia del seguimiento por reumatolog\xeda y oftalmolog\xeda","Explicar el riesgo de lupus neonatal en embarazadas con anti-Ro positivo","Recomendar evitar f\xe1rmacos que agravan la sequedad","Ense\xf1ar autocuidados para la sequedad vaginal si procede (lubricantes)"]}],npiNoc:[{codigo:"1101",nombre:"Integridad tisular: piel y membranas mucosas",indicadores:["Mucosa oral h\xfameda","Ausencia de caries activas","C\xf3rnea sin ulceraciones"],escala:"Mantenimiento de la integridad de mucosas con tratamiento sustitutivo y medidas preventivas"},{codigo:"1008",nombre:"Estado nutricional: ingesti\xf3n alimentaria y de l\xedquidos",indicadores:["Ingesta h\xeddrica adecuada","Alimentaci\xf3n sin dificultad para masticar/tragar","Peso estable"],escala:"Mantener ingesta nutricional adecuada a pesar de la xerostom\xeda con estrategias adaptadas"}],complicaciones:["Caries dental masiva y p\xe9rdida de piezas dentales","Queratoconjuntivitis grave con ulceraci\xf3n corneal","Linfoma MALT (5-10% de Sj\xf6gren primario a largo plazo)","Crioglobulinemia con vasculitis","Neuropat\xeda perif\xe9rica dolorosa","Lupus neonatal con bloqueo aur\xedculo-ventricular en hijo de madre anti-Ro+","Afectaci\xf3n pulmonar intersticial"],criteriosAlarma:["Crioglobulinemia con vasculitis sist\xe9mica","Linfoma MALT (transformaci\xf3n maligna, riesgo 5-10% en Sj\xf6gren primario)","Mielitis transversa o neuritis \xf3ptica (afectaci\xf3n del SNC)","Afectaci\xf3n pulmonar intersticial","Lupus neonatal si anti-Ro positivo en embarazada (bloqueo card\xedaco fetal)"],emergencyLevel:"leve",relatedPathologyIds:[],isPremium:!0},{id:"pat_upp",nombre:"\xdalceras Por Presi\xf3n (UPP)",bodySystemId:"tegumentario",definicion:"Lesi\xf3n localizada en la piel y/o tejido subyacente, generalmente sobre una prominencia \xf3sea, resultado de la presi\xf3n o de la presi\xf3n en combinaci\xf3n con la cizalla. Indicador de calidad asistencial en enfermer\xeda. Clasificadas en estadios I-IV por NPUAP/EPUAP.",epidemiologia:"",factoresRiesgo:[],fisiopatologia:"La presi\xf3n sostenida sobre los tejidos supera la presi\xf3n de perfusi\xf3n capilar (32 mmHg), generando isquemia tisular. La oclusi\xf3n de capilares reduce el aporte de ox\xedgeno y nutrientes, provocando acidosis local, acumulaci\xf3n de metabolitos y muerte celular. La cizalla (fuerzas paralelas a la superficie cut\xe1nea) estira y desgarra los vasos sangu\xedneos. La humedad macerada la piel, reduciendo su resistencia. El estadio I (eritema no blanqueable) refleja isquemia reversible; el IV implica necrosis que afecta a m\xfasculo, tend\xf3n y hueso. La necrosis isqu\xe9mica puede progresar desde capas profundas a la superficie (UPP de tejido profundo).",signosYSintomas:{signos:["Estadio I: eritema no blanqueable en piel intacta sobre prominencia \xf3sea","Estadio II: p\xe9rdida parcial del espesor de la piel (epidermis, dermis). \xdalcera superficial o ampolla","Estadio III: p\xe9rdida total del espesor de la piel con afectaci\xf3n del tejido subcut\xe1neo","Estadio IV: p\xe9rdida total del espesor de la piel con exposici\xf3n de m\xfasculo, hueso o tend\xf3n","Dolor local o sensaci\xf3n de ardor en las primeras fases","Signos de infecci\xf3n: eritema perilesional, calor, exudado purulento con olor f\xe9tido","Osteomielitis subyacente (UPP que no cicatriza sobre prominencia \xf3sea)","Sepsis con foco en UPP infectada","Celulitis extensiva alrededor de la \xfalcera","UPP estadio IV con afectaci\xf3n \xf3sea (requiere cirug\xeda)"],sintomas:["Exudado seroso o purulento (infecci\xf3n)","Necrosis seca (escara negra) o h\xfameda","Piel perilesional macerada o eritematosa","F\xedstulas y cavitaciones en estadios avanzados","S\xedntomas sist\xe9micos en infecci\xf3n profunda: fiebre, leucocitosis"]},diagnostico:{anamnesis:["Diagn\xf3stico cl\xednico por inspecci\xf3n y palpaci\xf3n","Clasificaci\xf3n NPUAP/EPUAP 2019: estadios I-IV + lesi\xf3n de tejido profundo sospechada + inclasificable","Herramienta TIME para valoraci\xf3n de la herida: Tissue (tejido), Infection, Moisture, Edge (bordes)"],examenFisico:[],pruebas:[{nombre:"Cultivo de herida (biopsia de tejido es gold standard, hisopo si no disponible)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Hemograma, PCR, VSG (signos de infecci\xf3n sist\xe9mica)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Hemocultivos si fiebre (sepsis con foco en UPP)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Radiograf\xeda \xf3sea (si sospecha osteomielitis)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"RMN de partes blandas (osteomielitis, absceso profundo)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Alb\xfamina, prealb\xfamina (estado nutricional)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Glucemia (diabetes como factor de riesgo)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"\xcdndice tobillo-brazo (isquemia arterial como causa)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]}]},tratamientoMedico:{objetivos:[],farmacologico:[{nombre:"Hidrogel (Ap\xf3sito de Hidrogel)",grupo:"Aporte de humedad",mecanismo:"Aporte de humedad al lecho de la herida facilitando el desbridamiento autol\xedtico de tejido necr\xf3tico y promoviendo la granulaci\xf3n. El ambiente h\xfamedo acelera la cicatrizaci\xf3n y reduce el dolor",dosis:"Aplicar en el lecho de la herida y cubrir con ap\xf3sito secundario absorbente. Cambiar seg\xfan saturaci\xf3n (cada 1-3 d\xedas). Evitar en heridas con exudado abundante",cuidadosEnfermeria:["Proteger la piel perilesional con pasta de \xf3xido de zinc o film transparente antes de aplicar","No aplicar sobre piel intacta (solo en el lecho de la herida)","Verificar que el hidrogel no se sale de los bordes de la herida (macera la piel sana)","Documentar dimensiones de la herida (largo, ancho, profundidad) en cada cura","Contraindicado en heridas infectadas sin cobertura antibi\xf3tica local/sist\xe9mica"]},{nombre:"Ap\xf3sito de Espuma (Foam)",grupo:"Ap\xf3sito absorbente que",mecanismo:"Ap\xf3sito absorbente que gestiona el exudado moderado-abundante manteniendo el ambiente h\xfamedo \xf3ptimo para la cicatrizaci\xf3n. La espuma de poliuretano protege mec\xe1nicamente el lecho de la herida",dosis:"Cambiar cada 3-7 d\xedas seg\xfan saturaci\xf3n de exudado. Disponibles con y sin silicona (los de silicona son m\xe1s atraum\xe1ticos al retirar)",cuidadosEnfermeria:["Elegir el tama\xf1o adecuado (debe superar 2 cm el margen de la herida)","Retirar con suavidad para no traumatizar el tejido de granulaci\xf3n","Documentar caracter\xedsticas del exudado: color, consistencia, cantidad, olor","Cambiar si el ap\xf3sito est\xe1 saturado o hay exudado visible en los bordes","Los ap\xf3sitos de foam con silicona son menos traum\xe1ticos en pieles fr\xe1giles (ancianos)"]},{nombre:"Clindamicina T\xf3pica / Antibi\xf3tico Local",grupo:"Antibi\xf3tico bacteriost\xe1tico (inhibidor",mecanismo:"Antibi\xf3tico bacteriost\xe1tico (inhibidor de la s\xedntesis proteica bacteriana) para uso t\xf3pico en heridas con signos de infecci\xf3n local (carga bacteriana elevada sin celulitis). No sustituye a la antisepsia correcta",dosis:"Aplicar en el lecho de la herida seg\xfan indicaci\xf3n m\xe9dica. M\xe1ximo 2 semanas para evitar resistencias",cuidadosEnfermeria:["No usar antibi\xf3ticos t\xf3picos de forma rutinaria (selecci\xf3n de resistencias)","Indicado solo si la herida tiene signos de infecci\xf3n local: eritema, exudado purulento, olor","Limitar el uso a 2 semanas","Si celulitis o infecci\xf3n sist\xe9mica: antibi\xf3tico sist\xe9mico, no solo t\xf3pico","Tomar muestra de cultivo ANTES de iniciar antibi\xf3tico"]}],noFarmacologico:["PREVENCI\xd3N: cambios posturales cada 2 horas en pacientes encamados (cada 15 min en silla)","Colchones y superficies especiales de manejo de presi\xf3n (viscoel\xe1sticas, de aire)","Desbridamiento quir\xfargico, enzim\xe1tico, autol\xedtico o mec\xe1nico del tejido necr\xf3tico","Terapia de presi\xf3n negativa (VAC) en \xfalceras estadio III-IV","Nutrici\xf3n hipercal\xf3rica e hiperproteica (argini na, zinc, vitamina C para cicatrizaci\xf3n)","Manejo de la incontinencia (riesgo de maceraci\xf3n)","Rehabilitaci\xf3n postural y movilizaci\xf3n precoz","Cirug\xeda pl\xe1stica reconstructiva en \xfalceras estadio III-IV no responsivas"]},cuidadosEnfermeria:{valoracion:["Aplicar escala Braden en TODO paciente al ingreso y en cada cambio de situaci\xf3n (riesgo: \u226418 pts)","Identificar factores de riesgo: inmovilidad, malnutrici\xf3n, incontinencia, alteraci\xf3n de la sensibilidad","Clasificar la \xfalcera seg\xfan estadio NPUAP/EPUAP","Valorar el lecho de la herida: tejido (necr\xf3tico, granulaci\xf3n, epitelizaci\xf3n), exudado, infecci\xf3n, bordes","Medir dimensiones: largo, ancho y profundidad en cada cura","Valorar el estado nutricional: IMC, alb\xfamina, ingesta cal\xf3rico-proteica","Evaluar el estado de la piel perilesional"],intervenciones:["Aplicar escala de Braden al ingreso y cada 48-72h","Realizar cambios posturales cada 2h en encamados (cada 15 min en silla de ruedas)","Utilizar colch\xf3n de manejo de presi\xf3n activo si Braden \u226414","Aplicar \xe1cidos grasos hiperoxigenados en prominencias \xf3seas en riesgo (nunca masajear)","Gestionar la incontinencia: cambios frecuentes de pa\xf1al, barreras cut\xe1neas","Asegurar ingesta proteica adecuada (1.2-1.5 g/kg/d\xeda) para mantenimiento de la piel","Limpiar la herida con suero fisiol\xf3gico a presi\xf3n controlada (jeringa 20 mL, aguja 18G)","Realizar desbridamiento del tejido necr\xf3tico seg\xfan indicaci\xf3n y tipo de desbridamiento prescrito","Aplicar el ap\xf3sito adecuado seg\xfan el estado de la herida (TIME framework)","Documentar estadio, dimensiones, tejido, exudado, infecci\xf3n y piel perilesional en cada cura","Fotografiar la herida para registro evolutivo","Cambiar ap\xf3sito con t\xe9cnica as\xe9ptica","Asegurar ingesta cal\xf3rico-proteica adecuada para cicatrizaci\xf3n: 30-35 kcal/kg/d\xeda, 1.2-1.5 g prote\xedna/kg/d\xeda","Suplementar con arginina, zinc (15-25 mg/d\xeda) y vitamina C (500-1000 mg/d\xeda) si d\xe9ficit","Solicitar valoraci\xf3n nutricional especializada si alb\xfamina <3 g/dL","Considerar nutrici\xf3n enteral si el paciente no puede alimentarse por v\xeda oral adecuadamente","Registrar ingesta diaria y evoluci\xf3n del peso"],educacionPaciente:["Explicar al paciente y familia la importancia de los cambios posturales y c\xf3mo realizarlos","Ense\xf1ar a inspeccionar diariamente la piel, especialmente en prominencias \xf3seas","Instruir sobre uso de colchones antiescaras, cojines de gel o viscoel\xe1sticos","Educar sobre la importancia de la nutrici\xf3n adecuada para la cicatrizaci\xf3n","Ense\xf1ar signos de infecci\xf3n de la \xfalcera: eritema, calor, exudado f\xe9tido, fiebre","Instruir sobre el manejo de la incontinencia para proteger la piel"],monitorizacion:[]},npiNanda:[{codigo:"00047",nombre:"Riesgo de deterioro de la integridad cut\xe1nea",definicion:"Riesgo de que la piel sea afectada adversamente",caracteristicasDefinitorias:[],factoresRelacionados:["Inmovilidad","Malnutrici\xf3n","Humedad por incontinencia","Edad avanzada"]},{codigo:"00044",nombre:"Deterioro de la integridad tisular",definicion:"Da\xf1o en la membrana mucosa, c\xf3rnea, sistema tegumentario, fascia muscular, m\xfasculo, tend\xf3n, hueso, cart\xedlago, c\xe1psula articular o ligamento",caracteristicasDefinitorias:["\xdalcera estadio I-IV sobre prominencia \xf3sea","Tejido necr\xf3tico","Exudado purulento"],factoresRelacionados:["Presi\xf3n sostenida","Cizalla","Fricci\xf3n","Isquemia tisular"]},{codigo:"00002",nombre:"Desequilibrio nutricional: ingesta inferior a las necesidades",definicion:"Ingesta de nutrientes insuficiente para satisfacer las necesidades metab\xf3licas",caracteristicasDefinitorias:["Alb\xfamina <3.5 g/dL","IMC <18.5","Ingesta insuficiente"],factoresRelacionados:["Malnutrici\xf3n proteico-cal\xf3rica","Dificultad para alimentarse","Hiporexia"]}],npiNic:[{codigo:"3540",nombre:"Prevenci\xf3n de las \xfalceras por presi\xf3n",actividades:["Aplicar escala de Braden al ingreso y cada 48-72h","Realizar cambios posturales cada 2h en encamados (cada 15 min en silla de ruedas)","Utilizar colch\xf3n de manejo de presi\xf3n activo si Braden \u226414","Aplicar \xe1cidos grasos hiperoxigenados en prominencias \xf3seas en riesgo (nunca masajear)","Gestionar la incontinencia: cambios frecuentes de pa\xf1al, barreras cut\xe1neas","Asegurar ingesta proteica adecuada (1.2-1.5 g/kg/d\xeda) para mantenimiento de la piel"]},{codigo:"3660",nombre:"Cuidados de las heridas",actividades:["Limpiar la herida con suero fisiol\xf3gico a presi\xf3n controlada (jeringa 20 mL, aguja 18G)","Realizar desbridamiento del tejido necr\xf3tico seg\xfan indicaci\xf3n y tipo de desbridamiento prescrito","Aplicar el ap\xf3sito adecuado seg\xfan el estado de la herida (TIME framework)","Documentar estadio, dimensiones, tejido, exudado, infecci\xf3n y piel perilesional en cada cura","Fotografiar la herida para registro evolutivo","Cambiar ap\xf3sito con t\xe9cnica as\xe9ptica"]},{codigo:"1100",nombre:"Manejo de la nutrici\xf3n",actividades:["Asegurar ingesta cal\xf3rico-proteica adecuada para cicatrizaci\xf3n: 30-35 kcal/kg/d\xeda, 1.2-1.5 g prote\xedna/kg/d\xeda","Suplementar con arginina, zinc (15-25 mg/d\xeda) y vitamina C (500-1000 mg/d\xeda) si d\xe9ficit","Solicitar valoraci\xf3n nutricional especializada si alb\xfamina <3 g/dL","Considerar nutrici\xf3n enteral si el paciente no puede alimentarse por v\xeda oral adecuadamente","Registrar ingesta diaria y evoluci\xf3n del peso"]}],npiNoc:[{codigo:"1103",nombre:"Curaci\xf3n de la herida: por segunda intenci\xf3n",indicadores:["Reducci\xf3n del tama\xf1o de la \xfalcera","Tejido de granulaci\xf3n presente","Exudado disminuido","Ausencia de signos de infecci\xf3n"],escala:"Reducci\xf3n del \xe1rea de la \xfalcera \u226530% en 4 semanas con tratamiento \xf3ptimo"},{codigo:"1101",nombre:"Integridad tisular: piel y membranas mucosas",indicadores:["Sin nuevas UPP","Piel \xedntegra en zonas de riesgo","Sin eritema no blanqueable"],escala:"Ausencia de nuevas \xfalceras por presi\xf3n durante el ingreso"}],complicaciones:["Infecci\xf3n de la herida con celulitis y osteomielitis","Sepsis con foco en UPP","F\xedstulas y trayectos sinuosos profundos","Amputaci\xf3n en casos de necrosis extensa","Degeneraci\xf3n maligna (carcinoma espinocelular en UPP cr\xf3nicas, raro)","Malnutrici\xf3n proteico-cal\xf3rica como consecuencia de la herida cr\xf3nica","Deterioro de la calidad de vida, dolor cr\xf3nico, impacto psicol\xf3gico"],criteriosAlarma:["Signos de infecci\xf3n: eritema perilesional, calor, exudado purulento con olor f\xe9tido","Osteomielitis subyacente (UPP que no cicatriza sobre prominencia \xf3sea)","Sepsis con foco en UPP infectada","Celulitis extensiva alrededor de la \xfalcera","UPP estadio IV con afectaci\xf3n \xf3sea (requiere cirug\xeda)"],emergencyLevel:"moderado",relatedPathologyIds:[],isPremium:!1},{id:"pat_celulitis",nombre:"Celulitis",bodySystemId:"tegumentario",definicion:"Infecci\xf3n bacteriana aguda de la piel y tejido celular subcut\xe1neo, predominantemente causada por Streptococcus pyogenes y Staphylococcus aureus. Se caracteriza por eritema, calor, edema y dolor. Puede progresar a fascitis necrotizante si no se trata adecuadamente.",epidemiologia:"",factoresRiesgo:[],fisiopatologia:"Las bacterias acceden al tejido celular subcut\xe1neo a trav\xe9s de soluciones de continuidad cut\xe1neas (heridas, \xfalceras, picaduras, tinea pedis) o por v\xeda linf\xe1tica. La respuesta inflamatoria local produce edema, eritema y calor. Las toxinas bacterianas pueden diseminarse localmente o hacia la sangre (bacteriemia). El Streptococcus del grupo A produce estreptoquinasa, hialuronidasa y exotoxinas que facilitan la diseminaci\xf3n horizontal r\xe1pida en los planos tisulares. La fascitis necrotizante tipo II (estreptoc\xf3cica) es una emergencia quir\xfargica con mortalidad del 20-50% por destrucci\xf3n r\xe1pida de fascia y m\xfasculo.",signosYSintomas:{signos:["Eritema rojo intenso, caliente, edematoso, de bordes mal definidos (diferente a erisipela)","Dolor local a la palpaci\xf3n","Expansi\xf3n progresiva del eritema (marca los bordes con rotulador para seguimiento)","Puerta de entrada visible (herida, \xfalcera, tinea pedis interdigital)","Fiebre y malestar general","Progresi\xf3n r\xe1pida del eritema a pesar de antibi\xf3ticos (resistencia o fascitis necrotizante)","Dolor desproporcionado a los signos locales (hallazgo clave de fascitis necrotizante)","Crepitaci\xf3n a la palpaci\xf3n (gas producido por bacterias anaerobias)","Necrosis cut\xe1nea o equimosis viol\xe1cea (fascitis necrotizante: EMERGENCIA QUIR\xdaRGICA)","Sepsis con inestabilidad hemodin\xe1mica","Fascitis necrotizante: desbridamiento quir\xfargico urgente"],sintomas:["Linfangitis (l\xednea roja desde la lesi\xf3n hacia ganglios regionales)","Adenopat\xedas regionales dolorosas","Ampollas hemorr\xe1gicas en celulitis grave","Fluctuaci\xf3n si hay absceso subyacente","Exudado seropurulento"]},diagnostico:{anamnesis:["Diagn\xf3stico cl\xednico: eritema, calor, edema y dolor en tejido subcut\xe1neo","Diferenciaci\xf3n erisipela (bordes n\xedtidos y sobreelevados, estreptoc\xf3cica) vs. celulitis (bordes difusos)","Laboratorio: leucocitosis con neutrofilia, PCR elevada (intensidad del proceso)"],examenFisico:[],pruebas:[{nombre:"Hemocultivos (si fiebre >38.5\xb0C o signos de sepsis: bacteriemia en 2-4%)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Hemograma, PCR, VSG, procalcitonina",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Punci\xf3n aspirativa para cultivo (especialmente en celulitis at\xedpica)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"TC o RMN si sospecha fascitis necrotizante (gas, engrosamiento de fascia)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Ecograf\xeda de partes blandas: diferencia celulitis, absceso y fascitis necrotizante",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"LRINEC score (Laboratory Risk Indicator for Necrotizing Fasciitis): PCR, leucocitos, Na, creatinina, glucosa, Hb",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]}]},tratamientoMedico:{objetivos:[],farmacologico:[{nombre:"Amoxicilina-Clavul\xe1nico",grupo:"Amoxicilina: penicilina semisint\xe9tica",mecanismo:"Amoxicilina: penicilina semisint\xe9tica que inhibe la s\xedntesis de pared celular. Clavul\xe1nico: inhibidor de betalactamasas que protege a la amoxicilina frente a bacterias productoras de penicilinasas (MSSA, estreptococos, anaerobios). Cobertura de Streptococcus y S. aureus MSSA",dosis:"875/125 mg VO cada 8h (leve-moderada). IV: 1-2 g/200 mg cada 8h. Duraci\xf3n: 5-7 d\xedas para celulitis leve, 10-14 d\xedas para moderada-grave",cuidadosEnfermeria:["Administrar con comidas para reducir intolerancia gastrointestinal","Monitorizar funci\xf3n hep\xe1tica si tratamiento prolongado","Verificar alergias a penicilinas antes de administrar","Educar sobre probi\xf3ticos para reducir diarrea asociada a antibi\xf3ticos","Marcar los bordes del eritema con rotulador permanente para evaluar progresi\xf3n"]},{nombre:"Vancomicina IV",grupo:"Glucop\xe9ptido activo frente",mecanismo:"Glucop\xe9ptido activo frente a MRSA. Indicado en celulitis grave hospitalaria, inmunodeprimidos o cuando se sospecha MRSA (factores de riesgo: contacto sanitario, manipulaciones previas, fracaso de betalact\xe1micos)",dosis:"15-20 mg/kg IV cada 8-12h. Ajustar por niveles plasm\xe1ticos. Infundir en m\xednimo 60 min por gramo",cuidadosEnfermeria:["Infundir en 60 min m\xednimo por gramo para evitar s\xedndrome del hombre rojo","Monitorizar funci\xf3n renal y niveles de vancomicina","Evitar f\xe1rmacos nefrot\xf3xicos concomitantes","Vigilar s\xedntomas de ototoxicidad: tinitus, hipoacusia"]}],noFarmacologico:["Elevaci\xf3n del miembro afectado (reduce edema y facilita drenaje linf\xe1tico)","Reposo relativo","Marcar los bordes del eritema con rotulador (monitorizaci\xf3n de progresi\xf3n)","Drenaje quir\xfargico si hay absceso fluctuante subyacente","Desbridamiento quir\xfargico urgente si fascitis necrotizante (no demorar por ninguna causa)","Tratar la puerta de entrada: tinea pedis (antif\xfangico t\xf3pico), \xfalcera subyacente"]},cuidadosEnfermeria:{valoracion:["Valorar extensi\xf3n del eritema, temperatura y consistencia del tejido afectado","Marcar los bordes del eritema con rotulador y fechas para control de progresi\xf3n","Monitorizar temperatura, FC, PA (signos de sepsis)","Evaluar dolor con EVA","Identificar la puerta de entrada (herida, \xfalcera, tinea pedis)","Vigilar signos de fascitis necrotizante: dolor desproporcionado, crepitaci\xf3n, necrosis","Valorar factores de riesgo: diabetes, inmunosupresi\xf3n, insuficiencia venosa"],intervenciones:["Marcar los bordes del eritema con rotulador cada 8-12h y documentar la progresi\xf3n","Administrar antibi\xf3ticos puntualmente en los horarios pautados (mantener niveles constantes)","Monitorizar respuesta al tratamiento: temperatura, leucocitosis, PCR","Instruir sobre higiene de la zona y evitar manipular la lesi\xf3n","Comunicar al m\xe9dico si el eritema progresa a pesar del tratamiento (cambio de antibi\xf3tico, posible fascitis)","Mantener el miembro afectado elevado por encima del nivel del coraz\xf3n","Aplicar fr\xedo local (no directamente sobre la piel) para reducir el dolor e inflamaci\xf3n si el paciente lo tolera","Evitar presi\xf3n sobre la zona afectada","Cambios posturales si hay inmovilizaci\xf3n prolongada"],educacionPaciente:["Explicar la importancia de completar el ciclo antibi\xf3tico completo incluso si mejora","Ense\xf1ar a reconocer signos de alarma de fascitis necrotizante: dolor intenso desproporcionado, necrosis","Instruir sobre la higiene de los pies y tratamiento de la tinea pedis (puerta de entrada frecuente)","Informar sobre hidrataci\xf3n y lubricaci\xf3n de la piel para prevenir fisuras","Educar sobre el cuidado de las heridas para evitar infecciones"],monitorizacion:[]},npiNanda:[{codigo:"00004",nombre:"Riesgo de infecci\xf3n",definicion:"Vulnerable a una invasi\xf3n y multiplicaci\xf3n de organismos pat\xf3genos",caracteristicasDefinitorias:[],factoresRelacionados:["Soluci\xf3n de continuidad cut\xe1nea","Inmunosupresi\xf3n","Diabetes"]},{codigo:"00046",nombre:"Deterioro de la integridad cut\xe1nea",definicion:"Alteraci\xf3n en la epidermis y/o dermis",caracteristicasDefinitorias:["Eritema","Calor","Edema","Dolor en tejido subcut\xe1neo"],factoresRelacionados:["Infecci\xf3n bacteriana","Edema","Calor local"]},{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable causada por la inflamaci\xf3n tisular",caracteristicasDefinitorias:["Eritema doloroso a la palpaci\xf3n","Calor local","Limitaci\xf3n del movimiento"],factoresRelacionados:["Inflamaci\xf3n e infecci\xf3n del tejido subcut\xe1neo"]}],npiNic:[{codigo:"6540",nombre:"Control de infecciones",actividades:["Marcar los bordes del eritema con rotulador cada 8-12h y documentar la progresi\xf3n","Administrar antibi\xf3ticos puntualmente en los horarios pautados (mantener niveles constantes)","Monitorizar respuesta al tratamiento: temperatura, leucocitosis, PCR","Instruir sobre higiene de la zona y evitar manipular la lesi\xf3n","Comunicar al m\xe9dico si el eritema progresa a pesar del tratamiento (cambio de antibi\xf3tico, posible fascitis)"]},{codigo:"0740",nombre:"Cuidados al paciente encamado",actividades:["Mantener el miembro afectado elevado por encima del nivel del coraz\xf3n","Aplicar fr\xedo local (no directamente sobre la piel) para reducir el dolor e inflamaci\xf3n si el paciente lo tolera","Evitar presi\xf3n sobre la zona afectada","Cambios posturales si hay inmovilizaci\xf3n prolongada"]}],npiNoc:[{codigo:"0702",nombre:"Estado inmune",indicadores:["Afebril","Leucocitosis en regresi\xf3n","PCR en descenso","Sin nuevos focos"],escala:"Resoluci\xf3n del eritema y normalizaci\xf3n de par\xe1metros inflamatorios en 5-7 d\xedas"}],complicaciones:["Fascitis necrotizante (emergencia quir\xfargica con alta mortalidad)","Sepsis por bacteriemia","Linfedema cr\xf3nico residual","Recurrencia (alta tasa si no se trata la puerta de entrada)","Absceso con necesidad de drenaje","Osteomielitis si la infecci\xf3n alcanza el hueso"],criteriosAlarma:["Progresi\xf3n r\xe1pida del eritema a pesar de antibi\xf3ticos (resistencia o fascitis necrotizante)","Dolor desproporcionado a los signos locales (hallazgo clave de fascitis necrotizante)","Crepitaci\xf3n a la palpaci\xf3n (gas producido por bacterias anaerobias)","Necrosis cut\xe1nea o equimosis viol\xe1cea (fascitis necrotizante: EMERGENCIA QUIR\xdaRGICA)","Sepsis con inestabilidad hemodin\xe1mica","Fascitis necrotizante: desbridamiento quir\xfargico urgente"],emergencyLevel:"moderado",relatedPathologyIds:[],isPremium:!0},{id:"pat_psoriasis",nombre:"Psoriasis",bodySystemId:"tegumentario",definicion:"Enfermedad inflamatoria cr\xf3nica de la piel con base autoinmune caracterizada por placas eritematodescamativas bien delimitadas. Afecta al 2-3% de la poblaci\xf3n. Puede asociarse a artritis psori\xe1sica (30%) y tiene mayor riesgo cardiovascular.",epidemiologia:"",factoresRiesgo:[],fisiopatologia:"La psoriasis es una enfermedad sist\xe9mica con componente gen\xe9tico (HLA-Cw6) y ambiental (estr\xe9s, infecciones, f\xe1rmacos). Los queratinocitos son activados por citocinas inflamatorias (TNF-alfa, IL-17A, IL-23) producidas por c\xe9lulas dendr\xedticas plasmocitoides y linfocitos T CD4+ (Th1, Th17). Esto provoca hiperproliferaci\xf3n epid\xe9rmica (ciclo de 7 d\xedas en vez de 28) con descamaci\xf3n acelerada y engrosamiento de la epidermis (acantosis). La neovascularizaci\xf3n d\xe9rmica genera el eritema caracter\xedstico. El eje IL-23/Th17 es el principal mediador de la inflamaci\xf3n psori\xe1sica y diana terap\xe9utica de los biol\xf3gicos.",signosYSintomas:{signos:["Placas eritematosas bien delimitadas cubiertas de escamas plateadas nacaradas","Localizaci\xf3n t\xedpica: codos, rodillas, cuero cabelludo, regi\xf3n lumbosacra","Fen\xf3meno de K\xf6bner: aparici\xf3n de lesiones en zonas de traumatismo","Signo de Auspitz: al raspar las escamas, aparece sangrado puntiforme","Prurito variable (generalmente leve-moderado)","Psoriasis pustulosa generalizada: fiebre, postraci\xf3n, p\xfastulas est\xe9riles difusas (emergencia)","Eritrodermia psori\xe1sica: eritema >90% SCQ, riesgo de hipotermia y fallo card\xedaco","Artritis psori\xe1sica con destrucci\xf3n articular r\xe1pida"],sintomas:["U\xf1as psori\xe1sicas: onicodistrofia, hoyuelos (pitting), leuconiquia, hiperqueratosis subungueal","Artritis psori\xe1sica: oligoartritis asim\xe9trica, artritis mutilante, dactilitis","Eritrodermia psori\xe1sica (forma grave: >90% de la superficie corporal)","Psoriasis pustulosa generalizada (von Zumbusch: emergencia)","Impacto psicol\xf3gico significativo: depresi\xf3n, aislamiento"]},diagnostico:{anamnesis:["Diagn\xf3stico cl\xednico: aspecto t\xedpico de las placas","Biopsia cut\xe1nea si dudas: hiperqueratosis, paraqueratosis, acantosis, infiltrado inflamatorio d\xe9rmico","PASI (Psoriasis Area and Severity Index): evaluaci\xf3n de extensi\xf3n y gravedad (0-72)"],examenFisico:[],pruebas:[{nombre:"Biopsia cut\xe1nea (si diagn\xf3stico incierto)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"PASI para cuantificar la gravedad y monitorizar respuesta al tratamiento",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"BSA (Body Surface Area) y DLQI (impacto en calidad de vida)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Anticuerpos ANA, FR (descartar otras enfermedades autoinmunes)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"HLA-B27 (espondilitis psori\xe1sica)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Perfil lip\xeddico, glucemia, PA (riesgo cardiovascular aumentado)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Serolog\xeda VIH (psoriasis puede ser manifestaci\xf3n de VIH)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]}]},tratamientoMedico:{objetivos:[],farmacologico:[{nombre:"Corticoides T\xf3picos (Betametasona 0.05%)",grupo:"Los glucocorticoides t\xf3picos",mecanismo:"Los glucocorticoides t\xf3picos inhiben la producci\xf3n de citocinas proinflamatorias y reducen la proliferaci\xf3n de queratinocitos. La potencia var\xeda seg\xfan la formulaci\xf3n (valeratos, dipropionatos) y el veh\xedculo (ung\xfcento > crema > loci\xf3n)",dosis:"Aplicar una capa fina en las placas 1-2 veces/d\xeda. Uso intermitente o de fin de semana para evitar taquifilaxia. Formas de alta potencia: cara/pliegues contraindicadas",cuidadosEnfermeria:["Ense\xf1ar a aplicar una capa fina (no en exceso): 'fingertip unit'","No usar de alta potencia en cara, pliegues, genitales ni en ni\xf1os","Advertir sobre atrofia cut\xe1nea con uso prolongado (intermitente para prevenir)","Ocluir con film o vendaje despu\xe9s de aplicar mejora la absorci\xf3n (uso supervisado)","Vigilar signos de candidosis si se usa bajo oclusi\xf3n en pliegues"]},{nombre:"Metotrexato",grupo:"Inhibidor del folato",mecanismo:"Inhibidor del folato con efectos inmunomoduladores y antiproliferativos en queratinocitos y c\xe9lulas T. Tratamiento sist\xe9mico de elecci\xf3n en psoriasis moderada-grave (PASI >10 o impacto severo en calidad de vida)",dosis:"7.5-25 mg VO o SC una vez por semana. Suplementar \xe1cido f\xf3lico 5 mg la semana del MTX excepto el d\xeda de la toma",cuidadosEnfermeria:["Hemograma y funci\xf3n hep\xe1tica cada 4-8 semanas","NO administrar a diario (solo 1 vez/semana: error grave documentado)","Suplementar \xe1cido f\xf3lico para reducir efectos adversos","Evitar embarazo en hombres y mujeres durante tratamiento y 3-6 meses despu\xe9s","No alcohol durante el tratamiento (hepatotoxicidad aditiva)"]},{nombre:"Secukinumab",grupo:"Anticuerpo monoclonal anti-IL-17A",mecanismo:"Anticuerpo monoclonal anti-IL-17A que bloquea la v\xeda Th17, principal mediadora de la inflamaci\xf3n psori\xe1sica. Alta eficacia (PASI 90 en >60% de los pacientes) con inicio de acci\xf3n r\xe1pido",dosis:"300 mg SC en semanas 0, 1, 2, 3, 4 y luego mensual. Para psoriasis en placas grave y artritis psori\xe1sica",cuidadosEnfermeria:["Descartar tuberculosis latente (Mantoux/IGRA) y hepatitis B antes de iniciar","Vigilar candidiasis oral y vaginal frecuentemente","Contraindicado si EII activa (especialmente Crohn: puede empeorar)","Guardar en nevera 2-8\xb0C, sacar 15-30 min antes de administrar","Ense\xf1ar autoinyecci\xf3n subcut\xe1nea","No usar vacunas vivas durante el tratamiento"]}],noFarmacologico:["Fototerapia UVB de banda estrecha (nbUVB): tratamiento de 2da l\xednea eficaz y seguro","Fototerapia PUVA (psoraleno + UVA): alta eficacia pero mayor riesgo carcinog\xe9nico","Hidrataci\xf3n intensiva de la piel (emolientes): reduce descamaci\xf3n y prurito","Eliminar desencadenantes: estr\xe9s, infecciones estreptoc\xf3cicas, f\xe1rmacos (betabloqueantes, litio, AINE)","Dieta mediterr\xe1nea y reducci\xf3n de peso (obesidad empeora la psoriasis)","Evitar tabaco y alcohol"]},cuidadosEnfermeria:{valoracion:["Calcular PASI y BSA para cuantificar la gravedad","Evaluar el impacto en la calidad de vida (DLQI)","Inspeccionar todas las lesiones: localizaci\xf3n, extensi\xf3n, descamaci\xf3n","Valorar presencia de artritis psori\xe1sica (dolor e inflamaci\xf3n articular)","Evaluar estado emocional: depresi\xf3n, ansiedad, impacto social","Revisar factores desencadenantes: estr\xe9s, f\xe1rmacos, infecciones","Valorar factores de riesgo cardiovascular asociados"],intervenciones:["Ense\xf1ar la t\xe9cnica correcta de aplicaci\xf3n de tratamientos t\xf3picos (corticoides, an\xe1logos de vitamina D)","Instruir sobre el uso de emolientes en toda la piel, no solo en las placas (previene fisuras)","Recomendar ba\xf1o o ducha con agua tibia (no caliente), tiempo breve y jab\xf3n neutro","Aplicar los emolientes inmediatamente despu\xe9s del ba\xf1o (sella la hidrataci\xf3n)","Educar sobre el uso intermitente de corticoides para evitar taquifilaxia y atrofia","Explorar el impacto psicosocial de la psoriasis (DLQI, preguntas directas)","Validar los sentimientos del paciente sobre la enfermedad (no trivializar)","Derivar a psicolog\xeda si hay depresi\xf3n o impacto severo en calidad de vida","Conectar con grupos de apoyo de psoriasis (asociaciones de pacientes)","Informar que la psoriasis no es contagiosa (estigma social frecuente)"],educacionPaciente:["Explicar la naturaleza cr\xf3nica de la psoriasis con brotes y remisiones","Ense\xf1ar identificaci\xf3n y evitaci\xf3n de desencadenantes personales","Insistir en la hidrataci\xf3n diaria de la piel (emolientes)","Instruir sobre la t\xe9cnica correcta de aplicaci\xf3n de tratamientos t\xf3picos","Informar sobre la psoriasis como enfermedad sist\xe9mica (riesgo cardiovascular)","Desmentir el mito de la contagiosidad"],monitorizacion:[]},npiNanda:[{codigo:"00047",nombre:"Riesgo de deterioro de la integridad cut\xe1nea",definicion:"Riesgo de que la piel sea afectada de forma adversa",caracteristicasDefinitorias:[],factoresRelacionados:["Psoriasis cr\xf3nica","Rascado","Uso incorrecto de tratamientos t\xf3picos"]},{codigo:"00137",nombre:"Aflicci\xf3n cr\xf3nica",definicion:"Modelo ciclico, recurrente y potencialmente progresivo de tristeza omnipresente que una persona experimenta frente a una p\xe9rdida continua",caracteristicasDefinitorias:["Sentimientos de tristeza recurrentes","Impacto negativo en la calidad de vida","Afectaci\xf3n de relaciones sociales"],factoresRelacionados:["Enfermedad cr\xf3nica desfigurante","Impacto social y laboral","Incertidumbre sobre la evoluci\xf3n"]},{codigo:"00126",nombre:"Conocimientos deficientes",definicion:"Ausencia o deficiencia de informaci\xf3n cognitiva relacionada con el tratamiento de la psoriasis",caracteristicasDefinitorias:["Aplicaci\xf3n incorrecta de tratamientos","Abandono del tratamiento en fases de mejor\xeda"],factoresRelacionados:["Falta de informaci\xf3n","Mala adherencia al tratamiento t\xf3pico"]}],npiNic:[{codigo:"3584",nombre:"Cuidado de la piel: tratamiento t\xf3pico",actividades:["Ense\xf1ar la t\xe9cnica correcta de aplicaci\xf3n de tratamientos t\xf3picos (corticoides, an\xe1logos de vitamina D)","Instruir sobre el uso de emolientes en toda la piel, no solo en las placas (previene fisuras)","Recomendar ba\xf1o o ducha con agua tibia (no caliente), tiempo breve y jab\xf3n neutro","Aplicar los emolientes inmediatamente despu\xe9s del ba\xf1o (sella la hidrataci\xf3n)","Educar sobre el uso intermitente de corticoides para evitar taquifilaxia y atrofia"]},{codigo:"5270",nombre:"Apoyo emocional",actividades:["Explorar el impacto psicosocial de la psoriasis (DLQI, preguntas directas)","Validar los sentimientos del paciente sobre la enfermedad (no trivializar)","Derivar a psicolog\xeda si hay depresi\xf3n o impacto severo en calidad de vida","Conectar con grupos de apoyo de psoriasis (asociaciones de pacientes)","Informar que la psoriasis no es contagiosa (estigma social frecuente)"]}],npiNoc:[{codigo:"1101",nombre:"Integridad tisular: piel y membranas mucosas",indicadores:["Reducci\xf3n del PASI","Menos placas activas","Menor descamaci\xf3n"],escala:"Reducci\xf3n del PASI \u226575% (PASI75) en 12-16 semanas con tratamiento sist\xe9mico"}],complicaciones:["Artritis psori\xe1sica con destrucci\xf3n articular","Eritrodermia psori\xe1sica (emergencia)","Psoriasis pustulosa generalizada","Infecciones cut\xe1neas sobrea\xf1adidas","Mayor riesgo cardiovascular (inflamaci\xf3n sist\xe9mica cr\xf3nica)","Depresi\xf3n y suicidio","Candidiasis con biol\xf3gicos anti-IL-17"],criteriosAlarma:["Psoriasis pustulosa generalizada: fiebre, postraci\xf3n, p\xfastulas est\xe9riles difusas (emergencia)","Eritrodermia psori\xe1sica: eritema >90% SCQ, riesgo de hipotermia y fallo card\xedaco","Artritis psori\xe1sica con destrucci\xf3n articular r\xe1pida"],emergencyLevel:"leve",relatedPathologyIds:[],isPremium:!0},{id:"pat_herpes_zoster",nombre:"Herpes Z\xf3ster",bodySystemId:"tegumentario",definicion:"Reactivaci\xf3n del virus varicela-z\xf3ster (VVZ) latente en los ganglios sensitivos dorsales tras una varicela primaria. Se manifiesta como erupci\xf3n vesiculosa dolorosa en el dermatoma correspondiente al ganglio afectado. La neuralgia postherp\xe9tica es la complicaci\xf3n m\xe1s frecuente e incapacitante.",epidemiologia:"",factoresRiesgo:[],fisiopatologia:"Tras la varicela primaria, el VVZ queda latente en los ganglios sensitivos dorsales y ganglios de pares craneales. La reactivaci\xf3n se produce cuando la inmunidad celular espec\xedfica disminuye (envejecimiento, inmunosupresi\xf3n, estr\xe9s). El virus viaja por los axones sensitivos desde el ganglio hasta la piel del dermatoma correspondiente, causando inflamaci\xf3n ganglionar (ganglionitis) y dermatitis vesiculosa. El dolor neurop\xe1tico precede a la erupci\xf3n (pr\xf3dromos) y puede persistir meses o a\xf1os tras la curaci\xf3n de las lesiones (neuralgia postherp\xe9tica: dolor en el dermatoma sin lesiones activas).",signosYSintomas:{signos:["Pr\xf3dromos: dolor quemante, prurito o parestesias en el dermatoma afectado (2-7 d\xedas antes)","Erupci\xf3n vesiculosa unilateral en banda (dermatoma) con base eritematosa","Localizaci\xf3n m\xe1s frecuente: t\xf3rax (T3-T10), cabeza y cuello (NC V1: z\xf3ster oft\xe1lmico)","Evoluci\xf3n: p\xe1pulas \u2192 ves\xedculas \u2192 p\xfastulas \u2192 costras (en 7-10 d\xedas)","Dolor intenso: quemante, ardiente, lancinante","Z\xf3ster oft\xe1lmico (NC V1): afectaci\xf3n corneal, uve\xedtis \u2192 urgencia oftalmol\xf3gica","S\xedndrome de Ramsay Hunt (NC VII + VIII): par\xe1lisis facial perif\xe9rica + ves\xedculas en o\xeddo + tinnitus/v\xe9rtigo","Z\xf3ster diseminado (>20 dermatomas o afectaci\xf3n visceral) en inmunodeprimidos","Encefalitis herp\xe9tica"],sintomas:["Fiebre y malestar general en fase aguda","Adenopat\xedas regionales dolorosas","Neuralgia postherp\xe9tica (dolor persistente >3 meses tras la erupci\xf3n)","Prurito residual"]},diagnostico:{anamnesis:["Diagn\xf3stico cl\xednico: erupci\xf3n vesiculosa dolorosa unilateral siguiendo un dermatoma","Confirmaci\xf3n virol\xf3gica si dudas: PCR del l\xedquido de las ves\xedculas (gold standard)","IgM anti-VVZ en fase aguda (seroconversi\xf3n)"],examenFisico:[],pruebas:[{nombre:"PCR del l\xedquido vesicular (confirma VVZ)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Citodiagn\xf3stico de Tzanck (c\xe9lulas gigantes multinucleadas: caracter\xedstico pero no espec\xedfico de VVZ vs HSV)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"IgM e IgG anti-VVZ (fase aguda)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Cultivo viral (lento, menos usado que PCR)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"En z\xf3ster oft\xe1lmico: l\xe1mpara de hendidura, tonometr\xeda (urgencia)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Hemograma y funci\xf3n inmune si z\xf3ster en <50 a\xf1os o diseminado (descartar inmunosupresi\xf3n)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]}]},tratamientoMedico:{objetivos:[],farmacologico:[{nombre:"Valaciclovir",grupo:"Prof\xe1rmaco del aciclovir",mecanismo:"Prof\xe1rmaco del aciclovir (biodisponibilidad VO 3-5x mayor). El aciclovir es fosforilado por la timidina quinasa viral e inhibe selectivamente la ADN polimerasa del VVZ, bloqueando la replicaci\xf3n viral",dosis:"1000 mg VO cada 8h durante 7 d\xedas. Iniciar en las primeras 72h desde el inicio de la erupci\xf3n (mayor eficacia). Si >72h pero hay ves\xedculas nuevas o z\xf3ster en inmunosuprimido: iniciar igualmente",cuidadosEnfermeria:["Insistir en iniciar en las primeras 72h: es cr\xedtico para la eficacia (reduce dolor y riesgo de neuralgia postherp\xe9tica)","Asegurar buena hidrataci\xf3n para reducir el riesgo renal","Ajustar dosis si insuficiencia renal (ClCr <50 mL/min)","Vigilar confusi\xf3n o agitaci\xf3n en ancianos con funci\xf3n renal disminuida"]},{nombre:"Gabapentina",grupo:"Ligando de la",mecanismo:"Ligando de la subunidad alfa-2-delta de canales de calcio, que reduce la liberaci\xf3n de neurotransmisores excitadores. Primera l\xednea en neuralgia postherp\xe9tica (dolor neurop\xe1tico) junto a pregabalina",dosis:"Inicio: 300 mg VO/d\xeda, aumentar gradualmente hasta 1800-3600 mg/d\xeda en 3 tomas. Titular seg\xfan respuesta y tolerancia",cuidadosEnfermeria:["Iniciar con dosis bajas y aumentar gradualmente (reduce efectos adversos)","Advertir sobre conducci\xf3n de veh\xedculos (somnolencia y mareo)","Ajustar dosis en insuficiencia renal","No suspender bruscamente (reducir gradualmente)","Vigilar ca\xeddas en ancianos (somnolencia + ataxia)"]},{nombre:"Lidoca\xedna Parche 5%",grupo:"Anest\xe9sico local que",mecanismo:"Anest\xe9sico local que bloquea los canales de sodio en fibras nerviosas perif\xe9ricas sensitivas, reduciendo la alodinia (dolor ante est\xedmulos no dolorosos) y el dolor neurop\xe1tico local en la neuralgia postherp\xe9tica",dosis:"1-3 parches aplicados sobre la zona dolorosa sin lesiones activas, durante 12h/d\xeda (12h on, 12h off)",cuidadosEnfermeria:["Solo aplicar sobre piel intacta (sin ves\xedculas activas)","M\xe1ximo 3 parches simult\xe1neos","Marcar la zona de aplicaci\xf3n y alternar para evitar irritaci\xf3n","Cortar a la forma adecuada si la zona es peque\xf1a","Observar eritema o irritaci\xf3n local"]}],noFarmacologico:["Curas de las ves\xedculas con antis\xe9ptico suave (clorhexidina) y ap\xf3sito no adhesivo","No rascar ni reventar las ves\xedculas (infecci\xf3n bacteriana secundaria)","Vacuna antiherpes z\xf3ster (Shingrix, vacuna recombinante) en \u226550 a\xf1os o inmunosuprimidos: previene el z\xf3ster y la neuralgia postherp\xe9tica en >90%","TENS (estimulaci\xf3n nerviosa el\xe9ctrica transcut\xe1nea) para neuralgia postherp\xe9tica","Capsaicina t\xf3pica en neuralgia postherp\xe9tica refractaria"]},cuidadosEnfermeria:{valoracion:["Valorar extensi\xf3n de la erupci\xf3n y estadio de las lesiones (ves\xedculas, costras)","Evaluar dolor con EVA (incluir alodinia y prurito)","Identificar el dermatoma afectado para anticipar complicaciones espec\xedficas (V1: oftalmo, VII: Ramsay Hunt)","Valorar el estado inmunol\xf3gico del paciente (inmunosupresi\xf3n = riesgo de diseminaci\xf3n)","Detectar signos oculares si V1: enrojecimiento, fotofobia, disminuci\xf3n de agudeza visual (urgencia)"],intervenciones:["Administrar analgesia pautada para el dolor neurop\xe1tico: analg\xe9sicos, gabapentina, pregabalina, antidepresivos tric\xedclicos","Evaluar el dolor neurop\xe1tico: alodinia, sensaci\xf3n de quemadura, corriente el\xe9ctrica","Aplicar parche de lidoca\xedna 5% sobre zona dolorosa sin lesiones activas","Ense\xf1ar t\xe9cnicas de distracci\xf3n y relajaci\xf3n para el manejo del dolor","Derivar a unidad del dolor si neuralgia postherp\xe9tica refractaria","Limpiar las lesiones con suero fisiol\xf3gico o clorhexidina suave","Cubrir con ap\xf3sito no adhesivo (las ves\xedculas son contagiosas hasta que se forman costras)","Instruir para no rascar ni reventar las ves\xedculas","Vigilar signos de sobreinfecci\xf3n bacteriana: eritema perilesional, exudado purulento, fiebre","Usar guantes en el manejo de las lesiones (precauciones de contacto)"],educacionPaciente:["Explicar la contagiosidad del herpes z\xf3ster: contagioso por contacto con ves\xedculas activas para personas sin varicela previa o vacunaci\xf3n","Instruir para cubrir las lesiones y evitar contacto con embarazadas, neonatos e inmunodeprimidos","Informar que las lesiones dejan de ser contagiosas cuando forman costras secas","Ense\xf1ar la importancia de iniciar el antiviral en las primeras 72h","Informar sobre la vacuna Shingrix para prevenci\xf3n en \u226550 a\xf1os","Explicar la neuralgia postherp\xe9tica y los tratamientos disponibles si persiste el dolor"],monitorizacion:[]},npiNanda:[{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable causada por la inflamaci\xf3n herp\xe9tica",caracteristicasDefinitorias:["Dolor quemante en dermatoma","Alodinia","Hiperestesia cut\xe1nea"],factoresRelacionados:["Inflamaci\xf3n ganglionar por VVZ","Afectaci\xf3n de fibras nerviosas sensitivas"]},{codigo:"00046",nombre:"Deterioro de la integridad cut\xe1nea",definicion:"Alteraci\xf3n en la epidermis y/o dermis",caracteristicasDefinitorias:["Ves\xedculas en dermatoma","Costras","Erosiones"],factoresRelacionados:["Infecci\xf3n viral por VVZ","Rascado"]},{codigo:"00153",nombre:"Riesgo de baja autoestima situacional",definicion:"Vulnerable a desarrollar una percepci\xf3n negativa de la propia val\xeda en respuesta a una situaci\xf3n actual",caracteristicasDefinitorias:[],factoresRelacionados:["Dolor cr\xf3nico (neuralgia postherp\xe9tica)","Limitaci\xf3n funcional","Desfiguraci\xf3n temporal"]}],npiNic:[{codigo:"1400",nombre:"Manejo del dolor",actividades:["Administrar analgesia pautada para el dolor neurop\xe1tico: analg\xe9sicos, gabapentina, pregabalina, antidepresivos tric\xedclicos","Evaluar el dolor neurop\xe1tico: alodinia, sensaci\xf3n de quemadura, corriente el\xe9ctrica","Aplicar parche de lidoca\xedna 5% sobre zona dolorosa sin lesiones activas","Ense\xf1ar t\xe9cnicas de distracci\xf3n y relajaci\xf3n para el manejo del dolor","Derivar a unidad del dolor si neuralgia postherp\xe9tica refractaria"]},{codigo:"3660",nombre:"Cuidados de las heridas",actividades:["Limpiar las lesiones con suero fisiol\xf3gico o clorhexidina suave","Cubrir con ap\xf3sito no adhesivo (las ves\xedculas son contagiosas hasta que se forman costras)","Instruir para no rascar ni reventar las ves\xedculas","Vigilar signos de sobreinfecci\xf3n bacteriana: eritema perilesional, exudado purulento, fiebre","Usar guantes en el manejo de las lesiones (precauciones de contacto)"]}],npiNoc:[{codigo:"2102",nombre:"Nivel del dolor",indicadores:["Dolor en reposo EVA","Alodinia","Frecuencia de episodios de dolor"],escala:"Control del dolor agudo EVA \u22644 en 7-14 d\xedas. Prevenci\xf3n de neuralgia postherp\xe9tica con antiviral precoz"}],complicaciones:["Neuralgia postherp\xe9tica (10-40%): dolor cr\xf3nico invalidante","Z\xf3ster oft\xe1lmico con queratitis y uve\xedtis (p\xe9rdida visual)","S\xedndrome de Ramsay Hunt (par\xe1lisis facial perif\xe9rica)","Encefalitis herp\xe9tica","Z\xf3ster diseminado en inmunodeprimidos","Sobreinfecci\xf3n bacteriana","Meningitis v\xedrica"],criteriosAlarma:["Z\xf3ster oft\xe1lmico (NC V1): afectaci\xf3n corneal, uve\xedtis \u2192 urgencia oftalmol\xf3gica","S\xedndrome de Ramsay Hunt (NC VII + VIII): par\xe1lisis facial perif\xe9rica + ves\xedculas en o\xeddo + tinnitus/v\xe9rtigo","Z\xf3ster diseminado (>20 dermatomas o afectaci\xf3n visceral) en inmunodeprimidos","Encefalitis herp\xe9tica"],emergencyLevel:"moderado",relatedPathologyIds:[],isPremium:!0},{id:"pat_preeclampsia",nombre:"Preeclampsia",bodySystemId:"reproductivo",definicion:"Trastorno hipertensivo del embarazo que se presenta despu\xe9s de las 20 semanas de gestaci\xf3n, caracterizado por hipertensi\xf3n arterial y proteinuria. La eclampsia (convulsiones) y el s\xedndrome HELLP son las complicaciones maternas m\xe1s graves con alta morbimortalidad.",epidemiologia:"",factoresRiesgo:[],fisiopatologia:"La preeclampsia resulta de una placentaci\xf3n anormal: la invasi\xf3n trofobl\xe1stica deficiente de las arterias espirales uterinas genera vasos de alta resistencia con flujo uteroplacentario reducido. La placenta isqu\xe9mica libera factores antiangiog\xe9nicos (sFlt-1, endoglina soluble) que inhiben el VEGF y el PlGF. Esto causa disfunci\xf3n endotelial sist\xe9mica: vasoconstricci\xf3n, aumento de la permeabilidad capilar, activaci\xf3n plaquetaria y del sistema de coagulaci\xf3n. La disfunci\xf3n endotelial multisist\xe9mica afecta el ri\xf1\xf3n (proteinuria), el h\xedgado (s\xedndrome HELLP), el cerebro (eclampsia) y la placenta (RCIU, desprendimiento).",signosYSintomas:{signos:["Hipertensi\xf3n: PAS \u2265140 mmHg o PAD \u226590 mmHg en dos ocasiones con 4h de intervalo, en embarazada >20 semanas","Proteinuria: \u2265300 mg/24h o cociente prote\xedna/creatinina \u22650.3","Edema especialmente de cara y manos (signo de alerta, no criterio diagn\xf3stico actual)","Cefalea intensa, fotofobia, escotomas (signos premonitorios de eclampsia)","Dolor en hipocondrio derecho (afectaci\xf3n hep\xe1tica en HELLP)","ECLAMPSIA: convulsiones t\xf3nico-cl\xf3nicas generalizadas (emergencia)","S\xcdNDROME HELLP: Hemolysis + Elevated Liver enzymes + Low Platelets (emergencia)","PA >160/110 mmHg (preeclampsia severa: inicio de tratamiento antihipertensivo urgente)","Desprendimiento de placenta normoinserta (hemorragia, dolor uterino, sufrimiento fetal)","Edema pulmonar","Deterioro visual s\xfabito (ceguera cortical)"],sintomas:["Oliguria (<500 mL/24h: disfunci\xf3n renal)","Clonus y reflejos osteotendinosos exaltados","Epigastralgia o n\xe1useas/v\xf3mitos","Trombocitopenia","Elevaci\xf3n de transaminasas (HELLP)"]},diagnostico:{anamnesis:["PA \u2265140/90 mmHg despu\xe9s de las 20 semanas m\xe1s proteinuria \u2265300 mg/24h","O PA \u2265140/90 mmHg m\xe1s trombocitopenia (<100,000), disfunci\xf3n renal (creatinina >1.1 mg/dL), elevaci\xf3n de transaminasas, edema pulmonar o s\xedntomas visuales o cerebrales","Preeclampsia severa: PA \u2265160/110 mmHg"],examenFisico:[],pruebas:[{nombre:"Tensi\xf3n arterial seriada (monitorizaci\xf3n continua)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Proteinuria en orina de 24h o cociente prote\xedna/creatinina en muestra",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Hemograma con plaquetas",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Funci\xf3n renal: creatinina, urea, \xe1cido \xfarico",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Perfil hep\xe1tico: AST, ALT, LDH (HELLP)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Frotis de sangre perif\xe9rica (esquistocitos en HELLP)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Tiempo de protrombina y TTPA",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Ecograf\xeda obst\xe9trica con Doppler de arterias umbilicales y uterinas",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Cardiotocograf\xeda fetal",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"sFlt-1/PlGF ratio (marcador predictivo y diagn\xf3stico)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]}]},tratamientoMedico:{objetivos:[],farmacologico:[{nombre:"Sulfato de Magnesio",grupo:"Antagonista del receptor",mecanismo:"Antagonista del receptor NMDA con actividad anticonvulsivante. Estabiliza la membrana neuronal y previene y trata las convulsiones ecl\xe1mpticas. Tambi\xe9n produce vasodilataci\xf3n cerebral. Es el tratamiento de elecci\xf3n para prevenci\xf3n y tratamiento de la eclampsia",dosis:"Dosis de carga: 4-6 g IV en 15-20 min. Mantenimiento: 1-2 g/h IV en infusi\xf3n continua (hasta 24-48h postparto). Si convulsi\xf3n durante la infusi\xf3n: 2 g IV en bolus",cuidadosEnfermeria:["MONITORIZAR TOXICIDAD CADA HORA: reflejos rotulianos (ausencia = toxicidad), FR >12/min, diuresis >25 mL/h","Tener GLUCONATO C\xc1LCICO 1 g IV preparado como ant\xeddoto (administrar si depresi\xf3n respiratoria)","Monitorizar niveles de Mg si disponible (rango terap\xe9utico: 4-7 mEq/L)","Suspender infusi\xf3n si: reflejos rotulianos ausentes, FR <12/min, diuresis <25 mL/h","Monitorizar signos vitales maternos y cardiotocograf\xeda fetal continua","No administrar calcio y sulfato de magnesio por la misma v\xeda"]},{nombre:"Labetalol IV",grupo:"Bloqueante adren\xe9rgico alfa",mecanismo:"Bloqueante adren\xe9rgico alfa y beta que reduce la resistencia vascular perif\xe9rica sin reducir el gasto card\xedaco ni el flujo uteroplacentario. De elecci\xf3n en urgencias hipertensivas del embarazo",dosis:"20 mg IV en bolus lento (2 min). Si no respuesta en 10 min: 40 mg IV. Si no respuesta: 80 mg IV. Dosis m\xe1xima acumulada: 300 mg. Alternativa: infusi\xf3n 1-2 mg/min",cuidadosEnfermeria:["Monitorizar PA cada 5 min durante la administraci\xf3n IV","Objetivo: PA <160/110 mmHg (no bajar demasiado r\xe1pido: riesgo de isquemia fetal)","Controlar FC materna y fetal","Contraindicado en asma, bloqueo card\xedaco, bradicardia","Observar hipotensi\xf3n supina: mantener en dec\xfabito lateral izquierdo","Informar al neonat\xf3logo si se us\xf3 labetalol (hipoglucemia e hipotensi\xf3n neonatal)"]},{nombre:"Nifedipino (Acci\xf3n Retardada)",grupo:"Antagonista del calcio",mecanismo:"Antagonista del calcio dihidropirid\xednico que produce vasodilataci\xf3n arteriolar perif\xe9rica. Segunda l\xednea en preeclampsia grave cuando el labetalol est\xe1 contraindicado. La formulaci\xf3n de liberaci\xf3n retardada previene hipotensi\xf3n brusca",dosis:"10-30 mg VO de liberaci\xf3n retardada cada 4-6h (no usar nifedipino de acci\xf3n r\xe1pida sublingual en embarazo: hipotensi\xf3n brusca con riesgo fetal)",cuidadosEnfermeria:["Usar SIEMPRE formulaci\xf3n de liberaci\xf3n retardada en el embarazo","NUNCA usar nifedipino sublingual en embarazo (hipotensi\xf3n brusca = isquemia fetal)","Monitorizar PA antes y 30 min despu\xe9s de cada dosis","Vigilar cefalea (posible diagn\xf3stico diferencial con cefalea ecl\xe1mptica)","Posible interacci\xf3n con sulfato de magnesio: mayor riesgo de hipotensi\xf3n y bloqueo neuromuscular"]}],noFarmacologico:["Finalizaci\xf3n del embarazo: \xfanica cura definitiva. Indicaciones urgentes: eclampsia, HELLP, preeclampsia grave con deterioro materno-fetal o >34 semanas","Hospitalizaci\xf3n para monitorizaci\xf3n materna y fetal","Maduraci\xf3n pulmonar fetal con corticoides si <34 semanas (betametasona 12 mg IM cada 24h \xd7 2 dosis)","Dec\xfabito lateral izquierdo (mejora el retorno venoso y el flujo uteroplacentario)","Control estricto de l\xedquidos (restricci\xf3n de volumen para evitar edema pulmonar)","Monitorizaci\xf3n fetal continua (cardiotocograf\xeda) ante preeclampsia severa"]},cuidadosEnfermeria:{valoracion:["Monitorizar PA cada 15-30 min en preeclampsia grave (continua en eclampsia)","Monitorizar diuresis horaria estrictamente (objetivo >25-30 mL/h)","Vigilar signos premonitorios de eclampsia: cefalea persistente, escotomas, epigastralgia","Evaluar edemas: generalizaci\xf3n, rapidez de aparici\xf3n","Monitorizar reflejos osteotendinosos (hiperreflexia = eclampsia inminente)","Monitorizaci\xf3n fetal continua (CTG)","Controlar laboratorio: plaquetas, transaminasas, LDH, creatinina (HELLP)"],intervenciones:["Restringir l\xedquidos a 80-100 mL/h (m\xe1ximo) para evitar edema pulmonar","Monitorizar diuresis horaria: objetivo m\xednimo 25-30 mL/h","Si oliguria: descartar intoxicaci\xf3n por magnesio antes de aumentar fluidoterapia","Controlar balance h\xeddrico estricto en preeclampsia grave","Vigilar signos de edema pulmonar: crepitantes basales, SatO2 descenso","Monitorizar PA cada 15-30 min en preeclampsia severa, cada 5 min si convulsi\xf3n","Objetivo de PA: 140-155/90-105 mmHg (no reducir bruscamente)","Monitorizar FCM (frecuencia card\xedaca materna) y fetal (CTG) continuamente","Monitorizar FR y SatO2 continuamente durante infusi\xf3n de MgSO4","Verificar reflejos rotulianos cada hora con MgSO4","Si convulsi\xf3n: colocar en posici\xf3n lateral de seguridad para proteger v\xeda a\xe9rea","Proteger a la paciente de lesiones durante la convulsi\xf3n (no sujetar con fuerza)","Administrar MgSO4 IV seg\xfan protocolo y gluconato c\xe1lcico si depresi\xf3n respiratoria","Llamar al equipo obst\xe9trico y neonatolog\xeda para preparar parto de urgencia","Monitorizar FCF durante y despu\xe9s de la convulsi\xf3n","Registrar tiempo, duraci\xf3n y caracter\xedsticas de la convulsi\xf3n"],educacionPaciente:["Explicar la gravedad de la situaci\xf3n de forma honesta pero sin provocar p\xe1nico","Ense\xf1ar los s\xedntomas de alarma que deben notificar INMEDIATAMENTE: cefalea intensa, visi\xf3n borrosa, dolor en barriga alta, convulsiones","Informar sobre el reposo en cama en dec\xfabito lateral izquierdo","Explicar que la \xfanica cura definitiva es el parto y preparar a la paciente para ello","Informar sobre el monitoreo continuo de la frecuencia card\xedaca fetal","Dar apoyo emocional y responder preguntas sobre el bienestar del beb\xe9"],monitorizacion:[]},npiNanda:[{codigo:"00032",nombre:"Patr\xf3n respiratorio ineficaz",definicion:"La inspiraci\xf3n y/o espiraci\xf3n no proporciona ventilaci\xf3n adecuada",caracteristicasDefinitorias:["FR <12/min","SatO2 disminuida","Incapacidad para mantener ventilaci\xf3n"],factoresRelacionados:["Depresi\xf3n respiratoria por sulfato de magnesio","Edema pulmonar"]},{codigo:"00029",nombre:"Disminuci\xf3n del gasto card\xedaco",definicion:"Cantidad de sangre bombeada por el coraz\xf3n en 1 minuto que es inadecuada",caracteristicasDefinitorias:["PA \u2265160/110 mmHg","Taquicardia","Edemas"],factoresRelacionados:["Hipertensi\xf3n severa","Vasoconstricci\xf3n sist\xe9mica"]},{codigo:"00146",nombre:"Ansiedad",definicion:"Sensaci\xf3n vaga e intranquilizadora de malestar o amenaza acompa\xf1ada de una respuesta auton\xf3mica",caracteristicasDefinitorias:["Expresi\xf3n de miedo y preocupaci\xf3n","Inquietud","Tensi\xf3n muscular"],factoresRelacionados:["Riesgo vital materno y fetal","Incertidumbre sobre el parto"]}],npiNic:[{codigo:"4120",nombre:"Manejo de l\xedquidos",actividades:["Restringir l\xedquidos a 80-100 mL/h (m\xe1ximo) para evitar edema pulmonar","Monitorizar diuresis horaria: objetivo m\xednimo 25-30 mL/h","Si oliguria: descartar intoxicaci\xf3n por magnesio antes de aumentar fluidoterapia","Controlar balance h\xeddrico estricto en preeclampsia grave","Vigilar signos de edema pulmonar: crepitantes basales, SatO2 descenso"]},{codigo:"6680",nombre:"Monitorizaci\xf3n de los signos vitales",actividades:["Monitorizar PA cada 15-30 min en preeclampsia severa, cada 5 min si convulsi\xf3n","Objetivo de PA: 140-155/90-105 mmHg (no reducir bruscamente)","Monitorizar FCM (frecuencia card\xedaca materna) y fetal (CTG) continuamente","Monitorizar FR y SatO2 continuamente durante infusi\xf3n de MgSO4","Verificar reflejos rotulianos cada hora con MgSO4"]},{codigo:"6450",nombre:"Manejo de la eclampsia",actividades:["Si convulsi\xf3n: colocar en posici\xf3n lateral de seguridad para proteger v\xeda a\xe9rea","Proteger a la paciente de lesiones durante la convulsi\xf3n (no sujetar con fuerza)","Administrar MgSO4 IV seg\xfan protocolo y gluconato c\xe1lcico si depresi\xf3n respiratoria","Llamar al equipo obst\xe9trico y neonatolog\xeda para preparar parto de urgencia","Monitorizar FCF durante y despu\xe9s de la convulsi\xf3n","Registrar tiempo, duraci\xf3n y caracter\xedsticas de la convulsi\xf3n"]}],npiNoc:[{codigo:"0401",nombre:"Estado circulatorio",indicadores:["PA controlada <160/110 mmHg","Diuresis adecuada","Sin signos de eclampsia"],escala:"Control de la PA por debajo de 160/110 mmHg y diuresis >25 mL/h durante todo el ingreso"},{codigo:"0111",nombre:"Crecimiento fetal",indicadores:["Frecuencia card\xedaca fetal en rango normal","Bienestar fetal en CTG","Crecimiento fetal adecuado en ecograf\xeda"],escala:"Bienestar fetal mantenido hasta la finalizaci\xf3n del embarazo"}],complicaciones:["Eclampsia (convulsiones)","S\xedndrome HELLP","Desprendimiento de placenta normoinserta","Edema pulmonar","Insuficiencia renal aguda","Hemorragia cerebral","CID","Mortalidad materna y perinatal"],criteriosAlarma:["ECLAMPSIA: convulsiones t\xf3nico-cl\xf3nicas generalizadas (emergencia)","S\xcdNDROME HELLP: Hemolysis + Elevated Liver enzymes + Low Platelets (emergencia)","PA >160/110 mmHg (preeclampsia severa: inicio de tratamiento antihipertensivo urgente)","Desprendimiento de placenta normoinserta (hemorragia, dolor uterino, sufrimiento fetal)","Edema pulmonar","Deterioro visual s\xfabito (ceguera cortical)"],emergencyLevel:"critico",relatedPathologyIds:[],isPremium:!1},{id:"pat_cancer_mama",nombre:"C\xe1ncer de Mama",bodySystemId:"reproductivo",definicion:"Neoplasia maligna originada en el epitelio ductal o lobulillar de la mama. Es el c\xe1ncer m\xe1s frecuente en mujeres. La supervivencia ha mejorado notablemente gracias al cribado mamogr\xe1fico y los tratamientos sist\xe9micos dirigidos (hormonoterapia, trastuzumab).",epidemiologia:"",factoresRiesgo:[],fisiopatologia:"El c\xe1ncer de mama resulta de mutaciones adquiridas (y ocasionalmente hereditarias: BRCA1, BRCA2) en genes que regulan el crecimiento celular. Los subtipos moleculares determinan el tratamiento: Luminal A/B (RE+ y/o RP+: hormonosensible, buen pron\xf3stico), HER2 enriquecido (amplificaci\xf3n de HER2: diana de trastuzumab), Triple negativo (RE-, RP-, HER2-: peor pron\xf3stico, solo quimioterapia). El c\xe1ncer invasivo rompe la membrana basal e infiltra el estroma mamario. La diseminaci\xf3n ocurre por v\xeda linf\xe1tica (ganglios axilares) y hemat\xf3gena (hueso, pulm\xf3n, h\xedgado, cerebro).",signosYSintomas:{signos:["N\xf3dulo mamario indoloro de consistencia dura e irregular","Cambio en el contorno o tama\xf1o de la mama","Retracci\xf3n del pez\xf3n o de la piel (piel de naranja: carcinoma inflamatorio)","Secreci\xf3n sanguinolenta por el pez\xf3n","Adenopat\xedas axilares ipsilaterales","Carcinoma inflamatorio: mama eritematosa y tensa (puede confundirse con mastitis: no mejorar con antibi\xf3ticos sin biopsia)","N\xf3dulo axilar palpable en joven sin masa mamaria (c\xe1ncer oculto)","Fractura patol\xf3gica o hipercalcemia (met\xe1stasis \xf3seas)","Disnea por derrame pleural maligno","Focalidad neurol\xf3gica (met\xe1stasis cerebrales)"],sintomas:["Dolor mamario (en estadios avanzados o carcinoma inflamatorio)","Enrojecimiento y calor de toda la mama (carcinoma inflamatorio)","Ulceraci\xf3n de la piel en estadios muy avanzados","S\xedntomas de met\xe1stasis: dolor \xf3seo, disnea, hepatomegalia"]},diagnostico:{anamnesis:["Triple test diagn\xf3stico: exploraci\xf3n cl\xednica + imagen (mamograf\xeda/ecograf\xeda) + biopsia percut\xe1nea","Biopsia con aguja gruesa (BAG): histolog\xeda e inmunohistoqu\xedmica (RE, RP, HER2, Ki67)","Estadificaci\xf3n TNM: T (tama\xf1o tumor), N (ganglios), M (met\xe1stasis)","Perfil molecular: Luminal A/B, HER2+, Triple negativo"],examenFisico:[],pruebas:[{nombre:"Mamograf\xeda bilateral (cribado y diagn\xf3stico)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Ecograf\xeda mamaria (complementaria a mamograf\xeda, indicada en <35 a\xf1os o mama densa)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"RMN de mama (alto riesgo BRCA, estadificaci\xf3n local en casos seleccionados)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Biopsia con aguja gruesa (BAG) guiada por imagen",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"TC de t\xf3rax, abdomen y pelvis (estadificaci\xf3n sist\xe9mica)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Gammagraf\xeda \xf3sea (si s\xedntomas o estadio II-III)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"PET-TC (estadificaci\xf3n si ganglios o sospecha de met\xe1stasis)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Test gen\xe9tico: BRCA1 y BRCA2 en j\xf3venes con antecedentes familiares",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Ca 15.3 (marcador tumoral, seguimiento no diagn\xf3stico)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]}]},tratamientoMedico:{objetivos:[],farmacologico:[{nombre:"Trastuzumab",grupo:"Anticuerpo monoclonal anti-HER2",mecanismo:"Anticuerpo monoclonal anti-HER2 que se une al dominio extracelular del receptor HER2, bloqueando su activaci\xf3n y se\xf1alizaci\xf3n proliferativa. Activa tambi\xe9n mecanismos de citotoxicidad celular mediada por anticuerpos (ADCC). Solo eficaz en tumores HER2 amplificados (HER2+)",dosis:"Dosis de carga: 8 mg/kg IV. Mantenimiento: 6 mg/kg IV cada 3 semanas durante 1 a\xf1o (adyuvancia). En metast\xe1sico: continuar hasta progresi\xf3n o toxicidad",cuidadosEnfermeria:["Controlar FEVI (fracci\xf3n de eyecci\xf3n del VI) con ecocardiograma antes de iniciar y cada 3 meses","Suspender si FEVI cae >10% por debajo del l\xedmite normal o >16% respecto al basal","Premedicar con paracetamol y antihistam\xednico (reacciones infusionales, especialmente primera dosis)","Iniciar la primera infusi\xf3n lentamente (90 min); las posteriores pueden administrarse en 30 min","Vigilar s\xedntomas de insuficiencia card\xedaca: disnea, ortopnea, edemas"]},{nombre:"Letrozol",grupo:"Inhibidor de la",mecanismo:"Inhibidor de la aromatasa de 3\xaa generaci\xf3n que bloquea la conversi\xf3n de andr\xf3genos suprarrenales en estr\xf3genos en tejido perif\xe9rico (no en ovario). Reduce los niveles de estr\xf3genos en mujeres postmenop\xe1usicas, privando al tumor hormonosensible de su est\xedmulo de crecimiento",dosis:"2.5 mg VO una vez al d\xeda. Tratamiento durante 5-10 a\xf1os en adyuvancia (previene recurrencias en tumores RE+)",cuidadosEnfermeria:["Monitorizar densidad \xf3sea (DXA) basal y anualmente (riesgo de osteoporosis)","Suplementar con calcio 1000-1200 mg/d\xeda y vitamina D 800-1000 UI/d\xeda","Informar sobre artralgias (frecuentes, suelen mejorar con el tiempo y ejercicio)","Solo eficaz en mujeres postmenop\xe1usicas o en premenop\xe1usicas con supresi\xf3n ov\xe1rica concomitante","Vigilar perfil lip\xeddico peri\xf3dicamente"]},{nombre:"Paclitaxel",grupo:"Taxano que estabiliza",mecanismo:"Taxano que estabiliza los microt\xfabulos impidiendo su depolimerizaci\xf3n, bloqueando la mitosis en metafase y causando apoptosis de c\xe9lulas en proliferaci\xf3n. Utilizado en quimioterapia adyuvante, neoadyuvante o metast\xe1sico en m\xfaltiples subtipos",dosis:"80 mg/m2 IV semanal (paclitaxel nab) o 175 mg/m2 IV cada 3 semanas. Premedicar con corticoides, antihistam\xednicos y bloqueantes H2",cuidadosEnfermeria:["Premedicaci\xf3n 30 min antes: dexametasona IV + difenhidramina IV + ranitidina IV (previene reacciones de hipersensibilidad)","Evaluar neuropat\xeda perif\xe9rica antes de cada ciclo (parestesias, debilidad distal): reducir dosis si NCI grade \u22652","Administrar en materiales no PVC (el paclitaxel absorbe el DEHP del PVC)","Monitorizar signos de reacci\xf3n de hipersensibilidad durante los primeros 10 min","Informar sobre alopecia: es reversible tras finalizar el tratamiento"]}],noFarmacologico:["Cirug\xeda: conservadora (tumorectom\xeda) o mastectom\xeda + biopsia del ganglio centinela o linfadenectom\xeda axilar","Radioterapia: post-cirug\xeda conservadora o en estadios localmente avanzados","Reconstrucci\xf3n mamaria inmediata o diferida tras mastectom\xeda","Rehabilitaci\xf3n linfedema: drenaje linf\xe1tico, compresi\xf3n si linfadenectom\xeda axilar","Fisioterapia: ejercicios de movilidad del hombro post-cirug\xeda","Apoyo psicol\xf3gico: impacto en imagen corporal y calidad de vida","Consejo gen\xe9tico si sospecha de mutaci\xf3n BRCA"]},cuidadosEnfermeria:{valoracion:["Valorar el estadio del tumor y el plan de tratamiento","Evaluar el estado emocional: impacto en la imagen corporal, miedo a la muerte","Monitorizar efectos adversos del tratamiento: neuropat\xeda, mielosupresi\xf3n, cardiotoxicidad","Evaluar la herida quir\xfargica post-mastectom\xeda","Detectar linfedema de brazo (circunferencia del brazo)","Valorar estado nutricional durante la quimioterapia","Revisar adherencia a la hormonoterapia (tratamiento de 5-10 a\xf1os)"],intervenciones:["Crear espacio para que la paciente exprese sus miedos sobre la enfermedad y el tratamiento","Abordar la preocupaci\xf3n por la imagen corporal (mastectom\xeda, alopecia)","Derivar a psicooncolog\xeda si hay depresi\xf3n significativa o crisis de adaptaci\xf3n","Informar sobre grupos de apoyo de c\xe1ncer de mama","Involucrar a la pareja y la familia (con el consentimiento de la paciente)","Cuidado de la herida quir\xfargica post-mastectom\xeda/cirug\xeda conservadora con t\xe9cnica as\xe9ptica","Controlar el drenaje (Jackson-Pratt): cantidad y caracter\xedsticas del drenado","Retirar los drenajes seg\xfan protocolo (habitualmente cuando producen <30 mL/d\xeda)","Vigilar signos de infecci\xf3n: eritema, exudado purulento, fiebre","Iniciar ejercicios de hombro a las 24-48h post-cirug\xeda (cuando lo autorice el cirujano)","Posicionar el brazo del lado operado levemente elevado (previene edema postquir\xfargico inicial)","Ense\xf1ar los ejercicios de movilizaci\xf3n del hombro progresivos","Instruir sobre la prevenci\xf3n del linfedema: no pinchazos ni tomas de PA en el brazo operado","Recomendar el uso de guantes en trabajos dom\xe9sticos para evitar heridas en el brazo del lado operado"],educacionPaciente:["Explicar el diagn\xf3stico y el plan terap\xe9utico de forma honesta y comprensible","Instruir sobre los cuidados de la herida quir\xfargica y el drenaje en domicilio","Ense\xf1ar los ejercicios de movilidad del hombro y el programa de rehabilitaci\xf3n","Informar sobre la prevenci\xf3n del linfedema: no pinchazos ni tomas de PA en el brazo operado","Explicar los efectos adversos del tratamiento sist\xe9mico (hormonoterapia, quimioterapia)","Hablar sobre los recursos de apoyo: asociaciones de c\xe1ncer de mama, grupos de pares","Informar sobre el seguimiento a largo plazo: mamograf\xedas, an\xe1lisis, FEVI"],monitorizacion:[]},npiNanda:[{codigo:"00053",nombre:"Aislamiento social",definicion:"Soledad experimentada como negativa e impuesta por otros",caracteristicasDefinitorias:["Retraimiento social","Expresi\xf3n de sentirse diferente","Evitaci\xf3n de relaciones \xedntimas"],factoresRelacionados:["Cambio en la imagen corporal","Mastectom\xeda","Alopecia"]},{codigo:"00004",nombre:"Riesgo de infecci\xf3n",definicion:"Vulnerable a infecci\xf3n por mielosupresi\xf3n",caracteristicasDefinitorias:[],factoresRelacionados:["Neutropenia por quimioterapia","Linfadenectom\xeda axilar"]},{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable postquir\xfargica",caracteristicasDefinitorias:["Dolor en regi\xf3n mamaria y axilar","Parestesias postquir\xfargicas"],factoresRelacionados:["Cirug\xeda mamaria y axilar","Tensi\xf3n tisular"]}],npiNic:[{codigo:"5270",nombre:"Apoyo emocional",actividades:["Crear espacio para que la paciente exprese sus miedos sobre la enfermedad y el tratamiento","Abordar la preocupaci\xf3n por la imagen corporal (mastectom\xeda, alopecia)","Derivar a psicooncolog\xeda si hay depresi\xf3n significativa o crisis de adaptaci\xf3n","Informar sobre grupos de apoyo de c\xe1ncer de mama","Involucrar a la pareja y la familia (con el consentimiento de la paciente)"]},{codigo:"3660",nombre:"Cuidados de las heridas",actividades:["Cuidado de la herida quir\xfargica post-mastectom\xeda/cirug\xeda conservadora con t\xe9cnica as\xe9ptica","Controlar el drenaje (Jackson-Pratt): cantidad y caracter\xedsticas del drenado","Retirar los drenajes seg\xfan protocolo (habitualmente cuando producen <30 mL/d\xeda)","Vigilar signos de infecci\xf3n: eritema, exudado purulento, fiebre","Iniciar ejercicios de hombro a las 24-48h post-cirug\xeda (cuando lo autorice el cirujano)"]},{codigo:"0840",nombre:"Cambio de posici\xf3n",actividades:["Posicionar el brazo del lado operado levemente elevado (previene edema postquir\xfargico inicial)","Ense\xf1ar los ejercicios de movilizaci\xf3n del hombro progresivos","Instruir sobre la prevenci\xf3n del linfedema: no pinchazos ni tomas de PA en el brazo operado","Recomendar el uso de guantes en trabajos dom\xe9sticos para evitar heridas en el brazo del lado operado"]}],npiNoc:[{codigo:"1402",nombre:"Autocontrol de la ansiedad",indicadores:["Expresi\xf3n de afrontamiento eficaz","Mantenimiento de relaciones sociales","Participaci\xf3n en la toma de decisiones terap\xe9uticas"],escala:"Paciente verbaliza afrontamiento adecuado del diagn\xf3stico y plan de tratamiento en 2-4 semanas"},{codigo:"1103",nombre:"Curaci\xf3n de la herida: por primera intenci\xf3n",indicadores:["Herida cerrada sin signos de infecci\xf3n","Drenaje m\xednimo","Sin seromas ni hematomas"],escala:"Cicatrizaci\xf3n de la herida quir\xfargica sin complicaciones en 2-3 semanas"}],complicaciones:["Linfedema del brazo (linfadenectom\xeda axilar)","Cardiotoxicidad por trastuzumab o antraciclinas","Neuropat\xeda perif\xe9rica por taxanos","Met\xe1stasis \xf3seas, cerebrales, hep\xe1ticas o pulmonares","Osteoporosis por inhibidores de aromatasa","Depresi\xf3n y s\xedndrome de adaptaci\xf3n","Infertilidad post-quimioterapia en mujeres j\xf3venes"],criteriosAlarma:["Carcinoma inflamatorio: mama eritematosa y tensa (puede confundirse con mastitis: no mejorar con antibi\xf3ticos sin biopsia)","N\xf3dulo axilar palpable en joven sin masa mamaria (c\xe1ncer oculto)","Fractura patol\xf3gica o hipercalcemia (met\xe1stasis \xf3seas)","Disnea por derrame pleural maligno","Focalidad neurol\xf3gica (met\xe1stasis cerebrales)"],emergencyLevel:"moderado",relatedPathologyIds:[],isPremium:!1},{id:"pat_endometriosis",nombre:"Endometriosis",bodySystemId:"reproductivo",definicion:"Enfermedad cr\xf3nica inflamatoria caracterizada por la presencia de tejido endometrial (gl\xe1ndulas y estroma) fuera del \xfatero. Afecta al 10% de las mujeres en edad reproductiva. Causa dismenorrea incapacitante, dispareunia, dolor p\xe9lvico cr\xf3nico e infertilidad.",epidemiologia:"",factoresRiesgo:[],fisiopatologia:"La teor\xeda m\xe1s aceptada es la menstruaci\xf3n retr\xf3grada (Sampson): el tejido endometrial refluye por las trompas al peritoneo durante la menstruaci\xf3n. En mujeres susceptibles (por factores inmunol\xf3gicos y gen\xe9ticos), este tejido implanta y prolifera bajo la influencia de los estr\xf3genos. Los implantes producen inflamaci\xf3n local cr\xf3nica, adherencias y fibrosis. Los endometriomas ov\xe1ricos ('quistes de chocolate') son acumulaciones de sangre menstrual encapsulada. La infiltraci\xf3n de nervios explica el dolor neurop\xe1tico. La infertilidad resulta de la distorsi\xf3n de la anatom\xeda p\xe9lvica, la toxicidad del l\xedquido peritoneal sobre los gametos y la disfunci\xf3n inmunol\xf3gica.",signosYSintomas:{signos:["Dismenorrea progresiva que comienza d\xedas antes de la menstruaci\xf3n (no responde a AINE)","Dispareunia profunda (dolor con penetraci\xf3n profunda)","Dolor p\xe9lvico cr\xf3nico no c\xedclico","Infertilidad (30-50% de mujeres con endometriosis)","Disquecia (dolor al defecar en menstruaci\xf3n): implantes en tabique rectovaginal","Endometrioma roto (dolor p\xe9lvico agudo intenso: urgencia quir\xfargica)","Torsi\xf3n ov\xe1rica con endometrioma","Obstrucci\xf3n ureteral con hidronefrosis","Oclusi\xf3n intestinal por endometriosis profunda","Afectaci\xf3n diafragm\xe1tica con neumot\xf3rax catamenial"],sintomas:["Disuria c\xedclica (afectaci\xf3n vesical)","Hematuria c\xedclica (endometriosis vesical)","Rectorragia c\xedclica (afectaci\xf3n intestinal)","Fatiga cr\xf3nica","Impacto en calidad de vida: laborel, sexual, reproductivo"]},diagnostico:{anamnesis:["Diagn\xf3stico definitivo: laparoscopia con biopsia de los implantes","Diagn\xf3stico cl\xednico presuntivo: s\xedntomas t\xedpicos + ecograf\xeda sugestiva","Ecograf\xeda transvaginal: endometriomas (quiste con contenido homog\xe9neo 'vidrio esmerilado')","RMN p\xe9lvica: endometriosis profunda infiltrante (DIE: tabique rectovaginal, vejiga, ur\xe9ter)"],examenFisico:[],pruebas:[{nombre:"Ecograf\xeda transvaginal (de elecci\xf3n para endometriomas ov\xe1ricos)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"RMN p\xe9lvica con y sin gadolinio (endometriosis profunda infiltrante)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"CA-125 s\xe9rico (elevado en endometriosis grave, baja especificidad)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Laparoscopia diagn\xf3stica y terap\xe9utica (gold standard)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Cistoscopia y colonoscopia si sospecha afectaci\xf3n vesical o intestinal",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Evaluaci\xf3n de fertilidad: reserva ov\xe1rica (AMH, FSH, antrum count)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]}]},tratamientoMedico:{objetivos:[],farmacologico:[{nombre:"Dienogest",grupo:"Progest\xe1geno sint\xe9tico de",mecanismo:"Progest\xe1geno sint\xe9tico de 4\xaa generaci\xf3n con alta selectividad por el receptor de progesterona uterino. Suprime el tejido endometri\xf3sico mediante inhibici\xf3n de la proliferaci\xf3n glandular y efecto anti-inflamatorio local. Provoca pseudodecidualizaci\xf3n y atrofia de los implantes. Crea un estado de hipoestrogenismo moderado",dosis:"2 mg VO una vez al d\xeda de forma continua (sin pausas). Tratamiento hasta el deseo de embarazo, menopausia o cambio de tratamiento",cuidadosEnfermeria:["Advertir sobre el sangrado irregular en los primeros meses (es esperado, no motivo de suspensi\xf3n)","Evaluar estado emocional y humor en cada visita (posible depresi\xf3n)","Recomendar DXA basal si uso >5 a\xf1os (control de densidad \xf3sea)","Informar que NO es anticonceptivo fiable en todos los reg\xedmenes","Explicar que el dolor puede persistir las primeras semanas hasta que el f\xe1rmaco hace efecto"]},{nombre:"Leuprolide (An\xe1logo GnRH)",grupo:"Agonista de la",mecanismo:"Agonista de la GnRH que tras estimulaci\xf3n inicial provoca down-regulation de los receptores hipofisarios de GnRH, suprimiendo la secreci\xf3n de LH y FSH. Esto genera una menopausia m\xe9dica reversible con hipoestrogenismo profundo que suprime el tejido endometri\xf3sico",dosis:"3.75 mg IM mensual o 11.25 mg IM trimestral (depot). M\xe1ximo 6 meses sin add-back. Con add-back hormonal (TH de baja dosis) puede usarse m\xe1s tiempo",cuidadosEnfermeria:["Informar sobre el efecto flare inicial (las primeras 2 semanas puede empeorar el dolor: es esperado)","Recomendar o prescribir add-back hormonal (estr\xf3geno en dosis bajas) para limitar la p\xe9rdida \xf3sea","Monitorizar DXA si tratamiento >6 meses","Suplementar calcio y vitamina D durante el tratamiento","Informar que la menstruaci\xf3n vuelve 2-3 meses despu\xe9s de suspender"]},{nombre:"Ibuprofeno",grupo:"AINE inhibidor de",mecanismo:"AINE inhibidor de COX que reduce la s\xedntesis de prostaglandinas, mediadores clave en la fisiopatolog\xeda del dolor menstrual y la inflamaci\xf3n peritoneal de la endometriosis",dosis:"400-600 mg VO cada 6-8h con alimentos, comenzar 1-2 d\xedas antes de la menstruaci\xf3n (analgesia anticipatoria)",cuidadosEnfermeria:["Recomendar tomar con alimentos","Usar siempre con protecci\xf3n g\xe1strica (omeprazol 20 mg)","Evitar en embarazo y si intenci\xf3n de embarazo a corto plazo (inhibici\xf3n de ovulaci\xf3n y implantaci\xf3n)"]}],noFarmacologico:["Cirug\xeda laparosc\xf3pica: ex\xe9resis de implantes, endometriomectom\xeda, adhesiolisis","Cirug\xeda en endometriosis profunda: resecci\xf3n intestinal, ureteral o vesical si afectaci\xf3n org\xe1nica","T\xe9cnicas de reproducci\xf3n asistida (FIV) para infertilidad asociada","Fisioterapia del suelo p\xe9lvico para el dolor p\xe9lvico cr\xf3nico","Terapia psicol\xf3gica multidisciplinar (impacto en calidad de vida y relaciones)"]},cuidadosEnfermeria:{valoracion:["Evaluar intensidad del dolor con EVA (dismenorrea, dispareunia, dolor p\xe9lvico cr\xf3nico)","Valorar el impacto en la calidad de vida: laboral, social, sexual (EHP-5 o EHP-30)","Evaluar el deseo reproductivo y las opciones de fertilidad","Revisar la adherencia al tratamiento hormonal","Valorar el estado emocional: depresi\xf3n y ansiedad son frecuentes","Evaluar efectos secundarios del tratamiento (spotting, s\xedndrome climat\xe9rico)"],intervenciones:["Ense\xf1ar la analgesia anticipatoria: tomar AINE 1-2 d\xedas antes de la menstruaci\xf3n esperada","Calor local (bolsa de agua caliente) en hipogastrio durante la dismenorrea: reducci\xf3n del espasmo","Evaluar la eficacia del tratamiento hormonal en la reducci\xf3n del dolor","Derivar a unidad del dolor si dolor cr\xf3nico refractario","Coordinar con fisioterapeuta de suelo p\xe9lvico para manejo multidisciplinar del dolor","Validar el impacto del dolor cr\xf3nico en la vida diaria (normalizar la experiencia)","Abordar el retraso diagn\xf3stico medio de 7-10 a\xf1os (frustraci\xf3n acumulada)","Derivar a psicolog\xeda si hay depresi\xf3n significativa","Informar sobre asociaciones de endometriosis para apoyo entre iguales","Abordar las preocupaciones sobre la fertilidad con informaci\xf3n realista"],educacionPaciente:["Explicar la enfermedad y su naturaleza cr\xf3nica (gesti\xf3n a largo plazo, no cura definitiva excepto menopausia)","Insistir en que el dolor menstrual grave NO es normal: buscar diagn\xf3stico y tratamiento","Informar sobre la importancia del tratamiento hormonal continuo para controlar los s\xedntomas","Abordar las opciones de fertilidad y la importancia de no posponer el embarazo si hay deseo reproductivo","Ofrecer informaci\xf3n sobre asociaciones de endometriosis"],monitorizacion:[]},npiNanda:[{codigo:"00132",nombre:"Dolor agudo/cr\xf3nico",definicion:"Experiencia sensitiva y emocional desagradable",caracteristicasDefinitorias:["Dismenorrea grave","Dispareunia","Dolor p\xe9lvico cr\xf3nico"],factoresRelacionados:["Implantes endometri\xf3sicos","Inflamaci\xf3n peritoneal","Adherencias","Neuropat\xeda p\xe9lvica"]},{codigo:"00199",nombre:"Planificaci\xf3n ineficaz de actividades",definicion:"Incapacidad para prepararse para una serie de acciones fijadas en el tiempo",caracteristicasDefinitorias:["Absentismo laboral","Evitaci\xf3n de actividades por miedo al dolor"],factoresRelacionados:["Dolor cr\xf3nico incapacitante","Incertidumbre sobre la fertilidad"]},{codigo:"00093",nombre:"Fatiga",definicion:"Sensaci\xf3n abrumadora y sostenida de agotamiento",caracteristicasDefinitorias:["Cansancio persistente","Incapacidad para mantener actividades habituales"],factoresRelacionados:["Dolor cr\xf3nico","Anemia por menorragia","Inflamaci\xf3n cr\xf3nica"]}],npiNic:[{codigo:"1400",nombre:"Manejo del dolor",actividades:["Ense\xf1ar la analgesia anticipatoria: tomar AINE 1-2 d\xedas antes de la menstruaci\xf3n esperada","Calor local (bolsa de agua caliente) en hipogastrio durante la dismenorrea: reducci\xf3n del espasmo","Evaluar la eficacia del tratamiento hormonal en la reducci\xf3n del dolor","Derivar a unidad del dolor si dolor cr\xf3nico refractario","Coordinar con fisioterapeuta de suelo p\xe9lvico para manejo multidisciplinar del dolor"]},{codigo:"5270",nombre:"Apoyo emocional",actividades:["Validar el impacto del dolor cr\xf3nico en la vida diaria (normalizar la experiencia)","Abordar el retraso diagn\xf3stico medio de 7-10 a\xf1os (frustraci\xf3n acumulada)","Derivar a psicolog\xeda si hay depresi\xf3n significativa","Informar sobre asociaciones de endometriosis para apoyo entre iguales","Abordar las preocupaciones sobre la fertilidad con informaci\xf3n realista"]}],npiNoc:[{codigo:"2102",nombre:"Nivel del dolor",indicadores:["EVA de dismenorrea","D\xedas de baja laboral por dolor","Impacto en vida sexual"],escala:"Reducci\xf3n de la intensidad de la dismenorrea de EVA 8-9 a \u22644 con tratamiento hormonal en 3-6 meses"}],complicaciones:["Infertilidad","Endometrioma ov\xe1rico roto (urgencia)","Obstrucci\xf3n intestinal o ureteral","Adherencias p\xe9lvicas severas","Transformaci\xf3n maligna (raro: carcinoma de c\xe9lulas claras, carcinoma endometrioide)","Depresi\xf3n y disfunci\xf3n sexual cr\xf3nica"],criteriosAlarma:["Endometrioma roto (dolor p\xe9lvico agudo intenso: urgencia quir\xfargica)","Torsi\xf3n ov\xe1rica con endometrioma","Obstrucci\xf3n ureteral con hidronefrosis","Oclusi\xf3n intestinal por endometriosis profunda","Afectaci\xf3n diafragm\xe1tica con neumot\xf3rax catamenial"],emergencyLevel:"leve",relatedPathologyIds:[],isPremium:!0},{id:"pat_ets",nombre:"Infecciones de Transmisi\xf3n Sexual (ITS)",bodySystemId:"reproductivo",definicion:"Grupo heterog\xe9neo de infecciones transmitidas principalmente por contacto sexual. Las m\xe1s prevalentes incluyen s\xedfilis, gonorrea, clamidia, herpes genital y VPH. Pueden causar complicaciones graves: enfermedad inflamatoria p\xe9lvica (EIP), infertilidad, transmisi\xf3n vertical y mayor riesgo de VIH.",epidemiologia:"",factoresRiesgo:[],fisiopatologia:"Cada ITS tiene fisiopatolog\xeda espec\xedfica. La s\xedfilis (Treponema pallidum) produce ulceraci\xf3n (chancro) en el punto de inoculaci\xf3n; si no se trata, la bacteriemia sifil\xedtica disemina el Treponema a m\xfaltiples \xf3rganos (s\xedfilis secundaria, terciaria). La gonorrea (Neisseria gonorrhoeae) infecta el epitelio cil\xedndrico (uretra, c\xe9rvix, recto, faringe); la diseminaci\xf3n puede causar artritis gonoc\xf3cica. La clamidia (Chlamydia trachomatis) puede ser asintom\xe1tica, pero la infecci\xf3n cr\xf3nica desencadena cicatrizaci\xf3n tub\xe1rica con riesgo de embarazo ect\xf3pico e infertilidad. El HPV puede causar condilomas acuminados (tipos 6,11) o neoplasia cervical (tipos 16,18: oncog\xe9nicos).",signosYSintomas:{signos:["S\xcdFILIS: Chancro indoloro en punto de inoculaci\xf3n (1aria), exantema palmo-plantar + condilomas planos (2aria)","GONORREA: Uretritis con exudado purulento, cervicitis, faringitis, proctitis","CLAMIDIA: Frecuentemente asintom\xe1tica; uretritis, cervicitis, EIP silente","HERPES GENITAL: Ves\xedculas/\xfalceras dolorosas en genitales, con primoinfecci\xf3n grave (fiebre, adenopat\xedas)","VPH: Condilomas acuminados (tipos no oncog\xe9nicos), displasia cervical/neoplasia (tipos 16, 18)","Neuros\xedfilis: cl\xednica neurol\xf3gica, psiqui\xe1trica o cardiovascular (s\xedfilis terciaria tard\xeda)","S\xedfilis cong\xe9nita: transmisi\xf3n vertical con afectaci\xf3n multisist\xe9mica del neonato","EIP grave con absceso tuboov\xe1rico (requiere hospitalizaci\xf3n y posible cirug\xeda)","Gonorrea diseminada: artritis, dermatitis, meningitis","S\xedfilis secundaria: exantema palmo-plantar (alta carga infecciosa)"],sintomas:["Dispareunia y disuria","Flujo vaginal o uretral an\xf3malo","Ulceraci\xf3n genital (herpes, s\xedfilis, linfogranuloma ven\xe9reo)","Artritis reactiva (s\xedndrome de Reiter: artritis + uretritis + conjuntivitis)","Enfermedad inflamatoria p\xe9lvica: dolor p\xe9lvico, fiebre, flujo vaginal purulento"]},diagnostico:{anamnesis:["S\xcdFILIS: RPR o VDRL (cribado) + TPHA/FTA-Abs (confirmatorio)","GONORREA: Cultivo exudado + PCR/NAAT (amplificaci\xf3n de \xe1cidos nucleicos)","CLAMIDIA: PCR/NAAT en muestra uretral/cervical/rectal (gold standard)","HERPES: PCR del exudado vesicular o cultivo viral","VPH: Citolog\xeda cervical + colposcopia + biopsia si lesi\xf3n; genotipado VPH oncog\xe9nico"],examenFisico:[],pruebas:[{nombre:"Serolog\xeda s\xedfilis (RPR, TPHA, FTA-Abs)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"PCR/NAAT para Chlamydia trachomatis y Neisseria gonorrhoeae (primer objetivo, primera orina o hisopo)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"PCR herpes simplex 1 y 2",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Serolog\xeda VIH (siempre en el contexto de ITS)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Serolog\xeda hepatitis B y C",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Citolog\xeda cervical + genotipado VPH oncog\xe9nico",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Hemocultivos si gonorrea diseminada",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Punci\xf3n lumbar si sospecha neuros\xedfilis",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]}]},tratamientoMedico:{objetivos:[],farmacologico:[{nombre:"Penicilina G Benzatina",grupo:"Penicilina de acci\xf3n",mecanismo:"Penicilina de acci\xf3n prolongada que inhibe la s\xedntesis de pared celular de Treponema pallidum. Mantiene niveles treponemicidas durante 3-4 semanas con una sola inyecci\xf3n",dosis:"S\xedfilis precoz (primaria, secundaria, latente precoz): 2.4 millones UI IM dosis \xfanica. S\xedfilis latente tard\xeda o terciaria: 2.4 millones UI IM semana 1, 2 y 3 (3 dosis). Neuros\xedfilis: penicilina G s\xf3dica IV 4 millones UI cada 4h \xd7 10-14 d\xedas",cuidadosEnfermeria:["Informar sobre la reacci\xf3n de Jarisch-Herxheimer: es esperada en las primeras 24h, tratar con antipir\xe9ticos y antihistam\xednicos","Preguntar historia de alergia a penicilinas antes de administrar (anafilaxia posible)","Administrar en m\xfasculo grande (gl\xfateo) con aguja IM larga (benzatina es muy viscosa)","Explicar la importancia de notificar y tratar a las parejas sexuales","Verificar serolog\xeda de control a los 3, 6 y 12 meses (seguimiento de curaci\xf3n)"]},{nombre:"Ceftriaxona + Azitromicina",grupo:"Tratamiento de la",mecanismo:"Tratamiento de la gonorrea sin sensibilidad testada. Ceftriaxona: cefalosporina de 3\xaa generaci\xf3n activa frente a N. gonorrhoeae (incluyendo la mayor\xeda de cepas con resistencias a fluoroquinolonas). Azitromicina: macr\xf3lido que cubre la posible coinfecci\xf3n por Chlamydia trachomatis",dosis:"Ceftriaxona 500 mg IM dosis \xfanica + Azitromicina 1 g VO dosis \xfanica. Si >150 kg: ceftriaxona 1 g IM",cuidadosEnfermeria:["Administrar ceftriaxona IM (diluir con lidoca\xedna 1% para reducir el dolor de inyecci\xf3n)","No administrar azitromicina si QTc prolongado en ECG","Insistir en tratar a las parejas sexuales (gonorrea es de declaraci\xf3n obligatoria)","Repetir PCR de control en 3-4 semanas (verificar curaci\xf3n)","Educar sobre el uso del preservativo"]},{nombre:"Aciclovir (Herpes Genital)",grupo:"An\xe1logo de nucle\xf3sido",mecanismo:"An\xe1logo de nucle\xf3sido que inhibe la ADN polimerasa del VHS, bloqueando la replicaci\xf3n viral. Aciclovir fosforilado por la timidina quinasa viral solo en c\xe9lulas infectadas (alta selectividad)",dosis:"Primoinfecci\xf3n: 400 mg VO cada 8h \xd7 7-10 d\xedas. Recurrencia: 800 mg VO cada 8h \xd7 5 d\xedas. Profilaxis: 400 mg VO cada 12h (para pacientes con >6 recurrencias/a\xf1o o para reducir transmisi\xf3n a pareja negativa)",cuidadosEnfermeria:["Insistir en iniciar el tratamiento precozmente (pr\xf3dromos o primeras 72h)","Buena hidrataci\xf3n para evitar cristaluria especialmente con IV","Explicar que el tratamiento supresivo reduce pero no elimina el riesgo de transmisi\xf3n","El paciente con herpes sigue siendo contagioso incluso sin lesiones visibles (excreci\xf3n viral asintom\xe1tica)","Preservativo reduce pero no elimina el riesgo de transmisi\xf3n"]}],noFarmacologico:["Uso consistente y correcto del preservativo (cond\xf3n masculino o femenino)","Reducci\xf3n del n\xfamero de parejas sexuales","Vacunaci\xf3n VPH (Gardasil 9): ni\xf1as y ni\xf1os 9-26 a\xf1os, adultos j\xf3venes no vacunados hasta 45 a\xf1os","Vacunaci\xf3n hepatitis B","Notificaci\xf3n y tratamiento de parejas sexuales (contact tracing)","Cribado rutinario en grupos de riesgo (cribado MSM, trabajadores sexuales, adolescentes activos)","PrEP para VIH en personas de alto riesgo"]},cuidadosEnfermeria:{valoracion:["Realizar historia sexual confidencial y sin juicios: tipo de contactos, uso de preservativo, n\xfamero de parejas","Evaluar s\xedntomas genitales y sist\xe9micos","Valorar estado emocional: culpa, verg\xfcenza, miedo al estigma","Revisar historia de ITS previas y vacunaciones","Evaluar el riesgo de VIH y otras ITS concomitantes","Valorar situaci\xf3n de violencia sexual si procede"],intervenciones:["Ense\xf1ar el uso correcto del preservativo: colocar antes del contacto, usar lubricante a base de agua","Informar sobre la vacuna del VPH y hepatitis B","Explicar la importancia de notificar a las parejas sexuales para tratamiento","Informar sobre la PrEP y profilaxis postexposici\xf3n (PEP) para VIH en situaciones de riesgo","Educar sobre el cribado peri\xf3dico en personas activas sexualmente o en grupos de riesgo","Garantizar la confidencialidad de la consulta","Crear un ambiente de comunicaci\xf3n sin juicios sobre conductas sexuales","Abordar el estigma: las ITS son enfermedades comunes, no un signo de inmoralidad","Apoyar en la comunicaci\xf3n del diagn\xf3stico a la pareja (counselling)","Explorar posible contexto de violencia o coerci\xf3n sexual"],educacionPaciente:["Explicar la importancia de completar el tratamiento aunque los s\xedntomas desaparezcan","Instruir sobre abstinencia sexual o uso de preservativo hasta confirmar curaci\xf3n (y de la pareja)","Ense\xf1ar el uso correcto del preservativo y sus limitaciones (no protege 100% frente a herpes y s\xedfilis)","Informar sobre la vacuna del VPH y recomendar si no vacunado","Insistir en la importancia del cribado peri\xf3dico en personas sexualmente activas","Informar sobre recursos de salud sexual accesibles (sin necesidad de consulta con m\xe9dico de familia)"],monitorizacion:[]},npiNanda:[{codigo:"00004",nombre:"Riesgo de infecci\xf3n",definicion:"Vulnerable a la transmisi\xf3n y reinfecci\xf3n de organismos pat\xf3genos",caracteristicasDefinitorias:[],factoresRelacionados:["Pr\xe1cticas sexuales sin protecci\xf3n","M\xfaltiples parejas","Inmunosupresi\xf3n"]},{codigo:"00126",nombre:"Conocimientos deficientes",definicion:"Ausencia o deficiencia de informaci\xf3n cognitiva",caracteristicasDefinitorias:["Pr\xe1cticas sexuales de riesgo","No uso del preservativo","Desconocimiento de s\xedntomas"],factoresRelacionados:["Falta de informaci\xf3n sobre ITS","Tab\xfa social"]},{codigo:"00053",nombre:"Aislamiento social",definicion:"Soledad percibida como impuesta por otros",caracteristicasDefinitorias:["Retraimiento","Miedo a comunicar el diagn\xf3stico a la pareja"],factoresRelacionados:["Estigma asociado a las ITS","Miedo al rechazo por la pareja"]}],npiNic:[{codigo:"5510",nombre:"Educaci\xf3n para la salud",actividades:["Ense\xf1ar el uso correcto del preservativo: colocar antes del contacto, usar lubricante a base de agua","Informar sobre la vacuna del VPH y hepatitis B","Explicar la importancia de notificar a las parejas sexuales para tratamiento","Informar sobre la PrEP y profilaxis postexposici\xf3n (PEP) para VIH en situaciones de riesgo","Educar sobre el cribado peri\xf3dico en personas activas sexualmente o en grupos de riesgo"]},{codigo:"5270",nombre:"Apoyo emocional",actividades:["Garantizar la confidencialidad de la consulta","Crear un ambiente de comunicaci\xf3n sin juicios sobre conductas sexuales","Abordar el estigma: las ITS son enfermedades comunes, no un signo de inmoralidad","Apoyar en la comunicaci\xf3n del diagn\xf3stico a la pareja (counselling)","Explorar posible contexto de violencia o coerci\xf3n sexual"]}],npiNoc:[{codigo:"1805",nombre:"Conocimiento: conducta sanitaria",indicadores:["Uso correcto del preservativo","Conocimiento de signos de ITS","Cumplimiento del tratamiento"],escala:"Verbalizaci\xf3n de medidas preventivas y adherencia al tratamiento completo"}],complicaciones:["Enfermedad inflamatoria p\xe9lvica (EIP) con infertilidad","Embarazo ect\xf3pico post-EIP","S\xedfilis cong\xe9nita","Neuros\xedfilis y s\xedfilis cardiovascular","C\xe1ncer cervical por VPH oncog\xe9nico","Mayor riesgo de adquirir VIH","Artritis reactiva (s\xedndrome de Reiter)","Transmisi\xf3n neonatal del herpes (peligrosa en reci\xe9n nacido)"],criteriosAlarma:["Neuros\xedfilis: cl\xednica neurol\xf3gica, psiqui\xe1trica o cardiovascular (s\xedfilis terciaria tard\xeda)","S\xedfilis cong\xe9nita: transmisi\xf3n vertical con afectaci\xf3n multisist\xe9mica del neonato","EIP grave con absceso tuboov\xe1rico (requiere hospitalizaci\xf3n y posible cirug\xeda)","Gonorrea diseminada: artritis, dermatitis, meningitis","S\xedfilis secundaria: exantema palmo-plantar (alta carga infecciosa)"],emergencyLevel:"moderado",relatedPathologyIds:[],isPremium:!0},{id:"pat_hpp",nombre:"Hemorragia Postparto (HPP)",bodySystemId:"reproductivo",definicion:"P\xe9rdida de sangre >500 mL tras parto vaginal o >1000 mL tras ces\xe1rea, o cualquier p\xe9rdida que cause compromiso hemodin\xe1mico. Principal causa de mortalidad materna en el mundo. La aton\xeda uterina es responsable del 80% de los casos. Requiere actuaci\xf3n multidisciplinar inmediata.",epidemiologia:"",factoresRiesgo:[],fisiopatologia:"El \xfatero puerperal se vac\xeda y la hemostasia se logra mediante la contracci\xf3n miometrial que comprime los vasos del lecho placentario. La aton\xeda uterina (fallo de contracci\xf3n) es la causa m\xe1s frecuente de HPP: el \xfatero permanece blando y sin contracci\xf3n, permitiendo el sangrado masivo desde los senos vasculares del lecho placentario. Otras causas: laceraciones del canal del parto (cuello, vagina, perin\xe9), retenci\xf3n de restos placentarios, alteraciones de la coagulaci\xf3n (hipofibrinogenemia en abruptio, CID). El sangrado masivo lleva a hipovolemia, hipotermia, acidosis e hipocalcemia (la 'tr\xedada letal') que perpet\xfaa la coagulopat\xeda.",signosYSintomas:{signos:["Sangrado vaginal excesivo post-expulsivo (>500 mL en parto vaginal, >1000 mL en ces\xe1rea)","\xdatero blando, mal retra\xeddo a la palpaci\xf3n abdominal (aton\xeda uterina)","Signos de shock hipovol\xe9mico: taquicardia, hipotensi\xf3n, palidez, diaforesis","Sangrado continuo pese a masaje uterino","Formaci\xf3n de hematomas en canal del parto (laceraciones)","TA sist\xf3lica <90 mmHg (shock hemorr\xe1gico grado III-IV)","FC >130 lpm","Sangrado masivo con coagulopat\xeda (CID): sangre sin co\xe1gulos, sangrado por CVC","Hematocrito <18% (p\xe9rdida de m\xe1s de la mitad del volumen sangu\xedneo)","Paro card\xedaco por exsanguinaci\xf3n"],sintomas:["Oliguria o anuria (hipoperfusi\xf3n renal)","Deterioro del nivel de conciencia","Sangrado por puntos de venopunci\xf3n (CID)","Dolor perineal intenso (hematoma)","Placenta no expulsada o expulsi\xf3n incompleta"]},diagnostico:{anamnesis:["P\xe9rdida hem\xe1tica cuantificada >500 mL (vaginal) o >1000 mL (ces\xe1rea)","Ca\xedda del hematocrito >10% respecto al valor previo al parto","Cualquier p\xe9rdida con signos de compromiso hemodin\xe1mico","Identificar la causa: 4T (Tono, Tejido, Trauma, Trombina)"],examenFisico:[],pruebas:[{nombre:"Hemograma urgente: Hb, hematocrito",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Coagulaci\xf3n: TP, TTPA, fibrin\xf3geno (fibrin\xf3geno <2 g/L en HPP grave = CID)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Funci\xf3n renal: creatinina, urea",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Gasometr\xeda: acidosis metab\xf3lica en shock",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Calcio i\xf3nico (hipocalcemia frecuente en transfusi\xf3n masiva)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Temperatura corporal (hipotermia en transfusi\xf3n masiva)",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Ecograf\xeda: restos placentarios retenidos",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]},{nombre:"Pruebas cruzadas y reserva de hemat\xedes urgente",descripcion:"",valoresReferencia:"",cuidadosEnfermeria:[]}]},tratamientoMedico:{objetivos:[],farmacologico:[{nombre:"Oxitocina",grupo:"Octap\xe9ptido uterot\xf3nico que",mecanismo:"Octap\xe9ptido uterot\xf3nico que act\xfaa sobre receptores espec\xedficos del miometrio causando contracci\xf3n uterina sostenida. Primera l\xednea en HPP por aton\xeda uterina. Profilaxis est\xe1ndar en la 3\xaa fase del parto",dosis:"Profilaxis: 10 UI IM o IV bolus lento. Tratamiento de HPP: 20-40 UI en 1L de SF a 500 mL/h. Infusi\xf3n de mantenimiento seg\xfan respuesta",cuidadosEnfermeria:["Administrar el bolus IV LENTAMENTE (hipotensi\xf3n con inyecci\xf3n r\xe1pida)","Monitorizar PA y FC continua durante la administraci\xf3n IV","Monitorizar diuresis (riesgo de intoxicaci\xf3n acuosa con altas dosis prolongadas)","Si no respuesta a oxitocina: escalar a carbetocina o ergometrina","Controlar la retracci\xf3n uterina con masaje uterino bimanual"]},{nombre:"\xc1cido Tranex\xe1mico",grupo:"Antifibrinol\xedtico que inhibe",mecanismo:"Antifibrinol\xedtico que inhibe el plasmin\xf3geno, previniendo la disoluci\xf3n del co\xe1gulo. Reduce la mortalidad materna por HPP si se administra en los primeros 3 horas del inicio del sangrado (estudio WOMAN: reducci\xf3n del 30% de muertes por sangrado)",dosis:"1 g IV en 10 min, repetir 1 g IV si sangrado contin\xfaa a los 30 min o si recidiva en las 24h. Iniciar lo antes posible (< 3h del inicio del sangrado)",cuidadosEnfermeria:["Administrar URGENTEMENTE, lo antes posible tras el diagn\xf3stico de HPP","Infundir en 10 min (bolus lento) no m\xe1s r\xe1pido (n\xe1useas, hipotensi\xf3n)","Puede administrarse aunque la causa del sangrado no sea solo fibrin\xf3lisis","Registrar hora exacta de administraci\xf3n (eficacia disminuye pasadas las 3h del inicio)"]},{nombre:"Ergometrina",grupo:"Alcaloide del cornezuelo",mecanismo:"Alcaloide del cornezuelo de centeno que act\xfaa sobre receptores alfa-adren\xe9rgicos y dopamin\xe9rgicos del m\xfasculo liso uterino causando una contracci\xf3n uterina t\xf3nica y sostenida. Segunda l\xednea cuando la oxitocina no logra controlar la aton\xeda",dosis:"0.5 mg IM o IV lento. Puede repetirse cada 4h, m\xe1ximo 3 dosis",cuidadosEnfermeria:["CONTRAINDICADO en hipertensi\xf3n e historia de preeclampsia (vasoconstricci\xf3n severa)","Monitorizar PA antes y despu\xe9s de la administraci\xf3n","Administrar IV EXTREMADAMENTE lento (riesgo de HTA severa)","Vigilar espasmo coronario (raro pero descrito, especialmente en mujeres con factores de riesgo cardiovascular)"]}],noFarmacologico:["Masaje uterino bimanual: comprimir el \xfatero entre la mano abdominal y la vaginal para estimular la contracci\xf3n","Taponamiento uterino con bal\xf3n de Bakri (intrauterino) o packing quir\xfargico","Compresi\xf3n a\xf3rtica manual hasta disponibilidad de transfusi\xf3n","Transfusi\xf3n masiva: protocolo 1:1:1 (hemat\xedes:PFC:plaquetas)","Cirug\xeda: sutura de B-Lynch (compresi\xf3n uterina), ligadura de arterias uterinas, embolizaci\xf3n arterial selectiva","Histerectom\xeda de emergencia como \xfaltimo recurso en HPP incoercible"]},cuidadosEnfermeria:{valoracion:["Monitorizar PA, FC, FR, SatO2 continua","Cuantificar el sangrado: bolsa colectora, pesaje de compresas y gasas (500 mL = 500 g)","Palpar el \xfatero: tono, altura de fondo uterino (\xfatero blando = aton\xeda)","Monitorizar diuresis horaria","Valorar signos de shock: taquicardia, hipotensi\xf3n, palidez, confusi\xf3n, frialdad","Controlar temperatura (hipotermia en transfusi\xf3n masiva: coagulopat\xeda)"],intervenciones:["Activar el protocolo de transfusi\xf3n masiva del hospital INMEDIATAMENTE (solicitar hemat\xedes, PFC, plaquetas y crioprecipitados)","Canalizar acceso venoso grueso de gran calibre (al menos 2 v\xedas perif\xe9ricas 16G o v\xeda central)","Administrar fluidos IV calientes (evitar hipotermia que agrava coagulopat\xeda)","Transfundir protocolo 1:1:1 (1 concentrado de hemat\xedes: 1 PFC: 1 pool de plaquetas)","Monitorizar calcio i\xf3nico (hipocalcemia por citrato del PFC: administrar gluconato c\xe1lcico)","Fluidoterapia de rescate: cristaloides en bolus de 500-1000 mL hasta llegada de hemoderivados","Evitar exceso de cristaloides (dilucional de la coagulaci\xf3n y edema pulmonar)","Monitorizar diuresis horaria: objetivo >0.5 mL/kg/h","Insertar sonda urinaria para monitorizaci\xf3n estricta","Balancear la reposici\xf3n: preferir hemoderivados sobre cristaloides en shock hemorr\xe1gico","Activar el equipo de HPP: obstetra, anestesi\xf3logo, enfermer\xeda experta, banco de sangre","Aplicar masaje uterino bimanual mientras se preparan los uterot\xf3nicos","Administrar oxitocina + \xe1cido tranex\xe1mico URGENTEMENTE","Posici\xf3n de Trendelenburg modificada si shock (en embarazada: desplazamiento uterino lateral izquierdo)","Registrar EXACTAMENTE el volumen de sangre perdida y los medicamentos administrados"],educacionPaciente:["Explicar a la paciente y familia la situaci\xf3n de forma honesta y tranquilizadora mientras se act\xfaa","Informar sobre los procedimientos que se van a realizar (transfusi\xf3n, medicamentos, posible cirug\xeda)","Ofrecer apoyo emocional durante y despu\xe9s de la HPP (traumatismo psicol\xf3gico)","Explicar que el reci\xe9n nacido est\xe1 siendo atendido si hay separaci\xf3n","Informar sobre la posibilidad de s\xedndrome de Sheehan (insuficiencia hipofisaria) en HPP muy graves: ense\xf1ar s\xedntomas tard\xedos"],monitorizacion:[]},npiNanda:[{codigo:"00028",nombre:"Riesgo de d\xe9ficit de volumen de l\xedquidos",definicion:"Vulnerable a experimentar una disminuci\xf3n del volumen de l\xedquidos intravasculares",caracteristicasDefinitorias:[],factoresRelacionados:["Hemorragia masiva postparto","Aton\xeda uterina","Coagulopat\xeda"]},{codigo:"00029",nombre:"Disminuci\xf3n del gasto card\xedaco",definicion:"Cantidad de sangre bombeada por el coraz\xf3n en 1 minuto que es inadecuada",caracteristicasDefinitorias:["Hipotensi\xf3n","Taquicardia","Oliguria","Palidez"],factoresRelacionados:["Hipovolemia severa","Shock hemorr\xe1gico"]},{codigo:"00146",nombre:"Ansiedad",definicion:"Sensaci\xf3n vaga e intranquilizadora de malestar o amenaza",caracteristicasDefinitorias:["Miedo intenso","Temblor","Agitaci\xf3n"],factoresRelacionados:["Amenaza vital","Separaci\xf3n del reci\xe9n nacido","Procedimientos invasivos urgentes"]}],npiNic:[{codigo:"4030",nombre:"Administraci\xf3n de hemoderivados",actividades:["Activar el protocolo de transfusi\xf3n masiva del hospital INMEDIATAMENTE (solicitar hemat\xedes, PFC, plaquetas y crioprecipitados)","Canalizar acceso venoso grueso de gran calibre (al menos 2 v\xedas perif\xe9ricas 16G o v\xeda central)","Administrar fluidos IV calientes (evitar hipotermia que agrava coagulopat\xeda)","Transfundir protocolo 1:1:1 (1 concentrado de hemat\xedes: 1 PFC: 1 pool de plaquetas)","Monitorizar calcio i\xf3nico (hipocalcemia por citrato del PFC: administrar gluconato c\xe1lcico)"]},{codigo:"4120",nombre:"Manejo de l\xedquidos",actividades:["Fluidoterapia de rescate: cristaloides en bolus de 500-1000 mL hasta llegada de hemoderivados","Evitar exceso de cristaloides (dilucional de la coagulaci\xf3n y edema pulmonar)","Monitorizar diuresis horaria: objetivo >0.5 mL/kg/h","Insertar sonda urinaria para monitorizaci\xf3n estricta","Balancear la reposici\xf3n: preferir hemoderivados sobre cristaloides en shock hemorr\xe1gico"]},{codigo:"6200",nombre:"Cuidados de urgencia",actividades:["Activar el equipo de HPP: obstetra, anestesi\xf3logo, enfermer\xeda experta, banco de sangre","Aplicar masaje uterino bimanual mientras se preparan los uterot\xf3nicos","Administrar oxitocina + \xe1cido tranex\xe1mico URGENTEMENTE","Posici\xf3n de Trendelenburg modificada si shock (en embarazada: desplazamiento uterino lateral izquierdo)","Registrar EXACTAMENTE el volumen de sangre perdida y los medicamentos administrados"]}],npiNoc:[{codigo:"0413",nombre:"Severidad de la p\xe9rdida de sangre",indicadores:["Sangrado visible controlado","Hemoglobina estable","Signos vitales normalizados"],escala:"Cese del sangrado activo, PA sist\xf3lica >90 mmHg, Hb >8 g/dL tras resucitaci\xf3n"},{codigo:"0601",nombre:"Equilibrio h\xeddrico",indicadores:["Diuresis >0.5 mL/kg/h","PA estable","FC <100 lpm","Relleno capilar <2 seg"],escala:"Estabilizaci\xf3n hemodin\xe1mica con perfusi\xf3n org\xe1nica adecuada en 1-2 horas"}],complicaciones:["Shock hemorr\xe1gico con fallo multiorg\xe1nico","CID","Histerectom\xeda de urgencia (p\xe9rdida de fertilidad)","FRA","SDRA","S\xedndrome de Sheehan (necrosis hipofisaria: infertilidad secundaria, hipotiroidismo, insuficiencia suprarrenal)","Anemia grave post-HPP","Muerte materna"],criteriosAlarma:["TA sist\xf3lica <90 mmHg (shock hemorr\xe1gico grado III-IV)","FC >130 lpm","Sangrado masivo con coagulopat\xeda (CID): sangre sin co\xe1gulos, sangrado por CVC","Hematocrito <18% (p\xe9rdida de m\xe1s de la mitad del volumen sangu\xedneo)","Paro card\xedaco por exsanguinaci\xf3n"],emergencyLevel:"critico",relatedPathologyIds:[],isPremium:!0},{id:"pat_pericarditis",nombre:"Pericarditis",bodySystemId:"cardiovascular",definicion:"Inflamacion del pericardio (saco fibroso que rodea el corazon), que puede ser aguda, recurrente o cronica. La forma mas frecuente es la pericarditis aguda idiopatica o viral.",epidemiologia:"Representa el 5% de las consultas por dolor toracico no isquemico en urgencias. Mas frecuente en hombres jovenes (16-65 a\xf1os). La causa viral o idiopatica representa el 80-90% de los casos en paises desarrollados.",factoresRiesgo:["Infecciones virales recientes (Coxsackie, Echovirus, VIH)","Enfermedades autoinmunes (LES, AR)","Insuficiencia renal cronica (uremica)","Infarto agudo de miocardio reciente (sindrome de Dressler)","Trauma toracico","Radioterapia mediastinal"],fisiopatologia:"La inflamacion del pericardio produce exudado que puede ser seroso, fibrinoso, purulento o hemorragico. El engrosamiento y la fusion de las hojas pericardicas genera friccion y dolor. En casos de acumulacion rapida de liquido se puede producir taponamiento cardiaco con compromiso hemodinamico.",signosYSintomas:{signos:["Frote pericardico (patognomonico)","Fiebre de bajo grado","Cambios difusos en ECG (elevacion del ST en silla de montar)","Derrame pericardico en ecocardiograma","Taquicardia"],sintomas:["Dolor toracico pleuritico (empeora en decubito, mejora sentado hacia adelante)","Disnea","Tos seca","Malestar general","Escalofrios"]},clasificacion:{nombre:"Clasificacion temporal",tipos:[{nombre:"Aguda",descripcion:"Duracion < 4-6 semanas"},{nombre:"Incesante",descripcion:"Duracion 4-6 semanas a 3 meses sin remision"},{nombre:"Recurrente",descripcion:"Recidiva despues de intervalo libre de al menos 4-6 semanas"},{nombre:"Cronica",descripcion:"Duracion > 3 meses; puede evolucionar a pericarditis constrictiva"}]},diagnostico:{anamnesis:["Caracteristicas del dolor (pleuritico, posicional)","Infeccion viral reciente (2-6 semanas previas)","Antecedentes de enfermedades autoinmunes o renales","Historia de IAM, cirugia cardiaca o radioterapia"],examenFisico:["Auscultacion de frote pericardico trifasico en mesocardio","Signos vitales: fiebre, taquicardia","Buscar triada de Beck: hipotension + ingurgitacion yugular + ruidos apagados"],pruebas:[{nombre:"ECG",descripcion:"Elevacion difusa del ST en silla de montar con depresion de PR; evolucion en 4 etapas",valoresReferencia:"Elevacion ST difusa no focal, depresion del segmento PR",cuidadosEnfermeria:["Realizar ECG de 12 derivaciones al ingreso","Repetir segun evolucion","Comparar con ECG previos"]},{nombre:"Ecocardiograma",descripcion:"Detecta derrame pericardico y signos de taponamiento",valoresReferencia:"Derrame: leve <10mm, moderado 10-20mm, severo >20mm",cuidadosEnfermeria:["Posicionar en decubito lateral izquierdo","Monitorizar signos vitales durante el procedimiento"]},{nombre:"PCR y VSG",descripcion:"Marcadores de inflamacion activa; la PCR guia duracion del tratamiento",valoresReferencia:"PCR < 0.5 mg/dL normal; VSG < 20 mm/h",cuidadosEnfermeria:["Extraer muestra venosa","Registrar resultado para seguimiento"]},{nombre:"Troponina",descripcion:"Elevada en miopericarditis con afectacion miocardica asociada",valoresReferencia:"Troponina I < 0.04 ng/mL normal",cuidadosEnfermeria:["Extraer en paralelo con otros biomarcadores","Registrar hora de extraccion"]}]},tratamientoMedico:{objetivos:["Aliviar el dolor y la inflamacion","Prevenir recurrencias","Detectar y tratar taponamiento cardiaco y pericarditis constrictiva"],farmacologico:[{nombre:"Aspirina",grupo:"AINE",mecanismo:"Inhibe ciclooxigenasa reduciendo prostaglandinas inflamatorias",dosis:"750-1000 mg cada 8h por 1-2 semanas con reduccion gradual",cuidadosEnfermeria:["Administrar con alimentos para reducir gastropatia","Monitorizar signos de sangrado digestivo","Reducir dosis gradualmente, no suspender abruptamente"]},{nombre:"Ibuprofeno",grupo:"AINE",mecanismo:"Inhibe COX-1 y COX-2 reduciendo inflamacion pericardica",dosis:"600 mg cada 8h por 1-2 semanas",cuidadosEnfermeria:["Administrar con omeprazol como gastroproteccion","Monitorizar PA y funcion renal con uso prolongado"]},{nombre:"Colchicina",grupo:"Antiinflamatorio especifico",mecanismo:"Inhibe quimiotaxis de neutrofilos reduciendo inflamacion y recurrencias",dosis:"0.5 mg cada 12h por 3 meses asociada a AINE",cuidadosEnfermeria:["Vigilar diarrea como efecto adverso frecuente","Contraindicada en insuficiencia renal grave","Educar sobre importancia de completar el tratamiento"]},{nombre:"Prednisona",grupo:"Corticosteroide",mecanismo:"Potente antiinflamatorio; reservado para casos refractarios o contraindicacion de AINEs",dosis:"0.25-0.5 mg/kg/dia con reduccion gradual muy lenta",cuidadosEnfermeria:["Usar solo cuando AINEs fallen o esten contraindicados","Monitorizar glucemia, PA y peso","Explicar mayor riesgo de recurrencias con corticoides"]}],noFarmacologico:["Reposo relativo hasta desaparicion de sintomas","Restringir actividad fisica intensa por 3 meses en atletas","Evitar anticoagulantes si hay derrame por riesgo hemorragico"]},cuidadosEnfermeria:{valoracion:["Evaluar caracteristicas del dolor toracico: intensidad y posicion","Monitorizar FC, FR, PA, SpO2 y temperatura","Auscultar frote pericardico en cada valoracion","Detectar signos de taponamiento cardiaco (triada de Beck)"],intervenciones:["Posicionar sentado con inclinacion anterior para aliviar dolor","Administrar analgesicos y antiinflamatorios segun prescripcion","Monitorizar ECG continuo para detectar arritmias","Preparar equipo de pericardiocentesis si hay sospecha de taponamiento","Control de PCR semanal para guiar duracion del tratamiento"],educacionPaciente:["Explicar la naturaleza generalmente benigna y autolimitada","Importancia de completar colchicina para prevenir recurrencias","Restriccion de ejercicio hasta normalizacion de PCR","Signos de alarma: empeoramiento de disnea, hipotension"],monitorizacion:["ECG diario en hospitalizados","Signos vitales cada 4-6h","PCR semanal hasta normalizacion","Ecocardiograma de control si habia derrame"]},npiNanda:[{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable asociada con da\xf1o tisular real o potencial",caracteristicasDefinitorias:["Informe verbal de dolor toracico pleuritico","Posicion antialgica (sentado hacia adelante)","Taquicardia"],factoresRelacionados:["Inflamacion pericardica","Friccion entre hojas del pericardio"]},{codigo:"00029",nombre:"Disminucion del gasto cardiaco",definicion:"Cantidad insuficiente de sangre bombeada por el corazon para satisfacer las demandas metabolicas",caracteristicasDefinitorias:["Taquicardia","Hipotension","Pulso paradojico","Distension yugular"],factoresRelacionados:["Derrame pericardico","Taponamiento cardiaco"]},{codigo:"00146",nombre:"Ansiedad",definicion:"Vaga sensacion de malestar o amenaza acompanada de respuesta autonoma",caracteristicasDefinitorias:["Expresion de preocupacion","Tension","Taquicardia"],factoresRelacionados:["Dolor toracico","Amenaza percibida para la salud"]}],npiNic:[{codigo:"1400",nombre:"Manejo del dolor",actividades:["Evaluar dolor con escala numerica cada 4h","Administrar analgesicos segun prescripcion","Posicionar al paciente en posicion antialgica","Monitorizar efectividad del tratamiento"]},{codigo:"4040",nombre:"Cuidados cardiacos",actividades:["Monitorizar signos vitales y ECG continuo","Vigilar signos de taponamiento (triada de Beck)","Preparar pericardiocentesis si necesario","Limitar actividad fisica"]},{codigo:"5820",nombre:"Disminucion de la ansiedad",actividades:["Explicar procedimientos y plan de cuidados","Promover ambiente tranquilo","Acompanar al paciente durante episodios de ansiedad"]}],npiNoc:[{codigo:"2102",nombre:"Nivel del dolor",indicadores:["Dolor toracico < 3/10","Ausencia de posicion antialgica","FC en rango normal"],escala:"1=Grave, 2=Sustancial, 3=Moderado, 4=Leve, 5=Ningun"},{codigo:"0400",nombre:"Efectividad de la bomba cardiaca",indicadores:["PA sistolica estable","Ausencia de pulso paradojico","FC entre 60-100 lpm"],escala:"1=Desviacion grave, 5=Sin desviacion"}],complicaciones:["Taponamiento cardiaco (emergencia)","Pericarditis constrictiva cronica","Miopericarditis","Recurrencias en 15-30% sin colchicina"],criteriosAlarma:["Triada de Beck: hipotension + ingurgitacion yugular + ruidos apagados","Pulso paradojico > 10 mmHg","PA sistolica < 90 mmHg","Fiebre > 38 grados refractaria a AINEs"],emergencyLevel:"moderado",relatedPathologyIds:["pat_icc","pat_irc"],isPremium:!0},{id:"pat_shock_cardiogenico",nombre:"Shock Cardiogenico",bodySystemId:"cardiovascular",definicion:"Estado de hipoperfusion tisular critica causado por falla cardiaca primaria, caracterizado por hipotension persistente, bajo gasto cardiaco y signos de hipoperfusion organica a pesar de una precarga adecuada.",epidemiologia:"Complica el 5-10% de los IAM con elevacion del ST. Mortalidad hospitalaria del 40-60%. Es la causa principal de muerte en pacientes hospitalizados por IAM.",factoresRiesgo:["Infarto agudo de miocardio extenso anterior","Insuficiencia cardiaca previa","Edad avanzada","Diabetes mellitus","Enfermedad multivaso coronaria","Retraso en la reperfusion"],fisiopatologia:"La perdida masiva de miocardio funcional (>40% del VI) reduce el gasto cardiaco. La hipoperfusion activa mecanismos compensadores: taquicardia refleja, vasoconstriccion periferica y retencion de liquidos. Estos mecanismos aumentan la demanda de oxigeno miocardico agravando la disfuncion ventricular en un circulo vicioso que lleva a acidosis lactica y fallo multiorganico.",signosYSintomas:{signos:["PA sistolica < 90 mmHg por mas de 30 min","Indice cardiaco < 1.8 L/min/m2","Extremidades frias y moteadas","Oliguria < 0.5 mL/kg/h","Ingurgitacion yugular","Estertores pulmonares bibasales"],sintomas:["Confusion o agitacion por hipoperfusion cerebral","Disnea severa","Debilidad extrema","Sensacion de muerte inminente"]},clasificacion:{nombre:"Clasificacion SCAI de shock cardiogenico",tipos:[{nombre:"Estadio A (At risk)",descripcion:"Riesgo de shock pero sin signos clinicos"},{nombre:"Estadio B (Beginning)",descripcion:"Hipoperfusion relativa con PA borderline o taquicardia compensadora"},{nombre:"Estadio C (Classic)",descripcion:"Shock cardiogenico clasico que requiere soporte vasopresor"},{nombre:"Estadio D (Deteriorating)",descripcion:"Deterioro hemodinamico a pesar del soporte inicial"},{nombre:"Estadio E (Extremis)",descripcion:"Colapso circulatorio, paro cardiaco inminente o en curso"}]},diagnostico:{anamnesis:["Dolor toracico previo sugestivo de IAM","Antecedentes de cardiopatia o IC","Tiempo de evolucion de sintomas","Medicacion previa: betabloqueantes, diureticos"],examenFisico:["Medicion de PA: hipotension","Evaluacion de perfusion periferica: tiempo de relleno capilar","Auscultacion cardiaca y pulmonar","Estado de conciencia con escala de Glasgow","Diuresis por sonda vesical"],pruebas:[{nombre:"Lactato arterial",descripcion:"Marcador de hipoperfusion tisular y pronostico",valoresReferencia:"Normal < 2 mmol/L; shock > 2; grave > 4 mmol/L",cuidadosEnfermeria:["Obtener muestra de gases arteriales","Repetir cada 2-4h para evaluar respuesta al tratamiento"]},{nombre:"Ecocardiograma urgente",descripcion:"Evalua FEVI, motilidad segmentaria, derrame y causa del shock",valoresReferencia:"FEVI < 30% en shock cardiogenico tipico",cuidadosEnfermeria:["Facilitar acceso urgente al ecocardiologo","Mantener monitoreo continuo durante el estudio"]},{nombre:"Troponina I/T",descripcion:"Cuantifica da\xf1o miocardico isquemico",valoresReferencia:"Troponina I > 0.04 ng/mL indica da\xf1o significativo",cuidadosEnfermeria:["Serie cada 3-6h en primeras 12h","Registrar hora de inicio de sintomas"]},{nombre:"Gasometria arterial",descripcion:"Evalua acidosis metabolica, hipoxemia y fallo respiratorio",valoresReferencia:"pH 7.35-7.45; pO2 > 80 mmHg; HCO3 22-26 mEq/L",cuidadosEnfermeria:["Extraer muestra arterial radial o femoral","Aplicar presion 5 min post-extraccion","Resultado urgente en menos de 15 min"]}]},tratamientoMedico:{objetivos:["Restablecer perfusion miocardica mediante reperfusion urgente","Estabilizar hemodinamica con PAM > 65 mmHg","Prevenir fallo multiorganico","Reducir mortalidad"],farmacologico:[{nombre:"Noradrenalina",grupo:"Vasopresor agonista alfa-adrenergico",mecanismo:"Vasoconstriccion periferica que aumenta la PA media y la perfusion coronaria",dosis:"0.1-2 mcg/kg/min en infusion continua IV por via central",cuidadosEnfermeria:["NUNCA administrar por via periferica","Monitorizar PA invasiva cada minuto con linea arterial","Vigilar isquemia distal en extremidades","Ajustar dosis con objetivo PAM > 65 mmHg"]},{nombre:"Dobutamina",grupo:"Inotrapico agonista beta1",mecanismo:"Aumenta contractilidad y gasto cardiaco sin vasoconstriccion periferica significativa",dosis:"2-20 mcg/kg/min en infusion continua IV",cuidadosEnfermeria:["Monitorizar FC: puede producir taquicardia","Vigilar arritmias en ECG continuo","Puede combinarse con noradrenalina si hay hipotension"]},{nombre:"Aspirina mas antiagregante",grupo:"Doble antiagregacion plaquetaria",mecanismo:"Previene trombosis coronaria aguda y reoclusion post-reperfusion",dosis:"Aspirina 300 mg mas Ticagrelor 180 mg o Clopidogrel 600 mg por SNG o VO",cuidadosEnfermeria:["Administrar antes de la reperfusion si es posible","Triturar comprimidos si se administran por SNG","Vigilar signos de sangrado activo"]},{nombre:"Heparina sodica",grupo:"Anticoagulante parenteral",mecanismo:"Previene propagacion del trombo coronario y trombosis del cateter",dosis:"Bolo 60 UI/kg (max 4000 UI) IV seguido de infusion 12 UI/kg/h ajustada por KPTT",cuidadosEnfermeria:["Controlar KPTT cada 6h (objetivo 60-100 seg)","Vigilar sitios de acceso vascular por sangrado","Tener protamina disponible como antidoto"]}],noFarmacologico:["Reperfusion urgente: angioplastia primaria en menos de 90 min","Oxigenoterapia o ventilacion mecanica si SpO2 < 90%","Sonda vesical para medicion de diuresis horaria","Acceso venoso central para administracion de vasopresores","Linea arterial radial para monitoreo continuo de PA"],quirurgico:["Angioplastia coronaria percutanea primaria (primera eleccion)","Balon de contrapulsacion intraortico","Dispositivo de asistencia ventricular percutaneo (Impella)","Cirugia de revascularizacion en enfermedad multivaso seleccionada"]},cuidadosEnfermeria:{valoracion:["Monitorizar PA invasiva, FC, FR, SpO2 de forma continua","Medir diuresis horaria con objetivo > 0.5 mL/kg/h","Evaluar estado de conciencia con escala de Glasgow","Valorar perfusion periferica: temperatura, relleno capilar, coloracion","Medir PVC si hay cateter venoso central"],intervenciones:["Preparar via venosa central de gran calibre de urgencia","Administrar vasopresores e inotopicos segun protocolo","Colocar sonda vesical para medicion horaria","Preparar sala de hemodinamica con urgencia","Monitorear ECG continuo de 12 derivaciones","Mantener hemoderivados disponibles"],educacionPaciente:["Explicar procedimientos de forma simple dado que el paciente puede estar confuso","Informar a la familia sobre la gravedad y los procedimientos que se realizaran","Mantener a la familia actualizada sobre el estado hemodinamico del paciente"],monitorizacion:["PA invasiva continua","FC, FR, SpO2 continuo","Diuresis horaria","Lactato arterial cada 2-4h","Ionograma y funcion renal cada 6-12h","ECG continuo"]},npiNanda:[{codigo:"00029",nombre:"Disminucion del gasto cardiaco",definicion:"Cantidad insuficiente de sangre bombeada por el corazon para satisfacer las demandas metabolicas",caracteristicasDefinitorias:["PA sistolica < 90 mmHg","Taquicardia > 100 lpm","Extremidades frias","Oliguria"],factoresRelacionados:["Infarto miocardico extenso","Disfuncion ventricular izquierda severa"]},{codigo:"00032",nombre:"Patron respiratorio ineficaz",definicion:"Inspiracion o espiracion que no proporciona ventilacion adecuada",caracteristicasDefinitorias:["Disnea severa","Uso de musculos accesorios","SpO2 < 90%"],factoresRelacionados:["Edema pulmonar por fallo ventricular izquierdo"]},{codigo:"00025",nombre:"Riesgo de perfusion tisular ineficaz",definicion:"Riesgo de disminucion de la circulacion a los tejidos corporales",caracteristicasDefinitorias:["Signos de hipoperfusion organica multiple"],factoresRelacionados:["Gasto cardiaco reducido","Hipotension severa persistente"]}],npiNic:[{codigo:"4254",nombre:"Cuidados del shock cardiogenico",actividades:["Monitorizar PA invasiva y ECG continuo","Administrar vasopresores e inotopicos prescritos","Medir diuresis horaria","Preparar equipo para procedimientos de reperfusion urgente"]},{codigo:"3300",nombre:"Manejo de la ventilacion mecanica",actividades:["Preparar equipo de intubacion si SpO2 < 88%","Monitorizar parametros ventilatorios","Aspirar secreciones segun necesidad clinica"]},{codigo:"4160",nombre:"Manejo de la resucitacion",actividades:["Mantener via aerea permeable","Administrar oxigeno suplementario al 100%","Documentar respuesta hemodinamica al tratamiento"]}],npiNoc:[{codigo:"0400",nombre:"Efectividad de la bomba cardiaca",indicadores:["PA sistolica > 90 mmHg","Diuresis > 0.5 mL/kg/h","Lactato < 2 mmol/L"],escala:"1=Desviacion grave, 5=Sin desviacion"},{codigo:"0402",nombre:"Estado circulatorio",indicadores:["Perfusion periferica adecuada","Relleno capilar < 2 seg","Ausencia de moteado cutaneo"],escala:"1=Desviacion grave, 5=Sin desviacion"}],complicaciones:["Fallo multiorganico","Edema agudo de pulmon","Arritmias malignas ventriculares","CID","Muerte"],criteriosAlarma:["PA sistolica < 80 mmHg refractaria a vasopresores","Lactato > 8 mmol/L","Glasgow < 8 (requiere intubacion urgente)","Anuria mayor a 2 horas","Fibrilacion ventricular o TV sin pulso"],emergencyLevel:"critico",relatedPathologyIds:["pat_iam","pat_icc"],isPremium:!0},{id:"pat_valvulopatia",nombre:"Valvulopatias Cardiacas",bodySystemId:"cardiovascular",definicion:"Conjunto de enfermedades que afectan a las valvulas cardiacas (mitral, aortica, tricuspidea, pulmonar), produciendo estenosis (obstruccion al flujo) o insuficiencia (regurgitacion) con consecuente sobrecarga de presion o volumen en las camaras cardiacas.",epidemiologia:"Afectan al 2-3% de la poblacion general adulta. La estenosis aortica es la valvulopatia mas frecuente en paises desarrollados (causa degenerativa en mayores de 65 a\xf1os). La insuficiencia mitral es la segunda mas prevalente.",factoresRiesgo:["Edad avanzada (degeneracion calcifica)","Fiebre reumatica (causa mas frecuente en paises en desarrollo)","Endocarditis infecciosa","Cardiopatia isquemica (insuficiencia mitral isquemica)","Enfermedades del tejido conectivo (Marfan, Ehlers-Danlos)","Radioterapia mediastinal previa","Hipertension arterial severa"],fisiopatologia:"En la estenosis, el orificio valvular reducido genera gradiente de presion: en estenosis aortica el VI desarrolla hipertrofia concentrica; en estenosis mitral hay dilatacion de auricula izquierda con riesgo de FA y embolia. En la insuficiencia, el reflujo produce sobrecarga de volumen: en insuficiencia aortica hay dilatacion del VI; en insuficiencia mitral la AI y el VI se dilatan. En ambos mecanismos el resultado final es la disfuncion ventricular y la IC.",signosYSintomas:{signos:["Soplos cardiacos caracteristicos segun valvula afectada","Cardiomegalia en Rx de torax","Signos de IC: estertores, edemas, ingurgitacion yugular","Pulso parvus et tardus en estenosis aortica severa","Latido apical desplazado en insuficiencia aortica severa"],sintomas:["Disnea de esfuerzo progresiva","Angina en estenosis aortica (triada de estenosis aortica)","Sincope en estenosis aortica severa","Palpitaciones (especialmente en FA asociada)","Fatiga cronica","Edemas en miembros inferiores"]},clasificacion:{nombre:"Clasificacion por severidad (ecocardiografica)",tipos:[{nombre:"Leve",descripcion:"Cambios hemodinamicos minimos, paciente asintomatico"},{nombre:"Moderada",descripcion:"Repercusion hemodinama parcial, sintomas con ejercicio intenso"},{nombre:"Severa",descripcion:"Repercusion hemodinama significativa, sintomas con ejercicio habitual o en reposo"},{nombre:"Muy severa",descripcion:"Compromiso hemodinamico critico, indicacion quirurgica urgente"}]},diagnostico:{anamnesis:["Fiebre reumatica en la infancia","Soplo cardiaco conocido de larga data","Evolucion de la capacidad funcional","Sincopes o presincopes (estenosis aortica)","Palpitaciones o episodios de FA"],examenFisico:["Auscultacion cardiaca detallada: localizacion, tipo, irradiacion del soplo","Cuantificacion de grado funcional (NYHA)","Palpacion del pulso arterial","Evaluacion de signos de IC"],pruebas:[{nombre:"Ecocardiograma Doppler transtorax",descripcion:"Estudio fundamental: gradiente valvular, area valvular, funcion ventricular, severidad",valoresReferencia:"Estenosis aortica severa: area < 1 cm2, gradiente medio > 40 mmHg",cuidadosEnfermeria:["No requiere preparacion especial","Posicionar en decubito lateral izquierdo","Facilitar acceso al torax del paciente"]},{nombre:"ECG",descripcion:"Detecta hipertrofia ventricular, FA asociada, bloqueos de conduccion",valoresReferencia:"Criterios de HVI en estenosis aortica; FA en estenosis mitral",cuidadosEnfermeria:["Realizar en reposo","Registrar ritmo y frecuencia cardiaca"]},{nombre:"Radiografia de torax",descripcion:"Valora cardiomegalia, congestion vascular pulmonar, calcificaciones valvulares",valoresReferencia:"Indice cardiotorax < 0.5 normal",cuidadosEnfermeria:["Posicion PA de pie si el paciente puede","Verificar ausencia de elementos metalicos"]},{nombre:"Cateterismo cardiaco",descripcion:"Confirma severidad cuando hay discordancia clinico-ecografica; descarta coronariopatia",valoresReferencia:"Gradiente transvalvular aortico > 50 mmHg en estenosis severa",cuidadosEnfermeria:["Preparar zona de puncion inguinal o radial","Vigilar via de acceso 24h post-procedimiento","Monitorizar PA y ECG post-cateterismo"]}]},tratamientoMedico:{objetivos:["Controlar sintomas y mejorar calidad de vida","Prevenir complicaciones (FA, IC, embolia)","Definir momento optimo de intervencion valvular"],farmacologico:[{nombre:"Diureticos (Furosemida)",grupo:"Diuretico de asa",mecanismo:"Reduce congestion pulmonar y edemas en IC valvular descompensada",dosis:"20-80 mg/dia VO o IV segun sintomas",cuidadosEnfermeria:["Monitorizar diuresis y peso diario","Controlar electrolitos semanales","Vigilar signos de deshidratacion"]},{nombre:"Anticoagulacion (Acenocumarol/Warfarina)",grupo:"Anticoagulante oral antagonista de vitamina K",mecanismo:"Previene trombosis en FA asociada y en valvulas mecanicas sustituidas",dosis:"Ajustar segun INR objetivo: FA 2-3; valvulas mecanicas 2.5-3.5",cuidadosEnfermeria:["Controlar INR segun protocolo","Educar sobre alimentos que interaccionan con acenocumarol","Vigilar signos de sangrado: hematomas, sangre en orina o heces"]},{nombre:"Betabloqueantes (Bisoprolol)",grupo:"Betabloqueante selectivo beta1",mecanismo:"Controla frecuencia cardiaca en FA; reduce demanda miocardica de oxigeno",dosis:"2.5-10 mg/dia",cuidadosEnfermeria:["Monitorizar FC y PA antes de cada dosis","No suspender abruptamente","Vigilar broncoespasmo en asmaticos"]},{nombre:"Profilaxis antibiotica (Amoxicilina)",grupo:"Antibiotico betalactamico",mecanismo:"Previene endocarditis infecciosa en procedimientos dentales o invasivos en alto riesgo",dosis:"2 g VO 30-60 min antes de procedimiento dental de alto riesgo",cuidadosEnfermeria:["Identificar pacientes con indicacion de profilaxis","Verificar alergias a penicilinas","Administrar en tiempo correcto antes del procedimiento"]}],noFarmacologico:["Seguimiento ecocardiografico periodico segun severidad","Actividad fisica adaptada (evitar ejercicio intenso en estenosis severa)","Higiene dental estricta para reducir riesgo de endocarditis"],quirurgico:["Recambio valvular quirurgico (valvula biologica o mecanica)","Valvuloplastia percutanea con balon (estenosis mitral)","TAVI: reemplazo valvular aortico transcateter en alto riesgo quirurgico","Reparacion mitral (mitroplastia) cuando es factible"]},cuidadosEnfermeria:{valoracion:["Auscultar soplo cardiaco y cambios en sus caracteristicas","Monitorizar signos de IC: disnea, edemas, ingurgitacion yugular","Evaluar clase funcional NYHA en cada contacto","Controlar FC para detectar FA (pulso irregular)"],intervenciones:["Administrar medicacion segun prescripcion","Monitorizar INR y ajustar anticoagulacion con el medico","Pesar al paciente diariamente en hospitalizados","Preparar al paciente para procedimientos diagnosticos y terapeuticos","Coordinar con equipo de cardiocirugia cuando este indicada la intervencion"],educacionPaciente:["Explicar la importancia del seguimiento ecocardiografico","Educacion sobre anticoagulacion: importancia del INR, alimentos, signos de sangrado","Profilaxis de endocarditis: higiene dental, informar al dentista","Reconocer signos de descompensacion: aumento de disnea, edemas, palpitaciones"],monitorizacion:["Signos vitales cada 8h","Peso diario en IC descompensada","INR segun protocolo si anticoagulado","ECG periodico para detectar FA o cambios de conduccion"]},npiNanda:[{codigo:"00029",nombre:"Disminucion del gasto cardiaco",definicion:"Cantidad insuficiente de sangre bombeada por el corazon",caracteristicasDefinitorias:["Soplo cardiaco","Disnea de esfuerzo","Taquicardia","Edemas"],factoresRelacionados:["Disfuncion valvular","Sobrecarga de presion o volumen"]},{codigo:"00092",nombre:"Intolerancia a la actividad",definicion:"Insuficiencia de energia fisiologica o psicologica para completar las actividades diarias",caracteristicasDefinitorias:["Disnea al esfuerzo","Fatiga","Angina con el ejercicio"],factoresRelacionados:["Desequilibrio entre aporte y demanda de oxigeno","Disfuncion valvular"]},{codigo:"00078",nombre:"Gestion de salud ineficaz",definicion:"Patron de regulacion del regimen terapeutico inadecuado para alcanzar objetivos de salud",caracteristicasDefinitorias:["Incumplimiento de controles ecocardiograficos","Falta de adherencia a anticoagulacion"],factoresRelacionados:["Complejidad del tratamiento","Falta de conocimiento"]}],npiNic:[{codigo:"4040",nombre:"Cuidados cardiacos",actividades:["Monitorizar signos y sintomas de IC","Auscultar soplos periodicamente","Pesar diariamente al paciente","Administrar medicacion prescrita"]},{codigo:"4120",nombre:"Manejo de liquidos",actividades:["Control de balance hidrico","Monitorizar electrolitos","Vigilar signos de sobrecarga hidrica"]},{codigo:"5510",nombre:"Educacion para la salud",actividades:["Ense\xf1ar importancia del seguimiento ecografico","Educar sobre anticoagulacion y profilaxis de endocarditis","Explicar signos de descompensacion"]}],npiNoc:[{codigo:"0400",nombre:"Efectividad de la bomba cardiaca",indicadores:["PA estable","FC controlada","Ausencia de signos de IC activa"],escala:"1=Desviacion grave, 5=Sin desviacion"},{codigo:"1803",nombre:"Conocimiento del proceso de la enfermedad",indicadores:["Explica su valvulopatia y su tratamiento","Menciona signos de alarma correctamente"],escala:"1=Ningun conocimiento, 5=Conocimiento extenso"}],complicaciones:["Insuficiencia cardiaca progresiva","Fibrilacion auricular","Tromboembolia y ACV embolico","Endocarditis infecciosa","Muerte subita en estenosis aortica severa sintomatica"],criteriosAlarma:["Sincope en estenosis aortica","Angina de reposo","Disnea brusca severa","Embolismo sistemico (ACV, isquemia aguda de extremidad)","Endocarditis: fiebre con soplo nuevo"],emergencyLevel:"moderado",relatedPathologyIds:["pat_icc","pat_hta","pat_icc"],isPremium:!0},{id:"pat_miocardiopatia",nombre:"Miocardiopatia Dilatada",bodySystemId:"cardiovascular",definicion:"Enfermedad del miocardio caracterizada por dilatacion y disfuncion sistolica del ventriculo izquierdo (o ambos ventriculos) en ausencia de condiciones de carga anormal o enfermedad coronaria que justifique el grado de disfuncion observado.",epidemiologia:"Prevalencia de 1/2500 en la poblacion general. Causa del 25-30% de los transplantes cardiacos. Mortalidad del 20-25% a los 5 a\xf1os con tratamiento optimo. Es la miocardiopatia mas frecuente.",factoresRiesgo:["Historia familiar (25-35% de casos son geneticos)","Alcoholismo cronico (cardiomiopatia alcoholica)","Quimioterapia cardiotoxica (antraciclinas, trastuzumab)","Miocarditis viral previa","Embarazo (cardiomiopatia periparto)","Enfermedades autoinmunes","Deficiencia de tiamina, selenio o carnitina"],fisiopatologia:"La lesion miocardica primaria produce disfuncion de cardiomiocitos con perdida de contractilidad. El VI se dilata y la fraccion de eyeccion se reduce (<40%). La activacion del sistema neurohormonas (SRAA, sistema simpatico) intenta compensar pero produce remodelado adverso con mayor dilatacion y fibrosis intersticial. El resultado es IC progresiva con riesgo de muerte subita por arritmias ventriculares.",signosYSintomas:{signos:["Cardiomegalia en Rx (indice cardiotorax > 0.55)","Tercer ruido cardiaco (galope ventricular)","Estertores crepitantes bibasales","Ingurgitacion yugular","Edemas con godet","Pulso alternante","Soplo de regurgitacion mitral funcional"],sintomas:["Disnea de esfuerzo progresiva (principal sintoma)","Ortopnea y disnea paroxistica nocturna","Fatiga cronica severa","Palpitaciones (taquicardia, extrasistoles)","Sincope en arritmias malignas","Angina atipica"]},clasificacion:{nombre:"Clasificacion etiologica",tipos:[{nombre:"Idiopatica",descripcion:"Sin causa identificable; diagnostico de exclusion"},{nombre:"Genetica familiar",descripcion:"Mutaciones en genes de proteinas del sarcomero o citoesqueleto"},{nombre:"Inflamatoria/viral",descripcion:"Secundaria a miocarditis; causas: Enterovirus, VIH, Chagas (endemica en Latinoamerica)"},{nombre:"Toxica",descripcion:"Alcoholismo, cocaina, antraciclinas, trastuzumab"},{nombre:"Metabolica",descripcion:"Deficiencias nutricionales, hipotiroidismo, feocromocitoma"}]},diagnostico:{anamnesis:["Historia familiar de miocardiopatia o muerte subita","Consumo de alcohol (cantidad y tiempo)","Quimioterapia cardiotoxica previa","Infeccion viral reciente precedente","Embarazo reciente (periparto)"],examenFisico:["Auscultacion: 3er ruido, soplo mitral funcional, estertores","Ingurgitacion yugular y reflujo hepatoyugular","Edema con godet bilateral","Cardiomegalia palpable (latido apical desplazado)"],pruebas:[{nombre:"Ecocardiograma transtorax",descripcion:"Define dilatacion ventricular, FEVI reducida y disfuncion sistolica global",valoresReferencia:"DTSVI > 55 mm; FEVI < 40%; sin alteraciones segmentarias",cuidadosEnfermeria:["No requiere preparacion","Posicionar en decubito lateral izquierdo","Documentar resultado para comparacion evolutiva"]},{nombre:"BNP / NT-proBNP",descripcion:"Marcador de estres de pared ventricular; guia tratamiento y pronostico",valoresReferencia:"BNP > 100 pg/mL sugiere IC; > 400 IC probable",cuidadosEnfermeria:["No requiere ayuno","Resultado rapido orienta tratamiento urgente"]},{nombre:"Resonancia magnetica cardiaca",descripcion:"Gold standard: caracteriza tejido miocardico, detecta fibrosis (realce tardio de gadolinio)",valoresReferencia:"Realce tardio de gadolinio indica fibrosis y mayor riesgo de arritmias",cuidadosEnfermeria:["Verificar ausencia de contraindicaciones para gadolinio (funcion renal)","Retirar objetos metalicos","Informar al paciente sobre duracion (45-60 min en tubo cerrado)"]},{nombre:"Holter de 24h",descripcion:"Detecta arritmias ventriculares y auriculares que guian indicacion de DAI",valoresReferencia:"Mas de 1000 extrasistoles ventriculares en 24h = significativo",cuidadosEnfermeria:["Colocar electrodos correctamente","Indicar al paciente que lleve diario de actividades y sintomas","Retirar dispositivo al dia siguiente"]}]},tratamientoMedico:{objetivos:["Reducir mortalidad mediante tratamiento neurohormonas","Mejorar clase funcional y calidad de vida","Prevenir muerte subita con DAI si FEVI < 35%","Tratar la causa subyacente si es identificable"],farmacologico:[{nombre:"Sacubitril/Valsartan (ARNI)",grupo:"Inhibidor de neprilisina y receptor de angiotensina",mecanismo:"Potencia peptidos natriureticos y bloquea SRAA, revirtiendo remodelado cardiaco",dosis:"Iniciar 24/26 mg cada 12h; titular hasta 97/103 mg cada 12h",cuidadosEnfermeria:["NO combinar con IECA (riesgo angioedema): esperar 36h de lavado","Monitorizar PA: hipotension frecuente al inicio","Controlar potasio y creatinina","Reemplaza al IECA en IC con FEVI reducida"]},{nombre:"Carvedilol",grupo:"Betabloqueante no selectivo",mecanismo:"Bloquea beta1, beta2 y alfa1; reduce remodelado, mortalidad y muerte subita",dosis:"3.125 mg c/12h inicial; doblar cada 2 semanas hasta 25-50 mg c/12h",cuidadosEnfermeria:["NO iniciar en IC aguda descompensada","Monitorizar FC y PA","No suspender abruptamente: riesgo de IC aguda"]},{nombre:"Dapagliflozina",grupo:"Inhibidor SGLT2",mecanismo:"Reduce hospitalizations por IC y mortalidad cardiovascular independientemente de diabetes",dosis:"10 mg/dia VO",cuidadosEnfermeria:["Monitorizar glucemia (puede producir hipoglucemia leve)","Vigilar infecciones urinarias y genitales","Contraindicada con TFG < 25 mL/min/1.73m2"]},{nombre:"Espironolactona",grupo:"Antagonista de aldosterona",mecanismo:"Reduce fibrosis miocardica y retencion de sodio; reduce mortalidad en IC",dosis:"25-50 mg/dia VO",cuidadosEnfermeria:["Monitorizar potasio: riesgo de hiperpotasemia","Contraindicada con K > 5.0 o creatinina > 2.5 mg/dL","Vigilar ginecomastia en hombres"]}],noFarmacologico:["Abstinencia absoluta de alcohol en cardiomiopatia alcoholica","Restriccion de sodio < 2 g/dia","Restriccion hidrica 1.5-2 L/dia en IC avanzada","Rehabilitacion cardiaca supervisada","Pesar a diario: consultar si aumento > 2 kg en 3 dias"],quirurgico:["DAI (Desfibrilador Automatico Implantable) si FEVI < 35% a pesar de tratamiento optimo 3 meses","TRC (Terapia de Resincronizacion Cardiaca) si bloqueo de rama izquierda y FEVI < 35%","Dispositivo de asistencia ventricular como puente a trasplante","Trasplante cardiaco en IC terminal refractaria"]},cuidadosEnfermeria:{valoracion:["Monitorizar disnea con escala modificada de Borg","Peso diario en mismas condiciones","Balance hidrico estricto","Evaluar clase funcional NYHA","Revisar adherencia a medicacion y restricciones"],intervenciones:["Posicionar en Fowler 30-45 grados","Administrar medicacion segun esquema","Monitorizar ECG para detectar arritmias ventriculares","Educar sobre autocontrol de peso y sintomas","Coordinar ecocardiograma de control periodico"],educacionPaciente:["Explicar importancia del tratamiento de cuatro pilares (IECA/ARNI, BB, ARM, SGLT2)","Instruir en automonitoreo de peso y cuando consultar","Educacion sobre restriccion de sodio y liquidos","Signos de alarma que requieren consulta urgente"],monitorizacion:["Peso diario","PA y FC cada 8h en hospitalizados","ECG: buscar extrasistoles ventriculares y BCRI","Ionograma y funcion renal semanales al inicio","BNP mensual para monitorizar respuesta"]},npiNanda:[{codigo:"00029",nombre:"Disminucion del gasto cardiaco",definicion:"Cantidad insuficiente de sangre bombeada",caracteristicasDefinitorias:["Disnea","Taquicardia","Edema","FEVI < 40%"],factoresRelacionados:["Disfuncion sistolica del ventriculo izquierdo"]},{codigo:"00092",nombre:"Intolerancia a la actividad",definicion:"Insuficiencia de energia para completar actividades diarias requeridas",caracteristicasDefinitorias:["Disnea de esfuerzo","Fatiga extrema","Clase NYHA III-IV"],factoresRelacionados:["Desequilibrio oferta-demanda de oxigeno miocardico"]},{codigo:"00002",nombre:"Desequilibrio nutricional: ingesta inferior a las necesidades",definicion:"Ingesta de nutrientes insuficiente para satisfacer necesidades metabolicas",caracteristicasDefinitorias:["Anorexia cardiaca","Nauseas","Perdida de peso no intencionada"],factoresRelacionados:["Congestion intestinal por IC","Medicacion"]}],npiNic:[{codigo:"4040",nombre:"Cuidados cardiacos",actividades:["Monitorizar peso diario y balance hidrico","Controlar ECG y signos de descompensacion","Administrar medicacion de 4 pilares"]},{codigo:"0180",nombre:"Manejo de la energia",actividades:["Planificar actividades con periodos de descanso","Evitar actividades extenuantes","Coordinar rehabilitacion cardiaca progresiva"]},{codigo:"5510",nombre:"Educacion para la salud",actividades:["Instruir en automonitoreo de peso","Ense\xf1ar restriccion de sodio y liquidos","Explicar esquema de 4 farmacos y su importancia"]}],npiNoc:[{codigo:"0400",nombre:"Efectividad de la bomba cardiaca",indicadores:["FEVI en seguimiento estable o mejorando","Clase NYHA mejorada","BNP en descenso"],escala:"1=Desviacion grave, 5=Sin desviacion"},{codigo:"1803",nombre:"Conocimiento del proceso de la enfermedad",indicadores:["Describe correctamente el tratamiento","Menciona signos de alarma","Practica automonitoreo de peso"],escala:"1=Ningun conocimiento, 5=Conocimiento extenso"}],complicaciones:["Muerte subita por arritmias ventriculares malignas","IC terminal refractaria","Tromboembolia (FA, trombos intraventriculares)","Muerte subita cardiaca"],criteriosAlarma:["Aumento de peso > 2 kg en 3 dias (descompensacion)","Disnea en reposo o a minimos esfuerzos","Sincope o presincope (arritmia maligna)","FA de nueva aparicion","SpO2 < 90% en reposo"],emergencyLevel:"moderado",relatedPathologyIds:["pat_icc","pat_hta"],isPremium:!0},{id:"pat_arteriopatia_periferica",nombre:"Enfermedad Arterial Periferica",bodySystemId:"cardiovascular",definicion:"Enfermedad aterosclerotica que afecta a las arterias de los miembros inferiores (principalmente), causando estenosis u oclusiones que reducen el flujo sanguineo distal y producen isquemia cronica o aguda.",epidemiologia:"Prevalencia del 3-10% en adultos mayores de 40 a\xf1os; aumenta al 15-20% en mayores de 70 a\xf1os. El 40-50% de los pacientes con EAP tiene enfermedad coronaria o cerebrovascular concomitante. La amputacion mayor ocurre en el 1-2% anual.",factoresRiesgo:["Tabaquismo (factor de riesgo mas importante)","Diabetes mellitus","Hipertension arterial","Dislipemia","Edad avanzada","Sexo masculino","Insuficiencia renal cronica","Hiperhomocisteinemia"],fisiopatologia:"La aterosclerosis produce placas que estenosan progresivamente las arterias iliofemoral y tibial. La reduccion del flujo produce isquemia muscular durante el ejercicio (claudicacion) y, en fases avanzadas, isquemia critica en reposo con riesgo de ulceras y gangrena. El indice tobillo-brazo (ITB) < 0.9 confirma el diagnostico.",signosYSintomas:{signos:["Ausencia o reduccion de pulsos distales (popliteo, pedio, tibial posterior)","ITB < 0.9 (diagnostico)","Palidez o cianosis del pie","Cambios troficos: perdida de vello, atrofia muscular, engrosamiento de unas","Ulceras isquemicas en talones o dedos","Gangrena seca en fases terminales"],sintomas:["Claudicacion intermitente: dolor muscular con el ejercicio que cede en reposo","Dolor en reposo en la extremidad distal (isquemia critica)","Frialdad de la extremidad","Parestesias (hormigueo, entumecimiento)"]},clasificacion:{nombre:"Clasificacion de Fontaine",tipos:[{nombre:"Estadio I",descripcion:"Asintomatico; ITB < 0.9 sin claudicacion"},{nombre:"Estadio II",descripcion:"Claudicacion intermitente; IIa > 200 metros; IIb < 200 metros"},{nombre:"Estadio III",descripcion:"Dolor isquemico en reposo"},{nombre:"Estadio IV",descripcion:"Necrosis o gangrena; isquemia critica con amenaza de la extremidad"}]},diagnostico:{anamnesis:["Caracteristicas y distancia de claudicacion (metros)","Tabaquismo: paquetes-anio","Antecedentes de diabetes, HTA, dislipemia","Antecedentes de episodios de isquemia aguda"],examenFisico:["Palpacion de pulsos en cuatro niveles: femoral, popliteo, pedio, tibial posterior","Medicion del ITB con Doppler","Inspeccion de la piel: temperatura, coloracion, lesiones","Busqueda de soplos femorales"],pruebas:[{nombre:"Indice Tobillo-Brazo (ITB)",descripcion:"Cociente entre la PA sistolica en tobillo y en brazo; prueba de cribado mas utilizada",valoresReferencia:"Normal 1.0-1.4; EAP leve 0.7-0.9; moderada 0.4-0.7; severa < 0.4",cuidadosEnfermeria:["Colocar manguitos en tobillo y brazo","Usar Doppler continuo de onda en arteria pedia y tibial posterior","Registrar valor mayor de cada tobillo para calculo"]},{nombre:"Ecografia Doppler arterial",descripcion:"Localiza y cuantifica las estenosis; mide velocidades de flujo",valoresReferencia:"Estenosis > 50% cuando la velocidad maxima sistolica se duplica",cuidadosEnfermeria:["No requiere preparacion especial","Evitar vendajes en zona de exploracion"]},{nombre:"Angio-TC o Angio-RMN",descripcion:"Planificacion preoperatoria: mapea toda la anatomia vascular del miembro",valoresReferencia:"Detecta estenosis > 50% con alta sensibilidad y especificidad",cuidadosEnfermeria:["Verificar funcion renal para contraste yodado en Angio-TC","Asegurar hidratacion adecuada pre y post contraste","Registrar alergias a contrastes"]},{nombre:"Perfil lipidico y glucemia",descripcion:"Evalua y monitoriza factores de riesgo modificables",valoresReferencia:"LDL objetivo < 70 mg/dL en EAP establecida; glucemia < 130 mg/dL postprandial",cuidadosEnfermeria:["Ayuno de 12 horas para lipidos","Registrar medicacion hipolipemiante actual"]}]},tratamientoMedico:{objetivos:["Reducir riesgo cardiovascular global (IAM, ACV)","Mejorar distancia de claudicacion","Prevenir amputacion en isquemia critica","Control estricto de factores de riesgo"],farmacologico:[{nombre:"Aspirina mas clopidogrel",grupo:"Antiagregacion plaquetaria",mecanismo:"Reduce trombosis arterial y eventos cardiovasculares en EAP establecida",dosis:"Aspirina 100 mg/dia mas Clopidogrel 75 mg/dia",cuidadosEnfermeria:["Administrar con alimentos","Vigilar sangrado digestivo y otros sangrados","No suspender antes de procedimientos sin consultar al medico"]},{nombre:"Atorvastatina",grupo:"Estatina de alta intensidad",mecanismo:"Reduce LDL, estabiliza placa aterosclerotica y reduce eventos cardiovasculares",dosis:"40-80 mg/dia; objetivo LDL < 70 mg/dL",cuidadosEnfermeria:["Administrar de noche para mayor eficacia","Monitorizar mialgias y CPK","Controlar perfil lipidico cada 3 meses hasta objetivo"]},{nombre:"Cilostazol",grupo:"Inhibidor de fosfodiesterasa III",mecanismo:"Vasodilatacion y antiagregacion; mejora la distancia de claudicacion",dosis:"100 mg cada 12h en ayunas",cuidadosEnfermeria:["Contraindicado en IC con cualquier grado","Puede producir cefalea y palpitaciones al inicio","Evaluar mejoria de la distancia caminada a las 12 semanas"]},{nombre:"Ramipril",grupo:"IECA",mecanismo:"Reduce eventos cardiovasculares en pacientes con EAP; tambien mejora la claudicacion",dosis:"5-10 mg/dia",cuidadosEnfermeria:["Monitorizar PA y funcion renal","Vigilar tos seca","Contraindicado en estenosis bilateral de arterias renales"]}],noFarmacologico:["Cese absoluto del tabaquismo (medida mas eficaz)","Programa de ejercicio supervisado (marcha 30-60 min/dia 3 veces/semana)","Control estricto de diabetes (HbA1c < 7%)","Control de dislipemia y HTA"],quirurgico:["Angioplastia transluminal percutanea (ATP) con o sin stent","Cirugia de bypass aortofemoral o femoropopliteo","Endarterectomia femoral","Amputacion en gangrena irreversible o sepsis incontrolable"]},cuidadosEnfermeria:{valoracion:["Palpar pulsos distales bilateralmente y documentar","Medir ITB con Doppler segun protocolo","Inspeccionar pie diabetico: lesiones, temperatura, coloracion","Evaluar distancia de claudicacion y dolor en reposo"],intervenciones:["Cuidado intensivo de los pies: higiene, hidratacion, corte de unas","Curar ulceras isquemicas con tecnica esteril","Elevar cabecera de la cama 15-20 cm (no elevar el pie en isquemia critica)","Proteger de traumatismos y presion en zonas de riesgo","Administrar antiagregantes y estatinas segun prescripcion"],educacionPaciente:["Instruccion detallada en cuidado de pies (inspeccion diaria, calzado adecuado)","Cese del tabaquismo: recursos disponibles, terapia sustitutiva de nicotina","Programa de ejercicio de marcha progresiva","Control glucemico y lipidico estrictos","Cuando consultar urgencias: dolor en reposo, herida que no cicatriza, pie frio o negro"],monitorizacion:["Pulsos distales y temperatura de extremidades diariamente","ITB periodicamente para evaluar progresion","Inspeccion de lesiones cutaneas cada turno en hospitalizados","PA y glucemia segun protocolo"]},npiNanda:[{codigo:"00024",nombre:"Perfusion tisular periferica ineficaz",definicion:"Disminucion de la circulacion sanguinea periferica que puede comprometer la salud",caracteristicasDefinitorias:["Ausencia de pulsos distales","Claudicacion intermitente","Cambios troficos del pie","ITB < 0.9"],factoresRelacionados:["Aterosclerosis periferica","Tabaquismo","Diabetes mellitus"]},{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva desagradable con da\xf1o tisular real o potencial",caracteristicasDefinitorias:["Claudicacion al caminar","Dolor en reposo nocturno en isquemia critica"],factoresRelacionados:["Isquemia muscular por estenosis arterial"]},{codigo:"00047",nombre:"Riesgo de deterioro de la integridad cutanea",definicion:"Riesgo de alteracion de la piel que puede comprometer la salud",caracteristicasDefinitorias:["ITB reducido","Cambios troficos","Pie frio"],factoresRelacionados:["Isquemia tisular periferica","Neuropatia diabetica asociada"]}],npiNic:[{codigo:"4070",nombre:"Precauciones circulatorias",actividades:["Monitorizar pulsos distales bilateralmente","Proteger la extremidad de trauma y presion","Elevar ligeramente la cabecera del lecho","No elevar el pie en isquemia critica (empeora perfusion)"]},{codigo:"3590",nombre:"Vigilancia de la piel",actividades:["Inspeccionar pie diariamente en busca de lesiones","Documentar caracteristicas de ulceras si existen","Curar lesiones con tecnica esteril"]},{codigo:"5510",nombre:"Educacion para la salud",actividades:["Ense\xf1ar cuidado intensivo del pie","Motivar cese del tabaquismo con recursos practicos","Explicar programa de marcha terapeutica"]}],npiNoc:[{codigo:"0407",nombre:"Perfusion tisular: periferica",indicadores:["Pulsos distales palpables","ITB mejorado o estable","Ausencia de ulceras nuevas","Temperatura del pie normal"],escala:"1=Desviacion grave, 5=Sin desviacion"},{codigo:"1103",nombre:"Curacion de la herida: por primera intencion",indicadores:["Reduccion del area de ulcera","Ausencia de signos de infeccion","Formacion de tejido de granulacion"],escala:"1=No hay evidencia, 5=Extensa evidencia"}],complicaciones:["Isquemia critica con amenaza de amputacion","Ulceras isquemicas de evolucion torpida","Gangrena seca o humeda","Amputacion mayor del miembro","Infarto de miocardio y ACV (riesgo cardiovascular global aumentado)"],criteriosAlarma:["Dolor isquemico en reposo (estadio III: urgencia vascular)","Pie negro o con gangrena (estadio IV)","Ulcera con signos de infeccion profunda: fiebre, celulitis, olor fetido","Perdida brusca de pulso distal (isquemia aguda): las 6 P: Pain, Pallor, Paresthesia, Paralysis, Pulselessness, Poikilothermia"],emergencyLevel:"moderado",relatedPathologyIds:["pat_hta","pat_dm2"],isPremium:!0},{id:"pat_derrame_pleural",nombre:"Derrame Pleural",bodySystemId:"respiratorio",definicion:"Acumulacion anormal de liquido en el espacio pleural, por desequilibrio entre la produccion y el drenaje del liquido pleural normal. Puede ser trasudado o exudado segun los criterios de Light.",epidemiologia:"Prevalencia de 320 casos por 100.000 habitantes/anio. Causas mas frecuentes: IC (trasudado), neumonia bacteriana (exudado parapneumonico), cancer (exudado maligno) y tuberculosis.",factoresRiesgo:["Insuficiencia cardiaca congestiva","Cirrosis hepatica","Sindrome nefrotico","Neumonia bacteriana","Neoplasias malignas","Tuberculosis","Embolia pulmonar","Artritis reumatoide y LES","Cirugia toracica o abdominal reciente"],fisiopatologia:"El liquido pleural normal (10-20 mL) se forma en la pleura parietal y se reabsorbe por los linfaticos. En el trasudado el desequilibrio se debe a aumento de presion hidrostatica o reduccion de presion oncotica (IC, cirrosis, sindrome nefrotico). En el exudado hay inflamacion pleural con aumento de permeabilidad vascular (neumonia, TB, cancer). El liquido acumulado comprime el pulmon reduciendo la capacidad vital.",signosYSintomas:{signos:["Disminucion del murmullo vesicular en base afectada","Matidez a la percusion en area del derrame","Abolicion del fremitovorboxilico","Egofonia por encima del derrame","Desviacion traqueal al lado contrario si es masivo","Disminucion de la expansion toracica ipsilateral"],sintomas:["Disnea proporcional al tamano del derrame","Tos seca e irritativa","Dolor pleuritico (agudo, en puntada) en derrames inflamatorios","Ortopnea si bilateral","Sintomas de la enfermedad subyacente: fiebre en neumonia, adelgazamiento en cancer"]},clasificacion:{nombre:"Clasificacion por criterios de Light (exudado vs trasudado)",tipos:[{nombre:"Trasudado",descripcion:"Proteinas LP/S < 0.5; LDH LP/S < 0.6; LDH LP < 2/3 del limite superior normal. Causas: IC, cirrosis, nefrotico"},{nombre:"Exudado",descripcion:"Al menos 1 criterio de Light positivo. Causas: neumonia, TB, cancer, embolia"},{nombre:"Empiema pleural",descripcion:"Exudado purulento con bacterias; pH < 7.2; glucosa < 40 mg/dL"},{nombre:"Hemotorax",descripcion:"Hematocrito del liquido pleural > 50% del sanguineo; causa traumatica o iatrogena"},{nombre:"Quilotorax",descripcion:"Trigliceridos > 110 mg/dL en liquido pleural; causa: trauma linfatico o linfoma"}]},diagnostico:{anamnesis:["Inicio y progresion de la disnea","Antecedente de IC, cirrosis, neoplasia, TB","Fiebre y sintomas infecciosos (neumonia)","Adelgazamiento no intencionado (neoplasia)","Trauma toracico reciente"],examenFisico:["Percusion: matidez desplazable segun posicion","Auscultacion: abolicion de murmullo vesicular","Valoracion de edemas y signos de IC","Busqueda de adenopatias (neoplasia o TB)"],pruebas:[{nombre:"Radiografia de torax",descripcion:"Detecta derrames de mas de 200 mL; opacidad homogenea con concavidad superior (curva de Damoiseau)",valoresReferencia:"Borramiento del seno costofrenico en derrames moderados",cuidadosEnfermeria:["Posicion PA estandar de pie","En paciente encamado realizar en proyeccion lateral si es posible","Comparar con Rx previa"]},{nombre:"Ecografia pleural",descripcion:"Gold standard para guiar toracocentesis; detecta derrames loculados",valoresReferencia:"Cuantifica volumen y caracteriza el liquido (anecoico vs ecogenico)",cuidadosEnfermeria:["Posicionar sentado o en decubito lateral","Marcar sitio de puncion con dermografo","Preparar equipo de toracocentesis"]},{nombre:"Toracocentesis diagnostica",descripcion:"Extraccion de liquido para analisis: citologia, bioquimica, cultivos, criterios de Light",valoresReferencia:"Criterios de Light: proteinas > 3 g/dL, LDH > 200 UI/L sugieren exudado",cuidadosEnfermeria:["Posicionar sentado con brazos sobre mesa","Monitorizar PA, FC y SpO2 durante el procedimiento","Extraer maximo 1500 mL en primera sesion para evitar edema de reexpansion","Rx de torax de control post-procedimiento"]},{nombre:"TC de torax con contraste",descripcion:"Caracteriza el derrame, detecta adenopatias, lesiones malignas y embolia pulmonar",valoresReferencia:"Evalua densidad del liquido y presencia de enhancement pleural (empiema o mesotelioma)",cuidadosEnfermeria:["Verificar funcion renal y alergias al contraste","Hidratacion pre y post contraste yodado"]}]},tratamientoMedico:{objetivos:["Tratar la causa subyacente (principal objetivo)","Aliviar la disnea drenando el derrame si es grande o sintomatico","Prevenir recurrencias en derrames malignos"],farmacologico:[{nombre:"Antibioticos (Amoxicilina-clavulanico)",grupo:"Antibiotico betalactamico con inhibidor de betalactamasas",mecanismo:"Tratamiento del derrame parapneumonico complicado o empiema por bacterias grampositivas y anaerobios",dosis:"1-2 g cada 8h IV; transicion a 875 mg VO cada 12h",cuidadosEnfermeria:["Administrar en 30 min IV","Registrar alergias a penicilinas","Controlar fiebre y PCR como marcadores de respuesta"]},{nombre:"Furosemida",grupo:"Diuretico de asa",mecanismo:"Reduce el derrame pleural trasudativo secundario a IC aumentando la eliminacion de sodio y agua",dosis:"20-80 mg/dia IV o VO segun respuesta",cuidadosEnfermeria:["Monitorizar diuresis y peso diario","Controlar electrolitos: hipopotasemia e hiponatremia","Vigilar signos de deshidratacion"]},{nombre:"Talco para pleurodesis",grupo:"Agente esclerosante",mecanismo:"Produce inflamacion pleural controlada que fusiona las hojas pleurales, previniendo reacumulacion en derrames malignos recurrentes",dosis:"5 g de talco en slurry o poudrage por toracoscopia",cuidadosEnfermeria:["Administrar analgesicos previos (dolor intenso post-procedimiento)","Monitorizar SpO2 post-pleurodesis","Posicionar al paciente en distintas posiciones para distribuir el talco"]}],noFarmacologico:["Toracocentesis evacuadora terapeutica si disnea significativa","Drenaje pleural con tubo si empiema o hemotorax","Drenaje pleural con cateter tunelizado en derrames malignos recurrentes","Pleurodesis quimica o toracoscopia en derrames malignos"],quirurgico:["Decorticacion pleural en empiema tabicado cronifico","VATS (cirugia toracoscopica) para diagnostico y tratamiento","Pleurodesis por toracoscopia con talco en derrames malignos"]},cuidadosEnfermeria:{valoracion:["Monitorizar disnea con escala numerica y SpO2","Auscultar campos pulmonares antes y despues de procedimientos","Evaluar caracteristicas del dolor toracico","Controlar signos vitales: fiebre, taquicardia, taquipnea"],intervenciones:["Posicionar en semifowler o fowler para aliviar disnea","Administrar oxigenoterapia si SpO2 < 92%","Preparar y asistir en toracocentesis (material esteril, posicion del paciente)","Medir y documentar caracteristicas del liquido extraido: color, turbidez, cantidad","Rx de torax de control post-procedimiento"],educacionPaciente:["Explicar causa del derrame y plan de tratamiento","Indicar cuando consultar: aumento de disnea, fiebre, dolor toracico intenso","Importancia del tratamiento de la enfermedad subyacente","Si tubo de drenaje: cuidados del tubo y cuando consultar"],monitorizacion:["SpO2 continua si sintomatico","Signos vitales cada 4-6h","Cantidad de drenaje si hay tubo pleural","Rx torax de control segun evolucion"]},npiNanda:[{codigo:"00032",nombre:"Patron respiratorio ineficaz",definicion:"La inspiracion o espiracion no proporciona ventilacion adecuada",caracteristicasDefinitorias:["Disnea","Disminucion del murmullo vesicular","SpO2 reducida","Uso de musculos accesorios"],factoresRelacionados:["Compresion pulmonar por liquido pleural"]},{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable asociada con da\xf1o tisular",caracteristicasDefinitorias:["Dolor pleuritico en puntada","Posicion antialgica","Taquicardia"],factoresRelacionados:["Inflamacion pleural en derrames exudativos"]},{codigo:"00004",nombre:"Riesgo de infeccion",definicion:"Riesgo de ser invadido por organismos patogenos",caracteristicasDefinitorias:["Procedimiento invasivo de toracocentesis"],factoresRelacionados:["Toracocentesis o drenaje pleural","Empiema subyacente"]}],npiNic:[{codigo:"3350",nombre:"Monitorizacion respiratoria",actividades:["Monitorizar FR, SpO2 y signos de dificultad respiratoria","Auscultar campos pulmonares cada turno","Registrar cambios en el patron respiratorio"]},{codigo:"1872",nombre:"Cuidados del tubo de torax",actividades:["Mantener sello de agua correcto","Registrar cantidad y caracteristicas del drenaje","Vigilar fugas de aire (burbujeo continuo)","Mantener sistema por debajo del nivel del pecho"]},{codigo:"1400",nombre:"Manejo del dolor",actividades:["Evaluar dolor con escala numerica","Administrar analgesicos previo a procedimientos","Posicionar al paciente para aliviar dolor pleuritico"]}],npiNoc:[{codigo:"0403",nombre:"Estado respiratorio: ventilacion",indicadores:["SpO2 > 92%","Ausencia de disnea en reposo","Murmullo vesicular presente en bases"],escala:"1=Desviacion grave, 5=Sin desviacion"},{codigo:"0702",nombre:"Estado de los signos vitales",indicadores:["FR 12-20 rpm","SpO2 > 92%","Afebril"],escala:"1=Desviacion grave, 5=Sin desviacion"}],complicaciones:["Empiema pleural","Fibrosis y atrapamiento pulmonar","Edema de reexpansion pulmonar post-drenaje","Neumotorax iatrogeno por toracocentesis","Fistula broncopleural"],criteriosAlarma:["Disnea severa con SpO2 < 90%","Fiebre con liquido purulento (empiema)","Hemoptisis o salida de sangre por tubo pleural","Desviacion traqueal (derrame masivo con tension)","Dolor toracico con hipotension (hemotorax)"],emergencyLevel:"moderado",relatedPathologyIds:["pat_icc","pat_neumonia"],isPremium:!0},{id:"pat_fibrosis_pulmonar",nombre:"Fibrosis Pulmonar",bodySystemId:"respiratorio",definicion:"Enfermedad pulmonar intersticial cronica y progresiva caracterizada por la acumulacion excesiva de tejido fibroso en el intersticio pulmonar, que destruye la arquitectura normal del pulmon y reduce progresivamente la capacidad de intercambio gaseoso.",epidemiologia:"La fibrosis pulmonar idiopatica (FPI) tiene una prevalencia de 13-20 casos por 100.000 habitantes. Predomina en hombres mayores de 60 a\xf1os. La supervivencia media desde el diagnostico es de 3-5 a\xf1os.",factoresRiesgo:["Tabaquismo (principal factor de riesgo para FPI)","Edad avanzada (> 60 a\xf1os)","Sexo masculino","Exposicion a polvos organicos (aves, mohos: neumonitis por hipersensibilidad)","Exposicion a asbesto o silice","Enfermedades autoinmunes (AR, LES, esclerodermia)","Mutaciones geneticas en surfactante o telomerasa","Reflujo gastroesofagico cronico"],fisiopatologia:"En la FPI, el da\xf1o repetido del epitelio alveolar activa fibroblastos que producen exceso de colageno tipo I y III, reemplazando el parenquima normal con tejido cicatricial. El patron histologico es la neumonia intersticial usual (NIU) con focos de fibroblastos activos (focos fibroblasticos), panalizaci\xf3n y traccion bronquiectasica. La fibrosis progresiva reduce la distensibilidad pulmonar y aumenta el trabajo respiratorio.",signosYSintomas:{signos:["Crepitantes secos tipo velcro en bases (hallazgo caracteristico)","Acropaquias (hipocratismo digital) en 25-50%","Taquipnea","Cianosis central en fases avanzadas","Signos de cor pulmonale en estadios avanzados: ingurgitacion yugular, edemas"],sintomas:["Disnea de esfuerzo progresiva de inicio insidioso (principal sintoma)","Tos seca e irritativa persistente","Fatiga cronica","Perdida de peso en estadios avanzados"]},clasificacion:{nombre:"Clasificacion por severidad funcional",tipos:[{nombre:"Leve",descripcion:"CVF > 70% y DLCO > 40%; minimos sintomas"},{nombre:"Moderada",descripcion:"CVF 50-70% y DLCO 30-40%; disnea con esfuerzos moderados"},{nombre:"Severa",descripcion:"CVF < 50% o DLCO < 30%; disnea con minimos esfuerzos; candidato a trasplante"},{nombre:"Exacerbacion aguda",descripcion:"Deterioro agudo sobre FPI cronica con nuevas opacidades; alta mortalidad"}]},diagnostico:{anamnesis:["Inicio y progresion de la disnea (meses o a\xf1os)","Historia de tabaquismo y cuantificacion","Exposiciones ocupacionales y ambientales detalladas","Antecedentes de enfermedades autoinmunes","Historia familiar de fibrosis pulmonar"],examenFisico:["Auscultacion: crepitantes tipo velcro en bases (bibasal)","Inspeccion: acropaquias","Frecuencia respiratoria en reposo y con esfuerzo","Saturacion de oxigeno basal y con ejercicio (prueba de la marcha de 6 min)"],pruebas:[{nombre:"TACAR de torax (TC de alta resolucion)",descripcion:"Estudio de eleccion: patron en panal (honeycombing) y bronquiectasias de traccion en bases y subpleural, sin vidrio esmerilado predominante",valoresReferencia:"Patron tipico de NIU: 90% de especificidad para FPI",cuidadosEnfermeria:["No requiere contraste en la mayoria de los casos","Informar sobre posicion y apnea inspiratoria durante la adquisicion"]},{nombre:"Pruebas de funcion pulmonar (espirometria y DLCO)",descripcion:"Patron restrictivo: CVF reducida, VEF1/CVF normal o aumentado; DLCO muy reducida",valoresReferencia:"CVF < 80% predicho; DLCO < 70% predicho en FPI moderada-severa",cuidadosEnfermeria:["Verificar que el paciente no haya fumado ni usado broncodilatadores 4h antes","Instruir en tecnica correcta de espirometria","Registrar resultado para comparacion evolutiva cada 6 meses"]},{nombre:"LBA (Lavado Broncoalveolar)",descripcion:"Descarta otras causas de enfermedad intersticial; en FPI predominan neutrofilos",valoresReferencia:"Neutrofilia > 3% orienta a FPI; linfocitosis > 30% sugiere NINE o NHP",cuidadosEnfermeria:["Preparar para broncoscopia: ayuno 8h, via venosa, monitoreo continuo","Vigilar post-procedimiento: fiebre, broncoespasmo, desaturacion"]},{nombre:"Prueba de la marcha de 6 minutos",descripcion:"Mide distancia caminada en 6 min y desaturacion de oxigeno con el esfuerzo; valor pronostico",valoresReferencia:"Normal > 400 m; desaturacion < 88% con esfuerzo = indicacion de oxigeno ambulatorio",cuidadosEnfermeria:["Realizar en pasillo estandar de 30 metros","Monitorizar SpO2 y FC durante la prueba","Tener oxigeno disponible por si hay desaturacion severa"]}]},tratamientoMedico:{objetivos:["Enlentecer la progresion de la fibrosis","Controlar los sintomas","Prevenir exacerbaciones agudas","Considerar trasplante pulmonar en candidatos"],farmacologico:[{nombre:"Nintedanib",grupo:"Inhibidor de tirosina cinasas (antifibrosante)",mecanismo:"Inhibe receptores de PDGF, VEGF y FGF, reduciendo la activacion de fibroblastos y la produccion de colageno",dosis:"150 mg cada 12h con alimentos",cuidadosEnfermeria:["Principal efecto adverso: diarrea (en 60%); indicar loperamida si ocurre","Hepatotoxicidad: controlar transaminasas al inicio, a las 4 semanas y luego mensual","No usar en embarazo; anticoncepcion eficaz obligatoria","Administrar siempre con alimentos para reducir nauseas"]},{nombre:"Pirfenidona",grupo:"Antifibrosante de mecanismo multiple",mecanismo:"Reduce proliferacion de fibroblastos y produccion de TGF-beta, enlenteciendo la perdida de CVF",dosis:"Titulacion progresiva hasta 2403 mg/dia en 3 dosis con alimentos",cuidadosEnfermeria:["Fotosensibilidad: usar protector solar SPF 50 y ropa protectora al sol","Nauseas y anorexia al inicio: titulacion lenta y toma con alimentos","Controlar transaminasas mensualmente en el primer ano"]},{nombre:"N-acetilcisteina",grupo:"Antioxidante mucol\xedtico",mecanismo:"Reduce el estres oxidativo; uso limitado como adyuvante en algunos pacientes",dosis:"600 mg cada 8h VO",cuidadosEnfermeria:["Bien tolerado en general","Puede producir nauseas y reflujo: tomar con agua abundante","No hay evidencia fuerte de beneficio en FPI como monoterapia"]}],noFarmacologico:["Oxigenoterapia domiciliaria si SpO2 < 88% con esfuerzo o < 90% en reposo","Rehabilitacion respiratoria: mejora capacidad de esfuerzo y calidad de vida","Vacunacion: antigripal anual y antineumococica","Cese del tabaquismo obligatorio","Tratamiento de reflujo gastroesofagico (IBP)"],quirurgico:["Trasplante pulmonar bilateral (primera eleccion en candidatos elegibles con FPI severa o progresiva)","Biopsia pulmonar por VATS cuando el diagnostico es incierto"]},cuidadosEnfermeria:{valoracion:["Monitorizar SpO2 en reposo y con actividad","Evaluar disnea con escala modificada de MRC (0-4)","Controlar peso: perdida en estadios avanzados","Escuchar crepitantes basales en cada turno"],intervenciones:["Administrar oxigenoterapia ajustando flujo para SpO2 > 90%","Administrar antifibrosantes con comidas segun indicacion","Posicionar en semifowler para reducir trabajo respiratorio","Planificar actividades para evitar fatiga excesiva","Educacion en tecnicas de ahorro energetico"],educacionPaciente:["Explicar naturaleza progresiva e incurable de la enfermedad con empatia","Instruir en uso correcto de oxigeno domiciliario","Cese del tabaquismo urgente","Proteccion solar con nintedanib o pirfenidona","Cuando consultar: empeoramiento brusco de disnea (posible exacerbacion aguda)"],monitorizacion:["SpO2 continua si en exacerbacion aguda","CVF y DLCO cada 6 meses en FPI estable","Transaminasas mensual en primer ano de antifibrosante","Prueba de 6 min anual o si hay cambio clinico"]},npiNanda:[{codigo:"00032",nombre:"Patron respiratorio ineficaz",definicion:"Inspiracion o espiracion que no proporciona ventilacion adecuada",caracteristicasDefinitorias:["Disnea de esfuerzo","Taquipnea","Uso de musculos accesorios","SpO2 reducida con el esfuerzo"],factoresRelacionados:["Reduccion de la distensibilidad pulmonar por fibrosis intersticial"]},{codigo:"00092",nombre:"Intolerancia a la actividad",definicion:"Insuficiencia de energia para completar actividades diarias",caracteristicasDefinitorias:["Disnea con esfuerzos menores","Fatiga cronica","Desaturacion con la marcha"],factoresRelacionados:["Limitacion ventilatoria restrictiva","Hipoxemia de esfuerzo"]},{codigo:"00187",nombre:"Disposicion para mejorar el poder personal",definicion:"Patron de participacion consciente en el autocuidado que puede ser reforzado",caracteristicasDefinitorias:["Adhiere al tratamiento antifibrosante","Usa oxigeno domiciliario correctamente"],factoresRelacionados:["Motivacion del paciente","Apoyo familiar"]}],npiNic:[{codigo:"3350",nombre:"Monitorizacion respiratoria",actividades:["Monitorizar SpO2 en reposo y con actividad","Registrar patron respiratorio y FR","Identificar signos de exacerbacion aguda"]},{codigo:"0180",nombre:"Manejo de la energia",actividades:["Planificar actividades con periodos de descanso","Ense\xf1ar tecnicas de ahorro energetico","Coordinar rehabilitacion respiratoria"]},{codigo:"5510",nombre:"Educacion para la salud",actividades:["Instruir en uso de oxigenoterapia domiciliaria","Explicar efectos adversos de antifibrosantes y como manejarlos","Educacion sobre proteccion solar"]}],npiNoc:[{codigo:"0403",nombre:"Estado respiratorio: ventilacion",indicadores:["SpO2 > 90% en reposo","Disnea controlada en actividades cotidianas","Uso eficaz del oxigeno domiciliario"],escala:"1=Desviacion grave, 5=Sin desviacion"},{codigo:"0005",nombre:"Tolerancia a la actividad",indicadores:["Distancia en prueba de 6 min estable o mejorada","SpO2 > 88% durante la marcha con oxigeno"],escala:"1=Comprometido gravemente, 5=No comprometido"}],complicaciones:["Insuficiencia respiratoria cronica con necesidad de oxigenoterapia permanente","Exacerbacion aguda de FPI (alta mortalidad)","Hipertension pulmonar secundaria","Cancer de pulmon (riesgo aumentado)","Cor pulmonale"],criteriosAlarma:["Empeoramiento brusco de disnea en dias (exacerbacion aguda)","SpO2 < 88% en reposo","Fiebre alta con aumento de disnea (infeccion sobre FPI)","Hemoptisis","Dolor toracico pleuritico (neumotorax)"],emergencyLevel:"moderado",relatedPathologyIds:["pat_epoc"],isPremium:!0},{id:"pat_sdra",nombre:"Sindrome de Distres Respiratorio Agudo",bodySystemId:"respiratorio",definicion:"Insuficiencia respiratoria aguda grave caracterizada por inflamacion pulmonar difusa, aumento de la permeabilidad vascular, edema alveolar no cardiogenico, hipoxemia severa refractaria y opacidades bilaterales en la imagen toracica.",epidemiologia:"Incidencia de 150-200 casos por 100.000 habitantes/ano. Mortalidad hospitalaria del 35-40% en SDRA moderado-severo. Es la principal causa de ingreso en UCI por causa respiratoria.",factoresRiesgo:["Neumonia grave (causa mas frecuente, 35% de los casos)","Sepsis de cualquier origen (20-40%)","Aspiracion de contenido gastrico","Trauma torax multiple o politrauma","Transfusion masiva de sangre (TRALI)","Pancreatitis aguda severa","Inhalacion de humos o toxicos"],fisiopatologia:"El da\xf1o alveolar difuso produce rotura de la barrera alveolo-capilar con extravasacion de liquido proteinaceo al alveolo. Los neutrofilos liberan citocinas proinflamatorias (IL-1, IL-6, TNF-alfa), radicales libres y proteasas que amplifican el da\xf1o. Los alveolos se llenan de exudado inflamatorio y la surfactante se inactiva, produciendo colapso alveolar difuso, shunt pulmonar masivo e hipoxemia refractaria. La relacion PaO2/FiO2 < 300 define el SDRA.",signosYSintomas:{signos:["Taquipnea severa (> 30 rpm)","Uso de musculos accesorios","Cianosis central","Hipoxemia refractaria al oxigeno (PaO2/FiO2 < 300)","Opacidades bilaterales difusas en Rx y TC","Estertores crepitantes difusos en ambos campos"],sintomas:["Disnea severa de inicio agudo (< 7 dias)","Sensacion de ahogo extremo","Agitacion o confusion por hipoxemia cerebral"]},clasificacion:{nombre:"Criterios de Berlin (2012)",tipos:[{nombre:"Leve",descripcion:"PaO2/FiO2 200-300 mmHg con PEEP o CPAP >= 5 cmH2O"},{nombre:"Moderado",descripcion:"PaO2/FiO2 100-200 mmHg con PEEP >= 5 cmH2O"},{nombre:"Severo",descripcion:"PaO2/FiO2 < 100 mmHg con PEEP >= 5 cmH2O; mortalidad 45%"}]},diagnostico:{anamnesis:["Inicio agudo en < 7 dias","Causa precipitante identificable (neumonia, sepsis, trauma)","Ausencia de IC como causa del edema (o descartar con ecocardiograma)"],examenFisico:["Evaluacion del patron respiratorio y uso de musculos accesorios","Auscultacion: estertores difusos bilaterales","Estado hemodinamico: PA, FC, signos de perfusion"],pruebas:[{nombre:"Gasometria arterial",descripcion:"Define severidad: calcula PaO2/FiO2 con FiO2 conocida",valoresReferencia:"PaO2/FiO2 < 300 en SDRA; < 100 en severo",cuidadosEnfermeria:["Extraer bajo FiO2 conocida y estable al menos 30 min","Manejar muestra en hielo","Resultado urgente en menos de 15 min"]},{nombre:"Radiografia de torax",descripcion:"Opacidades bilaterales alveolares difusas no explicadas por otra causa (no derrame, no atelectasia lobar)",valoresReferencia:"Infiltrados bilaterales difusos; no cardiomegalia",cuidadosEnfermeria:["Proyeccion AP en cama en ventilacion mecanica","Comparar con Rx anterior si existe"]},{nombre:"TC torax",descripcion:"Caracteriza distribucion del da\xf1o: areas de consolidacion, vidrio esmerilado, zonas sanas dorsales (reclutables)",valoresReferencia:"Patron heterogeneo tipico de SDRA: consolidacion declive + vidrio esmerilado",cuidadosEnfermeria:["Transportar con monitoreo completo y ventilacion manual o portable","Preparar equipo de emergencia para el traslado"]},{nombre:"Ecocardiograma",descripcion:"Descarta IC como causa del edema pulmonar bilateral",valoresReferencia:"FEVI normal, sin signos de disfuncion diastolica severa descarta IC",cuidadosEnfermeria:["Puede realizarse al lado de la cama (ecocardiograma de punto de cuidado)","No interrumpir ventilacion mecanica durante el estudio"]}]},tratamientoMedico:{objetivos:["Mantener oxigenacion adecuada mientras se resuelve la causa","Evitar da\xf1o pulmonar inducido por el ventilador (VILI)","Tratar la causa desencadenante (ej: antibioticos en neumonia)","Prevenir fallo multiorganico"],farmacologico:[{nombre:"Corticoides (Metilprednisolona)",grupo:"Corticosteroide sist\xe9mico",mecanismo:"Reduce la inflamacion sistemica en SDRA moderado-severo persistente (> 7 dias); evidencia en SDRA por COVID-19",dosis:"1-2 mg/kg/dia IV en SDRA moderado-severo con mas de 7 dias de evolucion",cuidadosEnfermeria:["Controlar glucemia cada 4-6h (hiperglucemia frecuente)","Vigilar infecciones secundarias","No usar en SDRA de causa traumatica o en los primeros 7 dias (puede ser perjudicial)"]},{nombre:"Neurorelajantes (Cisatracurio)",grupo:"Bloqueante neuromuscular",mecanismo:"Elimina el esfuerzo respiratorio espontaneo asincronico con el ventilador en las primeras 48h de SDRA severo",dosis:"37.5 mg bolo seguido de infusion 37.5 mg/h por 48h",cuidadosEnfermeria:["SIEMPRE con sedoanalgesia profunda simultanea","Vigilar acumulacion de secreciones (no tose)","Posicion prona recomendada simultaneamente","Monitorizar tren de cuatro con neuroestimulador"]},{nombre:"Antibioticos de amplio espectro",grupo:"Antibioticos para tratar causa precipitante",mecanismo:"Tratamiento de la causa precipitante infecciosa (neumonia, sepsis)",dosis:"Segun foco infeccioso y germen identificado (cultivos previos)",cuidadosEnfermeria:["Extraer hemocultivos antes del inicio","Administrar primera dosis en menos de 1 hora de indicado","Ajustar dosis en insuficiencia renal"]}],noFarmacologico:["Ventilacion mecanica protectora: VT 6 mL/kg de peso ideal, PEEP titulada, presion meseta < 30 cmH2O","Posicion prona 16-18h/dia en SDRA moderado-severo (PaO2/FiO2 < 150): reduce mortalidad","Balance hidrico neutro o negativo una vez hemodinamicamente estable","Estrategia de sedacion con objetivo RASS -1 a -2"],quirurgico:["ECMO (oxigenacion de membrana extracorporea) veno-venosa en SDRA severo refractario a ventilacion protectora"]},cuidadosEnfermeria:{valoracion:["Monitorizar parametros ventilatorios: VT, FiO2, PEEP, presion meseta cada hora","Gasometria arterial cada 4-6h o segun cambios de parametros","Evaluar sincronismo paciente-ventilador","Monitorizar balance hidrico estricto (ingresos-egresos)"],intervenciones:["Ejecutar protocolo de posicion prona con equipo de 5 personas (prono-team)","Cuidados en prono: proteger ojos, nariz, orejas y prominencias oseas","Aspiracion de secreciones por sistema cerrado","Higiene oral con clorhexidina cada 6h (prevencion de NAVM)","Mantener cabecera a 30-45 grados (excepto en prono)"],educacionPaciente:["Dado que el paciente suele estar sedado, la educacion es principalmente a la familia","Informar a familia sobre el estado critico y el plan terapeutico","Preparar a la familia para la posible imagen del paciente en prono con multiples dispositivos"],monitorizacion:["Parametros ventilatorios continuo","SpO2 continua","Gasometria cada 4-6h","Balance hidrico horario","Presion de meseta y driving pressure en cada cambio de parametros"]},npiNanda:[{codigo:"00030",nombre:"Deterioro del intercambio gaseoso",definicion:"Exceso o deficit en la oxigenacion o eliminacion de dioxido de carbono en la membrana alveolo-capilar",caracteristicasDefinitorias:["PaO2/FiO2 < 300","Hipoxemia refractaria","Cianosis central","Taquipnea"],factoresRelacionados:["Dano alveolar difuso","Edema pulmonar no cardiogenico","Colapso alveolar"]},{codigo:"00029",nombre:"Disminucion del gasto cardiaco",definicion:"Cantidad insuficiente de sangre bombeada",caracteristicasDefinitorias:["Hipotension","Taquicardia","Mala perfusion periferica"],factoresRelacionados:["PEEP elevada con reduccion de precarga","Sepsis subyacente"]},{codigo:"00004",nombre:"Riesgo de infeccion",definicion:"Riesgo de ser invadido por organismos patogenos",caracteristicasDefinitorias:["Intubacion orotraqueal prolongada"],factoresRelacionados:["Ventilacion mecanica invasiva","Inmunosupresion relativa por corticoides"]}],npiNic:[{codigo:"3300",nombre:"Manejo de la ventilacion mecanica",actividades:["Mantener VT 6 mL/kg de peso ideal","Titular PEEP para mantener SpO2 > 88-90%","Monitorizar presion de meseta (< 30 cmH2O)","Registrar parametros ventilatorios cada hora"]},{codigo:"0740",nombre:"Cuidados del paciente encamado",actividades:["Ejecutar protocolo de posicion prona cada 16-18h","Proteger prominencias oseas con apopsitos de espuma","Rotar al decubito supino con equipo entrenado"]},{codigo:"6540",nombre:"Control de infecciones",actividades:["Higiene oral con clorhexidina cada 6h","Aspiracion por sistema cerrado","Cambio de circuito segun protocolo"]}],npiNoc:[{codigo:"0402",nombre:"Estado respiratorio: intercambio gaseoso",indicadores:["PaO2/FiO2 en mejoria progresiva","SpO2 > 88% con FiO2 reducible","pH > 7.25"],escala:"1=Desviacion grave, 5=Sin desviacion"},{codigo:"0703",nombre:"Severidad de la infeccion",indicadores:["Ausencia de fiebre","PCR en descenso","Sin nueva consolidacion en Rx"],escala:"1=Grave, 5=Ninguna"}],complicaciones:["Fallo multiorganico","Neumonia asociada a ventilacion mecanica (NAVM)","Barotrauma: neumomediastino, neumotrax","Fibrosis pulmonar post-SDRA","Debilidad muscular adquirida en UCI"],criteriosAlarma:["PaO2/FiO2 < 100 refractario a PEEP y prono (indicacion de ECMO)","Neumotrax hipertensivo: desviacion traqueal, hipotension brusca, ingurgitacion yugular","Hipotension refractaria con vasopresores maximos","Arritmias malignas por hipoxemia severa"],emergencyLevel:"critico",relatedPathologyIds:["pat_neumonia","pat_sepsis"],isPremium:!0},{id:"pat_bronquiectasias",nombre:"Bronquiectasias",bodySystemId:"respiratorio",definicion:"Dilatacion anormal e irreversible de los bronquios de mediano calibre causada por destruccion de las capas muscular y elastica de la pared bronquial, asociada a inflamacion cronica y colonizacion bacteriana con ciclos de infeccion-inflamacion que perpetuan el da\xf1o.",epidemiologia:"Prevalencia de 67-566 casos por 100.000 habitantes en paises desarrollados, con tendencia creciente. Mas frecuente en mujeres mayores de 60 a\xf1os. Principal causa identificable: infecciones respiratorias previas graves.",factoresRiesgo:["Infecciones pulmonares graves en la infancia (sarampion, tos ferina, TB)","Fibrosis quistica (causa mas frecuente en jovenes)","Inmunodeficiencias primarias o secundarias","Discinesia ciliar primaria","EPOC severo (causa emergente en adultos)","Artritis reumatoide y otras conectivopatias","Broncoaspiracion cronica"],fisiopatologia:"El circulo vicioso de Cole: la infeccion produce inflamacion bronquial con liberacion de proteasas que danan el moco y los cilios, favoreciendo la colonizacion bacteriana cronica (principalmente Pseudomonas aeruginosa y Haemophilus influenzae). La respuesta inflamatoria cronica destruye el tejido elasto-muscular de la pared bronquial produciendo dilatacion permanente. Las exacerbaciones infecciosas aceleran el deterioro de la funcion pulmonar.",signosYSintomas:{signos:["Crepitantes gruesos o sibilancias en areas afectadas","Esputo purulento abundante (signo cardinal)","Acropaquias en casos severos","Hemoptisis (leve a masiva en un 10-15%)","Disminucion del murmullo vesicular focal"],sintomas:["Tos productiva cronica con esputo mucopurulento abundante (principal sintoma)","Disnea progresiva","Fatiga cronica","Fiebre recurrente en exacerbaciones","Dolor pleuritico en exacerbaciones agudas"]},clasificacion:{nombre:"Clasificacion morfologica (TACAR)",tipos:[{nombre:"Cilindricas",descripcion:"Dilatacion uniforme del bronquio; forma mas leve; patron en rieles de tren"},{nombre:"Varicosas",descripcion:"Dilatacion irregular con estrechamientos; forma intermedia"},{nombre:"Saculares o quisticas",descripcion:"Dilatacion en racimos de uvas; forma mas severa; alta incidencia de hemoptisis"}]},diagnostico:{anamnesis:["Tos productiva cronica: cantidad, color y consistencia del esputo","Historia de infecciones respiratorias repetidas desde la infancia","Antecedente de fibrosis quistica, inmunodeficiencia o conectivopatia","Hemoptisis: frecuencia y cantidad"],examenFisico:["Auscultacion: crepitantes gruesos y sibilancias inspiratorias y espiratorias","Inspeccion de esputo: purulento, en tres capas (espumosa, mucosa, purulenta)","Acropaquias en casos severos"],pruebas:[{nombre:"TACAR de torax",descripcion:"Estudio de eleccion: detecta dilatacion bronquial (diametro bronquial > diametro arteria adyacente = signo del anillo de sello) y engrosamiento de pared",valoresReferencia:"Relacion bronco-arterial > 1.0 confirma bronquiectasias",cuidadosEnfermeria:["No requiere contraste habitualmente","Informar al paciente sobre apneas durante la adquisicion"]},{nombre:"Cultivo de esputo con antibiograma",descripcion:"Identifica el germen colonizador y su sensibilidad antibiotic; guia el tratamiento antibiotico",valoresReferencia:"Colonizacion cronica por Pseudomonas aeruginosa: peor pronostico",cuidadosEnfermeria:["Obtener esputo matutino en ayunas antes de antibioticos","Pedir al paciente que realice lavado bucal previo con agua (sin antiseptico)","Transportar en recipiente esteril a temperatura ambiente en menos de 2h"]},{nombre:"Espirometria con broncodilatador",descripcion:"Evalua patron obstructivo o mixto y respuesta broncodilatadora",valoresReferencia:"Patron obstructivo (VEF1/CVF < 0.7) en la mayoria; CVF reducida en enfermedad avanzada",cuidadosEnfermeria:["Verificar que no haya tomado broncodilatador 4-6h antes","Instruir en tecnica correcta de espirometria"]},{nombre:"Test del sudor y estudio genetico CFTR",descripcion:"Descarta fibrosis quistica en pacientes jovenes con bronquiectasias difusas",valoresReferencia:"Cloro en sudor > 60 mEq/L = fibrosis quistica",cuidadosEnfermeria:["Realizar en ayunas","Limpiar la zona de estimulacion con alcohol sin tocar con manos","Pesar el papel de filtro antes y despues de la recogida"]}]},tratamientoMedico:{objetivos:["Reducir la frecuencia e intensidad de las exacerbaciones","Mejorar el aclaramiento mucociliar","Controlar la colonizacion bacteriana cronica","Preservar la funcion pulmonar"],farmacologico:[{nombre:"Amoxicilina-clavulanico o Ciprofloxacino",grupo:"Antibiotico para exacerbaciones",mecanismo:"Cubre los germenes habituales en exacerbaciones agudas (H. influenzae, S. pneumoniae) y Pseudomonas (ciprofloxacino)",dosis:"Amoxicilina-clavulanico 875 mg c/12h 14 dias o Ciprofloxacino 750 mg c/12h 14 dias si hay Pseudomonas",cuidadosEnfermeria:["Obtener cultivo previo al antibiotico","Administrar con alimentos para reducir intolerancia digestiva","Vigilar superinfeccion por Clostridium con amoxicilina-clavulanico"]},{nombre:"Tobramicina inhalada",grupo:"Antibiotico inhalado para colonizacion cronica por Pseudomonas",mecanismo:"Alcanza altas concentraciones en via aerea con minima absorcion sistemica; reduce carga bacteriana cronica",dosis:"300 mg nebulizacion cada 12h en ciclos de 28 dias on/28 dias off",cuidadosEnfermeria:["Instruir en tecnica de nebulizacion correcta (boquilla, no mascarilla)","Realizar fisioterapia respiratoria antes de nebulizar para abrir la via aerea","Vigilar broncoespasmo post-inhalacion: tener salbutamol disponible"]},{nombre:"Salbutamol inhalado (broncodilatador)",grupo:"Agonista beta-2 de accion corta",mecanismo:"Broncodilatacion que facilita el aclaramiento de secreciones y la fisioterapia respiratoria",dosis:"200-400 mcg antes de fisioterapia y nebulizacion de antibiotico",cuidadosEnfermeria:["Verificar tecnica inhalatoria correcta","Usar espaciador para maximizar deposito pulmonar","Usar 15 min antes de la fisioterapia respiratoria"]}],noFarmacologico:["Fisioterapia respiratoria 2 veces/dia: tecnica de espiacion forzada (huff), drenaje autogenico, Flutter o Aerobika","Hidratacion oral abundante para fluidificar secreciones","Vacunacion antigripal anual y antineumococica","Actividad fisica regular","Cese del tabaquismo"],quirurgico:["Reseccion pulmonar segmentaria o lobectomia en bronquiectasias localizadas no controladas medicamente","Embolizacion bronquial urgente en hemoptisis masiva"]},cuidadosEnfermeria:{valoracion:["Cuantificar y describir el esputo diariamente: cantidad, color, consistencia","Monitorizar SpO2 y FR en reposo y con actividad","Evaluar coloracion de esputo como indicador de exacerbacion (verde purulento = infeccion activa)","Auscultar campos pulmonares: crepitantes y sibilancias"],intervenciones:["Ense\xf1ar y supervisar tecnica de fisioterapia respiratoria (huff y drenaje autogenico)","Posicionar en decubito lateral con el pulmon mas afectado arriba para drenaje postural","Administrar broncodilatadores previo a fisioterapia","Administrar antibioticos inhalados segun protocolo","Fomentar hidratacion oral de al menos 2 litros al dia"],educacionPaciente:["Instruccion practica en tecnicas de fisioterapia respiratoria (demostrar y que el paciente demuestre)","Uso correcto del dispositivo de oscilacion (Flutter, Aerobika)","Signos de exacerbacion: aumento de esputo, cambio de color a verde, fiebre, mayor disnea","Cuando y como usar antibioticos de rescate si tiene prescripcion de plan de accion"],monitorizacion:["Cantidad y caracteristicas del esputo diariamente","SpO2 en reposo","Temperatura para detectar exacerbaciones precozmente","Spirometria cada 6 meses para seguimiento de funcion pulmonar"]},npiNanda:[{codigo:"00031",nombre:"Limpieza ineficaz de las vias aereas",definicion:"Incapacidad para eliminar secreciones u obstrucciones del tracto respiratorio",caracteristicasDefinitorias:["Esputo purulento abundante","Tos ineficaz","Crepitantes gruesos","Disnea"],factoresRelacionados:["Secreciones bronquiales excesivas y espesas","Alteracion del aclaramiento mucociliar"]},{codigo:"00004",nombre:"Riesgo de infeccion",definicion:"Riesgo de ser invadido por organismos patogenos",caracteristicasDefinitorias:["Esputo purulento","Fiebre recurrente"],factoresRelacionados:["Colonizacion bronquial cronica","Alteracion de los mecanismos de defensa respiratoria"]},{codigo:"00092",nombre:"Intolerancia a la actividad",definicion:"Insuficiencia de energia para completar actividades diarias",caracteristicasDefinitorias:["Disnea con esfuerzos","Fatiga cronica"],factoresRelacionados:["Limitacion ventilatoria obstructiva","Hipoxemia de esfuerzo"]}],npiNic:[{codigo:"3230",nombre:"Fisioterapia respiratoria",actividades:["Realizar tecnica de espiacion forzada (huff) 2 veces al dia","Aplicar drenaje postural segun localizacion de bronquiectasias","Ense\xf1ar uso del dispositivo de oscilacion (Flutter)","Administrar broncodilatador 15 min antes"]},{codigo:"3160",nombre:"Aspiracion de vias aereas",actividades:["Aspirar secreciones si el paciente no puede expectorar eficazmente","Usar tecnica esteril","Monitorizar SpO2 durante la aspiracion"]},{codigo:"5510",nombre:"Educacion para la salud",actividades:["Demostrar y evaluar tecnica de fisioterapia respiratoria","Instruir en signos de exacerbacion y plan de accion","Educar sobre uso correcto de nebulizadores"]}],npiNoc:[{codigo:"0410",nombre:"Estado respiratorio: permeabilidad de las vias aereas",indicadores:["Expectoracion eficaz de secreciones","Ausencia de crepitantes gruesos post-fisioterapia","SpO2 estable"],escala:"1=Desviacion grave, 5=Sin desviacion"},{codigo:"1902",nombre:"Control del riesgo",indicadores:["Realiza fisioterapia diariamente","Reconoce signos de exacerbacion","Consulta precozmente en exacerbaciones"],escala:"1=Nunca, 5=Constantemente"}],complicaciones:["Hemoptisis masiva (urgencia toracica)","Insuficiencia respiratoria cronica","Cor pulmonale","Colonizacion por Pseudomonas aeruginosa multirresistente","Amiloidosis secundaria en casos de larga evolucion"],criteriosAlarma:["Hemoptisis masiva (> 200 mL/24h)","SpO2 < 90% en reposo","Fiebre alta con aumento de esputo purulento (exacerbacion grave)","Disnea severa en reposo","Taquipnea > 30 rpm"],emergencyLevel:"moderado",relatedPathologyIds:["pat_epoc","pat_neumonia"],isPremium:!0},{id:"pat_cancer_pulmon",nombre:"Cancer de Pulmon",bodySystemId:"respiratorio",definicion:"Neoplasia maligna que se origina en el epitelio bronquial o alveolar. Se clasifica en cancer de pulmon de celulas no pequenas (CPCNP, 85%) y cancer de pulmon de celulas pequenas (CPCP, 15%), con diferentes biologias, tratamientos y pronosticos.",epidemiologia:"Primera causa de muerte por cancer a nivel mundial (1.8 millones de muertes/ano). Supervivencia global a 5 a\xf1os del 15-20%. La deteccion precoz con TC de baja dosis en fumadores de alto riesgo mejora la supervivencia.",factoresRiesgo:["Tabaquismo (causa del 85-90% de los casos; riesgo 20 veces mayor que no fumadores)","Tabaquismo pasivo","Exposicion a asbesto (efecto sinergico con tabaco)","Exposicion a rad\xf3n (segunda causa en no fumadores)","Contaminacion atmosferica","Historia familiar de cancer de pulmon","Fibrosis pulmonar preexistente","Infeccion por VIH"],fisiopatologia:"El humo del tabaco contiene mas de 70 cancerigenos que producen mutaciones en oncogenes (KRAS, EGFR, ALK) y genes supresores de tumores (TP53, RB1). En el CPCNP, las mutaciones conductoras (EGFR, ALK, ROS1, KRAS G12C) son el blanco de terapias dirigidas especificas. En el CPCP, la perdida de TP53 y RB1 produce un tumor de crecimiento muy rapido con alta tendencia a la diseminacion temprana.",signosYSintomas:{signos:["Perdida de peso significativa (> 5% en 6 meses)","Sindrome de vena cava superior: edema facial y de cuello","Paralisis del nervio recurrente laringeo (voz bitonal)","Sindrome de Horner (ptosis, miosis, anhidrosis)","Acropaquias","Adenopatias supraclaviculares","Derrame pleural maligno recurrente"],sintomas:["Tos nueva o cambio en tos cronica (principal sintoma)","Hemoptisis","Disnea de aparicion o empeoramiento progresivo","Dolor toracico (sugiere invasion pleural o costal)","Disfagia (invasion de esofago)","Sindrome paraneoplasico: hipercalcemia, hiponatremia (SIADH), Cushing","Sintomas de metastasis: cefalea, fractura patologica, ictericia"]},clasificacion:{nombre:"Clasificacion histologica e histomolecular",tipos:[{nombre:"Adenocarcinoma (CPCNP)",descripcion:"40% de todos los CP; mas frecuente en no fumadores y mujeres; alta tasa de mutaciones EGFR, ALK"},{nombre:"Carcinoma escamoso (CPCNP)",descripcion:"30%; central, fuertemente asociado a tabaco; mutaciones FGFR1"},{nombre:"Carcinoma de celulas grandes (CPCNP)",descripcion:"10%; diagnostico de exclusion; peor pronostico dentro del CPCNP"},{nombre:"Carcinoma microc\xedtico (CPCP)",descripcion:"15%; crecimiento rapido, diseminacion temprana; muy sensible a quimiorradioterapia inicial pero recae precozmente"}]},diagnostico:{anamnesis:["Historia de tabaquismo: cuantificacion en paquetes-anio","Exposiciones laborales (asbesto, silice, arsenico)","Hemoptisis: cantidad y frecuencia","Perdida de peso y apetito","Sintomas neurologicos o musculoesqueleticos (metastasis)"],examenFisico:["Auscultacion: disminucion de MV o atelectasia","Busqueda de adenopatias supraclaviculares y axilares","Examen neurologico basico para detectar metastasis","Signos de sindrome de vena cava superior o de Horner"],pruebas:[{nombre:"TC de torax con contraste",descripcion:"Estudio de eleccion: caracteriza la lesion primaria, adenopatias mediastinicas y posibles metastasis hepaticas y suprarrenales",valoresReferencia:"Nodulo solido > 8 mm: biopsia indicada; nodulo espiculado de alta sospecha",cuidadosEnfermeria:["Verificar funcion renal y alergia al contraste","Hidratacion pre y post contraste yodado","Preparar al paciente para la duracion del procedimiento"]},{nombre:"Broncoscopia con biopsia y EBUS",descripcion:"Obtiene histologia del tumor primario y estadifica ganglios mediastinicos mediante EBUS",valoresReferencia:"Rendimiento diagnostico > 90% en tumores centrales accesibles",cuidadosEnfermeria:["Ayuno de 6-8h previo","Via venosa permeable y monitoreo continuo","Vigilar hemoptisis, broncoespasmo y neumotorax post-procedimiento"]},{nombre:"Biopsia y estudio molecular completo",descripcion:"Estudio obligatorio en CPCNP: EGFR, ALK, ROS1, KRAS G12C, PD-L1 para determinar tratamiento oncologico",valoresReferencia:"EGFR mutado = osimertinib; ALK+ = alectinib; PD-L1 > 50% = pembrolizumab",cuidadosEnfermeria:["Preservar tejido tumoral en fijador adecuado para estudio molecular","Enviar muestra en formalina neutra tamponada al 10%"]},{nombre:"PET-TC con FDG",descripcion:"Estadificacion sistemica: detecta metastasis ocultas y evalua respuesta al tratamiento",valoresReferencia:"SUVmax > 2.5 sugiere malignidad en nodulos pulmonares",cuidadosEnfermeria:["Ayuno de 6h","Glucemia < 150 mg/dL antes del estudio","Reposo absoluto 1h post-inyeccion del radiotrazador"]}]},tratamientoMedico:{objetivos:["Curacion en estadios iniciales (I-II) con cirugia o radioterapia estereotaxica","Prolongar la supervivencia en estadios avanzados (III-IV)","Controlar los sintomas y mantener la calidad de vida"],farmacologico:[{nombre:"Osimertinib",grupo:"Inhibidor tirosina cinasa EGFR de 3ra generacion",mecanismo:"Bloquea selectivamente EGFR mutado (ex19del, L858R) y la mutacion de resistencia T790M",dosis:"80 mg/dia VO en CPCNP con mutacion EGFR; 40 mg si mutacion T790M",cuidadosEnfermeria:["Vigilar diarrea, rash y estomatitis","Monitorizar QTc en ECG mensual (puede prolongarlo)","Informar sobre teratogenicidad; anticoncepcion obligatoria"]},{nombre:"Pembrolizumab",grupo:"Anticuerpo monoclonal anti-PD1 (inmunoterapia)",mecanismo:"Bloquea el checkpoint PD-1/PD-L1, restaurando la actividad de los linfocitos T contra el tumor",dosis:"200 mg IV cada 3 semanas (CPCNP PD-L1 > 50% sin mutacion tratable)",cuidadosEnfermeria:["Infundir en 30 min con filtro","Vigilar toxicidades inmuno-relacionadas: colitis, neumonitis, hepatitis autoinmune","Educar al paciente sobre sintomas de toxicidad inmune (diarrea, disnea, ictericia)"]},{nombre:"Carboplatino mas Pemetrexed",grupo:"Quimioterapia citotoxica de primera linea (CPCNP no escamoso)",mecanismo:"El carboplatino produce enlaces cruzados en el ADN; el pemetrexed inhibe multiples enzimas del metabolismo del folato",dosis:"Carboplatino AUC5 IV + Pemetrexed 500 mg/m2 IV cada 21 dias",cuidadosEnfermeria:["Premedicacion obligatoria: dexametasona, acido folico y vitamina B12 (con pemetrexed)","Monitorizar hemograma (mielotoxicidad)","Hidratar bien por toxicidad renal del carboplatino"]},{nombre:"Morfina (manejo del dolor oncologico)",grupo:"Analgesico opioide potente",mecanismo:"Agonista de receptores mu-opioides; primera linea para dolor moderado-severo por cancer",dosis:"Morfina de liberacion lenta 10-30 mg cada 12h con rescates de 5-10 mg de morfina rapida",cuidadosEnfermeria:["Iniciar con dosis bajas y titular segun dolor","Usar escala analgesica de la OMS (escalera analgesica)","Prevenir estrenimiento (laxante obligatorio desde el inicio)","Monitorizar sedacion excesiva y depresion respiratoria"]}],noFarmacologico:["Cese del tabaquismo (incluso en cancer avanzado mejora la tolerancia al tratamiento)","Rehabilitacion oncologica","Soporte nutricional (dietista oncologico)","Cuidados paliativos desde el diagnostico (no solo al final de vida)","Soporte psicologico al paciente y familia"],quirurgico:["Lobectomia con diseccion ganglionar (gold standard en estadios I-II resecables)","Segmentectomia en pacientes con funcion pulmonar comprometida","Radioterapia estereotaxica (SBRT) en estadios I no quirurgicos o con riesgo operatorio alto","Radioterapia o radiocirugia en metastasis cerebrales sintomaticas"]},cuidadosEnfermeria:{valoracion:["Evaluar dolor con escala numerica de 0-10 y caracteristicas","Monitorizar estado nutricional: peso, albumina, ingesta","Valorar SpO2 y disnea","Detectar toxicidades del tratamiento: nauseas, diarrea, rash, mucosite"],intervenciones:["Administrar quimioterapia o inmunoterapia segun protocolo oncologico","Manejar efectos adversos: antiem\xe9ticos previos a quimioterapia, hidratacion","Cuidado de la via central (PICC o port-a-cath)","Coordinar con cuidados paliativos para control de sintomas","Apoyo emocional al paciente y familia"],educacionPaciente:["Explicar el plan de tratamiento oncologico en terminos comprensibles","Instruccion sobre signos de toxicidad inmune (con inmunoterapia) y cuando consultar urgente","Cuidado de boca y piel durante quimioterapia","Importancia del soporte nutricional","Recursos de apoyo psicologico y grupos de pacientes"],monitorizacion:["Hemograma completo antes de cada ciclo de quimioterapia","Funcion hepatica y renal en cada ciclo","TC de evaluacion de respuesta cada 2-3 ciclos (criterios RECIST)","Signos vitales y SpO2 durante la infusion de inmunoterapia"]},npiNanda:[{codigo:"00132",nombre:"Dolor agudo y cronico",definicion:"Experiencia sensitiva desagradable asociada con cancer y su tratamiento",caracteristicasDefinitorias:["Dolor toracico","Dolor oseo en metastasis","Cefalea en metastasis cerebrales"],factoresRelacionados:["Invasion tumoral","Metastasis oseas o cerebrales","Procedimientos diagnosticos invasivos"]},{codigo:"00002",nombre:"Desequilibrio nutricional: ingesta inferior a las necesidades",definicion:"Ingesta insuficiente de nutrientes para satisfacer necesidades metabolicas",caracteristicasDefinitorias:["Perdida de peso > 5%","Anorexia","Nauseas por quimioterapia"],factoresRelacionados:["Caquexia cancerosa","Toxicidad digestiva del tratamiento"]},{codigo:"00148",nombre:"Temor",definicion:"Respuesta a una amenaza percibida como consciente y reconocida",caracteristicasDefinitorias:["Expresion de miedo a la muerte","Preocupacion por la familia","Dificultad para tomar decisiones"],factoresRelacionados:["Diagnostico de cancer con pronostico reservado","Incertidumbre sobre el futuro"]}],npiNic:[{codigo:"1400",nombre:"Manejo del dolor",actividades:["Evaluar dolor con escala numerica cada 4-8h","Administrar opioides segun prescripcion y necesidad","Prevenir estrenimiento con laxantes desde el inicio de opioides","Ajustar dosis ante dolor mal controlado"]},{codigo:"1160",nombre:"Monitorizacion nutricional",actividades:["Pesar semanalmente","Registrar ingesta diaria de alimentos","Coordinar con dietista para suplementacion nutricional","Considerar nutricion enteral si ingesta < 50%"]},{codigo:"5270",nombre:"Apoyo emocional",actividades:["Escuchar activamente las preocupaciones del paciente","Involucrar a la familia con consentimiento del paciente","Coordinar atencion con psicologo oncologico"]}],npiNoc:[{codigo:"2102",nombre:"Nivel del dolor",indicadores:["Dolor < 4/10 en la mayoria de las horas del dia","Duerme sin que el dolor lo despierte","Puede realizar actividades basicas"],escala:"1=Grave, 5=Ningun"},{codigo:"1004",nombre:"Estado nutricional",indicadores:["Peso estable o sin descenso mayor a 2% mensual","Albumina > 3 g/dL","Ingesta superior al 75% de lo recomendado"],escala:"1=Desviacion grave, 5=Sin desviacion"}],complicaciones:["Sindrome de vena cava superior","Hemoptisis masiva","Metastasis cerebrales con hipertension intracraneal","Metastasis oseas con fractura patologica","Derrame pericardico maligno con taponamiento","Sindrome de lisis tumoral con quimioterapia"],criteriosAlarma:["Hemoptisis masiva (> 200 mL)","Sindrome de vena cava superior con estridor","Signos de metastasis cerebral: convulsiones, paresia","Dolor oseo agudo intenso (fractura patologica)","Disnea severa brusca (atelectasia masiva, derrame pericardico, embolia)"],emergencyLevel:"critico",relatedPathologyIds:["pat_epoc","pat_derrame_pleural"],isPremium:!0},{id:"pat_esclerosis_lateral",nombre:"Esclerosis Lateral Amiotrofica (ELA)",bodySystemId:"neurologico",definicion:"Enfermedad neurodegenerativa progresiva que afecta selectivamente a las neuronas motoras superiores (corteza motora) e inferiores (asta anterior medular y nucleos motores del tronco), produciendo paralisis muscular progresiva con preservacion de los sentidos y funciones cognitivas en la mayoria de los casos.",epidemiologia:"Incidencia de 2-3 casos por 100.000 habitantes/ano. Prevalencia de 5-7 casos por 100.000. Supervivencia media de 3-5 a\xf1os desde el diagnostico; el 10% supera los 10 a\xf1os (caso Stephen Hawking). Mayoria de casos son esporadicos; 5-10% son familiares (mutaciones SOD1, C9orf72, TDP-43).",factoresRiesgo:["Edad entre 50-70 a\xf1os (pico de incidencia)","Sexo masculino (relacion 1.5:1)","Historia familiar de ELA o demencia frontotemporal","Mutaciones geneticas: SOD1, C9orf72, FUS, TDP-43","Actividad fisica intensa y deporte de alto nivel (factores debatidos)","Exposicion a metales pesados (plomo, mercurio) como posible factor ambiental"],fisiopatologia:"La agregacion de proteinas mal plegadas (TDP-43, SOD1) produce disfuncion y muerte de neuronas motoras. La perdida de neuronas motoras superiores produce signos piramidales (espasticidad, hiperreflexia) y la perdida de neuronas motoras inferiores produce atrofia y fasciculaciones. La afectacion del musculo se denomina neurogenica (no miopatica). La progresion es inexorable, afectando a musculos bulbares (disfagia, disartria), respiratorios y de las extremidades.",signosYSintomas:{signos:["Fasciculaciones musculares (contraccion involuntaria visible)","Atrofia muscular progresiva en areas afectadas","Hiperreflexia (signo de neurona motora superior)","Hiporreflexia o arreflexia en areas con atrofia severa","Signo de Babinski positivo","Disartria (voz nasal, arrastrada o ininteligible)","Disfagia con riesgo de broncoaspiracion"],sintomas:["Debilidad muscular progresiva asimetrica (inicio en una extremidad en el 60%)","Torpeza en mano dominante o tropiezos frecuentes","Calambres musculares dolorosos","Fatiga extrema desproporcional al esfuerzo","Dificultad para tragar alimentos solidos primero, luego liquidos","Sensacion de ahogo progresivo en fases avanzadas"]},clasificacion:{nombre:"Variantes clinicas",tipos:[{nombre:"ELA clasica (espinal)",descripcion:"Inicio en extremidades; afectacion mixta de neuronas motoras superiores e inferiores; 70% de los casos"},{nombre:"Variante bulbar",descripcion:"Inicio con disartria y disfagia; peor pronostico; mas frecuente en mujeres mayores"},{nombre:"ELP (Esclerosis Lateral Primaria)",descripcion:"Solo neurona motora superior; evolucion mas lenta; mejor pronostico"},{nombre:"AMP (Atrofia Muscular Progresiva)",descripcion:"Solo neurona motora inferior; supervivencia algo mayor"}]},diagnostico:{anamnesis:["Inicio y progresion de la debilidad (topografia, velocidad)","Sintomas bulbares: disfagia, disartria, sialorrea","Historia familiar de ELA o demencia frontotemporal","Antecedentes de exposicion a metales pesados o actividad deportiva intensa"],examenFisico:["Examen neurologico completo: fuerza muscular segmentaria, reflejos osteotendinosos","Inspeccion de fasciculaciones con luz tangencial","Evaluacion del habla y la deglucion","Funcion respiratoria: FVC sentado y tumbado"],pruebas:[{nombre:"Electromiografia (EMG) con velocidades de conduccion",descripcion:"Estudio definitivo: denervacion activa y cronica generalizada en 3 regiones, con conduccion nerviosa sensitiva normal",valoresReferencia:"Criterios de El Escorial revisados: signos de denervacion en 3 regiones con NCS normales",cuidadosEnfermeria:["Preparar la sala y el equipo de EMG","Informar al paciente que es un procedimiento con agujas finas pero tolerable","Registrar medicacion actual que pueda interferir"]},{nombre:"RMN cerebral y medular",descripcion:"Descarta causas compresivas u otras enfermedades; en ELA puede mostrar hiperintensidad en tracto corticoespinal",valoresReferencia:"Hiperintensidad en tracto corticoespinal en T2 en ELA avanzada",cuidadosEnfermeria:["Retirar objetos metalicos","Informar sobre duracion (45-60 min)","Verificar contraindicaciones para gadolinio"]},{nombre:"Pruebas de funcion pulmonar (FVC)",descripcion:"Monitoriza la afectacion de los musculos respiratorios; guia la indicacion de VMNI",valoresReferencia:"FVC < 50% indica inicio de VMNI; < 30% supervivencia < 6 meses sin soporte ventilatorio",cuidadosEnfermeria:["Realizar en sedestacion y en decubito (diferencia > 20% indica debilidad diafragmatica)","Repetir cada 3 meses en ELA establecida"]},{nombre:"Estudio genetico (SOD1, C9orf72)",descripcion:"Identifica mutaciones en ELA familiar y en un 10% de los esporadicos; relevancia para consejo genetico y nuevas terapias",valoresReferencia:"C9orf72 es la mutacion mas frecuente en ELA familiar en Europa",cuidadosEnfermeria:["Informar sobre implicaciones del resultado para el paciente y sus familiares","Garantizar consejo genetico pre y post-test"]}]},tratamientoMedico:{objetivos:["Enlentecer la progresion con neuroprotectores","Manejar los sintomas (sialorrea, espasticidad, calambres, dolor)","Mantener la capacidad funcional el mayor tiempo posible","Soporte ventilatorio y nutricional en fases avanzadas","Apoyo psicologico y cuidados paliativos desde el diagnostico"],farmacologico:[{nombre:"Riluzol",grupo:"Neuroprotector glutamatergico",mecanismo:"Reduce la excitotoxicidad por glutamato bloqueando canales de sodio y reduciendo la liberacion de glutamato",dosis:"50 mg cada 12h en ayunas o con alimentos",cuidadosEnfermeria:["Controlar transaminasas antes del inicio y mensualmente los primeros 3 meses","Vigilar nauseas y astenia como efectos adversos mas frecuentes","No hay interaccion significativa con alimentos (puede tomarse con o sin comida)"]},{nombre:"Edaravona",grupo:"Antioxidante neuroprotector",mecanismo:"Elimina radicales libres reduciendo el estres oxidativo neuronal; aprobado en ELA de inicio reciente con FVC > 80%",dosis:"60 mg IV en infusion de 60 min; ciclos de 14 dias on / 14 dias off",cuidadosEnfermeria:["Administrar IV con bomba de infusion en 60 min exactamente","Vigilar reacciones alergicas en las primeras infusiones","Monitorizar funcion renal (puede elevarse creatinina)"]},{nombre:"Baclofeno",grupo:"Antiespastico agonista GABA-B",mecanismo:"Reduce la espasticidad dolorosa inhibiendo la transmision monosinaptica y polisin\xe1ptica en la medula espinal",dosis:"5 mg cada 8h titulando hasta 25-50 mg/dia",cuidadosEnfermeria:["No suspender abruptamente (riesgo de convulsiones y alucinaciones)","Vigilar sedacion excesiva, hipotension y debilidad muscular aumentada","Ajustar dosis en insuficiencia renal"]},{nombre:"Atropina o Escopolamina (para sialorrea)",grupo:"Anticolinergico",mecanismo:"Reduce la produccion de saliva inhibiendo las glandulas salivales",dosis:"Atropina 0.4 mg sublingual cada 4-8h o escopolamina parche 1.5 mg cada 72h",cuidadosEnfermeria:["Vigilar retencion urinaria, estrenimiento y confusion en ancianos","Valorar la eficacia objetivamente (baba en la ropa, cantidad de aspiraciones)"]},{nombre:"Ventilacion mecanica no invasiva (VMNI)",grupo:"Soporte ventilatorio",mecanismo:"Asiste la ventilacion en la insuficiencia respiratoria neuromuscular; prolonga la supervivencia y mejora la calidad de vida",dosis:"Iniciar con uso nocturno cuando FVC < 50% o con sintomas de hipoventilacion nocturna",cuidadosEnfermeria:["Adaptar la interfaz (mascarilla nasal o facial) para maxima comodidad","Ense\xf1ar al paciente y cuidador el manejo del equipo","Monitorizar SpO2 nocturna y sintomas de hipoventilacion"]}],noFarmacologico:["Logopedia para disartria y disfagia (tecnicas de comunicacion alternativa)","Nutricion enteral por gastrostomia endoscopica percutanea (PEG) cuando disfagia severa o perdida de peso > 10%","Fisioterapia para mantener movilidad, prevenir contracturas y linfedema","Terapia ocupacional: adaptaciones del hogar, ortesis, silla de ruedas","Comunicacion aumentativa y alternativa (tableros, ordenadores con seguimiento ocular)"],quirurgico:["Gastrostomia endoscopica percutanea (PEG) para nutricion enteral","Traqueotomia en ELA con decision de ventilacion mecanica invasiva permanente (decision personalizada)"]},cuidadosEnfermeria:{valoracion:["Evaluar fuerza muscular con escala MRC en miembros superiores e inferiores","Monitorizar FVC seriada cada 3 meses","Evaluar capacidad de deglucion: textura tolerada, peso y estado nutricional","Valorar SpO2 en reposo y nocturna","Evaluar comunicacion y estado emocional del paciente y cuidador"],intervenciones:["Cuidado de la piel y prevension de ulceras por presion","Aspiracion de secreciones cuando el paciente no puede toser eficazmente","Cuidados del PEG si tiene gastrostomia: limpieza, comprobacion de posicion","Manejo de la VMNI: ajuste de interfaz, monitoreo de fugas, alarmas","Apoyo emocional y coordinacion con trabajo social para recursos de dependencia"],educacionPaciente:["Explicar la naturaleza progresiva de la enfermedad de forma gradual y adaptada","Instruir al cuidador principal en manejo de la VMNI, aspiracion y PEG","Recursos de asociaciones de pacientes con ELA","Planificacion anticipada de decisiones: testamento vital, preferencias sobre ventilacion invasiva","Cuidados paliativos: explicar que son compatibles con el tratamiento activo"],monitorizacion:["FVC cada 3 meses","SpO2 continua o nocturna segun fase","Peso y estado nutricional mensual","Evaluacion de la deglucion con logopeda cada 3-6 meses","Estado emocional del cuidador: riesgo de sobrecarga"]},npiNanda:[{codigo:"00031",nombre:"Limpieza ineficaz de las vias aereas",definicion:"Incapacidad para eliminar secreciones del tracto respiratorio",caracteristicasDefinitorias:["Incapacidad para toser eficazmente","Sialorrea con riesgo de broncoaspiracion","SpO2 reducida"],factoresRelacionados:["Debilidad de musculos respiratorios y bulbares por denervacion"]},{codigo:"00103",nombre:"Deterioro de la deglucion",definicion:"Funcionamiento anormal del mecanismo de la deglucion",caracteristicasDefinitorias:["Tos o atragantamiento al ingerir liquidos","Tiempo de comida prolongado","Perdida de peso"],factoresRelacionados:["Debilidad de musculos bulbares por ELA"]},{codigo:"00199",nombre:"Planificacion ineficaz de la actividad",definicion:"Incapacidad para preparar un conjunto de acciones para satisfacer objetivos de salud",caracteristicasDefinitorias:["Dificultad para adaptarse a la progresion de la discapacidad"],factoresRelacionados:["Enfermedad progresiva","Necesidad de adaptaciones ambientales continuas"]}],npiNic:[{codigo:"3160",nombre:"Aspiracion de vias aereas",actividades:["Aspirar secreciones con tecnica esteril cuando el paciente no puede toser","Monitorizar SpO2 durante la aspiracion","Evaluar la eficacia de la tos y la necesidad de asistencia mecanica (cough assist)"]},{codigo:"1860",nombre:"Terapia de deglucion",actividades:["Evaluar la seguridad de la deglucion con diferentes texturas","Posicionar en 90 grados durante las comidas","Coordinacion con logopeda para tecnicas especificas"]},{codigo:"5270",nombre:"Apoyo emocional",actividades:["Escuchar activamente las preocupaciones del paciente y cuidador","Facilitar contacto con asociaciones de pacientes con ELA","Coordinar con psicologo especializado en enfermedades neurodegenerativas"]}],npiNoc:[{codigo:"0403",nombre:"Estado respiratorio: ventilacion",indicadores:["FVC estable o descenso < 10% en 3 meses","SpO2 > 90% con VMNI","Sin episodios de broncoaspiracion"],escala:"1=Desviacion grave, 5=Sin desviacion"},{codigo:"1010",nombre:"Estado de deglucion",indicadores:["Sin episodios de broncoaspiracion","Mantenimiento del peso con adaptaciones dieteticas o PEG"],escala:"1=Gravemente comprometido, 5=No comprometido"}],complicaciones:["Insuficiencia respiratoria por debilidad diafragmatica","Broncoaspiracion con neumonia aspirativa","Deshidratacion y desnutricion por disfagia","Depresion mayor y ansiedad","Sobrecarga del cuidador"],criteriosAlarma:["FVC < 50% (indicacion de VMNI urgente)","Episodio de broncoaspiracion con desaturacion","Perdida de peso > 10% (indicacion de PEG urgente)","Disfonia brusca o apneas nocturnas"],emergencyLevel:"moderado",relatedPathologyIds:[],isPremium:!0},{id:"pat_miastenia_gravis",nombre:"Miastenia Gravis",bodySystemId:"neurologico",definicion:"Enfermedad autoinmune de la union neuromuscular caracterizada por debilidad muscular fluctuante y fatigabilidad, causada por anticuerpos contra los receptores de acetilcolina (anti-AChR) o contra MuSK en la placa motora.",epidemiologia:"Prevalencia de 150-200 casos por 100.000 habitantes. Incidencia bifasica: pico en mujeres jovenes (20-40 a\xf1os) y en hombres mayores (> 60 a\xf1os). La crisis miastenica ocurre en el 15-20% de los pacientes y tiene mortalidad < 5% con tratamiento moderno.",factoresRiesgo:["Sexo femenino en jovenes","Timoma (tumor del timo) en 10-15% de los casos","Hiperplasia timica en jovenes","Otras enfermedades autoinmunes (tiroiditis, AR, LES)","Ciertos farmacos: aminoglucosidos, fluoroquinolonas, betabloqueantes (desencadenan crisis)"],fisiopatologia:"Los anticuerpos anti-AChR se unen al receptor de acetilcolina postsinaptico, bloqueandolo y activando el complemento que destruye la placa motora. Con cada estimulo nervioso, la cantidad de ACh disponible se agota progresivamente (fatiga sinaptica), produciendo debilidad que empeora con el ejercicio y mejora con el reposo. La reduccion del numero de receptores funcionales produce la fatigabilidad caracteristica.",signosYSintomas:{signos:["Ptosis palpebral (cae con el uso del ojo)","Diplop\xeda (vision doble) por debilidad de musculos extraoculares","Facies miastenica: expresion aplanada, sonrisa vertical (en rictus)","Debilidad de musculos bulbares: disartria nasal, disfagia","Debilidad de musculos proximales de extremidades","Signo de Cogan (ptosis reaparece tras elevar el parpado manualmente y soltarlo)"],sintomas:["Debilidad muscular que empeora con el uso y mejora con el reposo (fluctuante)","Vision doble que mejora al cerrar un ojo","Dificultad para masticar hacia el final de la comida","Voz nasal que empeora al hablar prolongadamente","Dificultad para subir escaleras o levantar objetos al final del dia","Disnea en crisis miast\xe9nica (debilidad de musculos respiratorios)"]},clasificacion:{nombre:"Clasificacion MGFA (Myasthenia Gravis Foundation of America)",tipos:[{nombre:"Clase I",descripcion:"Solo afectacion ocular"},{nombre:"Clase II",descripcion:"Afectacion leve de musculos distintos a los oculares: IIa (predominio extremidades), IIb (predominio bulbar)"},{nombre:"Clase III",descripcion:"Afectacion moderada: IIIa (extremidades), IIIb (bulbar)"},{nombre:"Clase IV",descripcion:"Afectacion severa: IVa (extremidades), IVb (bulbar con sonda nasogastrica)"},{nombre:"Clase V",descripcion:"Crisis miast\xe9nica: intubacion requerida con o sin ventilacion mecanica"}]},diagnostico:{anamnesis:["Patron de debilidad fluctuante y fatigabilidad","Empeoramiento vespertino y con el esfuerzo","Historia de ptosis y diplopia variables","Dificultad para deglutir o hablar al final del dia","Farmacos que pueden precipitar crisis"],examenFisico:["Test de ice pack: aplicar hielo en parpado 2 min; mejora de ptosis es positivo para MG","Test del edrofonio (solo en hospitalizacion por riesgo de bradicardia)","Evaluacion de la fatigabilidad: mirada sostenida 2 min (ptosis), abduccion sostenida de brazos","Examen de la via aerea y funcion respiratoria"],pruebas:[{nombre:"Anticuerpos anti-AChR",descripcion:"Positivos en 85% de MG generalizada y 50% de MG ocular; confirman el diagnostico",valoresReferencia:"Positivo > 0.5 nmol/L (sensibilidad 85% en MG generalizada)",cuidadosEnfermeria:["Extraer muestra venosa","No requiere ayuno","Resultado puede tardar 1-2 semanas"]},{nombre:"EMG de fibra unica",descripcion:"Estudio mas sensible para MG (95%): mide el jitter (variabilidad en la transmision neuromuscular)",valoresReferencia:"Jitter aumentado y bloqueos de impulso confirman disfuncion de la union neuromuscular",cuidadosEnfermeria:["Informar al paciente que es un procedimiento con agujas muy finas","Suspender anticolinesterasicos 12h antes si es posible (segun indicacion del neurlogo)"]},{nombre:"TC de torax",descripcion:"Busca timoma o hiperplasia timica; el timoma requiere timectomia",valoresReferencia:"Masa en mediastino anterior con densidad tejidos blandos",cuidadosEnfermeria:["Contraste si se sospecha timoma","Verificar funcion renal para contraste"]},{nombre:"FVC y PIM (presion inspiratoria maxima)",descripcion:"Monitoriza la funcion respiratoria para detectar crisis inminente; la regla del 20/30/40",valoresReferencia:"FVC < 20 mL/kg o PIM < 30 cmH2O = intubacion inminente si tendencia descendente",cuidadosEnfermeria:["Realizar en sedestacion y decubito","Repetir cada 2-4h en hospitalizados con sospecha de crisis","Registrar tendencia: importa mas la curva que el valor absoluto"]}]},tratamientoMedico:{objetivos:["Controlar los sintomas con anticolinesterasicos","Inducir remision con inmunosupresores","Timectomia en casos seleccionados","Manejo urgente de la crisis miast\xe9nica"],farmacologico:[{nombre:"Piridostigmina",grupo:"Inhibidor de la acetilcolinesterasa",mecanismo:"Inhibe la colinesterasa en la placa motora, aumentando el tiempo de disponibilidad de ACh en la sinapsis",dosis:"30-60 mg cada 4-6h VO; dosis maxima 120 mg cada 3h",cuidadosEnfermeria:["Administrar con alimentos para reducir efectos muscarinicos: nauseas, diarrea, calambres abdominales","Vigilar signos de sobredosificacion (crisis colinergica): fasiculaciones, hipersecreciones, bradicardia","No confundir crisis miast\xe9nica con crisis colinergica: opuesta respuesta al edrofonio"]},{nombre:"Prednisona",grupo:"Corticosteroide inmunosupresor",mecanismo:"Suprime la produccion de autoanticuerpos y la activacion de linfocitos B; primera linea inmunosupresora",dosis:"Iniciar 15-20 mg/dia; aumentar lentamente hasta 60-80 mg/dia; reduccion muy lenta",cuidadosEnfermeria:["Iniciar con dosis baja y aumentar gradualmente: el inicio brusco puede desencadenar empeoramiento","Monitorizar glucemia, PA y peso","Gastroproteccion con omeprazol obligatoria","Informar que el efecto terapeutico tarda 3-6 meses"]},{nombre:"Azatioprina",grupo:"Inmunosupresor ahorrador de esteroides",mecanismo:"Inhibe la sintesis de purinas bloqueando la proliferacion de linfocitos",dosis:"2-3 mg/kg/dia VO; inicio con 50 mg/dia y titulacion",cuidadosEnfermeria:["Verificar actividad de TPMT antes del inicio (riesgo de toxicidad hematologica)","Hemograma y funcion hepatica mensual el primer anio","Inicio de efecto a los 12-18 meses de tratamiento"]},{nombre:"Inmunoglobulina IV (IGIV) o Plasmaferesis",grupo:"Terapia inmunomoduladora rapida para crisis",mecanismo:"IGIV neutraliza autoanticuerpos; plasmaferesis los elimina fisicamente. Inicio de accion en 3-7 dias.",dosis:"IGIV 2 g/kg IV en 5 dias o Plasmaferesis: 5 intercambios en 10 dias",cuidadosEnfermeria:["IGIV: administrar lentamente con monitoreo de PA y temperatura","Plasmaferesis: cuidados del acceso vascular (cateter central de doble luz)","Monitorizar coagulacion y calcio en plasmaferesis","Ambas son tratamientos de rescate en crisis o pre-timectomia"]}],noFarmacologico:["Timectomia en todos los pacientes con timoma y en pacientes generalizados menores de 60 a\xf1os sin anticuerpos MuSK","Evitar farmacos que precipitan crisis: aminoglucosidos, fluoroquinolonas, betabloqueantes, magnesio IV","Educacion sobre factores precipitantes: infecciones, estres, cirugia, embarazo"],quirurgico:["Timectomia (laparoscopica o rob\xf3tica transcervical o transesternal)"]},cuidadosEnfermeria:{valoracion:["Monitorizar FVC y PIM cada 2-4h en hospitalizados con crisis o empeoramiento","Evaluar ptosis y diplopia como indicadores de actividad de la enfermedad","Vigilar funcion bulbar: calidad del habla y capacidad de deglucion","Identificar factores precipitantes: infeccion, nuevo farmaco"],intervenciones:["En crisis miast\xe9nica: preparar intubacion si FVC < 20 mL/kg o PIM < 30 cmH2O","Administrar piridostigmina en horario riguroso para evitar oscilaciones","Colocar aspirador disponible junto al paciente con disfagia","Monitorizar disnea y SpO2 continua en hospitalizados","Elevar cabecera para reducir riesgo de broncoaspiracion"],educacionPaciente:["Explicar la naturaleza autoinmune de la enfermedad: no tiene causa en el comportamiento del paciente","Lista de farmacos contraindicados que el paciente debe mostrar a cualquier medico","Reconocer signos de crisis miast\xe9nica y cuando ir a urgencias","Importancia de adherencia estricta a la medicacion y los controles"],monitorizacion:["FVC y PIM cada 2-4h en crisis","SpO2 continua en hospitalizados","Evaluacion de ptosis, diplopia y habla diariamente en hospitalizados","Hemograma y funcion hepatica mensual con azatioprina"]},npiNanda:[{codigo:"00032",nombre:"Patron respiratorio ineficaz",definicion:"Inspiracion o espiracion que no proporciona ventilacion adecuada",caracteristicasDefinitorias:["FVC reducida","Dificultad respiratoria progresiva","Uso de musculos accesorios"],factoresRelacionados:["Debilidad de musculos respiratorios por bloqueo de la union neuromuscular"]},{codigo:"00103",nombre:"Deterioro de la deglucion",definicion:"Funcionamiento anormal del mecanismo de la deglucion",caracteristicasDefinitorias:["Tos al tragar","Voz nasal","Dificultad para masticar al final de la comida"],factoresRelacionados:["Debilidad de musculos bulbares fatigables"]},{codigo:"00085",nombre:"Deterioro de la movilidad fisica",definicion:"Limitacion del movimiento fisico independiente y voluntario del cuerpo o de una o mas extremidades",caracteristicasDefinitorias:["Debilidad proximal de extremidades","Fatigabilidad con el esfuerzo"],factoresRelacionados:["Fatigabilidad neuromuscular autoinmune"]}],npiNic:[{codigo:"3350",nombre:"Monitorizacion respiratoria",actividades:["Medir FVC y PIM cada 2-4h en crisis miast\xe9nica","Preparar equipo de intubacion cuando FVC < 20 mL/kg","Monitorizar SpO2 y FR continuamente"]},{codigo:"1860",nombre:"Terapia de deglucion",actividades:["Evaluar seguridad de la deglucion en cada comida","Posicionar a 90 grados durante la alimentacion","Preparar aspirador disponible durante las comidas"]},{codigo:"6830",nombre:"Manejo de la urgencia neurologica",actividades:["Identificar signos de crisis miast\xe9nica: aumento de disnea, FVC descendente","Administrar IGIV o coordinar plasmaferesis urgente","Preparar intubacion si FVC cae progresivamente"]}],npiNoc:[{codigo:"0403",nombre:"Estado respiratorio: ventilacion",indicadores:["FVC > 20 mL/kg","PIM > 30 cmH2O","Sin requerimiento de ventilacion mecanica"],escala:"1=Desviacion grave, 5=Sin desviacion"},{codigo:"1010",nombre:"Estado de deglucion",indicadores:["Sin broncoaspiracion","Ingesta oral adecuada","Peso estable"],escala:"1=Gravemente comprometido, 5=No comprometido"}],complicaciones:["Crisis miast\xe9nica (insuficiencia respiratoria aguda)","Broncoaspiracion y neumonia aspirativa","Crisis colinergica por sobredosificacion de piridostigmina","Timoma maligno con invasion local"],criteriosAlarma:["FVC descendente o < 20 mL/kg (crisis inminente)","Dificultad respiratoria progresiva o incapacidad para hablar frases completas","Disfagia total con broncoaspiracion","Aparicion de nueva debilidad tras introduccion de un farmaco contraindicado"],emergencyLevel:"critico",relatedPathologyIds:[],isPremium:!0},{id:"pat_hipertension_intracraneal",nombre:"Hipertension Intracraneal",bodySystemId:"neurologico",definicion:"Elevacion de la presion intracraneal (PIC) por encima de 20 mmHg de forma sostenida. El craneo es una cavidad rigida con volumen fijo (doctrina de Monro-Kellie), por lo que el aumento de cualquiera de sus componentes (cerebro, sangre, LCR) eleva la PIC y puede producir herniacion cerebral.",epidemiologia:"Complicacion frecuente del traumatismo craneoencefalico grave, ictus hemorragico y meningitis. La hipertension intracraneal idiopatica (pseudotumor cerebri) tiene una incidencia de 0.9 casos por 100.000 habitantes/ano, con predominio en mujeres obesas en edad fertil.",factoresRiesgo:["Traumatismo craneoencefalico grave","Hemorragia intracraneal (subaracnoidea, intracerebral, subdural, epidural)","Tumores intracraneales primarios o metastaticos","Hidrocefalia obstructiva o comunicante","Meningitis o encefalitis","Encefalopatia hepatica","Hipertension arterial maligna (encefalopatia hipertensiva)","Obesidad en mujeres jovenes (HIC idiopatica)"],fisiopatologia:"La PIC normal es de 5-15 mmHg. La PIC elevada reduce la presion de perfusion cerebral (PPC = PAM - PIC). Cuando PPC < 60 mmHg se produce isquemia cerebral. La compensacion inicial (desplazamiento de LCR y sangre venosa) se agota rapidamente. La HIC produce herniacion cerebral (cingulada, central o uncal) con compresion del tronco cefalico y posible muerte. Las ondas de Lundberg tipo A (plateau waves > 50 mmHg por 5-20 min) son amenazantes.",signosYSintomas:{signos:["Triada de Cushing: hipertension + bradicardia + respiracion irregular (signo tardio y alarmante)","Edema de papila en fondo de ojo","Paralisis del VI par craneal (diplopia horizontal)","Alteracion del nivel de consciencia (escala de Glasgow descendente)","Postura de descerebraci\xf3n o decorticaci\xf3n","Reflejo de Babinski bilateral"],sintomas:["Cefalea en caso (holocraneal, matutina, peor en decubito y con Valsalva)","Nauseas y vomitos en proyectil (sin nausea previa)","Vision borrosa o diplopia transitoria","Confusion y somnolencia progresiva","Acufenos pulsatiles en HIC idiopatica"]},clasificacion:{nombre:"Clasificacion por mecanismo y etiologia",tipos:[{nombre:"HIC por aumento de volumen cerebral",descripcion:"Edema citotoxico (isquemia), edema vasogenico (tumor, trauma), edema intersticial"},{nombre:"HIC por aumento de volumen sanguineo",descripcion:"Hemorragia intracraneal, trombosis venosa cerebral"},{nombre:"HIC por obstruccion al flujo de LCR",descripcion:"Hidrocefalia obstructiva o comunicante"},{nombre:"HIC idiopatica (pseudotumor cerebri)",descripcion:"Aumento de la resistencia a la reabsorcion de LCR sin causa identificable; asociada a obesidad y ciertos farmacos (tetraciclinas, retinoides, vitamina A)"}]},diagnostico:{anamnesis:["Inicio y caracteristicas de la cefalea (peor al levantarse, con maniobras de Valsalva)","Trauma craneal o cirugia reciente","Antecedentes de cancer (metastasis)","Fiebre (infeccion del SNC)","Farmacologia: tetraciclinas, vitamina A, corticoides en hipereduccion"],examenFisico:["Escala de Glasgow: nivel de consciencia","Exploracion de pupilas: tamano, simetria, respuesta a la luz (anisocoria = herniacion uncal)","Fondo de ojo: edema de papila","Busqueda de signos meningeos","Evaluacion de reflejos del tronco cerebral"],pruebas:[{nombre:"TC craneal urgente sin contraste",descripcion:"Primera prueba de eleccion en urgencias: detecta hemorragia, hidrocefalia, efecto de masa, desplazamiento de la linea media",valoresReferencia:"Desplazamiento de linea media > 5 mm = HIC severa con riesgo de herniacion",cuidadosEnfermeria:["Prioridad urgente: el paciente no puede esperar","Monitorizar nivel de consciencia y pupilas durante el traslado","Tener equipo de reanimacion disponible"]},{nombre:"RMN cerebral con y sin contraste",descripcion:"Mas sensible que la TC para lesiones isquemicas, encefalitis, tumores y trombosis venosa cerebral",valoresReferencia:"Hiperintensidad en DWI indica isquemia aguda; realce con contraste sugiere tumor o encefalitis",cuidadosEnfermeria:["Solo en pacientes estables neurologicamente","Monitoreo continuo durante el estudio","Verificar implantes metalicos y marcapasos"]},{nombre:"Monitor de PIC (Camino o cateter ventricular)",descripcion:"Medicion continua de la presion intracraneal; gold standard en TCE grave y HIC severa en UCI",valoresReferencia:"PIC normal 5-15 mmHg; tratamiento agresivo si > 20 mmHg sostenido",cuidadosEnfermeria:["Cuidado esteril del sitio de insercion","Calibrar el transductor a nivel del trago auricular","Registrar valores continua y anotar factores que alteran la PIC (aspiracion, posicion)"]},{nombre:"Puncion lumbar (contraindicada si hay efecto de masa)",descripcion:"En HIC idiopatica o meningitis sin efecto de masa: mide presion de apertura y analiza el LCR",valoresReferencia:"Presion de apertura > 25 cmH2O confirma HIC; presion normal 10-20 cmH2O",cuidadosEnfermeria:["NUNCA realizar si hay signos de HIC con efecto de masa (riesgo de herniacion)","Posicionar en decubito lateral con piernas flexionadas","Medir presion de apertura con manometro antes de extraer LCR"]}]},tratamientoMedico:{objetivos:["Mantener PIC < 20 mmHg y PPC > 60 mmHg","Tratar la causa subyacente","Prevenir herniacion cerebral y muerte"],farmacologico:[{nombre:"Manitol hipertonico 20%",grupo:"Agente hiperosmolar diuretico osmotico",mecanismo:"Crea gradiente osmotico que extrae agua del cerebro edematizado hacia el plasma, reduciendo el volumen cerebral y la PIC en 15-30 min",dosis:"0.25-1 g/kg IV en bolo en 15-20 min; se puede repetir cada 4-6h",cuidadosEnfermeria:["Administrar con filtro de 5 micras (puede cristalizar)","Monitorizar osmolaridad plasmatica: no superar 320 mOsm/L (riesgo de toxicidad renal)","Controlar diuresis: el manitol es muy diuretico","Vigilar NA y electrolitos tras cada dosis"]},{nombre:"Suero hipertonico (ClNa 3%)",grupo:"Solucion hiperosmolar",mecanismo:"Eleva la osmolaridad plasmatica reduciendo el agua cerebral intersticial; mas sostenido que el manitol",dosis:"100-150 mL de ClNa 3% IV en 20 min, repetir segun PIC y natremia",cuidadosEnfermeria:["Administrar SIEMPRE por via central (riesgo de necrosis si extravasacion)","Monitorizar sodio plasmatico: objetivo 145-155 mEq/L en HIC severa","Vigilar sobrecarga de volumen"]},{nombre:"Dexametasona",grupo:"Corticosteroide potente",mecanismo:"Reduce el edema vasogenico peritumoral; NO tiene eficacia en el edema citotoxico del TCE o isquemia",dosis:"10 mg IV bolo seguido de 4 mg cada 6h en edema peritumoral por metastasis",cuidadosEnfermeria:["SOLO indicada en edema peritumoral neoplasico","Contraindicada en TCE (estudio CRASH: aumenta mortalidad)","Controlar glucemia cada 6h: hiperglucemia frecuente"]}],noFarmacologico:["Elevar la cabecera de la cama 30 grados (reduce la PIC sin comprometer la perfusion)","Evitar la rotacion y la flexion del cuello (obstaculizan el drenaje venoso yugular)","Mantener normotermia: la fiebre aumenta el metabolismo cerebral y la PIC","Sedoanalgesia en ventilacion mecanica: evitar la agitacion y la tos que aumentan la PIC","Hipocapnia leve (pCO2 35-40 mmHg en ventilacion mecanica): NO usar hiperventilacion agresiva cronica (solo como medida de emergencia por PIC en ascenso)"],quirurgico:["Drenaje ventricular externo (DVE) para HIC por hidrocefalia: drenaje de LCR","Cran\xedectomia descompresiva en TCE o infarto maligno con efecto de masa refractario","Evacuacion del hematoma intracraneal segun localizacion y tamano","Derivacion ventriculo-peritoneal en hidrocefalia cronica"]},cuidadosEnfermeria:{valoracion:["Monitorizar nivel de consciencia con escala de Glasgow cada hora","Evaluar pupilas: tamano, simetria y reactividad a la luz en cada control","Monitorizar signos vitales cada hora (triada de Cushing = alerta maxima)","Registrar PIC y calcular PPC cuando hay monitor intracraneal","Detectar signos de herniacion: anisocoria, postura de descerebraci\xf3n"],intervenciones:["Mantener cabecera elevada a 30 grados estrictamente","Evitar estimulos dolorosos, ruidos fuertes y la tos que elevan la PIC","Aspirar con sedacion previa para minimizar el aumento de PIC","Administrar manitol o suero hipertonico segun prescripcion urgente","Monitorizar electrolitos, osmolaridad y diuresis despues de agentes hiperosmolares","Preparar craneotomia de urgencia si hay signos de herniacion"],educacionPaciente:["La educacion es principalmente a la familia dado el estado critico del paciente","Explicar a la familia el significado del monitor de PIC y los valores de alarma","Preparar a la familia para posibles intervenciones quirurgicas urgentes"],monitorizacion:["PIC continua si hay monitor","Signos vitales y Glasgow cada hora","Sodio y osmolaridad cada 4-6h con agentes hiperosmolares","Pupilas cada hora","Diuresis horaria con manitol"]},npiNanda:[{codigo:"00049",nombre:"Disminucion de la capacidad adaptativa intracraneal",definicion:"Mecanismo de compensacion intracraneal dinamico normalmente comprometido por incrementos de volumen intracraneal",caracteristicasDefinitorias:["PIC > 20 mmHg","Alteracion del nivel de consciencia","Cambios pupilares"],factoresRelacionados:["Lesion cerebral con edema","Hemorragia intracraneal","Hidrocefalia"]},{codigo:"00002",nombre:"Deterioro del intercambio gaseoso cerebral",definicion:"Perfusion cerebral insuficiente",caracteristicasDefinitorias:["PPC < 60 mmHg","Alteracion de la consciencia","Signos neurologicos focales"],factoresRelacionados:["PIC elevada que reduce la presion de perfusion cerebral"]},{codigo:"00085",nombre:"Deterioro de la movilidad fisica",definicion:"Limitacion del movimiento fisico",caracteristicasDefinitorias:["Hemiparesia o tetraparesia","Postura anormal"],factoresRelacionados:["Lesion cerebral con hipertension intracraneal"]}],npiNic:[{codigo:"2540",nombre:"Monitorizacion de la presion intracraneal",actividades:["Calibrar el transductor a nivel del trago auricular","Registrar PIC y PPC cada hora","Identificar ondas de Lundberg tipo A y avisar al medico","Mantener PPC > 60 mmHg ajustando PAM y PIC"]},{codigo:"2590",nombre:"Manejo de la presion intracraneal elevada",actividades:["Mantener cabecera a 30 grados sin flexion de cuello","Administrar agentes hiperosmolares segun prescripcion urgente","Minimizar estimulos que aumentan la PIC","Documentar respuesta de la PIC a cada intervencion"]},{codigo:"2620",nombre:"Monitorizacion neurologica",actividades:["Evaluar Glasgow, pupilas y signos neurol\xf3gicos cada hora","Detectar precozmente signos de herniacion","Registrar tendencia del Glasgow (descenso es alarmante)"]}],npiNoc:[{codigo:"0909",nombre:"Estado neurologico",indicadores:["Glasgow estable o en mejoria","Pupilas isocoricas y reactivas","PIC < 20 mmHg","PPC > 60 mmHg"],escala:"1=Gravemente comprometido, 5=No comprometido"},{codigo:"0406",nombre:"Perfusion tisular: cerebral",indicadores:["Glasgow 15","Ausencia de anisocoria","PPC > 60 mmHg"],escala:"1=Desviacion grave, 5=Sin desviacion"}],complicaciones:["Herniacion cerebral uncal o transtentorial (urgencia vital)","Isquemia cerebral global o focal por hipoperfusion","Muerte cerebral","Diabetes insipida (lesion hipofisaria)","Sindrome de secrecion inadecuada de ADH (SIADH)"],criteriosAlarma:["Anisocoria: pupila dilatada y fija unilateral (herniacion uncal)","Descenso de Glasgow de 2 o mas puntos","Triada de Cushing: hipertension + bradicardia + respiracion irregular","PIC > 25 mmHg sostenida a pesar de tratamiento","Postura de descerebraci\xf3n o decorticacion"],emergencyLevel:"critico",relatedPathologyIds:["pat_acv","pat_tceg"],isPremium:!0},{id:"pat_neuralgia_trigemino",nombre:"Neuralgia del Trigemino",bodySystemId:"neurologico",definicion:"Sindrome de dolor orofacial severo caracterizado por episodios de dolor electrico, punzante o en descarga electrica, de inicio y fin bruscos, confinados a una o mas ramas del nervio trigemino (V par craneal), habitualmente desencadenados por estimulos minimos.",epidemiologia:"Incidencia de 4-5 casos por 100.000 habitantes/ano. Mas frecuente en mujeres mayores de 50 a\xf1os. Es el sindrome de dolor orofacial mas intenso conocido.",factoresRiesgo:["Compresion vascular del nervio trigemino (arteria cerebelosa superior)","Placas de desmielinizacion en nervio trigemino por esclerosis multiple (en jovenes)","Tumores del angulo pontocerebeloso (neurinoma del acustico)","Edad avanzada","Hipertension arterial (vasos tortuosos que comprimen el nervio)"],fisiopatologia:"En la forma clasica, un vaso sanguineo tortuoso (habitualmente la arteria cerebelosa superior) comprime la raiz del nervio trigemino en su entrada en el tronco cerebral, produciendo desmielinizacion focal. Esto genera descargas ectopicas espontaneas y una hipersensibilizacion que hace que estimulos minimos desencadenen paroxismos de dolor intenso.",signosYSintomas:{signos:["El examen neurologico suele ser normal en la forma clasica","En esclerosis multiple: alteracion de la sensibilidad facial (signo diferenciador)","La exploracion de la zona trigger desencadena el dolor (signo diagnostico)"],sintomas:["Dolor electrico o en descarga en hemicara, unilateral en el 97%","Duracion de segundos a 2 minutos por paroxismo","Desencadenado por tocar la cara, masticar, hablar, cepillado de dientes, brisa","Dolor libre entre paroxismos (diferencia de la neuropatia)","Rama mas afectada: V2 (mejilla) y V3 (menton) en el 95%","Periodos de remision de semanas o meses","Impacto severo en la calidad de vida (puede llevar a desnutricion por miedo a masticar)"]},clasificacion:{nombre:"Clasificacion ICHD-3",tipos:[{nombre:"Neuralgia clasica",descripcion:"Compresion neurovascular demostrada en RMN; 85% de los casos"},{nombre:"Neuralgia secundaria",descripcion:"Causada por esclerosis multiple (joven, bilateral), tumor del angulo pontocerebeloso"},{nombre:"Neuralgia idiopatica",descripcion:"Sin causa demostrable en la RMN"}]},diagnostico:{anamnesis:["Caracteristicas del dolor: electrico, punzante, en descarga","Duracion de cada paroxismo (segundos)","Factores desencadenantes: masticacion, habla, higiene dental","Localizacion y rama afectada","Presencia de dolor constante de fondo (sugiere causa secundaria)"],examenFisico:["Exploracion sensitiva del territorio trigeminal (tacto, calor, frio)","Palpacion de la zona trigger (mejilla, nariz, boca)","Evaluacion de los demas pares craneales","Auscultacion de soplos vasculares en el cuello"],pruebas:[{nombre:"RMN cerebral con secuencias especiales de nervio craneal (FIESTA/CISS)",descripcion:"Detecta compresion neurovascular y descarta lesiones secundarias (tumor, placa de EM)",valoresReferencia:"Contacto o compresion de la raiz trigeminal por un vaso visible en el 80-90% de la forma clasica",cuidadosEnfermeria:["No requiere contraste en primera instancia para deteccion de compresion","Informar sobre duracion del estudio (45-60 min)","Verificar contraindicaciones para resonancia"]},{nombre:"Potenciales evocados trigeminales",descripcion:"Detecta retardo en la conduccion trigeminal; util en esclerosis multiple",valoresReferencia:"Latencia normal del reflejo de parpadeo R1 < 13 ms; R2 < 41 ms",cuidadosEnfermeria:["Preparar sala de neurofisiologia","Informar al paciente sobre el procedimiento y los estimulos electricos leves"]}]},tratamientoMedico:{objetivos:["Reducir la frecuencia e intensidad de los paroxismos","Mejorar la calidad de vida y la funcion oral","Considerar cirugia en casos refractarios al tratamiento farmacologico"],farmacologico:[{nombre:"Carbamacepina",grupo:"Anticonvulsivante estabilizador de membrana",mecanismo:"Bloquea canales de sodio voltaje-dependientes reduciendo las descargas nerviosas ectopicas del trig\xe9mino",dosis:"100-200 mg/dia titulando hasta 600-1200 mg/dia en 2-3 tomas",cuidadosEnfermeria:["Iniciar con dosis bajas y aumentar cada 3-5 dias para tolerancia","Vigilar hiponatremia (efecto adverso en ancianos)","Control de hemograma y funcion hepatica al inicio y periodicamente","Advertir sobre sedacion, vertigo y diplopia al inicio"]},{nombre:"Oxcarbacepina",grupo:"Anticonvulsivante analogo de carbamacepina",mecanismo:"Similar mecanismo a carbamacepina con mejor tolerabilidad y menos interacciones farmacologicas",dosis:"150-300 mg/12h titulando hasta 600-1800 mg/dia",cuidadosEnfermeria:["Menor riesgo de hepatotoxicidad que carbamacepina","Vigilar hiponatremia con mas frecuencia que con carbamacepina","Mejor tolerada en ancianos"]},{nombre:"Baclofeno",grupo:"Agonista GABA-B",mecanismo:"Reduce la excitabilidad del ganglio trigeminal como adyuvante",dosis:"5-10 mg 3 veces al dia",cuidadosEnfermeria:["Util como adyuvante cuando carbamacepina no es suficiente","Vigilar sedacion excesiva"]},{nombre:"Pregabalina",grupo:"Ligando alfa-2-delta de canales de calcio",mecanismo:"Reduce la liberacion de neurotransmisores excitatorios en el ganglio trigeminal",dosis:"75-150 mg cada 12h",cuidadosEnfermeria:["Util como alternativa o en combinacion con carbamacepina","Vigilar sedacion, edema y ganancia de peso","Ajustar dosis en insuficiencia renal"]}],noFarmacologico:["Identificar y evitar los desencadenantes (higiene dental suave, comer en trozos peque\xf1os)","Mantener nutricion e hidratacion adecuadas (riesgo de desnutricion)","Apoyo psicologico (alta tasa de depresion y suicidio por el dolor severo)"],quirurgico:["Descompresion microvascular de Janetta (gold standard): separa el vaso del nervio con una esponja de teflon; 80-90% de remision a 5 a\xf1os","Radiocirugia estereotaxica (Gamma Knife): menos invasiva; 70% de respuesta inicial","Rizotomia percutanea (lesion del ganglio de Gasser): opcion en ancianos no candidatos a cirugia abierta"]},cuidadosEnfermeria:{valoracion:["Evaluar intensidad del dolor con escala numerica (NRS 0-10) en reposo y con desencadenantes","Identificar los desencadenantes especificos del paciente","Valorar estado nutricional: peso, ingesta alimentaria (puede negarse a comer)","Evaluar impacto emocional: depresion, ansiedad, ideacion suicida"],intervenciones:["Administrar carbamacepina segun horario estricto con alimentos","Monitorizar sodio y hemograma con carbamacepina","Planificar la higiene oral de forma que minimice los estimulos triggerantes","Ayudar a identificar alimentos blandos tolerados para mantener nutricion","Coordinar atencion con psicologo si hay afectacion emocional severa"],educacionPaciente:["Explicar el mecanismo del dolor y los factores desencadenantes","Importancia de la titulacion lenta de carbamacepina","No suspender medicacion abruptamente","Informar sobre opciones quirurgicas cuando el farmaco falla","Recursos de apoyo psicologico y asociaciones de pacientes"],monitorizacion:["Sodio plasmatico periodico con carbamacepina","Hemograma y funcion hepatica con carbamacepina","Peso y estado nutricional mensual","Registro de frecuencia de paroxismos para evaluar respuesta al tratamiento"]},npiNanda:[{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva desagradable con da\xf1o tisular real o potencial",caracteristicasDefinitorias:["Paroxismos de dolor electrico en hemicara","Intensidad NRS 9-10","Evitacion de actividades desencadenantes"],factoresRelacionados:["Compresion neurovascular del nervio trigemino","Desmielinizacion de la raiz trigeminal"]},{codigo:"00002",nombre:"Desequilibrio nutricional: ingesta inferior a las necesidades",definicion:"Ingesta insuficiente de nutrientes",caracteristicasDefinitorias:["Evitacion de la masticacion por miedo al dolor","Perdida de peso","Ingesta reducida"],factoresRelacionados:["Dolor severo desencadenado por la masticacion"]},{codigo:"00124",nombre:"Desesperanza",definicion:"Estado subjetivo en el que el individuo percibe pocas o ninguna alternativa",caracteristicasDefinitorias:["Expresion de desesperanza ante el dolor","Depresion reactiva"],factoresRelacionados:["Dolor severo e incapacitante de larga evolucion"]}],npiNic:[{codigo:"1400",nombre:"Manejo del dolor",actividades:["Evaluar dolor con NRS antes y despues de medicacion","Administrar carbamacepina segun horario con alimentos","Identificar factores desencadenantes y estrategias de evitacion"]},{codigo:"1160",nombre:"Monitorizacion nutricional",actividades:["Pesar semanalmente","Identificar alimentos tolerados (blandos, temperatura templada)","Recomendar suplementos nutricionales si hay perdida de peso significativa"]},{codigo:"5270",nombre:"Apoyo emocional",actividades:["Escuchar activamente el impacto del dolor en la vida del paciente","Evaluar riesgo de depresion y suicidio","Derivar a psicologo especializado en dolor cronico"]}],npiNoc:[{codigo:"2102",nombre:"Nivel del dolor",indicadores:["Reduccion de la frecuencia de paroxismos","Duracion reducida con medicacion","Menos interferencia con actividades diarias"],escala:"1=Grave, 5=Ningun"},{codigo:"1004",nombre:"Estado nutricional",indicadores:["Peso estable","Ingesta oral adecuada con alimentos adaptados"],escala:"1=Desviacion grave, 5=Sin desviacion"}],complicaciones:["Desnutricion y deshidratacion por evitacion de la masticacion","Depresion mayor con riesgo de suicidio","Refractariedad al tratamiento farmacologico (30-50% a largo plazo)"],criteriosAlarma:["Dolor constante de fondo ademas de los paroxismos (sugiere causa secundaria)","Alteracion de la sensibilidad facial objetiva (tumor o EM)","Debut en menores de 50 a\xf1os (buscar esclerosis multiple o tumor)","Ideacion suicida activa por el dolor"],emergencyLevel:"leve",relatedPathologyIds:[],isPremium:!0},{id:"pat_hidrocefalia",nombre:"Hidrocefalia",bodySystemId:"neurologico",definicion:"Acumulacion patologica de liquido cefalorraquideo (LCR) en el sistema ventricular y/o en el espacio subaracnoideo, que produce dilatacion del sistema ventricular (ventriculomegalia) y aumento de la presion intracraneal en la mayoria de los casos.",epidemiologia:"Incidencia de hidrocefalia congenita: 3-4 casos por 1000 nacidos vivos. La hidrocefalia normotensiva del adulto (HNA) tiene una prevalencia del 0.2-2.9% en mayores de 65 a\xf1os, siendo subdiagnosticada. La hidrocefalia aguda post-hemorragia subaracnoidea se produce en el 20-30% de los casos.",factoresRiesgo:["Prematuridad (hemorragia intraventricular neonatal)","Espina bifida y otras malformaciones del SNC (Chiari, Dandy-Walker)","Hemorragia subaracnoidea o intraventricular","Meningitis bacteriana o tuberculosa con adherencias meningeas","Tumores que obstruyen el flujo de LCR (pineal, tercer ventriculo)","Estenosis del acueducto de Silvio (congenita o adquirida)","Edad avanzada en hidrocefalia normotensiva"],fisiopatologia:"El LCR se produce en los plexos coroideos (500 mL/dia), circula desde los ventriculos laterales a traves del III y IV ventriculo al espacio subaracnoideo, y se reabsorbe en las vellosidades aracnoideas. La hidrocefalia obstructiva resulta del bloqueo del flujo de LCR (estenosis del acueducto, tumor). La hidrocefalia comunicante resulta de la alteracion de la reabsorcion (post-hemorragica, post-meningitis). La HNA se produce por reduccion de la distensibilidad cerebral con aumento de la resistencia a la reabsorcion.",signosYSintomas:{signos:["Macrocefalia en lactantes (suturas abiertas)","Signo del sol poniente: desviacion conjugada inferior de los ojos en ni\xf1os","Dilatacion de las venas del cuero cabelludo en neonatos","Signos de HIC en adultos: papiledema, triada de Cushing","En HNA adulto: marcha magnetica (pasos cortos, pies pegados al suelo)","Incontinencia urinaria e indiferencia emocional en HNA"],sintomas:["Cefalea en caso que empeora en las ma\xf1anas en adultos","Nauseas y vomitos en proyectil","Somnolencia y alteracion del nivel de consciencia","Deficit visual (compresion de las vias opticas)","Triada de Hakim-Adams en HNA: demencia + alteracion de la marcha + incontinencia urinaria"]},clasificacion:{nombre:"Clasificacion por mecanismo y presion",tipos:[{nombre:"Hidrocefalia obstructiva (no comunicante)",descripcion:"Obstruccion del flujo de LCR dentro del sistema ventricular; causa mas frecuente: estenosis del acueducto"},{nombre:"Hidrocefalia comunicante",descripcion:"Obstruccion en las cisternas basales o en la reabsorcion aracnoidea; post-hemorragica, post-meningitis"},{nombre:"Hidrocefalia normotensiva (HNA)",descripcion:"PIC normal o intermitentemente elevada; triada de Hakim-Adams en adultos mayores"},{nombre:"Ex vacuo",descripcion:"Dilatacion ventricular por atrofia cerebral (no hay HIC); NO es hidrocefalia verdadera"}]},diagnostico:{anamnesis:["Antecedente de hemorragia subaracnoidea, meningitis o tumor","Evolucion de la cefalea y la alteration del nivel de consciencia","En HNA: inicio y evolucion de la triada (marcha, memoria, continencia)","Prematuridad y hemorragia intraventricular en neonatos"],examenFisico:["Medicion del perimetro cefalico en lactantes y comparacion con tablas","Palpacion de la fontanela (abombada y tensa = HIC)","Evaluacion neurologica: nivel de consciencia, marcha, signos cerebelosos","Fondo de ojo: edema de papila"],pruebas:[{nombre:"TC craneal",descripcion:"Primera prueba de imagen de eleccion: confirma la dilatacion ventricular y su causa",valoresReferencia:"Indice de Evans (relacion entre maximo diametro ventricular / diametro intracraneal transverso) > 0.3 confirma hidrocefalia",cuidadosEnfermeria:["Urgente si hay signos de HIC o descenso del nivel de consciencia","Monitorizar nivel de consciencia durante el traslado"]},{nombre:"RMN cerebral",descripcion:"Mas sensible que la TC: detecta la causa de la obstruccion (estenosis de acueducto, tumor), valoracion del flujo de LCR",valoresReferencia:"Aqueductal flow void en secuencias de flujo; Hiperintensidad periventricular en T2 en HNA",cuidadosEnfermeria:["Solo en pacientes estables","Verificar contraindicaciones para resonancia"]},{nombre:"Test de infusion de LCR (resistencia a la reabsorcion)",descripcion:"En HNA: mide la resistencia al flujo de LCR mediante infusion en el espacio subaracnoideo; predice la respuesta a la cirugia",valoresReferencia:"Resistencia a la reabsorcion > 12 mmHg/mL/min predice respuesta favorable a DVP",cuidadosEnfermeria:["Monitorizar al paciente durante la prueba (dura 2-3 horas)","Registrar presiones de LCR continuamente"]},{nombre:"Test de sustraccion de LCR (tap test)",descripcion:"En HNA: extraccion de 40-60 mL de LCR por puncion lumbar; mejoria de la marcha en las horas siguientes predice respuesta a la derivacion",valoresReferencia:"Mejoria > 20% en la velocidad de la marcha a las 2-4h = test positivo",cuidadosEnfermeria:["Evaluar la marcha antes y 2-4h despues de la puncion (velocidad y pasos)","Monitorizar cefalea post-puncion lumbar"]}]},tratamientoMedico:{objetivos:["Reducir la PIC y el volumen ventricular","Tratar la causa subyacente","Prevenir el da\xf1o neuronal irreversible","Recuperar la funcion neurologica (especialmente en HNA)"],farmacologico:[{nombre:"Acetazolamida",grupo:"Inhibidor de la anhidrasa carbonica",mecanismo:"Reduce la produccion de LCR en los plexos coroideos; medida temporal o en hidrocefalia leve",dosis:"25 mg/kg/dia en 3 dosis en ni\xf1os; 250-1000 mg/dia en adultos",cuidadosEnfermeria:["Monitorizar electrolitos: produce acidosis metabolica hiperclor\xe9mica y hipopotasemia","Contraindicada en insuficiencia renal o hepatica","Medida temporal: no sustituye a la cirugia en hidrocefalia establecida"]},{nombre:"Manitol 20% (en hidrocefalia aguda con HIC)",grupo:"Agente hiperosmolar",mecanismo:"Reduce rapidamente el volumen cerebral y la PIC como medida de emergencia mientras se prepara la cirugia",dosis:"0.5-1 g/kg IV en bolo urgente",cuidadosEnfermeria:["Medida de puente hasta la descompresion quirurgica urgente","Monitorizar osmolaridad y electrolitos","Administrar con filtro de 5 micras"]}],noFarmacologico:["Posicion con cabecera a 30 grados","Drenaje ventricular externo (DVE) de urgencia en hidrocefalia aguda obstructiva con deterioro neurologico"],quirurgico:["Derivacion ventriculo-peritoneal (DVP): primera linea en hidrocefalia comunicante y HNA; el LCR drena desde el ventriculo lateral al peritoneo por un cateter con valvula","Ventriculostomia endoscopica del III ventriculo (ETV): alternativa a la DVP en estenosis del acueducto; crea una comunicacion entre el III ventriculo y las cisternas basales","Drenaje ventricular externo (DVE): temporal en hidrocefalia aguda; permite monitorizar la PIC y drenar LCR","Derivacion lumbo-peritoneal: en hidrocefalia comunicante o HIC idiopatica"]},cuidadosEnfermeria:{valoracion:["Evaluar nivel de consciencia con escala de Glasgow cada hora en hidrocefalia aguda","Monitorizar el funcionamiento de la derivacion (DVP): signos de obstruccion o infeccion","Medir perimetro cefalico diariamente en lactantes","Evaluar fontanela en neonatos: normalmente plana; abombada = HIC; hundida = hiperdrenaje"],intervenciones:["Mantener cabecera a 30 grados para facilitar el drenaje venoso","Cuidado del sitio de cirugia de la derivacion: vigilar eritema, exudado, fiebre (meningitis por DVP)","Monitorizar signos de malfuncion de la derivacion: cefalea progresiva, nauseas, deterioro del nivel de consciencia","Cuidado del DVE: mantener el nivel del transductor segun prescripcion, evitar acodamientos del tubo","Ense\xf1ar a los padres y cuidadores a reconocer signos de disfuncion de la valvula"],educacionPaciente:["Instruir en el reconocimiento de signos de disfuncion de la derivacion","Explicar que la derivacion es permanente y requiere vigilancia de por vida","Actividades a evitar: contacto deportes de golpe en la cabeza","Planificacion de controles neurologicos periodicos e imagenes de seguimiento"],monitorizacion:["Glasgow cada hora en hidrocefalia aguda","Perimetro cefalico diario en lactantes","Drenaje por DVE: cantidad, color y presion del LCR","Signos de infeccion en sitio quirurgico","Signos de disfuncion de DVP a largo plazo"]},npiNanda:[{codigo:"00049",nombre:"Disminucion de la capacidad adaptativa intracraneal",definicion:"Mecanismo de compensacion intracraneal comprometido",caracteristicasDefinitorias:["Ventriculomegalia","PIC elevada","Glasgow descendente"],factoresRelacionados:["Acumulacion de LCR por obstruccion o falta de reabsorcion"]},{codigo:"00004",nombre:"Riesgo de infeccion",definicion:"Riesgo de ser invadido por organismos patogenos",caracteristicasDefinitorias:["Derivacion intracraneana","Sitio quirurgico"],factoresRelacionados:["Dispositivo de derivacion implatado (DVP, DVE)","Cirugia del SNC"]},{codigo:"00085",nombre:"Deterioro de la movilidad fisica",definicion:"Limitacion del movimiento fisico",caracteristicasDefinitorias:["Marcha magnetica en HNA","Inestabilidad de la marcha","Riesgo de caidas"],factoresRelacionados:["Hidrocefalia normotensiva con alteracion de circuitos frontales de la marcha"]}],npiNic:[{codigo:"2540",nombre:"Monitorizacion de la presion intracraneal",actividades:["Calibrar DVE al nivel del trago auricular","Registrar PIC y drenaje de LCR cada hora","Documentar caracteristicas del LCR: color, turbidez (amarillo o turbio = infeccion)"]},{codigo:"2620",nombre:"Monitorizacion neurologica",actividades:["Evaluar Glasgow, pupilas y signos de HIC cada hora en fase aguda","Medir perimetro cefalico en lactantes","Valorar la fontanela en neonatos"]},{codigo:"6550",nombre:"Proteccion contra las infecciones",actividades:["Cuidado esteril del sitio de derivacion","Vigilar signos de meningitis: fiebre, rigidez de nuca, LCR turbio","Cambio de ap\xf3sito segun protocolo"]}],npiNoc:[{codigo:"0909",nombre:"Estado neurologico",indicadores:["Glasgow 15 o en mejoria","Pupilas isocoricas y reactivas","Ausencia de cefalea severa"],escala:"1=Gravemente comprometido, 5=No comprometido"},{codigo:"0703",nombre:"Severidad de la infeccion",indicadores:["Afebril","LCR claro y sin microorganismos","Herida quirurgica sin signos inflamatorios"],escala:"1=Grave, 5=Ninguna"}],complicaciones:["Malfuncion de la derivacion (obstruccion, desconexion, fractura del cateter)","Infeccion de la derivacion (meningitis o ventriculitis)","Hiperdrenaje con hematoma subdural bilateral","Epilepsia postquirurgica","Herniacion cerebral en hidrocefalia aguda no tratada"],criteriosAlarma:["Deterioro brusco del nivel de consciencia","Cefalea muy intensa de inicio brusco con nauseas y vomitos","Fiebre con rigidez de nuca en paciente con DVP (meningitis por derivacion)","Fontanela muy abombada y tensa en lactante","Anisocoria (herniacion inminente)"],emergencyLevel:"critico",relatedPathologyIds:["pat_hipertension_intracraneal"],isPremium:!0},{id:"pat_colecistitis",nombre:"Colecistitis Aguda",bodySystemId:"digestivo",definicion:"Inflamacion aguda de la vesicula biliar, generalmente causada por la obstruccion del conducto cistico por un calculo biliar (colecistitis calculosa, 90-95%). La colecistitis alitiasica (5-10%) ocurre en pacientes criticos.",epidemiologia:"Afecta al 10-15% de la poblacion adulta. Es la complicacion mas frecuente de la colelitiasis. La colecistectomia laparoscopica es una de las cirugias mas realizadas en el mundo.",factoresRiesgo:["Colelitiasis previa (principal factor)","Obesidad","Sexo femenino","Embarazo y multiparidad","Edad > 40 a\xf1os","Dieta rica en grasas","Diabetes mellitus","Ayuno prolongado (colecistitis alitiasica en UCI)"],fisiopatologia:"La obstruccion del conducto cistico por un calculo produce distension vesicular con aumento de la presion intraluminal. La mucosa inflamada libera fosfolipasas que hidrolizan la lecitina biliar en lisolecitina, irritante de la mucosa. La inflamacion progresa con isquemia de la pared vesicular y riesgo de perforacion. En el 20% se produce sobreinfeccion bacteriana (E. coli, Klebsiella, Enterococcus).",signosYSintomas:{signos:["Signo de Murphy positivo (dolor a la palpacion en el hipocondrio derecho durante la inspiracion profunda)","Defensa muscular en hipocondrio derecho","Fiebre (38-39 grados)","Taquicardia","Ictericia leve en el 20% (calculo en coledoco)"],sintomas:["Dolor en hipocondrio derecho o epigastrio de inicio brusco","Irradiacion al hombro derecho o escapula (dolor phrenic)","Nauseas y vomitos","Intolerancia a alimentos grasos","Fiebre con escalofrios"]},clasificacion:{nombre:"Criterios de Tokio 2018 por severidad",tipos:[{nombre:"Grado I (Leve)",descripcion:"Sin disfuncion organica; responde al tratamiento medico conservador"},{nombre:"Grado II (Moderada)",descripcion:"Leucocitosis > 18.000, masa palpable, duracion > 72h o inflamacion local severa"},{nombre:"Grado III (Severa)",descripcion:"Disfuncion de al menos un organo: hipotension, alteracion neurologica, fallo respiratorio, renal o hepatico"}]},diagnostico:{anamnesis:["Antecedente de colicos biliares previos","Inicio y caracteristicas del dolor: intensidad, irradiacion","Intolerancia a grasas","Fiebre y escalofrios"],examenFisico:["Signo de Murphy: palpacion profunda en hipocondrio derecho durante inspiracion","Temperatura: fiebre moderada","Busqueda de ictericia escleral"],pruebas:[{nombre:"Ecografia abdominal",descripcion:"Primera prueba de eleccion: detecta calculos, engrosamiento de pared vesicular (> 4 mm), liquido perivesicular y signo de Murphy ecografico",valoresReferencia:"Pared vesicular > 4 mm, calculo impactado en infundibulo",cuidadosEnfermeria:["Ayuno de 6-8h para optima visualizacion de la vesicula","Posicionar en decubito lateral izquierdo o supino"]},{nombre:"Hemograma con formula leucocitaria",descripcion:"Leucocitosis con neutrofilia indica inflamacion bacteriana; leucocitosis > 18.000 = grado II",valoresReferencia:"Leucocitos normales 4.500-11.000; neutrofilia > 75%",cuidadosEnfermeria:["No requiere ayuno especifico","Extraer antes del inicio de antibioticos"]},{nombre:"Perfil hepatico y amilasa",descripcion:"Detecta coledocolitiasis (elevacion de bilirrubina, FA y GGT) y pancreatitis asociada (amilasa)",valoresReferencia:"Bilirrubina total < 1.2 mg/dL; FA < 120 UI/L; Amilasa < 100 UI/L",cuidadosEnfermeria:["Ayuno previo para lipidos si se solicita perfil completo","Registrar hora de extraccion"]}]},tratamientoMedico:{objetivos:["Control del dolor e inflamacion","Prevencion de complicaciones","Colecistectomia laparoscopica en las primeras 72h (tratamiento definitivo)"],farmacologico:[{nombre:"Ceftriaxona",grupo:"Cefalosporina de 3ra generacion",mecanismo:"Antibiotico de amplio espectro activo contra germenes ent\xe9ricos gramnegativos causantes de infeccion vesicular",dosis:"1-2 g IV cada 24h durante 3-5 dias",cuidadosEnfermeria:["Administrar en 30 min IV diluida en 100 mL SF","Verificar alergias a cefalosporinas y penicilinas","Cultivo de bilis durante la cirugia para ajuste posterior"]},{nombre:"Metronidazol",grupo:"Antibiotico nitroimidazol antianaer?bico",mecanismo:"Cubre anaerobios como Bacteroides fragilis en infecciones biliares complicadas",dosis:"500 mg IV cada 8h",cuidadosEnfermeria:["Administrar en 30-60 min IV","Avisar al paciente sobre la intolerancia al alcohol (efecto disulfiram)","Vigilar nauseas y sabor metalico"]},{nombre:"Ketorolaco",grupo:"AINE analgesico parenteral",mecanismo:"Inhibe COX reduciendo el dolor viseceral y la inflamacion de la pared vesicular",dosis:"15-30 mg IV cada 6-8h (no mas de 5 dias)",cuidadosEnfermeria:["Vigilar sangrado digestivo y funcion renal","Contraindicado con insuficiencia renal","Usar como adyuvante de opioides en dolor severo"]}],noFarmacologico:["Dieta absoluta hasta cirugia o mejoria clinica","Hidratacion IV con suero fisiologico o Ringer lactato","Analgesia adecuada (no contraindicada por morfina)","Colecistostomia percutanea en pacientes de alto riesgo quirurgico como puente"],quirurgico:["Colecistectomia laparoscopica en las primeras 24-72h (tratamiento de eleccion)","Colecistectomia abierta en complicaciones: perforacion, peritonitis"]},cuidadosEnfermeria:{valoracion:["Evaluar dolor con escala NRS: localizacion, irradiacion, intensidad","Monitorizar temperatura cada 4-6h (fiebre indica infeccion activa)","Valorar signos peritoneales: defensa, rigidez, Blumberg","Controlar frecuencia cardiaca y PA: taquicardia por dolor o sepsis"],intervenciones:["Mantener dieta absoluta y via venosa permeable para hidratacion","Administrar analgesicos y antibioticos segun prescripcion","Monitorizar balance hidrico","Preparacion preoperatoria para colecistectomia laparoscopica","Informar al paciente sobre el procedimiento quirurgico"],educacionPaciente:["Explicar la naturaleza calculosa y la necesidad de cirugia","Dieta pobre en grasas hasta la cirugia y durante la recuperacion","Cuidado de la herida laparoscopica postoperatoria","Signos de alarma post-cirugia: fiebre, dolor abdominal, ictericia"],monitorizacion:["Temperatura cada 4-6h","Signos vitales cada 4h","Signos de peritonitis en cada valoracion","Diuresis si se administran antibioticos nefrotoxicos"]},npiNanda:[{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva desagradable asociada con inflamacion vesicular",caracteristicasDefinitorias:["Dolor en hipocondrio derecho","Signo de Murphy positivo","Taquicardia","Posicion antialgica"],factoresRelacionados:["Inflamacion de la pared vesicular","Distension vesicular por calculo impactado"]},{codigo:"00002",nombre:"Desequilibrio nutricional: ingesta inferior a las necesidades",definicion:"Ingesta insuficiente de nutrientes",caracteristicasDefinitorias:["Dieta absoluta indicada","Nauseas y vomitos"],factoresRelacionados:["Dieta absoluta terapeutica","Intolerancia digestiva por inflamacion"]},{codigo:"00004",nombre:"Riesgo de infeccion",definicion:"Riesgo de ser invadido por organismos patogenos",caracteristicasDefinitorias:["Inflamacion vesicular con posible sobreinfeccion"],factoresRelacionados:["Estasis biliar","Isquemia de la pared vesicular"]}],npiNic:[{codigo:"1400",nombre:"Manejo del dolor",actividades:["Evaluar dolor cada 4h con escala NRS","Administrar analgesicos y antiespasm\xf3dicos segun prescripcion","Monitorizar eficacia del tratamiento analgesico"]},{codigo:"6540",nombre:"Control de infecciones",actividades:["Administrar antibioticos segun protocolo","Monitorizar temperatura y recuento leucocitario","Vigilar signos de peritonitis o colangitis"]},{codigo:"1080",nombre:"Manejo de la eliminacion gastrointestinal",actividades:["Mantener dieta absoluta segun indicacion","Hidratacion IV","Valorar reintroduccion de dieta tras cirugia"]}],npiNoc:[{codigo:"2102",nombre:"Nivel del dolor",indicadores:["Dolor < 3/10 con analgesia","Ausencia de signo de Murphy","FC < 100 lpm"],escala:"1=Grave, 5=Ningun"},{codigo:"0703",nombre:"Severidad de la infeccion",indicadores:["Afebril","Leucocitos en rango normal","Sin signos peritoneales"],escala:"1=Grave, 5=Ninguna"}],complicaciones:["Perforacion vesicular con peritonitis biliar","Colangitis ascendente (urgencia)","Empiema vesicular","Fistula colecisto-duodenal con ilieo biliar","Colecistitis enfisematosa (gas en pared vesicular)"],criteriosAlarma:["Fiebre > 39 grados con escalofrios (colangitis)","Ictericia progresiva (coledocolitiasis)","Signos peritoneales: rigidez abdominal, Blumberg positivo (perforacion)","Hipotension (sepsis biliar)","Ausencia de mejoria a las 72h con tratamiento medico"],emergencyLevel:"moderado",relatedPathologyIds:["pat_pancreatitis"],isPremium:!0},{id:"pat_hepatitis",nombre:"Hepatitis Viral",bodySystemId:"digestivo",definicion:"Inflamacion del higado causada por virus hepatotropos (VHA, VHB, VHC, VHD, VHE), con espectro clinico desde formas asintomaticas hasta hepatitis fulminante con insuficiencia hepatica aguda.",epidemiologia:"VHB: 290 millones de portadores cronicos; 820.000 muertes/ano por cirrosis y hepatocarcinoma. VHC: 58 millones de portadores cronicos; 290.000 muertes/ano. VHA: mas de 1.4 millones de casos agudos/ano; forma epidemica en paises en desarrollo.",factoresRiesgo:["VHA/VHE: agua o alimentos contaminados, viajes a areas endemicas, hacinamiento","VHB: relaciones sexuales sin proteccion, uso de drogas IV, transmision vertical madre-hijo, personal sanitario","VHC: uso de drogas IV (principal factor en paises desarrollados), transfusiones previas a 1992, procedimientos medicos invasivos en areas endemicas"],fisiopatologia:"Los virus hepatotropos infectan los hepatocitos. El da\xf1o hepatico es principalmente inmunomediado: los linfocitos T CD8+ reconocen antigenos virales en la superficie de los hepatocitos e inducen apoptosis. En la infeccion cronica por VHB y VHC, la inflamacion persistente produce fibrosis progresiva (cicatrices) que puede evolucionar a cirrosis en 20-30 a\xf1os.",signosYSintomas:{signos:["Ictericia escleroconjuntival y cutanea","Hepatomegalia dolorosa a la palpacion","Orina de color oscuro (coluria)","Heces decoloradas (acolia) en colestasis","Signos de insuficiencia hepatica en formas graves: encefalopatia, ascitis, equimosis"],sintomas:["Fase preterica: astenia, anorexia, nauseas, fiebre (sindrome gripal)","Coluria y acolia (inicio de la ictericia)","Dolor en hipocondrio derecho","Prurito en colestasis","Artralgias y mialgias (VHB: sindrome serumlike)"]},clasificacion:{nombre:"Clasificacion por agente etiologico",tipos:[{nombre:"Hepatitis A",descripcion:"RNA virus picornavirus; transmision fecal-oral; aguda autolimitada; nunca cronifica; vacuna disponible"},{nombre:"Hepatitis B",descripcion:"DNA virus hepadnavirus; transmision parenteral, sexual y vertical; cronifica en 5-10% adultos, 90% neonatos; vacuna disponible"},{nombre:"Hepatitis C",descripcion:"RNA virus flavivirus; transmision parenteral (ADVP); cronifica en 70-80%; curable con antivirales de accion directa"},{nombre:"Hepatitis D",descripcion:"RNA virus defectivo; solo en coinfeccion con VHB; la coinfeccion aguda VHB+VHD es autolimitada; la superinfeccion VHD en portador VHB es grave"},{nombre:"Hepatitis E",descripcion:"RNA virus; transmision fecal-oral; severa en embarazadas (mortalidad 20%); zoonosis en paises desarrollados (cerdo)"}]},diagnostico:{anamnesis:["Antecedentes epidemiologicos: viajes, contactos, practica sexual de riesgo, drogas IV","Vacunacion previa frente a VHA y VHB","Tiempo de evolucion y sintomas prodromicos","Medicacion (hepatitis medicamentosa en diagnostico diferencial)"],examenFisico:["Grado de ictericia (esclerotical, cutanea)","Tamano y consistencia del higado (hepatomegalia blanda en hepatitis aguda)","Signos de hipertension portal (ascitis, circulacion colateral)","Encefalopatia hepatica: flapping tremor, desorientacion"],pruebas:[{nombre:"Perfil hepatico completo (transaminasas, bilirrubina, GGT, FA)",descripcion:"Cuantifica el da\xf1o hepatocelular y el grado de colestasis",valoresReferencia:"ALT normal < 40 UI/L; en hepatitis viral aguda puede superar 1000-5000 UI/L",cuidadosEnfermeria:["Extraer en ayunas de 4-6h","Registrar hora y condiciones de extraccion","Serie de transaminasas para monitorizar la evolucion"]},{nombre:"Serologia viral completa",descripcion:"Identifica el agente etiologico y el estadio de la infeccion: AgHBs, anti-HBs, IgM anti-HBc, anti-HCV, IgM anti-HAV, AgHBe",valoresReferencia:"AgHBs positivo = infeccion activa por VHB; IgM anti-HBc = infeccion aguda; anti-HCV positivo = contacto con VHC (confirmar con PCR)",cuidadosEnfermeria:["No requiere ayuno para serologia","Registrar el resultado para la notificacion epidemiologica obligatoria"]},{nombre:"Carga viral (PCR VHB o VHC)",descripcion:"Cuantifica la replicacion viral; guia la indicacion y la respuesta al tratamiento antiviral",valoresReferencia:"VHB: ADN < 2000 UI/mL = portador inactivo; > 20.000 = hepatitis activa. VHC: ARN detectable confirma infeccion activa",cuidadosEnfermeria:["Mantener muestra a temperatura adecuada","Resultado puede tardar 2-7 dias"]},{nombre:"Tiempo de protrombina (TP) y albumina",descripcion:"Evaluan la funcion de sintesis hepatica; fundamentales para detectar insuficiencia hepatica aguda",valoresReferencia:"TP < 70% o INR > 1.5 indica afectacion de la sintesis hepatica",cuidadosEnfermeria:["En hepatitis fulminante: extraer urgente","Un TP < 40% con encefalopatia = criterio de trasplante urgente"]}]},tratamientoMedico:{objetivos:["En hepatitis aguda: soporte y monitorizacion; prevencion de hepatitis fulminante","En VHC cronica: erradicacion viral con antivirales de accion directa (curacion en > 95%)","En VHB cronica: supresion viral de por vida; prevenir cirrosis y hepatocarcinoma"],farmacologico:[{nombre:"Sofosbuvir + Velpatasvir (antivirales directos para VHC)",grupo:"Antivirales de accion directa (AAD) pangenotipicos",mecanismo:"Sofosbuvir inhibe la polimerasa NS5B del VHC; velpatasvir inhibe NS5A; combinacion sinergica con alta barrera genetica a la resistencia",dosis:"Un comprimido al dia durante 12 semanas (todos los genotipos)",cuidadosEnfermeria:["Verificar respuesta virologica sostenida (RVS) con PCR a las 12 semanas post-tratamiento","Vigilar interacciones: amiodarona contraindicada con sofosbuvir","Eficacia > 95%: ense\xf1ar que es curable para mejorar la adherencia"]},{nombre:"Tenofovir disoproxil (TAF o TDF) para VHB cronica",grupo:"Analogo de nucleotido inhibidor de la polimerasa VHB",mecanismo:"Inhibe la ADN polimerasa viral; alta barrera genetica a la resistencia; de por vida en la mayoria",dosis:"TAF 25 mg/dia o TDF 300 mg/dia VO",cuidadosEnfermeria:["Monitorizar funcion renal y densidad osea con TDF (mas nefrotoxicidad)","TAF tiene mejor perfil renal y oseo","Adherencia estricta: la supresion viral previene cirrosis y hepatocarcinoma"]},{nombre:"N-acetilcisteina IV (hepatitis fulminante)",grupo:"Antioxidante y precursor de glutathion",mecanismo:"Repone glutathion hepatico y actua como antioxidante en la necrosis hepatica masiva; indicado principalmente en insuficiencia hepatica por paracetamol",dosis:"150 mg/kg en 60 min, luego 50 mg/kg en 4h, luego 100 mg/kg en 16h",cuidadosEnfermeria:["Preparar con glucosa 5% segun protocolo","Vigilar reacciones anafilactoides en la primera hora (mas frecuentes)","En caso de reaccion: detener infusion, administrar antihistaminico y reiniciar mas lentamente"]}],noFarmacologico:["Reposo relativo durante la fase aguda ict\xe9rica","Dieta hepatoprotectora: evitar alcohol absolutamente, reducir grasas","Hidratacion oral o IV en caso de intolerancia oral","Notificacion epidemiologica obligatoria y rastreo de contactos","Vacunacion de contactos (VHA y VHB)"],quirurgico:["Trasplante hepatico urgente en insuficiencia hepatica aguda fulminante (criterios del Kings College)"]},cuidadosEnfermeria:{valoracion:["Monitorizar diariamente transaminasas, TP y bilirrubina en hepatitis aguda moderada-severa","Evaluar nivel de consciencia: flapping tremor y desorientacion indican encefalopatia","Valorar ictericia: escala de coloracion de la piel y escleras","Controlar diuresis y edemas (fallo hepatico avanzado)"],intervenciones:["Precauciones de aislamiento segun via de transmision (ent\xe9rico para VHA, universal para VHB/VHC)","Administrar antivirales segun prescripcion y adherencia","Control estricto de la via venosa (VHC y VHB: evitar contaminacion)","Reposo en cama durante la fase ict\xe9rica aguda","Notificacion a salud publica segun protocolo"],educacionPaciente:["Abstinencia absoluta de alcohol durante y despues de la hepatitis","Medidas de prevencion de transmision segun el virus: uso de preservativos en VHB/VHC, higiene de manos en VHA","Importancia de la adherencia al tratamiento antiviral en VHC y VHB cronica","En VHC: explicar que es curable con tratamiento completo","No donar sangre, organos ni tejidos"],monitorizacion:["Transaminasas y TP diario en fase aguda severa","Nivel de consciencia cada 4-8h en hepatitis severa","Peso y diuresis diarios si hay ascitis","PCR viral a las 12 semanas post-tratamiento de VHC (RVS)"]},npiNanda:[{codigo:"00178",nombre:"Gestion ineficaz de la propia salud",definicion:"Patron de regulacion del regimen terapeutico inadecuado",caracteristicasDefinitorias:["Dificultad con el tratamiento antiviral de larga duracion","Consumo continuado de alcohol"],factoresRelacionados:["Complejidad del tratamiento","Dependencia al alcohol"]},{codigo:"00188",nombre:"Tendencia a adoptar conductas de riesgo para la salud",definicion:"Incapacidad para modificar el estilo de vida",caracteristicasDefinitorias:["Continua con conductas de riesgo para transmision del virus"],factoresRelacionados:["Falta de conocimiento sobre modos de transmision"]},{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva desagradable",caracteristicasDefinitorias:["Dolor en hipocondrio derecho","Malestar general"],factoresRelacionados:["Inflamacion hepatica y hepatomegalia"]}],npiNic:[{codigo:"2080",nombre:"Manejo de la eliminacion hepatica",actividades:["Monitorizar transaminasas y TP diariamente en fase aguda","Evaluar signos de encefalopatia hepatica","Restringir proteinas si hay encefalopatia"]},{codigo:"6540",nombre:"Control de infecciones",actividades:["Aplicar precauciones segun via de transmision","Educar al paciente sobre medidas de prevencion","Notificar a autoridades sanitarias"]},{codigo:"5510",nombre:"Educacion para la salud",actividades:["Explicar la transmision del virus especifico","Ense\xf1ar medidas de prevencion de transmision","Explicar el tratamiento antiviral y su curabilidad en VHC"]}],npiNoc:[{codigo:"0800",nombre:"Termicidad",indicadores:["Afebril","Transaminasas en descenso progresivo","Bilirrubina normalizada"],escala:"1=Desviacion grave, 5=Sin desviacion"},{codigo:"1803",nombre:"Conocimiento del proceso de la enfermedad",indicadores:["Identifica modos de transmision","Conoce el tratamiento","Abstinencia de alcohol"],escala:"1=Ningun conocimiento, 5=Conocimiento extenso"}],complicaciones:["Hepatitis fulminante con insuficiencia hepatica aguda (VHB, VHE en embarazadas)","Cirrosis hepatica tras infeccion cronica (VHB, VHC)","Hepatocarcinoma sobre cirrosis","Crioglobulinemia mixta en VHC cronica"],criteriosAlarma:["TP < 40% o INR > 2.5 (insuficiencia hepatica)","Encefalopatia hepatica: flapping tremor, confusion, desorientacion","Ascitis de rapida instauracion","Bilirrubina > 20 mg/dL","Hemorragia digestiva alta (varices esofagicas en cirrosis)"],emergencyLevel:"moderado",relatedPathologyIds:["pat_cirrosis"],isPremium:!0},{id:"pat_diverticulitis",nombre:"Diverticulitis",bodySystemId:"digestivo",definicion:"Inflamacion o infeccion de uno o mas diverticulos del colon, formaciones saculares adquiridas de la mucosa y submucosa que protruyen a traves de la pared muscular del colon. La localizacion mas frecuente es el colon sigmoide.",epidemiologia:"La diverticulosis (presencia de diverticulos sin inflamacion) afecta al 5-10% de adultos > 40 a\xf1os, aumentando al 65% en mayores de 85 a\xf1os. El 10-25% de los portadores de diverticulosis desarrollaran diverticulitis a lo largo de su vida.",factoresRiesgo:["Edad avanzada (> 50 a\xf1os)","Dieta baja en fibra","Estrenimiento cronico y esfuerzo defecatorio","Obesidad","Sedentarismo","Consumo de carne roja","AINEs y corticoides (aumentan el riesgo de perforacion)","Tabaquismo"],fisiopatologia:"Los diverticulos se forman en los puntos de mayor debilidad de la pared colica (donde penetran los vasa recta). La microperfuracion de un diverticulo por impacto fecal o por isquemia focal produce inflamacion pericolica. En la mayoria de los casos esta contenida por el tejido peric\xf3lico (diverticulitis no complicada). En el 15-20% se producen complicaciones: absceso, peritonitis, fistula o estenosis.",signosYSintomas:{signos:["Defensa muscular en fosa iliaca izquierda","Masa palpable en FII si hay absceso peric\xf3lico","Fiebre (37.5-38.5 grados)","Signos de peritonitis en formas complicadas: rigidez abdominal, Blumberg"],sintomas:["Dolor en fosa iliaca izquierda (signo cardinal)","Cambios en el ritmo intestinal: diarrea o estrenimiento","Nauseas y vomitos","Disuria y polaquiuria si hay inflamacion sobre la vejiga (fistula vesicocolica)","Fiebre con escalofrios en formas complicadas"]},clasificacion:{nombre:"Clasificacion de Hinchey modificada",tipos:[{nombre:"Estadio Ia",descripcion:"Inflamacion pericolica confinada sin absceso; tratamiento antibiotico ambulatorio u hospitalario"},{nombre:"Estadio Ib",descripcion:"Absceso peric\xf3lico confinado < 4 cm; antibioticos IV hospitalarios"},{nombre:"Estadio II",descripcion:"Absceso p\xe9lvico o intraabdominal > 4 cm; drenaje percutaneo mas antibioticos"},{nombre:"Estadio III",descripcion:"Peritonitis purulenta generalizada por perforacion cubierta; cirugia urgente"},{nombre:"Estadio IV",descripcion:"Peritonitis fecal por perforacion libre; cirugia urgente de Hartmann"}]},diagnostico:{anamnesis:["Dolor en FII de inicio progresivo en horas","Episodios previos de dolor similar","Cambio en el ritmo intestinal","Fiebre y malestar general"],examenFisico:["Palpacion: defensa voluntaria o involuntaria en FII","Temperatura: fiebre moderada","Signos peritoneales en formas complicadas","Tacto rectal: dolor en la cara lateral izquierda"],pruebas:[{nombre:"TC abdominal con contraste",descripcion:"Gold standard diagnostico: detecta engrosamiento de la pared colica, inflamacion peric\xf3lica, abscesos y perforacion libre",valoresReferencia:"Engrosamiento pared > 4 mm con inflamacion peric\xf3lica = criterio diagnostico",cuidadosEnfermeria:["Verificar funcion renal y alergias al contraste yodado","Hidratacion pre y post contraste","No requiere preparacion intestinal especial"]},{nombre:"PCR y hemograma",descripcion:"Marcadores de inflamacion: PCR > 150 mg/L y leucocitosis sugieren complicacion",valoresReferencia:"PCR > 50 mg/L orienta a diverticulitis; > 150 mg/L sugiere absceso o perforacion",cuidadosEnfermeria:["Extraer antes del inicio de antibioticos","Repetir PCR a las 72h para evaluar respuesta"]},{nombre:"Colonoscopia (diferida 6-8 semanas post-episodio agudo)",descripcion:"Confirma el diagnostico, descarta cancer colorrectal y evalua la extension de la diverticulosis",valoresReferencia:"No realizar en fase aguda por riesgo de perforacion",cuidadosEnfermeria:["Programar colonoscopia 6-8 semanas despues del episodio agudo","Preparacion colonica completa el dia previo"]}]},tratamientoMedico:{objetivos:["Resolver el episodio agudo","Prevenir complicaciones","Prevencion de recurrencias con dieta rica en fibra","Cirugia electiva en casos seleccionados con episodios recurrentes"],farmacologico:[{nombre:"Amoxicilina-clavulanico",grupo:"Antibiotico de amplio espectro",mecanismo:"Cubre la flora colica: gramnegativos ent\xe9ricos y anaerobios causantes de diverticulitis",dosis:"Ambulatorio: 875/125 mg cada 12h VO 7 dias. Hospitalario: 1-2 g IV cada 8h",cuidadosEnfermeria:["Administrar IV en 30 min diluido en 100 mL SF","Vigilar diarrea por Clostridium difficile con uso prolongado","Verificar tolerancia oral antes de cambio VO"]},{nombre:"Ciprofloxacino + Metronidazol",grupo:"Antibioticos combinados para flora ent\xe9rica",mecanismo:"Ciprofloxacino cubre gramnegativos; metronidazol cubre anaerobios; combinacion de primera linea alternativa",dosis:"Ciprofloxacino 500 mg cada 12h VO + Metronidazol 500 mg cada 8h VO por 7-10 dias",cuidadosEnfermeria:["Administrar con alimentos para reducir intolerancia digestiva","No consumir alcohol con metronidazol","Ciprofloxacino puede producir tendinitis en ancianos"]}],noFarmacologico:["Dieta absoluta o liquida en fase aguda","Hidratacion IV en hospitalizados","Reposo relativo","Drenaje percutaneo de abscesos > 4 cm guiado por TC o ecografia","Dieta rica en fibra (> 25 g/dia) en la prevencion de recurrencias"],quirurgico:["Cirugia de Hartmann urgente en peritonitis fecal o purulenta (Hinchey III-IV)","Sigmoidectomia electiva laparoscopica en episodios recurrentes (> 2 episodios/ano) o complicaciones (estenosis, fistula)"]},cuidadosEnfermeria:{valoracion:["Evaluar dolor en FII con escala NRS y signos peritoneales en cada turno","Monitorizar temperatura cada 4-6h","Valorar tolerancia oral para determinar inicio de dieta","Detectar signos de deterioro: aumento del dolor, rigidez abdominal, hipotension"],intervenciones:["Dieta absoluta o liquida segun indicacion medica","Hidratacion IV con solucion balanceada","Administrar antibioticos IV segun prescripcion y protocolo","Preparacion del paciente para TC con contraste (via venosa, consntimiento)","Si hay drenaje percutaneo: cuidado y registro de la cantidad y caracteristicas del drenaje"],educacionPaciente:["Dieta rica en fibra (25-30 g/dia) para prevenir recurrencias: frutas, verduras, cereales integrales","Importancia de la hidratacion y el ejercicio regular","Cuando consultar: aumento del dolor, fiebre alta, cambios en el ritmo intestinal","Colonoscopia de control obligatoria tras el episodio agudo"],monitorizacion:["Signos vitales cada 4-6h","Temperatura para detectar bacteriemia","Signos peritoneales en cada turno","Hemograma y PCR al ingreso y a las 48-72h"]},npiNanda:[{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva desagradable por inflamacion colonica",caracteristicasDefinitorias:["Dolor en FII","Defensa muscular","Fiebre","Taquicardia"],factoresRelacionados:["Inflamacion pericolica por microperfuracion diverticular"]},{codigo:"00196",nombre:"Motilidad gastrointestinal disfuncional",definicion:"Aumento, disminucion, ineficacia o carencia de actividad perist\xe1ltica gastrointestinal",caracteristicasDefinitorias:["Cambio en el ritmo intestinal","Nauseas","Distension abdominal"],factoresRelacionados:["Inflamacion del colon sigmoide"]},{codigo:"00004",nombre:"Riesgo de infeccion",definicion:"Riesgo de ser invadido por organismos patogenos",caracteristicasDefinitorias:["Microperfuracion diverticular con flora ent\xe9rica"],factoresRelacionados:["Perforacion contenida de diverticulo colico"]}],npiNic:[{codigo:"1400",nombre:"Manejo del dolor",actividades:["Evaluar dolor con NRS cada 4h","Administrar analgesicos segun prescripcion","Vigilar progresion del dolor como indicador de complicacion"]},{codigo:"6540",nombre:"Control de infecciones",actividades:["Administrar antibioticos segun protocolo y ajuste por cultivos","Monitorizar temperatura y leucocitos","Vigilar signos de peritonitis en cada turno"]},{codigo:"1080",nombre:"Manejo gastrointestinal",actividades:["Mantener dieta absoluta en fase aguda","Iniciar liquidos claros cuando mejore el dolor","Progresar dieta segun tolerancia"]}],npiNoc:[{codigo:"2102",nombre:"Nivel del dolor",indicadores:["Dolor FII < 3/10 con tratamiento","Ausencia de defensa muscular","Afebril"],escala:"1=Grave, 5=Ningun"},{codigo:"0703",nombre:"Severidad de la infeccion",indicadores:["Afebril a las 48-72h","PCR en descenso","Sin signos de peritonitis"],escala:"1=Grave, 5=Ninguna"}],complicaciones:["Absceso peric\xf3lico o p\xe9lvico","Peritonitis purulenta o fecal (emergencia)","Fistula vesicocolica o colovaginal","Estenosis colica con obstruccion intestinal","Hemorragia diverticular masiva"],criteriosAlarma:["Dolor abdominal difuso con rigidez de tabla (peritonitis)","Hipotension o taquicardia (sepsis)","Incapacidad para tolerar liquidos","No respuesta a antibioticos a las 72h","Neumoperitoneo en radiografia (perforacion libre)"],emergencyLevel:"moderado",relatedPathologyIds:[],isPremium:!0},{id:"pat_reflujo",nombre:"Enfermedad por Reflujo Gastroesofagico (ERGE)",bodySystemId:"digestivo",definicion:"Condicion en la que el contenido gastrico refluy hacia el esofago produciendo sintomas molestos o complicaciones. Se produce por la disfuncion del esfinter esofagico inferior (EEI) y los mecanismos antirreflujo normales.",epidemiologia:"Prevalencia del 10-30% en la poblacion occidental (una de las enfermedades digestivas mas frecuentes). El 40% de los adultos experimenta pirosis al menos una vez al mes. El esofago de Barrett complica el 10-15% de los casos de ERGE cronica.",factoresRiesgo:["Obesidad (principal factor modificable)","Hernia hiatal por deslizamiento","Embarazo","Tabaquismo","Consumo de alcohol","Dieta: chocolate, menta, caf\xe9, comidas grasas y picantes","Medicamentos: antagonistas del calcio, anticolinergicos, benzodiacepinas","Gastroparesia","Esclerodermia"],fisiopatologia:"El EEI normal mantiene una presion de reposo de 15-30 mmHg que evita el reflujo. En la ERGE, la presion del EEI esta reducida o hay relajaciones transitorias inapropiadas del EEI (causa mas frecuente). El reflujo del acido clorhidrico produce esofagitis quimica. En el esofago de Barrett, el epitelio escamoso esofagico se reemplaza por epitelio columnar metaplasico, con riesgo de adenocarcinoma esofagico.",signosYSintomas:{signos:["Erosiones en esofago distal en endoscopia","Esofago de Barrett: cambio de epitelio en la union esofagogastrica","Estenosis esofagica en ERGE cronica no tratada","Laringitis posterior (faringe roja en exploracion)"],sintomas:["Pirosis (ardor retroesternal): sintoma cardinal","Regurgitacion acida (liquido amargo en la boca)","Disfagia leve (estenosis esofagica en casos avanzados)","Sintomas extraesofagicos: tos cronica nocturna, disfon\xeda, asma exacerbada","Dolor toracico atipico no cardiaco"]},clasificacion:{nombre:"Clasificacion de Los Angeles (endoscopica)",tipos:[{nombre:"Grado A",descripcion:"Erosiones < 5 mm en la mucosa esofagica"},{nombre:"Grado B",descripcion:"Erosiones > 5 mm sin confluencia entre los pliegues mucosos"},{nombre:"Grado C",descripcion:"Erosiones confluentes entre pliegues pero que afectan < 75% de la circunferencia"},{nombre:"Grado D",descripcion:"Erosiones que afectan >= 75% de la circunferencia esofagica"}]},diagnostico:{anamnesis:["Frecuencia y severidad de la pirosis (> 2 veces/semana = ERGE)","Factores desencadenantes: postprandial, decubito, alimentos especificos","Disfagia (indicacion de endoscopia urgente)","Sintomas de alarma: perdida de peso, hemorragia, anemia"],examenFisico:["El examen fisico suele ser normal","Valorar IMC: obesidad como factor principal","Signos de esofagitis severa o complicaciones en casos avanzados"],pruebas:[{nombre:"Endoscopia digestiva alta (EDA)",descripcion:"Evalua la mucosa esofagica, grado de esofagitis y presencia de esofago de Barrett o estenosis. Indicada en sintomas de alarma o falta de respuesta a tratamiento empirico",valoresReferencia:"Clasificacion de Los Angeles en caso de esofagitis; biopsias en el esofago de Barrett",cuidadosEnfermeria:["Ayuno de 8h previo","Via venosa y monitorizacion durante la sedacion","Vigilar post-procedimiento: disfagia, fiebre, dolor abdominal"]},{nombre:"pHmetria esofagica de 24h o impedanciometria",descripcion:"Confirma el diagnostico objetivo de ERGE cuando la endoscopia es normal; cuantifica los episodios de reflujo acido y no acido",valoresReferencia:"Exposicion acida > 4.5% del tiempo total = ERGE patologico",cuidadosEnfermeria:["Insertar sonda nasofaingea con el electrodo y confirmar posicion por Rx","Instruir al paciente en el diario de sintomas durante las 24h","Retirar la sonda al dia siguiente"]},{nombre:"Manometria esofagica de alta resolucion",descripcion:"Mide la presion del EEI y la funcion peristaltica; descarta acalasia antes de cirugia antirreflujo",valoresReferencia:"Presion integrada de relajacion (IRP) > 15 mmHg en acalasia; presion EEI < 10 mmHg en ERGE",cuidadosEnfermeria:["Ayuno de 6h","Lubrificar sonda con gel xilcaina","El estudio dura 30-45 min"]}]},tratamientoMedico:{objetivos:["Aliviar los sintomas y mejorar la calidad de vida","Cicatrizar la esofagitis","Prevenir complicaciones: esofago de Barrett, estenosis, adenocarcinoma"],farmacologico:[{nombre:"Omeprazol (IBP)",grupo:"Inhibidor de la bomba de protones",mecanismo:"Bloquea irreversiblemente la ATPasa H+/K+ de la celula parietal gastrica, reduciendo la secrecion acida en > 90%",dosis:"20-40 mg en ayunas 30 min antes del desayuno; en esofagitis grave 40 mg cada 12h",cuidadosEnfermeria:["Administrar 30-60 min antes del desayuno para maxima eficacia","Uso prolongado: vigilar hipomagnesemia y riesgo de fractura osea","Informar que la pirosis puede reaparecer dias tras la suspension (rebote)"]},{nombre:"Alginato sodico (Gaviscon)",grupo:"Antiacido de barrera",mecanismo:"Forma una balsa viscosa flotante en el estomago que evita fisicamente el reflujo postprandial; util como adyuvante o en ERGE no acida",dosis:"10-20 mL o 2 comprimidos mascados despues de cada comida y al acostarse",cuidadosEnfermeria:["Indicar que se tome despues de las comidas (no antes)","Util para alivio inmediato de la pirosis postprandial","Seguro en embarazo como primera linea"]},{nombre:"Domperidona",grupo:"Procin\xe9tico (antagonista D2 perif\xe9rico)",mecanismo:"Aumenta el tono del EEI y acelera el vaciamiento gastrico, reduciendo el tiempo de contacto del acido con el esofago",dosis:"10 mg 3 veces al dia antes de las comidas",cuidadosEnfermeria:["Vigilar prolongacion del QTc (ECG previo si hay factores de riesgo cardiovascular)","Contraindicado con antifungicos azolicos y macrolidos","Uso limitado a < 4 semanas en ficha tecnica por riesgo cardiaco"]}],noFarmacologico:["Reduccion de peso en pacientes obesos (principal medida modificable)","Elevar la cabecera de la cama 15-20 cm (no solo almohadas)","Evitar comidas 2-3h antes de acostarse","Eliminar alimentos desencadenantes: caf\xe9, alcohol, chocolate, citricos, grasas","Cese del tabaquismo"],quirurgico:["Fundoplicatura de Nissen laparoscopica (envuelve el fondo gastrico alrededor del EEI) en ERGE severa o dependiente de IBP en pacientes jovenes","Tratamiento endoscopico de la estenosis esofagica (dilatacion con balon)"]},cuidadosEnfermeria:{valoracion:["Evaluar frecuencia e intensidad de la pirosis (escala NRS)","Valorar disfagia: progresion, tipo de alimentos que la producen","Registrar habitos diet\xe9ticos y posturales del paciente","Evaluar IMC y peso corporal"],intervenciones:["Administrar IBP 30 min antes del desayuno segun indicacion","Educar sobre medidas posturales: cabecera elevada al dormir","Asesoramiento nutricional: alimentos a evitar","Preparar para endoscopia cuando este indicada"],educacionPaciente:["Explicar la importancia de las medidas higienico-diet\xe9ticas como tratamiento de primera linea","Elevar la cabecera de la cama: uso de cunas bajo las patas de la cama (no solo almohadas)","Evitar cenas copiosas y acostarse inmediatamente tras comer","Cuando consultar: disfagia progresiva, perdida de peso, vomitos con sangre"],monitorizacion:["Sintomas con el tratamiento (pirosis, regurgitacion)","Peso mensual para seguimiento de la reduccion","Si tiene esofago de Barrett: endoscopia de vigilancia segun protocolo (cada 1-3 a\xf1os)"]},npiNanda:[{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva desagradable",caracteristicasDefinitorias:["Pirosis retroesternal","Regurgitacion acida","Dolor postprandial"],factoresRelacionados:["Reflujo de contenido acido al esofago","Disfuncion del esfinter esofagico inferior"]},{codigo:"00002",nombre:"Desequilibrio nutricional: ingesta inferior a las necesidades",definicion:"Ingesta insuficiente por disfagia",caracteristicasDefinitorias:["Evitacion de alimentos por miedo al dolor","Perdida de peso"],factoresRelacionados:["Disfagia por estenosis esofagica en ERGE cronica"]},{codigo:"00078",nombre:"Gestion de salud ineficaz",definicion:"Patron de regulacion del regimen terapeutico inadecuado",caracteristicasDefinitorias:["No cumple medidas higienico-diet\xe9ticas","Abandona el IBP cuando mejoran los sintomas"],factoresRelacionados:["Falta de conocimiento","Complejidad de los cambios de estilo de vida"]}],npiNic:[{codigo:"1080",nombre:"Manejo gastrointestinal",actividades:["Educar sobre modificaciones diet\xe9ticas especificas","Indicar la elevacion de la cabecera del lecho","Administrar IBP 30 min antes del desayuno"]},{codigo:"5510",nombre:"Educacion para la salud",actividades:["Explicar las medidas posturales eficaces (diferencia entre almohada y cuna)","Ense\xf1ar que alimentos evitar con ejemplos practicos","Importancia de la perdida de peso en obesos"]}],npiNoc:[{codigo:"2102",nombre:"Nivel del dolor",indicadores:["Pirosis < 2 episodios/semana","Sin regurgitacion nocturna","Sin disfagia"],escala:"1=Grave, 5=Ningun"},{codigo:"1803",nombre:"Conocimiento del proceso de la enfermedad",indicadores:["Conoce los alimentos a evitar","Practica medidas posturales","Adhiere al tratamiento con IBP"],escala:"1=Ningun conocimiento, 5=Conocimiento extenso"}],complicaciones:["Esofago de Barrett (riesgo de adenocarcinoma)","Estenosis esofagica peptica","Ulcera esofagica con hemorragia","Adenocarcinoma esofagico (sobre Barrett)"],criteriosAlarma:["Disfagia progresiva (solidos a liquidos)","Perdida de peso inexplicada > 5%","Hematemesis o melena","Anemia ferropenica sin otra causa","Odinofagia severa (dolor al tragar)"],emergencyLevel:"leve",relatedPathologyIds:[],isPremium:!0},{id:"pat_peritonitis",nombre:"Peritonitis",bodySystemId:"digestivo",definicion:"Inflamacion del peritoneo, la membrana serosa que tapiza la cavidad abdominal y los organos abdominales, causada generalmente por la presencia de bacterias o contenido intestinal en la cavidad peritoneal. Es una emergencia quirurgica con alta mortalidad.",epidemiologia:"La peritonitis secundaria (perforacion de viscera hueca) tiene una mortalidad del 10-40% dependiendo del tiempo de evolucion. La peritonitis espontanea bacteriana (PBE) en cirrosis tiene una mortalidad hospitalaria del 20-30%.",factoresRiesgo:["Apendicitis aguda perforada (causa mas frecuente de peritonitis secundaria)","Ulcera peptica perforada","Diverticulitis perforada","Obstruccion intestinal con perforacion isquemica","Cirrosis con ascitis (peritonitis bacteriana espontanea)","Cirugia abdominal previa (peritonitis postoperatoria)"],fisiopatologia:"La contaminacion peritoneal por bacteria o contenido intestinal activa una respuesta inflamatoria masiva. Las citoquinas proinflamatorias y la traslocacion bacteriana producen vasodilatacion, aumento de la permeabilidad vascular y secuestro de liquido en el tercer espacio (hasta 6-10 L en 24h). La sepsis peritoneal puede progresar rapidamente a shock septico y fallo multiorganico.",signosYSintomas:{signos:["Rigidez abdominal en tabla (musculo abdominal involuntariamente contraido)","Silencio abdominal: ausencia de ruidos intestinales (ileus paralitico)","Signo de Blumberg positivo: dolor a la descompresion brusca","Fiebre alta (38-40 grados)","Taquicardia e hipotension en shock septico","Abdomen en tabla (defensa involuntaria generalizada)"],sintomas:["Dolor abdominal difuso severo de inicio brusco (perforacion) o progresivo","Nauseas y vomitos","Incapacidad para moverse sin empeorar el dolor","Fiebre con escalofrios intensos","Agitacion o confusion en shock septico avanzado"]},clasificacion:{nombre:"Clasificacion por origen",tipos:[{nombre:"Peritonitis primaria (PBE)",descripcion:"Sin perforacion de viscera; tipica en cirrosis con ascitis; germenes: E. coli, Klebsiella"},{nombre:"Peritonitis secundaria",descripcion:"Por perforacion de viscera hueca (apendicitis, ulcera, diverticulo); flora mixta polimicrobiana"},{nombre:"Peritonitis terciaria",descripcion:"Persistente o recurrente tras cirugia; germenes oportunistas: Candida, Pseudomonas; alta mortalidad"}]},diagnostico:{anamnesis:["Inicio y localizacion del dolor: brusco en perforacion, gradual en peritonitis secundaria a proceso inflamatorio","Antecedentes de ulcera peptica, diverticulitis, apendicitis o cirrosis","Cirugia abdominal previa","Uso de AINEs o corticoides (pueden enmascarar sintomas)"],examenFisico:["Abdomen en tabla: rigidez involuntaria difusa","Signo de Blumberg positivo","Ausencia de peristaltismo (silencio abdominal)","Signos vitales: fiebre, taquicardia, hipotension"],pruebas:[{nombre:"Radiografia de abdomen en bipedestacion",descripcion:"Detecta neumoperitoneo: aire libre bajo el diafragma que indica perforacion de viscera hueca",valoresReferencia:"Presencia de aire subfrenic = perforacion confirmada; ausencia no descarta",cuidadosEnfermeria:["Realizar en bipedestacion si el paciente puede","Si no puede: decubito lateral izquierdo durante 10 min","Resultado urgente en minutos"]},{nombre:"TC abdominal con contraste (urgente)",descripcion:"Confirma el diagnostico, localiza el origen de la perforacion, detecta abscesos y cuantifica el derrame libre",valoresReferencia:"Neumoperitoneo, liquido libre, engrosamiento peritoneal, coleccion purulenta",cuidadosEnfermeria:["Urgente: no demorar la cirugia por la TC en paciente inestable","Verificar funcion renal para contraste","Monitorizar durante el traslado"]},{nombre:"Paracentesis diagnostica con recuento celular (en PBE)",descripcion:"En cirrosis con ascitis: PMN > 250 celulas/mL confirma PBE; se toma cultivo del liquido",valoresReferencia:"PMN > 250/mL en ascitis = PBE diagnostica; iniciar antibiotico sin esperar cultivo",cuidadosEnfermeria:["Posicionar en decubito supino o semisedestacion","Marcar el sitio con ecografia (FII preferiblemente)","Enviar urgente al laboratorio el liquido peritoneal"]}]},tratamientoMedico:{objetivos:["Control del foco de infeccion mediante cirugia (peritonitis secundaria)","Antibioticoterapia de amplio espectro urgente","Resucitacion hemodin\xe1mica del shock septico","Prevencion y tratamiento del fallo multiorganico"],farmacologico:[{nombre:"Piperacilina-tazobactam",grupo:"Betalactamico de amplio espectro con inhibidor de betalactamasa",mecanismo:"Cubre germenes gramnegativos ent\xe9ricos, anaerobios y Staphylococcus causantes de peritonitis secundaria",dosis:"4.5 g IV cada 6-8h (administrar en 3-4h para maxima eficacia PK/PD)",cuidadosEnfermeria:["Administrar la primera dosis antes de la cirugia (profilaxis preseptica)","Infundir en 3-4h para optimizar el tiempo sobre la CMI","Controlar funcion renal y electrolitos"]},{nombre:"Cefazolina + Metronidazol (alternativa)",grupo:"Cefalosporina de 1ra generacion + antianaer?bico",mecanismo:"Cefazolina cubre gram positivos y algunas enterobacterias; metronidazol cubre anaerobios como Bacteroides fragilis",dosis:"Cefazolina 1-2 g IV cada 8h + Metronidazol 500 mg IV cada 8h",cuidadosEnfermeria:["Administrar la primera dosis antes de la cirugia","Metronidazol: infundir lentamente en 30-60 min","Vigilar interaccion del metronidazol con alcohol"]},{nombre:"Noradrenalina (en shock septico)",grupo:"Vasopresor de primera linea en shock septico",mecanismo:"Vasoconstriccion alfa que restaura la presion de perfusion organica en el shock distributivo septico",dosis:"0.1-3 mcg/kg/min en infusion continua IV central titulada por PAM > 65 mmHg",cuidadosEnfermeria:["Via central obligatoria","Monitorizar PA invasiva de forma continua con linea arterial","Objetivo: PAM > 65 mmHg","Vigilar perfusion distal: extremidades calientes es buen signo"]}],noFarmacologico:["Resucitacion con cristaloides: 30 mL/kg en las primeras 3h de sepsis grave","Sonda nasogastrica para descompresion gastrica y evitar broncoaspiracion","Sonda vesical para medicion de diuresis horaria","Oxigenoterapia o ventilacion mecanica si shock severo"],quirurgico:["Laparotomia exploradora urgente con cierre del foco de perforacion","Colostomia de Hartmann en perforacion colica con peritonitis fecal","Lavado y drenaje peritoneal intraoperatorio","Segunda cirugia (second look) a las 48-72h en casos severos"]},cuidadosEnfermeria:{valoracion:["Evaluar el abdomen en cada turno: rigidez, Blumberg, ruidos intestinales","Monitorizar temperatura, FC, PA y FR cada hora en sepsis","Medir diuresis horaria (objetivo > 0.5 mL/kg/h)","Evaluar nivel de consciencia: la confusion indica hipoperfusion cerebral"],intervenciones:["Preparacion urgente para cirugia: consentimiento, rasurado, via venosa de gran calibre","Administrar antibioticos IV dentro de la primera hora del diagnostico de sepsis","Resucitacion hemodin\xe1mica agresiva con cristaloides IV","Colocar sonda nasogastrica y vesical urgente","Monitorizar parametros de perfusion: lactato, diuresis, nivel de consciencia"],educacionPaciente:["Dado el estado critico, la educacion es principalmente dirigida a la familia","Informar a la familia sobre la gravedad, el procedimiento quirurgico urgente y el postoperatorio esperado","Explicar el postoperatorio en UCI si es necesario"],monitorizacion:["Signos vitales cada hora en shock","Diuresis horaria","Lactato arterial cada 2-4h","Signos abdominales en cada turno","Hemograma y PCR diarios"]},npiNanda:[{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva desagradable de gran intensidad",caracteristicasDefinitorias:["Abdomen en tabla","Signo de Blumberg positivo","Taquicardia","Expresion facial de dolor severo"],factoresRelacionados:["Inflamacion peritoneal generalizada por contenido s\xe9ptico"]},{codigo:"00029",nombre:"Disminucion del gasto cardiaco",definicion:"Cantidad insuficiente de sangre bombeada por el corazon",caracteristicasDefinitorias:["Hipotension","Taquicardia","Oliguria","Extremidades frias"],factoresRelacionados:["Shock septico por peritonitis bacteriana"]},{codigo:"00004",nombre:"Riesgo de infeccion diseminada",definicion:"Riesgo de sepsis grave y bacteriemia secundaria",caracteristicasDefinitorias:["Foco s\xe9ptico abdominal","Bacteriemia documentada o probable"],factoresRelacionados:["Perforacion de viscera hueca con contaminacion peritoneal masiva"]}],npiNic:[{codigo:"6654",nombre:"Vigilancia de la seguridad",actividades:["Monitorizar signos de shock septico: hipotension, taquicardia, oliguria","Evaluar abdomen en cada turno","Documentar evolucion del dolor abdominal"]},{codigo:"4250",nombre:"Manejo del shock septico",actividades:["Administrar cristaloides 30 mL/kg en la primera hora","Iniciar antibioticos en < 1h del diagnostico","Titular vasopresores para PAM > 65 mmHg"]},{codigo:"2900",nombre:"Asistencia quirurgica",actividades:["Preparar al paciente para cirugia urgente","Documentar medicacion administrada","Monitorizar continuamente durante el traslado a quirofano"]}],npiNoc:[{codigo:"0400",nombre:"Efectividad de la bomba cardiaca",indicadores:["PAM > 65 mmHg","Diuresis > 0.5 mL/kg/h","Lactato en descenso"],escala:"1=Desviacion grave, 5=Sin desviacion"},{codigo:"0703",nombre:"Severidad de la infeccion",indicadores:["Temperatura normalizada a las 48-72h","PCR en descenso","Sin signos de fallo multiorganico"],escala:"1=Grave, 5=Ninguna"}],complicaciones:["Shock septico con fallo multiorganico","Absceso intraabdominal residual post-cirugia","Fistula enterocutanea","Ileus paralitico prolongado","Sindrome abdominal compartimental"],criteriosAlarma:["Hipotension PA sistolica < 90 mmHg (shock septico)","Abdomen en tabla de inicio brusco (perforacion libre)","Oliguria o anuria a pesar de resucitacion","Lactato > 4 mmol/L (hipoperfusion severa)","Deterioro del nivel de consciencia"],emergencyLevel:"critico",relatedPathologyIds:["pat_sepsis","pat_diverticulitis"],isPremium:!0},{id:"pat_cushing",nombre:"Sindrome de Cushing",bodySystemId:"endocrino",definicion:"Conjunto de signos y sintomas producidos por la exposicion prolongada y excesiva al cortisol, ya sea de origen exogeno (uso cronico de corticoides) o endogeno (hipercortisolismo ACTH-dependiente o independiente).",epidemiologia:"El Cushing endogeno tiene una incidencia de 2-3 casos por millon/ano. La causa mas frecuente del endogeno es la enfermedad de Cushing (adenoma hipofisario productor de ACTH, 70%). El Cushing exogeno (iatrogeno) es mucho mas frecuente por el uso generalizado de corticoides.",factoresRiesgo:["Uso cronico de corticoides sistemicos (causa mas frecuente global)","Adenoma hipofisario productor de ACTH (enfermedad de Cushing)","Tumor suprarrenal (adenoma o carcinoma adrenocortical)","Produccion ectopica de ACTH (carcinoma pulmonar de celulas pequenas, carcinoide)"],fisiopatologia:"El exceso de cortisol produce efectos catab\xf3licos: movilizacion de proteinas musculares y oseas, redistribucion central de la grasa (visceral, facial, interescapular), hiperglucemia por resistencia a la insulina. El cortisol actua como mineralocorticoide en exceso produciendo hipertension arterial e hipopotasemia. La supresion del eje hipotalamo-hipofisario-suprarrenal produce atrofia suprarrenal bilateral en el Cushing exogeno.",signosYSintomas:{signos:["Obesity central con redistribucion facial: cara de luna llena","Joroba dorsal (giba de bisonte) por acumulacion de grasa interescapular","Estrias violaceas anchas (> 1 cm) en abdomen y muslos","Atrofia muscular proximal (debilidad para levantarse de una silla)","Hirsutismo y acne en mujeres","Pletora facial","Hematomas faciles con minimos traumatismos","HTA en el 80%"],sintomas:["Aumento de peso con preferencia central","Debilidad muscular proximal severa","Cambios del animo: depresion, labilidad emocional, insomnio","Oligomenorrea o amenorrea","Polidipsia y poliuria en diabetes corticoidea","Cefalea","Disfuncion sexual"]},clasificacion:{nombre:"Clasificacion por origen del hipercortisolismo",tipos:[{nombre:"Cushing exogeno (iatrogeno)",descripcion:"Por administracion cronica de corticoides; ACTH suprimida"},{nombre:"Enfermedad de Cushing",descripcion:"Adenoma hipofisario productor de ACTH (70% del Cushing endogeno); ACTH elevada"},{nombre:"Tumor suprarrenal",descripcion:"Adenoma o carcinoma adrenocortical productor de cortisol; ACTH suprimida"},{nombre:"Cushing ectopico",descripcion:"Produccion de ACTH por tumor no hipofisario (pulmon, pancreas); ACTH muy elevada; hipopotasemia severa"}]},diagnostico:{anamnesis:["Historia detallada de uso de corticoides (via y dosis)","Tiempo de evolucion de los sintomas caracteristicos","Antecedentes familiares de tumores endocrinos (NEM1)","Sintomas de compresion tumoral: cefalea, alteraciones visuales (adenoma hipofisario)"],examenFisico:["Peso, talla, IMC, PA","Inspeccion: redistribucion grasa, estrias, hematomas, atrofia muscular","Fuerza proximal: prueba de levantarse de la silla sin apoyar los brazos","Campos visuales: hemianopsia bitemporal en macroadenoma hipofisario"],pruebas:[{nombre:"Cortisol libre en orina de 24h",descripcion:"Primer screening: mide la excrecion total de cortisol libre en 24h; positivo si > 3-4 veces el limite superior normal en dos muestras",valoresReferencia:"Normal < 50 mcg/24h (varia segun laboratorio)",cuidadosEnfermeria:["Instruccion detallada para la recoleccion correcta de orina de 24h","Conservar en recipiente de acido o refrigerado segun laboratorio","Descartar la primera miccion del dia"]},{nombre:"Test de supresion con dexametasona 1 mg (nocturno)",descripcion:"Screening: 1 mg de dexametasona oral a las 23h; cortisol plasmatico a las 8h; falta de supresion < 1.8 mcg/dL es positivo",valoresReferencia:"Cortisol post-dexametasona > 1.8 mcg/dL = test positivo (hipercortisolismo)",cuidadosEnfermeria:["Asegurarse de que el paciente tome el comprimido de dexametasona exactamente a las 23h","Extraer la muestra de cortisol a las 8-9h del dia siguiente en ayunas","Registrar si el paciente tomo farmacos que alteran el metabolismo de la dexametasona"]},{nombre:"ACTH plasmatica basale",descripcion:"Diferencia el Cushing ACTH-dependiente (elevado: hipofisario o ectopico) del independiente (suprimido: suprarrenal)",valoresReferencia:"Normal 10-50 pg/mL; < 5 sugiere origen suprarrenal; > 100 sugiere ectopico",cuidadosEnfermeria:["Extraer muestra en EDTA en hielo","Enviar urgente al laboratorio en hielo (la ACTH es inestable)","Extraer a las 8-9h (pico circadiano)"]},{nombre:"RMN hipofisaria con gadolinio",descripcion:"Detecta adenoma hipofisario en enfermedad de Cushing; puede ser microadenoma < 6 mm (50% de los casos)",valoresReferencia:"Lesion hipointensa en T1 con realce tardio o ausente de gadolinio",cuidadosEnfermeria:["Verificar contraindicaciones para gadolinio: funcion renal, marcapasos","Informar sobre la duracion del estudio (30-45 min)"]}]},tratamientoMedico:{objetivos:["Normalizar el cortisol y sus efectos sistemicos","Tratar la causa subyacente","Prevenir y tratar complicaciones (DM, osteoporosis, infecciones, HTA)"],farmacologico:[{nombre:"Ketoconazol",grupo:"Inhibidor de la esteroidogenesis suprarrenal",mecanismo:"Inhibe multiples enzimas del paso de colesterol a cortisol en la suprarrenal; tratamiento medico de segunda linea o preoperatorio",dosis:"200-400 mg cada 8-12h, titulando por niveles de cortisol",cuidadosEnfermeria:["Hepatotoxicidad: control de transaminasas mensual","Vigilar insuficiencia suprarrenal: nauseas, hipotension, hipoglucemia","Puede interaccionar con muchos farmacos (inhibidor potente de CYP3A4)"]},{nombre:"Metirapona",grupo:"Inhibidor de la 11-beta-hidroxilasa",mecanismo:"Bloquea el paso final de la sintesis de cortisol; alternativa al ketoconazol; rapido inicio de accion",dosis:"500-6000 mg/dia en 3-4 tomas",cuidadosEnfermeria:["Monitorizar cortisol y ACTH periodicamente para ajustar dosis","Vigilar exceso de androgenos (hirsutismo, acne) y mineralocorticoides (edemas, hipertension, hipopotasemia)","Puede empeorar la hipertension en algunos pacientes"]},{nombre:"Hidrocortisona (reemplazo post-cirugia)",grupo:"Corticosteroide de reemplazo",mecanismo:"Sustituye el cortisol endogeno tras la suprarrenalectomia o la hipofisectomia; la suprarrenal atrofiada no produce cortisol en los primeros meses",dosis:"15-25 mg/dia en 2-3 tomas: mayor dosis matutina (simulando el perfil circadiano)",cuidadosEnfermeria:["Educar sobre la necesidad de aumentar la dosis en situaciones de estres (regla del doble o triple)","Ense\xf1ar signos de crisis suprarrenal: hipotension, hipoglucemia, vomitos","El paciente debe llevar siempre tarjeta de identificacion de tratamiento corticoide"]}],noFarmacologico:["Control estricto de PA, glucemia y densidad mineral osea","Calcio 1000-1200 mg/dia y vitamina D 800 UI/dia para osteoporosis corticoidea","Actividad fisica para combatir la atrofia muscular y la obesidad","Apoyo psicologico por la afectacion del animo y la imagen corporal"],quirurgico:["Adenomectomia transesfenoidal (cirugia de primera eleccion en enfermedad de Cushing: curacion 70-90%)","Suprarrenalectomia unilateral en adenoma suprarrenal","Suprarrenalectomia bilateral en Cushing suprarrenal bilateral o ectopico sin tumor localizable","Radioterapia hipofisaria si falla la cirugia"]},cuidadosEnfermeria:{valoracion:["Monitorizar PA en cada turno (HTA severa frecuente)","Controlar glucemia en ayunas y postprandial (diabetes corticoidea)","Evaluar fuerza muscular proximal: levantarse de la silla","Evaluar integridad cutanea: estrias, hematomas, heridas que no cicatrizan"],intervenciones:["Administrar antihipertensivos e hipoglucemiantes segun indicacion","Cuidado especial de la piel (fragilidad cutanea por cortisol)","Prevencion de caidas por debilidad muscular y osteoporosis","Soporte emocional por cambios en la imagen corporal y alteraciones del animo","Educacion sobre el tratamiento de reemplazo post-cirugia"],educacionPaciente:["Explicar que la reduccion del cortisol tarda semanas en producir mejoria de los sintomas","Instruccion sobre la regla del doble o triple de hidrocortisona en situaciones de estres fisico","Siempre llevar tarjeta de alerta medica: paciente con insuficiencia suprarrenal en tratamiento","Cuando consultar urgencias: vomitos con incapacidad de tomar la medicacion oral, hipotension, fiebre alta"],monitorizacion:["PA cada 8h","Glucemia ayunas y 2h post-prandial","Cortisol libre en orina para seguimiento de la respuesta al tratamiento","Densitometria osea (DEXA) al diagnostico y anual"]},npiNanda:[{codigo:"00069",nombre:"Afrontamiento ineficaz",definicion:"Incapacidad para formular una apreciacion valida de los agentes estresantes",caracteristicasDefinitorias:["Cambios en la imagen corporal","Labilidad emocional","Depresion"],factoresRelacionados:["Alteracion de la imagen corporal por hipercortisolismo","Efectos del cortisol sobre el sistema limbico"]},{codigo:"00029",nombre:"Disminucion del gasto cardiaco",definicion:"Gasto cardiaco insuficiente",caracteristicasDefinitorias:["Hipertension arterial severa"],factoresRelacionados:["Efecto mineralocorticoide del cortisol en exceso"]},{codigo:"00047",nombre:"Riesgo de deterioro de la integridad cutanea",definicion:"Riesgo de alteracion de la piel",caracteristicasDefinitorias:["Fragilidad cutanea","Estrias","Hematomas espontaneos"],factoresRelacionados:["Efecto catabolico del cortisol sobre el colageno dermico"]}],npiNic:[{codigo:"2080",nombre:"Manejo del trastorno endocrino",actividades:["Controlar glucemia y PA periodicamente","Administrar farmacos que reducen el cortisol segun prescripcion","Monitorizar transaminasas con ketoconazol"]},{codigo:"3590",nombre:"Vigilancia de la piel",actividades:["Inspeccionar la piel diariamente en busca de hematomas y heridas","Usar ap\xf3sitos atraumaticos al retirar","Evitar venopunciones innecesarias en pacientes con piel muy fragil"]},{codigo:"5270",nombre:"Apoyo emocional",actividades:["Escuchar las preocupaciones sobre cambios en la imagen corporal","Explicar que los cambios fisicos son reversibles con el tratamiento","Derivar a psicologo si hay depresion significativa"]}],npiNoc:[{codigo:"0800",nombre:"Termicidad y metabolismo",indicadores:["Glucemia en objetivo","PA en objetivo < 130/80 mmHg","Cortisol libre en descenso"],escala:"1=Desviacion grave, 5=Sin desviacion"},{codigo:"1200",nombre:"Imagen corporal",indicadores:["Acepta los cambios fisicos como temporales","Mantiene las relaciones sociales","Expresa adaptacion positiva"],escala:"1=Nunca positiva, 5=Constantemente positiva"}],complicaciones:["Diabetes mellitus corticoidea","Osteoporosis con fracturas por fragilidad","Infecciones oportunistas (Pneumocystis, aspergillus)","Trombosis venosa profunda y embolia pulmonar","Insuficiencia suprarrenal aguda post-cirugia"],criteriosAlarma:["Hipotension + nauseas + hipoglucemia post-cirugia (crisis suprarrenal: corticoide IV urgente)","Fractura vertebral o de cadera (osteoporosis)","Infeccion grave de curso atipico (inmunosupresion por cortisol)","Deterioro brusco del nivel de consciencia"],emergencyLevel:"moderado",relatedPathologyIds:["pat_hta","pat_dm2"],isPremium:!0},{id:"pat_feocromocitoma",nombre:"Feocromocitoma",bodySystemId:"endocrino",definicion:"Tumor neuroendocrino que se origina en las celulas cromafines de la medula suprarrenal (feocromocitoma) o en los ganglios simpaticos extraadrenales (paraganglioma), con capacidad de secretar catecolaminas (adrenalina, noradrenalina, dopamina) produciendo una constelacion de sintomas cardiovasculares graves.",epidemiologia:"Incidencia de 2-8 casos por millon/ano. El 10% es bilateral, el 10% es maligno, el 10% es extraadrenal (regla del 10%). El 30-40% es hereditario (mutaciones VHL, RET, NF1, SDHB). Es una causa tratable de hipertension arterial secundaria.",factoresRiesgo:["Neoplasia endocrina multiple tipo 2 (NEM2): mutacion RET","Enfermedad de Von Hippel-Lindau: mutacion VHL","Neurofibromatosis tipo 1: mutacion NF1","Sindrome de paraganglioma familiar: mutaciones SDH"],fisiopatologia:"La liberacion episodica o continua de catecolaminas produce activacion excesiva de los receptores adrenergicos alfa (vasoconstriccion, HTA, midriasis) y beta (taquicardia, arritmias, sudoracion). La estimulacion alfa produce vasoconstriccion periferica intensa con HTA paroxistica. La elevacion de catecolaminas puede producir miocardiopatia de estres (Takotsubo) e incluso hemorragia cerebral.",signosYSintomas:{signos:["Hipertension arterial severa: paroxistica (50%) o sostenida (50%)","Hipertension resistente a multiples farmacos","Taquicardia o arritmias durante las crisis","Palidez cutanea durante las crisis (vasoconstriccion alfa)","Midriasis durante las crisis"],sintomas:["Triada clasica: cefalea severa + sudoracion profusa + palpitaciones (especificidad 90%)","HTA paroxistica con inicio y fin bruscos (minutos a horas)","Ansiedad intensa o sensacion de muerte inminente durante la crisis","Palidez o rubor alternantes","Dolor precordial","Temblor de manos"]},clasificacion:{nombre:"Clasificacion por localizacion",tipos:[{nombre:"Feocromocitoma adrenal unilateral",descripcion:"Medula suprarrenal; 90% de los casos; 10% bilateral; suprarrenalectomia laparoscopica"},{nombre:"Paraganglioma extraadrenal",descripcion:"Ganglios simpaticos paravertebrales, organo de Zuckerkandl; 10% de los casos; mayor riesgo de malignidad"},{nombre:"Maligno (metastatico)",descripcion:"10% de los feocromocitomas; metastasis en hueso, higado, pulmon; asociado a mutaciones SDHB"}]},diagnostico:{anamnesis:["Triada: cefalea + sudoracion + palpitaciones (especialmente paroxistica con HTA severa)","Historia familiar de feocromocitoma u otras neoplasias endocrinas","Factores desencadenantes de las crisis: ejercicio, maniobras de Valsalva, anestesia, ciertos farmacos (opioides, metoclopramida)","Antecedente de HTA resistente o crisis hipertensivas graves"],examenFisico:["Medicion de PA en crisis y en reposo","Evaluacion cardiologica (arritmias, miocardiopatia)","Examen de abdomen: masa palpable en tumor grande","Busqueda de estigmas de sindromes hereditarios: manchas cafe con leche, hemangioblastomas oculares"],pruebas:[{nombre:"Metanefrinas fraccionadas en plasma o en orina de 24h",descripcion:"Test bioquimico de eleccion: las metanefrinas son metabolitos estables de las catecolaminas con alta sensibilidad",valoresReferencia:"Metanefrina plasmatica > 0.5 nmol/L o normetanefrina > 1 nmol/L = altamente sugestivo",cuidadosEnfermeria:["Orina de 24h: conservar con HCl en recipiente especial y refrigerado","Para plasma: extraer en decubito supino tras 30 min de reposo","Evitar farmacos que interfieren: antidepresivos, levodopa, labetalol 48-72h antes"]},{nombre:"TC o RMN de abdomen y pelvis",descripcion:"Localiza el tumor tras confirmacion bioquimica; la RMN es de eleccion en tumores extraadrenales o hereditarios",valoresReferencia:"Feocromocitoma: masa adrenal > 3 cm con alta captacion en T2 en RMN",cuidadosEnfermeria:["Verificar funcion renal para contraste yodado (TC)","Informar sobre duracion del estudio","El paciente DEBE estar bloqueado alfa antes del TC con contraste (contaste puede desencadenar crisis)"]},{nombre:"Gammagrafia con MIBG (metayodobencilguanidina)",descripcion:"Localiza feocromocitoma/paraganglioma con alta especificidad; util en tumores multiples o enfermedad metastatica",valoresReferencia:"Captacion positiva en el tumor confirma la naturaleza cromafin",cuidadosEnfermeria:["Bloqueo tiroideo previo con yodo lugol o perclorato para proteger la tiroides del I-131","Verificar que el paciente no tome farmacos que interfieren con la captacion de MIBG: labetalol, antidepresivos triciclicos, calcioantagonistas"]}]},tratamientoMedico:{objetivos:["Bloqueo farmacologico completo antes de la cirugia para prevenir crisis hipertensiva intraoperatoria","Cirugia curativa (suprarrenalectomia laparoscopica)","Vigilancia genetica y seguimiento a largo plazo"],farmacologico:[{nombre:"Fenoxibenzamina",grupo:"Bloqueante alfa-adrenergico no selectivo irreversible",mecanismo:"Bloqueo alfa permanente que previene la vasoconstriccion catecolaminica; preparacion preoperatoria obligatoria durante 10-14 dias",dosis:"10 mg cada 12h aumentando cada 2-3 dias hasta alcanzar el bloqueo (PA < 130/80, hipotension ortost\xe1tica leve)",cuidadosEnfermeria:["Monitorizar PA en bipedestacion: hipotension ortost\xe1tica es signo de bloqueo correcto","Advertir al paciente sobre hipotension al levantarse: levantarse despacio","El paciente puede requerir expansion de volumen (hidratacion generosa) por vasodilatacion"]},{nombre:"Doxazosina",grupo:"Bloqueante alfa-1 selectivo",mecanismo:"Alternativa a la fenoxibenzamina; mas selectivo y mejor tolerado; usado en la preparacion preoperatoria",dosis:"2-16 mg/dia en 1-2 tomas",cuidadosEnfermeria:["Iniciar con dosis baja (2 mg) y titular","Primera dosis en la noche para reducir hipotension ortost\xe1tica","Monitorizar PA en cada turno durante la titulacion"]},{nombre:"Propranolol (SOLO tras el bloqueo alfa)",grupo:"Betabloqueante no selectivo",mecanismo:"Controla la taquicardia y las arritmias tras el bloqueo alfa; NUNCA iniciar sin alfa-bloqueante previo",dosis:"20-40 mg cada 8h, inicio solo tras 3-7 dias de bloqueo alfa completo",cuidadosEnfermeria:["CONTRAINDICADO como primer farmaco: puede producir crisis hipertensiva paradojica por bloqueo beta con alfa libre","Iniciar solo cuando el bloqueo alfa este establecido","Vigilar broncoespasmo en asmaticos"]}],noFarmacologico:["Dieta rica en sodio y alta ingesta de liquidos durante el bloqueo alfa (compensa la vasodilatacion)","Evitar factores desencadenantes de crisis: esfuerzo fisico, maniobras de Valsalva, ciertos farmacos","Screening genetico y de la familia en casos hereditarios"],quirurgico:["Suprarrenalectomia laparoscopica (primera eleccion en feocromocitoma adrenal unilateral)","Cirugia abierta en tumores grandes > 6-8 cm o con invasion local","Radioembolizacion o MIBG terapeutico en enfermedad metastatica"]},cuidadosEnfermeria:{valoracion:["Monitorizar PA de forma continua o cada 30-60 min en preparacion preoperatoria","Evaluar la PA en bipedestacion (hipotension ortost\xe1tica deseada como signo de bloqueo alfa eficaz)","Registrar los episodios de crisis: inicio, duracion, PA, sintomas","Monitorizar FC y ritmo cardiaco: taquicardia y arritmias"],intervenciones:["Administrar alfa-bloqueantes segun horario exacto para mantener el bloqueo continuo","Mantener acceso venoso de gran calibre por riesgo de crisis intraoperatoria","Evitar cualquier medicacion que pueda desencadenar una crisis (metoclopramida, droperidol, morfina IV rapida)","Preparar nitroprusato sodico o nicardipino IV para crisis hipertensiva perioperatoria","En crisis hipertensiva: nitroprusato IV o phentolamine IV inmediatos"],educacionPaciente:["Explicar la importancia del bloqueo alfa preoperatorio: sin el, la cirugia es de muy alto riesgo","Educar sobre el reconocimiento de las crisis","Instruir para evitar desencadenantes","En casos hereditarios: importancia del seguimiento genetico de la familia"],monitorizacion:["PA continua o cada 30 min en perioperatorio","ECG continuo en la induccion anestesica y la cirugia","PA postoperatoria: hipotension frecuente tras extirpacion del tumor","Glucemia: hipoglucemia reactiva post-tumor por rebote insulinico"]},npiNanda:[{codigo:"00233",nombre:"Riesgo de presion arterial inestable",definicion:"Riesgo de cambios en las fuerzas de la sangre que pueden comprometer la salud",caracteristicasDefinitorias:["Episodios de HTA paroxistica severa","Variabilidad de PA entre crisis"],factoresRelacionados:["Secrecion episodica de catecolaminas por el tumor"]},{codigo:"00146",nombre:"Ansiedad",definicion:"Vaga sensacion de malestar o amenaza con respuesta autonoma",caracteristicasDefinitorias:["Ansiedad durante las crisis","Sensacion de muerte inminente"],factoresRelacionados:["Liberacion masiva de adrenalina y noradrenalina"]},{codigo:"00004",nombre:"Riesgo de infeccion",definicion:"Riesgo de infeccion postquirurgica",caracteristicasDefinitorias:["Intervencion quirurgica suprarrenal"],factoresRelacionados:["Suprarrenalectomia laparoscopica"]}],npiNic:[{codigo:"4162",nombre:"Manejo de la hipertension",actividades:["Monitorizar PA continua en preparacion preoperatoria","Administrar alfa-bloqueantes segun horario","Tener farmacos de rescate IV preparados (nitroprusato)","Instruir al paciente en reconocimiento de crisis"]},{codigo:"4040",nombre:"Cuidados cardiacos",actividades:["Monitorizar ECG continuo en perioperatorio","Detectar taquicardia y arritmias","Administrar betabloqueantes solo tras alfa-bloqueo establecido"]},{codigo:"5820",nombre:"Disminucion de la ansiedad",actividades:["Explicar que las crisis son producto del tumor y son tratables","Ense\xf1ar tecnicas de relajacion durante las crisis leves","Asegurar que el equipo esta preparado para manejar una crisis"]}],npiNoc:[{codigo:"0401",nombre:"Estado circulatorio",indicadores:["PA < 130/80 mmHg en reposo con alfa-bloqueante","FC < 90 lpm","Sin episodios de crisis hipertensiva en el postoperatorio"],escala:"1=Desviacion grave, 5=Sin desviacion"},{codigo:"1302",nombre:"Afrontamiento de problemas",indicadores:["Adhiere al bloqueo alfa preoperatorio","Evita los desencadenantes conocidos","Consulta precozmente en episodios de crisis"],escala:"1=Nunca demostrado, 5=Constantemente demostrado"}],complicaciones:["Crisis hipertensiva intraoperatoria (mortal sin bloqueo alfa previo)","Miocardiopatia de estres (Takotsubo) inducida por catecolaminas","Hemorragia o infarto cerebral durante la crisis","Hipotension postoperatoria severa","Recurrencia o malignizacion en casos hereditarios"],criteriosAlarma:["Crisis hipertensiva PA > 200/120 mmHg con cefalea severa y sudoracion profusa","Arritmia ventricular maligna en el contexto de una crisis","Dolor toracico con cambios isquemicos en ECG (miocardiopatia de estres)","Hemorragia intratumoral espontanea"],emergencyLevel:"critico",relatedPathologyIds:["pat_hta"],isPremium:!0},{id:"pat_hipopituitarismo",nombre:"Hipopituitarismo",bodySystemId:"endocrino",definicion:"Deficiencia de una o mas hormonas de la hipofisis anterior (GH, LH, FSH, TSH, ACTH, PRL) o posterior (ADH, oxitocina), que produce insuficiencia de las glandulas diana perifericas y sus consecuencias clinicas.",epidemiologia:"Prevalencia de 45 casos por 100.000 habitantes. La causa mas frecuente en adultos es el adenoma hipofisario (con o sin cirugia previa). La deficiencia de ACTH es la mas peligrosa por riesgo de crisis suprarrenal.",factoresRiesgo:["Adenoma hipofisario (macro o microadenoma; causa mas frecuente en adultos)","Cirugia hipofisaria o radioterapia craneal","Traumatismo craneoencefalico grave","Sindrome de Sheehan (necrosis hipofisaria postparto por hemorragia)","Craneofaringioma (causa mas frecuente en ni\xf1os)","Infiltracion por sarcoidosis, histiocitosis, hemocromatosis","Apoplejia hipofisaria (infarto o hemorragia en un adenoma)"],fisiopatologia:"La hipofisis anterior produce hormonas tropoicas bajo control hipotalamica. La lesion o la compresion de las celulas hipofisarias produce deficiencias hormonales en un orden tipico de aparicion: GH y FSH/LH se pierden primero (90%); TSH y ACTH mas tarde (60-80%); PRL y ADH raramente se pierden en el hipopituitarismo parcial. La deficiencia de ACTH produce insuficiencia suprarrenal secundaria (sin hiperpigmentacion ni hiperaldosteronismo a diferencia de la primaria).",signosYSintomas:{signos:["Palidez cutanea (deficiencia de MSH por ACTH baja)","Perdida de vello pubico y axilar (deficiencia de FSH/LH)","Atrofia testicular u oovarica","Hipotension arterial (insuficiencia suprarrenal secundaria)","Bradicardia y piel seca (hipotiroidismo secundario)","Galactorrea si hay lesion del tallo hipofisario (PRL elevada paradojicamente)"],sintomas:["Fatiga severa y debilidad (insuficiencia suprarrenal secundaria)","Intolerancia al frio y estrenimineto (hipotiroidismo secundario)","Perdida de la libido e impotencia o amenorrea (deficiencia de LH/FSH)","Retardo del crecimiento en ni\xf1os (deficiencia de GH)","Poliuria y polidipsia si hay deficiencia de ADH (diabetes insipida)","Cefalea y alteraciones visuales en adenoma hipofisario"]},clasificacion:{nombre:"Clasificacion por deficiencias hormonales",tipos:[{nombre:"Panhipopituitarismo",descripcion:"Deficiencia de todas las hormonas hipofisarias anteriores; por lo general por lesion extensa"},{nombre:"Hipopituitarismo parcial",descripcion:"Deficiencia de 1-2 ejes; mas frecuente; GH y gonadotropinas se pierden primero"},{nombre:"Insuficiencia suprarrenal secundaria",descripcion:"Deficiencia de ACTH aislada o en hipopituitarismo; sin hiperpigmentacion; la mas peligrosa"},{nombre:"Hipotiroidismo central",descripcion:"Deficiencia de TSH; TSH normal o baja con T4 libre baja; no se diagnostica solo con TSH"}]},diagnostico:{anamnesis:["Historia de cirugia hipofisaria, radioterapia craneal o TCC grave","Parto complicado con hemorragia (Sheehan)","Sintomas de deficiencias hormonales especificas","Cefalea o alteraciones visuales (tumor hipofisario)"],examenFisico:["Evaluacion de caracteres sexuales secundarios","Inspeccion de la piel: palidez, vello pubico y axilar","Campos visuales por confrontacion (hemianopsia bitemporal)","PA y FC: hipotension en insuficiencia suprarrenal"],pruebas:[{nombre:"Perfil hormonal basal completo",descripcion:"TSH + T4 libre; LH + FSH + Estradiol (mujeres) o Testosterona (hombres); ACTH + Cortisol basal; IGF-1 (marcador de GH); Prolactina",valoresReferencia:"Cortisol basal < 3 mcg/dL = insuficiencia suprarrenal probable; TSH baja con T4 libre baja = hipotiroidismo central",cuidadosEnfermeria:["Extraer a las 8-9h de la ma\xf1ana (cortisol y ACTH son pico circadiano)","Muestra de ACTH en hielo urgente al laboratorio","Registrar tratamientos corticoideos previos que alteran los resultados"]},{nombre:"Test de estimulacion con glucagon o hipoglucemia insulinica",descripcion:"Confirma la reserva de GH y de ACTH; el cortisol debe subir > 18 mcg/dL ante el estres hipoglucemico",valoresReferencia:"Cortisol pico > 18 mcg/dL descarta insuficiencia suprarrenal; GH pico > 3 mcg/L descarta deficiencia",cuidadosEnfermeria:["Via venosa permeable y medico presente durante todo el test","Monitorizar glucemia cada 15 min (hipoglucemia de 40 mg/dL es el objetivo)","Tener glucosa al 33% y glucagon disponibles para revertir la hipoglucemia"]},{nombre:"RMN hipofisaria con gadolinio",descripcion:"Define la anatomia hipofisaria, detecta adenomas, sellavacia, inflamacion o compresion del tallo",valoresReferencia:"Sella turcica vacia (empty sella) en formas cronicas; adenoma hipofisario como masa con efecto de masa",cuidadosEnfermeria:["Verificar contraindicaciones para gadolinio","Informar sobre duracion del estudio"]}]},tratamientoMedico:{objetivos:["Reemplazar las hormonas deficientes con hormonas exogenas","Tratar la causa subyacente (adenoma: cirugia o radioterapia)","Prevenir la crisis suprarrenal aguda (la complicacion mas grave)"],farmacologico:[{nombre:"Hidrocortisona (reemplazo de ACTH)",grupo:"Corticosteroide de reemplazo fisiologico",mecanismo:"Sustituye el cortisol endogeno en la insuficiencia suprarrenal secundaria; dosis mas baja que en la primaria",dosis:"15-25 mg/dia: mayor dosis en la ma\xf1ana, menor al mediodia, no dar por la noche",cuidadosEnfermeria:["Educar sobre la regla del doble o triple en situaciones de estres fisico","Siempre llevar tarjeta de alerta medica e inyectable de emergencia (hidrocortisona 100 mg IM)","La insuficiencia suprarrenal nunca debe ser la ultima deficiencia en diagnosticarse o la primera en dejar de tratarse"]},{nombre:"Levotiroxina (reemplazo de TSH)",grupo:"Hormona tiroidea sintetica",mecanismo:"Sustituye T4; en hipopituitarismo, la TSH no es valida para monitorizar la dosis; usar T4 libre como guia",dosis:"1.6 mcg/kg/dia; ajustar por T4 libre (objetivo: tercio superior del rango normal)",cuidadosEnfermeria:["NUNCA iniciar levotiroxina antes de haber reemplazado el cortisol (puede precipitar crisis suprarrenal)","Monitorizar T4 libre (no TSH) en hipopituitarismo","Administrar en ayunas 30 min antes del desayuno"]},{nombre:"Testosterona (reemplazo de LH/FSH en hombres)",grupo:"Androgeno de reemplazo",mecanismo:"Sustituye la testosterona en el hipogonadismo hipogonadotropo masculino",dosis:"Testosterona depot 250 mg IM cada 3-4 semanas o testosterona transd\xe9rmica 50 mg/dia",cuidadosEnfermeria:["Monitorizar testosterona plasmatica (objetivo rango normal medio)","Controlar hematocrito: la testosterona puede producir poliglobulia","PSA anual en hombres > 45 a\xf1os (contraindicada en cancer de prostata activo)"]}],noFarmacologico:["Seguimiento endocrinologico especializado cada 6-12 meses","En mujeres en edad fertil: tratamiento de la infertilidad con gonadotropinas exogenas","Educacion intensa sobre la crisis suprarrenal: como prevenirla y tratarla"],quirurgico:["Adenomectomia transesfenoidal si hay adenoma hipofisario causal (restaura parcialmente la funcion en algunos casos)"]},cuidadosEnfermeria:{valoracion:["Monitorizar PA y FC: la hipotension puede indicar insuficiencia suprarrenal no reemplazada","Evaluar nivel de consciencia: la confusion puede indicar crisis suprarrenal o hipoglucemia","Registrar temperatura: hipotermia en hipotiroidismo central grave","Valorar el nivel de fatiga y la capacidad funcional"],intervenciones:["Administrar hidrocortisona exactamente en el horario prescrito","En situaciones de estres (cirugia, fiebre > 38.5, vomitos): aplicar la regla del doble y comunicar al medico","En crisis suprarrenal: hidrocortisona 100 mg IV bolo de urgencia","Educar al paciente y la familia sobre la inyeccion de emergencia"],educacionPaciente:["Explicar que el tratamiento de reemplazo es de por vida en la mayoria","La regla del estres: cuando doblar o triplicar la hidrocortisona","Llevar siempre la tarjeta de alerta medica y la ampolla de hidrocortisona IM de emergencia","Cuando acudir urgencias: vomitos que impiden tomar la medicacion oral, hipotension, confusion","El hipotiroidismo central se monitoriza con T4 libre, NO con TSH"],monitorizacion:["Cortisol basal trimestral para ajuste de dosis","T4 libre semestral","Testosterona o estradiol semestral","PA en cada visita","IGF-1 anual si recibe GH"]},npiNanda:[{codigo:"00178",nombre:"Gestion ineficaz de la propia salud",definicion:"Patron de regulacion del regimen terapeutico inadecuado",caracteristicasDefinitorias:["Olvidos en la toma de hidrocortisona","No dobla la dosis en situaciones de estres"],factoresRelacionados:["Complejidad del tratamiento de reemplazo multiple","Falta de conocimiento sobre la crisis suprarrenal"]},{codigo:"00092",nombre:"Intolerancia a la actividad",definicion:"Insuficiencia de energia para completar actividades diarias",caracteristicasDefinitorias:["Fatiga severa","Debilidad muscular"],factoresRelacionados:["Insuficiencia suprarrenal secundaria no compensada","Hipotiroidismo central"]},{codigo:"00029",nombre:"Disminucion del gasto cardiaco",definicion:"Gasto cardiaco insuficiente",caracteristicasDefinitorias:["Hipotension","Bradicardia"],factoresRelacionados:["Insuficiencia suprarrenal secundaria","Hipotiroidismo central"]}],npiNic:[{codigo:"2080",nombre:"Manejo del trastorno endocrino",actividades:["Administrar hormona de reemplazo en horario correcto","Monitorizar signos de insuficiencia suprarrenal (hipotension, nauseas, confusion)","Educar sobre el protocolo de estres"]},{codigo:"6650",nombre:"Vigilancia",actividades:["Detectar signos precoces de crisis suprarrenal","Monitorizar PA, FC y glucemia en situaciones de estres fisico","Registrar cumplimiento de la medicacion en cada turno"]},{codigo:"5510",nombre:"Educacion para la salud",actividades:["Ense\xf1ar la regla del doble en situaciones de estres","Practicar la tecnica de inyeccion de emergencia con el paciente y la familia","Explicar que hormonas monitorizar y como interpretar los resultados"]}],npiNoc:[{codigo:"0800",nombre:"Termicidad y metabolismo",indicadores:["PA estable","FC en rango normal","Sin episodios de crisis suprarrenal","T4 libre en rango normal"],escala:"1=Desviacion grave, 5=Sin desviacion"},{codigo:"1803",nombre:"Conocimiento del proceso de la enfermedad",indicadores:["Explica correctamente la regla del estres","Lleva la tarjeta de alerta medica","Sabe cuando ir a urgencias"],escala:"1=Ningun conocimiento, 5=Conocimiento extenso"}],complicaciones:["Crisis suprarrenal aguda (emergencia vital: hipotension, shock, coma)","Hipoglucemia severa (especialmente en ni\xf1os con deficit de GH)","Complicaciones cardiovasculares del hipotiroidismo central (dislipemia, aterosclerosis)","Osteoporosis por deficit de GH y hormonas sexuales"],criteriosAlarma:["Hipotension + nauseas + confusion (crisis suprarrenal: hidrocortisona 100 mg IV urgente)","Vomitos que impiden la medicacion oral en paciente con insuficiencia suprarrenal (administrar IM)","Hipoglucemia severa < 40 mg/dL","Bradicardia + hipotermia + alteracion del nivel de consciencia (mixedema)"],emergencyLevel:"moderado",relatedPathologyIds:["pat_cushing"],isPremium:!0},{id:"pat_hiperparatiroidismo",nombre:"Hiperparatiroidismo",bodySystemId:"endocrino",definicion:"Exceso de secrecion de hormona paratiroidea (PTH) que produce hipercalcemia y sus consecuencias sistemicas. El hiperparatiroidismo primario (HPTP) es causado por hipersecrecion autonoma de la paratiroides; el secundario por estimulacion reactiva (insuficiencia renal cronica).",epidemiologia:"El HPTP es la causa mas frecuente de hipercalcemia en pacientes ambulatorios. Incidencia de 66 casos por 100.000 habitantes/ano. Predominio en mujeres posmenopaupausicas (3:1). La causa mas frecuente de HPTP es el adenoma unico de paratiroides (85%).",factoresRiesgo:["Sexo femenino posmenopausico","Irradiacion cervical previa","Litio cronico (estimula la PTH)","NEM1 y NEM2A (hiperplasia paratiroidea multiglandular)","Insuficiencia renal cronica (hiperparatiroidismo secundario)","Deficiencia de vitamina D"],fisiopatologia:"La PTH eleva el calcio serico mediante tres mecanismos: 1) resorcion osea (activacion de osteoclastos), 2) reabsorcion tubular renal de calcio, 3) estimulacion de la 1-alfa-hidroxilasa renal que produce calcitriol (aumenta la absorcion intestinal de calcio). La hipercalcemia produce sus efectos en el SNC (confusion, depresion), muscular (debilidad), renal (nefrolitiasis, poliuria), cardiaco (acortamiento del QT) y digestivo (ulcera peptica, pancreatitis).",signosYSintomas:{signos:["Hipercalcemia en analitic (calcio > 10.5 mg/dL)","Calcio corregido por albumina elevado","PTH elevada en presencia de hipercalcemia","Nefrolitiasis recurrente en radiografia","Osteoporosis en densitometria osea (cortical preferente)","QTc acortado en ECG"],sintomas:["Renal: nefrolitiasis recurrente, poliuria, polidipsia, nefrocalcinosis","Oseo: dolor oseo, fracturas por fragilidad, osteitis fibrosa quistica (formas severas)","Gastrointestinal: anorexia, nauseas, estrenimiento, ulcera peptica, pancreatitis","Neuromuscular: debilidad muscular proximal, fatiga, confusion","Regla de las 7 S: Stones, Bones, Groans, Psychic moans y otros"]},clasificacion:{nombre:"Clasificacion por origen",tipos:[{nombre:"Primario",descripcion:"Hipersecrecion autonoma: adenoma unico (85%), hiperplasia multiglandular (15%), carcinoma (< 1%)"},{nombre:"Secundario",descripcion:"Hiperplasia reactiva de todas las paratiroides por hipocalcemia cronica (IRC, deficit vit D)"},{nombre:"Terciario",descripcion:"Autonomia adquirida de una gl\xe1ndula hiperpl\xe1sica en el secundario (post-trasplante renal)"},{nombre:"Crisis hipercalcemica",descripcion:"Calcio > 14 mg/dL con sintomas graves: emergencia medica"}]},diagnostico:{anamnesis:["Antecedentes de nefrolitiasis recurrente","Historia de osteoporosis o fracturas en localizaciones atipicas","Sintomas neuropsiquiatricos: depresion, confusion, fatiga","Historia familiar de NEM o hipercalcemia familiar","Uso de litio o suplementos de calcio o vitamina D en exceso"],examenFisico:["Evaluacion neurologica basica: orientacion, fuerza muscular","Palpacion cervical: raramente se palpa un adenoma paratiroideo"],pruebas:[{nombre:"Calcio total y albumina (calcio corregido)",descripcion:"Primer paso: confirmar hipercalcemia real. Calcio corregido = calcio total + 0.8 x (4 - albumina)",valoresReferencia:"Calcio normal 8.5-10.5 mg/dL; hipercalcemia > 10.5 mg/dL; severa > 14 mg/dL",cuidadosEnfermeria:["Ayuno de 4h para calcio","Registrar la albumina del mismo dia para el calculo del calcio corregido","Extraer en decubito (el torniquete puede elevar falsamente la albumina)"]},{nombre:"PTH intacta (iPTH)",descripcion:"Confirma el origen paratiroideo de la hipercalcemia: PTH elevada o inadecuadamente normal en hipercalcemia = HPTP",valoresReferencia:"PTH normal 15-65 pg/mL; en HPTP usualmente > 65 pg/mL o inapropiadamente elevada para el calcio",cuidadosEnfermeria:["Extraer en EDTA en hielo y enviar inmediatamente","Registrar la hora de extraccion","Extraer en ayunas a las 8-9h de la ma\xf1ana"]},{nombre:"Ecografia cervical + gammagrafia con sestamibi",descripcion:"Localizan el adenoma paratiroideo antes de la cirugia; sensibilidad combinada > 90%",valoresReferencia:"Adenoma paratiroideo: captacion de sestamibi que se retiene en la fase tardia (wash out lento)",cuidadosEnfermeria:["Gammagrafia: no requiere preparacion especial","Sestamibi: contraindicado en embarazo y lactancia","La localizacion preoperatoria permite cirugia minimamente invasiva en lugar de exploracion bilateral"]},{nombre:"Densitometria osea (DEXA)",descripcion:"Evalua la densidad mineral osea en columna, femur y radio distal (cortical: mas afectado en HPTP)",valoresReferencia:"T-score < -2.5 en cualquier sitio = indicacion de paratiroidectomia en asintomatico",cuidadosEnfermeria:["Retirar objetos metalicos","Registrar peso, talla y medicacion actual","Comparar con DEXA previa si existe"]}]},tratamientoMedico:{objetivos:["Normalizar el calcio serico","Prevenir las complicaciones renales y oseas","Cirugia paratiroidea cuando este indicada"],farmacologico:[{nombre:"Cinacalcet",grupo:"Calcimimetico (modulador del receptor sensible al calcio)",mecanismo:"Aumenta la sensibilidad del receptor sensible al calcio en la celula paratiroidea, reduciendo la secrecion de PTH",dosis:"30 mg cada 12h titulando hasta 90 mg cada 12h segun calcio",cuidadosEnfermeria:["Monitorizar calcio serico semanalmente al inicio hasta estabilizacion","Vigilar hipocalcemia como efecto adverso","Administrar con alimentos o inmediatamente despues de comer"]},{nombre:"Bifosfonatos (Alendronato)",grupo:"Bisfosfonato oral",mecanismo:"Inhibe la resorcion osea mediada por osteoclastos; protege la densidad mineral osea en el HPTP",dosis:"70 mg semana VO en ayunas",cuidadosEnfermeria:["Administrar con agua y permanecer de pie 30 min (previene esofagitis)","Suplementar con calcio y vitamina D","Contraindicado con TFG < 35 mL/min"]},{nombre:"Hidratacion IV mas furosemida (en crisis hipercalcemica)",grupo:"Tratamiento de urgencia de la hipercalcemia severa",mecanismo:"La hidratacion IV restaura el volumen y aumenta la excrecion renal de calcio; la furosemida aumenta la calciuria",dosis:"SF 0.9% a 200-300 mL/h + Furosemida 20-40 mg IV cada 4-6h tras hidratar",cuidadosEnfermeria:["Monitorizar diuresis horaria (objetivo 200-300 mL/h)","Controlar electrolitos cada 4-6h: hipopotasemia e hiponatremia frecuentes","Vigilar signos de sobrecarga hidrica en cardiologicos y renales"]}],noFarmacologico:["Hidratacion oral abundante (> 2 L/dia) para prevenir nefrolitiasis","Evitar inmovilizacion prolongada (aumenta la resorcion osea)","Dieta moderada en calcio (no restriccion excesiva: paradoja de la restriccion)","Evitar tiazidas (reducen la excrecion renal de calcio y empeoran la hipercalcemia)"],quirurgico:["Paratiroidectomia dirigida (minimamente invasiva, guiada por PTH intraoperatoria)","Exploracion bilateral en hiperplasia multiglandular o cuando la localizacion falla","Indicaciones en asintomaticos: calcio > 1 mg/dL sobre el limite, TFG < 60, T-score < -2.5, fracturas, edad < 50 a\xf1os"]},cuidadosEnfermeria:{valoracion:["Monitorizar calcio serico en cada ingreso o visita relevante","Evaluar estado de hidratacion: turgencia cutanea, mucosas, diuresis","Valorar estado mental: confusion, letargia en hipercalcemia severa","Monitorizar ECG: QTc acortado en hipercalcemia"],intervenciones:["En hipercalcemia sintomatica o > 12 mg/dL: hidratacion IV agresiva con SF 0.9%","Monitorizar diuresis horaria con la hidratacion IV","Administrar bifosfonatos IV (pamidronato o acido zoledronico) en hipercalcemia severa segun prescripcion","Preparar al paciente para la cirugia paratiroidea: evitar comidas pre-anestesia, consentimiento"],educacionPaciente:["Hidratacion oral de al menos 2 litros al dia para prevenir litiasis renal","Evitar restriccion excesiva de calcio en la dieta (paradojicamente puede estimular mas la PTH)","Reconocer signos de hipercalcemia: nauseas, confusion, poliuria","Si hay cinacalcet: importancia de los controles de calcio y los signos de hipocalcemia (parestesias, calambres)"],monitorizacion:["Calcio y albumina semanales en inicio de cinacalcet","Calcio diario en crisis hipercalcemica y postoperatorio inmediato de paratiroidectomia","Funcion renal y electrolitos en hipercalcemia severa tratada con hidratacion","DEXA anual en HPTP asintomatico"]},npiNanda:[{codigo:"00025",nombre:"Riesgo de desequilibrio de la perfusion tisular renal",definicion:"Riesgo de disminucion de la circulacion sanguinea renal",caracteristicasDefinitorias:["Hipercalcemia","Nefrolitiasis recurrente","Poliuria"],factoresRelacionados:["Hipercalcemia con nefrocalcinosis y vasoconstriccion renal"]},{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva desagradable",caracteristicasDefinitorias:["Colico renal por litiasis calcica","Dolor oseo"],factoresRelacionados:["Nefrolitiasis por hipercalciuria","Resorcion osea por PTH elevada"]},{codigo:"00028",nombre:"Riesgo de deficit de volumen de liquidos",definicion:"Riesgo de disminucion del volumen intravascular, intersticial o intracelular",caracteristicasDefinitorias:["Poliuria por hipercalcemia","Nauseas y vomitos que reducen la ingesta"],factoresRelacionados:["Diabetes insipida nefrogena por hipercalcemia cronica"]}],npiNic:[{codigo:"2080",nombre:"Manejo del trastorno endocrino",actividades:["Monitorizar calcio serico periodicamente","Administrar cinacalcet con alimentos y monitorizar calcio","Coordinar cirugia paratiroidea cuando este indicada"]},{codigo:"4120",nombre:"Manejo de liquidos",actividades:["En hipercalcemia sintomatica: SF 0.9% IV a ritmo de diuresis forzada","Monitorizar diuresis horaria","Controlar electrolitos cada 4-6h"]},{codigo:"5510",nombre:"Educacion para la salud",actividades:["Instruir en hidratacion oral abundante","Explicar que alimentos contienen calcio sin recomendar restriccion excesiva","Educar sobre los sintomas de hipercalcemia y cuando consultar urgencias"]}],npiNoc:[{codigo:"0601",nombre:"Equilibrio electrol\xedtico y acido-basico",indicadores:["Calcio serico < 10.5 mg/dL","Sin sintomas de hipercalcemia","Diuresis normal"],escala:"1=Desviacion grave, 5=Sin desviacion"},{codigo:"1902",nombre:"Control del riesgo",indicadores:["Ingesta hidrica > 2 L/dia","Controles de calcio regulares","Adhiere a tratamiento medico o planificacion quirurgica"],escala:"1=Nunca, 5=Constantemente"}],complicaciones:["Nefrolitiasis recurrente con insuficiencia renal cronica","Osteoporosis con fracturas de cadera o vertebrales","Pancreatitis aguda","Crisis hipercalcemica (calcio > 14 mg/dL: emergencia medica)","Hipertension arterial"],criteriosAlarma:["Calcio > 14 mg/dL (crisis hipercalcemica: vomitos, confusion, poliuria severa)","Colico renal con obstruccion o infeccion","Fractura patologica","Arritmia cardiaca con QTc muy acortado","Pancreatitis aguda"],emergencyLevel:"moderado",relatedPathologyIds:["pat_irc"],isPremium:!0},{id:"pat_coma_mixedematoso",nombre:"Coma Mixedematoso",bodySystemId:"endocrino",definicion:"Forma extrema y potencialmente mortal del hipotiroidismo descompensado, caracterizada por la trias de alteracion del nivel de consciencia (hasta el coma), hipotermia e hipotiroidismo severo, precipitada generalmente por un factor desencadenante en un paciente con hipotiroidismo de base.",epidemiologia:"Raramente ocurre con una incidencia de 0.22 casos por millon/ano. Mortalidad del 20-50% incluso con tratamiento agresivo. Predomina en mujeres ancianas. Es mas frecuente en invierno (hipotermia como desencadenante).",factoresRiesgo:["Hipotiroidismo primario de larga data no tratado o mal tratado","Suspension abrupta de levotiroxina","Infecciones (neumonia, ITU como desencadenantes mas frecuentes)","Farmacos depresores del SNC: amiodarona, litio, betabloqueantes en hipotiroideos","Hipotermia ambiental","Cirugia o trauma en hipotiroideo","Fallo cardiaco o respiratorio que precipita el coma"],fisiopatologia:"El hipotiroidismo severo produce disminucion del metabolismo basal, reduccion de la termogenesis, acumulacion de glicosaminoglicanos en tejidos (edema mixedematoso), bradycardia, hipotension e hipoventilacion alveolar con retencion de CO2. La combinacion de hipercapnia, hipoxia, hiponatremia dilucional y la reduccion del metabolismo cerebral produce la depresion del nivel de consciencia. La hipotermia agrava todos estos mecanismos en un circulo vicioso.",signosYSintomas:{signos:["Hipotermia (temperatura < 35 grados, a veces < 32 grados)","Bradicardia severa (< 50 lpm)","Hipotension arterial","Bradipnea con hipercapnia (CO2 > 50 mmHg)","Macroglosia y rasgos faciales toscos","Edema periorbitario y facial sin fovea (mixedema)","Reflejos osteotendinosos enlentecidos o ausentes","Piel seca, amarillenta, con caida del tercio externo de las cejas (signo de Hertoghe)"],sintomas:["Coma o alteracion profunda del nivel de consciencia (principal sintoma)","Hipotermia severa","Historia de hipotiroidismo conocido o signos de hipotiroidismo de larga data"]},clasificacion:{nombre:"Clasificacion por severidad (escala de puntuacion del coma mixedematoso)",tipos:[{nombre:"Leve (puntuacion 25-60)",descripcion:"Somnolencia, bradycardia moderada, hipotermia leve; mortalidad 10%"},{nombre:"Moderado (puntuacion 60-100)",descripcion:"Estupor, bradicardia severa, hipotermia moderada; mortalidad 30%"},{nombre:"Severo (puntuacion > 100)",descripcion:"Coma profundo, bradicardia extrema, hipotermia severa, fallo respiratorio; mortalidad > 50%"}]},diagnostico:{anamnesis:["Historia de hipotiroidismo previo y tratamiento con levotiroxina","Suspension reciente de la medicacion tiroidea","Infeccion, exposicion al frio o cirugia reciente como desencadenante","Medicacion depresora del SNC: amiodarona, litio, sedantes"],examenFisico:["Temperatura rectal (termometro de baja temperatura si < 35 grados)","Glasgow: nivel de consciencia","Signos vitales: bradicardia, hipotension, bradipnea","Aspecto fisico: edema facial, piel seca, lengua gruesa, caida de cejas"],pruebas:[{nombre:"TSH y T4 libre (urgente)",descripcion:"Confirma el hipotiroidismo severo: TSH muy elevada (> 100 mUI/L) con T4 libre indetectable en primario",valoresReferencia:"TSH > 100 mUI/L con T4 libre indetectable en coma mixedematoso por hipotiroidismo primario",cuidadosEnfermeria:["Extraer urgente con hemograma y bioquimica completa","No esperar el resultado para iniciar el tratamiento en paciente con cuadro clinico tipico","TSH baja con T4 libre baja sugiere origen central (hipopituitarismo)"]},{nombre:"Gasometria arterial",descripcion:"Evalua la hipoventilacion: hipercapnia y acidosis respiratoria; hipoxemia",valoresReferencia:"pCO2 > 50 mmHg en hipoventilacion; pH < 7.35 en acidosis respiratoria",cuidadosEnfermeria:["Extraer urgente con la muestra en hielo","Resultado en 15 minutos","Puede indicar necesidad de ventilacion mecanica"]},{nombre:"Ionograma, glucemia y cortisol basale",descripcion:"La hiponatremia dilucional es frecuente (sodio < 125 mEq/L en graves); hipoglucemia; cortisol bajo si hay insuficiencia suprarrenal concomitante",valoresReferencia:"Na < 130 mEq/L en el 50% de los comas mixedematosos; cortisol < 15 mcg/dL en insuficiencia suprarrenal",cuidadosEnfermeria:["Urgente: el resultado orienta el tratamiento inmediato","Si sodio < 125 mEq/L: restriccion hidrica y posiblemente SF hipertonico"]}]},tratamientoMedico:{objetivos:["Reemplazo urgente de hormonas tiroideas IV","Tratar el factor desencadenante (infeccion)","Soporte ventilatorio y hemodinamico","Recalentamiento pasivo y activo si hay hipotermia severa"],farmacologico:[{nombre:"Levotiroxina IV (T4)",grupo:"Hormona tiroidea de reemplazo IV urgente",mecanismo:"Dosis de carga de T4 IV para restaurar rapidamente los depositos tisulares de hormona tiroidea",dosis:"300-500 mcg IV en bolo lento en 30 min (dosis de carga), seguido de 50-100 mcg/dia IV hasta que el paciente pueda tomar VO",cuidadosEnfermeria:["Administrar lentamente (en 30 min) por riesgo de arritmias en corazon mixedematoso","Monitorizar ECG continuo durante la carga inicial","Siempre administrar hidrocortisona ANTES de la levotiroxina (puede precipitar crisis suprarrenal)"]},{nombre:"Liotironina IV (T3)",grupo:"Triyodotironina IV de accion rapida",mecanismo:"La T3 es la hormona activa; acelera la respuesta al tratar el coma mixedematoso al no requerir conversion hepatica de T4 a T3",dosis:"5-20 mcg IV cada 8h como adyuvante de la T4 IV en casos severos",cuidadosEnfermeria:["Usar solo en casos muy severos o sin respuesta a T4 IV","Mayor riesgo cardiaco que la T4: monitorizar ECG continuo","Disponibilidad limitada en muchos paises"]},{nombre:"Hidrocortisona 100 mg IV",grupo:"Corticosteroide de emergencia",mecanismo:"Cubre la posible insuficiencia suprarrenal concomitante (frecuente) y previene la crisis suprarrenal que puede precipitarse al aumentar el metabolismo con la tiroxina",dosis:"100 mg IV bolo inmediato, seguido de 50 mg IV cada 8h durante 48h",cuidadosEnfermeria:["Administrar ANTES o simult\xe1neamente a la primera dosis de levotiroxina","Nunca administrar levotiroxina sin cubrir con hidrocortisona en el coma mixedematoso","Puede reducirse cuando se confirme que el cortisol es normal"]}],noFarmacologico:["Intubacion orotraqueal y ventilacion mecanica si pCO2 > 60 mmHg o coma profundo (Glasgow < 8)","Recalentamiento pasivo con mantas calientes (no recalentamiento activo agresivo: vasodilatacion brusca puede empeorar la hipotension)","Restriccion hidrica si hay hiponatremia dilucional","Suero fisiologico para hipotension (no hipoosmolares)","Busqueda y tratamiento del factor desencadenante (antibioticos si infeccion)"],quirurgico:[]},cuidadosEnfermeria:{valoracion:["Monitorizar temperatura rectal con termometro de baja temperatura cada hora (hipotermia severa puede no detectarse con termometros normales)","Monitorizar Glasgow, PA, FC, FR y SpO2 continuo","ECG continuo: evaluar bradicardia, QTc y respuesta a la tiroxina IV","Medir diuresis horaria: retencion hidrica frecuente"],intervenciones:["Recalentamiento con mantas calientes: lento y pasivo, no activo brusco","Preparar intubacion urgente si Glasgow < 8 o hipercapnia severa","Administrar hidrocortisona IV antes de la primera dosis de tiroxina","Administrar tiroxina IV lentamente con monitorizacion cardiaca continua","Busqueda e inicio inmediato del tratamiento del factor precipitante (antibioticos empiricos para posible infeccion)"],educacionPaciente:["En la fase aguda la educacion es principalmente hacia los familiares","Explicar la gravedad de la situacion y el plan de tratamiento","Tras la recuperacion: educar sobre la importancia de no suspender nunca la levotiroxina","Identificar los signos precoces de descompensacion del hipotiroidismo para consultar antes de llegar al coma"],monitorizacion:["Temperatura horaria","ECG continuo en las primeras 24-48h","Gasometria arterial cada 4-6h","TSH y T4 libre a las 24h de inicio del tratamiento","Sodio cada 4-6h si hay hiponatremia severa"]},npiNanda:[{codigo:"00030",nombre:"Deterioro del intercambio gaseoso",definicion:"Exceso o deficit en la oxigenacion o eliminacion de CO2",caracteristicasDefinitorias:["pCO2 > 50 mmHg","pH < 7.35","SpO2 reducida","Bradipnea"],factoresRelacionados:["Hipoventilacion alveolar severa por hipotiroidismo extremo"]},{codigo:"00007",nombre:"Hipertermia",definicion:"Temperatura corporal por encima del rango normal (en este caso la variante inversa: hipotermia)",caracteristicasDefinitorias:["Temperatura < 35 grados","Piel fria y palida","Bradicardia"],factoresRelacionados:["Reduccion severa del metabolismo basal por deficit de hormonas tiroideas"]},{codigo:"00029",nombre:"Disminucion del gasto cardiaco",definicion:"Gasto cardiaco insuficiente",caracteristicasDefinitorias:["Bradicardia < 50 lpm","Hipotension","Extremidades frias"],factoresRelacionados:["Hipotiroidismo severo con reduccion de la contractilidad y la FC"]}],npiNic:[{codigo:"3300",nombre:"Manejo de la ventilacion mecanica",actividades:["Preparar intubacion si Glasgow < 8 o pCO2 > 60 mmHg","Monitorizar parametros ventilatorios","Gasometria arterial de control a la hora del inicio de ventilacion mecanica"]},{codigo:"3800",nombre:"Tratamiento de la hipotermia",actividades:["Recalentamiento pasivo con mantas calientes","Monitorizar temperatura rectal cada hora","Evitar el recalentamiento externo activo agresivo"]},{codigo:"2080",nombre:"Manejo del trastorno endocrino",actividades:["Administrar hidrocortisona IV antes de la levotiroxina","Infundir levotiroxina IV lentamente con ECG continuo","Monitorizar TSH y T4 libre a las 24h del inicio del tratamiento"]}],npiNoc:[{codigo:"0906",nombre:"Toma de decisiones",definicion:"Capacidad de tomar decisiones del paciente",indicadores:["Recuperacion progresiva del nivel de consciencia","Glasgow en mejoria en 24-48h","Respuesta a estimulos verbales"],escala:"1=Gravemente comprometido, 5=No comprometido"},{codigo:"0402",nombre:"Estado respiratorio: intercambio gaseoso",indicadores:["pCO2 < 45 mmHg con tratamiento","SpO2 > 90%","pH > 7.35"],escala:"1=Desviacion grave, 5=Sin desviacion"}],complicaciones:["Paro cardiorrespiratorio (bradicardia extrema y asistolia)","Fallo respiratorio con necesidad de ventilacion mecanica","Crisis suprarrenal precipitada por el tratamiento con tiroxina sin cobertura de corticoides","Hiponatremia severa con edema cerebral","Muerte (20-50% incluso con tratamiento)"],criteriosAlarma:["Temperatura < 32 grados (hipotermia severa)","Glasgow < 8 (coma profundo: intubacion inmediata)","Bradicardia < 40 lpm o paro sinusal","pCO2 > 60 mmHg (ventilacion mecanica urgente)","Hipotension refractaria a fluidos"],emergencyLevel:"critico",relatedPathologyIds:["pat_hipotiroidismo","pat_hipopituitarismo"],isPremium:!0},{id:"pat_purpura_trombocitopenica",nombre:"Purpura Trombocitopenica Idiopatica",bodySystemId:"hematologico",definicion:"Trastorno autoinmune adquirido caracterizado por trombocitopenia aislada (plaquetas < 100.000/uL) debida a la destruccion periferica de plaquetas mediada por autoanticuerpos IgG dirigidos contra antigenos plaquetarios (principalmente GPIIb/IIIa y GPIb/IX), en ausencia de causa subyacente identificable.",epidemiologia:"Incidencia de 5-10 casos por 100.000 habitantes/ano. En ni\xf1os predomina la forma aguda autolimitada post-viral (pico 2-5 a\xf1os). En adultos predomina la forma cronica, con mayor frecuencia en mujeres en edad fertil (relacion 3:1). En adultos mayores de 60 a\xf1os la incidencia se iguala entre sexos.",factoresRiesgo:["Infecciones virales previas (VEB, CMV, VIH, hepatitis C)","Sexo femenino en edad reproductiva","Enfermedades autoinmunes concomitantes (LES)","Infeccion por Helicobacter pylori","Vacunaciones recientes (forma aguda pediatrica)","Uso de ciertos farmacos (heparina, quinidina)","Antecedentes familiares de trombocitopenia autoinmune"],fisiopatologia:"Los autoanticuerpos IgG se unen a antigenos de la membrana plaquetaria (principalmente GPIIb/IIIa). Las plaquetas opsonizadas son reconocidas por receptores Fc en macrofagos del bazo e higado, donde son destruidas prematuramente (vida media reducida de 7-10 dias a horas). Ademas, los autoanticuerpos pueden inhibir la megacariopoyesis en medula osea, reduciendo la produccion plaquetaria. La trombocitopenia resultante deteriora la hemostasia primaria, manifestandose como sangrado mucocutaneo.",signosYSintomas:{signos:["Petequias en piel y mucosas","Purpura palpable o no palpable","Equimosis espontaneas o desproporcionadas al traumatismo","Epistaxis recurrente","Sangrado gingival","Menorragia (en mujeres)","Recuento plaquetario < 100.000/uL en hemograma"],sintomas:["Historia de aparicion brusca de hematomas","Sangrado prolongado ante cortes menores","Fatiga (si hay anemia por sangrado cronico)","Ausencia de esplenomegalia (diferencia con otras trombocitopenias)","Generalmente sin fiebre ni sindrome constitucional"]},clasificacion:{nombre:"Clasificacion por duracion (ASH 2019)",tipos:[{nombre:"PTI nueva o recien diagnosticada",descripcion:"Duracion < 3 meses desde el diagnostico"},{nombre:"PTI persistente",descripcion:"Duracion entre 3 y 12 meses sin remision espontanea"},{nombre:"PTI cronica",descripcion:"Duracion > 12 meses; mas frecuente en adultos"},{nombre:"PTI refractaria",descripcion:"Fallo a esplenectomia y al menos una segunda linea de tratamiento, con plaquetas < 30.000/uL"}]},diagnostico:{anamnesis:["Inicio y duracion del sangrado","Infecciones o vacunaciones recientes","Medicamentos actuales (heparina, AINEs, quinidinicos)","Antecedentes de enfermedades autoinmunes","Consumo de alcohol","Historia familiar de trombocitopenia"],examenFisico:["Inspeccion de piel: petequias, purpura, equimosis","Examen de mucosas: sangrado gingival, ampollas hemosucas","Palpacion abdominal: ausencia de esplenomegalia (orienta a PTI)","Busqueda de adenopatias (descarta linfoma)","Signos de sangrado activo en cualquier sitio"],pruebas:[{nombre:"Hemograma con recuento plaquetario",descripcion:"Confirma trombocitopenia aislada; resto de series normales en PTI primaria",valoresReferencia:"Plaquetas normales: 150.000-400.000/uL; PTI: < 100.000/uL",cuidadosEnfermeria:["Extraer muestra en tubo con EDTA verificando correcta proporcion","Informar al laboratorio sobre sospecha de seudotrombocitopenia para confirmacion con citrato","Aplicar presion prolongada en sitio de puncion (minimo 5 minutos)","Observar sangrado activo post-extraccion"]},{nombre:"Frotis de sangre periferica",descripcion:"Confirma trombocitopenia real y descarta esquistocitos (PTT), blastos (leucemia) o plaquetas gigantes",valoresReferencia:"Morfologia plaquetaria normal; plaquetas grandes pueden verse en PTI (mayor produccion compensadora)",cuidadosEnfermeria:["Obtener muestra de buena calidad sin coagulos","Transportar al laboratorio dentro de la primera hora"]},{nombre:"Anticuerpos antiplaquetarios (anti-GPIIb/IIIa)",descripcion:"Confirma etiologia autoinmune; sensibilidad 49-66%, especificidad 78-92%",valoresReferencia:"Negativo en condiciones normales",cuidadosEnfermeria:["Centrifugar y separar suero dentro de las 2 horas","Conservar a -20 grados si no se procesa de inmediato"]},{nombre:"Serologia para VIH, VHC, VHB",descripcion:"Descartar trombocitopenia secundaria a infecciones virales cronicas",valoresReferencia:"Resultado negativo esperado en PTI primaria",cuidadosEnfermeria:["Consentimiento informado para VIH","Mantener confidencialidad de resultados"]},{nombre:"Mielograma (aspirado de medula osea)",descripcion:"Indicado en mayores de 60 a\xf1os, antes de esplenectomia, o con datos atipicos para descartar mielodisplasia o leucemia",valoresReferencia:"Megacariocitos normales o aumentados con morfologia normal en PTI",cuidadosEnfermeria:["Preparar campo esteril y material de biopsia","Monitorizar signos vitales post-procedimiento","Vigilar hematoma en sitio de puncion (habitualmente cresta iliaca posterior)","Indicar al paciente reposo relativo 24 horas"]}]},tratamientoMedico:{objetivos:["Elevar recuento plaquetario a nivel seguro (> 30.000/uL para evitar sangrado espontaneo grave)","Controlar manifestaciones hemorragicas","Minimizar toxicidad del tratamiento","Lograr remision a largo plazo"],farmacologico:[{nombre:"Prednisona",grupo:"Corticosteroide sist\xe9mico",mecanismo:"Inhibe la fagocitosis de plaquetas opsonizadas por macrofagos espl\xe9nicos y reduce la produccion de autoanticuerpos",dosis:"1 mg/kg/dia VO (maximo 80 mg/dia) durante 4-6 semanas con reduccion gradual",cuidadosEnfermeria:["Administrar con alimentos para reducir irritacion gastrica","Monitorizar glucemia (puede inducir hiperglucemia)","Vigilar presion arterial y peso (retencion hidrosodica)","Educar sobre no suspender bruscamente el tratamiento","Controlar recuento plaquetario cada 1-2 semanas"]},{nombre:"Inmunoglobulina intravenosa (IgIV)",grupo:"Inmunoglobulina polivalente",mecanismo:"Bloquea receptores Fc en macrofagos, reduciendo la destruccion de plaquetas opsonizadas; efecto rapido (24-72h)",dosis:"1 g/kg/dia IV durante 1-2 dias; alternativa 0.4 g/kg/dia x 5 dias",cuidadosEnfermeria:["Infundir lentamente la primera hora (0.5 mL/kg/h) y aumentar gradualmente","Monitorizar signos vitales cada 30 minutos durante infusion","Vigilar reacciones adversas: cefalea, fiebre, escalofrios, nauseas","Tener disponible adrenalina ante anafilaxia","Verificar grupo sanguineo previo a la infusion (riesgo de hemolisis en anti-D)"]},{nombre:"Eltrombopag",grupo:"Agonista del receptor de trombopoyetina (TPO-RA)",mecanismo:"Estimula la proliferacion y diferenciacion de megacariocitos, aumentando la produccion plaquetaria",dosis:"25-75 mg/dia VO en ayunas",cuidadosEnfermeria:["Administrar 2 horas antes o 4 horas despues de comidas con calcio o anti\xe1cidos","Monitorizar funcion hepatica (ALT, AST) mensualmente","Vigilar signos de trombosis (efecto adverso por exceso de plaquetas)","Controlar recuento plaquetario semanal al inicio"]}],noFarmacologico:["Evitar farmacos que inhiben funcion plaquetaria (AAS, AINEs, clopidogrel)","Restriccion de actividades con riesgo de traumatismo (plaquetas < 50.000/uL)","Evitar inyecciones intramusculares","Esplenectomia en PTI cronica refractaria a corticoides (segunda linea)","Uso de casco protector en ni\xf1os con plaquetas < 20.000/uL"]},cuidadosEnfermeria:{valoracion:["Evaluar presencia y extension de petequias, purpura y equimosis","Registrar recuento plaquetario actual y su tendencia","Valorar sangrado activo: epistaxis, hemoptisis, hematuria, melena","Identificar nivel de actividad fisica y riesgo de traumatismo","Evaluar farmacos que puedan agravar la trombocitopenia","Valorar estado emocional (impacto de enfermedad cronica)"],intervenciones:["Aplicar presion prolongada en sitios de venopuncion (minimo 5-10 minutos)","Usar agujas de calibre fino para extracciones","Evitar via intramuscular si plaquetas < 50.000/uL","Indicar al paciente que use cepillo dental suave","Coordinar con medico antes de cualquier procedimiento invasivo","Preparar y administrar hemoderivados (plaquetas) segun indicacion medica"],educacionPaciente:["Explicar la naturaleza autoinmune de la enfermedad y la necesidad de seguimiento","Instruir sobre signos de alarma: sangrado intracraneal (cefalea severa, alteracion de conciencia)","Ense\xf1ar a evitar medicamentos que alteren la funcion plaquetaria","Recomendar uso de pulsera de identificacion medica","Informar sobre importancia de comunicar el diagnostico a cualquier profesional de salud antes de procedimientos"],monitorizacion:["Recuento plaquetario segun frecuencia indicada (diario en casos agudos)","Vigilar signos de sangrado interno: cambios neurologicos, hematuria, melena","Monitorizar efectos adversos de corticoides: glucemia, PA, peso","Observar sitios de venopuncion durante 30 minutos post-extraccion","Controlar nivel de conciencia ante plaquetas < 10.000/uL"]},npiNanda:[{codigo:"00206",nombre:"Riesgo de sangrado",definicion:"Vulnerable a una disminucion del volumen de sangre que puede comprometer la salud",caracteristicasDefinitorias:["Trombocitopenia grave (< 20.000/uL)","Presencia de petequias y equimosis espontaneas","Antecedente de epistaxis recurrente"],factoresRelacionados:["Trombocitopenia por destruccion autoinmune de plaquetas","Conocimiento insuficiente sobre precauciones de sangrado","Uso de agentes que deterioran la coagulacion"]},{codigo:"00004",nombre:"Riesgo de infeccion",definicion:"Vulnerable a ser invadido y multiplicado por organismos patogenos que puede comprometer la salud",caracteristicasDefinitorias:["Tratamiento inmunosupresor con corticoides","Procedimientos invasivos (venopunciones frecuentes)"],factoresRelacionados:["Inmunosupresion secundaria al tratamiento con corticosteroides","Defensas primarias inadecuadas (lesiones cutaneas por purpura)"]},{codigo:"00146",nombre:"Ansiedad",definicion:"Sensacion vaga e inquietante de malestar o amenaza acompanada de una respuesta autonomica",caracteristicasDefinitorias:["Preocupacion por evolucion de la enfermedad","Inquietud ante procedimientos diagnosticos","Verbaliza miedo al sangrado grave"],factoresRelacionados:["Diagnostico de enfermedad cronica con riesgo de sangrado","Incertidumbre sobre respuesta al tratamiento","Cambios en el estilo de vida requeridos"]}],npiNic:[{codigo:"4010",nombre:"Precauciones con hemorragias",actividades:["Vigilar de cerca signos y sintomas de hemorragia","Aplicar presion en sitios de puncion","Evitar inyecciones intramusculares en trombocitopenia grave","Coordinar con medico el umbral de transfusion de plaquetas","Instruir al paciente sobre medidas de prevencion de traumatismos"]},{codigo:"6550",nombre:"Proteccion contra las infecciones",actividades:["Monitorizar signos de infeccion en pacientes con corticoterapia","Mantener tecnica aseptica en todos los procedimientos invasivos","Limitar visitas en periodos de inmunosupresion intensa","Verificar estado de vacunacion (especialmente neumonoco y meningococo previo a esplenectomia)"]},{codigo:"5820",nombre:"Disminucion de la ansiedad",actividades:["Explicar en lenguaje comprensible el proceso de la enfermedad y el tratamiento","Escuchar activamente las preocupaciones del paciente","Facilitar el contacto con grupos de apoyo de pacientes con PTI","Proporcionar informacion escrita sobre signos de alarma"]}],npiNoc:[{codigo:"0413",nombre:"Severidad de la perdida de sangre",indicadores:["Ausencia de petequias nuevas","Recuento plaquetario en rango seguro (> 30.000/uL)","Ausencia de sangrado en mucosas","Ausencia de signos de sangrado intracraneal"],escala:"1=Grave, 2=Sustancial, 3=Moderada, 4=Leve, 5=Ninguna"},{codigo:"1902",nombre:"Control del riesgo",indicadores:["Identifica farmacos que deben evitarse","Adopta medidas de proteccion ante traumatismos","Acude a controles programados","Reconoce signos de alarma de sangrado grave"],escala:"1=Nunca demostrado, 2=Raramente demostrado, 3=A veces demostrado, 4=Frecuentemente demostrado, 5=Siempre demostrado"}],complicaciones:["Hemorragia intracraneal (complicacion mas grave; riesgo con plaquetas < 10.000/uL)","Sangrado gastrointestinal masivo","Hemorragia retiniana con perdida de vision","Anemia ferropenica por perdidas cronicas","Efectos adversos de corticoterapia prolongada (osteoporosis, diabetes, sindrome de Cushing)","Infecciones graves post-esplenectomia (sepsis por capsulados)","Trombosis (complicacion de agonistas de TPO)"],criteriosAlarma:["Plaquetas < 10.000/uL (riesgo de sangrado espontaneo grave)","Cefalea intensa o alteracion del nivel de conciencia (sospecha de hemorragia intracraneal)","Sangrado digestivo activo (hematemesis o melena)","Hematuria macroscopica","Vision borrosa o perdida subita de vision","Fiebre con inmunosupresion activa (riesgo infeccioso)"],emergencyLevel:"moderado",relatedPathologyIds:["pat_anemias","pat_lupus","pat_neutropenia","pat_mieloma"],isPremium:!0},{id:"pat_talasemia",nombre:"Talasemia",bodySystemId:"hematologico",definicion:"Grupo heterogeneo de anemias hemoliticas hereditarias causadas por mutaciones en los genes de las cadenas de globina (alfa o beta), que resultan en una sintesis reducida o ausente de dichas cadenas, generando un desequilibrio entre cadenas alfa y beta con precipitacion de cadenas en exceso, destruccion eritroide intramedular y hemolisis periferica.",epidemiologia:"Es la hemoglobinopatia mas frecuente del mundo. La talasemia beta afecta principalmente a poblaciones del Mediterraneo, Oriente Medio, subcontinente indio y Sudeste Asiatico. La talasemia alfa es prevalente en Africa, Oriente Medio y Asia. En Argentina la prevalencia del rasgo talasemico beta es del 1-2% en la poblacion general, con mayor concentracion en comunidades de origen italiano, griego y sirio-libanes.",factoresRiesgo:["Origen etnico de zonas endemicas (Mediterraneo, Oriente Medio, Asia)","Padres portadores del rasgo talasemico","Consanguinidad","Historia familiar de anemia hemolitica cronica","Zonas de alta prevalencia de malaria historica (seleccion positiva del rasgo)"],fisiopatologia:"En la talasemia beta, la reduccion de cadenas beta provoca exceso de cadenas alfa que se precipitan en precursores eritroides medulares, causando eritropoyesis ineficaz (destruccion intramedular). Las cadenas alfa precipitadas tambien lesionan los eritrocitos maduros, acortando su vida media (hemolisis). La hipoxia cronica estimula la eritropoyesis extramedular (hepato-esplenomegalia). En la talasemia alfa, la ausencia de cadenas alfa genera hemoglobinas anomalas (HbH, Hb Barts) con alta afinidad por O2 y escasa liberacion tisular.",signosYSintomas:{signos:["Palidez cutaneomucosa progresiva","Ictericia escleral y cutanea (hemolisis)","Esplenomegalia (a veces masiva)","Hepatomegalia","Deformidades oseas craneo-faciales (facies talasemica: prominencia malar, maxilar superior prominente)","Retraso del crecimiento en ni\xf1os","Microcitosis e hipocromia en hemograma (VCM < 70 fL)"],sintomas:["Fatiga y debilidad cronica","Disnea de esfuerzo","Palidez notada por familiares","Dolor oseo (expansion medular)","Ictericia recurrente","En talasemia minor: generalmente asintomatico o fatiga leve"]},clasificacion:{nombre:"Clasificacion clinica de Talasemia Beta",tipos:[{nombre:"Talasemia Minor (rasgo talasemico)",descripcion:"Heterocigoto (beta+/normal). Anemia leve o ausente, microcitosis. Generalmente asintomatico. Portador."},{nombre:"Talasemia Intermedia",descripcion:"Anemia moderada (Hb 7-10 g/dL). Puede requerir transfusiones ocasionales. Esplenomegalia variable."},{nombre:"Talasemia Mayor (Anemia de Cooley)",descripcion:"Homocigoto (beta0/beta0). Anemia grave desde los 6-24 meses de vida. Requiere transfusiones regulares cada 3-4 semanas de por vida."}]},diagnostico:{anamnesis:["Origen etnico y geografico familiar","Antecedentes familiares de anemia, ictericia o esplenectomia","Edad de inicio de la anemia","Requerimientos transfusionales previos","Historia de crecimiento y desarrollo en pediatria","Consanguinidad entre los padres"],examenFisico:["Palidez cutaneomucosa y escleras ict\xe9ricas","Palpacion abdominal: tamano de bazo e higado","Evaluacion de deformidades oseas craneofaciales","Talla y peso en percentiles (retraso de crecimiento)","Auscultacion cardiaca (cardiomegalia, soplos por anemia)","Evaluacion de signos de sobrecarga de hierro: hiperpigmentacion, hepatomegalia"],pruebas:[{nombre:"Hemograma completo con indices eritrocitarios",descripcion:"Revela anemia microcitica hipocromica con incremento del recuento eritrocitario relativo; VCM < 70 fL sugiere talasemia",valoresReferencia:"VCM normal 80-100 fL; HCM normal 27-33 pg; en talasemia: VCM < 70 fL, HCM < 22 pg",cuidadosEnfermeria:["Obtener muestra en tubo EDTA correctamente mezclado","Registrar hora de extraccion y medicacion actual","Aplicar presion adecuada post-puncion"]},{nombre:"Electroforesis de hemoglobina",descripcion:"Estudio diagnostico de eleccion: determina porcentajes de HbA, HbA2 y HbF",valoresReferencia:"HbA2 > 3.5% confirma rasgo beta-talasemico; HbF elevada en talasemia mayor; ausencia de HbA en talasemia mayor beta0",cuidadosEnfermeria:["No transfundir al paciente en las 4 semanas previas al estudio (altera resultados)","Conservar muestra refrigerada","Coordinar con laboratorio de hemostasia especializado"]},{nombre:"Ferremia, ferritina y TIBC",descripcion:"Diferencia talasemia de anemia ferropenica; en talasemia la ferritina suele ser normal o elevada",valoresReferencia:"Ferritina: 20-200 ng/mL (mujer), 30-300 ng/mL (hombre); en talasemia mayor con multitransfusiones: ferritina frecuentemente > 1000 ng/mL",cuidadosEnfermeria:["Muestra en ayunas preferible","Registrar ultimas transfusiones recibidas"]},{nombre:"Estudio molecular de globinas (PCR)",descripcion:"Identifica la mutacion especifica de las cadenas alfa o beta; utl para diagnostico prenatal y consejo genetico",valoresReferencia:"Resultado cualitativo: identifica mutacion presente",cuidadosEnfermeria:["Extraer sangre en tubo EDTA","Puede tomarse en cualquier momento del dia","Informar al paciente sobre implicancias geneticas del resultado"]}]},tratamientoMedico:{objetivos:["Mantener hemoglobina pre-transfusional > 9-10 g/dL en talasemia mayor","Prevenir y tratar la sobrecarga de hierro","Reducir la eritropoyesis ineficaz","Mejorar la calidad de vida y esperanza de vida normal"],farmacologico:[{nombre:"Deferasirox",grupo:"Quelante del hierro oral",mecanismo:"Forma complejos estables con el hierro libre circulante y tisular, facilitando su eliminacion por via biliar y renal",dosis:"14-28 mg/kg/dia VO en suspension o comprimidos dispersables, una vez al dia",cuidadosEnfermeria:["Administrar en ayunas o con comida ligera baja en grasas","Monitorizar funcion renal y hepatica mensualmente al inicio","Vigilar molestias gastrointestinales (nauseas, vomitos, diarrea) especialmente al inicio","Controlar proteinuria periodicamente","Educiar sobre importancia de adherencia (terapia de por vida)"]},{nombre:"Acido folico",grupo:"Vitamina del complejo B",mecanismo:"Suplementa el consumo aumentado de folato por la eritropoyesis acelerada cronica, previniendo la deficiencia enzimatica en la sintesis de ADN eritroide",dosis:"5 mg/dia VO",cuidadosEnfermeria:["Administrar con o sin alimentos","Verificar que no haya deficit de vitamina B12 antes de iniciar (puede enmascararlo)","Reforzar que no sustituye a las transfusiones en talasemia mayor"]},{nombre:"Luspatercept",grupo:"Agente promotor de la maduracion eritroide (trampa de ligandos de TGF-beta)",mecanismo:"Inhibe se\xf1ales negativas de TGF-beta que bloquean la maduracion eritroide tardia, reduciendo la eritropoyesis ineficaz",dosis:"1 mg/kg SC cada 3 semanas (dosis maxima 1.25 mg/kg)",cuidadosEnfermeria:["Administrar via subcutanea en abdomen, muslo o brazo","Rotar sitios de inyeccion en cada aplicacion","Monitorizar PA (puede producir hipertension arterial)","Controlar recuento de plaquetas (trombocitosis como efecto adverso)","Conservar en refrigerador entre 2-8 grados; no congelar"]}],noFarmacologico:["Transfusiones de globulos rojos desleucotizados cada 3-4 semanas (talasemia mayor)","Trasplante alog\xe9nico de celulas madre hematopoyeticas (unica terapia curativa disponible; indicada en talasemia mayor con donante compatible)","Terapia genica (betibeglogene autotamcel, aprobada FDA 2022; en evaluacion en Argentina)","Esplenectomia en casos con esplenomegalia masiva o hiperesplenismo significativo","Consejo genetico familiar y diagnostico prenatal","Dietoterapia: evitar suplementos de hierro; dieta equilibrada"]},cuidadosEnfermeria:{valoracion:["Evaluar nivel de hemoglobina pre-transfusional y umbral de indicacion","Valorar signos de sobrecarga de hierro: hiperpigmentacion, hepatomegalia, disfuncion cardiaca","Registrar numero de transfusiones acumuladas y ferritina serica","Evaluar cumplimiento del tratamiento quelante","Valorar estado nutricional y curvas de crecimiento en pediatria","Evaluar repercusion psicosocial de la enfermedad cronica"],intervenciones:["Preparar y administrar transfusion de globulos rojos segun protocolo hospitalario","Verificar compatibilidad ABO-Rh y fenotipo eritrocitario extendido previo a transfusion","Monitorizar reacciones transfusionales durante toda la infusion","Administrar quelantes del hierro segun indicacion y educar sobre su uso","Coordinar con equipo de nutricion para optimizacion dietetica","Asegurar acceso venoso adecuado para transfusiones cronicas (valorar port-a-cath)"],educacionPaciente:["Explicar la naturaleza genetica de la enfermedad y la importancia del consejo familiar","Ense\xf1ar sobre el programa transfusional: frecuencia, duracion, riesgos","Instruir en administracion de quelantes del hierro y su importancia vital","Explicar signos de reacciones transfusionales que deben comunicarse inmediatamente","Orientar sobre evitar hierro suplementario no indicado por el medico","Informar sobre grupos de apoyo y asociaciones de pacientes con talasemia"],monitorizacion:["Hemoglobina pre-transfusional (objetivo > 9-10 g/dL en talasemia mayor)","Ferritina serica trimestral (objetivo < 1000 ng/mL con quelacion adecuada)","Funcion hepatica y renal mensual (toxicidad de quelantes)","Ecocardiograma anual (sobrecarga de hierro cardiaco)","Resonancia magnetica hepatica y cardiaca (T2*) para cuantificar hierro","Densitometria osea anual en adultos (osteoporosis frecuente)"]},npiNanda:[{codigo:"00093",nombre:"Fatiga",definicion:"Sensacion abrumadora y sostenida de agotamiento y capacidad disminuida para el trabajo mental y fisico habitual",caracteristicasDefinitorias:["Verbalizacion de cansancio constante","Incapacidad para mantener el nivel habitual de actividad fisica","Falta de energia para realizar actividades cotidianas","Hemoglobina baja que limita el transporte de oxigeno"],factoresRelacionados:["Anemia hemolitica cronica con reduccion del transporte de oxigeno","Eritropoyesis ineficaz","Estado de enfermedad cronica"]},{codigo:"00179",nombre:"Riesgo de glucemia inestable",definicion:"Vulnerable a variacion en los niveles de glucosa en sangre respecto al rango normal que puede comprometer la salud",caracteristicasDefinitorias:["Deposito de hierro en pancreas por multitransfusiones","Antecedente de diabetes relacionada con sobrecarga de hierro"],factoresRelacionados:["Hemocromatosis secundaria a transfusiones multiples","Deposito de hierro en celulas beta pancreaticas"]},{codigo:"00188",nombre:"Tendencia a adoptar conductas de riesgo para la salud",definicion:"Deterioro de la capacidad para modificar el estilo de vida / conducta de manera que mejore el nivel de salud",caracteristicasDefinitorias:["No cumple el regimen terapeutico quelante","Minimiza los cambios necesarios en el estilo de vida"],factoresRelacionados:["Complejidad del regimen terapeutico de por vida","Baja percepcion de beneficio del tratamiento quelante"]}],npiNic:[{codigo:"0560",nombre:"Manejo de la energia",actividades:["Planificar actividades que minimicen el gasto energetico","Educar al paciente en tecnicas de ahorro de energia","Programar transfusiones antes de actividades exigentes","Fomentar periodos de reposo intercalados con actividad","Monitorizar respuesta a la actividad y nivel de fatiga"]},{codigo:"7310",nombre:"Cuidados de apoyo durante el tratamiento",actividades:["Asegurar la correcta administracion de transfusiones segun protocolo","Supervisar la administracion de quelantes del hierro","Coordinar con el equipo multidisciplinario (hematologia, nutricion, cardiologia)","Proporcionar apoyo emocional durante el proceso transfusional"]}],npiNoc:[{codigo:"0005",nombre:"Tolerancia a la actividad",indicadores:["Saturacion de oxigeno en actividad dentro de rango normal","Frecuencia cardiaca de respuesta a la actividad normalizada","Capacidad para realizar actividades de la vida diaria sin fatiga excesiva","Hemoglobina en rango terapeutico post-transfusional"],escala:"1=Gravemente comprometida, 2=Sustancialmente comprometida, 3=Moderadamente comprometida, 4=Levemente comprometida, 5=No comprometida"},{codigo:"1813",nombre:"Conocimiento: regimen terapeutico",indicadores:["Describe correctamente el programa transfusional","Demuestra correcta administracion de quelantes","Identifica signos de reaccion transfusional","Cumple con controles analiticos periodicos"],escala:"1=Ningun conocimiento, 2=Conocimiento escaso, 3=Conocimiento moderado, 4=Conocimiento sustancial, 5=Conocimiento extenso"}],complicaciones:["Hemocromatosis secundaria (corazon, higado, pancreas, glandulas endocrinas)","Miocardiopatia por deposito de hierro (causa principal de muerte en talasemia mayor)","Cirrosis hepatica por deposito de hierro","Diabetes mellitus relacionada con talasemia","Hipogonadismo e infertilidad (deposito hipofisario)","Hipotiroidismo e hipoparatiroidismo","Osteoporosis y fracturas patologicas","Infecciones graves post-esplenectomia","Aloinmunizacion eritrocitaria por multitransfusiones"],criteriosAlarma:["Hemoglobina pre-transfusional < 7 g/dL con sintomas","Signos de insuficiencia cardiaca (disnea, edemas, ingurgitacion yugular)","Fiebre > 38.5 grados en paciente esplenectomizado (riesgo sepsis por capsulados)","Ferritina > 2500 ng/mL (sobrecarga grave de hierro)","Reaccion transfusional aguda: escalofrios, fiebre, dolor lumbar, hematuria"],emergencyLevel:"leve",relatedPathologyIds:["pat_anemias","pat_purpura_trombocitopenica","pat_policitemia","pat_mieloma"],isPremium:!0},{id:"pat_mieloma",nombre:"Mieloma Multiple",bodySystemId:"hematologico",definicion:"Neoplasia hematologica maligna caracterizada por la proliferacion clonal de plasmocitos en la medula osea que producen una inmunoglobulina monoclonal (proteina M) y ocasionan da\xf1o organico: hipercalcemia, insuficiencia renal, anemia y lesiones oseas (criterios CRAB).",epidemiologia:"Representa el 1% de todas las neoplasias y el 10% de las hematologicas. Incidencia de 6-7 casos por 100.000 habitantes/ano en paises occidentales. Mediana de edad al diagnostico: 65-70 a\xf1os. Mas frecuente en hombres (relacion 1.5:1) y en poblacion afroamericana. En Argentina, es la segunda neoplasia hematologica en frecuencia tras el linfoma.",factoresRiesgo:["Edad > 65 a\xf1os","Sexo masculino","Raza afroamericana","Antecedente de gammapatia monoclonal de significado incierto (GMSI; riesgo de progresion 1%/ano)","Exposicion a radiacion ionizante","Exposicion a pesticidas y solventes organicos","Obesidad","Antecedentes familiares de mieloma"],fisiopatologia:"Las c\xe9lulas plasm\xe1ticas malignas se acumulan en la m\xe9dula \xf3sea y producen una prote\xedna M (IgG, IgA, IgD, IgE o cadenas livianas kappa/lambda). Las c\xe9lulas del mieloma interaccionan con c\xe9lulas del estroma medular activando osteoclastos (via RANKL) e inhibiendo osteoblastos, causando lesiones osteol\xedticas. La prote\xedna M en exceso puede depositarse en ri\xf1ones causando nefropat\xeda por cilindros (cast nephropathy). La sustituci\xf3n de m\xe9dula normal produce pancitopenia y deficiencia inmunol\xf3gica por reducci\xf3n de inmunoglobulinas normales.",signosYSintomas:{signos:["Dolor oseo en columna vertebral y costillas (mas frecuente)","Lesiones osteoliticas en radiografias (imagen en sacabocados)","Fractura patologica vertebral o de huesos largos","Anemia normocitica normocromica","Hipercalcemia (calcio > 11 mg/dL)","Creatinina elevada (insuficiencia renal)","Pico monoclonal en electroforesis de proteinas s\xe9ricas","Proteinuria de Bence Jones en orina"],sintomas:["Dolor oseo de ritmo inflamatorio o mecanico (mas intenso en reposo o movimiento)","Fatiga intensa y debilidad","Confusion, nauseas, poliuria (hipercalcemia)","Infecciones bacterianas recurrentes (deficit inmunologico)","Parestesias o debilidad en miembros (compresion medular)","Perdida de peso y anorexia"]},clasificacion:{nombre:"Estadificacion de Durie-Salmon revisada (ISS - International Staging System)",tipos:[{nombre:"Estadio I (ISS)",descripcion:"Beta2-microglobulina < 3.5 mg/L y albumina >= 3.5 g/dL. Pronostico favorable."},{nombre:"Estadio II (ISS)",descripcion:"Ni estadio I ni estadio III. Pronostico intermedio."},{nombre:"Estadio III (ISS)",descripcion:"Beta2-microglobulina >= 5.5 mg/L. Pronostico desfavorable."},{nombre:"Mieloma multiple sintomatico (activo)",descripcion:"Presencia de criterios CRAB o biomarcadores de malignidad (plasmocitos >= 60%, cadenas livianas libres >= 100)"}]},diagnostico:{anamnesis:["Dolor oseo: localizacion, caracter, factores agravantes","Historia de infecciones bacterianas recurrentes (neumonia, sinusitis)","Sintomas de hipercalcemia: confusion, nauseas, poliuria, constipacion","Historia de fractura ante traumatismo minimo","Perdida de peso involuntaria","Antecedente de GMSI diagnosticada previamente"],examenFisico:["Evaluacion del dolor oseo a la palpacion y percusion vertebral","Signos neurologicos: fuerza, sensibilidad, reflejos (compresion medular)","Estado de hidratacion (hipercalcemia)","Palpacion hepatoesplenica (hepatomegalia leve posible)","Signos de anemia: palidez, taquicardia"],pruebas:[{nombre:"Electroforesis de proteinas sericas e inmunofijacion",descripcion:"Detecta e identifica el pico monoclonal (proteina M) y su isotipo (IgG, IgA, cadenas livianas)",valoresReferencia:"Ausencia de pico monoclonal normal; pico M > 3 g/dL sugiere mieloma activo",cuidadosEnfermeria:["Extraer muestra en tubo seco (sin anticoagulante) para suero","Indicar ayuno de 4 horas previo","Registrar farmacos que puedan interferir (gammaglobulinas exogenas)"]},{nombre:"Proteinuria de 24 horas con electroforesis urinaria",descripcion:"Detecta proteinuria de Bence Jones (cadenas livianas libres en orina); marcador de nefropatia por mieloma",valoresReferencia:"Normal: proteinuria < 150 mg/24h; en mieloma puede superar varios gramos",cuidadosEnfermeria:["Instruir recoleccion correcta de orina de 24 horas (desechar primera miccion)","Conservar en recipiente refrigerado durante la recoleccion","Registrar hora de inicio y fin de la recoleccion","Verificar volumen total al finalizar"]},{nombre:"Biopsia y aspirado de medula osea",descripcion:"Confirma el diagnostico: plasmocitosis >= 10% con morfologia mielomamatosa; citogenetica (FISH para alteraciones de mal pronostico)",valoresReferencia:"Normal: plasmocitos < 3-5%; mieloma: >= 10% de plasmocitos clonales",cuidadosEnfermeria:["Preparar campo esteril y bandeja de puncion","Administrar analgesia y ansiolisis segun prescripcion","Monitorizar constantes vitales durante y despues del procedimiento","Vigilar hematoma y sangrado en sitio de puncion","Indicar reposo relativo 24 horas post-procedimiento"]},{nombre:"Serie osea radiologica o PET-TAC",descripcion:"Identifica lesiones osteoliticas, fracturas patologicas y enfermedad extramedular",valoresReferencia:"Ausencia de lesiones osteoliticas en sujeto sano; en mieloma: lesiones en sacabocados en craneo, columna, pelvis",cuidadosEnfermeria:["Asegurar que el paciente pueda tolerar el decubito durante el estudio","Si se administra contraste para TAC: verificar funcion renal y alergias previas","Proporcionar analgesicos antes del estudio si hay dolor intenso","Ayudar en el posicionamiento cuidadoso evitando fracturas"]}]},tratamientoMedico:{objetivos:["Lograr respuesta al tratamiento (remision completa o muy buena respuesta parcial)","Prolongar supervivencia libre de progresion","Controlar las complicaciones organicas (CRAB)","Mejorar la calidad de vida del paciente"],farmacologico:[{nombre:"Bortezomib",grupo:"Inhibidor del proteosoma",mecanismo:"Inhibe el proteosoma 26S, alterando la degradacion de proteinas reguladoras del ciclo celular y la apoptosis; induce muerte de c\xe9lulas plasm\xe1ticas malignas",dosis:"1.3 mg/m2 SC o IV los dias 1, 4, 8 y 11 de cada ciclo de 21 dias (esquema VRd u otros)",cuidadosEnfermeria:["Administrar via SC (preferida) para reducir neuropatia periferica respecto a IV","Rotar sitios de inyeccion subcutanea entre muslo, abdomen y brazo","Monitorizar sintomas de neuropatia periferica: parestesias, dolor, debilidad (efecto limitante de dosis)","Vigilar herpes zoster: profilaxis con aciclovir obligatoria","Controlar presion arterial (puede causar hipotension ortost\xe1tica)"]},{nombre:"Lenalidomida",grupo:"Inmunomodulador (IMiD)",mecanismo:"Modula el sistema inmune, inhibe la angiogenesis tumoral, induce apoptosis de c\xe9lulas plasm\xe1ticas y tiene efecto anti-inflamatorio",dosis:"25 mg/dia VO los dias 1-21 de cada ciclo de 28 dias; ajustar por funcion renal",cuidadosEnfermeria:["Verificar resultado de test de embarazo negativo ANTES de cada ciclo (teratogenica categoria X)","Educar sobre anticoncepcion obligatoria durante el tratamiento y 4 semanas posteriores","Vigilar trombosis venosa profunda: profilaxis con AAS o HBPM segun riesgo","Controlar hemograma (mielosupresion: neutropenia, trombocitopenia)","Educiar sobre no compartir el medicamento bajo ningun concepto (programa REMS)"]},{nombre:"Acido zoledronico",grupo:"Bifosfonato IV",mecanismo:"Inhibe la farnesil-pirofosfato sintasa en osteoclastos, reduciendo la resorcion osea y previniendo nuevas lesiones osteoliticas y fracturas",dosis:"4 mg IV en 15 minutos cada 4 semanas (mensual); despues del primer ano cada 3 meses",cuidadosEnfermeria:["Verificar funcion renal ANTES de cada dosis (contraindicado si ClCr < 30 mL/min)","Asegurar hidratacion adecuada antes y despues de la infusion (500-1000 mL de SF)","Evaluar estado dental previo al inicio: riesgo de osteonecrosis de mandibula","Monitorizar calcemia y fosfatemia post-infusion","Vigilar dolor oseo agudo (reaccion de fase aguda en primeras 72h)"]}],noFarmacologico:["Trasplante autologo de celulas madre hematopoyeticas (en pacientes elegibles < 70-75 a\xf1os como consolidacion)","Radioterapia local en lesiones oseas dolorosas o compresion medular inminente","Ortesis y corse vertebral en fracturas por compresion","Cifoplastia o vertebroplastia en fracturas vertebrales sintomaticas","Hidratacion agresiva en nefropatia aguda por mieloma","Fisioterapia y rehabilitacion para mantener movilidad y prevenir complicaciones"]},cuidadosEnfermeria:{valoracion:["Evaluar intensidad y localizacion del dolor oseo (escala EVA)","Valorar signos neurologicos de compresion medular (urgencia oncologica)","Registrar nivel de hidratacion y diuresis (nefropatia)","Evaluar signos de hipercalcemia: confusion, nauseas, poliuria, constipacion","Valorar hemograma actual (citopenia por mieloma o quimioterapia)","Identificar riesgo de infeccion (inmunosupresion)"],intervenciones:["Administrar analgesicos segun escala multimodal (AINEs contraindicados en IR; usar paracetamol y opioides)","Posicionar al paciente con cuidado, evitando maniobras bruscas (riesgo de fractura)","Mantener hidratacion adecuada (objetivo diuresis > 100 mL/h en nefropatia aguda)","Administrar quimioterapia segun protocolo oncologico con medidas de seguridad citotoxica","Implementar precauciones de aislamiento en fases de neutropenia severa","Monitorizar y registrar balance hidrico estricto"],educacionPaciente:["Explicar la naturaleza de la enfermedad y los objetivos del tratamiento en terminos comprensibles","Instruir en signos de compresion medular (urgencia: comunicar inmediatamente debilidad o parestesias en miembros)","Ense\xf1ar signos de hipercalcemia y la importancia de buena hidratacion oral","Informar sobre riesgo de fractura: evitar movimientos bruscos y cargas excesivas","Educar sobre higiene bucal estricta durante tratamiento con bifosfonatos (prevencion de osteonecrosis mandibular)","Explicar la importancia del seguimiento hematologico regular y el calendario de quimioterapia"],monitorizacion:["Proteina M serica mensual (respuesta al tratamiento)","Hemograma completo antes de cada ciclo de quimioterapia","Creatinina, calcio y LDH en cada evaluacion","Dolor oseo diario con escala EVA","Evaluacion neurologica en cada visita (compresion medular)","Densidad mineral osea anual"]},npiNanda:[{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable ocasionada por una lesion tisular real o potencial o descrita en tales terminos",caracteristicasDefinitorias:["Informe verbal de dolor oseo intenso (EVA > 6)","Facies de dolor","Posicion antalgica","Taquicardia y diaforesis"],factoresRelacionados:["Lesiones osteoliticas y fracturas patologicas por infiltracion mielomatosa","Hipercalcemia que produce dolores musculares y oseos","Compresion de estructuras nerviosas por fracturas vertebrales"]},{codigo:"00016",nombre:"Deterioro de la eliminacion urinaria",definicion:"Disfuncion en la eliminacion urinaria",caracteristicasDefinitorias:["Oliguria","Creatinina elevada","Orina espumosa (proteinuria)"],factoresRelacionados:["Deposito de cadenas livianas en tubulos renales (cast nephropathy)","Hipercalcemia que causa vasoconstriccion renal","Deshidratacion por nauseas y vomitos"]},{codigo:"00004",nombre:"Riesgo de infeccion",definicion:"Vulnerable a ser invadido y multiplicado por organismos patogenos que puede comprometer la salud",caracteristicasDefinitorias:["Historia de infecciones bacterianas recurrentes","Neutropenia inducida por quimioterapia","Hipogammaglobulinemia por sustituci\xf3n de inmunoglobulinas normales"],factoresRelacionados:["Inmunodeficiencia humoral por reduccion de inmunoglobulinas policlonales","Neutropenia secundaria a quimioterapia","Procedimientos invasivos (via venosa central, biopsia)"]}],npiNic:[{codigo:"1400",nombre:"Manejo del dolor",actividades:["Valorar el dolor con escala EVA en cada contacto","Administrar analgesicos pautados y de rescate segun protocolo","Posicionar al paciente para alivio del dolor evitando maniobras que puedan provocar fractura","Aplicar frio o calor local segun preferencia y contraindicaciones","Coordinar con equipo de cuidados paliativos si el dolor es refractario"]},{codigo:"6550",nombre:"Proteccion contra las infecciones",actividades:["Implementar tecnica aseptica estricta en todos los procedimientos","Monitorizar temperatura cada 8 horas durante neutropenia","Educar al paciente sobre higiene de manos y evitar contacto con personas enfermas","Administrar profilaxis antibiotica y antiviral segun protocolo oncologico","Activar protocolo de neutropenia febril ante temperatura > 38 grados"]},{codigo:"0590",nombre:"Manejo de la eliminacion urinaria",actividades:["Registrar balance hidrico estricto (ingresos y egresos)","Monitorizar creatinina y urea cada 24-48h en fase aguda","Asegurar ingesta hidrica de al menos 2-3 L/dia","Avisar al medico si diuresis < 0.5 mL/kg/h","Preparar al paciente para hemodialisis si hay indicacion de urgencia"]}],npiNoc:[{codigo:"2102",nombre:"Nivel del dolor",indicadores:["Dolor referido en escala EVA <= 4","No interrumpe el sueno","Tolerancia a actividades basicas de autocuidado","No requiere escalada de analgesicos de emergencia"],escala:"1=Grave, 2=Sustancial, 3=Moderada, 4=Leve, 5=Ninguno"},{codigo:"0504",nombre:"Funcion renal",indicadores:["Creatinina serica en valores normales o estables","Diuresis > 0.5 mL/kg/h","Ausencia de edemas perifericos","Electrolitos en rango normal"],escala:"1=Gravemente comprometida, 2=Sustancialmente comprometida, 3=Moderadamente comprometida, 4=Levemente comprometida, 5=No comprometida"}],complicaciones:["Fractura patologica vertebral con compresion medular (emergencia oncologica)","Insuficiencia renal aguda o cronica por nefropatia del mieloma","Hipercalcemia severa con encefalopatia","Infecciones graves (neumonia, sepsis) por inmunodeficiencia","Trombosis venosa profunda y tromboembolismo pulmonar (asociado a lenalidomida)","Leucemia plasmacelular (transformacion terminal)","Amiloidosis primaria por deposito de cadenas livianas","Osteonecrosis de mandibula por bifosfonatos"],criteriosAlarma:["Debilidad o parestesias progresivas en miembros inferiores (compresion medular inminente)","Confusion aguda, nauseas y vomitos (hipercalcemia severa)","Fiebre > 38 grados con neutropenia (neutropenia febril)","Diuresis < 400 mL/24h (insuficiencia renal olig\xfarica)","Dolor oseo de inicio brusco e intenso (fractura patologica)","Disnea aguda (tromboembolismo pulmonar)"],emergencyLevel:"moderado",relatedPathologyIds:["pat_purpura_trombocitopenica","pat_neutropenia","pat_talasemia","pat_policitemia"],isPremium:!0},{id:"pat_policitemia",nombre:"Policitemia Vera",bodySystemId:"hematologico",definicion:"Neoplasia mieloproliferativa cronica clonal caracterizada por la expansion descontrolada de la masa eritroide (y frecuentemente de las otras series mieloides) independiente de la eritropoyetina, debida casi universalmente a la mutacion JAK2 V617F, que resulta en eritrocitosis absoluta con riesgo de trombosis y hemorragia.",epidemiologia:"Incidencia de 2-3 casos por 100.000 habitantes/ano. Mediana de edad al diagnostico: 60-65 a\xf1os. Ligero predominio masculino. Es la mas frecuente de las neoplasias mieloproliferativas. La mutacion JAK2 V617F esta presente en el 95-97% de los casos; el 3-5% restante tiene mutaciones en el exon 12 de JAK2.",factoresRiesgo:["Edad > 60 a\xf1os","Sexo masculino (leve predominio)","Antecedentes familiares de neoplasia mieloproliferativa","Exposicion a radiacion ionizante","Mutacion JAK2 V617F constitucional (hereditaria en casos raros)"],fisiopatologia:"La mutacion JAK2 V617F activa constitutivamente la via de se\xf1alizacion JAK2-STAT5, que normalmente requiere la union de eritropoyetina a su receptor para activarse. Esta activacion permanente induce proliferacion eritroide autonoma e independiente de EPO. La expansion de masa eritroide aumenta la viscosidad sanguinea, promoviendo trombosis en arterias (infarto, ACV) y venas (trombosis portal, Budd-Chiari). Paradojicamente, el exceso de eritrocitos puede alterar la funcion plaquetaria (adsorcion de factor de von Willebrand) causando tendencia hemorragica.",signosYSintomas:{signos:["Pl\xe9tora facial (rubicundez de cara, cuello y extremidades)","Esplenomegalia (en el 70% de los casos)","Eritrocitosis: hematocrito > 49% (H) o > 48% (M)","Hemoglobina > 16.5 g/dL (H) o > 16 g/dL (M)","Leucocitosis neutrofila (frecuente)","Trombocitosis (frecuente)","Hipertension arterial (por hiperviscosidad)"],sintomas:["Cefalea pulsatil y mareos","Prurito acuatico (sello clinico: prurito intenso post-bano con agua caliente)","Eritromelalgia: dolor urente en manos y pies con enrojecimiento","Tinnitus y vision borrosa","Fatiga cronica","Sudoracion nocturna","Disnea de esfuerzo"]},clasificacion:{nombre:"Criterios diagnosticos WHO 2022",tipos:[{nombre:"Policitemia Vera franca (clasica)",descripcion:"Eritrocitosis con Hb > 16.5 g/dL (H) / 16 g/dL (M) + JAK2 mutado + biopsia medular con hipercelularidad trilinaje"},{nombre:"Policitemia Vera enmascarada (masked PV)",descripcion:"Eritrocitosis relativa con valores de Hb en rango normal-alto, pero masa eritrocitaria elevada; requiere estudio de masa eritrocitaria con radioisotopos"},{nombre:"Fase post-policitica (mielofibrosis post-PV)",descripcion:"Evolucion a fibrosis medular; anemia progresiva, esplenomegalia masiva, citopenias"}]},diagnostico:{anamnesis:["Historia de trombosis previa (ACV, IAM, trombosis portal, Budd-Chiari)","Prurito acuatico post-bano","Cefalea cronica y trastornos visuales","Antecedentes familiares de neoplasias mieloproliferativas","Enfermedades pulmonares o cardiacas (policitemia secundaria)"],examenFisico:["Inspeccion: pl\xe9tora facial, cianosis acral, eritromelalgia en manos/pies","Palpacion abdominal: tamano y consistencia del bazo","Presion arterial: frecuente hipertension por hiperviscosidad","Auscultacion cardiaca: soplos por hiperviscosidad","Evaluacion neurologica: signos focales (trombosis cerebrovascular)"],pruebas:[{nombre:"Hemograma completo con recuento diferencial",descripcion:"Revela eritrocitosis, leucocitosis y trombocitosis (panmielosis); base del diagnostico inicial",valoresReferencia:"Hb normal: 13.5-17.5 g/dL (H), 12-15.5 g/dL (M); en PV: Hb > 16.5 (H) / 16 (M) g/dL",cuidadosEnfermeria:["Obtener muestra en tubo EDTA en correcta proporcion","Registrar hora de extraccion (valores pueden variar por deshidratacion)","No comprimir el tubo ni agitar vigorosamente"]},{nombre:"Determinacion de mutacion JAK2 V617F (PCR alelo-especifica)",descripcion:"Confirma el origen clonal de la eritrocitosis; positivo en 95-97% de PV",valoresReferencia:"Resultado cualitativo: presencia o ausencia de la mutacion; carga al\xe9lica (%) en casos positivos",cuidadosEnfermeria:["Extraer en tubo EDTA (sangre total para ADN genomico)","Mantener a temperatura ambiente y procesar en menos de 72 horas","Informar al paciente que el resultado puede tardar 7-14 dias"]},{nombre:"Eritropoyetina serica",descripcion:"Niveles bajos o indetectables en PV (eritropoyesis independiente de EPO); eleva en poliglobulia secundaria",valoresReferencia:"EPO normal: 4-26 mUI/mL; en PV: frecuentemente < 4 mUI/mL o indetectable",cuidadosEnfermeria:["Muestra en suero (tubo seco o de gel)","No requiere ayuno","Centrifugar dentro de la primera hora"]},{nombre:"Biopsia de medula osea",descripcion:"Demuestra hipercelularidad con panmielosis (proliferacion de los tres linajes); megacariocitos pleomorfos agrupados",valoresReferencia:"Celularidad normal ajustada por edad; en PV: hipercelularidad con panmielosis",cuidadosEnfermeria:["Preparar material y campo esteril","Administrar analgesia y sedacion leve segun protocolo","Vigilar signos vitales durante y 1 hora post-procedimiento","Mantener compresion sobre sitio de puncion durante 10 minutos","Indicar reposo relativo 24-48 horas"]}]},tratamientoMedico:{objetivos:["Reducir el riesgo de trombosis cardiovascular","Mantener hematocrito < 45% (objetivo principal de flebotomia)","Controlar los sintomas relacionados con hiperviscosidad","Prevenir la transformacion a mielofibrosis o leucemia mieloide aguda"],farmacologico:[{nombre:"Hidroxiurea (hidroxicarbamida)",grupo:"Citostatico / agente mielosupresor",mecanismo:"Inhibe la ribonucleotido reductasa, reduciendo la sintesis de ADN y la proliferacion de celulas hematopoyeticas en todos los linajes mieloides",dosis:"15-20 mg/kg/dia VO en dosis unica; ajustar segun respuesta hematologica",cuidadosEnfermeria:["Monitorizar hemograma completo cada 4-6 semanas al inicio","Vigilar ulceras en piernas (efecto adverso frecuente a largo plazo)","Educar sobre fotosensibilidad y uso de protector solar","Controlar uricemia (puede elevar acido urico)","Instruir sobre medidas de anticoncepcion (teratogenica)"]},{nombre:"Acido acetilsalicilico (AAS) a dosis bajas",grupo:"Antiagregante plaquetario",mecanismo:"Inhibe irreversiblemente la COX-1 plaquetaria, reduciendo la sintesis de tromboxano A2 y la agregacion plaquetaria, disminuyendo el riesgo tromb\xf3tico",dosis:"100 mg/dia VO con alimentos",cuidadosEnfermeria:["Administrar con alimentos o anti\xe1cido si hay dispepsia","Monitorizar signos de sangrado gastrointestinal (melena, dolor epigastrico)","Verificar ausencia de contraindicaciones: sangrado activo, ulcera peptica activa","Advertir sobre aumento del riesgo hemorragico si se asocian otros antiagregantes o anticoagulantes"]},{nombre:"Ruxolitinib",grupo:"Inhibidor de JAK1/JAK2",mecanismo:"Bloquea selectivamente las quinasas JAK1 y JAK2, interrumpiendo la via de se\xf1alizacion JAK-STAT responsable de la proliferacion clonal en PV",dosis:"10 mg VO dos veces al dia; ajustar segun respuesta y tolerancia (max 25 mg dos veces al dia)",cuidadosEnfermeria:["Monitorizar hemograma: puede producir anemia y trombocitopenia","Vigilar infecciones oportunistas (herpes zoster: profilaxis con aciclovir recomendada)","No suspender bruscamente (riesgo de sindrome de abstinencia con esplenomegalia rebote)","Controlar perfil lipidico (dislipemia como efecto adverso)","Administrar a horas regulares con o sin alimentos"]}],noFarmacologico:["Flebotomia terap\xe9utica: extraccion de 300-500 mL de sangre para reducir hematocrito < 45% (tratamiento de primera linea en todo paciente con PV)","Hidratacion adecuada (al menos 2 L/dia) para reducir viscosidad","Evitar deshidratacion y altitudes elevadas (aumentan viscosidad)","Control riguroso de factores de riesgo cardiovascular (HTA, tabaquismo, dislipemia)","Cese obligatorio del tabaquismo","Uso de medias de compresion en pacientes con riesgo de trombosis venosa"]},cuidadosEnfermeria:{valoracion:["Registrar hematocrito y hemoglobina actuales","Evaluar signos de hiperviscosidad: cefalea, vision borrosa, eritromelalgia","Vigilar signos de trombosis: dolor, edema, calor en extremidades; deficit neurologico focal","Valorar prurito acuatico y su impacto en la calidad de vida","Evaluar signos de sangrado (epistaxis, hemoptisis, melena)","Registrar hematocrito y respuesta a flebotomias previas"],intervenciones:["Realizar flebotomia terap\xe9utica segun prescripcion medica (300-500 mL con reposicion de suero fisiologico)","Monitorizar PA y FC antes, durante y despues de la flebotomia","Administrar farmacoterapia segun indicacion (hidroxiurea, AAS, ruxolitinib)","Aplicar medidas de hidratacion activa","Asegurar reposo post-flebotomia hasta estabilizacion hemodin\xe1mica","Coordinar seguimiento hematologico regular"],educacionPaciente:["Explicar la importancia del control del hematocrito < 45% para prevenir trombosis","Instruir sobre signos de trombosis arterial y venosa que requieren atencion urgente","Educar sobre hidratacion suficiente diaria (minimo 2 litros)","Recomendar evitar deshidratacion, viajes aereos prolongados y altitudes elevadas sin consulta previa","Instruir sobre cuidado de la piel ante ulceras (efecto de hidroxiurea)","Ense\xf1ar reconocimiento de prurito acuatico como signo de la enfermedad"],monitorizacion:["Hematocrito antes de cada flebotomia (objetivo < 45%)","Hemograma completo cada 4-6 semanas","Uricemia periodica (riesgo de gota por recambio celular acelerado)","Presion arterial en cada consulta","Signos de trombosis en cada evaluacion","Evolucion del tamano espl\xe9nico (palpacion y ecografia)"]},npiNanda:[{codigo:"00291",nombre:"Riesgo de trombosis",definicion:"Vulnerable a la obstruccion de un vaso sanguineo por un trombo que puede comprometer la salud",caracteristicasDefinitorias:["Hematocrito elevado > 49%","Trombocitosis > 600.000/uL","Antecedente de episodio tromb\xf3tico previo"],factoresRelacionados:["Hiperviscosidad sanguinea por eritrocitosis absoluta","Activacion plaquetaria por mutacion JAK2","Deshidratacion que agrava la viscosidad"]},{codigo:"00049",nombre:"Disminucion de la capacidad adaptativa intracraneal",definicion:"Mecanismo de compensacion intracraneal dinamico que resulta en un patron de disparo desproporcionado entre estimulos y respuestas intracraneales",caracteristicasDefinitorias:["Cefalea cronica","Tinnitus y vision borrosa","Hematocrito elevado con hiperviscosidad"],factoresRelacionados:["Hiperviscosidad por eritrocitosis que reduce el flujo microvascular cerebral","Riesgo de trombosis de peque\xf1os vasos cerebrales"]},{codigo:"00133",nombre:"Dolor cronico",definicion:"Experiencia sensitiva y emocional desagradable asociada con da\xf1o tisular real o potencial, que se describe en estos terminos, y que tiene un inicio subito o lento de cualquier intensidad de leve a grave, que no cesa y que ocurre durante mas de 3 meses",caracteristicasDefinitorias:["Prurito acuatico cronico post-bano","Eritromelalgia: dolor urente en extremidades","Alteracion del patron de sueno por sintomas"],factoresRelacionados:["Liberacion de histamina por bas\xf3filos y mastocitos estimulados por JAK2","Activacion de fibras nerviosas cutaneas por prostaglandinas y citocinas"]}],npiNic:[{codigo:"4232",nombre:"Flebotomia: muestra de sangre",actividades:["Verificar prescripcion medica de flebotomia terapeutica con volumen indicado","Monitorizar PA y FC antes, durante y despues del procedimiento","Infundir volumen de reposicion (SF 0.9%) simultaneamente","Registrar volumen extraido, tolerancia del paciente y valores de hematocrito post-flebotomia","Indicar reposo en cama durante 30 minutos post-procedimiento"]},{codigo:"4040",nombre:"Cuidados cardiacos",actividades:["Monitorizar signos vitales y saturacion de oxigeno","Vigilar signos de trombosis arterial: dolor toracico, deficit neurologico, isquemia de extremidades","Asegurar hidratacion adecuada para reducir viscosidad","Administrar AAS segun prescripcion para antiagregacion","Coordinar con cardiologia ante eventos agudos"]}],npiNoc:[{codigo:"0401",nombre:"Estado circulatorio",indicadores:["Hematocrito < 45% mantenido","Ausencia de eventos tromb\xf3ticos","PA en rango normal","Saturacion de oxigeno > 95%"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"},{codigo:"1908",nombre:"Deteccion del riesgo",indicadores:["Reconoce signos de trombosis que requieren atencion urgente","Mantiene hidratacion adecuada","Acude a controles de hematocrito programados","Identifica situaciones de riesgo (deshidratacion, altitud)"],escala:"1=Nunca demostrado, 2=Raramente demostrado, 3=A veces demostrado, 4=Frecuentemente demostrado, 5=Siempre demostrado"}],complicaciones:["Trombosis arterial: infarto agudo de miocardio, accidente cerebrovascular isquemico","Trombosis venosa: trombosis portal, sindrome de Budd-Chiari, tromboembolismo pulmonar","Transformacion a mielofibrosis post-policemica (10-15% a 15 a\xf1os)","Transformacion a leucemia mieloide aguda (2-5% a 15 a\xf1os)","Complicaciones hemorragicas (sangrado gastrointestinal, epistaxis masiva)","Gota (hiperuricemia por recambio celular)","Hipertension portal secundaria a trombosis esplenoportal","Eritromelalgia severa con isquemia digital"],criteriosAlarma:["Deficit neurologico focal agudo (ACV isquemico por trombosis)","Dolor toracico con cambios en ECG (IAM)","Dolor abdominal agudo intenso (trombosis portal o mesenterica)","Hematocrito > 55% (hiperviscosidad extrema)","Epistaxis masiva o sangrado gastrointestinal activo","Eritromelalgia severa con signos de isquemia digital"],emergencyLevel:"moderado",relatedPathologyIds:["pat_hta","pat_iam","pat_acv","pat_mieloma","pat_talasemia"],isPremium:!0},{id:"pat_neutropenia",nombre:"Neutropenia Febril",bodySystemId:"hematologico",definicion:"Sindrome de urgencia oncologica definido por la concurrencia de neutropenia absoluta (recuento absoluto de neutrofilos < 500 celulas/uL o < 1000/uL con caida predecible a < 500/uL en 48 horas) y fiebre (temperatura unica >= 38.3\xb0C axilar o >= 38\xb0C durante >= 1 hora), frecuentemente en el contexto de quimioterapia o enfermedad hematologica subyacente.",epidemiologia:"Ocurre en el 10-50% de los pacientes con tumores solidos y en hasta el 80% de los pacientes con neoplasias hematologicas que reciben quimioterapia intensiva. Es la causa mas frecuente de hospitalizacion urgente en pacientes oncoHematologicos. La mortalidad asociada oscila entre el 5-20% segun el tipo de cancer, la profundidad de la neutropenia y la presencia de complicaciones.",factoresRiesgo:["Quimioterapia mielosupresora reciente (nadir tipicamente a los 7-14 dias del ciclo)","Neoplasias hematologicas (LMA, LLA, linfoma de alto grado)","Trasplante de celulas madre hematopoyeticas","Edad > 65 a\xf1os","Estado funcional deteriorado (ECOG > 2)","Comorbilidades significativas (IRC, hepatopatia, DM)","Episodio previo de neutropenia febril","Albumina baja (< 3.5 g/dL) como marcador de desnutricion"],fisiopatologia:"La quimioterapia (y la enfermedad hematologica de base) suprime la produccion medular de neutrofilos. Los neutrofilos son la primera linea de defensa contra bacterias y hongos; su deficit (< 500/uL) rompe esta barrera. La flora comensal de mucosas (boca, intestino) da\xf1adas por la quimioterapia o la enfermedad transloca facilmente a la sangre. Sin la respuesta inflamatoria neutrofilica, los signos clasicos de infeccion (pus, induraci\xf3n, radiografia consolidada) pueden estar ausentes; la fiebre puede ser el UNICO indicador. Los agentes mas frecuentes son bacilos gramnegativos (E. coli, Klebsiella, Pseudomonas) y cocos grampositivos (Staphylococcus epidermidis en pacientes con cateter, Streptococcus viridans).",signosYSintomas:{signos:["Fiebre >= 38.3\xb0C (o >= 38\xb0C en >= 1 hora) - SIGNO CARDINAL","Recuento absoluto de neutrofilos (RAN) < 500/uL en hemograma","Taquicardia (compensacion ante posible bacteriemia)","Hipotension (signo de sepsis grave o shock septico)","Mucositis oral visible","Eritema, dolor o pus en sitio de cateter venoso central"],sintomas:["Fiebre con escalofrios (bacteriemia)","Ausencia de sintomas localizadores en muchos casos (por falta de neutrofilos para formar pus)","Odinofagia (infeccion orofaringea)","Diarrea (colitis por Clostridium o infeccion intestinal)","Dolor en flanco (pielonefritis subcl\xednica)","Tos seca o disnea (neumonia neutropenica)","Confusi\xf3n o alteracion del nivel de conciencia (shock septico)"]},clasificacion:{nombre:"Estratificacion de riesgo MASCC (Multinational Association of Supportive Care in Cancer)",tipos:[{nombre:"Bajo riesgo (MASCC >= 21 puntos)",descripcion:"Sin comorbilidades graves, sin hipotension, neutropenia < 7 dias esperada, no hematologico. Puede considerarse tratamiento ambulatorio con antibioticos orales."},{nombre:"Alto riesgo (MASCC < 21 puntos)",descripcion:"Neoplasia hematologica, neutropenia profunda y prolongada esperada (> 7 dias), comorbilidades graves, sepsis. Requiere hospitalizacion y antibioticos IV empiricos inmediatos."}]},diagnostico:{anamnesis:["Tipo de neoplasia y esquema de quimioterapia recibida y fecha del ultimo ciclo","Numero de dias desde el ultimo ciclo (nadir esperado)","Tiempo de evolucion de la fiebre","Sintomas localizadores: dolor orofaringeo, tos, disuria, dolor abdominal, alteraciones en cateter","Episodios previos de neutropenia febril y agentes causantes","Alergias a antibioticos"],examenFisico:["Toma de temperatura (criterio diagnostico)","Frecuencia cardiaca y presion arterial (signos de sepsis)","Examen minucioso de orofaringe: mucositis, placas, aftas","Inspeccion de sitios de cateter venoso central: eritema, calor, pus, tunelitis","Auscultacion pulmonar (consolidacion ausente en neutropenia pese a neumonia)","Examen de piel: lesiones cutaneas, petequias, eccema (infeccion por Candida o Aspergillus)","Examen perianal (evitar tacto rectal por riesgo de bacteriemia)"],pruebas:[{nombre:"Hemograma con recuento diferencial urgente",descripcion:"Confirma neutropenia: RAN < 500/uL; evalua otras citopenias (anemia, trombocitopenia)",valoresReferencia:"RAN normal: 1800-7700/uL; neutropenia severa: < 500/uL; profunda: < 100/uL",cuidadosEnfermeria:["Obtener ANTES de iniciar antibioticos si es posible (no demorar mas de 1 hora el inicio de tratamiento)","Extraer con tecnica aseptica estricta por riesgo de bacteriemia durante la puncion","Aplicar presion prolongada post-extraccion (trombocitopenia frecuente asociada)","Resultado URGENTE: comunicar al medico de inmediato"]},{nombre:"Hemocultivos x2 (uno de vena periferica y uno de cada lumen del cateter central)",descripcion:"Identifican el agente causal en el 20-30% de los casos; guian la desescalada antibiotica",valoresReferencia:"Normal: ausencia de desarrollo bacteriano o fungico",cuidadosEnfermeria:["Obtener ANTES de iniciar antibioticos (critico para sensibilidad del cultivo)","Tecnica aseptica rigurosa en la extraccion (reducir contaminacion con flora cutanea)","Inocular en frascos de aerobios y anaerobios, llenando al menos 10 mL por frasco","Transportar al laboratorio a temperatura ambiente e inmediatamente","Documentar hora exacta de extraccion y via utilizada"]},{nombre:"Urocultivo y sedimento urinario",descripcion:"Descarta infeccion urinaria como foco; la infeccion urinaria puede ser silente en neutropenia",valoresReferencia:"Normal: < 10.000 UFC/mL",cuidadosEnfermeria:["Obtener por chorro medio con tecnica aseptica","Si el paciente tiene sonda vesical: obtener muestra del puerto lateral con tecnica aseptica","Procesar antes de 2 horas o refrigerar"]},{nombre:"TAC de torax de alta resolucion",descripcion:"Detecta neumonia neutropenica o aspergilosis pulmonar invasiva (signos como el halo sign en aspergilosis); la RX de torax puede ser normal pese a neumonia",valoresReferencia:"Sin consolidaciones, sin infiltrados, sin derrame pleural en TAC normal",cuidadosEnfermeria:["Acompa\xf1ar al paciente si el estado clinico lo requiere (riesgo de deterioro rapido)","Verificar funcion renal y alergias si se administra contraste","Mantener medidas de aislamiento durante el traslado","Priorizar el estudio como urgente ante sospecha de aspergilosis"]},{nombre:"Galactomanano serico (Aspergillus)",descripcion:"Biomarcador de aspergilosis invasiva; util en pacientes de alto riesgo (trasplantados, LMA en induccion)",valoresReferencia:"Indice < 0.5: negativo; >= 0.5: positivo (requiere confirmacion con TAC y cultivo)",cuidadosEnfermeria:["Extraer en tubo de suero (sin anticoagulante)","No puede obtenerse en pacientes que reciben piperacilina-tazobactam (falsos positivos)","Transportar refrigerado al laboratorio de microbiologia especializado"]}]},tratamientoMedico:{objetivos:["Iniciar antibioterapia empirica de amplio espectro en la primera hora del diagnostico","Cubrir bacilos gramnegativos incluyendo Pseudomonas aeruginosa","Controlar el foco infeccioso identificado","Prevenir la progresion a sepsis grave y shock septico","Lograr recuperacion de neutrofilo (RAN > 500/uL) como meta biologica"],farmacologico:[{nombre:"Piperacilina-Tazobactam",grupo:"Beta-lactamico con inhibidor de beta-lactamasa (antibiotico empirico de primera linea)",mecanismo:"La piperacilina inhibe la sintesis de pared bacteriana; el tazobactam inhibe las beta-lactamasas de espectro extendido; cobertura amplia incluyendo Pseudomonas y enterobacterias",dosis:"4.5 g IV cada 6-8 horas (o 3.375 g/6h); ajustar en insuficiencia renal",cuidadosEnfermeria:["INICIAR EN LA PRIMERA HORA del diagnostico de neutropenia febril (objetivo Hora 1)","Preparar en SF 0.9% 100-150 mL e infundir en 30 minutos","Verificar alergias a penicilinas previo a la administracion","Monitorizar funcion renal (puede causar nefrotoxicidad en combinacion con aminoglucosidos)","Documentar hora exacta de inicio del antibiotico"]},{nombre:"Amikacina",grupo:"Aminoglucosido (se agrega en sepsis grave o resistencia sospechada)",mecanismo:"Inhibe la sintesis proteica bacteriana uniendose a la subunidad 30S del ribosoma; efecto bactericida sinergico con beta-lactamicos contra gramnegativos incluyendo Pseudomonas",dosis:"15-20 mg/kg/dia IV en dosis unica diaria (infusion en 30-60 minutos)",cuidadosEnfermeria:["Obtener nivel valle (antes de la dosis) a partir de la tercera dosis para ajuste","Monitorizar funcion renal y diuresis diariamente (nefrotoxicidad)","Vigilar ototoxicidad: preguntar por tinitus o hipoacusia en cada evaluacion","Preparar en SF 0.9% 100-200 mL; no mezclar con beta-lactamicos en el mismo frasco","Ajustar dosis segun aclaramiento de creatinina"]},{nombre:"Factor estimulante de colonias de granulocitos (G-CSF) - Filgrastim",grupo:"Factor de crecimiento hematopoyetico",mecanismo:"Estimula la proliferacion, diferenciacion y activacion funcional de los precursores de neutrofilos en medula osea, acelerando la recuperacion de la neutropenia",dosis:"5 microgramos/kg/dia SC hasta recuperacion de neutrofilo (RAN > 500/uL x 2 dias consecutivos); puede iniciarse 24-72h despues de la quimioterapia como profilaxis",cuidadosEnfermeria:["Administrar por via subcutanea en abdomen, muslo o brazo con tecnica aseptica","Conservar en refrigerador entre 2-8 grados; sacar 30 minutos antes de la administracion","Advertir sobre dolor oseo (efecto adverso frecuente por expansion medular) y recomendar paracetamol","No agitar el vial (puede desnaturalizar la proteina)","Monitorizar hemograma diario para objetivar recuperacion de neutrofilos"]}],noFarmacologico:["Aislamiento protector (habitacion individual con presion positiva o al menos habitacion individual con restriccion de visitas)","Precauciones de aislamiento inverso: mascarilla, guantes y bata para todo el personal y visitas","Higiene de manos estricta como medida mas importante de prevencion de infecciones","Dieta de neutropenia (evitar alimentos crudos, vegetales sin cocinar, quesos frescos, carnes poco cocidas)","Cuidado oral intensivo para reducir mucositis (enjuagues con bicarbonato, nistatina profilactica)","Cuidado de la piel perianal con higiene rigurosa sin tacto rectal"]},cuidadosEnfermeria:{valoracion:["Registrar temperatura cada 4 horas (y de inmediato ante escalofrios)","Monitorizar signos vitales completos: buscar signos precoces de sepsis (taquicardia, taquipnea, hipotension)","Evaluar RAN del hemograma actual y tendencia","Inspeccionar sitio de cateter venoso central en cada turno","Valorar mucositis oral (escala OMS o OMAS)","Evaluar nivel de conciencia (deterioro puede indicar sepsis grave)"],intervenciones:["ACTIVAR PROTOCOLO NEUTROPENIA FEBRIL ante temperatura >= 38.3\xb0C con neutropenia","Obtener hemocultivos (x2) y urocultivo ANTES de iniciar antibioticos","Iniciar antibioticos empiricos IV en la PRIMERA HORA (objetivo Time to Antibiotics < 60 min)","Implementar aislamiento protector y medidas de higiene estrictas","Administrar G-CSF segun prescripcion medica","Mantener balance hidrico estricto (objetivo diuresis > 0.5 mL/kg/h)","Cuidado de mucositis: enjuagues cada 2-4 horas con solucion de bicarbonato 1%"],educacionPaciente:["Instruir al paciente a reportar INMEDIATAMENTE cualquier fiebre > 38\xb0C o escalofrios durante el nadir de neutropenia","Explicar que la fiebre puede ser el UNICO signo de infeccion grave durante la neutropenia","Ense\xf1ar higiene de manos: antes y despues de comer, despues del bano, antes de tocar heridas","Instruir sobre dieta de neutropenia: evitar crudos, no consumir agua no filtrada","Educar sobre cuidado de la cavidad oral: cepillado suave, enjuagues frecuentes","Indicar que no deben automedicarse con antibioticos ni antitermicos sin consultar antes"],monitorizacion:["Temperatura cada 4 horas (minimo); continua si hay fiebre activa","Signos vitales completos cada 4-8 horas segun gravedad","Hemograma diario hasta recuperacion de neutrofilos","Hemocultivos de control si fiebre persiste > 72 horas","Funcion renal y electrolitos diarios (toxicidad antibioticos y sepsis)","Balance hidrico horario en sepsis grave o shock septico","Saturacion de oxigeno continua si hay afeccion pulmonar"]},npiNanda:[{codigo:"00004",nombre:"Riesgo de infeccion",definicion:"Vulnerable a ser invadido y multiplicado por organismos patogenos que puede comprometer la salud",caracteristicasDefinitorias:["RAN < 500/uL (neutropenia severa)","Mucositis grado >= 2 como puerta de entrada","Cateter venoso central como reservorio potencial de biofilm"],factoresRelacionados:["Inmunosupresion profunda por quimioterapia mielosupresora","Destruccion de barreras mucosas por mucositis","Procedimientos invasivos (cateter venoso central, flebotomias repetidas)"]},{codigo:"00031",nombre:"Limpieza ineficaz de las vias aereas",definicion:"Incapacidad para eliminar las secreciones u obstrucciones del tracto respiratorio para mantener las vias aereas permeables",caracteristicasDefinitorias:["Cambios en la frecuencia respiratoria","Ausencia de fiebre pese a consolidacion radiologica (por falta de neutrofilos)","Hipoxemia con saturacion reducida"],factoresRelacionados:["Neumonia neutropenica con exudado inflamatorio minimo","Debilidad muscular por enfermedad sistemica","Mucositis que dificulta la expectoracion"]},{codigo:"00002",nombre:"Desequilibrio nutricional: ingesta inferior a las necesidades",definicion:"Ingesta de nutrientes insuficiente para satisfacer las necesidades metabolicas",caracteristicasDefinitorias:["Perdida de peso > 10% del peso habitual","Mucositis que impide la ingesta oral","Nauseas y vomitos por quimioterapia"],factoresRelacionados:["Incapacidad para ingerir alimentos por mucositis y odinofagia","Anorexia relacionada con el cancer y la quimioterapia","Aumento de requerimientos metabolicos por estado febril e infeccion"]}],npiNic:[{codigo:"6550",nombre:"Proteccion contra las infecciones",actividades:["Activar protocolo de neutropenia febril de forma inmediata ante temperatura >= 38.3\xb0C","Obtener hemocultivos y urocultivo antes de iniciar antibioticos","Iniciar antibioticoterapia empirica IV en la primera hora","Implementar aislamiento protector con higiene de manos estricta","Vigilar signos de infeccion por hongos (placas orales, lesiones cutaneas)","Revisar sitio de cateter venoso central en cada turno"]},{codigo:"7610",nombre:"Examen de laboratorio",actividades:["Obtener y enviar hemograma urgente con recuento diferencial","Coordinar obtencion de hemocultivos antes del antibiotico empirico","Monitorizar resultados de cultivos y comunicar al medico al obtenerlos","Controlar funcion renal y electrolitos diariamente","Registrar y reportar cambios significativos en el RAN"]},{codigo:"1160",nombre:"Monitorizacion nutricional",actividades:["Valorar capacidad de ingesta oral en presencia de mucositis","Coordinar con nutricion para soporte enteral si mucositis grado >= 3","Ofrecer dieta adaptada a neutropenia (alimentos cocidos, sin crudos)","Monitorizar peso cada 48 horas","Asegurar hidratacion IV si la ingesta oral es insuficiente"]}],npiNoc:[{codigo:"0702",nombre:"Estado inmune",indicadores:["RAN en recuperacion (tendencia ascendente > 500/uL)","Temperatura < 37.5\xb0C en dos evaluaciones consecutivas","Ausencia de nuevos focos de infeccion","Hemocultivos negativos tras inicio de antibioticos"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"},{codigo:"0800",nombre:"Termorregulacion",indicadores:["Temperatura corporal entre 36.5 y 37.5\xb0C","Ausencia de escalofrios","FC y FR en rango normal","No requiere antitermicos en las ultimas 24 horas"],escala:"1=Gravemente comprometida, 2=Sustancialmente comprometida, 3=Moderadamente comprometida, 4=Levemente comprometida, 5=No comprometida"}],complicaciones:["Shock septico (mortalidad > 30-50% si no se trata en la primera hora)","Aspergilosis pulmonar invasiva (mortalidad > 50% en inmunocomprometidos)","Candidemia (infeccion sistemica por Candida)","Neumonia neutropenica grave con insuficiencia respiratoria","Bacteriemia por Pseudomonas aeruginosa (gram negativo mas letal en neutropenia)","Tiflitis (enterocolitis neutropenica) por infeccion del ciego","Infeccion del cateter venoso central con bacteriemia asociada","Muerte si el antibiotico empirico no se inicia en la primera hora"],criteriosAlarma:["Temperatura >= 38.3\xb0C con RAN < 500/uL (ACTIVAR PROTOCOLO INMEDIATAMENTE)","Hipotension (PAS < 90 mmHg) con fiebre (shock septico)","Taquipnea > 30 rpm o saturacion < 92% (sepsis con disfuncion respiratoria)","Confusion o alteracion del nivel de conciencia (sepsis con disfuncion cerebral)","Tiempo de inicio de antibioticos > 60 minutos desde el diagnostico (factor de riesgo de mortalidad)","Fiebre persistente > 72 horas sin foco identificado (escalar a antifungicos empiricos)"],emergencyLevel:"critico",relatedPathologyIds:["pat_mieloma","pat_purpura_trombocitopenica","pat_talasemia","pat_leucemia"],isPremium:!0},{id:"pat_artritis_reactiva",nombre:"Artritis Reactiva (Sindrome de Reiter)",bodySystemId:"inmunologico",definicion:"Artritis reactiva es una artropatia inflamatoria aseptica que se desarrolla dias a semanas despues de una infeccion extraarticular, tipicamente gastrointestinal o urogenital. Antiguamente denominada Sindrome de Reiter cuando se presenta con la triada clasica de artritis, uretritis y conjuntivitis.",epidemiologia:"Incidencia de 30-40 casos por 100.000 habitantes. Predomina en adultos jovenes entre 20-40 a\xf1os. La forma urogenital es mas frecuente en hombres (relacion 9:1), mientras que la forma postenterica afecta ambos sexos por igual. Desencadenada principalmente por Chlamydia trachomatis, Salmonella, Shigella, Yersinia y Campylobacter.",factoresRiesgo:["Portador del antigeno HLA-B27 (aumenta riesgo 50 veces)","Infeccion urogenital por Chlamydia trachomatis","Gastroenteritis bacteriana (Salmonella, Shigella, Yersinia, Campylobacter)","Sexo masculino para la forma urogenital","Inmunosupresion (VIH aumenta severidad)","Antecedentes familiares de espondiloartropatias","Promiscuidad sexual sin proteccion"],fisiopatologia:"Los microorganismos desencadenantes estimulan una respuesta inmune en individuos geneticamente predispuestos (HLA-B27). Los antigenos bacterianos o el material genetico del microorganismo migra desde el sitio de infeccion primaria hasta la sinovial articular, donde activan linfocitos T CD4+ y CD8+. La activacion inmune genera inflamacion sinovial con produccion de TNF-alfa, IL-1 e IL-6. En portadores de HLA-B27, la presentacion aberrante de peptidos bacterianos puede provocar mimetismo molecular con tejidos propios, perpetuando la inflamacion articular.",signosYSintomas:{signos:["Artritis asimetrica oligoarticular en miembros inferiores (rodilla, tobillo, pie)","Sinovitis con derrame articular","Dactilitis (dedos en salchicha)","Entesopatia (inflamacion en inserciones tendinosas, especialmente talon)","Conjuntivitis bilateral no purulenta","Uretritis o cervicitis","Lesiones mucocutaneas (queratodermia blenorragica, balanitis circinada)","Ulceras orales indoloras"],sintomas:["Dolor articular de caracter inflamatorio (peor en reposo, mejora con movimiento)","Rigidez matutina mayor a 30 minutos","Ardor uretral o disuria","Dolor ocular y fotofobia","Fiebre de bajo grado","Malestar general y fatiga","Dolor lumbar bajo (sacroileitis en casos cronicos)"]},clasificacion:{nombre:"Clasificacion por forma clinica y evolucion",tipos:[{nombre:"Forma urogenital",descripcion:"Desencadenada por infeccion de transmision sexual, principalmente Chlamydia trachomatis. Predomina en hombres jovenes."},{nombre:"Forma postenterica",descripcion:"Secundaria a gastroenteritis bacteriana por Salmonella, Shigella, Yersinia o Campylobacter. Afecta ambos sexos."},{nombre:"Sindrome de Reiter completo",descripcion:"Triada clasica: artritis + uretritis + conjuntivitis. Solo presente en 30-40% de los casos."},{nombre:"Forma cronica",descripcion:"Persistencia de sintomas mas de 6 meses. Riesgo de sacroileitis y espondilitis en portadores HLA-B27."}]},diagnostico:{anamnesis:["Antecedente de infeccion urogenital o gastrointestinal 2-6 semanas previas","Historia sexual y practicas de riesgo","Presencia de la triada clasica (artritis, uretritis, conjuntivitis)","Antecedentes familiares de espondiloartropatias","Historia de episodios previos similares"],examenFisico:["Evaluacion articular: numero de articulaciones afectadas, patron de distribucion","Busqueda de entesopatia (presion en insercion del tendon de Aquiles y fascia plantar)","Examen ocular: conjuntivitis, uveitis","Examen de piel y mucosas: queratodermia blenorragica, balanitis circinada, ulceras orales","Evaluacion de columna: movilidad lumbar, maniobras sacroiliacas"],pruebas:[{nombre:"HLA-B27",descripcion:"Marcador genetico de susceptibilidad; positivo en 60-80% de los casos",valoresReferencia:"Positivo o negativo (presente en 6-8% de la poblacion general)",cuidadosEnfermeria:["Extraer muestra de sangre periferica en tubo con EDTA","No requiere ayuno","Informar al paciente que el resultado no confirma ni descarta la enfermedad por si solo"]},{nombre:"Reactantes de fase aguda (PCR y VSG)",descripcion:"Indicadores de inflamacion sistemica activa",valoresReferencia:"PCR < 5 mg/L; VSG < 20 mm/h (hombre) / < 30 mm/h (mujer)",cuidadosEnfermeria:["Extraer muestra en ayunas para PCR cuantitativa","Para VSG usar tubo de citrato, evitar agitacion excesiva","Registrar temperatura del paciente al momento de la extraccion"]},{nombre:"Hemograma completo",descripcion:"Detecta leucocitosis moderada y anemia de proceso cronico",valoresReferencia:"Leucocitos 4.500-11.000/mm3; Hb > 12 g/dL",cuidadosEnfermeria:["Extraer muestra en tubo con EDTA","Procesar dentro de las 2 horas de obtenida","Anotar medicacion actual que pueda alterar el recuento"]},{nombre:"Cultivo uretral o cervical / PCR para Chlamydia",descripcion:"Identificar el agente infeccioso desencadenante urogenital",valoresReferencia:"Negativo (ausencia de microorganismos patogenos)",cuidadosEnfermeria:["Obtener muestra antes de iniciar antibioticoterapia","En hombres: hisopado uretral; en mujeres: hisopado endocervical","Informar al paciente sobre el procedimiento para reducir ansiedad","Conservar la muestra a 4\xb0C si no se procesa inmediatamente"]},{nombre:"Radiografia articular y sacroiliaca",descripcion:"Detecta erosiones articulares, periostitis y sacroileitis en formas cronicas",valoresReferencia:"Sin alteraciones en fase aguda; sacroileitis grado I-II en formas cronicas",cuidadosEnfermeria:["Retirar objetos metalicos de la zona a radiografiar","Proteger zonas no exploradas con delantal plomado","En mujeres en edad fertil verificar posibilidad de embarazo"]}]},tratamientoMedico:{objetivos:["Tratar la infeccion desencadenante si aun esta activa","Controlar la inflamacion articular y sistemica","Preservar la funcion articular","Prevenir la cronicidad y las complicaciones oculares","Educar sobre prevencion de reinfecciones"],farmacologico:[{nombre:"Naproxeno",grupo:"AINE (Antiinflamatorio No Esteroideo)",mecanismo:"Inhibicion no selectiva de COX-1 y COX-2, reduciendo sintesis de prostaglandinas y tromboxano A2",dosis:"500-1000 mg/dia en 2 tomas con alimentos",cuidadosEnfermeria:["Administrar siempre con alimentos para minimizar irritacion gastrica","Monitorizar funcion renal y presion arterial","Vigilar signos de sangrado gastrointestinal (melena, hematemesis)","Contraindicado en insuficiencia renal grave y ulcera peptica activa","Evaluar dolor articular antes y 1 hora despues de la administracion"]},{nombre:"Azitromicina",grupo:"Macrolido antibiotico",mecanismo:"Inhibe la sintesis proteica bacteriana uniendose a la subunidad 50S del ribosoma, con especial efectividad frente a Chlamydia trachomatis",dosis:"1 g dosis unica (forma urogenital por Chlamydia) o 500 mg/dia por 3 dias",cuidadosEnfermeria:["Administrar en dosis unica para asegurar cumplimiento","Tratar simultaneamente a la pareja sexual","Vigilar prolongacion del intervalo QT en pacientes con factores de riesgo","Monitorizar molestias gastrointestinales (nauseas, diarrea)","Verificar alergias a macrolidos antes de administrar"]},{nombre:"Prednisona",grupo:"Corticosteroide sistemico",mecanismo:"Potente accion antiinflamatoria e inmunosupresora mediante inhibicion de fosfolipasa A2 y reduccion de citocinas proinflamatorias",dosis:"0.5 mg/kg/dia con reduccion progresiva segun respuesta clinica",cuidadosEnfermeria:["Administrar en dosis matutina unica para minimizar supresion del eje HHA","Monitorizar glucemia especialmente en diabeticos","Vigilar presion arterial y peso (retencion hidrosalina)","No suspender bruscamente; reducir dosis gradualmente","Proteger de infecciones oportunistas; informar sobre signos de alarma"]}],noFarmacologico:["Reposo articular relativo en fase aguda","Fisioterapia y ejercicios de rango de movimiento en fase subaguda","Aplicacion de frio local en articulaciones inflamadas (15-20 min, 3-4 veces/dia)","Uso de ortesis o bastones si hay afectacion de miembros inferiores","Prevencion de reinfecciones: uso de preservativo, higiene alimentaria","Cese del tabaquismo (agrava espondiloartropatias)"]},cuidadosEnfermeria:{valoracion:["Evaluar numero y localizacion de articulaciones afectadas (escala DAS28 si aplica)","Registrar intensidad del dolor con escala EVA","Valorar rigidez matutina (duracion en minutos)","Inspeccionar piel y mucosas en busca de lesiones caracteristicas","Evaluar sintomas oculares: enrojecimiento, fotofobia, secrecion","Investigar antecedente de infeccion previa y conducta sexual"],intervenciones:["Administrar AINEs con alimentos para reducir toxicidad gastrica","Aplicar tecnicas de fisioterapia articular segun indicacion medica","Derivar a oftalmologia ante signos de uveitis","Coordinar seguimiento con reumatologia","Proporcionar ayudas tecnicas para la movilidad si es necesario","Realizar vendajes funcionales en articulaciones con derrame"],educacionPaciente:["Explicar la naturaleza reactiva de la artritis y su relacion con la infeccion previa","Instruir sobre la importancia del tratamiento antibiotico completo","Ense\xf1ar tecnicas de proteccion articular en actividades cotidianas","Informar sobre la necesidad de tratar a la pareja sexual en formas urogenitales","Reconocer signos de alarma ocular que requieren atencion urgente","Explicar la posibilidad de recurrencia y como prevenirla"],monitorizacion:["Evaluacion articular cada 48-72 horas en fase aguda","Control de reactantes de fase aguda (PCR, VSG) cada 2-4 semanas","Monitorizar funcion renal y hepatica si usa AINEs prolongados","Evaluacion oftalmologica periodica por riesgo de uveitis","Seguimiento reumatologico cada 3 meses el primer ano"]},npiNanda:[{codigo:"00102",nombre:"Deficit de autocuidado: bano",definicion:"Deterioro de la habilidad para realizar o completar actividades de bano/higiene por si solo",caracteristicasDefinitorias:["Incapacidad para lavarse el cuerpo o partes de el","Incapacidad para acceder al cuarto de bano","Dolor articular que limita la movilidad"],factoresRelacionados:["Dolor articular agudo","Deterioro de la movilidad fisica","Fatiga"]},{codigo:"00232",nombre:"Movilidad fisica deteriorada",definicion:"Limitacion del movimiento fisico independiente e intencionado del cuerpo o de una o mas extremidades",caracteristicasDefinitorias:["Disminucion del rango de movimiento articular","Enlentecimiento del movimiento","Dificultad para girar o rotar","Rigidez articular"],factoresRelacionados:["Dolor articular inflamatorio","Rigidez articular","Derrame sinovial"]},{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable asociada con da\xf1o tisular real o potencial, de inicio subito o lento, de cualquier intensidad de leve a grave, con un final anticipado o previsible",caracteristicasDefinitorias:["Informe verbal de dolor","Conducta de proteccion articular","Expresion facial de dolor","Posicion antialgica"],factoresRelacionados:["Inflamacion sinovial","Sinovitis aguda","Entesopatia"]}],npiNic:[{codigo:"1400",nombre:"Manejo del dolor",actividades:["Evaluar el dolor con escala EVA antes y despues de intervenciones","Administrar analgesicos y AINEs segun prescripcion medica","Aplicar frio local en articulaciones inflamadas agudas","Posicionar las articulaciones en posicion funcional","Ensen\u0627\u0631 tecnicas de distraccion y relajacion"]},{codigo:"0224",nombre:"Terapia de ejercicios: movilidad articular",actividades:["Realizar ejercicios de rango de movimiento pasivos y activos","Instruir al paciente sobre ejercicios de mantenimiento articular","Evitar ejercicio de alto impacto en fase aguda","Progresar gradualmente la intensidad del ejercicio segun tolerancia","Coordinar con fisioterapia para programa de rehabilitacion"]},{codigo:"5510",nombre:"Educacion para la salud",actividades:["Explicar la relacion entre infeccion y artritis reactiva","Instruir sobre medidas de prevencion de reinfecciones","Informar sobre la importancia del tratamiento antibiotico completo","Ense\xf1ar signos de alarma que requieren consulta urgente","Proporcionar informacion sobre grupos de apoyo y recursos"]}],npiNoc:[{codigo:"2102",nombre:"Nivel del dolor",indicadores:["Dolor referido en escala EVA menor a 3/10","Ausencia de conductas de proteccion articular","Capacidad de realizar actividades cotidianas sin dolor incapacitante","Reduccion de la rigidez matutina"],escala:"1=Grave, 2=Sustancial, 3=Moderado, 4=Leve, 5=Ninguno"},{codigo:"0208",nombre:"Movilidad",indicadores:["Rango de movimiento articular conservado","Capacidad de deambulacion independiente","Realizacion de actividades de la vida diaria","Ausencia de contracturas articulares"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"}],complicaciones:["Uveitis anterior aguda con riesgo de perdida visual","Cronificacion con sacroileitis y espondilitis anquilosante","Carditis (pericarditis, bloqueo AV en casos graves)","Lesion renal por uso prolongado de AINEs","Recurrencias ante nuevas infecciones","Discapacidad funcional por da\xf1o articular cronico"],criteriosAlarma:["Dolor ocular intenso con vision borrosa o perdida visual (uveitis)","Fiebre alta persistente mayor a 38.5\xb0C","Signos de sepsis articular (articulacion caliente, tensa, con limitacion total)","Dolor toracico o palpitaciones (carditis)","Melena o hematemesis (sangrado por AINEs)","Deficit neurologico (compromiso de columna cervical)"],emergencyLevel:"leve",relatedPathologyIds:["pat_artritis_reumatoide","pat_espondiloartritis","pat_lupus","pat_enfermedad_inflamatoria_intestinal"],isPremium:!0},{id:"pat_vasculitis",nombre:"Vasculitis Sistemica",bodySystemId:"inmunologico",definicion:"Grupo heterogeneo de enfermedades caracterizadas por inflamacion de la pared vascular (arterias, venas o capilares) que produce da\xf1o tisular por isquemia, necrosis o hemorragia. Pueden ser primarias (de causa inmune desconocida) o secundarias a otras enfermedades sistematicas.",epidemiologia:"Incidencia variable segun el tipo: arteritis de celulas gigantes es la mas frecuente (15-30/100.000 en mayores de 50 a\xf1os), granulomatosis con poliangeitis (8-10/1.000.000), poliarteritis nodosa (3-10/1.000.000). En conjunto afectan a 100-150 personas por millon de habitantes. La vasculitis de vaso peque\xf1o asociada a ANCA es mas frecuente en adultos de mediana edad.",factoresRiesgo:["Predisposicion genetica (HLA-DR4 en arteritis de celulas gigantes)","Edad avanzada (arteritis de celulas gigantes y polimialgia reumatica)","Infecciones previas (hepatitis B en poliarteritis nodosa, hepatitis C en crioglobulinemia)","Exposicion a silice y otras sustancias inhaladas","Uso de ciertos farmacos (hidralazina, propiltiouracilo, levamisol)","Enfermedades autoinmunes previas (LES, AR)","Tabaquismo"],fisiopatologia:"Segun el tipo de vasculitis, el mecanismo difiere: en las asociadas a ANCA (granulomatosis con poliangeitis, poliangeitis microsc\xf3pica), los anticuerpos ANCA activan neutrofilos que liberan enzimas toxicas daniando el endotelio de vasos peque\xf1os. En la arteritis de celulas gigantes, linfocitos T CD4+ reconocen antigenos en la adventicia arterial activando macrofagos que producen granulomas. En vasculitis por inmunocomplejos (PAN, crioglobulinemia), los complejos se depositan en la pared vascular activando complemento e inflamacion. El da\xf1o final es isquemia por oclucion luminal, aneurismas por debilitamiento de la pared, o hemorragia.",signosYSintomas:{signos:["Purpura palpable (vasculitis de vaso peque\xf1o)","Livedo reticularis","Ulceras cutaneas de bordes bien definidos","Nodulos subcutaneos","Hematuria y proteinuria (glomerulonefritis asociada)","Mononeuritis multiplex (caida de pie, mano)","Infiltrados pulmonares en RX (hemorragia alveolar)","Isquemia digital o gangrena"],sintomas:["Fiebre prolongada inexplicada","Perdida de peso involuntaria mayor al 10%","Fatiga intensa y malestar general","Cefalea temporal (arteritis de celulas gigantes)","Claudicacion mandibular al masticar","Dolor abdominal postprandial (isquemia mesenterica)","Sinusitis cronica con epistaxis (granulomatosis con poliangeitis)","Mialgias y artralgias"]},clasificacion:{nombre:"Clasificacion de Chapel Hill 2012 por calibre del vaso",tipos:[{nombre:"Vasculitis de vaso grande",descripcion:"Arteritis de celulas gigantes (temporal) y arteritis de Takayasu. Afecta aorta y sus ramas principales."},{nombre:"Vasculitis de vaso mediano",descripcion:"Poliarteritis nodosa y enfermedad de Kawasaki. Afecta arterias musculares principales y sus ramas iniciales."},{nombre:"Vasculitis de vaso peque\xf1o asociada a ANCA",descripcion:"Granulomatosis con poliangeitis (Wegener), poliangeitis microscopica, granulomatosis eosinofilica con poliangeitis (Churg-Strauss)."},{nombre:"Vasculitis por inmunocomplejos",descripcion:"Vasculitis IgA (Henoch-Schonlein), crioglobulinemias, vasculitis urticariante hipocomplementemica."}]},diagnostico:{anamnesis:["Sintomas constitucionales: fiebre, perdida de peso, fatiga","Antecedente de infecciones recientes (hepatitis viral, estreptococcica)","Exposicion a farmacos que pueden inducir vasculitis","Manifestaciones de afectacion organica: hematuria, hemoptisis, neuropatia","Antecedentes de enfermedades autoinmunes","Historia familiar de vasculitis o enfermedades reumaticas"],examenFisico:["Evaluacion dermatologica: purpura, ulceras, livedo, nodulos","Palpacion y auscultacion de pulsos perifericos (asimetria, soplos)","Evaluacion neurologica: deficits sensitivos o motores","Evaluacion renal: edemas, hipertension","Palpacion abdominal: hepatoesplenomegalia, dolor","Examen ocular: isquemia retiniana, epiescleritis"],pruebas:[{nombre:"ANCA (Anticuerpos anti-citoplasma de neutrofilos)",descripcion:"c-ANCA/anti-PR3 en granulomatosis con poliangeitis; p-ANCA/anti-MPO en poliangeitis microscopica",valoresReferencia:"Negativo (ausencia de anticuerpos)",cuidadosEnfermeria:["Extraer muestra de suero en tubo de tapa roja o amarilla","No requiere ayuno","Evitar hemolisis de la muestra (no agitar)","Registrar tratamientos actuales que puedan dar falsos positivos"]},{nombre:"Biopsia vascular o de organo afectado",descripcion:"Confirma el diagnostico histologico de vasculitis (gold standard); se realizan biopsias de arteria temporal, ri\xf1on o piel segun el caso",valoresReferencia:"Sin inflamacion ni necrosis vascular en tejido normal",cuidadosEnfermeria:["Preparar material esteril de biopsia segun protocolo institucional","Obtener consentimiento informado antes del procedimiento","Monitorizar sitio de biopsia por sangrado durante 24 horas","Conservar muestra en formol al 10% para histologia o en solucion salina para inmunofluorescencia","Registrar aspecto macroscopico de la muestra"]},{nombre:"Sedimento urinario y proteinuria de 24h",descripcion:"Detecta glomerulonefritis por vasculitis (cilindruria, hematuria microscopica, proteinuria)",valoresReferencia:"Proteinuria < 150 mg/24h; ausencia de cilindruria eritrocitaria",cuidadosEnfermeria:["Instruir sobre tecnica correcta de recoleccion de orina de 24h","Primera miccion del dia se descarta, la ultima del dia siguiente se incluye","Conservar la recoleccion refrigerada a 4\xb0C","Procesar sedimento urinario dentro de 2 horas de obtenido"]},{nombre:"Angio-TAC o angio-RMN de grandes vasos",descripcion:"Detecta estenosis, oclusiones o aneurismas en vasculitis de vaso grande y mediano",valoresReferencia:"Sin estenosis, oclusiones ni aneurismas vasculares",cuidadosEnfermeria:["Verificar funcion renal antes de administrar contraste yodado","Evaluar alergias al contraste previas","Asegurar via periferica permeable de calibre adecuado","Hidratar al paciente antes y despues del procedimiento con contraste"]}]},tratamientoMedico:{objetivos:["Inducir remision de la inflamacion vascular","Prevenir da\xf1o organico irreversible (renal, pulmonar, neurologico)","Mantener remision con la minima toxicidad farmacologica","Tratar complicaciones isquemicas o hemorragicas","Monitorizar y prevenir efectos adversos del tratamiento inmunosupresor"],farmacologico:[{nombre:"Metilprednisolona",grupo:"Corticosteroide de alta potencia",mecanismo:"Potente accion antiinflamatoria e inmunosupresora; inhibe produccion de citocinas, quimiotaxis leucocitaria y sintesis de mediadores inflamatorios",dosis:"500-1000 mg IV/dia por 3 dias (pulso) en formas graves; luego prednisona 1 mg/kg/dia oral",cuidadosEnfermeria:["Administrar en infusion IV lenta (30-60 minutos) para prevenir arritmias","Monitorizar glucemia cada 6 horas durante los pulsos","Controlar presion arterial y frecuencia cardiaca durante la infusion","Vigilar signos de infeccion oportunista","Administrar proteccion gastrica (omeprazol) concomitantemente"]},{nombre:"Rituximab",grupo:"Anticuerpo monoclonal anti-CD20 (biologico)",mecanismo:"Deplecion de linfocitos B CD20+, reduciendo la produccion de ANCA y la respuesta inflamatoria en vasculitis asociadas a ANCA",dosis:"375 mg/m2 IV semanal por 4 semanas, o 1000 mg IV en 2 dosis con 2 semanas de intervalo",cuidadosEnfermeria:["Premedicar con antihistaminico, acetaminofen y corticosteroide 30 min antes","Iniciar infusion lentamente (50 mg/h) e incrementar segun tolerancia","Monitorizar signos de reaccion infusional: fiebre, escalofrios, hipotension","Verificar ausencia de infeccion activa antes de cada ciclo","Controlar hemograma y niveles de inmunoglobulinas periodicamente"]},{nombre:"Ciclofosfamida",grupo:"Agente alquilante inmunosupresor",mecanismo:"Alquilacion del ADN de linfocitos y celulas proinflamatorias, reduciendo la respuesta inmune patologica",dosis:"2 mg/kg/dia oral o 15 mg/kg IV mensual (pulso); ajustar por funcion renal",cuidadosEnfermeria:["Hiperhidratar al paciente (2-3 L/dia) para prevenir cistitis hemorragica","Administrar MESNA (uroprotector) con cada pulso IV","Monitorizar hemograma semanal: nadir leucocitario a los 10-14 dias","Vigilar hematuria microscopica en orina (cistitis hemorragica)","Informar sobre riesgo de esterilidad y ofrecer cripreservacion de gametos si aplica"]}],noFarmacologico:["Reposo relativo en fases de actividad severa","Dieta hiposodica si hay corticoterapia prolongada o hipertension","Suplementacion con calcio y vitamina D durante corticoterapia prolongada","Proteccion solar por fotosensibilidad en vasculitis cutanea","Cese absoluto del tabaquismo","Vacunacion neumococica y anti-influenza antes de iniciar inmunosupresion"]},cuidadosEnfermeria:{valoracion:["Evaluar integridad cutanea: purpura, ulceras, necrosis digital","Monitorizar funcion renal: diuresis, edemas, creatinina, sedimento urinario","Evaluar sintomas neurologicos: parestesias, debilidad, caida de pie","Registrar temperatura y signos de infeccion (inmunosupresion)","Auscultar ruidos respiratorios: crepitantes en hemorragia alveolar","Evaluar dolor con escala EVA y localizar su origen vascular o isquemico"],intervenciones:["Administrar inmunosupresores con estrictas medidas de asepsia","Mantener hidratacion adecuada durante ciclofosfamida","Curar ulceras cutaneas con tecnica esteril segun protocolo de heridas","Prevenir infecciones oportunistas (higiene de manos, aislamiento protector si es necesario)","Coordinar con nefrologia, neumologia y neurologia segun compromiso organico","Gestionar acceso venoso central para infusiones prolongadas"],educacionPaciente:["Explicar la naturaleza cronica de la vasculitis y la importancia del seguimiento","Instruir sobre signos de infeccion que requieren consulta inmediata (inmunosuprimido)","Explicar efectos adversos de los corticoides y como manejarlos","Ense\xf1ar autocuidado de lesiones cutaneas","Informar sobre la necesidad de vacunacion antes del tratamiento inmunosupresor","Importancia de no automedicar ni suspender tratamiento sin indicacion medica"],monitorizacion:["Hemograma completo cada 1-2 semanas al inicio del tratamiento inmunosupresor","Funcion renal y electrolitos semanales en fase aguda","Sedimento urinario y proteinuria mensual","ANCA cuantitativo cada 3 meses para monitorizar respuesta","Densitometria osea anual en corticoterapia prolongada","Presion arterial y glucemia diarias durante pulsos de corticoides"]},npiNanda:[{codigo:"00204",nombre:"Perfusion tisular periferica ineficaz",definicion:"Reduccion de la circulacion sanguinea a la periferia que puede comprometer la salud",caracteristicasDefinitorias:["Pulsos perifericos debiles o ausentes","Cambios en la piel: palidez, cianosis, livedo reticularis","Heridas que no cicatrizan","Dolor en reposo o claudicacion"],factoresRelacionados:["Inflamacion vascular con oclucion luminal","Formacion de trombos en vasos inflamados","Vasospasmo"]},{codigo:"00004",nombre:"Riesgo de infeccion",definicion:"Vulnerable a ser invadido y multiplicado por organismos patogenos que pueden comprometer la salud",caracteristicasDefinitorias:["Tratamiento inmunosupresor activo","Leucopenia por ciclofosfamida","Soluciones de continuidad en piel por ulceras vasculiticas"],factoresRelacionados:["Inmunosupresion farmacologica","Corticoterapia prolongada","Alteracion de la integridad cutanea"]},{codigo:"00025",nombre:"Riesgo de desequilibrio de volumen de liquidos",definicion:"Vulnerable a una disminucion, aumento o cambio rapido de uno al otro del espacio intravascular, intersticial y/o intracelular que puede comprometer la salud",caracteristicasDefinitorias:["Nefritis vasculitica con proteinuria","Edemas perifericos","Tratamiento con ciclofosfamida que requiere hiperhidratacion"],factoresRelacionados:["Compromiso renal por vasculitis glomerular","Tratamiento con corticosteroides (retencion hidrosalina)","Protocolo de hiperhidratacion con ciclofosfamida"]}],npiNic:[{codigo:"3390",nombre:"Ayuda a la ventilacion",actividades:["Monitorizar saturacion de oxigeno y frecuencia respiratoria","Administrar oxigeno suplementario segun prescripcion en hemorragia alveolar","Posicionar al paciente en semifowler para optimizar la ventilacion","Auscultar ruidos respiratorios cada 4-8 horas","Preparar material para broncoscopia de urgencia si hay hemoptisis masiva"]},{codigo:"6540",nombre:"Control de infecciones",actividades:["Aplicar higiene de manos estricta antes de cada procedimiento","Mantener tecnica aseptica en accesos venosos y procedimientos invasivos","Monitorizar temperatura cada 6 horas en pacientes inmunosuprimidos","Realizar cultivos ante cualquier signo de infeccion","Administrar profilaxis antiinfecciosa segun protocolo (trimetoprim-sulfametoxazol para Pneumocystis)"]},{codigo:"4070",nombre:"Precauciones circulatorias",actividades:["Evaluar pulsos perifericos y temperatura de extremidades cada turno","Monitorizar lesiones isquemicas cutaneas y documentar su evolucion","Evitar compresion de extremidades isquemicas","Mantener temperatura ambiental adecuada para prevenir vasospasmo","Coordinar con cirugia vascular ante isquemia critica"]}],npiNoc:[{codigo:"0407",nombre:"Perfusion tisular: periferica",indicadores:["Pulsos perifericos palpables en todas las extremidades","Temperatura de extremidades normal","Ausencia de dolor en reposo","Coloracion normal de la piel","Heridas con signos de cicatrizacion"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"},{codigo:"0703",nombre:"Severidad de la infeccion",indicadores:["Temperatura corporal en rango normal","Recuento leucocitario dentro de limites normales","Ausencia de cultivos positivos","Ausencia de signos locales de infeccion en accesos vasculares"],escala:"1=Grave, 2=Sustancial, 3=Moderado, 4=Leve, 5=Ninguno"}],complicaciones:["Insuficiencia renal aguda o cronica por glomerulonefritis vasculitica","Hemorragia alveolar difusa con insuficiencia respiratoria","Isquemia critica de extremidades con gangrena","Aneurismas arteriales con riesgo de rotura","Accidente cerebrovascular isquemico o hemorragico","Infecciones oportunistas por inmunosupresion (Pneumocystis, CMV, aspergilosis)","Cistitis hemorragica por ciclofosfamida","Perdida visual por isquemia del nervio optico (arteritis de celulas gigantes)"],criteriosAlarma:["Hemoptisis con deterioro respiratorio agudo (hemorragia alveolar)","Anuria u oliguria grave (falla renal aguda)","Isquemia critica de extremidad (dolor intenso, palidez, ausencia de pulsos)","Fiebre alta con signos de sepsis en paciente inmunosuprimido","Deterioro neurologico agudo (ACV, mononeuritis con paralisis)","Perdida visual subita (arteritis temporal)","Hemorragia digestiva masiva (isquemia mesenterica)"],emergencyLevel:"moderado",relatedPathologyIds:["pat_lupus","pat_artritis_reumatoide","pat_insuficiencia_renal","pat_sindrome_nefrotico"],isPremium:!0},{id:"pat_sarcoidosis",nombre:"Sarcoidosis",bodySystemId:"inmunologico",definicion:"Enfermedad inflamatoria multisistemica de etiologia desconocida caracterizada por la formacion de granulomas no caseificantes en los organos afectados, predominantemente en pulmones, ganglios linfaticos, piel, ojos e higado. Se considera una enfermedad autoinmune mediada por celulas T ante antigenos no identificados.",epidemiologia:"Incidencia global de 10-40 casos por 100.000 habitantes. Prevalencia mayor en poblacion afroamericana (40/100.000) y paises nordicos. Predomina en adultos jovenes entre 20-40 a\xf1os, con un segundo pico en mujeres mayores de 50 a\xf1os. En Argentina, la prevalencia estimada es de 1-3/10.000. Remision espontanea en 60-70% de los casos dentro de los primeros 2-3 a\xf1os.",factoresRiesgo:["Predisposicion genetica (alelos HLA-DRB1 especificos)","Raza negra (mayor incidencia y formas mas graves)","Exposicion a polvo inorganico (silice, berilio)","Exposicion a sustancias organicas (moho, pesticidas)","Antecedentes de infecciones por micobacterias o propionibacterias","Sexo femenino para formas extrapulmonares","Antecedentes familiares de sarcoidosis (riesgo 3-5 veces mayor)"],fisiopatologia:"Un antigeno no identificado (posiblemente micobacteriano o ambiental) es captado por celulas dendriticas que lo presentan a linfocitos T helper CD4+. Estos se diferencian predominantemente hacia fenotipo Th1, produciendo IFN-gamma e IL-2. La activacion macrofagica sostenida lleva a la fusion de macrofagos en celulas epitelioides y celulas gigantes multinucleadas, formando granulomas no caseificantes. Estos granulomas liberan 1-alfa-hidroxilasa que convierte vitamina D a su forma activa, causando hipercalcemia. La fibrosis progresiva por activacion de fibroblastos puede causar da\xf1o organico irreversible en pulmones (fibrosis pulmonar) y otros organos.",signosYSintomas:{signos:["Adenopatias hiliares bilaterales en radiografia de torax (hallazgo mas frecuente)","Infiltrados pulmonares intersticiales","Lesiones cutaneas: eritema nodoso, lupus pernio (placas violaceas nasales)","Uveitis anterior o posterior","Hepatomegalia y esplenomegalia","Artritis de tobillo en sindrome de L\xf6fgren","Paresia facial periferica (neurosarcoidosis)","Hipercalcemia (10-20% de casos)"],sintomas:["Tos seca no productiva","Disnea de esfuerzo progresiva","Fatiga cronica intensa","Fiebre de bajo grado","Perdida de peso","Dolor articular (artritis de L\xf6fgren)","Vision borrosa o dolor ocular","Palpitaciones o sincope (sarcoidosis cardiaca)"]},clasificacion:{nombre:"Clasificacion radiologica de Scadding (pulmonar)",tipos:[{nombre:"Estadio 0",descripcion:"Radiografia de torax normal. Afectacion extrapulmonar posible."},{nombre:"Estadio I",descripcion:"Adenopatias hiliares bilaterales sin infiltrados pulmonares. Buen pronostico, remision espontanea frecuente."},{nombre:"Estadio II",descripcion:"Adenopatias hiliares bilaterales con infiltrados pulmonares parenquimatosos."},{nombre:"Estadio III",descripcion:"Infiltrados pulmonares sin adenopatias hiliares. Mayor riesgo de fibrosis."},{nombre:"Estadio IV",descripcion:"Fibrosis pulmonar establecida con distorsion arquitectural. Mal pronostico funcional."}]},diagnostico:{anamnesis:["Sintomas respiratorios: tos seca, disnea de esfuerzo de inicio insidioso","Sintomas constitucionales: fiebre, fatiga, perdida de peso","Historia de exposicion a sustancias inhaladas o infecciones previas","Antecedentes familiares de sarcoidosis","Sintomas oculares: vision borrosa, fotofobia, ojo rojo","Historia de lesiones cutaneas o ganglios palpables"],examenFisico:["Auscultacion pulmonar: crepitantes finos en estadios avanzados","Evaluacion cutanea: eritema nodoso (espinillas), lupus pernio (nariz, mejillas)","Palpacion de adenopatias perifericas","Examen ocular con lampara de hendidura (uveitis)","Evaluacion neurologica: paralisis facial, neuropatias","Auscultacion cardiaca: arritmias, bloqueos"],pruebas:[{nombre:"Enzima Convertidora de Angiotensina (ECA) serica",descripcion:"Producida por macrofagos del granuloma; elevada en 60-80% de sarcoidosis activa. Util para monitorizar actividad",valoresReferencia:"Normal: 8-52 U/L (varia segun laboratorio); elevada en sarcoidosis activa",cuidadosEnfermeria:["Extraer muestra de suero en tubo seco","No requiere ayuno","Registrar si el paciente toma IECAs (falsan negativos)","Informar que el resultado debe interpretarse en contexto clinico"]},{nombre:"TAC de torax de alta resolucion (TACAR)",descripcion:"Detecta adenopatias mediastinicas, nodulos perilinfaticos, opacidades en vidrio esmerilado y fibrosis",valoresReferencia:"Sin adenopatias ni infiltrados en torax normal",cuidadosEnfermeria:["No requiere contraste endovenoso de rutina para TACAR","Instruir al paciente sobre apnea inspiratoria durante el estudio","Registrar antecedentes de claustrofobia o alergias al contraste"]},{nombre:"Lavado broncoalveolar (BAL)",descripcion:"Muestra cociente linfocitos CD4+/CD8+ mayor a 3.5, altamente sugestivo de sarcoidosis",valoresReferencia:"CD4+/CD8+ normal: 1.5-1.8; en sarcoidosis activa > 3.5",cuidadosEnfermeria:["Preparar equipo de broncoscopia flexible segun protocolo","Asegurar via periferica y monitoreo continuo durante el procedimiento","Administrar anestesia topica con lidocaina segun indicacion medica","Monitorizar saturacion de oxigeno y frecuencia respiratoria post-procedimiento","Mantener al paciente en ayunas de 4-6 horas antes del estudio"]},{nombre:"Calcemia y calciuria de 24h",descripcion:"Detecta hipercalcemia por produccion de vitamina D activa por macrofagos granulomatosos",valoresReferencia:"Calcemia: 8.5-10.2 mg/dL; Calciuria < 300 mg/24h",cuidadosEnfermeria:["Extraer muestra en ayunas para calcemia serica","Para calciuria: recoleccion de orina de 24h con acidificacion del recipiente","Registrar suplementos de calcio o vitamina D que tome el paciente","Vigilar sintomas de hipercalcemia: poliuria, letargo, nauseas, estre\xf1imiento"]}]},tratamientoMedico:{objetivos:["Controlar los sintomas y la inflamacion granulomatosa","Prevenir da\xf1o organico irreversible (fibrosis pulmonar, ceguera, arritmias)","Lograr remision con la menor toxicidad posible","Monitorizar la actividad de la enfermedad","Tratar las manifestaciones extrapulmonares potencialmente graves"],farmacologico:[{nombre:"Prednisona",grupo:"Corticosteroide (tratamiento de primera linea)",mecanismo:"Suprime la respuesta inflamatoria Th1 y la activacion macrofagica, reduciendo la formacion y el tamano de los granulomas",dosis:"0.3-0.5 mg/kg/dia (20-40 mg/dia) inicial, con reduccion progresiva durante 12-24 meses",cuidadosEnfermeria:["Administrar en dosis matutina unica para respetar el ritmo circadiano del cortisol","Monitorizar glucemia, presion arterial y peso semanalmente","Suplementar con calcio (1000-1500 mg/dia) y vitamina D (800 UI/dia) desde el inicio","Vigilar densidad osea y prescribir bifosfonatos si corticoterapia mayor a 3 meses","No suspender bruscamente; seguir pauta de reduccion progresiva prescrita"]},{nombre:"Metotrexato",grupo:"Antimetabolito inmunosupresor (ahorrador de corticoides)",mecanismo:"Inhibe la dihidrofolato reductasa, reduciendo la proliferacion linfocitaria y la produccion de citocinas inflamatorias",dosis:"10-15 mg/semana oral o subcutaneo; asociar acido folico 5 mg/semana (dia diferente)",cuidadosEnfermeria:["Administrar SIEMPRE acido folico en dia diferente al metotrexato","Monitorizar hemograma y transaminasas mensuales los primeros 6 meses","Contraindicado en embarazo (categoria X); asegurar anticoncepcion eficaz","Vigilar signos de toxicidad: ulceras orales, nauseas, caida de cabello","Evitar AINEs y alcohol durante el tratamiento (aumentan toxicidad hepatica)"]},{nombre:"Hidroxicloroquina",grupo:"Antipaludico (util en sarcoidosis cutanea e hipercalcemia)",mecanismo:"Inhibe la activacion de celulas dendriticas y la respuesta de linfocitos T, con efecto especifico en sarcoidosis cutanea e hipercalcemia granulomatosa",dosis:"200-400 mg/dia oral",cuidadosEnfermeria:["Realizar examen oftalmologico basal y anual (riesgo de retinopatia)","Administrar con alimentos para reducir irritacion gastrointestinal","Monitorizar glucemia (tiene efecto hipoglucemiante leve)","Informar al paciente que el efecto terapeutico tarda 2-3 meses en observarse"]}],noFarmacologico:["Cese absoluto del tabaquismo (agrava la funcion pulmonar)","Ejercicio aerobico moderado adaptado a la capacidad funcional pulmonar","Evitar exposicion solar excesiva (puede agravar hipercalcemia)","Dieta baja en calcio en presencia de hipercalcemia","Hidratacion adecuada para prevenir nefrolitiasis por hipercalciuria","Rehabilitacion pulmonar en estadios avanzados con fibrosis"]},cuidadosEnfermeria:{valoracion:["Evaluar funcion respiratoria: disnea, tos, saturacion de oxigeno y espirometria","Monitorizar signos de hipercalcemia: nauseas, letargo, poliuria, dolor abdominal","Evaluar vision: cambios visuales, fotofobia (uveitis)","Inspeccionar lesiones cutaneas y documentar su extension","Valorar capacidad funcional para actividades cotidianas (escala MRC)","Evaluar estado nutricional por riesgo de perdida de peso"],intervenciones:["Administrar corticoides con proteccion gastrica y suplementos de calcio-vitamina D","Coordinar espirometria y prueba de marcha de 6 minutos para seguimiento","Derivar a oftalmologia ante cualquier sintoma ocular","Proporcionar oxigenoterapia domiciliaria si SatO2 basal menor a 88%","Realizar educacion sobre tecnica inhalatoria si se prescriben broncodilatadores","Facilitar acceso a grupos de apoyo de pacientes con enfermedades intersticiales"],educacionPaciente:["Explicar la naturaleza de la enfermedad y la posibilidad de remision espontanea","Importancia del seguimiento regular aunque se encuentre asintomatico","Signos de alarma: disnea brusca, vision borrosa, palpitaciones, sincope","Necesidad de proteccion solar para prevenir empeorar la hipercalcemia","Instruir sobre el cumplimiento del tratamiento y no suspenderlo sin consultar","Explicar efectos adversos de los corticoides y como manejar el aumento de peso"],monitorizacion:["Espirometria y DLCO cada 3-6 meses para seguimiento de funcion pulmonar","Calcemia y calciuria mensual en fase activa con hipercalcemia","ECA serica cada 3 meses como marcador de actividad","Hemograma y hepatograma mensual si usa metotrexato","Examen oftalmologico semestral en tratamiento con hidroxicloroquina","ECG anual para detectar bloqueos o arritmias por sarcoidosis cardiaca"]},npiNanda:[{codigo:"00032",nombre:"Patron respiratorio ineficaz",definicion:"La inspiracion y/o espiracion no proporcionan una ventilacion adecuada",caracteristicasDefinitorias:["Disnea de esfuerzo progresiva","Disminucion de la capacidad vital y DLCO","Uso de musculos accesorios","Saturacion de oxigeno reducida con el ejercicio"],factoresRelacionados:["Infiltrados pulmonares granulomatosos","Fibrosis pulmonar en estadios avanzados","Broncoespasmo asociado"]},{codigo:"00093",nombre:"Fatiga",definicion:"Sensacion abrumadora y sostenida de agotamiento y disminucion de la capacidad para el trabajo fisico y mental habitual",caracteristicasDefinitorias:["Incapacidad para mantener la actividad habitual","Cansancio desproporcionado al esfuerzo","Necesidad de reposo frecuente","Alteracion de la concentracion"],factoresRelacionados:["Proceso inflamatorio sistemico cronico","Anemia de proceso cronico","Alteracion del patron de sueno"]},{codigo:"00126",nombre:"Conocimiento deficiente",definicion:"Ausencia o deficiencia de informacion cognitiva relacionada con un tema especifico",caracteristicasDefinitorias:["Verbaliza desconocimiento sobre su enfermedad","Comportamiento inadecuado (suspende tratamiento ante mejoria)","Pregunta sobre el significado de sus sintomas"],factoresRelacionados:["Falta de exposicion a informacion sobre enfermedad rara","Dificultad para interpretar informacion medica compleja","Barreras de comprension"]}],npiNic:[{codigo:"3350",nombre:"Monitorizacion respiratoria",actividades:["Evaluar frecuencia, ritmo y profundidad respiratoria cada turno","Medir saturacion de oxigeno en reposo y con deambulacion","Auscultar ruidos respiratorios y documentar cambios","Registrar resultados de espirometria y DLCO en cada visita","Coordinar prueba de marcha de 6 minutos para evaluar capacidad funcional"]},{codigo:"1800",nombre:"Ayuda al autocuidado",actividades:["Evaluar grado de dependencia para actividades de la vida diaria","Proporcionar ayudas tecnicas adaptadas a la capacidad respiratoria","Planificar actividades con periodos de descanso intercalados","Coordinar con terapia ocupacional para adaptacion del entorno","Ense\xf1ar tecnicas de ahorro energetico"]},{codigo:"5616",nombre:"Ensenanza: medicamentos prescritos",actividades:["Explicar la razon de ser de cada medicamento y su duracion","Instruir sobre efectos adversos de los corticoides y como manejarlos","Ense\xf1ar la importancia de tomar el acido folico en dia diferente al metotrexato","Proporcionar hoja de medicacion escrita con horarios claros","Verificar comprension mediante demostracion o devolucion verbal"]}],npiNoc:[{codigo:"0410",nombre:"Estado respiratorio: permeabilidad de las vias respiratorias",indicadores:["Frecuencia respiratoria en rango normal (12-20 rpm)","Saturacion de oxigeno mayor al 95% en reposo","Ausencia de disnea en reposo","Capacidad de hablar frases completas sin fatigarse"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"},{codigo:"1803",nombre:"Conocimiento: proceso de la enfermedad",indicadores:["Describe correctamente que es la sarcoidosis","Identifica signos de alarma que requieren consulta urgente","Explica correctamente su regimen de medicacion","Comprende la necesidad de seguimiento regular"],escala:"1=Ningun conocimiento, 2=Conocimiento escaso, 3=Conocimiento moderado, 4=Conocimiento sustancial, 5=Conocimiento extenso"}],complicaciones:["Fibrosis pulmonar progresiva con insuficiencia respiratoria cronica","Ceguera por uveitis cronica no tratada","Bloqueo auriculoventricular completo y muerte subita cardiaca (sarcoidosis cardiaca)","Nefrolitiasis e insuficiencia renal por hipercalciuria cronica","Neurosarcoidosis: epilepsia, hidrocefalia, meningitis granulomatosa","Hipertension pulmonar como complicacion de la fibrosis","Insuficiencia hepatica en sarcoidosis hepatica grave"],criteriosAlarma:["Disnea en reposo o desaturacion menor a 90% (exacerbacion respiratoria)","Sincope o palpitaciones rapidas (arritmia por sarcoidosis cardiaca)","Vision borrosa subita o perdida de campo visual (uveitis aguda)","Fiebre alta con tos productiva (infeccion oportunista en inmunosuprimido)","Confusion, convulsiones o cefalea intensa (neurosarcoidosis)","Hipercalcemia grave: nauseas, vomitos, debilidad muscular extrema, calcemia > 13 mg/dL"],emergencyLevel:"leve",relatedPathologyIds:["pat_fibrosis_pulmonar","pat_tuberculosis","pat_insuficiencia_renal","pat_vasculitis"],isPremium:!0},{id:"pat_inmunodeficiencia_primaria",nombre:"Inmunodeficiencias Primarias",bodySystemId:"inmunologico",definicion:"Grupo heterogeneo de mas de 450 trastornos geneticos caracterizados por defectos intrinsicos en el desarrollo o funcion del sistema inmune, que resultan en mayor susceptibilidad a infecciones, autoinmunidad, inflamacion desregulada y mayor riesgo de neoplasias. Se distinguen de las inmunodeficiencias secundarias por su base genetica y presentacion generalmente en la infancia.",epidemiologia:"Prevalencia global estimada de 1 en 2.000 personas, aunque esta subdiagnosticada. La inmunodeficiencia comun variable (IDCV) es la mas frecuente en adultos (1:25.000). La agammaglobulinemia de Bruton afecta 1:200.000 recien nacidos varones. El deficit selectivo de IgA es la mas frecuente en general (1:500-1:700). En Argentina se estima que el 90% de los casos no estan diagnosticados. La mortalidad ha disminuido con el diagnostico precoz y la terapia de reemplazo con inmunoglobulinas.",factoresRiesgo:["Antecedentes familiares de inmunodeficiencia primaria","Consanguinidad parental","Infecciones bacterianas recurrentes en sitios inusuales (sinusitis, otitis, neumonia)","Infecciones por microorganismos oportunistas (Pneumocystis jirovecii, Cryptosporidium)","Ausencia de respuesta a antibioticos convencionales","Retraso del desarrollo ponderoestatural sin causa aparente","Historia de muerte infantil por infecciones en la familia"],fisiopatologia:"Segun el componente afectado se distinguen: 1) Deficiencias de anticuerpos (mas frecuentes): mutaciones en genes de diferenciacion de linfocitos B (BTK en Bruton, TACI, ICOS en IDCV), resultando en hipogammaglobulinemia con mayor susceptibilidad a bacterias encapsuladas. 2) Inmunodeficiencias combinadas (T y B): mutaciones en genes de recombinacion VDJ (RAG1/2) o de se\xf1alizacion del receptor (IL-7R, cadena gamma comun), causando ausencia de celulas T y B maduras (SCID). 3) Defectos fagociticos: mutaciones en NADPH oxidasa (enfermedad granulomatosa cronica) con incapacidad para eliminar patogenos intracelulares. 4) Defectos del complemento: vulnerabilidad a Neisseria y bacterias encapsuladas.",signosYSintomas:{signos:["Infecciones bacterianas recurrentes (> 2 neumonias/ano, > 4 sinusitis/ano, > 2 otitis/mes)","Ausencia de ganglios linfaticos y amigdalas palpables (agammaglobulinemia de Bruton)","Candidiasis mucocutanea persistente (defectos de celulas T)","Infecciones por germenes oportunistas a cualquier edad","Abscesos recurrentes en piel, ganglios y higado (enfermedad granulomatosa cronica)","Retraso ponderoestatural en ni\xf1os","Bronquiectasias en RX/TAC de torax por infecciones repetidas"],sintomas:["Infecciones que no responden a antibioticos o requieren antibioticos IV","Fiebre prolongada sin foco claro","Diarrea cronica con malabsorcion","Fatiga cronica","Historia de infecciones desde la infancia con internaciones frecuentes","Manifestaciones autoinmunes (citopenias, artritis, enfermedad inflamatoria intestinal)"]},clasificacion:{nombre:"Clasificacion por componente del sistema inmune afectado (IUIS 2022)",tipos:[{nombre:"Deficiencias predominantes de anticuerpos",descripcion:"Hipogammaglobulinemia o agammaglobulinemia. Incluye IDCV, agammaglobulinemia de Bruton (XLA), deficit de IgA, deficit de subclases de IgG."},{nombre:"Inmunodeficiencias combinadas (T y B)",descripcion:"SCID (inmunodeficiencia combinada grave): ausencia funcional de celulas T y B. Emergencia pediatrica que requiere trasplante de medula osea urgente."},{nombre:"Defectos fagociticos",descripcion:"Enfermedad granulomatosa cronica (EGC), neutropenia congenita grave. Susceptibilidad a bacterias catalasa-positivas y hongos."},{nombre:"Defectos del complemento",descripcion:"Susceptibilidad a infecciones por Neisseria y bacterias encapsuladas. Riesgo de autoinmunidad (LES-like)."},{nombre:"Sindromes bien definidos con inmunodeficiencia",descripcion:"Sindrome de DiGeorge, sindrome de Wiskott-Aldrich, ataxia-telangiectasia. Asocian inmunodeficiencia con otras anomalias."}]},diagnostico:{anamnesis:["Los 10 signos de alarma de la Jeffrey Modell Foundation (> 2 neumonias/ano, infecciones recurrentes, etc.)","Antecedentes familiares de inmunodeficiencia, muertes infantiles por infeccion","Historia detallada de todas las infecciones: tipo, localizacion, frecuencia, respuesta a tratamiento","Edad de inicio de los sintomas","Historia vacunal y respuesta a vacunas"],examenFisico:["Evaluacion de tejido linfoide: presencia o ausencia de amigdalas y adenopatias","Busqueda de estigmas de sindromes asociados (DiGeorge, Wiskott-Aldrich)","Evaluacion del crecimiento en ni\xf1os: peso, talla, perimetro cefalico","Busqueda de infecciones activas: foco pulmonar, cutaneo, oral","Evaluacion de bronquiectasias (auscultacion y aspecto general)","Examen dermatologico: eccema, petequias, telangiectasias, granulomas cutaneos"],pruebas:[{nombre:"Dosaje de inmunoglobulinas s\xe9ricas (IgG, IgA, IgM, IgE)",descripcion:"Evalua la produccion de anticuerpos; niveles bajos o ausentes segun el tipo de inmunodeficiencia",valoresReferencia:"IgG: 700-1600 mg/dL; IgA: 70-400 mg/dL; IgM: 40-230 mg/dL (adultos)",cuidadosEnfermeria:["Extraer muestra en tubo sin anticoagulante (suero)","No requiere ayuno especifico","Anotar si el paciente recibio transfusiones o inmunoglobulinas IV en las ultimas semanas (interfiere)","Registrar la edad del paciente (los valores de referencia varian por edad en ni\xf1os)"]},{nombre:"Inmunofenotipo linfocitario por citometria de flujo",descripcion:"Cuantifica subpoblaciones de linfocitos T (CD3, CD4, CD8), B (CD19/CD20) y NK (CD16/CD56)",valoresReferencia:"CD4+: 500-1500/mm3; CD19+: 100-500/mm3; NK: 90-600/mm3 (adultos)",cuidadosEnfermeria:["Extraer muestra en tubo con EDTA","Procesar dentro de las 24 horas en temperatura ambiente (no refrigerar)","No agitar la muestra","Evitar extraer muestra durante infecciones agudas activas (puede alterar resultados)"]},{nombre:"Pruebas de funcion fagocitica (dihidrorodamina - DHR)",descripcion:"Detecta enfermedad granulomatosa cronica; mide la produccion de superoxido por neutrofilos activados",valoresReferencia:"Indice de estimulacion normal > 100; en EGC ausencia total de conversion",cuidadosEnfermeria:["Procesar la muestra de forma URGENTE (dentro de 2 horas de extraida)","Mantener a temperatura ambiente, NUNCA refrigerar","Coordinar con el laboratorio de inmunologia para disponibilidad del reactivo","Extraer en tubo con heparina litio (no EDTA)"]},{nombre:"Estudio genetico molecular",descripcion:"Identifica mutaciones causales en genes especificos (BTK, RAG1/2, IL2RG, CYBB, etc.); confirma el diagnostico y orienta el consejo genetico",valoresReferencia:"Sin mutaciones patogenicas en genes del sistema inmune",cuidadosEnfermeria:["Extraer muestra de sangre en tubo con EDTA para ADN genomico","Proporcionar consejo genetico previo al estudio junto con genetista","Informar que el resultado puede tardar semanas a meses","Ofrecer estudio a familiares de primer grado si se identifica mutacion"]}]},tratamientoMedico:{objetivos:["Reemplazar o restaurar la funcion inmune deficiente","Prevenir infecciones recurrentes y sus complicaciones","Tratar infecciones activas con antibioticoterapia dirigida","Curar la inmunodeficiencia cuando sea posible (trasplante en SCID)","Mejorar la calidad de vida y permitir desarrollo normal en ni\xf1os"],farmacologico:[{nombre:"Inmunoglobulina Intravenosa (IGIV)",grupo:"Terapia de reemplazo de anticuerpos",mecanismo:"Aporta anticuerpos IgG policlonales que suplementan o reemplazan la produccion endogena deficiente, restaurando la opsonizacion y neutralizacion de patogenos",dosis:"400-600 mg/kg IV cada 3-4 semanas; ajustar para mantener IgG valle > 700-800 mg/dL",cuidadosEnfermeria:["Premedicar con ibuprofeno o paracetamol 30-60 min antes para prevenir reacciones","Iniciar infusion a velocidad lenta (0.5 mg/kg/min) e incrementar gradualmente","Monitorizar signos vitales cada 30 minutos durante la infusion","Tener adrenalina 0.3 mg IM disponible por riesgo de reaccion anafilactoide","Registrar numero de lote de la IGIV para trazabilidad"]},{nombre:"Trimetoprim-Sulfametoxazol (TMP-SMX)",grupo:"Profilaxis antibiotica",mecanismo:"Inhibicion sinergica de la sintesis de folatos bacterianos y de Pneumocystis jirovecii; efectivo para profilaxis en defectos de celulas T",dosis:"Profilaxis: TMP 5 mg/kg/dia en 2 tomas (max 160 mg TMP), 3 dias/semana",cuidadosEnfermeria:["Administrar con abundante agua para prevenir cristaluria","Monitorizar hemograma mensual (puede causar citopenias)","Vigilar aparicion de rash cutaneo (puede ser severo: Stevens-Johnson)","Controlar funcion renal periodicamente","Informar al paciente que debe tomarlo aunque se sienta bien (es profilaxis)"]},{nombre:"Itraconazol",grupo:"Antifungico triazolico (profilaxis en defectos fagociticos)",mecanismo:"Inhibe la 14-alfa-desmetilasa del ergosterol fungico, con actividad frente a Aspergillus spp., Candida spp. y otros hongos dimorficos relevantes en EGC",dosis:"200 mg/dia oral de manera continua",cuidadosEnfermeria:["Administrar con alimentos o bebida acida para mejorar absorcion","Monitorizar interacciones farmacologicas (inhibidor potente CYP3A4)","Vigilar funcion hepatica mensual (hepatotoxicidad posible)","Verificar que el paciente no tome otros azoles simultaneamente","Comprobar niveles plasmaticos si hay dudas sobre la absorcion"]}],noFarmacologico:["Evitar vacunas a virus vivos (sarampion, varicela, fiebre amarilla) en inmunodeficiencias celulares graves","Higiene rigurosa de manos y alimentos en el domicilio","Uso de mascarilla en lugares con alta densidad de personas durante temporadas de virus respiratorios","Registro sistematico de todas las infecciones para optimizar el seguimiento","Soporte nutricional especifico en pacientes con malabsorcion","Trasplante de celulas hematopoyeticas en SCID y casos seleccionados (curativo)"]},cuidadosEnfermeria:{valoracion:["Registrar historia detallada de infecciones: tipo, frecuencia, severidad y respuesta a tratamiento","Evaluar el estado nutricional: peso, talla, pliegues (especialmente en ni\xf1os)","Valorar el estado vacunal actual","Identificar signos de infeccion activa en todos los focos posibles","Evaluar el impacto psicosocial de la enfermedad cronica en el paciente y la familia","Verificar adherencia al tratamiento profilactico"],intervenciones:["Preparar y administrar IGIV segun protocolo de infusion institucional","Implementar precauciones de aislamiento inverso (protector) segun grado de inmunosupresion","Evitar TODAS las vacunas a virus vivos en pacientes con deficiencia de celulas T","Realizar curaciones de heridas con tecnica aseptica rigurosa","Coordinar con equipo de inmunologia, infectologia y genetica","Gestionar acceso venoso de larga duracion (port-a-cath, PICC) para infusiones regulares de IGIV"],educacionPaciente:["Explicar la naturaleza genetica de la inmunodeficiencia y la necesidad de tratamiento de por vida","Ense\xf1ar signos de infeccion que requieren consulta medica urgente","Instruir sobre higiene de manos y medidas de prevencion de infecciones en el hogar","Explicar cuales vacunas son seguras y cuales estan contraindicadas","Informar sobre la Fundacion Jeffrey Modell y grupos de apoyo para pacientes y familias","Orientar sobre el consejo genetico para planificacion familiar"],monitorizacion:["Niveles sericos de IgG (IgG valle) 3-4 semanas antes de cada infusion de IGIV","Hemograma mensual durante profilaxis con TMP-SMX","Funcion renal y hepatica trimestral","Radiografia de torax semestral para detectar bronquiectasias progresivas","Espirometria anual en adultos con afectacion pulmonar","Registro de todas las infecciones intercurrentes con fechas, tipo y tratamiento"]},npiNanda:[{codigo:"00004",nombre:"Riesgo de infeccion",definicion:"Vulnerable a ser invadido y multiplicado por organismos patogenos que pueden comprometer la salud",caracteristicasDefinitorias:["Niveles bajos de inmunoglobulinas sericas","Historia de infecciones bacterianas recurrentes","Ausencia o deficiencia de subpoblaciones linfocitarias"],factoresRelacionados:["Defecto intrinseco del sistema inmune","Hipogammaglobulinemia o agammaglobulinemia","Deficiencia de celulas T o NK"]},{codigo:"00036",nombre:"Riesgo de deterioro de la integridad cutanea",definicion:"Vulnerable a sufrir una alteracion en la epidermis y/o dermis que puede comprometer la salud",caracteristicasDefinitorias:["Infecciones cutaneas recurrentes","Eccema cronico en sindrome de Wiskott-Aldrich","Granulomas cutaneos en EGC"],factoresRelacionados:["Defecto fagocitico con infecciones cutaneas repetidas","Respuesta inflamatoria aberrante","Malnutricion asociada"]},{codigo:"00069",nombre:"Afrontamiento ineficaz",definicion:"Incapacidad para valorar correctamente los factores de estres, seleccionar adecuadamente las respuestas y usar los recursos disponibles",caracteristicasDefinitorias:["Verbaliza incapacidad para manejar la enfermedad cronica","Incumplimiento del tratamiento profilactico","Aislamiento social por miedo a infecciones"],factoresRelacionados:["Enfermedad cronica incurable de por vida","Restricciones sociales por riesgo infeccioso","Incertidumbre sobre el pronostico"]}],npiNic:[{codigo:"6540",nombre:"Control de infecciones",actividades:["Implementar precauciones de aislamiento protector en hospitalizaciones","Aplicar higiene de manos estricta antes de cualquier contacto con el paciente","Limitar visitas a personas sanas durante periodos de infeccion comunitaria alta","Realizar cultivos ante cualquier signo o sintoma de infeccion","Administrar profilaxis antiinfecciosa segun indicacion medica y protocolo"]},{codigo:"2300",nombre:"Administracion de medicacion",actividades:["Preparar y administrar IGIV segun protocolo de velocidad de infusion","Premedicar para prevenir reacciones adversas a IGIV","Monitorizar signos vitales durante toda la infusion de IGIV","Verificar que los farmacos profilacticos se administran segun pauta prescrita","Documentar cada administracion con numero de lote para trazabilidad"]},{codigo:"5230",nombre:"Mejorar el afrontamiento",actividades:["Escuchar activamente las preocupaciones del paciente y la familia","Proporcionar informacion veraz y adaptada sobre la evolucion esperada","Conectar con grupos de apoyo de pacientes con inmunodeficiencia primaria","Facilitar la participacion en el autocuidado para aumentar la sensacion de control","Derivar a psicologia clinica ante signos de ansiedad o depresion"]}],npiNoc:[{codigo:"0703",nombre:"Severidad de la infeccion",indicadores:["Reduccion en la frecuencia de infecciones bacterianas","Ausencia de infecciones oportunistas","Temperatura corporal en rango normal","Hemocultivos negativos"],escala:"1=Grave, 2=Sustancial, 3=Moderado, 4=Leve, 5=Ninguno"},{codigo:"1302",nombre:"Afrontamiento de problemas",indicadores:["Verbaliza aceptacion de la enfermedad cronica","Cumple con el tratamiento profilactico prescrito","Identifica y usa recursos de apoyo disponibles","Mantiene actividades sociales adaptadas"],escala:"1=Nunca demostrado, 2=Raramente demostrado, 3=A veces demostrado, 4=Frecuentemente demostrado, 5=Siempre demostrado"}],complicaciones:["Bronquiectasias y enfermedad pulmonar cronica por infecciones respiratorias repetidas","Sepsis fulminante por bacterias encapsuladas (Streptococcus pneumoniae, Haemophilus influenzae)","Infecciones oportunistas graves: Pneumocystis, CMV, criptosporidiosis","Neoplasias linfoides (linfomas B en IDCV)","Autoinmunidad: citopenias, artritis, EII, tiroiditis","Retraso del desarrollo cognitivo por encefalitis viral en inmunodeficiencias celulares","Muerte en la infancia sin diagnostico y tratamiento oportuno (SCID)"],criteriosAlarma:["Fiebre alta con deterioro del estado general en paciente con inmunodeficiencia conocida","Signos de sepsis: hipotension, taquicardia, alteracion del sensorio","Disnea o hipoxemia (neumonia grave u oportunista)","Reaccion grave durante infusion de IGIV: hipotension, broncoespasmo, urticaria generalizada","Primera infeccion oportunista diagnosticada en nino (sugiere SCID)","Convulsiones o deterioro neurologico (encefalitis viral, meningitis)"],emergencyLevel:"moderado",relatedPathologyIds:["pat_lupus","pat_vasculitis","pat_rechazo_trasplante","pat_linfoma"],isPremium:!0},{id:"pat_rechazo_trasplante",nombre:"Rechazo de Trasplante",bodySystemId:"inmunologico",definicion:"Respuesta inmune del receptor contra el organo o tejido trasplantado debido al reconocimiento de antigenos de histocompatibilidad (HLA) del donante como extra\xf1os. Constituye la principal causa de perdida del injerto a largo plazo y puede poner en peligro la vida del receptor en sus formas agudas y aceleradas.",epidemiologia:"Afecta al 10-20% de los trasplantes renales en el primer ano a pesar de la inmunosupresion moderna. El rechazo agudo mediado por anticuerpos es la forma mas grave con perdida del injerto en el 40-60% de los casos no tratados. El rechazo cronico afecta al 30-40% de los injertos renales a los 10 a\xf1os. En trasplante hepatico la incidencia de rechazo agudo es de 30-60%, pero la tolerancia espontanea es mas frecuente que en otros organos. La supervivencia del injerto renal al ano es del 90-95% en la actualidad.",factoresRiesgo:["Alto grado de incompatibilidad HLA entre donante y receptor (especialmente HLA-DR)","Presencia de anticuerpos donante-especificos (DSA) preformados o de novo","Incumplimiento del tratamiento inmunosupresor","Infecciones virales (CMV, BK virus) que activan el sistema inmune","Trasplante de donante cadaverico vs. donante vivo","Sensibilizacion previa por transfusiones, embarazos o trasplantes anteriores","Panel de anticuerpos reactivos (PRA) preoperatorio elevado"],fisiopatologia:"El reconocimiento de aloantigenos del donante se produce por dos vias: 1) Via directa: celulas T del receptor reconocen complejos HLA del donante con peptidos en la superficie de celulas presentadoras de antigenos del injerto. 2) Via indirecta: celulas T del receptor reconocen peptidos del donante presentados por HLA propios. La activacion de celulas T lleva a produccion de citocinas (IL-2, IFN-gamma, TNF), activacion de celulas B con produccion de anticuerpos anti-HLA (DSA) y activacion del complemento (via C4d). Los DSA danan el endotelio vascular del injerto, generando microtromboembolia, isquemia y perdida progresiva del organo.",signosYSintomas:{signos:["Elevacion de creatinina serica (trasplante renal: aumento > 25% del valor basal)","Disminucion de la diuresis u oliguria","Hipertension arterial de reciente aparicion o empeoramiento","Dolor o sensibilidad en sitio del injerto (trasplante renal: fosa iliaca)","Fiebre de bajo grado","Edema del injerto detectable por ecografia Doppler","Ictericia y elevacion de bilirrubina (trasplante hepatico)","C4d positivo en capilares peritubulares (marcador de rechazo humoral)"],sintomas:["Malestar general y fatiga","Reduccion de la diuresis percibida por el paciente","Dolor en fosa iliaca sobre el injerto renal","Fiebre o febricula","Nauseas y anorexia","Alteracion del peso corporal por retencion hidrica"]},clasificacion:{nombre:"Clasificacion de Banff 2022 por mecanismo y temporalidad",tipos:[{nombre:"Rechazo hiperagudo",descripcion:"Mediado por anticuerpos preformados. Ocurre en minutos a horas post-trasplante. Catastrofico, requiere nefrectomia inmediata. Actualmente muy raro por el crossmatch previo."},{nombre:"Rechazo agudo mediado por celulas T (TCMR)",descripcion:"Ocurre dias a semanas post-trasplante. Infiltrado linfocitario intersticial y tubulitis en biopsia. Responde bien a pulsos de corticoides."},{nombre:"Rechazo agudo mediado por anticuerpos (ABMR)",descripcion:"Mediado por DSA anti-HLA. C4d positivo en biopsia. Capilaritis peritubular. Requiere plasmaferesis, IGIV y rituximab. Peor pronostico."},{nombre:"Rechazo cronico activo (CAMR)",descripcion:"Perdida lenta y progresiva de la funcion del injerto por DSA persistentes. Glomerulopatia del trasplante en biopsia. Difucil tratamiento."}]},diagnostico:{anamnesis:["Historia de cumplimiento del tratamiento inmunosupresor","Antecedente de infecciones recientes (CMV, BK virus que activan sistema inmune)","Cambios en la diuresis, peso corporal o presion arterial","Episodios previos de rechazo y tratamientos recibidos","Historia de transfusiones o embarazos (sensibilizacion)","Fecha del trasplante y tipo de donante (vivo vs. cadaverico)"],examenFisico:["Palpacion del injerto renal: dolor, aumento de tamano, consistencia","Evaluacion de la diuresis: oliguria, cambios en el color de la orina","Medicion de presion arterial (hipertension como signo de rechazo)","Evaluacion del estado de hidratacion: edemas, mucosas","Ictericia en trasplante hepatico","Auscultacion pulmonar por causas alternativas de deterioro (infeccion)"],pruebas:[{nombre:"Creatinina serica y clearance de creatinina",descripcion:"Marcador primario de funcion del injerto renal; elevacion sugiere rechazo, toxicidad por inhibidores de calcineurina, infeccion u obstruccion",valoresReferencia:"Creatinina objetivo post-trasplante: < 1.5 mg/dL (varia segun basal del paciente); aumento > 25% requiere investigacion urgente",cuidadosEnfermeria:["Extraer muestra de sangre en tubo sin anticoagulante cada ma\xf1ana en hospitalizados","Registrar diuresis de las ultimas 24 horas junto con la creatinina","Notificar inmediatamente al medico cualquier aumento > 0.3 mg/dL respecto al dia anterior","Verificar que el paciente no tome AINEs ni aminoglucosidos (nefrotoxicos)"]},{nombre:"Biopsia del injerto (gold standard)",descripcion:"Permite clasificacion de Banff: tipo e intensidad del rechazo, grado de fibrosis y cambios cronicoos. Guia el tratamiento especifico",valoresReferencia:"Sin infiltrado inflamatorio, sin tubulitis, C4d negativo, sin glomerulopatia del trasplante",cuidadosEnfermeria:["Verificar coagulacion (TP, KPTT, plaquetas) y presion arterial antes del procedimiento","Suspender anticoagulantes segun protocolo (generalmente 5 dias antes para warfarina)","Posicionar al paciente en decubito supino con rodillo bajo el flanco del injerto","Monitorizar presion arterial y hematocrito cada 30 minutos por 4 horas post-biopsia","Indicar reposo absoluto en cama durante 6-12 horas post-biopsia","Vigilar hematuria macroscopica y dolor en sitio de puncion"]},{nombre:"Anticuerpos donante-especificos (DSA) por Luminex",descripcion:"Detecta y cuantifica anticuerpos anti-HLA especificos contra el donante; marcadores clave de rechazo humoral activo y cronico",valoresReferencia:"DSA negativos (MFI < 500 segun cut-off institucional)",cuidadosEnfermeria:["Extraer muestra de suero en tubo sin anticoagulante","Registrar si el paciente recibio IGIV en las ultimas 3-4 semanas (puede interferir)","Coordinar con laboratorio de histocompatibilidad la disponibilidad del test","Informar al paciente sobre la importancia del resultado para guiar el tratamiento"]},{nombre:"Ecografia Doppler del injerto",descripcion:"Evalua perfusion vascular del injerto, descarta obstruccion ureteral, colecciones periinjerto y estenosis de arteria renal del trasplante",valoresReferencia:"Indice de resistencia (IR): 0.50-0.70; perfusion normal de corteza e hilio",cuidadosEnfermeria:["No requiere ayuno ni preparacion especial","Informar al paciente que el estudio es indoloro y sin radiacion","Acomodar al paciente en decubito supino con exposicion del injerto","Registrar la hora del ultimo nivel de tacrolimus previo al estudio"]}]},tratamientoMedico:{objetivos:["Revertir el episodio de rechazo agudo y recuperar la funcion del injerto","Prevenir el rechazo cronico y prolongar la sobrevida del injerto","Minimizar la toxicidad del tratamiento inmunosupresor","Mantener la calidad de vida del receptor","Evaluar la necesidad de retrasplante en perdida definitiva del injerto"],farmacologico:[{nombre:"Metilprednisolona en pulsos",grupo:"Corticosteroide de alta dosis (primera linea en rechazo celular agudo)",mecanismo:"Supresion masiva de la respuesta inmune celular: inhibe la proliferacion de linfocitos T, reduce produccion de IL-2 y otras citocinas activadoras, disminuye la expresion de moleculas de adhesion en el endotelio del injerto",dosis:"500 mg IV/dia por 3 dias consecutivos (pulso de esteroides); monitorear estrechamente",cuidadosEnfermeria:["Administrar en infusion IV lenta de 30-60 minutos para prevenir arritmias cardiacas","Monitorizar glucemia cada 4 horas durante los pulsos (hiperglucemia severa frecuente)","Controlar electrolitos (hipopotasemia) con correcciones segun necesidad","Registrar presion arterial y frecuencia cardiaca cada hora durante la infusion","Administrar proteccion gastrica (pantoprazol 40 mg IV) para prevenir ulceras"]},{nombre:"Timoglobulina (Globulina antitimocitica - ATG)",grupo:"Anticuerpo policlonal antilinfocitario (rechazo corticorresistente o grave)",mecanismo:"Depleciona linfocitos T por citotoxicidad complemento-dependiente y celular; bloquea moleculas coestimulatorias y de activacion linfocitaria",dosis:"1.5 mg/kg/dia IV por 5-10 dias; filtro de 0.2 micras; infusion lenta (>6 horas)",cuidadosEnfermeria:["Premedicar OBLIGATORIO: metilprednisolona 1 mg/kg IV + difenhidramina 25-50 mg IV + paracetamol 1 g IV, 30 min antes","Infundir por acceso venoso central preferentemente; si es periferica usar vena de gran calibre","Monitorizar temperatura y presion arterial cada 30 minutos durante la infusion","Vigilar leucopenia y trombocitopenia: hemograma diario durante el tratamiento","Reducir dosis 50% si plaquetas < 50.000/mm3 o leucocitos < 2.000/mm3"]},{nombre:"Rituximab + Inmunoglobulina IV + Plasmaferesis",grupo:"Tratamiento combinado del rechazo humoral agudo mediado por anticuerpos",mecanismo:"Rituximab depleciona linfocitos B CD20+; IGIV neutraliza DSA y bloquea receptores Fc; plasmaferesis elimina DSA circulantes del compartimiento intravascular",dosis:"Rituximab 375 mg/m2 IV x 1-4 dosis; IGIV 1-2 g/kg/dosis; plasmaferesis diaria x 5-10 sesiones",cuidadosEnfermeria:["Coordinar sesiones de plasmaferesis con el equipo de nefrologia o aferesis","Monitorizar fibrinogeno y factores de coagulacion durante la plasmaferesis (riesgo de sangrado)","Reponer albumina al 5% o plasma fresco congelado segun protocolo post-plasmaferesis","Administrar IGIV DESPUES de la sesion de plasmaferesis para evitar su eliminacion","Monitorizar acceso vascular para plasmaferesis (cateter de doble lumen): signos de infeccion, permeabilidad"]}],noFarmacologico:["Refuerzo estricto de la adherencia al tratamiento inmunosupresor de mantenimiento","Educacion sobre el reconocimiento precoz de signos de rechazo","Restriccion de nefrotoxicos (AINEs, aminoglucosidos, contraste yodado) en trasplante renal","Monitoreo estrecho de niveles plasmaticos de inhibidores de calcineurina (tacrolimus, ciclosporina)","Seguimiento psicologico para mejorar adherencia en pacientes con historia de incumplimiento"]},cuidadosEnfermeria:{valoracion:["Monitorizar creatinina serica diaria y comparar con basal del paciente","Registrar diuresis horaria en pacientes hospitalizados por sospecha de rechazo","Evaluar dolor, sensibilidad y tamano del injerto en cada turno","Verificar cumplimiento del tratamiento inmunosupresor y registrar niveles en sangre","Buscar signos de infeccion concomitante que puede simular rechazo","Evaluar presion arterial y peso diario (retencion hidrosalina en rechazo)"],intervenciones:["Administrar pulsos de metilprednisolona IV con monitoreo estricto de glucemia y presion arterial","Preparar acceso venoso central o cateter de doble lumen para ATG y plasmaferesis","Administrar premedicacion obligatoria antes de ATG y rituximab","Programar y coordinar sesiones de plasmaferesis con el equipo de aferesis","Realizar registros horarios de diuresis, presion arterial y temperatura","Coordinar con farmacia hospitalaria el acceso a medicacion de alto costo (rituximab, ATG)"],educacionPaciente:["Enfatizar que la adherencia al tratamiento inmunosupresor es la principal prevencion del rechazo","Ense\xf1ar a reconocer signos de alarma: disminucion de orina, dolor en fosa iliaca, fiebre, aumento de peso rapido","Instruir sobre la importancia de los controles de creatinina y niveles de tacrolimus","Explicar que ciertas infecciones (CMV, BK) pueden desencadenar rechazo","Proporcionar lista de medicamentos nefrotoxicos a evitar sin consulta medica","Informar sobre los recursos de atencion de urgencia si sospecha rechazo fuera del horario habitual"],monitorizacion:["Creatinina serica y diuresis diariamente en fase aguda","Niveles de tacrolimus o ciclosporina en sangre (nivel valle) en cada visita","DSA cada 3-6 meses en pacientes de alto riesgo","Hemograma semanal durante tratamiento con ATG o rituximab","Glucemia cada 4 horas durante pulsos de metilprednisolona","Presion arterial dos veces al dia; ajustar antihipertensivos segun respuesta"]},npiNanda:[{codigo:"00030",nombre:"Deterioro del intercambio gaseoso",definicion:"Exceso o deficit en la oxigenacion y/o eliminacion de dioxido de carbono en la membrana alveolocapilar",caracteristicasDefinitorias:["En rechazo pulmonar: disnea progresiva","Saturacion de oxigeno disminuida","Infiltrados en radiografia de torax"],factoresRelacionados:["Rechazo de trasplante pulmonar","Infeccion oportunista complicando el rechazo","Edema pulmonar por disfuncion del injerto"]},{codigo:"00078",nombre:"Gestion de salud ineficaz",definicion:"Patron de regulacion e integracion en la vida diaria de un regimen terapeutico que no es adecuado para alcanzar objetivos de salud especificos",caracteristicasDefinitorias:["Incumplimiento del tratamiento inmunosupresor prescrito","Omision de dosis referida por el paciente","Niveles subterapeuticos de tacrolimus en controles"],factoresRelacionados:["Complejidad del regimen inmunosupresor","Efectos adversos de la medicacion","Barreras economicas para acceder a medicacion de alto costo"]},{codigo:"00146",nombre:"Ansiedad",definicion:"Sensacion vaga e intranquilizadora de malestar o amenaza acompanada de una respuesta autonoma cuyo origen es con frecuencia inespecifico o desconocido para la persona",caracteristicasDefinitorias:["Verbaliza miedo a perder el injerto","Insomnio y tension muscular","Busqueda excesiva de informacion sobre su estado"],factoresRelacionados:["Amenaza a la integridad del injerto y la vida","Incertidumbre sobre la respuesta al tratamiento del rechazo","Experiencias previas de complicaciones graves"]}],npiNic:[{codigo:"2440",nombre:"Mantenimiento de dispositivos de acceso venoso",actividades:["Verificar permeabilidad del cateter central o PICC antes de cada uso","Realizar cura del sitio de insercion con tecnica esteril cada 72 horas","Monitorizar signos de infeccion del cateter: enrojecimiento, exudado, fiebre","Registrar fecha de insercion y cambiar segun protocolo institucional","Preparar correctamente el circuito de plasmaferesis con el equipo de aferesis"]},{codigo:"4120",nombre:"Manejo de liquidos",actividades:["Registrar balance hidrico estricto (ingresos y egresos) cada 8 horas","Monitorizar diuresis horaria en fase aguda de rechazo","Pesar al paciente en ayunas cada ma\xf1ana","Ajustar ritmo de infusion segun diuresis y presion arterial","Notificar al medico si diuresis cae por debajo de 0.5 mL/kg/h"]},{codigo:"5820",nombre:"Disminucion de la ansiedad",actividades:["Explicar en terminos claros cada procedimiento diagnostico y terapeutico","Favorecer la presencia de familiar de apoyo durante procedimientos","Proporcionar tiempo para que el paciente exprese sus miedos y preguntas","Actualizar al paciente sobre la evolucion de los examenes y la respuesta al tratamiento","Derivar a psicologia clinica si la ansiedad interfiere con el tratamiento"]}],npiNoc:[{codigo:"0504",nombre:"Funcion renal",indicadores:["Creatinina serica en rango objetivo para el paciente","Diuresis mayor a 0.5 mL/kg/h","Ausencia de edemas perifericos progresivos","Electrolitos sericos en rango normal"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"},{codigo:"1813",nombre:"Conocimiento: regimen terapeutico",indicadores:["El paciente nombra correctamente todos sus inmunosupresores y dosis","Identifica signos de rechazo que requieren consulta urgente","Verbaliza por que es critico no saltarse dosis","Refiere los alimentos e interacciones que debe evitar"],escala:"1=Ningun conocimiento, 2=Conocimiento escaso, 3=Conocimiento moderado, 4=Conocimiento sustancial, 5=Conocimiento extenso"}],complicaciones:["Perdida definitiva del injerto con retorno a dialisis (trasplante renal)","Muerte del receptor en rechazo de organos vitales no revertido (hepatico, cardiaco, pulmonar)","Infecciones oportunistas graves por exceso de inmunosupresion en el tratamiento del rechazo","Neoplasias linfoproliferativas post-trasplante (PTLD) por tratamiento con ATG o rituximab","Nefrotoxicidad cronica por inhibidores de calcineurina en el injerto superviviente","Complicaciones cardiovasculares por corticoterapia a largo plazo (hipertension, diabetes, osteoporosis)"],criteriosAlarma:["Anuria u oliguria grave (< 0.3 mL/kg/h) en receptor de trasplante renal","Creatinina que aumenta > 0.5 mg/dL en 24 horas","Fiebre mayor a 38.5\xb0C con deterioro del estado general en inmunosuprimido","Reaccion anafilactoide durante infusion de ATG o rituximab: hipotension, broncoespasmo","Sangrado excesivo post-biopsia del injerto: hematuria macroscopica persistente, hipotension","Ictericia de rapida instalacion en trasplante hepatico","Deterioro respiratorio agudo en trasplante pulmonar: caida de FEV1 > 20%"],emergencyLevel:"critico",relatedPathologyIds:["pat_insuficiencia_renal","pat_inmunodeficiencia_primaria","pat_vasculitis","pat_lupus"],isPremium:!0},{id:"pat_espondilitis",nombre:"Espondilitis Anquilosante",bodySystemId:"musculoesqueletico",definicion:"Enfermedad inflamatoria cronica de la columna vertebral y las articulaciones sacroiliacas que pertenece al grupo de las espondiloartropatias. Se caracteriza por inflamacion persistente que puede llevar a la fusion osea progresiva de las vertebras, causando rigidez y deformidad de la columna.",epidemiologia:"Afecta al 0.1-0.5% de la poblacion mundial. Es mas frecuente en hombres jovenes (relacion 3:1), con inicio tipico entre los 20-30 a\xf1os. El 90-95% de los pacientes son portadores del antigeno HLA-B27. En Argentina se estima una prevalencia de 0.3%, con subdiagnostico frecuente por inicio insidioso.",factoresRiesgo:["Positividad para HLA-B27","Antecedentes familiares de espondiloartropatia","Sexo masculino","Edad entre 15-35 a\xf1os","Historia de infecciones gastrointestinales o urogenitales","Enfermedad inflamatoria intestinal (Crohn, colitis ulcerosa)","Psoriasis","Uveitis anterior"],fisiopatologia:"El proceso inflamatorio se inicia en las entesis (union de tendones y ligamentos al hueso). Los linfocitos T CD4+ y CD8+ activados liberan TNF-alfa e IL-17, promoviendo inflamacion en articulaciones sacroiliacas y vertebras. Con el tiempo, la inflamacion cronica activa osteoblastos que forman sindesmofitos (puentes oseos entre vertebras), llevando a la fusion progresiva denominada 'columna en cana de bambu'. Tambien se afectan articulaciones perifericas, ojos, corazon y pulmones.",signosYSintomas:{signos:["Limitacion de la movilidad lumbar (test de Schober positivo < 5 cm)","Sacroileitis bilateral en radiografia o RMN","Sindesmofitos vertebrales en radiografia","Postura en flexion anterior (cifosis)","Columna en cana de bambu en estadios avanzados","Uveitis anterior (enrojecimiento, fotofobia)"],sintomas:["Lumbalgia inflamatoria de inicio insidioso (> 3 meses)","Rigidez matutina de mas de 30-60 minutos","Mejoria con el ejercicio y empeora con el reposo","Dolor que despierta al paciente en la segunda mitad de la noche","Dolor en region glulea alternante","Fatiga cronica","Dolor en talon (entesitis del tendon de Aquiles)","Dactilitis (dedo en salchicha)"]},clasificacion:{nombre:"Clasificacion ASAS (Assessment of SpondyloArthritis International Society)",tipos:[{nombre:"Espondiloartritis axial radiografica",descripcion:"Sacroileitis visible en radiografia convencional segun criterios de Nueva York modificados"},{nombre:"Espondiloartritis axial no radiografica",descripcion:"Inflamacion en RMN sin cambios radiograficos evidentes; estadio mas precoz"},{nombre:"Espondiloartritis periferica",descripcion:"Predominio de artritis, entesitis o dactilitis en articulaciones perifericas"}]},diagnostico:{anamnesis:["Caracteristicas del dolor lumbar (inicio < 45 a\xf1os, cronico, inflamatorio)","Rigidez matutina y duracion","Respuesta a AINEs","Historia familiar de espondiloartropatia, psoriasis, EII, uveitis","Antecedentes de uveitis, artritis periferica, entesitis","Sintomas extraarticulares (ocular, intestinal, cutaneo)"],examenFisico:["Test de Schober modificado (movilidad lumbar)","Expansion toracica (normal > 2.5 cm)","Distancia occipucio-pared","Maniobras de provocacion sacroiliaca (FABER, Gaenslen)","Evaluacion de postura y deformidades","Exploracion de entesis (talon, rodilla, cadera)","Examen ocular en busqueda de uveitis"],pruebas:[{nombre:"HLA-B27",descripcion:"Antigeno leucocitario humano presente en el 90-95% de los pacientes con EA",valoresReferencia:"Positivo o negativo; positivo apoya el diagnostico pero no es diagnostico por si solo",cuidadosEnfermeria:["Extraer muestra de sangre en tubo con anticoagulante (EDTA)","Informar al paciente que es un analisis genetico, no un analisis de rutina","Resultado positivo no confirma la enfermedad ni negativo la descarta"]},{nombre:"Proteina C reactiva (PCR) y VSG",descripcion:"Marcadores de inflamacion sistemica; pueden ser normales en hasta 50% de los casos",valoresReferencia:"PCR < 0.5 mg/dL; VSG < 20 mm/h (hombre), < 30 mm/h (mujer)",cuidadosEnfermeria:["No requiere ayuno","Informar que pueden ser normales incluso con enfermedad activa","Registrar junto a la escala de dolor para correlacion clinica"]},{nombre:"Radiografia de pelvis y columna lumbar",descripcion:"Detecta sacroileitis (esclerosis, erosiones, fusion) y sindesmofitos vertebrales",valoresReferencia:"Grado 0-IV de sacroileitis segun criterios de Nueva York; grado II bilateral o III-IV unilateral es diagnostico",cuidadosEnfermeria:["Proteger gonadas con delantal de plomo","Posicionar correctamente en decubito supino para pelvis AP","Informar que los cambios radiograficos pueden tardar a\xf1os en aparecer"]},{nombre:"Resonancia Magnetica Nuclear (RMN) de sacroiliacas",descripcion:"Gold standard para detectar inflamacion activa (edema oseo subcondral) antes de los cambios radiograficos",valoresReferencia:"Presencia de edema oseo subcondral en secuencias STIR es hallazgo patologico",cuidadosEnfermeria:["Verificar contraindicaciones (marcapasos, metal ferromagnetico, claustrofobia)","Retirar objetos metalicos antes del estudio","No requiere contraste en la mayoria de los casos; si se usa gadolinio, verificar funcion renal"]}]},tratamientoMedico:{objetivos:["Reducir el dolor y la rigidez","Mantener la funcion y movilidad de la columna","Prevenir la progresion estructural","Mejorar la calidad de vida","Controlar manifestaciones extraarticulares"],farmacologico:[{nombre:"Naproxeno",grupo:"AINE (Antiinflamatorio no esteroideo)",mecanismo:"Inhibe la COX-1 y COX-2, reduciendo la sintesis de prostaglandinas inflamatorias",dosis:"500-1000 mg/dia en 2 tomas; uso continuo mas eficaz que a demanda en EA",cuidadosEnfermeria:["Administrar con comidas para reducir irritacion gastrica","Monitorizar funcion renal y hepatica en uso prolongado","Vigilar signos de hemorragia digestiva (melena, hematemesis)","Evitar en pacientes con enfermedad renal, hepatica o ulcera peptica activa","Considerar proteccion gastrica con IBP si hay factores de riesgo gastrointestinal"]},{nombre:"Adalimumab",grupo:"Agente biologico anti-TNF (anticuerpo monoclonal)",mecanismo:"Neutraliza el TNF-alfa, citoquina clave en la inflamacion de la espondiloartritis",dosis:"40 mg subcutaneo cada 2 semanas",cuidadosEnfermeria:["Descartar tuberculosis latente con PPD y radiografia de torax antes de iniciar","Conservar en refrigerador (2-8 grados C), no congelar","Instruir tecnica de autoinyeccion subcutanea en abdomen o muslo","Vigilar signos de infeccion (fiebre, escalofrios) dado el riesgo de inmunosupresion","Suspender si se planifica cirugia mayor o aparecen infecciones graves"]},{nombre:"Secukinumab",grupo:"Agente biologico anti-IL-17A (anticuerpo monoclonal)",mecanismo:"Bloquea la interleuquina 17A, reduciendo la cascada inflamatoria en la entesis",dosis:"150-300 mg subcutaneo mensual (con dosis de carga semanal las primeras 4 semanas)",cuidadosEnfermeria:["Descartar tuberculosis latente antes de iniciar","Precaucion en pacientes con enfermedad inflamatoria intestinal (puede exacerbarla)","Monitorizar candidiasis mucocutanea (efecto adverso frecuente)","Conservar en refrigerador; sacar 30 min antes para administrar a temperatura ambiente","Educar sobre signos de infeccion y cuando consultar al medico"]}],noFarmacologico:["Fisioterapia y ejercicios de movilidad vertebral diarios (natacion, pilates)","Postura erecta; evitar posiciones en flexion prolongadas","Ejercicios de respiracion para mantener expansion toracica","Evitar tabaquismo (acelera progresion radiografica)","Colchon firme y almohada baja","Termoterapia para alivio de rigidez matutina"]},cuidadosEnfermeria:{valoracion:["Evaluar intensidad del dolor con escala EVA y localizacion","Medir movilidad lumbar (test de Schober) y expansion toracica","Valorar rigidez matutina: duracion y impacto funcional","Identificar manifestaciones extraarticulares (ojo, piel, intestino)","Evaluar capacidad para actividades de la vida diaria","Revisar cumplimiento del tratamiento farmacologico y fisioterapeutico"],intervenciones:["Administrar AINEs y biologicos segun indicacion medica","Aplicar calor local en zonas rigidas antes de los ejercicios","Supervisar y reforzar programa de ejercicios y postura","Coordinar con fisioterapia para plan de movilizacion","Monitorizar efectos adversos de la medicacion biologica","Educar sobre signos de uveitis (ojo rojo, dolor ocular, vision borrosa) para consulta urgente"],educacionPaciente:["Importancia de ejercicio diario como pilar del tratamiento","Posiciones correctas para dormir y trabajar (evitar flexion sostenida)","Como reconocer y reportar efectos adversos de los biologicos","Necesidad de controles periodicos y no suspender tratamiento sin indicacion medica","Signos de alerta de uveitis y consulta oftalmologica urgente","Importancia de cesar el tabaquismo en la progresion de la enfermedad"],monitorizacion:["Escala de actividad BASDAI (Bath Ankylosing Spondylitis Disease Activity Index)","PCR y VSG cada 3 meses","Radiografias de columna y pelvis anualmente en estadios avanzados","Control oftalmologico periodico","Densitometria osea ante riesgo de osteoporosis secundaria","Funcion hepatica y renal en uso de AINEs cronicos"]},npiNanda:[{codigo:"00132",nombre:"Dolor cronico",definicion:"Experiencia sensitiva y emocional desagradable ocasionada por una lesion tisular real o potencial o descrita en tales terminos (International Association for the Study of Pain); inicio subito o lento, de cualquier intensidad de leve a grave, constante o recurrente, sin un final anticipado o previsible y con duracion mayor de 3 meses.",caracteristicasDefinitorias:["Informe de dolor lumbar con duracion > 3 meses","Rigidez matutina prolongada","Expresion facial de dolor","Alteracion del patron de sueno","Reduccion de la capacidad para realizar actividades"],factoresRelacionados:["Proceso inflamatorio cronico en columna y sacroiliacas","Entesitis en sitios de insercion tendinosa","Progresion de la enfermedad sin tratamiento adecuado"]},{codigo:"00085",nombre:"Deterioro de la movilidad fisica",definicion:"Limitacion del movimiento fisico independiente e intencionado del cuerpo o de una o mas extremidades.",caracteristicasDefinitorias:["Disminucion del rango de movimiento vertebral","Dificultad para girarse en la cama","Incapacidad para mantener postura erecta","Lentitud en el movimiento","Test de Schober disminuido"],factoresRelacionados:["Rigidez articular por inflamacion cronica","Fusion vertebral progresiva","Dolor que limita el movimiento","Desacondicionamiento fisico"]},{codigo:"00093",nombre:"Fatiga",definicion:"Sensacion abrumadora y continua de agotamiento y disminucion de la capacidad para el trabajo fisico y mental habitual.",caracteristicasDefinitorias:["Verbaliza cansancio persistente no aliviado con el reposo","Incapacidad para mantener el nivel habitual de actividad","Falta de energia","Somnolencia"],factoresRelacionados:["Estado inflamatorio sistemico cronico","Alteracion del sueno por dolor nocturno","Efecto secundario de medicacion biologica"]}],npiNic:[{codigo:"1400",nombre:"Manejo del dolor",actividades:["Realizar valoracion exhaustiva del dolor (localizacion, caracter, frecuencia, duracion)","Administrar analgesicos y AINEs segun prescripcion","Aplicar medidas no farmacologicas: calor local, ejercicio terapeutico","Evaluar la eficacia de las medidas de control del dolor","Ajustar el plan de cuidados segun la respuesta del paciente"]},{codigo:"0224",nombre:"Terapia de ejercicios: movilidad articular",actividades:["Determinar la limitacion del movimiento articular y su efecto en la funcion","Instruir al paciente en ejercicios de amplitud de movimiento activos","Colaborar con fisioterapia en el plan de ejercicios especifico para EA","Monitorizar la localizacion e incomodidad del dolor durante el movimiento","Fomentar ejercicios en agua (natacion) para reducir carga articular"]},{codigo:"5510",nombre:"Educacion para la salud",actividades:["Explicar la cronicidad de la enfermedad y la importancia del autocuidado","Ense\xf1ar posiciones ergonomicas y tecnicas para proteger la columna","Informar sobre signos de complicaciones que requieren atencion urgente (uveitis)","Educar sobre el uso correcto de la medicacion biologica y efectos adversos"]}],npiNoc:[{codigo:"2102",nombre:"Nivel del dolor",indicadores:["Intensidad del dolor referida por el paciente","Duracion de los episodios de dolor","Expresiones faciales de dolor","Interferencia del dolor con las actividades diarias"],escala:"1=Grave, 2=Sustancial, 3=Moderado, 4=Leve, 5=Ninguno"},{codigo:"0208",nombre:"Movilidad",indicadores:["Mantenimiento de la posicion corporal","Movimiento articular","Movimiento muscular","Capacidad para caminar"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"}],complicaciones:["Fractura vertebral por osteoporosis secundaria y columna rigida","Uveitis anterior recurrente con riesgo de ceguera","Sindrome de cola de caballo por aracnoiditis","Insuficiencia aortica y alteraciones de la conduccion cardiaca","Fibrosis pulmonar apical","Amiloidosis renal secundaria","Osteoporosis y riesgo de fractura"],criteriosAlarma:["Dolor lumbar nocturno intenso de inicio brusco (descartar fractura)","Deficit neurologico: parestesias, debilidad o incontinencia (sindrome cola de caballo)","Ojo rojo con dolor y fotofobia (uveitis anterior)","Fiebre alta en paciente con biologicos (infeccion grave)","Disnea progresiva (afectacion cardiaca o pulmonar)"],emergencyLevel:"leve",relatedPathologyIds:["pat_artritis_reumatoide","pat_osteoporosis","pat_gota"],isPremium:!0},{id:"pat_fibromialgia",nombre:"Fibromialgia",bodySystemId:"musculoesqueletico",definicion:"Sindrome de dolor musculoesqueletico cronico y generalizado, caracterizado por sensibilizacion central del sistema nervioso que produce umbral del dolor disminuido, fatiga, alteraciones del sueno y disfuncion cognitiva. No existe da\xf1o tisular demostrable ni proceso inflamatorio.",epidemiologia:"Afecta al 2-8% de la poblacion mundial, con predominio femenino marcado (relacion mujer:hombre 9:1). Inicio tipico entre los 30-60 a\xf1os. Es la segunda enfermedad reumatologica mas frecuente despues de la artrosis. En Argentina se estima una prevalencia del 3-5% de la poblacion adulta.",factoresRiesgo:["Sexo femenino","Antecedentes de trauma fisico o psicologico","Trastornos del sueno cronicos","Ansiedad y depresion","Historia de abuso fisico o emocional","Antecedentes familiares de fibromialgia","Otras enfermedades reumatologicas (AR, lupus)","Sindrome de intestino irritable","Cefalea tensional o migrana cronica"],fisiopatologia:"La fibromialgia es consecuencia de una sensibilizacion central: el sistema nervioso central amplifica las se\xf1ales dolorosas de manera anormal. Se observa hipersensibilizacion de neuronas del asta dorsal medular y alteraciones en la modulacion descendente del dolor (reduccion de serotonina, noradrenalina y opioides endogenos). Los estudios de neuroimagen muestran aumento de la actividad en areas de procesamiento del dolor ante estimulos normalmente no dolorosos (alodinia). Factores geneticos y estresores ambientales contribuyen al desarrollo.",signosYSintomas:{signos:["Dolor a la palpacion en multiples puntos anatomicos (tender points)","Alodinia cutanea generalizada","Hiperalgesia difusa","Ausencia de signos inflamatorios articulares objetivos","Exploracion neurologica normal"],sintomas:["Dolor musculoesqueletico cronico y generalizado (> 3 meses, en los 4 cuadrantes)","Fatiga severa no aliviada con el reposo","Sueno no reparador (despertar sin descanso)","Disfuncion cognitiva (niebla mental: dificultad de concentracion y memoria)","Rigidez matutina generalizada","Cefalea tensional frecuente","Parestesias en extremidades","Sindrome de intestino irritable","Hipersensibilidad a temperatura, ruido y luz","Ansiedad y depresion"]},clasificacion:{nombre:"Criterios ACR 2010/2016 (American College of Rheumatology)",tipos:[{nombre:"Indice de Dolor Generalizado (WPI)",descripcion:"Conteo de areas dolorosas en la ultima semana (0-19 areas); se requiere WPI >= 7"},{nombre:"Escala de Gravedad de Sintomas (SS)",descripcion:"Puntuacion de fatiga, sueno no reparador y disfuncion cognitiva (0-12); se requiere SS >= 5"},{nombre:"Fibromialgia diagnosticada",descripcion:"WPI >= 7 y SS >= 5, o WPI 4-6 y SS >= 9; sintomas presentes >= 3 meses; sin otro trastorno que explique el dolor"}]},diagnostico:{anamnesis:["Descripcion detallada del dolor: localizacion, caracter, intensidad, factores moduladores","Patron del sueno y calidad del descanso","Nivel de fatiga con escala numerica","Sintomas cognitivos: memoria, concentracion","Historial de trauma fisico o psicologico","Sintomas de ansiedad y depresion","Impacto en actividades laborales y sociales","Tratamientos previos y respuesta"],examenFisico:["Exploracion de los 18 puntos sensibles clasicos (tender points ACR 1990)","Evaluacion de alodinia cutanea","Descarta signos inflamatorios articulares (sinovitis, eritema, calor)","Exploracion neurologica completa","Evaluacion del estado de animo (escala PHQ-9)","Medicion de presion al dolor con algometro"],pruebas:[{nombre:"Hemograma completo y VSG",descripcion:"Para descartar enfermedades inflamatorias o infecciosas que simulen fibromialgia",valoresReferencia:"Normales en fibromialgia; VSG < 20 mm/h (hombre), < 30 mm/h (mujer)",cuidadosEnfermeria:["Explicar que los analisis son para descartar otras causas, no para confirmar fibromialgia","Obtener en ayunas si se solicitan junto a glucemia","Registrar sintomas actuales al momento de la extraccion"]},{nombre:"TSH (hormona estimulante del tiroides)",descripcion:"Descarta hipotiroidismo, causa frecuente de fatiga y dolor muscular que puede confundirse con fibromialgia",valoresReferencia:"0.4-4.0 mUI/L",cuidadosEnfermeria:["No requiere ayuno","Informar que el hipotiroidismo puede coexistir con fibromialgia","Registrar medicacion tiroidea actual si la hubiera"]},{nombre:"ANA (anticuerpos antinucleares)",descripcion:"Descarta enfermedades del tejido conectivo como lupus eritematoso sistemico",valoresReferencia:"Negativo o titulos bajos (< 1:80) en fibromialgia",cuidadosEnfermeria:["Explicar que un ANA positivo debil no confirma lupus","No requiere preparacion especial","Complementar con anti-DNA, complemento si ANA positivo"]}]},tratamientoMedico:{objetivos:["Reducir la intensidad del dolor","Mejorar la calidad del sueno","Incrementar la capacidad funcional","Tratar comorbilidades (ansiedad, depresion)","Mejorar la calidad de vida"],farmacologico:[{nombre:"Duloxetina",grupo:"Inhibidor de la recaptacion de serotonina y noradrenalina (IRSN)",mecanismo:"Aumenta la disponibilidad de serotonina y noradrenalina en sinapsis, reforzando las vias descendentes inhibitorias del dolor",dosis:"30-60 mg/dia (iniciar con 30 mg, aumentar a 60 mg al mes)",cuidadosEnfermeria:["Administrar con comidas para minimizar nauseas iniciales","Advertir que el efecto terapeutico puede tardar 4-8 semanas","No suspender bruscamente; reduccion gradual para evitar sindrome de discontinuacion","Vigilar cambios en el estado de animo e ideacion suicida al inicio","Contraindicada con IMAO; esperar 14 dias entre ambos farmacos"]},{nombre:"Pregabalina",grupo:"Ligando de canales de calcio (anticonvulsivante con efecto analgesico central)",mecanismo:"Se une a la subunidad alfa-2-delta de canales de calcio voltaje-dependientes, reduciendo la liberacion de neurotransmisores excitatorios",dosis:"150-450 mg/dia en 2-3 tomas; iniciar con 75 mg/12h",cuidadosEnfermeria:["Vigilar sedacion y mareos, especialmente al inicio y al aumentar dosis","Advertir que no debe conducir hasta conocer su efecto","Monitorizar edema periferico y aumento de peso","Reduccion progresiva al discontinuar para evitar convulsiones","Ajuste de dosis en insuficiencia renal segun clearance de creatinina"]},{nombre:"Amitriptilina",grupo:"Antidepresivo triciclico (TCA)",mecanismo:"Inhibe la recaptacion de serotonina y noradrenalina; a dosis bajas mejora la calidad del sueno y la modulacion del dolor",dosis:"10-50 mg al acostarse (dosis bajas para fibromialgia)",cuidadosEnfermeria:["Administrar 1-2 horas antes de acostarse por efecto sedante","Advertir sobre sequedad de boca, constipacion y vision borrosa (efectos anticolinergicos)","Precaucion en ancianos (riesgo de caidas por hipotension ortostatica)","Contraindicada en infarto reciente, glaucoma de angulo cerrado, retencion urinaria","Vigilar signos de toxicidad cardiaca (arritmias) en dosis elevadas"]}],noFarmacologico:["Ejercicio aerobico gradual y progresivo (caminar, natacion, bicicleta): pilar del tratamiento","Terapia cognitivo-conductual (TCC) para manejo del dolor cronico","Higiene del sueno: horarios regulares, ambiente oscuro y silencioso","Tecnicas de relajacion y mindfulness","Fisioterapia: estiramientos, hidroterapia","Psicoeducacion sobre la naturaleza del sindrome","Apoyo psicologico para ansiedad y depresion comorbidas","Grupos de apoyo de pacientes"]},cuidadosEnfermeria:{valoracion:["Evaluar dolor con escala EVA y cuestionario FIQ (Fibromyalgia Impact Questionnaire)","Valorar calidad y patron del sueno","Identificar sintomas cognitivos y su impacto funcional","Evaluar presencia de ansiedad y depresion (PHQ-9, GAD-7)","Valorar el impacto en actividades laborales, sociales y familiares","Identificar factores desencadenantes o agravantes del dolor"],intervenciones:["Establecer relacion terapeutica de confianza: validar la experiencia del dolor del paciente","Administrar medicacion segun prescripcion y monitorizar efectos","Promover y supervisar programa de ejercicio gradual","Ense\xf1ar tecnicas de relajacion y manejo del estres","Coordinar con psicologia, fisioterapia y trabajo social","Proporcionar entorno de descanso adecuado durante hospitalizacion"],educacionPaciente:["Explicar la fisiopatologia en lenguaje accesible: el dolor es real aunque los analisis sean normales","Importancia del ejercicio aerobico como tratamiento principal","Tecnicas de higiene del sueno","Como manejar los brotes de dolor sin incrementar la discapacidad","Uso correcto de la medicacion y por que tarda en hacer efecto","Recursos de apoyo: grupos de autoayuda y asociaciones de pacientes"],monitorizacion:["Escala EVA de dolor en cada consulta","Cuestionario FIQ trimestralmente","Calidad del sueno con escala de Pittsburgh mensualmente al inicio","Estado de animo con PHQ-9 cada 3 meses","Control de efectos adversos de duloxetina y pregabalina","Peso mensual por riesgo de ganancia con pregabalina"]},npiNanda:[{codigo:"00132",nombre:"Dolor cronico",definicion:"Experiencia sensitiva y emocional desagradable de origen multifactorial, con duracion mayor de 3 meses, asociada a sensibilizacion central del sistema nervioso.",caracteristicasDefinitorias:["Informe de dolor musculoesqueletico generalizado > 3 meses","Alodinia e hiperalgesia difusas","Alteraciones del sueno por dolor","Cambios en el patron de actividad","Expresion de agotamiento"],factoresRelacionados:["Sensibilizacion central del sistema nervioso","Trastorno del sueno cronico","Ansiedad y depresion comorbidas"]},{codigo:"00093",nombre:"Fatiga",definicion:"Sensacion abrumadora y continua de agotamiento y disminucion de la capacidad para el trabajo fisico y mental habitual.",caracteristicasDefinitorias:["Verbalizacion de cansancio persistente","Incapacidad para mantener actividades habituales","Sueno no reparador","Dificultad de concentracion"],factoresRelacionados:["Alteracion del sueno por dolor","Estado de dolor cronico","Ansiedad y depresion","Sedentarismo por evitacion del dolor"]},{codigo:"00095",nombre:"Patron de sueno deteriorado",definicion:"Interrupciones durante un tiempo limitado de la cantidad y calidad del sueno debidas a factores externos.",caracteristicasDefinitorias:["Dificultad para conciliar el sueno","Despertar frecuente durante la noche","Sensacion de no haber descansado al despertar","Fatiga diurna","Irritabilidad"],factoresRelacionados:["Dolor cronico que interrumpe el sueno","Ansiedad","Sindrome de piernas inquietas asociado"]}],npiNic:[{codigo:"1400",nombre:"Manejo del dolor",actividades:["Realizar valoracion exhaustiva del dolor con escalas validadas (EVA, FIQ)","Administrar analgesicos y coadyuvantes segun prescripcion","Aplicar tecnicas no farmacologicas: relajacion, calor superficial, distraccion","Explorar con el paciente factores que alivian o agravan el dolor","Involucrar a la familia en el plan de manejo del dolor"]},{codigo:"1850",nombre:"Mejorar el sueno",actividades:["Determinar el patron de sueno del paciente y posibles factores perturbadores","Instruir al paciente y familia sobre tecnicas de higiene del sueno","Limitar la ingesta de cafeina y alcohol por la tarde-noche","Ajustar el ambiente para favorecer el sueno (luz, ruido, temperatura)","Coordinar el horario de administracion de amitriptilina antes de acostarse"]},{codigo:"5270",nombre:"Apoyo emocional",actividades:["Establecer relacion terapeutica de confianza y validar la experiencia del dolor","Escuchar activamente las preocupaciones del paciente","Facilitar la expresion de sentimientos de frustacion y tristeza","Derivar a apoyo psicologico cuando sea necesario","Informar sobre grupos de apoyo de pacientes con fibromialgia"]}],npiNoc:[{codigo:"2102",nombre:"Nivel del dolor",indicadores:["Intensidad del dolor referida","Duracion de los episodios","Interferencia con actividades diarias","Expresiones de dolor"],escala:"1=Grave, 2=Sustancial, 3=Moderado, 4=Leve, 5=Ninguno"},{codigo:"0004",nombre:"Sueno",indicadores:["Horas de sueno","Patron de sueno","Calidad del sueno","Sensacion de descanso tras el sueno"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"}],complicaciones:["Depresion mayor secundaria al dolor cronico","Ansiedad generalizada y trastorno de panico","Discapacidad laboral permanente","Abuso de analgesicos y medicamentos","Aislamiento social y deterioro de relaciones interpersonales","Sindrome de sensibilidad quimica multiple"],criteriosAlarma:["Ideacion suicida o conducta autolesiva","Signos inflamatorios articulares objetivos (descartar AR, lupus)","Deficit neurologico focal (descartar causa organica)","Fiebre y perdida de peso (descartar causa infecciosa o neoplasica)","Empeoramiento rapido sin respuesta a tratamiento (revisar diagnostico)"],emergencyLevel:"ninguno",relatedPathologyIds:["pat_artritis_reumatoide","pat_espondilitis","pat_sarcopenia"],isPremium:!0},{id:"pat_gota",nombre:"Gota",bodySystemId:"musculoesqueletico",definicion:"Artropatia inflamatoria cristalina causada por el deposito de cristales de urato monosodico (UMS) en articulaciones y tejidos blandos, secundaria a hiperuricemia. Se manifiesta como episodios de artritis aguda recurrente, con riesgo de da\xf1o articular cronico y formacion de tofos.",epidemiologia:"Es la artritis inflamatoria mas frecuente en hombres mayores de 40 a\xf1os. Afecta al 1-4% de la poblacion general, con aumento sostenido en las ultimas decadas. Es mas frecuente en hombres (relacion 4:1), aunque la brecha disminuye en mujeres posmenopausicas. Se asocia fuertemente a sindrome metabolico, hipertension y enfermedad renal cronica.",factoresRiesgo:["Hiperuricemia (acido urico > 7 mg/dL en hombres, > 6 mg/dL en mujeres)","Consumo de alcohol (especialmente cerveza y licores)","Dieta rica en purinas (carnes rojas, visceras, mariscos)","Consumo de fructosa y bebidas azucaradas","Obesidad","Enfermedad renal cronica","Hipertension arterial","Medicamentos hiperuricemiantes (diureticos tiazidicos, aspirina dosis bajas)","Trasplante de organos (ciclosporina)","Psoriasis"],fisiopatologia:"La hiperuricemia produce supersaturacion del liquido sinovial con acido urico. Cuando los niveles superan el umbral de solubilidad (6.8 mg/dL), los uratos precipitan como cristales de UMS en articulaciones y tejidos blandos. Los cristales son fagocitados por neutrofilos y macro\u0444agos, activando el inflamasoma NLRP3 que genera IL-1beta, IL-6 y TNF-alfa, desencadenando inflamacion sinovial aguda intensa. La exposicion cronica produce tofos (depositos macroscopicos de cristales) y da\xf1o articular erosivo.",signosYSintomas:{signos:["Monoartritis aguda con calor, enrojecimiento y edema intenso","Articulacion metatarsofalangica del primer dedo (podagra) clasica","Tofos en helice auricular, olecranon, tendones","Efusion articular con liquido turbio","Cristales de UMS en liquido sinovial (birrefringencia negativa bajo luz polarizada)","Erosiones oseas subcondrales en radiografia (signo de la mordedura)"],sintomas:["Dolor articular agudo de inicio nocturno, muy intenso","Incapacidad para soportar el peso de la sabana sobre el dedo (podagra)","Fiebre y malestar general durante el ataque agudo","Artritis que alcanza su pico en 24-48 horas","Resolucion espontanea en 7-14 dias sin tratamiento","Periodos intercriticos asintomaticos entre ataques"]},clasificacion:{nombre:"Estadios de la enfermedad gotosa",tipos:[{nombre:"Hiperuricemia asintomatica",descripcion:"Niveles elevados de acido urico sin sintomas clinicos; no requiere tratamiento farmacologico especifico"},{nombre:"Gota aguda (ataque gotoso)",descripcion:"Episodio de artritis inflamatoria aguda por cristales de UMS; dolor severo, inicio subito, tipicamente nocturno"},{nombre:"Periodo intercritico",descripcion:"Fase asintomatica entre ataques; puede durar meses a a\xf1os; inicio del tratamiento hipouricemiante"},{nombre:"Gota tophacea cronica",descripcion:"Depositos macroscopicos de uratos (tofos), artritis cronica y da\xf1o articular erosivo"}]},diagnostico:{anamnesis:["Caracteristicas del dolor articular: inicio, localizacion, duracion, resolucion","Ataques previos y articulaciones afectadas","Dieta: consumo de alcohol, carnes, mariscos, fructosa","Medicacion actual (diureticos, AAS, ciclosporina)","Antecedentes de litiasis renal","Antecedentes familiares de gota","Enfermedades asociadas: HTA, DM2, insuficiencia renal, dislipemia"],examenFisico:["Articulacion afectada: calor, enrojecimiento, edema, dolor a la palpacion","Busqueda de tofos (helice auricular, olecranon, tendones)","Evaluacion de todas las articulaciones","Presion arterial (gota asociada a HTA)","Calculo de IMC"],pruebas:[{nombre:"Acido urico en sangre",descripcion:"Cuantifica hiperuricemia; puede ser normal durante el ataque agudo por redistribucion",valoresReferencia:"Normal: < 7 mg/dL en hombres, < 6 mg/dL en mujeres; objetivo terapeutico < 6 mg/dL",cuidadosEnfermeria:["Informar que el valor puede estar falsamente bajo durante el ataque agudo","Solicitar junto a funcion renal para planificacion del tratamiento","Ayuno de 8 horas para mayor precision analitica"]},{nombre:"Analisis de liquido sinovial",descripcion:"Gold standard: identificacion de cristales de UMS con birrefringencia negativa bajo luz polarizada",valoresReferencia:"Presencia de cristales aciculares de UMS es diagnostico; leucocitos > 2000/mm3 en ataque agudo",cuidadosEnfermeria:["Asistir en la artrocentesis en condiciones de esterilidad estricta","Enviar muestra a laboratorio inmediatamente (los cristales pueden disolverse)","Identificar correctamente el tubo sin anticoagulante para examen citologico"]},{nombre:"Radiografia de articulaciones afectadas",descripcion:"En estadios cronicos muestra erosiones con margen en voladizo (punch-out lesions) y tofos calcificados",valoresReferencia:"Normal en estadios agudos; erosiones caracteristicas en gota cronica",cuidadosEnfermeria:["Posicionar la articulacion afectada con cuidado dado el dolor intenso","Informar que la radiografia puede ser normal en primeros ataques","Ecografia de alta resolucion es alternativa mas sensible para detectar cristales"]},{nombre:"Funcion renal (creatinina, urea, TFG estimada)",descripcion:"La enfermedad renal cronica favorece la hiperuricemia y condiciona el tratamiento hipouricemiante",valoresReferencia:"Creatinina: 0.6-1.2 mg/dL; TFG > 60 mL/min/1.73m2",cuidadosEnfermeria:["No requiere ayuno especial","Registrar diuresis de 24h si se solicita acido urico urinario","La insuficiencia renal modifica la dosis de alopurinol"]}]},tratamientoMedico:{objetivos:["Resolver rapidamente el ataque agudo","Prevenir recurrencias","Reducir el acido urico a < 6 mg/dL (< 5 mg/dL en gota tophacea)","Disolver tofos existentes","Prevenir da\xf1o articular y renal"],farmacologico:[{nombre:"Colchicina",grupo:"Alcaloide antimitotico con efecto antiinflamatorio especifico en gota",mecanismo:"Inhibe la polimerizaci\xf3n de la tubulina, bloqueando la quimiotaxis de neutrofilos y la activacion del inflamasoma NLRP3",dosis:"Ataque agudo: 1 mg al inicio, luego 0.5 mg a la hora (max 1.5 mg/dia). Profilaxis: 0.5 mg/dia",cuidadosEnfermeria:["Iniciar lo antes posible en el ataque (ideal < 12h del inicio)","Vigilar diarrea, nauseas y vomitos (efectos adversos gastrointestinales frecuentes)","Reducir dosis en insuficiencia renal y hepatica","Interaccion con estatinas: riesgo de miopatia; monitorizar CPK","No usar en pacientes con insuficiencia renal grave (TFG < 15 mL/min)"]},{nombre:"Indometacina",grupo:"AINE potente (inhibidor COX no selectivo)",mecanismo:"Inhibe COX-1 y COX-2, reduciendo prostaglandinas inflamatorias y el dolor articular agudo",dosis:"50 mg cada 8 horas las primeras 48h, luego reduccion gradual en 5-7 dias",cuidadosEnfermeria:["Administrar con alimentos para reducir irritacion gastrica","Agregar proteccion gastrica con IBP en mayores de 65 a\xf1os o con factores de riesgo","Contraindicada en insuficiencia renal, enfermedad peptica activa e insuficiencia cardiaca","Vigilar elevacion de tension arterial en hipertensos","No combinar con otros AINEs; usar la dosis minima eficaz el menor tiempo posible"]},{nombre:"Alopurinol",grupo:"Inhibidor de la xantina oxidasa (hipouricemiante)",mecanismo:"Inhibe la xantina oxidasa, enzima que convierte hipoxantina en xantina y xantina en acido urico",dosis:"Iniciar con 100 mg/dia, aumentar 100 mg cada 2-4 semanas hasta lograr uricemia < 6 mg/dL; max 800-900 mg/dia",cuidadosEnfermeria:["NO iniciar durante el ataque agudo; esperar al menos 2-4 semanas","Iniciar siempre con dosis baja y escalar lentamente para evitar precipitar ataques","Vigilar rash cutaneo (puede indicar sindrome de Stevens-Johnson: suspender inmediatamente)","Administrar profilaxis con colchicina 0.5 mg/dia los primeros 6 meses","Ajustar dosis segun funcion renal (TFG); verificar genotipo HLA-B*58:01 en asiaticos (mayor riesgo de reaccion grave)"]}],noFarmacologico:["Restriccion de alcohol (especialmente cerveza y licores)","Reduccion de alimentos ricos en purinas (carnes rojas, visceras, mariscos)","Limitar bebidas azucaradas con fructosa","Hidratacion abundante (2-3 litros de agua por dia)","Reduccion de peso gradual (evitar ayuno prolongado que aumenta el urato)","Reposo e inmovilizacion de la articulacion durante el ataque agudo","Hielo local en articulacion durante el ataque"]},cuidadosEnfermeria:{valoracion:["Evaluar dolor con escala EVA y localizacion de la articulacion afectada","Inspeccionar articulacion: calor, enrojecimiento, edema","Identificar tofos visibles","Valorar movilidad articular y capacidad para deambular","Revisar dieta habitual y consumo de alcohol","Verificar medicacion actual que pueda elevar el acido urico"],intervenciones:["Administrar colchicina e indometacina segun prescripcion en el ataque agudo","Elevar y reposar la articulacion afectada","Aplicar frio local (hielo envuelto en pano) 20 min cada hora","Asegurar hidratacion adecuada (> 2 L/dia)","Iniciar alopurinol una vez resuelto el ataque segun indicacion","Educar sobre dieta hipopurinica y modificacion de habitos"],educacionPaciente:["Que es la gota y por que se producen los ataques","Alimentos a restringir y cuales son mas seguros (lacteos desnatados, vegetales, cereales)","Importancia de la hidratacion para eliminar el acido urico","Por que no iniciar hipouricemiantes durante el ataque agudo","Necesidad de tratamiento hipouricemiante de por vida y controles periodicos","Reconocer signos de tofo y consultar si aparecen nuevas lesiones"],monitorizacion:["Acido urico en sangre cada 2-4 semanas al ajustar alopurinol, luego cada 6 meses","Funcion renal y hepatica cada 3-6 meses","Numero y frecuencia de ataques","Evolucion y regresion de tofos","Tension arterial (gota asociada a HTA)","Peso mensual"]},npiNanda:[{codigo:"00132",nombre:"Dolor cronico",definicion:"Experiencia sensitiva y emocional desagradable causada por el deposito de cristales de urato monosodico en articulaciones y tejidos blandos.",caracteristicasDefinitorias:["Informe de dolor articular agudo e intenso","Conductas de proteccion de la articulacion afectada","Expresion facial de dolor","Limitacion del movimiento articular","Incapacidad para deambular"],factoresRelacionados:["Deposito de cristales de UMS en la articulacion","Proceso inflamatorio agudo por activacion del inflamasoma","Hiperuricemia no controlada"]},{codigo:"00188",nombre:"Tendencia a adoptar conductas de riesgo para la salud",definicion:"Deterioro de la capacidad para modificar el estilo de vida o los comportamientos de manera coherente con un cambio en el estado de salud.",caracteristicasDefinitorias:["Continua consumiendo alcohol a pesar del conocimiento del riesgo","No modifica la dieta tras ataques repetidos","Abandona el tratamiento hipouricemiante en periodos intercriticos"],factoresRelacionados:["Conocimiento insuficiente sobre la enfermedad","Habitos dieteticos arraigados","Falsa percepcion de mejoria en el periodo intercritico"]},{codigo:"00045",nombre:"Deterioro de la mucosa oral",definicion:"En este contexto, deterioro de la integridad de tejidos por depositos de urato en tejidos blandos (tofos).",caracteristicasDefinitorias:["Presencia de tofos visibles en helice auricular o tendones","Ulceracion de la piel sobre tofos","Exudado blanquecino por rotura de tofo"],factoresRelacionados:["Deposito cronico de cristales de UMS","Hiperuricemia persistente sin tratamiento adecuado"]}],npiNic:[{codigo:"1400",nombre:"Manejo del dolor",actividades:["Evaluar el dolor con escala EVA antes y despues de cada intervencion","Administrar colchicina e indometacina segun prescripcion","Elevar y reposar la articulacion afectada","Aplicar frio local para reducir inflamacion","Instruir al paciente sobre medidas no farmacologicas de alivio del dolor"]},{codigo:"5246",nombre:"Asesoramiento nutricional",actividades:["Evaluar los habitos alimentarios actuales del paciente","Proporcionar una lista de alimentos ricos en purinas a evitar","Indicar alimentos beneficiosos: lacteos desnatados, cereales, frutas (excepto fructosa)","Insistir en la importancia de la hidratacion abundante","Abordar el consumo de alcohol con estrategias de reduccion progresiva"]},{codigo:"5510",nombre:"Educacion para la salud",actividades:["Explicar la fisiopatologia de la gota en lenguaje accesible","Ense\xf1ar cuando y como usar la medicacion durante un ataque","Enfatizar la necesidad de continuar el hipouricemiante durante los periodos intercriticos","Informar sobre los objetivos de acido urico y la importancia de los controles analiticos"]}],npiNoc:[{codigo:"2102",nombre:"Nivel del dolor",indicadores:["Intensidad del dolor articular","Calor y enrojecimiento articular","Capacidad para deambular","Uso de medicacion analgesica"],escala:"1=Grave, 2=Sustancial, 3=Moderado, 4=Leve, 5=Ninguno"},{codigo:"1622",nombre:"Conducta de cumplimiento: dieta prescrita",indicadores:["Identifica alimentos a evitar","Consume dieta baja en purinas","Mantiene hidratacion adecuada","Restringe el alcohol"],escala:"1=Nunca demostrado, 2=Raramente demostrado, 3=A veces demostrado, 4=Frecuentemente demostrado, 5=Siempre demostrado"}],complicaciones:["Artritis gotosa cronica con da\xf1o articular erosivo","Tofos con ulceracion e infeccion secundaria","Nefrolitiasis por calculos de urato","Nefropatia por urato con insuficiencia renal cronica","Sindrome metabolico (gota como marcador)","Discapacidad funcional por destruccion articular"],criteriosAlarma:["Fiebre alta con artritis (descartar artritis septica)","Ataque poliarticular con sintomas sistemicos graves","Tofo con signos de infeccion (calor, pus, fiebre)","Deterioro rapido de la funcion renal en gotoso cronico","Reaccion cutanea grave al alopurinol (exantema extenso, ampollas)"],emergencyLevel:"leve",relatedPathologyIds:["pat_espondilitis","pat_artritis_reumatoide","pat_sarcopenia"],isPremium:!0},{id:"pat_sarcopenia",nombre:"Sarcopenia",bodySystemId:"musculoesqueletico",definicion:"Sindrome caracterizado por la perdida progresiva y generalizada de masa muscular esqueletica, fuerza muscular y rendimiento fisico, asociada al envejecimiento y/o a condiciones patologicas. Incrementa el riesgo de caidas, fracturas, dependencia funcional y mortalidad.",epidemiologia:"Afecta al 10-27% de las personas mayores de 65 a\xf1os, y hasta al 50% de los mayores de 80 a\xf1os. Es un problema de salud publica creciente en sociedades envejecidas. En Argentina, con el 15% de la poblacion mayor de 60 a\xf1os, se estima una prevalencia significativa y subdiagnosticada. Se asocia a mayor riesgo de hospitalizacion, caidas y mortalidad.",factoresRiesgo:["Edad avanzada (> 65 a\xf1os)","Sedentarismo e inactividad fisica","Desnutricion y deficit proteico","Enfermedades cronicas: insuficiencia cardiaca, EPOC, cancer, IRC","Diabetes mellitus tipo 2","Inflamacion cronica de bajo grado","Deficit de vitamina D y testosterona","Hospitalizacion prolongada","Uso de corticosteroides cronicos","Tabaquismo y consumo de alcohol"],fisiopatologia:"La sarcopenia resulta de un desequilibrio entre la sintesis y degradacion de proteinas musculares. Con el envejecimiento, disminuye la respuesta anabolica a la ingesta proteica y al ejercicio (resistencia anabolica). Se activan vias catabolicas (ubiquitina-proteasoma, autofagia) mediadas por citoquinas proinflamatorias (IL-6, TNF-alfa). La disminucion de hormonas anabolicas (testosterona, IGF-1, DHEA) y el aumento de miostatina contribuyen a la perdida de fibras musculares tipo II (rapidas). La reinervacion deficiente por neuropatia y la infiltracion grasa del musculo (mioesteatosis) agravan el cuadro.",signosYSintomas:{signos:["Masa muscular apendicular baja (DXA: < 7.0 kg/m2 en hombres, < 5.5 kg/m2 en mujeres)","Fuerza de presion manual reducida (< 28 kg en hombres, < 18 kg en mujeres)","Velocidad de marcha lenta (< 0.8 m/s en test de 4 metros)","Atrofia muscular visible, especialmente en extremidades","Perdida de peso y masa magra","Test de levantarse de la silla (5 repeticiones > 12 segundos)"],sintomas:["Debilidad generalizada y perdida de fuerza","Dificultad para realizar actividades cotidianas (subir escaleras, levantarse de una silla)","Mayor riesgo de caidas y tropiezos","Fatiga al esfuerzo fisico minimo","Perdida de peso involuntaria","Dificultad para caminar distancias habituales","Dependencia progresiva para actividades basicas"]},clasificacion:{nombre:"Criterios EWGSOP2 2019 (European Working Group on Sarcopenia in Older People)",tipos:[{nombre:"Presarcopenia / Probable sarcopenia",descripcion:"Solo fuerza muscular baja (F+) sin confirmacion de masa; indicacion de intervenir"},{nombre:"Sarcopenia confirmada",descripcion:"Fuerza muscular baja + masa muscular baja (F+ M+); confirmar con DXA o BIA"},{nombre:"Sarcopenia grave",descripcion:"Fuerza muscular baja + masa muscular baja + rendimiento fisico bajo (F+ M+ R+); mayor riesgo de discapacidad"}]},diagnostico:{anamnesis:["Caidas en el ultimo ano y circunstancias","Capacidad para realizar actividades de la vida diaria","Habitos alimentarios e ingesta proteica","Nivel de actividad fisica habitual","Enfermedades cronicas concomitantes","Medicacion actual (corticoides, diureticos)","Cuestionario SARC-F (5 preguntas de cribado)"],examenFisico:["Antropometria: peso, talla, IMC, perimetro de pantorrilla (< 31 cm es sugestivo)","Dinamometria de presion manual (handgrip): fuerza muscular","Test de velocidad de marcha (4 metros)","Test de levantarse de la silla (5 repeticiones sin apoyarse)","Test Short Physical Performance Battery (SPPB): equilibrio, marcha, levantarse","Evaluacion nutricional (MNA en ancianos)","Evaluacion cognitiva breve"],pruebas:[{nombre:"Densitometria de doble energia (DXA)",descripcion:"Gold standard para medir masa muscular apendicular; determina indice de masa muscular esqueletica",valoresReferencia:"IMM: < 7.0 kg/m2 en hombres, < 5.5 kg/m2 en mujeres (criterios EWGSOP2)",cuidadosEnfermeria:["Verificar contraindicaciones (embarazo)","Retirar objetos metalicos antes del estudio","El paciente debe estar en decubito supino tranquilo durante la exploracion","Informar que la radiacion es minima (menor que una radiografia convencional)"]},{nombre:"Bioimpedanciometria (BIA)",descripcion:"Alternativa practica al DXA para estimar masa muscular y grasa corporal en campo clinico",valoresReferencia:"Masa muscular apendicular: mismos puntos de corte que DXA; resultados afectados por hidratacion",cuidadosEnfermeria:["Paciente debe estar en ayunas 4h y sin ejercicio previo","Contraindicada en portadores de marcapasos","Asegurar que el paciente este bien hidratado (la deshidratacion sobreestima la sarcopenia)","Retirar metales y ropa gruesa antes del estudio"]},{nombre:"Analisis bioquimico: albumina, proteinas totales, vitamina D, hemograma",descripcion:"Evalua estado nutricional y factores contribuyentes a la sarcopenia",valoresReferencia:"Albumina > 3.5 g/dL; Vitamina D 25-OH > 30 ng/mL; proteinas totales 6.4-8.3 g/dL",cuidadosEnfermeria:["Extraer en ayunas de 8 horas","La albumina baja refleja desnutricion o inflamacion cronica","El deficit de vitamina D es muy frecuente y contribuye a la debilidad muscular"]}]},tratamientoMedico:{objetivos:["Incrementar la masa y fuerza muscular","Mejorar el rendimiento fisico y la velocidad de marcha","Prevenir caidas y fracturas","Mantener la independencia funcional","Tratar las causas subyacentes identificables"],farmacologico:[{nombre:"Vitamina D3 (Colecalciferol)",grupo:"Suplemento vitaminico (prohormona esteroidea)",mecanismo:"Actua sobre receptores de vitamina D en el musculo esqueletico, promoviendo la sintesis proteica y la funcion de fibras musculares tipo II",dosis:"800-2000 UI/dia oral; dosis de carga mensual (50.000 UI) si deficit severo",cuidadosEnfermeria:["Administrar con alimentos que contengan grasa para mejorar absorcion","Monitorizar niveles de 25-OH vitamina D y calcio cada 3-6 meses","Vigilar sintomas de hipervitaminosis (nauseas, calculos renales) con dosis altas","Corregir primero el deficit y luego mantener con dosis de mantenimiento","Registro de exposicion solar del paciente (complementa la suplementacion)"]},{nombre:"Leucina (aminoacido esencial de cadena ramificada)",grupo:"Suplemento nutricional / aminoacido esencial",mecanismo:"Activa la via mTOR en el musculo esqueletico, estimulando la sintesis proteica muscular postprandial",dosis:"2.5-3 g de leucina por comida principal; como parte de suplementos proteicos de 20-40 g",cuidadosEnfermeria:["Administrar junto a las comidas principales para maximizar la respuesta anabolica","Combinar siempre con ejercicio de resistencia para efecto sinergico","Vigilar en pacientes con enfermedad renal cronica (restriccion proteica)","Registrar la ingesta proteica total diaria (objetivo 1.2-1.5 g/kg/dia en sarcopenia)","Valorar tolerancia gastrointestinal al inicio de la suplementacion"]},{nombre:"Testosterona (solo en hombres con hipogonadismo confirmado)",grupo:"Hormona androgenica",mecanismo:"Estimula la sintesis proteica muscular, la diferenciacion de celulas satelite y aumenta la masa muscular",dosis:"Undecanoato de testosterona 1000 mg IM cada 12 semanas (ajustar segun respuesta y niveles)",cuidadosEnfermeria:["Uso exclusivo en hombres con hipogonadismo confirmado (testosterona total < 300 ng/dL)","Contraindicado en cancer de prostata o mama masculina","Monitorizar hematocrito (riesgo de poliglobulia) y PSA cada 6 meses","Vigilar efectos secundarios: acne, ginecomastia, apnea del sueno","Administrar en gluteo o deltoides en condiciones de esterilidad"]}],noFarmacologico:["Ejercicio de resistencia (pesas, bandas elasticas) 2-3 veces/semana: tratamiento principal","Ejercicio aerobico complementario (caminar, bicicleta) 150 min/semana","Ingesta proteica adecuada: 1.2-1.5 g/kg/dia distribuida en las 3 comidas","Suplemento proteico con leucina en cada comida principal","Exposicion solar controlada y suplementacion de vitamina D","Fisioterapia para mejorar equilibrio y prevenir caidas","Adaptaciones del hogar para reducir riesgo de caidas"]},cuidadosEnfermeria:{valoracion:["Aplicar cuestionario SARC-F para cribado de sarcopenia","Medir perimetro de pantorrilla (< 31 cm es sugestivo)","Evaluar fuerza con dinamometria si disponible","Valorar velocidad de marcha y equilibrio","Evaluar ingesta alimentaria y estado nutricional (MNA)","Identificar riesgo de caidas con escala Downton o Morse"],intervenciones:["Administrar suplementos de vitamina D y proteicos segun indicacion","Implementar programa de ejercicio de resistencia progresivo con fisioterapia","Asegurar ingesta proteica adecuada en cada comida","Aplicar medidas de prevencion de caidas (calzado, iluminacion, barandas)","Coordinar con nutricionista para plan alimentario individualizado","Movilizacion precoz en pacientes hospitalizados para prevenir desacondicionamiento"],educacionPaciente:["Que es la sarcopenia y por que ocurre con el envejecimiento","Importancia del ejercicio de resistencia como tratamiento principal","Cuantas proteinas necesita consumir y en que alimentos encontrarlas","Medidas de seguridad en el hogar para prevenir caidas","Por que la vitamina D es importante para los musculos y como tomarla","Recursos comunitarios: gimnasios adaptados para adultos mayores, clubes de caminata"],monitorizacion:["Peso y perimetro de pantorrilla mensualmente","Evaluacion funcional (SPPB, velocidad de marcha) cada 3-6 meses","Estado nutricional y albumina cada 3 meses","Niveles de vitamina D cada 6 meses","Registro de caidas: frecuencia y circunstancias","Adherencia al programa de ejercicio y nutricion"]},npiNanda:[{codigo:"00085",nombre:"Deterioro de la movilidad fisica",definicion:"Limitacion del movimiento fisico independiente e intencionado del cuerpo o de una o mas extremidades, secundaria a la perdida de masa y fuerza muscular.",caracteristicasDefinitorias:["Disminucion de la fuerza muscular","Lentitud en el movimiento","Dificultad para girarse","Inestabilidad postural","Marcha lenta e insegura"],factoresRelacionados:["Perdida de masa muscular esqueletica por envejecimiento","Desnutricion y deficit proteico","Inactividad fisica y sedentarismo","Enfermedades cronicas subyacentes"]},{codigo:"00155",nombre:"Riesgo de caidas",definicion:"Vulnerable a sufrir una caida que puede causar da\xf1o fisico y comprometer la salud.",caracteristicasDefinitorias:["Historia de caidas previas","Marcha inestable","Equilibrio deteriorado","Debilidad muscular en miembros inferiores"],factoresRelacionados:["Sarcopenia con perdida de fuerza y equilibrio","Alteraciones de la marcha","Uso de medicamentos que afectan el equilibrio","Deterioro cognitivo asociado"]},{codigo:"00002",nombre:"Desequilibrio nutricional: ingestion inferior a las necesidades",definicion:"Ingesta de nutrientes insuficiente para satisfacer las necesidades metabolicas, con deficit proteico que agrava la perdida muscular.",caracteristicasDefinitorias:["Perdida de peso involuntaria","Ingesta proteica insuficiente","Albumina disminuida","Atrofia muscular visible"],factoresRelacionados:["Anorexia del anciano","Dificultad para masticar o deglutir","Aislamiento social y falta de recursos","Multiples enfermedades cronicas con aumento del catabolismo"]}],npiNic:[{codigo:"0224",nombre:"Terapia de ejercicios: movilidad articular",actividades:["Evaluar el nivel de condicion fisica basal antes de iniciar","Disenar programa de ejercicio de resistencia progresivo con fisioterapia","Iniciar con cargas bajas y aumentar progresivamente segun tolerancia","Incluir ejercicios de equilibrio y coordinacion para prevencion de caidas","Monitorizar respuesta al ejercicio: frecuencia cardiaca, fatiga, dolor"]},{codigo:"1120",nombre:"Terapia nutricional",actividades:["Valorar el estado nutricional con herramientas validadas (MNA, albumina)","Asegurar ingesta proteica de 1.2-1.5 g/kg/dia en cada comida","Coordinar con nutricionista para plan alimentario adaptado","Administrar suplementos proteicos con leucina segun indicacion","Monitorizar el peso y la ingesta alimentaria regularmente"]},{codigo:"6490",nombre:"Prevencion de caidas",actividades:["Evaluar riesgo de caidas con escala validada al ingreso y periodicamente","Asegurar iluminacion adecuada y eliminar obstaculos en el entorno","Indicar calzado adecuado (suela antideslizante, buen soporte)","Colocar barandas en bano y pasillos","Instruir al paciente y familia sobre medidas de seguridad en el hogar"]}],npiNoc:[{codigo:"0208",nombre:"Movilidad",indicadores:["Fuerza muscular","Velocidad de marcha","Equilibrio en marcha","Capacidad para levantarse de una silla"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"},{codigo:"1004",nombre:"Estado nutricional",indicadores:["Ingesta de nutrientes","Relacion peso-talla","Albumina serica","Ingesta proteica"],escala:"1=Desviacion grave del rango normal, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Caidas y fracturas osteoporoticas (cadera, vertebra)","Dependencia funcional y perdida de autonomia","Hospitalizaciones frecuentes y prolongadas","Complicaciones postoperatorias aumentadas","Mayor vulnerabilidad a infecciones","Mortalidad aumentada por cualquier causa","Diabetes tipo 2 por resistencia a la insulina muscular"],criteriosAlarma:["Caida con traumatismo craneal o fractura","Perdida de peso involuntaria rapida (> 5% en 6 meses)","Incapacidad repentina para caminar o levantarse","Debilidad muscular asimetrica o focal (descartar causa neurologica)","Deterioro funcional rapido (semanas): descartar enfermedad aguda subyacente"],emergencyLevel:"ninguno",relatedPathologyIds:["pat_fibromialgia","pat_osteoporosis","pat_luxacion"],isPremium:!0},{id:"pat_luxacion",nombre:"Luxacion",bodySystemId:"musculoesqueletico",definicion:"Perdida completa y permanente del contacto entre las superficies articulares de una articulacion, producida generalmente por un traumatismo de alta energia. Implica ruptura capsular, lesion ligamentosa y posible da\xf1o neurovascular. Se diferencia de la subluxacion por ser una perdida de contacto total (vs parcial).",epidemiologia:"Las luxaciones representan el 10-15% de las lesiones traumaticas articulares. La luxacion de hombro (gleno-humeral) es la mas frecuente (50% de todas las luxaciones), seguida por la de codo y cadera. Predomina en hombres jovenes (20-30 a\xf1os) por mecanismos deportivos y accidentes de transito. La luxacion traumatica de cadera es mas frecuente en accidentes de alta energia.",factoresRiesgo:["Actividades deportivas de contacto y alto impacto","Accidentes de transito","Caidas de altura","Hiperlaxitud ligamentosa constitucional","Luxaciones previas (incrementan el riesgo de recidiva)","Displasia articular (acetabular, glenohumeral)","Edad jovenes con alta actividad fisica","Epilepsia (luxacion posterior de hombro en convulsiones)"],fisiopatologia:"Un traumatismo de alta energia supera la resistencia capsuloligamentosa articular, desplazando las superficies articulares fuera de su posicion normal. La capsula articular se rompe parcial o totalmente, con lesion de ligamentos, musculatura periarticular y posible fractura asociada (luxacion-fractura). El desplazamiento puede comprimir o elongar estructuras neurovasculares adyacentes (nervio axilar en luxacion de hombro, arteria poplitea en luxacion de rodilla). La reduccion incorrecta o tardia aumenta el da\xf1o condral, el edema y el riesgo de necrosis avascular (especialmente en luxacion de cadera).",signosYSintomas:{signos:["Deformidad articular evidente (posicion anormal del miembro)","Impotencia funcional absoluta de la articulacion","Edema y hematoma periarticular rapido","Prominencia o vacio palpable en la articulacion","Espasmo muscular reflejo intenso","Deficit sensitivo o motor distal (si hay lesion neurovascular)","Pulsos distales disminuidos o ausentes (emergencia vascular)"],sintomas:["Dolor intenso e inmediato en el momento del traumatismo","Incapacidad para mover la articulacion afectada","Sensacion de chasquido o 'tronido' en el momento de la luxacion","Parestesias o anestesia distal (lesion nerviosa asociada)","Frialdad distal (compromiso vascular)"]},clasificacion:{nombre:"Clasificacion por articulacion y direccion del desplazamiento",tipos:[{nombre:"Luxacion de hombro anterior",descripcion:"La mas frecuente (95%): la cabeza humeral se desplaza anterior e inferior; mecanismo de abduccion y rotacion externa forzada"},{nombre:"Luxacion de hombro posterior",descripcion:"Poco frecuente (5%); asociada a convulsiones y electrocucion; facilmente pasada por alto en radiografia AP"},{nombre:"Luxacion de cadera posterior",descripcion:"La mas frecuente de cadera (90%); mecanismo de impacto axial en cadera flexionada (accidente automovilistico); urgencia por riesgo de necrosis avascular de la cabeza femoral"},{nombre:"Luxacion de codo posterior",descripcion:"Segunda luxacion mas frecuente en adultos; caida sobre mano extendida; vigilar lesion de nervio cubital y arteria braquial"},{nombre:"Luxacion de rotula",descripcion:"Generalmente lateral; frecuente en jovenes deportistas y en hiperlaxitud; alta tasa de recidiva"}]},diagnostico:{anamnesis:["Mecanismo del traumatismo: fuerza, direccion, velocidad","Tiempo transcurrido desde la luxacion (urgencia para la reduccion)","Luxaciones previas en la misma articulacion","Sintomas neurovasculares distales: parestesias, frialdad","Enfermedades previas: epilepsia, hiperlaxitud, displasia articular","Medicacion anticoagulante (afecta hematoma y manejo)"],examenFisico:["Inspeccion de la deformidad y posicion del miembro","Exploracion neurovascular distal ANTES de la reduccion (pulsos, sensibilidad, fuerza)","Evaluacion de la piel (heridas abiertas: luxacion abierta = urgencia quirurgica)","Palpacion de la articulacion y referencias oseas","Exploracion comparativa con el lado sano","Re-evaluacion neurovascular DESPUES de la reduccion"],pruebas:[{nombre:"Radiografia convencional (dos proyecciones minimo)",descripcion:"Confirma la luxacion, define la direccion del desplazamiento y descarta fracturas asociadas",valoresReferencia:"Imagen: perdida de congruencia articular; proyecciones especificas segun articulacion (AP, lateral, Y-scapular para hombro)",cuidadosEnfermeria:["Movilizar el miembro con extremo cuidado para no agravar la lesion","Administrar analgesicos antes del traslado a radiologia para reducir el dolor","Solicitar proyeccion axilar para hombro para no perder una luxacion posterior","Acompanyar al paciente durante el estudio para asistir en el posicionamiento"]},{nombre:"Tomografia computarizada (TC) de la articulacion",descripcion:"Indicada ante sospecha de fractura-luxacion o lesiones condrales; mejor definicion anatomica preoperatoria",valoresReferencia:"Evalua fragmentos oseos, escalones articulares y lesiones de Bankart oseo (glenoide) o Hill-Sachs (cabeza humeral)",cuidadosEnfermeria:["Verificar contraindicaciones de contraste si se solicita TC con contraste","Inmovilizar previamente la articulacion para evitar dolor durante el traslado","Si hay compromiso neurovascular, realizar TC con angioTC para evaluar vasos"]},{nombre:"Evaluacion neurovascular clinica + Doppler vascular si es necesario",descripcion:"Fundamental para descartar lesion arterial o nerviosa asociada; el Doppler evalua la perfusion distal",valoresReferencia:"Pulsos distales presentes y simetricos; sensibilidad y fuerza conservadas distalmente",cuidadosEnfermeria:["Palpar pulsos distales (radial, pedio, tibial posterior) y comparar con lado sano","Evaluar sensibilidad en los territorios nerviosos en riesgo segun la articulacion (nervio axilar en hombro, cubital en codo)","Registrar tiempo de relleno capilar (normal < 2 segundos)","Documentar hallazgos ANTES de la reduccion para establecer linea de base"]}]},tratamientoMedico:{objetivos:["Reduccion articular precoz e indolora","Restaurar la congruencia articular y la funcion","Proteger las estructuras neurovasculares","Inmovilizacion adecuada para cicatrizacion capsuloligamentosa","Rehabilitacion funcional progresiva","Prevenir recidivas y complicaciones cronicas"],farmacologico:[{nombre:"Morfina intravenosa",grupo:"Analgesico opioide mayor",mecanismo:"Agonista de receptores mu-opioides en el SNC, produciendo analgesia potente y permitiendo la relajacion muscular necesaria para la reduccion",dosis:"0.05-0.1 mg/kg IV lento; titular segun respuesta (generalmente 2-5 mg iniciales)",cuidadosEnfermeria:["Monitorizar FR, SpO2 y nivel de conciencia durante y post-administracion","Tener naloxona disponible como antidoto (0.4 mg IV)","Via IV permeable y segura antes de administrar","Avisar al medico si FR < 12 rpm o SpO2 < 94%","Registrar hora, dosis y respuesta del paciente"]},{nombre:"Midazolam intravenoso",grupo:"Benzodiacepina (sedacion y relajacion muscular)",mecanismo:"Potencia el GABA-A produciendo sedacion, ansiloisis y relajacion muscular que facilita la reduccion articular",dosis:"1-2.5 mg IV lento, titulando hasta la sedacion consciente deseada",cuidadosEnfermeria:["Mantener al paciente monitorizado: ECG, PA, SpO2, FR","Tener flumazenil disponible como antidoto (0.2 mg IV)","Contraindicado en insuficiencia respiratoria grave","No administrar rapidamente: riesgo de apnea","Informar al paciente sobre posible amnesia del procedimiento (efecto esperado)"]},{nombre:"Ibuprofeno",grupo:"AINE (antiinflamatorio no esteroideo)",mecanismo:"Inhibe COX-1 y COX-2 reduciendo prostaglandinas inflamatorias, el edema y el dolor postreduccion",dosis:"400-600 mg cada 8 horas por 5-7 dias; con alimentos",cuidadosEnfermeria:["Administrar con comidas para reducir irritacion gastrica","Evitar en insuficiencia renal o hepatica, ulcera peptica activa","Vigilar signos de hemorragia digestiva en uso prolongado","No combinar con otros AINEs ni aspirina","Reducir dosis o evitar en mayores de 65 a\xf1os; considerar IBP protector"]}],noFarmacologico:["Reduccion articular cerrada urgente (maniobras especificas segun articulacion: Cunningham, Stimson, Kocher para hombro)","Inmovilizacion post-reduccion: cabestrillo o vendaje para hombro, ferula para codo","Crioterapia (hielo): 20 min cada 2-3 horas las primeras 48h para reducir edema","Elevacion del miembro para reducir edema","Rehabilitacion progresiva: movilizacion precoz supervisada por fisioterapia","Cirugia (artroscopia o cirugia abierta) si hay fractura-luxacion, lesion de Bankart o luxaciones recidivantes"]},cuidadosEnfermeria:{valoracion:["Evaluar dolor con escala EVA","Valorar estado neurovascular distal: pulsos, sensibilidad, fuerza, color y temperatura","Inspeccionar la piel en busqueda de heridas (luxacion abierta)","Verificar tiempo transcurrido desde la luxacion","Evaluar mecanismo del traumatismo y energia involucrada","Valorar nivel de ansiedad del paciente ante el procedimiento de reduccion"],intervenciones:["Inmovilizar la articulacion en la posicion de mayor comodidad ANTES de la reduccion","Asistir al medico durante la maniobra de reduccion","Administrar analgesicos y sedacion segun prescripcion previa a la reduccion","Reevaluar estado neurovascular distal inmediatamente POST-reduccion","Aplicar inmovilizacion (cabestrillo, vendaje) segun indicacion medica","Aplicar hielo local envuelto en pano (nunca directo sobre la piel)"],educacionPaciente:["Importancia de respetar el tiempo de inmovilizacion prescrito","Como realizar la higiene respetando la inmovilizacion","Signos de alarma que requieren consulta urgente (frialdad, parestesias, aumento del dolor)","Programa de rehabilitacion: inicio, frecuencia y ejercicios permitidos","Medidas para prevenir recidivas (evitar posiciones de riesgo, fortalecimiento muscular)","Cuando puede retornar a la actividad deportiva"],monitorizacion:["Estado neurovascular distal cada 30-60 minutos las primeras horas post-reduccion","Intensidad del dolor con EVA cada 2-4 horas","Vigilar signos de sindrome compartimental (dolor desproporcionado, parestesias, tension de la piel)","Control radiologico post-reduccion","Evolucion del edema y el hematoma periarticular","Adherencia al programa de rehabilitacion en seguimiento ambulatorio"]},npiNanda:[{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable ocasionada por una lesion tisular real asociada al traumatismo y a la luxacion articular, de inicio subito y duracion limitada.",caracteristicasDefinitorias:["Informe de dolor intenso en la articulacion luxada","Postura antialgica y proteccion de la articulacion","Expresion facial de dolor","Cambios en signos vitales (taquicardia, hipertension)","Llanto o vocalizacion"],factoresRelacionados:["Traumatismo articular con ruptura capsuloligamentosa","Espasmo muscular reflejo","Edema y hematoma periarticular"]},{codigo:"00086",nombre:"Riesgo de disfuncion neurovascular periferica",definicion:"Vulnerable a una interrupcion de la circulacion, sensibilidad o movilidad de una extremidad, que puede comprometer la salud.",caracteristicasDefinitorias:["Pulsos distales debilitados o ausentes","Parestesias o anestesia distal","Frialdad y palidez del miembro","Debilidad motora distal"],factoresRelacionados:["Compresion neurovascular por el desplazamiento articular","Edema posttraumatico que aumenta la presion en los compartimentos","Inmovilizacion compresiva inadecuada"]},{codigo:"00085",nombre:"Deterioro de la movilidad fisica",definicion:"Limitacion del movimiento fisico independiente de la extremidad afectada por la luxacion articular.",caracteristicasDefinitorias:["Impotencia funcional absoluta de la articulacion","Incapacidad para realizar movimientos activos","Necesidad de asistencia para moverse","Inmovilizacion terapeutica"],factoresRelacionados:["Luxacion articular con perdida de congruencia","Dolor que impide el movimiento","Inmovilizacion terapeutica post-reduccion","Espasmo muscular"]}],npiNic:[{codigo:"1400",nombre:"Manejo del dolor",actividades:["Evaluar el dolor con escala EVA antes y despues de las intervenciones","Administrar analgesicos opioides y sedacion segun prescripcion para la reduccion","Aplicar inmovilizacion en posicion funcional para reducir el dolor","Aplicar crioterapia local las primeras 48 horas","Valorar la eficacia del manejo del dolor y ajustar segun respuesta"]},{codigo:"4070",nombre:"Precauciones circulatorias",actividades:["Evaluar pulsos distales, llenado capilar, color y temperatura antes y despues de la reduccion","Vigilar aparicion de parestesias, frialdad o debilidad distal","Aflojar vendajes o inmovilizaciones si producen compresion neurovascular","Mantener la extremidad elevada para reducir edema","Alertar al medico inmediatamente ante signos de compromiso vascular"]},{codigo:"0840",nombre:"Cambio de posicion",actividades:["Inmovilizar la articulacion en la posicion de mayor confort antes de la reduccion","Aplicar inmovilizacion correcta post-reduccion segun indicacion medica","Posicionar el miembro con almohadas para aliviar la tension y el dolor","Facilitar cambios posturales del resto del cuerpo respetando la inmovilizacion","Ense\xf1ar al paciente a movilizarse de forma segura con el miembro inmovilizado"]}],npiNoc:[{codigo:"2102",nombre:"Nivel del dolor",indicadores:["Intensidad del dolor referida","Expresiones faciales de dolor","Tension muscular","Frecuencia cardiaca"],escala:"1=Grave, 2=Sustancial, 3=Moderado, 4=Leve, 5=Ninguno"},{codigo:"0407",nombre:"Perfusion tisular: periferico",indicadores:["Pulsos distales presentes","Color normal del miembro","Temperatura del miembro","Llenado capilar","Sensibilidad conservada"],escala:"1=Desviacion grave del rango normal, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Lesion del nervio axilar (hombro): anestesia de hombro y debilidad del deltoides","Lesion de la arteria poplitea (rodilla): isquemia del miembro inferior","Necrosis avascular de la cabeza femoral (cadera): urgencia ortopedica","Lesion condral y osteoartritis postraumatica tardia","Inestabilidad articular cronica y luxaciones recidivantes","Sindrome compartimental (complication grave, requiere fasciotomia urgente)","Rigidez articular por inmovilizacion prolongada","Miositis osificante (calcificacion periarticular)"],criteriosAlarma:["Ausencia de pulsos distales o isquemia del miembro (urgencia vascular inmediata)","Deficit neurologico progresivo post-reduccion","Dolor desproporcionado, parestesias y tension de la piel del compartimento (sindrome compartimental)","Luxacion abierta con comunicacion cutanea (riesgo de infeccion y urgencia quirurgica)","Fractura-luxacion con desplazamiento oseo importante","Imposibilidad de reduccion cerrada (indicacion quirurgica)"],emergencyLevel:"moderado",relatedPathologyIds:["pat_sarcopenia","pat_osteoporosis","pat_espondilitis"],isPremium:!0},{id:"pat_pielonefritis",nombre:"Pielonefritis Aguda",bodySystemId:"renal_urinario",definicion:"Infeccion bacteriana aguda del parenquima renal y del sistema colector, caracterizada por inflamacion del intersticio renal. Constituye una infeccion del tracto urinario superior que puede comprometer la funcion renal y evolucionar hacia sepsis urologica si no se trata oportunamente.",epidemiologia:"Incidencia de 15-17 casos por 10.000 mujeres y 3-4 por 10.000 hombres por ano. Es mas frecuente en mujeres jovenes en edad fertil, embarazadas y adultos mayores. En Argentina representa una causa frecuente de internacion por infeccion urinaria, con riesgo aumentado en pacientes diabeticos e inmunodeprimidos.",factoresRiesgo:["Sexo femenino","Embarazo","Diabetes mellitus","Obstruccion urinaria (litiasis, hiperplasia prostatica)","Cateterismo vesical","Vejiga neurogenica","Inmunosupresion","Reflujo vesicoureteral","Infecciones urinarias a repeticion","Instrumentacion urologica reciente"],fisiopatologia:"El mecanismo mas frecuente es la via ascendente: bacterias colonizadoras del perineo (principalmente Escherichia coli, 80% de los casos) ascienden por la uretra, vejiga y ureter hasta el parenquima renal. Los factores de virulencia bacteriana (fimbrias tipo P, hemolisinas) facilitan la adhesion al urotelio y la invasion del epitelio tubular. La respuesta inflamatoria local produce edema intersticial, infiltrado leucocitario y microabscesos. La activacion del sistema inmune puede desencadenar respuesta inflamatoria sistemica (SIRS) y sepsis urologica.",signosYSintomas:{signos:["Fiebre > 38.5 grados C (frecuentemente con escalofrios)","Signo de Giorda\xf1o positivo (punopeotosis lumbar dolorosa)","Sensibilidad en angulo costovertebral","Taquicardia","Piuria en sedimento urinario","Bacteriuria > 100.000 UFC/mL en urocultivo","Leucocitosis con desviacion a la izquierda"],sintomas:["Dolor lumbar unilateral intenso de inicio agudo","Fiebre con escalofrios y sudoracion","Nauseas y vomitos","Disuria y polaquiuria (sintomas de cistitis acompanante)","Malestar general y astenia","Anorexia","Dolor abdominal irradiado al flanco"]},clasificacion:{nombre:"Clasificacion por severidad clinica",tipos:[{nombre:"Pielonefritis no complicada",descripcion:"Mujer no embarazada, sin anomalias estructurales ni funcionales del tracto urinario, sin comorbilidades graves. Tratamiento ambulatorio posible."},{nombre:"Pielonefritis complicada",descripcion:"Cualquier paciente con factores anatomicos, funcionales o inmunosupresores asociados: obstruccion, reflujo, embarazo, diabetes, trasplante renal. Requiere internacion."},{nombre:"Pielonefritis enfisematosa",descripcion:"Forma necrotizante severa con gas en el parenquima renal. Predomina en diabeticos. Alta mortalidad. Requiere internacion en UCI y posible nefrectomia."},{nombre:"Pielonefritis xantogranulomatosa",descripcion:"Forma cronica destructiva asociada a litiasis coraliforme y obstruccion. Colecciones de macrpfagos espumosos. Tratamiento quirurgico habitual."}]},diagnostico:{anamnesis:["Inicio y duracion del dolor lumbar","Sintomas miccionales previos o actuales","Episodios anteriores de infeccion urinaria","Embarazo actual o reciente","Antecedente de litiasis renal o instrumentacion urologica","Comorbilidades: diabetes, inmunosupresion, trasplante","Medicacion habitual (antibioticos recientes)","Alergias a antibioticos"],examenFisico:["Toma de temperatura, FC, FR, PA (evaluar SIRS)","Palpacion abdominal (defensa, rebote)","Punopeotosis lumbar bilateral (signo de Giorda\xf1o)","Palpacion de puntos ureterales (superior e inferior)","Examen de genitales externos","Evaluacion de hidratacion"],pruebas:[{nombre:"Sedimento y tira reactiva de orina",descripcion:"Piuria (> 10 leucocitos/campo), bacteriuria, nitritos positivos, cilindruria leucocitaria indica afectacion renal",valoresReferencia:"Leucocitos: < 5/campo normal; Nitritos: negativo normal",cuidadosEnfermeria:["Obtener muestra de orina de chorro medio previo aseo genital","Procesar la muestra dentro de la primera hora o refrigerar","Registrar hora de obtencion y caracteristicas macroscopicas"]},{nombre:"Urocultivo con antibiograma",descripcion:"Identifica el germen causal y su sensibilidad antibiotica. Fundamental para ajuste del tratamiento empirico",valoresReferencia:"Positivo: > 100.000 UFC/mL de un unico germen uropatogeno",cuidadosEnfermeria:["Obtener muestra ANTES de iniciar antibioticoterapia","Tecnica aseptica estricta para recoleccion","Transportar al laboratorio inmediatamente o refrigerar a 4 grados C"]},{nombre:"Hemograma completo con recuento diferencial",descripcion:"Evalua leucocitosis como respuesta inflamatoria sistemica y detecta anemia asociada",valoresReferencia:"Leucocitos: 4.500-11.000/mcL; Neutrofilos: 50-70%",cuidadosEnfermeria:["Extraer muestra venosa con tecnica aseptica","Registrar si el paciente recibio corticoides recientes","Enviar muestra al laboratorio sin demora"]},{nombre:"Hemocultivo x 2",descripcion:"Obligatorio en cuadros febriles con escalofrios. Positivo en 15-30% de pielonefritis complicadas. Confirma bacteriemia",valoresReferencia:"Negativo en condiciones normales",cuidadosEnfermeria:["Extraer dos muestras de sitios de venopuncion diferentes","Tecnica aseptica rigurosa (desinfeccion de piel y tapones de frascos)","Idealmente extraer antes de administrar antibioticos o en pico febril"]},{nombre:"Creatinina, urea y electrolitos",descripcion:"Evalua funcion renal basal y detecta injuria renal aguda asociada. La hiponatremia puede indicar SIADH en contexto septico",valoresReferencia:"Creatinina: 0.6-1.2 mg/dL; Urea: 15-40 mg/dL; Na: 135-145 mEq/L",cuidadosEnfermeria:["No requiere ayuno para creatinina y urea","Registrar diuresis horaria en pacientes hospitalizados","Repetir a las 48-72h para evaluar respuesta al tratamiento"]},{nombre:"Ecografia renal y de vias urinarias",descripcion:"Primera imagen de eleccion. Descarta obstruccion, litiasis, absceso renal, malformaciones. Puede mostrar edema renal",valoresReferencia:"Rinones de tamano y ecoestructura normal sin dilatacion de via excretora",cuidadosEnfermeria:["No requiere preparacion especial en urgencias","Coordinar traslado al servicio de imagen","Registrar resultado en historia clinica para seguimiento"]}]},tratamientoMedico:{objetivos:["Erradicar el microorganismo causal","Prevenir complicaciones (absceso, sepsis, insuficiencia renal)","Aliviar sintomas y fiebre","Tratar patologia subyacente (obstruccion, litiasis)","Prevenir recurrencias"],farmacologico:[{nombre:"Ceftriaxona",grupo:"Cefalosporina de tercera generacion",mecanismo:"Inhibe la sintesis de la pared bacteriana uniendose a proteinas fijadoras de penicilina (PBP), con amplio espectro contra gram negativos incluyendo E. coli",dosis:"1-2 g IV cada 24 horas en adultos; duracion 10-14 dias total (puede rotar a oral tras mejoria clinica a las 48-72h)",cuidadosEnfermeria:["Verificar alergia a betalactamicos antes de la primera dosis","Administrar en infusion IV de 30 minutos diluida en 100 mL de SF","Monitorizar signos de reaccion alergica durante la infusion","Vigilar funcion hepatica en tratamientos prolongados","Registrar respuesta clinica: descenso febril a las 48-72 h indica eficacia"]},{nombre:"Ciprofloxacina",grupo:"Fluoroquinolona",mecanismo:"Inhibe la ADN girasa y topoisomerasa IV bacteriana, impidiendo la replicacion del ADN bacteriano. Excelente penetracion en tejido renal",dosis:"500 mg VO cada 12 horas o 400 mg IV cada 12 horas; duracion 7-10 dias en no complicada",cuidadosEnfermeria:["No administrar junto a anti\xe1cidos, suplementos de calcio, magnesio o hierro (reducen absorcion)","Vigilar tendinitis y riesgo de rotura tendinosa (suspender si dolor tendinoso)","Advertir fotosensibilidad: proteger de exposicion solar durante tratamiento","Monitorizar QT en pacientes con antecedentes cardiacos o que toman otros farmacos que prolongan QT","Ajustar dosis si ClCr < 30 mL/min"]},{nombre:"Paracetamol",grupo:"Analgesico-antipiretico",mecanismo:"Inhibe la sintesis de prostaglandinas a nivel central. Efecto antipiretico y analgesico sin accion antiinflamatoria periferica significativa",dosis:"1 g VO o IV cada 6-8 horas segun necesidad; maximo 4 g/dia en adultos sin hepatopatia",cuidadosEnfermeria:["Verificar funcion hepatica previa en pacientes con antecedentes de hepatopatia o alcoholismo","No superar dosis maxima diaria (riesgo hepatotoxicidad)","Administrar IV en infusion de 15 minutos","Registrar temperatura antes y 1 hora despues de la administracion para evaluar eficacia antipiretica","Vigilar diuresis: la fiebre y sudoracion generan perdida hidrica"]}],noFarmacologico:["Hidratacion parenteral 2-3 L/dia si hay vomitos o intolerancia oral","Reposo relativo durante periodo febril agudo","Calor local en zona lumbar para alivio del dolor","Balance hidrico estricto (ingresos/egresos)","Mantenimiento de via urinaria permeable (sondaje si obstruccion)","Dieta blanda con adecuada hidratacion oral al tolerar"]},cuidadosEnfermeria:{valoracion:["Tomar signos vitales completos (T, FC, FR, PA, SatO2) cada 4-6 horas","Evaluar intensidad del dolor lumbar con escala EVA","Registrar caracteristicas de la orina (color, turbidez, olor)","Medir diuresis horaria en pacientes con signos de sepsis o deterioro renal","Valorar nivel de hidratacion: turgencia cutanea, mucosas, peso diario","Evaluar estado neurologico en pacientes mayores o inmunocomprometidos"],intervenciones:["Administrar antibioticos a las horas exactas indicadas para mantener niveles terapeuticos","Canalizar via venosa periferica de calibre adecuado para hidratacion y antibioticoterapia IV","Tomar hemocultivos y urocultivo ANTES de iniciar antibioticos","Asegurar ingesta hidrica de al menos 2 L/dia si tolerancia oral","Aplicar medidas fisicas antipireticas (compresas frias, ambiente fresco)","Realizar balance hidrico riguroso cada 8 horas","Gestionar pruebas de imagen (ecografia) de forma prioritaria"],educacionPaciente:["Explicar la importancia de completar el ciclo antibiotico aunque mejoren los sintomas","Instruir sobre tecnica correcta de higiene genital (limpieza de adelante hacia atras en mujeres)","Indicar ingesta de abundante liquido (2-3 L/dia) para facilitar eliminacion bacteriana","Explicar signos de alarma que requieren consulta urgente: fiebre que no cede, dolor intenso, oliguria","Educar sobre factores de riesgo modificables (cambio de ropa interior, evitar retencion urinaria)","Indicar importancia del urocultivo de control post-tratamiento"],monitorizacion:["Temperatura cada 4-6 horas: la persistencia de fiebre > 72h debe alertar sobre complicaciones","Diuresis horaria en pacientes con datos de sepsis o deterioro hemodinamico","Funcion renal (creatinina, urea) cada 48-72 horas durante internacion","Respuesta al tratamiento antibiotico: mejoria clinica esperada a las 48-72h","Signos de bacteriemia/sepsis: hipotension, taquicardia, alteracion del sensorio","Hemocultivos de control si no hay mejoria clinica a las 72 horas"]},npiNanda:[{codigo:"00007",nombre:"Hipertermia",definicion:"Temperatura corporal central por encima del rango normal diurno debido a fallo de la termorregulacion",caracteristicasDefinitorias:["Temperatura corporal superior al rango normal (> 38.5 grados C)","Piel caliente al tacto","Taquicardia","Escalofrios"],factoresRelacionados:["Proceso infeccioso bacteriano (pielonefritis)","Deshidratacion","Respuesta inflamatoria sistemica"]},{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable ocasionada por una lesion tisular real o potencial, de inicio subito o lento, de cualquier intensidad de leve a grave, con un final anticipado o previsible",caracteristicasDefinitorias:["Informe verbal de dolor lumbar intenso","Expresion facial de dolor","Proteccion de la zona afectada","Taquicardia y taquipnea por dolor"],factoresRelacionados:["Inflamacion del parenquima renal","Distension de la capsula renal","Espasmo de la musculatura lumbar"]},{codigo:"00027",nombre:"Deficit de volumen de liquidos",definicion:"Disminucion del liquido intravascular, intersticial y/o intracelular. Hace referencia a la deshidratacion, perdida de agua sin cambio en el sodio",caracteristicasDefinitorias:["Disminucion de la diuresis","Orina concentrada","Mucosas secas","Fiebre con sudoracion profusa","Nauseas y vomitos que impiden la ingesta oral"],factoresRelacionados:["Perdidas activas por fiebre y sudoracion","Nauseas y vomitos que reducen la ingesta oral","Poliuria inicial como mecanismo de eliminacion bacteriana"]}],npiNic:[{codigo:"3740",nombre:"Tratamiento de la fiebre",actividades:["Monitorizar temperatura cada 4 horas y ante escalofrios","Administrar antipireticos segun prescripcion medica","Aplicar medidas fisicas de enfriamiento (compresas frias en frente y axilas)","Aumentar aporte hidrico para compensar perdidas por sudoracion","Registrar patron febril y respuesta a antipireticos","Vigilar signos de deshidratacion asociada a la fiebre"]},{codigo:"1400",nombre:"Manejo del dolor",actividades:["Realizar valoracion exhaustiva del dolor con escala EVA","Administrar analgesicos segun prescripcion y evaluar eficacia","Posicionar al paciente para maximizar la comodidad (decubito lateral con flexion de caderas)","Aplicar calor local en zona lumbar si ayuda al alivio","Explorar tecnicas no farmacologicas complementarias","Registrar la respuesta al tratamiento analgesico"]},{codigo:"4120",nombre:"Manejo de liquidos",actividades:["Monitorizar estado de hidratacion (mucosas, turgencia cutanea, diuresis)","Administrar fluidos IV segun prescripcion en pacientes con vomitos o intolerancia oral","Registrar ingresos y egresos cada 8 horas","Vigilar signos de sobrecarga hidrica en pacientes con funcion renal comprometida","Fomentar ingesta oral de liquidos cuando sea posible","Controlar peso diario"]}],npiNoc:[{codigo:"0800",nombre:"Termorregulacion",indicadores:["Temperatura corporal en rango normal (36-37.5 grados C)","Ausencia de escalofrios","Piel normot\xe9rmica al tacto","Frecuencia cardiaca en rango normal"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"},{codigo:"0602",nombre:"Hidratacion",indicadores:["Turgencia cutanea normal","Mucosas humedas","Diuresis mayor de 0.5 mL/kg/hora","Tension arterial en rango normal","Ausencia de sed intensa"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"}],complicaciones:["Sepsis urologica y shock septico","Absceso renal o perirrenal","Pielonefritis enfisematosa (especialmente en diabeticos)","Injuria renal aguda","Bacteriemia con focos septicos a distancia","Pielonefritis cronica con cicatrizacion renal","Parto pretermino en embarazadas","Necrosis papilar renal"],criteriosAlarma:["Fiebre > 39.5 grados C que no responde a antipireticos a las 48-72 horas de tratamiento antibiotico adecuado","Hipotension o taquicardia sostenida (signos de sepsis)","Oliguria u anuria (diuresis < 0.5 mL/kg/hora)","Deterioro del estado de consciencia","Dolor lumbar que aumenta en lugar de mejorar","Signos de abdomen agudo (sugiere absceso roto)","Creatinina en ascenso progresivo"],emergencyLevel:"moderado",relatedPathologyIds:["pat_litiasis_renal","pat_ira","pat_dm2","pat_vejiga_neurogenica"],isPremium:!0},{id:"pat_vejiga_neurogenica",nombre:"Vejiga Neurogenica",bodySystemId:"renal_urinario",definicion:"Disfuncion del llenado y/o vaciado vesical secundaria a una lesion o enfermedad del sistema nervioso central o periferico que altera el control neural de la vejiga y el esfinter uretral. Puede manifestarse como vejiga hiperactiva (espastica) o hiporreflexica (flaccida) segun el nivel de la lesion neurologica.",epidemiologia:"Afecta al 40-90% de pacientes con lesion medular, al 50-80% de pacientes con esclerosis multiple, y al 30-50% de diabeticos con neuropatia auton\xf3mica. En Argentina, la lesion medular tiene una incidencia de 20-30 nuevos casos por millon de habitantes al ano. Es una causa importante de morbimortalidad por infecciones urinarias recurrentes e insuficiencia renal.",factoresRiesgo:["Lesion medular (traumatica o no traumatica)","Esclerosis multiple","Enfermedad de Parkinson","Accidente cerebrovascular","Diabetes mellitus con neuropatia autonoma","Tumor o compresion medular","Espina bifida","Hernia de disco lumbar severa","Cirugia pelvica extensa (histerectomia radical, proctocolectomia)","Neuropatia periferica severa"],fisiopatologia:"El control normal de la miccion depende de la coordinacion entre el sistema nervioso central (centros pontinos y corteza prefrontal) y el sistema nervioso periferico (nervios sacros S2-S4). Una lesion por encima del cono medular (lesion supraespinal o cervico-tor\xe1cica) produce vejiga espastica: el musculo detrusor se contrae de forma involuntaria e incontrolada (hiperreflexia del detrusor) con esfinter externo disinergio. Una lesion en el cono medular o cauda equina (S2-S4) produce vejiga flaccida: el detrusor pierde capacidad contrctil (areflexia) y el esfinter interno permanece cerrado por actividad simpatica conservada, generando retencion con globo vesical. La disautonomia en diabeticos afecta la sensacion de llenado y la contraccion del detrusor.",signosYSintomas:{signos:["Globo vesical palpable o percutible en hipogastrio (vejiga flaccida)","Residuo postmiccional elevado > 100 mL en ecografia","Perdida de orina sin sensacion de urgencia previa (incontinencia refleja)","Infecciones urinarias recurrentes","Hidronefrosis bilateral en estadios avanzados","Hiperreflexia autonoma en lesiones cervicales altas (cefalea, sudoracion, bradicardia, HTA)"],sintomas:["Incontinencia urinaria (por rebosamiento o refleja)","Retencion urinaria (dificultad o imposibilidad para orinar)","Ausencia de sensacion de llenado vesical","Urgencia miccional e incontinencia de urgencia (vejiga espastica)","Polaquiuria o anuria segun tipo","Infecciones urinarias de repeticion con o sin sintomas clasicos"]},clasificacion:{nombre:"Clasificacion segun nivel de lesion neurologica (Lapides)",tipos:[{nombre:"Vejiga sensitiva denervada",descripcion:"Lesion de nervios sensoriales aferentes. Ausencia de sensacion de llenado, distension progresiva. Tipica de tabes dorsal y neuropatia diabetica inicial."},{nombre:"Vejiga motora paralizada",descripcion:"Lesion de nervios motores eferentes (S2-S4 o nervios pelvicos). Retencion urinaria con sensacion conservada pero incapacidad de contraer el detrusor. Tipica de hernia discal, tumor sacro."},{nombre:"Vejiga neurologica automatica (espastica)",descripcion:"Lesion medular por encima del cono (T6 hacia arriba). Contracciones reflexas del detrusor sin control cortical. Vaciado involuntario en pequenas cantidades. Tipica de lesion medular cervical o tor\xe1cica."},{nombre:"Vejiga refleja",descripcion:"Lesion medular completa por encima del centro sacro. Arco reflejo medular intacto pero sin coordinacion pontina. Vaciado reflejo con disinergia detrusor-esfinter."},{nombre:"Vejiga autonoma (flaccida)",descripcion:"Lesion del cono medular o cauda equina. Deaferentacion completa. Distension vesical severa, vaciado solo por maniobra de Valsalva o Crede. Alto riesgo de reflujo vesicoureteral."}]},diagnostico:{anamnesis:["Tipo, nivel y completitud de la lesion neurologica","Patron miccional actual: retenci\xf3n, incontinencia, urgencia","Frecuencia y caracteristicas de infecciones urinarias previas","Metodo actual de vaciado vesical (cateterismo, Cred\xe9, Valsalva, espontaneo)","Presencia de disautonomia (cefalea, sudoracion, HTA en lesion cervical alta)","Impacto en calidad de vida y actividades cotidianas"],examenFisico:["Evaluacion neurologica del nivel de lesion","Palpacion y percusion del hipogastrio (globo vesical)","Reflejo bulbocavernoso (evalua integridad del arco sacro S2-S4)","Tono del esfinter anal (sustituye al esfinter uretral en valoracion neurologica)","Sensibilidad perineal y perianal","Examen de genitales externos (maceraci\xf3n por incontinencia)"],pruebas:[{nombre:"Ecografia renal y vesical con residuo postmiccional",descripcion:"Evalua morfologia renal (hidronefrosis), volumen vesical y residuo postmiccional. No invasivo, primera eleccion",valoresReferencia:"Residuo postmiccional normal < 50 mL; > 100 mL es patologico",cuidadosEnfermeria:["Realizar la medicion de residuo postmiccional inmediatamente despues de la miccion","Si se usa cateterismo intermitente, coordinarlo con la exploracion","Registrar volumen orinado espontaneamente y volumen del residuo"]},{nombre:"Estudio urodinamico completo",descripcion:"Cistometria, perfil de presion uretral, electromiografia. Permite clasificar el tipo de disfuncion vesical y orientar el tratamiento. Estudio de referencia",valoresReferencia:"Capacidad vesical normal 300-500 mL; presion detrusor estable durante llenado",cuidadosEnfermeria:["Explicar el procedimiento al paciente (cateterizacion vesical y rectal durante el estudio)","Verificar ausencia de infeccion urinaria activa antes del estudio","Preparar material esteril para cateterizacion","Asegurar posicion comoda durante el estudio (puede ser prolongado)"]},{nombre:"Urocultivo",descripcion:"Detecta infeccion urinaria activa. Fundamental en pacientes con cateterismo o infecciones recurrentes",valoresReferencia:"Positivo > 100.000 UFC/mL; en cateterizados > 10.000 UFC/mL puede ser significativo",cuidadosEnfermeria:["En cateterismo vesical: obtener muestra del puerto lateral del cateter, no de la bolsa","En sondaje intermitente: obtener al inicio del cateterismo","Procesar inmediatamente o refrigerar"]}]},tratamientoMedico:{objetivos:["Preservar la funcion renal evitando presiones intravesicales elevadas","Prevenir infecciones urinarias recurrentes","Lograr continencia urinaria","Facilitar el vaciado vesical completo","Mejorar la calidad de vida del paciente"],farmacologico:[{nombre:"Oxibutinina",grupo:"Anticolinergico / Antimuscarinico",mecanismo:"Bloquea receptores muscarinicos M2 y M3 en el detrusor, reduciendo las contracciones involuntarias y aumentando la capacidad vesical. Util en vejiga hiperactiva espastica",dosis:"5 mg VO 2-3 veces al dia; formulacion de liberacion prolongada: 5-15 mg/dia",cuidadosEnfermeria:["Vigilar efectos anticolinergicos: sequedad bucal, constipacion, vision borrosa, retencion urinaria","Contraindicado en glaucoma de angulo estrecho: verificar antecedentes oftalmologicos","Monitorizar residuo postmiccional: puede empeorar la retencion en vejiga flaccida","Advertir al paciente sobre posible deterioro cognitivo en adultos mayores","Evaluar eficacia a las 4-8 semanas con registro de episodios de incontinencia"]},{nombre:"Tamsulosina",grupo:"Alfabloqueante alfa-1A selectivo",mecanismo:"Bloquea receptores alfa-1A en el cuello vesical y uretra proximal, reduciendo la resistencia al vaciado. Util en vejiga neurogenica con obstruccion infravesical funcional",dosis:"0.4 mg VO una vez al dia despues del desayuno",cuidadosEnfermeria:["Advertir sobre hipotension ortostatica, especialmente en primeras dosis y en pacientes con lesion medular","Vigilar PA al incorporarse (pacientes en silla de ruedas tienen mayor riesgo)","Puede causar eyaculacion retrograda: informar al paciente","No interrumpir bruscamente el tratamiento","Monitorizar residuo postmiccional para evaluar eficacia"]},{nombre:"Trimetoprim-sulfametoxazol (TMP-SMX)",grupo:"Antibiotico sulfonamida",mecanismo:"Inhibe la sintesis de acido folico bacteriano (doble bloqueo). Usado en profilaxis antibiotica de infecciones urinarias recurrentes en pacientes con cateterismo intermitente",dosis:"Profilaxis: 80/400 mg VO cada noche; tratamiento: 160/800 mg cada 12 horas por 7-14 dias",cuidadosEnfermeria:["Evaluar antecedentes de alergia a sulfas antes de iniciar","Monitorizar funcion renal y hematologica en uso prolongado (puede causar neutropenia)","Vigilar resistencias: solicitar urocultivo si infeccion a pesar de profilaxis","Administrar con abundante liquido para evitar cristaluria renal","No usar en insuficiencia renal severa (ClCr < 15 mL/min)"]}],noFarmacologico:["Cateterismo intermitente limpio (CIL): metodo de eleccion para vaciado en vejiga neurogenica, cada 4-6 horas","Entrenamiento vesical (timed voiding) en pacientes con cierta capacidad miccional","Ejercicios de suelo pelvico en casos de incontinencia de esfuerzo","Toxina botulinica intravesical (inyeccion cistosc pica) en vejiga hiperactiva refractaria","Neuromodulacion sacra en casos seleccionados","Manejo de la piel perineal: higiene, barreras cutaneas para prevenir dermatitis","Diario miccional para seguimiento de patron de vaciado"]},cuidadosEnfermeria:{valoracion:["Evaluar nivel y completitud de la lesion neurologica","Registrar patron miccional: frecuencia, volumen, episodios de incontinencia","Valorar tecnica de cateterismo intermitente del paciente o cuidador","Inspeccionar zona perineal y genital: maceraci\xf3n, eritema, ulceras por humedad","Evaluar conocimiento del paciente sobre el manejo de su vejiga","Registrar frecuencia y caracteristicas de infecciones urinarias previas"],intervenciones:["Ensenhar y supervisar tecnica aseptica de cateterismo intermitente limpio (CIL)","Establecer horario de cateterismos adaptado al patron de llenado del paciente (cada 4-6 h)","Aplicar cuidados de la piel perineal con barreras cutaneas en pacientes con incontinencia","Administrar medicacion anticolinergica o alfabloqueante segun prescripcion","Fomentar ingesta hidrica regular y distribuida en el dia (evitar sobrecarga vesical nocturna)","Instruir al paciente o cuidador en el reconocimiento precoz de infeccion urinaria","Coordinar estudio urodinamico y seguimiento urologico regular"],educacionPaciente:["Ense\xf1ar tecnica de cateterismo intermitente limpio paso a paso, con devolucion de demostracion","Explicar la importancia del vaciado regular para prevenir presiones elevadas y proteger el rino","Instruir sobre signos de infeccion urinaria: orina turbia, maloliente, fiebre, espasticidad aumentada","Informar sobre hiperreflexia autonoma (en lesion T6 o mas alta): cefalea, sudoracion, HTA = emergencia","Educar sobre cuidados de la piel perineal","Explicar necesidad de seguimiento urologico y urodinamico anual"],monitorizacion:["Diario miccional: volumen cateterizado, volumen espontaneo, episodios de incontinencia","Residuo postmiccional mensual en seguimiento ambulatorio","Urocultivo ante cualquier signo de infeccion o cambio en caracteristicas de la orina","Funcion renal y ecografia renal anual para detectar hidronefrosis","PA en pacientes con lesion T6 o superior: riesgo de hiperreflexia autonoma","Signos cutaneos perineales: eritema, ulceracion, dermatitis por humedad"]},npiNanda:[{codigo:"00016",nombre:"Deterioro de la eliminacion urinaria",definicion:"Disfuncion en la eliminacion urinaria",caracteristicasDefinitorias:["Incontinencia urinaria","Retencion urinaria con globo vesical","Residuo postmiccional elevado","Polaquiuria o ausencia de diuresis espontanea"],factoresRelacionados:["Lesion medular que altera la inervacion vesical","Disinergia detrusor-esfinter","Perdida de la sensacion de llenado vesical"]},{codigo:"00023",nombre:"Retencion urinaria",definicion:"Vaciado incompleto de la vejiga",caracteristicasDefinitorias:["Globo vesical palpable","Ausencia de miccion espontanea o miccion en goteo","Residuo postmiccional > 300 mL","Distension vesical"],factoresRelacionados:["Obstruccion infravesical funcional por disinergia","Areflexia del detrusor por lesion del cono medular","Neuropatia auton\xf3mica diabetica"]},{codigo:"00004",nombre:"Riesgo de infeccion",definicion:"Vulnerable a ser invadido y multiplicado por organismos patogenos que pueden comprometer la salud",caracteristicasDefinitorias:["Cateterismo vesical frecuente","Residuo postmiccional que favorece proliferacion bacteriana","Alteracion de barreras naturales por cateterizacion"],factoresRelacionados:["Cateterismo vesical intermitente o permanente","Estasis urinaria por vaciado incompleto","Inmunosupresion asociada a corticoides en lesion medular"]}],npiNic:[{codigo:"0590",nombre:"Manejo de la eliminacion urinaria",actividades:["Monitorizar la eliminacion urinaria: frecuencia, consistencia, olor, volumen y color","Ensenar al paciente tecnicas para estimular la miccion (Valsalva, Crede, golpeteo suprapubico segun tipo)","Establecer horario de cateterismos adaptado al patron del paciente","Obtener muestra de orina para urocultivo ante signos de infeccion","Instruir sobre registro del diario miccional","Coordinar con el equipo multidisciplinario (urologo, fisioterapeuta, trabajador social)"]},{codigo:"1804",nombre:"Ayuda con el autocuidado: uso del inodoro",actividades:["Evaluar capacidad del paciente para realizar cateterismo intermitente de forma independiente","Proporcionar el material necesario para el cateterismo limpio","Supervisar la tecnica hasta que el paciente la domine con seguridad","Adaptar la tecnica a las capacidades motoras del paciente (cateter de insercion facil, espejo)","Implicar al cuidador o familiar en el aprendizaje si el paciente no puede realizarlo solo"]},{codigo:"6550",nombre:"Proteccion contra las infecciones",actividades:["Instruir sobre tecnica aseptica para cateterismo y cuidado del material","Fomentar hidratacion adecuada para diluir orina y reducir proliferacion bacteriana","Vigilar signos y sintomas de infeccion urinaria","Administrar antibioticos profilacticos segun prescripcion","Cambiar sondas permanentes segun protocolo institucional"]}],npiNoc:[{codigo:"0503",nombre:"Eliminacion urinaria",indicadores:["Patron de eliminacion urinaria en rango esperado","Ausencia de retencion urinaria","Residuo postmiccional dentro de limites aceptables","Orina de color y olor normales"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"},{codigo:"1902",nombre:"Control del riesgo",indicadores:["Reconoce los factores de riesgo de infeccion urinaria","Realiza cateterismo con tecnica correcta","Identifica precozmente signos de infeccion","Mantiene ingesta hidrica adecuada"],escala:"1=Nunca demostrado, 2=Raramente demostrado, 3=A veces demostrado, 4=Frecuentemente demostrado, 5=Siempre demostrado"}],complicaciones:["Infecciones urinarias recurrentes y urosepsis","Hidronefrosis bilateral con insuficiencia renal cronica","Reflujo vesicoureteral y cicatrices renales","Litiasis renal (por estasis e infecciones)","Hiperreflexia autonoma (en lesiones T6 o superior): emergencia medica","Ulceras por presion perineales por incontinencia cronica","Impacto psicosocial grave: aislamiento, depresion, dependencia"],criteriosAlarma:["Hiperreflexia autonoma: cefalea pulsatil intensa, sudoracion por encima del nivel de lesion, HTA > 150/100, bradicardia reflexa","Fiebre con escalofrios en paciente con sonda vesical (sospecha urosepsis)","Oligoanuria o anuria con globo vesical (sospecha obstruccion)","Hematuria macroscopica intensa","Dolor abdominal intenso en paciente sin sensacion","Deterioro agudo de la funcion renal (creatinina en ascenso)"],emergencyLevel:"leve",relatedPathologyIds:["pat_pielonefritis","pat_ira","pat_dm2","pat_lesion_medular"],isPremium:!0},{id:"pat_nefropatia_diabetica",nombre:"Nefropatia Diabetica",bodySystemId:"renal_urinario",definicion:"Complicacion microangiopatica cronica y progresiva de la diabetes mellitus caracterizada por da\xf1o estructural y funcional del ri\xf1on, que se manifiesta inicialmente como microalbuminuria y puede progresar hacia proteinuria franca, deterioro del filtrado glomerular e insuficiencia renal terminal. Es la principal causa de enfermedad renal cronica estadio 5 en paises desarrollados.",epidemiologia:"Afecta al 20-40% de los pacientes con diabetes mellitus tipo 1 y tipo 2. En Argentina, la diabetes es la primera causa de ingreso a dialisis cronica, representando el 35-40% de los nuevos pacientes en hemodialisis. El riesgo aumenta con la duracion de la diabetes y el control glucemico deficiente. La mortalidad cardiovascular en pacientes con nefropatia diabetica es 10-30 veces superior a la poblacion general.",factoresRiesgo:["Control glucemico deficiente (HbA1c > 7%)","Hipertension arterial concomitante","Tabaquismo","Antecedentes familiares de nefropatia","Dislipemia","Obesidad","Duracion prolongada de la diabetes (> 10 a\xf1os)","Etnia: mayor riesgo en hispanos, afroamericanos","Proteinuria establecida","Uso de AINEs o medios de contraste iodados sin precaucion"],fisiopatologia:"La hiperglucemia cronica produce da\xf1o renal por multiples mecanismos: 1) Glucosilacion no enzimatica de proteinas de la membrana basal glomerular, alterando su permeabilidad selectiva. 2) Activacion de la via de los polioles y del DAG-PKC, con estres oxidativo. 3) Hiperfiltraci\xf3n glomerular inicial (aumento del FG por vasodilatacion aferente mediada por prostanoides) que eleva la presion intraglomerular. 4) Activacion del SRAA con angiotensina II que produce hipertension intraglomerular y estimula la sintesis de TGF-beta, principal mediador de la fibrosis glomerular e intersticial. Esto lleva a engrosamiento de la membrana basal, expansion mesangial y finalmente a la glomeruloesclerosis nodular de Kimmelstiel-Wilson (hallazgo patologico patognomonico).",signosYSintomas:{signos:["Microalbuminuria (30-300 mg/24h o cociente albumina/creatinina 30-300 mg/g)","Macroproteinuria o proteinuria franca (> 300 mg/24h) en estadios avanzados","Reduccion progresiva del filtrado glomerular estimado (FGe)","Hipertension arterial de dificil control","Edemas en miembros inferiores en estadios con sindrome nefrotico","Palidez (anemia nefrogena en estadios avanzados)","Retinopatia diabetica concomitante (la coexistencia refuerza el diagnostico)"],sintomas:["Asintomatica en estadios iniciales (microalbuminuria)","Edema de miembros inferiores y facial (estadios con proteinuria importante)","Fatiga y astenia progresiva","Nauseas, vomitos y anorexia (sintomas uremicos en estadios avanzados)","Prurito generalizado (uremia avanzada)","Espuma en orina (proteinuria macroscopica)","Nicturia y poliuria iniciales, oliguria en estadios terminales"]},clasificacion:{nombre:"Estadios de nefropatia diabetica segun albuminuria y FGe (KDIGO 2022)",tipos:[{nombre:"Estadio 1: Hiperfiltraci\xf3n",descripcion:"FGe > 90 mL/min/1.73m2 aumentado. Albuminuria < 30 mg/g (normoalbuminuria). Hipertrofia renal. Reversible con control glucemico."},{nombre:"Estadio 2: Microalbuminuria incipiente",descripcion:"FGe normal o levemente aumentado. Microalbuminuria 30-300 mg/g. Engrosamiento inicial de la membrana basal. Tratamiento con IECA/ARA-II puede detener la progresion."},{nombre:"Estadio 3: Nefropatia manifiesta",descripcion:"FGe en descenso progresivo (45-90 mL/min). Proteinuria franca > 300 mg/g. Expansion mesangial difusa. Puede aparecer sindrome nefrotico."},{nombre:"Estadio 4: Insuficiencia renal avanzada",descripcion:"FGe 15-44 mL/min. Proteinuria masiva. Glomeruloesclerosis nodular (lesiones de Kimmelstiel-Wilson). HTA severa. Preparacion para terapia renal sustitutiva."},{nombre:"Estadio 5: Insuficiencia renal terminal",descripcion:"FGe < 15 mL/min. Uremia. Requiere hemodialisis, dialisis peritoneal o trasplante renal."}]},diagnostico:{anamnesis:["Tipo y duracion de la diabetes mellitus","Nivel de control glucemico historico (HbA1c)","Antecedente de hipertension arterial y su tratamiento","Historia de infecciones urinarias recurrentes","Uso de farmacos nefrotoxicos: AINEs, aminoglucosidos, medios de contraste","Antecedentes familiares de enfermedad renal","Tabaquismo y habitos dieteticos (ingesta proteica, sodio)"],examenFisico:["Medicion de PA (objetivo < 130/80 mmHg en nefropatia diabetica)","Evaluacion de edemas (pretibiales, sacros, periorbital = sindrome nefrotico)","Peso y talla para calculo de IMC","Fondo de ojo (retinopatia diabetica concomitante refuerza diagnostico)","Palpacion abdominal (ri\xf1ones pueden estar aumentados en fases iniciales)","Evaluacion de acceso vascular (para futuro uso de hemodialisis en estadios avanzados)"],pruebas:[{nombre:"Cociente albumina/creatinina en orina de primera ma\xf1ana",descripcion:"Metodo de eleccion para cribado y seguimiento de nefropatia diabetica. Mas practico que la orina de 24h. Se realiza anualmente en todo diabetico",valoresReferencia:"Normal < 30 mg/g; Microalbuminuria: 30-300 mg/g; Macroproteinuria: > 300 mg/g",cuidadosEnfermeria:["Instruir al paciente que traiga la primera orina de la ma\xf1ana","Evitar la recogida tras ejercicio intenso, infeccion urinaria o menstruacion (falsos positivos)","Si el resultado es positivo, confirmar con dos determinaciones adicionales en 3-6 meses","Registrar en historia clinica con fecha para seguimiento longitudinal"]},{nombre:"Creatinina serica y FGe (CKD-EPI)",descripcion:"El filtrado glomerular estimado se calcula con la formula CKD-EPI usando creatinina, edad, sexo y etnia. Permite estadificar la ERC y tomar decisiones terapeuticas",valoresReferencia:"FGe normal > 90 mL/min/1.73m2; ERC estadio 3a: 45-59; 3b: 30-44; 4: 15-29; 5: < 15",cuidadosEnfermeria:["Registrar resultado de creatinina con fecha para calcular la tasa de perdida de FGe anual","Asegurar que el paciente no haya realizado ejercicio intenso ni consumido carne roja en exceso","Alertar al medico si FGe cae mas del 25% en un ano o supera umbrales criticos de cambio de estadio"]},{nombre:"HbA1c (hemoglobina glicosilada)",descripcion:"Refleja el control glucemico de los ultimos 2-3 meses. Objetivo < 7% en nefropatia diabetica. En FGe muy reducido puede ser falsamente baja",valoresReferencia:"Objetivo en nefropatia diabetica: < 7%; Normal: < 5.7%; Diabetes: >= 6.5%",cuidadosEnfermeria:["No requiere ayuno para la extraccion","Informar al laboratorio si el paciente tiene anemia hemolitica (afecta el resultado)","Correlacionar con glucemias domiciliarias del paciente para identificar discordancias"]},{nombre:"Perfil lipidico completo",descripcion:"La dislipemia (elevacion de LDL y trigliceridos, descenso de HDL) acelera la progresion de la nefropatia y el riesgo cardiovascular",valoresReferencia:"LDL objetivo < 70 mg/dL en DM con ERC; TG < 150 mg/dL; HDL > 40 (H) > 50 (M) mg/dL",cuidadosEnfermeria:["Requiere ayuno de 12 horas para TG","Evitar ejercicio intenso 24 horas antes","Evaluar adherencia a estatinas en revisiones periodicas"]},{nombre:"Ecografia renal",descripcion:"Evalua tamano renal (normal o aumentado en fases iniciales, reducido en fases tardias), descarta otras causas de ERC (obstruccion, quistes) y evalua ecogenicidad del parenquima",valoresReferencia:"Longitud renal normal: 9-12 cm; Parenquima hiperecogenico = fibrosis avanzada",cuidadosEnfermeria:["No requiere preparacion especial","Coordinar con radiodiagn\xf3stico para realizacion oportuna","Registrar medidas renales para comparacion en el tiempo"]}]},tratamientoMedico:{objetivos:["Retrasar la progresion de la nefropatia diabetica","Control glucemico estricto: HbA1c < 7%","Control tensional estricto: PA < 130/80 mmHg","Reducir proteinuria con IECA o ARA-II","Manejo de la dislipemia con estatinas","Prevenir complicaciones cardiovasculares (principal causa de muerte)"],farmacologico:[{nombre:"Losartan",grupo:"ARA-II (Antagonista del Receptor de Angiotensina II)",mecanismo:"Bloquea el receptor AT1 de la angiotensina II, reduciendo la vasoconstriccion eferente glomerular y la presion intraglomerular, disminuyendo la proteinuria y retardando la progresion de la nefropatia. Tiene efecto nefroprotector independiente del efecto antihipertensivo",dosis:"50-100 mg/dia VO; titular segun PA y tolerancia. Dosis maxima nefroprotectora: 100 mg/dia",cuidadosEnfermeria:["Monitorizar PA y funcion renal (creatinina) a la semana y al mes de iniciar o aumentar dosis","Un aumento de creatinina < 30% al inicio es aceptable y no indica suspension","Vigilar hiperpotasemia: controlar K+ semanalmente al inicio, luego mensualmente","Contraindicado en embarazo (categoria X): verificar en mujeres en edad fertil","Educar sobre no suspender el farmaco sin consultar medico aunque aparezca aumento leve de creatinina"]},{nombre:"Empagliflozina",grupo:"Inhibidor SGLT-2 (cotransportador sodio-glucosa tipo 2)",mecanismo:"Inhibe la reabsorcion de glucosa en el tubulo proximal renal, produciendo glucosuria y reduccion de la glucemia. Ademas, reduce la presion intraglomerular por vasoconstriccion aferente y tiene efectos antiinflamatorios y antifibr\xf3ticos directos en el ri\xf1on. Demostrado que reduce la progresion de la nefropatia diabetica en estudios EMPA-REG y CREDENCE",dosis:"10 mg VO una vez al dia por la ma\xf1ana. Puede aumentarse a 25 mg si FGe >= 45 mL/min",cuidadosEnfermeria:["Contraindicado si FGe < 30 mL/min (ineficaz e inseguro)","Vigilar infecciones genitourinarias micoticas: instruir sobre higiene genital","Monitorizar glucemia: puede causar hipoglucemia si se combina con insulina o sulfonilureas","Educar sobre cetoacidosis eugluc\xe9mica (rara pero grave): sintomas de acidosis metabolica con glucemia normal","Suspender 3-4 dias antes de cirugia o procedimientos con ayuno prolongado (riesgo de cetoacidosis)"]},{nombre:"Atorvastatina",grupo:"Estatina (inhibidor de HMG-CoA reductasa)",mecanismo:"Inhibe la sintesis de colesterol en el higado, reduciendo LDL en un 30-50%. Tambien tiene efectos pleiotr picos: antiinflamatorio, estabilizador de placas ateroscleroticas. Reduce el riesgo cardiovascular en pacientes con nefropatia diabetica",dosis:"20-40 mg VO al acostarse (mayor sintesis colesterol nocturna). Ajuste segun FGe no necesario",cuidadosEnfermeria:["Vigilar miopatia y rabdomiolisis: consultar ante dolor muscular intenso o debilidad","Monitorizar enzimas hepaticas (ALT/AST) al inicio y ante sintomas hepaticos","Informar sobre interacciones: eritromicina, antifungicos, ciclosporina aumentan riesgo de miopatia","Administrar preferentemente a la noche","Evaluar adherencia en cada consulta: muchos pacientes suspenden por miedo a efectos adversos"]}],noFarmacologico:["Dieta hiposodica: restriccion de sodio < 2.3 g/dia para control de PA y edemas","Restriccion proteica moderada: 0.8 g/kg/dia en estadios 3-4 para reducir carga glomerular","Control de peso: IMC objetivo < 25 kg/m2","Abandono del tabaquismo (acelera la perdida de funcion renal)","Actividad fisica regular adaptada (150 min/semana de actividad moderada)","Autocontrol glucemico domiciliario y registro de PA","Evitar AINEs, aminoglucosidos y medios de contraste iodados sin premedicacion y ajuste de dosis"]},cuidadosEnfermeria:{valoracion:["Medir PA en ambos brazos en reposo de 5 minutos","Evaluar presencia y grado de edemas (escala +1 a +4)","Registrar peso diario en ayunas para detectar retencion hidrica","Valorar adherencia al tratamiento farmacologico y diet\xe9tico","Evaluar tecnica de autocontrol glucemico domiciliario","Identificar uso de farmacos nefrotoxicos (AINEs, suplementos herbales)"],intervenciones:["Administrar IECA o ARA-II segun prescripcion y vigilar PA y potasio","Educar sobre dieta hiposodica e hipoprot\xe9ica con ejemplos practicos","Coordinar con diabetologo, nefrologo y nutricionista en manejo multidisciplinario","Gestionar analitica periodica (creatinina, potasio, HbA1c, microalbuminuria)","Preparar y educar al paciente sobre posibilidad futura de terapia renal sustitutiva en estadios avanzados","Registrar y reportar signos de progresion: aumento de edemas, elevacion de creatinina, PA descontrolada"],educacionPaciente:["Explicar la relacion entre control glucemico, control de PA y progresion de la nefropatia","Ense\xf1ar a interpretar los resultados de la microalbuminuria y el FGe","Indicar la importancia de evitar AINEs (ibuprofeno, diclofenac) y usar paracetamol para el dolor","Instruir sobre restriccion proteica: evitar exceso de carnes y proteinas, no eliminar totalmente","Explicar por que no debe suspender el losartan aunque aparezca creatinina levemente elevada","Ense\xf1ar a reconocer signos de descompensacion: edema que aumenta, disnea, oliguria"],monitorizacion:["PA en cada consulta; objetivo < 130/80 mmHg","Cociente albumina/creatinina en orina: cada 3-6 meses en nefropatia establecida","Creatinina y FGe: cada 3 meses en estadios 3-4","Potasio: mensual al inicio con IECA/ARA-II, luego cada 3-6 meses","HbA1c: cada 3 meses hasta control optimo, luego cada 6 meses","Peso diario: en pacientes con edemas o en tratamiento con diureticos"]},npiNanda:[{codigo:"00179",nombre:"Riesgo de nivel de glucemia inestable",definicion:"Vulnerable a variacion en los niveles sericos de glucosa respecto al rango normal que puede comprometer la salud",caracteristicasDefinitorias:["Glucemia fuera del rango objetivo","HbA1c elevada","Registros de hiperglucemia frecuente"],factoresRelacionados:["Control glucemico deficiente","Falta de adherencia al tratamiento antidiabetico","Ajuste de dosis incorrecto de insulina o hipoglucemiantes"]},{codigo:"00025",nombre:"Riesgo de desequilibrio de volumen de liquidos",definicion:"Vulnerable a una disminucion, aumento o cambio rapido de un espacio a otro de los liquidos intravasculares, intersticiales y/o intracelulares",caracteristicasDefinitorias:["Edemas en miembros inferiores","Aumento de peso rapido","Proteinuria con hipoalbuminemia"],factoresRelacionados:["Sindrome nefrotico con hipoproteinemia","Retencion hidrosalina por reduccion del FGe","Uso de diureticos"]},{codigo:"00078",nombre:"Gestion de salud ineficaz",definicion:"Patron de regulacion e integracion en la vida diaria de un regimen terapeutico para el tratamiento de la enfermedad que no es adecuado para alcanzar objetivos de salud especificos",caracteristicasDefinitorias:["Falta de adherencia a restriccion dietetica","Uso de AINEs o automedicacion nefrot\xf3xica","Abandono de controles periodicos"],factoresRelacionados:["Complejidad del regimen terapeutico","Falta de conocimiento sobre la enfermedad","Multimorbilidad asociada"]}],npiNic:[{codigo:"2120",nombre:"Manejo de la hiperglucemia",actividades:["Monitorizar la glucemia segun protocolo y resultados de HbA1c","Administrar insulina o hipoglucemiantes orales segun prescripcion","Identificar posibles causas de hiperglucemia (infeccion, estres, incumplimiento dietetico)","Ajustar el plan de cuidados ante cambios en la funcion renal que afecten la dosis de farmacos","Educar sobre autocontrol glucemico domiciliario e interpretacion de resultados"]},{codigo:"4130",nombre:"Monitorizacion de liquidos",actividades:["Pesar al paciente diariamente a la misma hora y con la misma ropa","Vigilar presencia y grado de edemas","Monitorizar PA para detectar sobrecarga de volumen","Registrar ingresos y egresos en pacientes hospitalizados","Vigilar nivel de albumina serica como indicador de estado nutritivo y sindrome nefrotico"]},{codigo:"7400",nombre:"Guias del sistema sanitario",actividades:["Coordinar derivacion a nefrologia cuando FGe < 45 mL/min o progresion rapida","Programar controles analiticos periodicos segun estadio de la ERC","Gestionar derivacion a nutricionista para plan dietetico individualizado","Programar fondo de ojo anual para cribado y seguimiento de retinopatia diabetica","Preparar al paciente para inicio de terapia renal sustitutiva cuando FGe < 20 mL/min"]}],npiNoc:[{codigo:"2300",nombre:"Nivel de glucemia",indicadores:["Glucemia en ayunas en rango objetivo (80-130 mg/dL)","HbA1c por debajo del objetivo terapeutico (< 7%)","Ausencia de episodios hipoglucemicos severos","Glucemia postprandial < 180 mg/dL"],escala:"1=Desviacion grave del rango normal, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"},{codigo:"1101",nombre:"Integridad tisular: piel y membranas mucosas",indicadores:["Ausencia de edema con fovea","Piel sin lesiones de rascado por prurito","Mucosas humedas","Peso estable sin ganancia hidrica"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"}],complicaciones:["Insuficiencia renal terminal con necesidad de dialisis o trasplante","Enfermedad cardiovascular acelerada (principal causa de muerte)","Sindrome nefrotico (edemas masivos, hipoalbuminemia, hiperlipemia)","Anemia nefrogena (deficit de eritropoyetina)","Hiperparatiroidismo secundario y osteodistrofia renal","Neuropatia periferica y autonomica concomitante","Mayor susceptibilidad a infecciones (urinarias, pulmonares)"],criteriosAlarma:["Caida del FGe > 25% en menos de 3 meses","Hiperpotasemia > 6 mEq/L","Edema severo con dificultad respiratoria (edema agudo de pulmon)","Sindrome uremico: nauseas, vomitos, asterixis, confusion","PA > 180/110 mmHg a pesar de tratamiento","Proteinuria > 3.5 g/24h con hipoalbuminemia grave (< 2.5 g/dL)","Oliguria en paciente con nefropatia avanzada (puede indicar estadio terminal)"],emergencyLevel:"leve",relatedPathologyIds:["pat_dm2","pat_hta","pat_ira","pat_irc"],isPremium:!0},{id:"pat_rabdomiolisis",nombre:"Rabdomiolisis",bodySystemId:"renal_urinario",definicion:"Sindrome clinico grave caracterizado por la destruccion masiva del musculo esqueletico (miolisis) con liberacion de contenido intracelular muscular a la circulacion, incluyendo mioglobina, creatinquinasa (CK), electrolitos y otras sustancias toxicas. La mioglobinuria resultante puede precipitar injuria renal aguda severa, potencialmente letal.",epidemiologia:"Incidencia estimada de 26.000 casos por ano en EE.UU. Representa el 5-15% de los casos de insuficiencia renal aguda en paises desarrollados. La mortalidad global es del 8%, pero puede superar el 20% en pacientes con IRA grave, hiperpotasemia y acidosis metabolica severa. Los traumatismos y el sindrome de aplastamiento son las causas mas frecuentes en Argentina dado los antecedentes de terremotos y accidentes de transito.",factoresRiesgo:["Traumatismo muscular severo o sindrome de aplastamiento","Ejercicio fisico extenuante (rabdomiolisis de esfuerzo)","Convulsiones prolongadas o status epilepticus","Hipertermia maligna","Isquemia muscular prolongada (torniquete, sindrome compartimental)","Intoxicacion por alcohol, cocaina, heroina, anfetaminas","Estatinas (especialmente en combinacion con otros farmacos)","Miopatias inflamatorias (polimiositis, dermatomiositis)","Hipopotasemia o hipofosfatemia severa","Infecciones virales (influenza, coxsackievirus, VIH)"],fisiopatologia:"La lesi n muscular produce fallo de la bomba Na+/K+-ATPasa y del intercambiador Na+/Ca2+, con acumulacion intracelular de calcio que activa proteasas, lipasas y endonucleasas que destruyen la celula muscular. Se liberan a la circulacion: mioglobina (responsable de la toxicidad renal), CK (marcador diagnostico), potasio (hiperpotasemia potencialmente fatal), fosforo (hiperfosfatemia), acido urico, aldolasa y tromboplastina tisular (activa la cascada de coagulacion, riesgo de CID). La mioglobina precipita en los tubulos renales (especialmente en ambiente acido e hipovolemico), causando obstruccion tubular directa, vasoconstriccion renal mediada por estres oxidativo y deplecion del oxido nitrico, y toxicidad directa del hierro libre sobre el tubulo proximal. El resultado es necrosis tubular aguda e injuria renal aguda olig\xfarica.",signosYSintomas:{signos:["Orina de color marron oscuro o color te/cola (mioglobinuria)","Elevacion marcada de CK (> 1000 U/L, habitualmente > 10.000 U/L)","Mioglobinuria positiva en tira reactiva (reacciona con hemoglobina/mioglobina)","Creatinina en ascenso rapido (IRA olig\xfarica en casos severos)","Hiperpotasemia (K+ > 6 mEq/L en cuadros graves)","Hipocalcemia inicial (por deposito de calcio en musculo lesionado)","Hiperuricemia","Edema muscular local con aumento de circunferencia del miembro afectado"],sintomas:["Dolor muscular intenso y difuso (mialgia), especialmente en musculos afectados","Debilidad muscular marcada o paralisis flaccida del area lesionada","Orina oscura o marron (mioglobinuria macrosc\xf3pica)","Oliguria progresiva","Nauseas, vomitos, malestar general","Fiebre (por respuesta inflamatoria sistemica o causa subyacente)","Calambres musculares"]},clasificacion:{nombre:"Clasificacion segun causa precipitante y severidad",tipos:[{nombre:"Rabdomiolisis traumatica",descripcion:"Sindrome de aplastamiento, politraumatismo, quemaduras extensas. Mecanismo directo de destruccion celular. Mayor riesgo de CID y sindrome compartimental. Alta mortalidad en contexto de trauma mayor."},{nombre:"Rabdomiolisis de esfuerzo",descripcion:"Ejercicio fisico intenso no habitual. Tipica en militares, deportistas amateurs, maratones extremas. Generalmente leve a moderada. Puede ser grave en condiciones de deshidratacion o calor extremo (golpe de calor)."},{nombre:"Rabdomiolisis no traumatica",descripcion:"Causes metabolicas, toxicas, infecciosas, miopaticas. Incluye intoxicaciones por alcohol, drogas de abuso, estatinas, miopatias inflamatorias. Inicio mas insidioso, puede no haber dolor muscular prominente."},{nombre:"Sindrome de aplastamiento",descripcion:"Forma extrema de rabdomiolisis traumatica. Compresion prolongada de grandes masas musculares. Al liberar la compresion se produce liberacion masiva y brusca de mioglobina. Riesgo de shock, hiperpotasemia fatal e IRA fulminante."}]},diagnostico:{anamnesis:["Mecanismo lesional: traumatismo, ejercicio extenuante, convulsiones, ingestion de toxicos","Tiempo transcurrido desde el evento desencadenante","Cambios en el color de la orina (orina oscura/coca cola)","Historia de mialgias o debilidad muscular previa","Uso de estatinas, fibratos u otros farmacos miotoxicos","Antecedente de episodios previos (miopatias heredadas o intoxicaciones recurrentes)"],examenFisico:["Evaluacion de estado hemodinamico (PA, FC, diuresis horaria)","Inspeccion y palpacion de masas musculares (edema, tension, dolor)","Busqueda de sindrome compartimental: dolor a la extension pasiva, tension del compartimento, parestesias","Color de la orina: marron o coca cola en mioglobinuria macrosc\xf3pica","Evaluacion neurologica: nivel de consciencia (encefalopatia en IRA severa)","Signos de hiperpotasemia: debilidad, arritmias, paralisis ascendente"],pruebas:[{nombre:"Creatinquinasa (CK) serica",descripcion:"Marcador principal de da\xf1o muscular. Se eleva a las 2-12h del evento, pico a las 24-72h. El valor > 5 veces el limite superior normal define rabdomiolisis. El riesgo de IRA aumenta con CK > 15.000-20.000 U/L",valoresReferencia:"Normal: 30-200 U/L; Rabdomiolisis: habitualmente > 1.000 U/L, casos graves > 50.000-100.000 U/L",cuidadosEnfermeria:["Extraer en el momento del diagnostico y repetir cada 6-12h para evaluar tendencia","El descenso de CK con buena hidratacion indica respuesta favorable","Registrar valor absoluto y velocidad de ascenso o descenso","Mantener la muestra a temperatura ambiente y procesar rapidamente"]},{nombre:"Mioglobina en orina (mioglobinuria)",descripcion:"La tira reactiva de orina detecta grupo hemo (positivo si hay hemoglobina o mioglobina). Sin hematuria en el microscopio = mioglobinuria. Confirma el diagnostico cuando la orina es marron",valoresReferencia:"Negativo en condiciones normales; positivo indica mioglobinuria si no hay hematuria microscopica",cuidadosEnfermeria:["Registrar color de la orina en cada miccion o por sondaje vesical","Realizar tira reactiva y sedimento urinario (ausencia de globulos rojos con tira positiva = mioglobinuria)","Si hay sonda vesical, vaciar bolsa antes de la muestra para obtener orina fresca"]},{nombre:"Ionograma completo (Na, K, Cl, Ca, P, Mg)",descripcion:"Hiperpotasemia (por salida de K+ intracelular): potencialmente fatal por arritmias. Hipocalcemia inicial (por deposito en musculo). Hiperfosfatemia. Acidosis metabolica por acidos organicos",valoresReferencia:"K+ normal: 3.5-5.0 mEq/L; Ca2+ normal: 8.5-10.5 mg/dL; P normal: 2.5-4.5 mg/dL",cuidadosEnfermeria:["Monitorizar ECG ante K+ > 6 mEq/L (cambios: ondas T picudas, ensanchamiento QRS, onda sinusoidal = emergencia)","Repetir ionograma cada 2-4h en las primeras 24h si hay IRA o hiperpotasemia","Preparar gluconato de calcio para estabilizacion cardiaca si hiperpotasemia severa","NO corregir la hipocalcemia asintomatica inicial (el calcio suplementado se puede depositar en el musculo lesionado y empeorar el cuadro)"]},{nombre:"Gasometria arterial",descripcion:"Detecta acidosis metabolica con anion gap elevado (acumulacion de acidos organicos y fosfatos). La acidosis favorece la precipitacion de mioglobina en tubulos. Orienta la necesidad de bicarbonato",valoresReferencia:"pH normal: 7.35-7.45; HCO3- normal: 22-26 mEq/L; Anion gap normal: 8-12 mEq/L",cuidadosEnfermeria:["Extraer muestra de arteria radial o femoral con tecnica adecuada","Mantener la muestra en hielo si no se procesa en menos de 15 minutos","Registrar temperatura del paciente (la fiebre afecta los valores gasometricos)","Alertar al medico si pH < 7.20 o HCO3- < 15 mEq/L"]},{nombre:"Coagulacion (TP, KPTT, fibrinogeno, dimero-D)",descripcion:"Busca CID (coagulacion intravascular diseminada) por liberacion de tromboplastina tisular. El CID agrava el pronostico y puede provocar hemorragias graves",valoresReferencia:"TP: 11-14s; KPTT: 25-35s; Fibrinogeno: 200-400 mg/dL; D-dimero: < 500 ng/mL",cuidadosEnfermeria:["Repetir cada 4-6h si se confirma CID","Vigilar signos de sangrado en sitios de puncion, mucosas y piel","Preparar plasma fresco congelado o crioprecipitado segun indicacion medica","Registrar todos los sitios de sangrado activo"]}]},tratamientoMedico:{objetivos:["Prevenir o tratar la injuria renal aguda","Corregir las alteraciones hidroelectroliticas (hiperpotasemia, acidosis)","Alcalinizar la orina para prevenir precipitacion de mioglobina (pH orina > 6.5)","Mantener diuresis forzada > 200-300 mL/hora","Identificar y tratar la causa subyacente","Prevenir sindrome compartimental y CID"],farmacologico:[{nombre:"Solucion Fisiologica 0.9% (SF)",grupo:"Cristaloide isot\xf3nico - fluidoterapia de resucitacion",mecanismo:"Expande el volumen intravascular, mejora la perfusion renal, diluye la mioglobina en los tubulos y aumenta la diuresis para facilitar la eliminacion de la mioglobina antes de que precipite",dosis:"Adultos: 1-1.5 L/hora las primeras horas para revertir hipovolemia, luego ajustar para mantener diuresis 200-300 mL/hora. Total primeras 24h: 6-12 L segun respuesta",cuidadosEnfermeria:["Colocar sonda vesical para monitorizar diuresis horaria estrictamente (objetivo: 200-300 mL/h)","Vigilar sobrecarga hidrica: edema pulmonar, crepitantes basales, aumento de PA","Monitorizar presion venosa central si disponible para guiar la hidratacion","Registrar balance hidrico cada hora en las primeras 12-24h","Ajustar velocidad de infusion segun diuresis y estado hemodinamico"]},{nombre:"Bicarbonato de Sodio 1/6 Molar",grupo:"Agente alcalinizante urinario",mecanismo:"Alcaliniza la orina (pH urinario objetivo > 6.5), lo que aumenta la solubilidad de la mioglobina y reduce su precipitacion en los tubulos renales. Tambien corrige la acidosis metabolica sistemica",dosis:"Alternando con SF 0.9%, 500 mL-1L de bicarbonato 1/6 M por cada 2-3 L de SF. Titular segun pH urinario y arterial",cuidadosEnfermeria:["Monitorizar pH urinario cada 2-4h con tira reactiva (objetivo pH orina > 6.5)","Vigilar hipocalcemia sintomatica: la alcalinizacion puede exacerbar los sintomas neuromusculares","Controlar potasio: el bicarbonato puede producir descenso de K+, util si hay hiperpotasemia","Vigilar signos de alcalosis: irritabilidad neuromuscular, tetania, calambres","Suspender bicarbonato si pH arterial > 7.50 para evitar alcalosis"]},{nombre:"Gluconato de Calcio 10%",grupo:"Antagonista cardiaco del potasio",mecanismo:"El calcio estabiliza la membrana del miocito cardiaco antagonizando los efectos toxicos de la hiperpotasemia sobre el potencial de accion, previniendo arritmias ventriculares fatales. No reduce el potasio serico, solo antagoniza su efecto cardiaco",dosis:"1-2 ampollas (10-20 mL) de gluconato de calcio 10% IV en 2-3 minutos. Repetir cada 5-10 min si persisten cambios en ECG",cuidadosEnfermeria:["Reservado para hiperpotasemia severa con cambios en ECG (K+ > 6.5 mEq/L con cambios ECG)","Administrar lentamente en 2-3 minutos monitorizando ECG continuo durante la infusion","No mezclar con bicarbonato en la misma via (precipita calcio-carbonato)","La duracion del efecto es breve (30-60 min): planificar medidas definitivas de reduccion de potasio","Vigilar bradicardia e hipotension durante la administracion IV rapida"]}],noFarmacologico:["Reposo absoluto de los grupos musculares afectados","Fasciotomia urgente si hay sindrome compartimental confirmado (presion > 30 mmHg)","Hemodialisis de urgencia si: hiperpotasemia refractaria (K+ > 6.5 sin respuesta), acidosis severa (pH < 7.10), sobrecarga hidrica grave con oligoanuria","Monitorizacion continua de ECG durante las primeras 24-48 horas","Inmovilizacion correcta y prevencion de ulceras por presion","Evitar farmacos nefrotoxicos, AINEs y medios de contraste durante el episodio agudo"]},cuidadosEnfermeria:{valoracion:["Evaluar estado hemodinamico completo: PA, FC, FR, SatO2, temperatura cada hora en fase aguda","Monitorizar diuresis horaria: objetivo 200-300 mL/h con tratamiento instaurado","Observar y registrar color de la orina en cada miccion (escala: claro, ambarino, marron oscuro, coca cola)","Evaluar presencia e intensidad del dolor muscular con escala EVA","Detectar signos de sindrome compartimental: dolor desproporcionado, tension muscular, parestesias, debilidad progresiva","Monitorizar ECG continuo buscando cambios por hiperpotasemia"],intervenciones:["Instalar sonda vesical para monitoreo horario estricto de diuresis","Administrar fluidoterapia intensa segun prescripcion: 1-1.5 L/hora de SF en fase inicial","Alternar SF con bicarbonato para alcalinizar orina: verificar pH urinario cada 2-4 horas","Realizar balance hidrico cada hora en las primeras 24 horas","Administrar gluconato de calcio IV ante hiperpotasemia con cambios en ECG","Preparar material para hemodialisis urgente si el medico la indica (hiperpotasemia refractaria, oligoanuria)","Vigilar y reportar inmediatamente signos de sindrome compartimental"],educacionPaciente:["Explicar al paciente y familia la causa de la orina oscura y la gravedad del cuadro","Instruir sobre la importancia de la hidratacion abundante y el sondaje para el seguimiento","Informar sobre la necesidad de reposo estricto del area muscular afectada","Explicar los signos de alarma tras el alta: reaparicion de orina oscura, reduccion de orina, edema o dolor muscular creciente","Si fue por ejercicio extenuante: educar sobre calentamiento previo, hidratacion durante el ejercicio y progresion gradual de la intensidad","Si fue por farmaco (estatina): explicar la importancia de informar al medico para ajuste o cambio de medicacion"],monitorizacion:["Diuresis horaria obligatoria con sonda vesical: objetivo > 200-300 mL/h en fase de tratamiento activo","Color de orina en cada medicion: aclaramiento progresivo indica eficacia del tratamiento","CK serica cada 6-12h hasta que inicie el descenso","Ionograma y gasometria cada 4-6h en las primeras 24h (hiperpotasemia, acidosis)","ECG continuo las primeras 24-48h: buscar cambios de hiperpotasemia (T picudas, QRS ancho)","Creatinina y urea cada 12h para monitorizar la IRA","Presion muscular si hay sospecha de sindrome compartimental"]},npiNanda:[{codigo:"00203",nombre:"Riesgo de perfusion renal ineficaz",definicion:"Vulnerable a una disminucion de la circulacion de la sangre en los ri\xf1ones que puede comprometer la salud",caracteristicasDefinitorias:["Oliguria progresiva","Creatinina en ascenso","Orina de color marron oscuro por mioglobinuria","Hiperpotasemia"],factoresRelacionados:["Mioglobinuria con precipitacion en tubulos renales","Hipovolemia por perdidas a tercer espacio muscular","Vasoconstriccion renal por estres oxidativo de la mioglobina"]},{codigo:"00001",nombre:"Desequilibrio nutricional: ingestion inferior a las necesidades",definicion:"Ingestion de nutrientes insuficiente para satisfacer las necesidades metabolicas",caracteristicasDefinitorias:["Incapacidad de ingesta oral por nauseas y vomitos","Catabolismo muscular elevado","Anorexia en contexto de IRA"],factoresRelacionados:["Nauseas y vomitos asociados a IRA e hiperpotasemia","Anorexia en estado critico","Restriccion dietetica (hiperpotasemia, hiperfosfatemia)"]},{codigo:"00204",nombre:"Perfusion tisular periferica ineficaz",definicion:"Disminucion de la circulacion sanguinea en la periferia que puede comprometer la salud",caracteristicasDefinitorias:["Edema muscular con aumento de tension compartimentales","Debilidad o paralisis distal al compartimento afectado","Parestesias y frialdad distal (sindrome compartimental)"],factoresRelacionados:["Edema muscular masivo post-lisis con aumento de presion intracompartimental","Hipovolemia relativa por secuestro de liquido en musculo","Compresion vascular por edema muscular"]}],npiNic:[{codigo:"4200",nombre:"Terapia intravenosa (I.V.)",actividades:["Canalizar dos vias venosas perifericas de grueso calibre (minimo 16G) o via central","Administrar fluidoterapia masiva segun prescripcion (1-1.5 L/h de SF inicialmente)","Mantener la permeabilidad de las vias venosas y prevenir la flebitis","Alternar SF con bicarbonato segun prescripcion y pH urinario","Registrar todo lo infundido con horarios exactos en el balance hidrico"]},{codigo:"2080",nombre:"Manejo de liquidos y electrolitos",actividades:["Monitorizar ionograma cada 4-6h en fase aguda (hiperpotasemia, hipocalcemia)","Administrar gluconato de calcio IV ante hiperpotasemia con cambios en ECG segun prescripcion","Vigilar signos clinicos de hiperpotasemia: debilidad muscular, paralisis, arritmias","NO corregir hipocalcemia asintomatica inicial en rabdomiolisis activa","Monitorizar balance hidrico estricto y vigilar signos de sobrehidratacion"]},{codigo:"4044",nombre:"Cuidados cardiacos: agudos",actividades:["Monitorizar ECG continuo las primeras 24-48 horas","Reconocer cambios de hiperpotasemia en ECG: ondas T picudas, PR prolongado, QRS ancho, onda sinusoidal","Alertar al medico inmediatamente ante cualquier cambio en el ritmo cardiaco","Preparar y administrar gluconato de calcio IV de urgencia ante arritmia por hiperpotasemia","Registrar y comunicar frecuencia, ritmo y cualquier cambio del trazado ECG"]}],npiNoc:[{codigo:"0501",nombre:"Eliminacion urinaria",indicadores:["Diuresis horaria > 100 mL/h (objetivo 200-300 mL/h con tratamiento)","Aclaramiento progresivo del color de la orina","Ausencia de mioglobinuria macrosc\xf3pica en 24-48h","Creatinina serica en descenso o estabilizacion"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"},{codigo:"0600",nombre:"Equilibrio electrolitico y acido-basico",indicadores:["Potasio serico dentro del rango normal (3.5-5.0 mEq/L)","pH arterial en rango normal (7.35-7.45)","Ausencia de cambios en ECG por hiperpotasemia","Calcio serico en rango normal","pH urinario > 6.5 con tratamiento alcalinizante"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"}],complicaciones:["Injuria renal aguda (IRA) olig\xfarica: principal causa de mortalidad","Hiperpotasemia grave con arritmias ventriculares fatales (fibrilacion ventricular, paro cardiaco)","Coagulacion intravascular diseminada (CID)","Sindrome compartimental que puede requerir fasciotomia","Acidosis metabolica severa","Hipocalcemia sintomatica (tetania, convulsiones)","Shock hipovolemico por secuestro masivo de liquido en musculo lesionado","Fallo multiorganico en casos graves"],criteriosAlarma:["Oliguria o anuria: diuresis < 0.5 mL/kg/hora a pesar de hidratacion adecuada","Hiperpotasemia severa: K+ > 6.5 mEq/L o cualquier cambio en ECG (ondas T picudas, QRS ancho)","CK > 100.000 U/L (indicador de destruccion muscular masiva y alto riesgo de IRA)","Acidosis metabolica severa: pH < 7.20 o HCO3- < 12 mEq/L","Sindrome compartimental: dolor desproporcionado, tension muscular extrema, parestesias, perdida de fuerza","Signos de CID: sangrado en sitios de puncion, petequias, equimosis diseminadas","Deterioro hemodinamico: hipotension, taquicardia, signos de shock"],emergencyLevel:"critico",relatedPathologyIds:["pat_ira","pat_hiperkalemia","pat_acidosis_metabolica","pat_sindrome_compartimental"],isPremium:!0},{id:"pat_placenta_previa",nombre:"Placenta Previa",bodySystemId:"reproductivo",definicion:"Insercion anormal de la placenta en el segmento uterino inferior, ocluiendo parcial o totalmente el orificio cervical interno (OCI). Constituye una de las principales causas de hemorragia obstetrica en el tercer trimestre y representa una emergencia obst\xe9trica mayor.",epidemiologia:"Incidencia de 1 en 200-250 embarazos. El riesgo aumenta con ces\xe1reas previas (0.3% en primigestas vs 3% con 4 o m\xe1s ces\xe1reas). Responsable del 20% de las hemorragias anteparto. Mortalidad materna reducida al 0.03% en pa\xedses con atenci\xf3n obstetrica adecuada, pero mortalidad perinatal de 2-3%.",factoresRiesgo:["Cesarea previa","Cirugia uterina previa (miomectomia, legrado)","Multiparidad","Edad materna avanzada (> 35 a\xf1os)","Embarazo multiple","Tabaquismo","Uso de cocaina","Antecedente de placenta previa","Tecnicas de reproduccion asistida"],fisiopatologia:"La implantaci\xf3n placentaria en el segmento uterino inferior se debe a defectos en la decidua basal, generalmente secundarios a cicatrices uterinas previas. A medida que el segmento inferior se forma y dilata en el tercer trimestre, los vellos cori\xf3nicos se desprenden, produciendo hemorragia de los sinusoides maternos. La sangre es de origen materno, roja y fresca. La separaci\xf3n placentaria compromete el intercambio gaseoso fetal. La hipovolemia materna puede provocar shock y coagulopat\xeda de consumo.",signosYSintomas:{signos:["Sangrado vaginal rojo rutilante sin causa aparente","\xdatero blando y no doloroso a la palpaci\xf3n","Presentaci\xf3n fetal alta o an\xf3mala (transversa u oblicua)","Latidos cardiacos fetales normales inicialmente","Hipotensi\xf3n materna en sangrados severos","Taquicardia materna compensatoria"],sintomas:["Sangrado vaginal indoloro en el tercer trimestre (sello diagn\xf3stico)","Primera hemorragia generalmente autolimitada y repetitiva","Ausencia de contracciones uterinas dolorosas","Sensaci\xf3n de debilidad o mareo en hemorragias abundantes","Ansiedad materna"]},clasificacion:{nombre:"Clasificaci\xf3n seg\xfan grado de oclusi\xf3n del OCI",tipos:[{nombre:"Placenta previa oclusiva total",descripcion:"La placenta cubre completamente el OCI. Resoluci\xf3n obligatoria por ces\xe1rea."},{nombre:"Placenta previa oclusiva parcial",descripcion:"La placenta cubre parcialmente el OCI."},{nombre:"Placenta previa marginal",descripcion:"El borde placentario alcanza el margen del OCI sin cubrirlo."},{nombre:"Placenta de inserci\xf3n baja",descripcion:"La placenta se inserta en el segmento inferior pero su borde est\xe1 a m\xe1s de 2 cm del OCI."}]},diagnostico:{anamnesis:["Antecedente de sangrado vaginal indoloro en el tercer trimestre","N\xfamero de ces\xe1reas o cirug\xedas uterinas previas","Edad gestacional actual","Cantidad y caracter\xedsticas del sangrado (color, cantidad, episodios previos)","Presencia o ausencia de dolor abdominal","Actividad fetal percibida por la madre","Uso de tocol\xedticos o corticoides previos"],examenFisico:["Signos vitales maternos completos (PA, FC, FR, Temp)","Evaluaci\xf3n del estado hemodin\xe1mico materno","Palpaci\xf3n abdominal: tono uterino, presentaci\xf3n fetal, altura uterina","Auscultaci\xf3n de latidos cardiacos fetales (LCF)","CONTRAINDICADO tacto vaginal hasta descartar placenta previa por ecograf\xeda","Evaluaci\xf3n de sangrado externo (ap\xf3sito perineal)"],pruebas:[{nombre:"Ecograf\xeda obst\xe9trica transvaginal",descripcion:"Gold standard para diagn\xf3stico y clasificaci\xf3n de placenta previa. Determina localizaci\xf3n exacta, distancia del borde placentario al OCI y grado de oclusi\xf3n.",valoresReferencia:"Distancia borde placentario - OCI: > 20 mm = normal; 0-20 mm = inserci\xf3n baja; < 0 mm = previa",cuidadosEnfermeria:["Informar al paciente sobre el procedimiento transvaginal","Transvaginal tiene mayor precisi\xf3n que transabdominal","Verificar que sonda est\xe9 limpia y cubierta","Preparar vejiga semillena para abdominal"]},{nombre:"Hemograma completo y grupo y factor",descripcion:"Eval\xfaa anemia por sangrado, leucocitosis y disponibilidad para transfusi\xf3n. Determina grupo sangu\xedneo y factor Rh para profilaxis anti-D si corresponde.",valoresReferencia:"Hb > 11 g/dL en embarazo; Hto > 33%; Plaquetas > 150.000/mm3",cuidadosEnfermeria:["Extracci\xf3n urgente al ingreso","Enviar muestra para tipificaci\xf3n y pruebas cruzadas","Reservar 2-4 unidades de gl\xf3bulos rojos","Administrar anti-D 300 mcg si madre Rh negativo"]},{nombre:"Coagulograma (TP, KPTT, fibrin\xf3geno)",descripcion:"Detecta coagulopat\xeda de consumo en hemorragias severas. El fibrin\xf3geno < 200 mg/dL indica CID.",valoresReferencia:"TP: 11-15 seg; KPTT: 25-35 seg; Fibrin\xf3geno: 200-400 mg/dL",cuidadosEnfermeria:["Extracci\xf3n en tubo citratado (tapa celeste)","Transporte inmediato al laboratorio","Repetir cada 4-6 horas en sangrado activo","Informar inmediatamente valores cr\xedticos al m\xe9dico"]},{nombre:"Monitorizaci\xf3n cardiotocogr\xe1fica (CTG)",descripcion:"Eval\xfaa bienestar fetal mediante registro de frecuencia cardiaca fetal y din\xe1mica uterina. Detecta sufrimiento fetal agudo.",valoresReferencia:"FCF normal: 110-160 lpm; variabilidad normal: 5-25 lpm; sin desaceleraciones tard\xedas",cuidadosEnfermeria:["Colocar en dec\xfabito lateral izquierdo","Aplicar gel conductor en transductores","Registrar m\xednimo 20 minutos","Informar inmediatamente desaceleraciones tard\xedas o bradicardia"]}]},tratamientoMedico:{objetivos:["Controlar hemorragia y preservar vida materna","Prolongar embarazo hasta madurez pulmonar fetal (> 34 semanas)","Prevenir shock hipovol\xe9mico materno","Detectar y tratar coagulopat\xeda de consumo","Planificar v\xeda de parto (ces\xe1rea en la mayor\xeda de los casos)"],farmacologico:[{nombre:"Betametasona",grupo:"Corticoide antenatal (glucocorticoide)",mecanismo:"Induce maduraci\xf3n pulmonar fetal acelerando la s\xedntesis de surfactante, reduciendo s\xedndrome de dificultad respiratoria neonatal en partos pret\xe9rmino.",dosis:"12 mg IM cada 24 horas x 2 dosis (entre 24-34 semanas de gestaci\xf3n)",cuidadosEnfermeria:["Administrar IM profundo en m\xfasculo vasto externo o gl\xfateo","Registrar hora exacta de cada dosis para completar esquema","Monitorizar glucemia materna (puede elevar glicemia transitoriamente)","Verificar semanas de gestaci\xf3n antes de administrar","Informar al neonat\xf3logo sobre administraci\xf3n del esquema"]},{nombre:"Sulfato de Magnesio",grupo:"Neuroprotector fetal / Tocol\xedtico",mecanismo:"Neuroprotecci\xf3n fetal en < 32 semanas: reduce riesgo de par\xe1lisis cerebral. Efecto tocol\xedtico suave para inhibir contracciones y prolongar gestaci\xf3n.",dosis:"Neuroprotecci\xf3n: 4 g IV en 20 min (dosis carga), luego 1 g/h hasta el parto. Tocolisis: 4-6 g IV en 30 min, luego 1-3 g/h",cuidadosEnfermeria:["Monitorizar reflejos osteotendinosos cada hora (p\xe9rdida de ROT = toxicidad)","Controlar diuresis: m\xednimo 30 mL/h (oliguria precede toxicidad)","Tener disponible gluconato de calcio 1 g IV como ant\xeddoto","Vigilar frecuencia respiratoria: no administrar si FR < 12/min","Monitorizar niveles s\xe9ricos de magnesio si disponible (terap\xe9utico: 4-7 mEq/L)"]},{nombre:"\xc1cido Tranex\xe1mico",grupo:"Antifibrinol\xedtico",mecanismo:"Inhibe competitivamente la activaci\xf3n del plasmin\xf3geno a plasmina, reduciendo la fibrin\xf3lisis y el sangrado activo.",dosis:"1 g IV en 10 minutos. Puede repetirse 1 g si sangrado continua despu\xe9s de 30 min. Administrar dentro de las primeras 3 horas del sangrado.",cuidadosEnfermeria:["Administrar lentamente (no m\xe1s de 100 mg/min) para evitar hipotensi\xf3n","No mezclar con otros medicamentos en la misma v\xeda","Vigilar signos de trombosis (hinchaz\xf3n en extremidades, dolor)","Registrar hora exacta de inicio del sangrado para validar ventana terap\xe9utica","Monitorizar PA durante infusi\xf3n"]}],noFarmacologico:["Reposo absoluto en cama (hospitalizaci\xf3n) ante cualquier episodio de sangrado","Acceso venoso perif\xe9rico de grueso calibre (14-16G) x2","Reposici\xf3n de volumen con cristaloides (SF 0.9% o Ringer lactato)","Transfusi\xf3n de gl\xf3bulos rojos desplasmatizados si Hb < 8 g/dL o inestabilidad hemodin\xe1mica","Plasma fresco congelado si TP/KPTT prolongados o fibrin\xf3geno < 150 mg/dL","Ces\xe1rea de urgencia ante hemorragia incontrolable o sufrimiento fetal agudo","Abstenci\xf3n de relaciones sexuales y tactos vaginales","Monitorizaci\xf3n continua materno-fetal"]},cuidadosEnfermeria:{valoracion:["Monitorizar signos vitales maternos cada 15-30 minutos en episodio agudo","Cuantificar p\xe9rdida hem\xe1tica (pesar ap\xf3sitos: 1 g = 1 mL de sangre)","Evaluar caracter\xedsticas del sangrado: color, cantidad, presencia de co\xe1gulos","Auscultar latidos cardiacos fetales y registrar cardiotocograf\xeda continua","Valorar nivel de consciencia y signos de shock hipovol\xe9mico","Evaluar tono uterino en cada valoraci\xf3n (\xfatero blando en placenta previa)"],intervenciones:["Canalizar 2 v\xedas venosas perif\xe9ricas de gran calibre inmediatamente","Administrar oxigenoterapia 8-10 L/min por m\xe1scara si saturaci\xf3n < 95%","Posici\xf3n dec\xfabito lateral izquierdo para aliviar compresi\xf3n de vena cava","NUNCA realizar tacto vaginal sin indicaci\xf3n m\xe9dica expresa y ecograf\xeda previa","Preparar equipo de reanimaci\xf3n neonatal ante posible parto pret\xe9rmino","Coordinar con banco de sangre para disponibilidad de hemoderivados","Preparar paciente para ces\xe1rea de urgencia si se indica"],educacionPaciente:["Explicar la condici\xf3n en t\xe9rminos comprensibles, reduciendo ansiedad materna","Instruir sobre reposo estricto en cama y abstenci\xf3n sexual","Indicar consulta inmediata ante cualquier sangrado, aunque sea leve","Explicar importancia del control prenatal frecuente","Ense\xf1ar a reconocer signos de alarma: aumento del sangrado, dolor abdominal, contracciones, disminuci\xf3n de movimientos fetales"],monitorizacion:["Signos vitales cada 15-30 min durante episodio agudo","Cardiotocograf\xeda continua durante sangrado activo","Diuresis horaria con sonda vesical en inestabilidad hemodin\xe1mica","Hemograma y coagulograma cada 4-6 horas en sangrado activo","Peso diario para estimar balance h\xeddrico","Ecograf\xeda obst\xe9trica de seguimiento cada 2-4 semanas"]},npiNanda:[{codigo:"00206",nombre:"Riesgo de hemorragia",definicion:"Vulnerable a una disminuci\xf3n del volumen de sangre que puede comprometer la salud",caracteristicasDefinitorias:["Sangrado vaginal activo o recurrente","Hemoglobina y hematocrito en descenso","Hipotensi\xf3n arterial"],factoresRelacionados:["Inserci\xf3n placentaria an\xf3mala en segmento uterino inferior","Separaci\xf3n de vellos cori\xf3nicos con dilataci\xf3n cervical","Coagulopat\xeda de consumo asociada"]},{codigo:"00032",nombre:"Patron respiratorio ineficaz del feto",definicion:"Intercambio gaseoso fetal comprometido por separaci\xf3n placentaria y shock materno",caracteristicasDefinitorias:["Alteraciones en la frecuencia cardiaca fetal","Desaceleraciones tard\xedas en CTG","Disminuci\xf3n de movimientos fetales"],factoresRelacionados:["Reducci\xf3n del flujo uteroplacentario por separaci\xf3n placentaria","Hipovolemia materna con hipoperfusi\xf3n placentaria","Anemia fetal por p\xe9rdida hem\xe1tica"]},{codigo:"00146",nombre:"Ansiedad",definicion:"Sensaci\xf3n vaga e intranquilizadora de malestar o amenaza acompa\xf1ada de una respuesta aut\xf3noma",caracteristicasDefinitorias:["Expresi\xf3n de preocupaci\xf3n por bienestar fetal","Taquicardia","Inquietud","Verbalizaci\xf3n del miedo"],factoresRelacionados:["Amenaza para el bienestar propio y del feto","Hospitalizaci\xf3n no planificada","Incertidumbre sobre el resultado del embarazo"]}],npiNic:[{codigo:"4160",nombre:"Control de hemorragias",actividades:["Monitorizar signos de hemorragia: PA, FC, nivel de consciencia","Cuantificar sangrado vaginal objetivamente","Mantener v\xedas venosas permeables de gran calibre","Administrar fluidos IV y hemoderivados seg\xfan indicaci\xf3n","Preparar para intervenci\xf3n quir\xfargica de urgencia si es necesario"]},{codigo:"6772",nombre:"Vigilancia: seguridad del feto en el anteparto",actividades:["Aplicar monitorizaci\xf3n cardiotocogr\xe1fica continua","Registrar y evaluar frecuencia cardiaca fetal","Valorar movimientos fetales cada turno","Notificar al m\xe9dico cambios en el patr\xf3n fetal","Preparar equipo de reanimaci\xf3n neonatal"]},{codigo:"5820",nombre:"Disminuci\xf3n de la ansiedad",actividades:["Explicar todos los procedimientos a realizar","Mantener presencia tranquilizadora junto a la paciente","Favorecer participaci\xf3n de pareja o familiar de apoyo","Proporcionar informaci\xf3n veraz y adaptada sobre el estado","Fomentar expresi\xf3n de miedos y preguntas"]}],npiNoc:[{codigo:"0413",nombre:"Severidad de la perdida de sangre",indicadores:["Volumen de sangrado visible dentro de l\xedmites aceptables","Presi\xf3n arterial estable","Frecuencia cardiaca en rango normal","Hemoglobina dentro de valores aceptables"],escala:"1=Grave, 2=Sustancial, 3=Moderada, 4=Leve, 5=Ninguna"},{codigo:"2509",nombre:"Estado materno: anteparto",indicadores:["Signos vitales maternos estables","Sin evidencia de hemorragia activa","Bienestar emocional materno","Conocimiento del plan de cuidados"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Shock hipovol\xe9mico materno","Coagulaci\xf3n intravascular diseminada (CID)","Acretismo placentario (placenta \xe1creta, \xedncreta, p\xe9rcreta)","Parto pret\xe9rmino","Sufrimiento fetal agudo","Muerte fetal intrauterina","Histerectom\xeda obst\xe9trica de urgencia","Muerte materna"],criteriosAlarma:["Sangrado vaginal abundante o que aumenta progresivamente","Hipotensi\xf3n arterial (PAS < 90 mmHg)","Taquicardia materna > 120 lpm","Alteraciones en la frecuencia cardiaca fetal (bradicardia < 110 lpm, desaceleraciones tard\xedas)","Disminuci\xf3n o ausencia de movimientos fetales","Aparici\xf3n de dolor abdominal (sugiere desprendimiento asociado)","Signos de shock: palidez, diaforesis, oliguria, alteraci\xf3n del estado mental"],emergencyLevel:"critico",relatedPathologyIds:["pat_dpp","pat_embarazo_ectopico"],isPremium:!0},{id:"pat_embarazo_ectopico",nombre:"Embarazo Ectopico",bodySystemId:"reproductivo",definicion:"Implantaci\xf3n del \xf3vulo fecundado fuera de la cavidad uterina, ocurriendo en el 95-97% de los casos en la trompa de Falopio (embarazo tubario). Constituye una emergencia gineco-obst\xe9trica que amenaza la vida por riesgo de rotura y hemorragia intraabdominal masiva.",epidemiologia:"Incidencia del 1-2% de todos los embarazos. Representa la principal causa de mortalidad materna en el primer trimestre (6-13% de muertes maternas). La tasa ha aumentado por mayor incidencia de EPI y mayor uso de t\xe9cnicas de reproducci\xf3n asistida. Tasa de recurrencia del 15% tras un primer ect\xf3pico.",factoresRiesgo:["Enfermedad inflamatoria p\xe9lvica previa (EPI)","Cirug\xeda tub\xe1rica previa (esterilizaci\xf3n quir\xfargica)","Embarazo ect\xf3pico previo","Uso de DIU (especialmente en fallos)","Endometriosis p\xe9lvica","Infecci\xf3n por Chlamydia trachomatis o Neisseria gonorrhoeae","T\xe9cnicas de reproducci\xf3n asistida (FIV)","Tabaquismo activo","Cirug\xeda abdomino-p\xe9lvica previa","Malformaciones tub\xe1ricas cong\xe9nitas"],fisiopatologia:"La implantaci\xf3n ect\xf3pica ocurre cuando el \xf3vulo fecundado no progresa adecuadamente hacia el \xfatero, generalmente por da\xf1o ciliar o estructural de la trompa. El trofoblasto invade la pared tub\xe1rica, que carece de decidua y miometrio adecuados para sostener el embarazo. La trompa se dilata y puede romperse entre las 6-10 semanas de gestaci\xf3n, produciendo hemorragia intraabdominal masiva con hemoperitoneo. La sangre acumulada en el fondo de saco de Douglas irrita el diafragma (dolor referido al hombro) y provoca shock hipovol\xe9mico.",signosYSintomas:{signos:["Masa anexial palpable al examen p\xe9lvico","Dolor a la movilizaci\xf3n del cuello uterino (signo de Chandelier)","Sangrado vaginal escaso y oscuro (distinto del menstrual)","Abdomen en tabla con signos peritoneales en caso de rotura","Hipotensi\xf3n y taquicardia en rotura tub\xe1rica","Test de embarazo (beta-hCG) positivo con \xfatero vac\xedo en ecograf\xeda"],sintomas:["Dolor abdomino-p\xe9lvico unilateral (s\xedntoma cardinal)","Amenorrea de 6-8 semanas","Sangrado vaginal irregular o manchado","N\xe1useas y v\xf3mitos (similares a embarazo normal)","Dolor referido al hombro derecho (irritaci\xf3n diafragm\xe1tica por hemoperitoneo)","Lipotimia o s\xedncope en rotura con hemorragia masiva","Sensaci\xf3n de presi\xf3n rectal"]},clasificacion:{nombre:"Clasificaci\xf3n seg\xfan localizaci\xf3n de la implantaci\xf3n",tipos:[{nombre:"Tub\xe1rico ampular",descripcion:"M\xe1s frecuente (80%). Implantaci\xf3n en la ampolla tub\xe1rica. Mayor tiempo antes de la rotura."},{nombre:"Tub\xe1rico \xedstmico",descripcion:"10-15%. Implantaci\xf3n en el istmo. Rotura m\xe1s temprana por menor di\xe1metro luminal."},{nombre:"Tub\xe1rico f\xedmbrico",descripcion:"5%. Implantaci\xf3n en las fimbrias. Puede evolucionar a aborto tub\xe1rico."},{nombre:"Intersticial o cornual",descripcion:"2-4%. Implantaci\xf3n en la porci\xf3n intramural de la trompa. Rotura tard\xeda (10-12 sem) con hemorragia masiva."},{nombre:"No tub\xe1rico (ov\xe1rico, cervical, abdominal)",descripcion:"< 3%. Localizaciones raras con alta morbilidad. Ect\xf3pico cervical: riesgo de hemorragia masiva."}]},diagnostico:{anamnesis:["Fecha de \xfaltima menstruaci\xf3n y caracter\xedsticas del ciclo","Antecedentes de EPI, ITS, cirug\xeda p\xe9lvica o ect\xf3pico previo","M\xe9todos anticonceptivos actuales (DIU, ligadura tub\xe1rica)","S\xedntomas: tr\xedada cl\xe1sica dolor + amenorrea + sangrado","Dolor referido al hombro (signo de irritaci\xf3n peritoneal por hemoperitoneo)","S\xedncope o lipotimia (sugiere hemorragia significativa)"],examenFisico:["Signos vitales completos con \xe9nfasis en hipotensi\xf3n y taquicardia","Evaluaci\xf3n del estado hemodin\xe1mico","Palpaci\xf3n abdominal: dolor en fosa iliaca, defensa y rebote en rotura","Examen p\xe9lvico: masa anexial, dolor a movilizaci\xf3n cervical","Valorar distensi\xf3n abdominal por hemoperitoneo","Pu\xf1o-percusi\xf3n renal bilateral"],pruebas:[{nombre:"Beta-hCG cuantitativa en suero",descripcion:"Hormona clave para diagn\xf3stico y seguimiento. En embarazo intrauterino normal aumenta > 66% cada 48h. En ect\xf3pico la curva es sub\xf3ptima. Nivel discriminatorio: > 1500-2000 mUI/mL sin saco gestacional en ecograf\xeda = alta sospecha de ect\xf3pico.",valoresReferencia:"Normal en embarazo: duplicaci\xf3n cada 48h. Nivel discriminatorio ecogr\xe1fico: 1500-2000 mUI/mL",cuidadosEnfermeria:["Extraer muestra basal urgente al ingreso","Programar determinaci\xf3n seriada a las 48h para evaluar curva","Comunicar resultado inmediatamente al m\xe9dico de guardia","Verificar que la muestra sea suero (no plasma con EDTA)"]},{nombre:"Ecograf\xeda transvaginal",descripcion:"Piedra angular del diagn\xf3stico. Busca saco gestacional intrauterino, masa anexial (anillo tub\xe1rico), l\xedquido libre en Douglas (hemoperitoneo) y \xfatero vac\xedo.",valoresReferencia:"Saco gestacional visible TV con beta-hCG > 1500 mUI/mL; l\xedquido libre en Douglas = hemoperitoneo",cuidadosEnfermeria:["Realizar con vejiga vac\xeda (transvaginal)","Preparar sonda con cubierta y gel","Documentar presencia de l\xedquido libre y su cantidad estimada","Registrar si se visualiza latido card\xedaco fetal en masa anexial"]},{nombre:"Hemograma y grupo sangu\xedneo urgente",descripcion:"Eval\xfaa anemia por hemorragia interna. Determina grupo y factor Rh para transfusi\xf3n. Leucocitosis moderada puede estar presente.",valoresReferencia:"Hb > 11 g/dL; Hto > 33%; Leucocitos: 4.000-11.000/mm3",cuidadosEnfermeria:["Extracci\xf3n urgente al ingreso simult\xe1neamente con v\xeda venosa","Solicitar tipificaci\xf3n y pruebas cruzadas ante inestabilidad","Administrar anti-D 300 mcg si Rh negativo","Repetir Hb en 2-4h ante sospecha de sangrado activo"]}]},tratamientoMedico:{objetivos:["Controlar la hemorragia y estabilizar hemodin\xe1micamente a la paciente","Eliminar el embarazo ect\xf3pico preservando la fertilidad cuando sea posible","Prevenir rotura tub\xe1rica con tratamiento precoz","Monitorizar resoluci\xf3n completa mediante curva de beta-hCG"],farmacologico:[{nombre:"Metotrexato",grupo:"Antimetabolito (an\xe1logo del \xe1cido f\xf3lico)",mecanismo:"Inhibe la dihidrofolato reductasa, bloqueando la s\xedntesis de purinas y timidilato, deteniendo la proliferaci\xf3n trofobl\xe1stica y resolviendo el embarazo ect\xf3pico sin cirug\xeda en casos seleccionados.",dosis:"Dosis \xfanica: 50 mg/m2 SC o IM. Protocolo multidosis: 1 mg/kg IM d\xedas 1,3,5,7 alternando con \xe1cido fol\xednico 0.1 mg/kg d\xedas 2,4,6,8",cuidadosEnfermeria:["Verificar criterios de elegibilidad antes de administrar (beta-hCG < 5000, masa < 3.5 cm, sin latido fetal, hemodin\xe1micamente estable)","Contraindicado en lactancia, inmunodeficiencia, disfunci\xf3n hep\xe1tica o renal","Instruir a la paciente: evitar relaciones sexuales, alcohol, \xe1cido f\xf3lico y AINEs durante el tratamiento","Explicar que puede ocurrir dolor abdominal transitorio (lisis trofobl\xe1stica) los d\xedas 3-7","Programar controles de beta-hCG seriados (d\xedas 4 y 7, luego semanal hasta negativizaci\xf3n)"]},{nombre:"Morfina",grupo:"Analg\xe9sico opiode mayor",mecanismo:"Agonista de receptores mu opioides en SNC y m\xe9dula espinal, produciendo analgesia potente para control del dolor en embarazo ect\xf3pico complicado o postquir\xfargico.",dosis:"2-4 mg IV cada 4-6 horas; o PCA (analgesia controlada por paciente) postoperatoria",cuidadosEnfermeria:["Monitorizar frecuencia respiratoria antes de cada dosis (no administrar si FR < 12/min)","Tener naloxona 0.4 mg IV disponible como ant\xeddoto","Evaluar escala de dolor EVA antes y 30 min despu\xe9s de administraci\xf3n","Vigilar n\xe1useas y v\xf3mitos (efecto adverso frecuente)","Registrar nivel de sedaci\xf3n (escala de Ramsay)"]},{nombre:"Ceftriaxona + Doxiciclina",grupo:"Antibioticoterapia profil\xe1ctica/terap\xe9utica (cefalosporina 3ra gen + tetraciclina)",mecanismo:"Cobertura de g\xe9rmenes habituales en EPI y cirug\xeda p\xe9lvica: Chlamydia, Gonococo, anaerobios. Previene infecci\xf3n postoperatoria y trata EPI concomitante.",dosis:"Ceftriaxona 1-2 g IV/IM dosis \xfanica; Doxiciclina 100 mg VO c/12h x 14 d\xedas",cuidadosEnfermeria:["Verificar alergias a betalact\xe1micos antes de administrar ceftriaxona","Doxiciclina: administrar con abundante agua, evitar en dec\xfabito (esofagitis)","Advertir fotosensibilidad con doxiciclina: evitar exposici\xf3n solar","Administrar ceftriaxona IM en m\xfasculo grande (gl\xfateo) diluida en lidoca\xedna 1% para reducir dolor","Registrar y comunicar cualquier reacci\xf3n al\xe9rgica inmediatamente"]}],noFarmacologico:["Cirug\xeda laparosc\xf3pica (salpingostom\xeda o salpinguectom\xeda): tratamiento de elecci\xf3n en inestabilidad hemodin\xe1mica","Laparotom\xeda de urgencia en rotura con shock hipovol\xe9mico","Reposo absoluto y vigilancia estrecha en tratamiento m\xe9dico con metotrexato","2 v\xedas venosas perif\xe9ricas de gran calibre para reposici\xf3n de volumen","Transfusi\xf3n de hemoderivados si Hb < 8 g/dL o inestabilidad hemodin\xe1mica","Asesoramiento sobre fertilidad futura y anticoncepci\xf3n"]},cuidadosEnfermeria:{valoracion:["Monitorizar signos vitales cada 15-30 min ante sospecha de rotura","Evaluar dolor abdominal con escala EVA y caracter\xedsticas (localizaci\xf3n, intensidad, irradiaci\xf3n)","Vigilar signos de shock: hipotensi\xf3n, taquicardia, palidez, diaforesis, alteraci\xf3n del nivel de consciencia","Cuantificar sangrado vaginal","Verificar resultado de beta-hCG y ecograf\xeda urgente","Evaluar antecedentes de riesgo para ect\xf3pico"],intervenciones:["Canalizar v\xedas venosas perif\xe9ricas de gran calibre (14-16G) inmediatamente","Administrar fluidoterapia IV seg\xfan protocolo ante inestabilidad hemodin\xe1mica","Preparar para cirug\xeda de urgencia (laparoscopia/laparotom\xeda) si se indica","Administrar analgesia prescrita y evaluar respuesta","Extraer muestras urgentes: beta-hCG, hemograma, grupo y factor, coagulograma","Colocar sonda vesical en quir\xf3fano para monitorizar diuresis intraoperatoria","Brindar soporte emocional: la paciente enfrenta p\xe9rdida gestacional + cirug\xeda urgente"],educacionPaciente:["Explicar en t\xe9rminos comprensibles qu\xe9 es el embarazo ect\xf3pico y por qu\xe9 es una emergencia","Si se trata con metotrexato: educar sobre signos de alarma para consulta urgente (dolor intenso, sangrado abundante, mareo)","Informar sobre posibilidades de fertilidad futura tras el tratamiento","Indicar anticonceptivos por m\xednimo 3 meses tras metotrexato (teratogenicidad residual)","Explicar necesidad de seguimiento con beta-hCG seriadas hasta negativizaci\xf3n"],monitorizacion:["Signos vitales cada 15-30 min en fase aguda","Beta-hCG seriada post-metotrexato (d\xedas 4, 7, luego semanal)","Hemograma de control a las 48-72h","Ecograf\xeda de control si persisten s\xedntomas con tratamiento m\xe9dico","Vigilancia de efectos adversos del metotrexato: mucositis, leucopenia, hepatotoxicidad"]},npiNanda:[{codigo:"00206",nombre:"Riesgo de hemorragia",definicion:"Vulnerable a una disminuci\xf3n del volumen de sangre que puede comprometer la salud",caracteristicasDefinitorias:["Masa anexial palpable con beta-hCG positiva","L\xedquido libre intraabdominal en ecograf\xeda","Hipotensi\xf3n y taquicardia"],factoresRelacionados:["Rotura tub\xe1rica con hemoperitoneo","Invasi\xf3n trofobl\xe1stica de pared tub\xe1rica vascularizada","Coagulopat\xeda asociada a hemorragia masiva"]},{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable ocasionada por una lesi\xf3n tisular real o potencial",caracteristicasDefinitorias:["Expresi\xf3n verbal de dolor abdomino-p\xe9lvico unilateral","Facies de dolor","Postura anti\xe1lgica","Taquicardia y taquipnea"],factoresRelacionados:["Distensi\xf3n tub\xe1rica por crecimiento trofobl\xe1stico","Irritaci\xf3n peritoneal por hemoperitoneo","Rotura tub\xe1rica con lesi\xf3n tisular directa"]},{codigo:"00141",nombre:"Sindrome de duelo complicado",definicion:"Trastorno que ocurre tras la muerte de una persona significativa en el que la experiencia de angustia que acompa\xf1a al duelo no sigue las expectativas normativas",caracteristicasDefinitorias:["Llanto","Expresi\xf3n de angustia por p\xe9rdida del embarazo","Negaci\xf3n","Preocupaci\xf3n por fertilidad futura"],factoresRelacionados:["P\xe9rdida gestacional no esperada","Posible impacto en fertilidad futura","Cirug\xeda urgente con p\xe9rdida tub\xe1rica"]}],npiNic:[{codigo:"4160",nombre:"Control de hemorragias",actividades:["Monitorizar signos vitales y estado hemodin\xe1mico continuamente","Mantener accesos venosos de gran calibre permeables","Administrar fluidoterapia y hemoderivados seg\xfan protocolo","Preparar campo quir\xfargico y documentaci\xf3n para cirug\xeda urgente","Coordinar con banco de sangre y anestesiolog\xeda"]},{codigo:"1400",nombre:"Manejo del dolor",actividades:["Evaluar dolor con escala EVA cada 2-4 horas","Administrar analgesia prescrita verificando alergias y contraindicaciones","Aplicar medidas no farmacol\xf3gicas: posici\xf3n c\xf3moda, calor local suave","Registrar respuesta analg\xe9sica y comunicar dolor refractario al m\xe9dico","Diferenciar dolor esperado (post-metotrexato) de dolor de alarma (rotura)"]},{codigo:"5290",nombre:"Facilitar el duelo",actividades:["Escuchar activamente las expresiones de dolor emocional","Reconocer la p\xe9rdida gestacional como un duelo real","Facilitar el llanto y la expresi\xf3n emocional sin juzgar","Proporcionar informaci\xf3n sobre recursos de apoyo psicol\xf3gico","Incluir a la pareja en el proceso de duelo cuando la paciente lo desee"]}],npiNoc:[{codigo:"0413",nombre:"Severidad de la perdida de sangre",indicadores:["Estabilidad hemodin\xe1mica mantenida","Hemoglobina dentro de rangos aceptables","Ausencia de signos de shock","D\xe9bito de drenaje dentro de par\xe1metros normales postquir\xfargico"],escala:"1=Grave, 2=Sustancial, 3=Moderada, 4=Leve, 5=Ninguna"},{codigo:"1306",nombre:"Dolor: respuesta psicologica adversa",indicadores:["Escala EVA <= 3 con tratamiento analg\xe9sico","Expresi\xf3n facial sin tensi\xf3n","Postura relajada","Capacidad de descansar"],escala:"1=Grave, 2=Sustancial, 3=Moderada, 4=Leve, 5=Ninguna"}],complicaciones:["Rotura tub\xe1rica con hemoperitoneo masivo","Shock hipovol\xe9mico","Coagulaci\xf3n intravascular diseminada","Infertilidad tub\xe1rica (especialmente con salpinguectom\xeda bilateral)","Ect\xf3pico recurrente (15% de probabilidad)","Hemorragia intraoperatoria con necesidad de transfusi\xf3n","Toxicidad por metotrexato (mucositis, hepatotoxicidad, mielotoxicidad)","Ect\xf3pico persistente tras tratamiento m\xe9dico (15-20% requiere segunda dosis)"],criteriosAlarma:["Hipotensi\xf3n arterial (PAS < 90 mmHg)","Taquicardia > 100 lpm","Dolor abdominal severo de inicio brusco","Dolor referido al hombro (irritaci\xf3n diafragm\xe1tica por hemoperitoneo)","S\xedncope o pre-s\xedncope","Distensi\xf3n abdominal progresiva","Beta-hCG positiva con \xfatero vac\xedo en ecograf\xeda transvaginal","L\xedquido libre abundante en fondo de saco de Douglas"],emergencyLevel:"critico",relatedPathologyIds:["pat_placenta_previa","pat_dpp"],isPremium:!0},{id:"pat_cancer_cervix",nombre:"Cancer de Cuello Uterino",bodySystemId:"reproductivo",definicion:"Neoplasia maligna originada en el epitelio del cuello uterino, en la zona de transformaci\xf3n donde se produce la uni\xf3n escamocolumnar. Es causada en pr\xe1cticamente el 100% de los casos por la infecci\xf3n persistente por el Virus del Papiloma Humano (VPH), siendo los genotipos 16 y 18 responsables del 70% de los casos.",epidemiologia:"Cuarto c\xe1ncer m\xe1s frecuente en mujeres a nivel mundial (604.127 nuevos casos en 2020). En Argentina es el tercer c\xe1ncer ginecol\xf3gico m\xe1s frecuente. Mortalidad de 341.831 mujeres anuales globalmente. La vacunaci\xf3n contra VPH y el tamizaje con PAP/colposcop\xeda han reducido la incidencia un 60-80% en pa\xedses desarrollados. Mayor incidencia en pa\xedses de bajos ingresos por limitado acceso al tamizaje.",factoresRiesgo:["Infecci\xf3n persistente por VPH de alto riesgo (16, 18, 31, 33, 45)","Inicio temprano de relaciones sexuales (< 16 a\xf1os)","M\xfaltiples parejas sexuales","Inmunosupresi\xf3n (VIH, transplante, tratamiento inmunosupresor)","Tabaquismo activo (duplica el riesgo)","Infecciones de transmisi\xf3n sexual concomitantes (Clamidia, Herpes)","No realizaci\xf3n de tamizaje con PAP/VPH","Multiparidad","Uso prolongado de anticonceptivos hormonales orales (> 5 a\xf1os)","Bajo nivel socioecon\xf3mico y acceso limitado a salud"],fisiopatologia:"El VPH infecta las c\xe9lulas basales del epitelio cervical en la zona de transformaci\xf3n. Las prote\xednas oncog\xe9nicas E6 y E7 de los genotipos de alto riesgo inactivan los supresores tumorales p53 y Rb respectivamente, provocando desregulaci\xf3n del ciclo celular, inmortalizaci\xf3n y transformaci\xf3n maligna. La progresi\xf3n ocurre desde infecci\xf3n \u2192 NIC I \u2192 NIC II \u2192 NIC III \u2192 carcinoma in situ \u2192 carcinoma invasor, un proceso que tarda entre 10-20 a\xf1os. El 90% de las infecciones son aclaradas por el sistema inmune en 1-2 a\xf1os. El carcinoma invasor infiltra el estroma cervical y puede diseminarse por contig\xfcidad, v\xeda linf\xe1tica y hemat\xf3gena.",signosYSintomas:{signos:["Sangrado vaginal postcoital (s\xedntoma m\xe1s precoz y frecuente)","C\xe9rvix con lesi\xf3n visible, friable, exof\xedtica o ulcerada en especuloscop\xeda","Flujo vaginal purulento o serosanguinolento maloliente","Masa palpable en c\xe9rvix al tacto vaginal en estadios avanzados","Adenopat\xedas inguinales o p\xe9lvicas palpables en enfermedad metast\xe1sica"],sintomas:["Sangrado vaginal intermenstrual o postmenop\xe1usico","Sangrado postcoital recurrente","Flujo vaginal anormal (acuoso, mucoso o purulento)","Dolor p\xe9lvico cr\xf3nico en estadios avanzados","Disuria, hematuria o rectorragia (invasi\xf3n de vejiga/recto en estadios IV)","Edema de miembros inferiores por obstrucci\xf3n linf\xe1tica","Estadios tempranos frecuentemente ASINTOM\xc1TICOS (importancia del tamizaje)"]},clasificacion:{nombre:"Estadificacion FIGO 2018",tipos:[{nombre:"Estadio I",descripcion:"Carcinoma confinado al cuello uterino. IA: microinvasivo (< 5 mm profundidad, < 7 mm ancho). IB: invasivo cl\xednicamente visible o > IA."},{nombre:"Estadio II",descripcion:"Invasi\xf3n m\xe1s all\xe1 del \xfatero pero sin alcanzar la pared p\xe9lvica ni el tercio inferior de la vagina. IIA: sin parametrios. IIB: con afectaci\xf3n parametrial."},{nombre:"Estadio III",descripcion:"Invasi\xf3n a pared p\xe9lvica, tercio inferior de vagina, o causa hidronefrosis/ri\xf1\xf3n no funcionante. IIIC: ganglios p\xe9lvicos (IIIC1) o paraa\xf3rticos (IIIC2) positivos."},{nombre:"Estadio IV",descripcion:"Invasi\xf3n de mucosa vesical o rectal (IVA) o met\xe1stasis a distancia (IVB: pulm\xf3n, h\xedgado, hueso)."}]},diagnostico:{anamnesis:["Historia de tamizaje previo con PAP y resultado","Estado vacunal frente a VPH","Antecedentes de lesiones cervicales previas (NIC, colposcop\xeda)","S\xedntomas: sangrado postcoital, intermenstrual, flujo vaginal anormal","Factores de riesgo: tabaquismo, ITS previas, inmunosupresi\xf3n","Historia sexual (n\xfamero de parejas, inicio de relaciones)"],examenFisico:["Especuloscop\xeda: inspecci\xf3n visual del c\xe9rvix (lesi\xf3n exof\xedtica, ulceraci\xf3n, friabilidad)","Tacto vaginal bimanual: tama\xf1o uterino, movilidad, masa parametrial","Tacto rectal: extensi\xf3n a tabique rectovaginal y parametrios","Inspecci\xf3n de genitales externos y regi\xf3n inguinal","Palpaci\xf3n de cadenas ganglionares"],pruebas:[{nombre:"Citologia cervical (Papanicolaou)",descripcion:"Test de tamizaje fundamental. Detecta c\xe9lulas an\xf3malas (ASCUS, LSIL, HSIL, carcinoma). Sensibilidad 55-80%, especificidad 90-99%. Se recomienda cada 3 a\xf1os entre 21-65 a\xf1os.",valoresReferencia:"Normal: c\xe9lulas escamosas maduras sin atipia. HSIL o carcinoma = derivaci\xf3n urgente a colposcop\xeda",cuidadosEnfermeria:["Toma ideal entre d\xedas 10-20 del ciclo, evitar menstruaci\xf3n","Abstenci\xf3n sexual, duchas vaginales y \xf3vulos vaginales 48h previas","T\xe9cnica correcta: toma del exoc\xe9rvix (esp\xe1tula) y endoc\xe9rvix (cepillo)","Extender en portaobjetos fijando con spray citofix inmediatamente","Registrar datos cl\xednicos en la solicitud (FUM, anticonceptivos)"]},{nombre:"Colposcop\xeda con biopsia dirigida",descripcion:"Gold standard diagn\xf3stico. Visualizaci\xf3n ampliada del c\xe9rvix con \xe1cido ac\xe9tico y lugol para identificar zonas de transformaci\xf3n an\xf3malas (acetoblanco, mosaico, puntilleo) y tomar biopsia de zonas sospechosas.",valoresReferencia:"Colposcop\xeda satisfactoria: zona de transformaci\xf3n visible en su totalidad",cuidadosEnfermeria:["Informar que se realizar\xe1 biopsia y puede presentar leve sangrado y calambres post-procedimiento","Instruir reposo sexual y uso de tampones 1 semana post-biopsia","Preparar material est\xe9ril: esp\xe9culo, pinzas de biopsia, f\xf3rceps de Pozzi, soluci\xf3n de Monsel","Recoger muestra en frasco con formol 10% correctamente rotulado","Indicar consulta inmediata ante sangrado abundante post-biopsia"]},{nombre:"Test de VPH (genotipificaci\xf3n)",descripcion:"Detecta ADN viral de genotipos de alto riesgo. Mayor sensibilidad que el PAP (95% vs 55%). Puede usarse como tamizaje primario a partir de los 30 a\xf1os o como co-test con PAP.",valoresReferencia:"Negativo: sin ADN de VPH de alto riesgo detectado. Positivo para VPH 16/18: mayor riesgo, derivar a colposcop\xeda",cuidadosEnfermeria:["Mismas condiciones que para el PAP (sin menstruaci\xf3n, sin relaciones 48h previas)","La muestra puede obtenerse con cepillo endocervical o autodeterminaci\xf3n vaginal seg\xfan protocolo","Explicar que un resultado positivo no significa c\xe1ncer sino mayor vigilancia necesaria","Registrar resultado en historial y programar seguimiento seg\xfan protocolo"]},{nombre:"RMN pelvica y TAC toracoabdominopelvico",descripcion:"Para estadificaci\xf3n locorregional (RMN) y sist\xe9mica (TAC). La RMN eval\xfaa invasi\xf3n parametrial, vaginal y ganglionar. El TAC detecta met\xe1stasis a distancia.",valoresReferencia:"Sin invasi\xf3n parametrial ni ganglionar en estadios resecables",cuidadosEnfermeria:["Verificar funci\xf3n renal antes de contraste yodado (creatinina, TFG)","Preguntar alergias a contraste y metformina (suspender 48h antes)","RMN: retirar elementos met\xe1licos, verificar marcapasos u implantes met\xe1licos contraindicados","Informar sobre ruido del equipo de RMN y necesidad de permanecer inm\xf3vil"]}]},tratamientoMedico:{objetivos:["Curar la enfermedad en estadios tempranos (I-IIA)","Control locorregional y paliaci\xf3n en estadios avanzados","Preservar la funci\xf3n sexual y reproductiva cuando sea posible","Prevenir y tratar complicaciones del tratamiento","Seguimiento a largo plazo para detecci\xf3n de recidiva"],farmacologico:[{nombre:"Cisplatino",grupo:"Agente alquilante (platino) - quimioterapia radiosensibilizante",mecanismo:"Forma enlaces covalentes con el ADN celular (crosslinks intra e intercatenarios), inhibiendo la replicaci\xf3n y transcripci\xf3n del ADN. En c\xe1ncer de c\xe9rvix se usa como radiosensibilizador: aumenta eficacia de la radioterapia al inhibir reparaci\xf3n del ADN irradiado.",dosis:"40 mg/m2 IV semanal durante la radioterapia (concurrent chemoradiation). M\xe1ximo 6 ciclos.",cuidadosEnfermeria:["Hiperhidrataci\xf3n obligatoria: 1-2 L de SF antes y 1-2 L despu\xe9s para prevenir nefrotoxicidad","Monitorizar funci\xf3n renal (creatinina, BUN) antes de cada ciclo","Premedicas con antiem\xe9ticos potentes: ondansetr\xf3n + dexametasona 30 min antes","Vigilar ototoxicidad: preguntar por ac\xfafenos y cambios en la audici\xf3n","Monitorizar hemograma: neutropenia en nadir (d\xedas 10-14)"]},{nombre:"Bevacizumab",grupo:"Anticuerpo monoclonal anti-VEGF (terapia diana)",mecanismo:"Inhibe el factor de crecimiento endotelial vascular (VEGF-A), bloqueando la neoangiog\xe9nesis tumoral. En combinaci\xf3n con quimioterapia mejora supervivencia en estadios IVB o recidivante.",dosis:"15 mg/kg IV cada 3 semanas en combinaci\xf3n con paclitaxel + cisplatino o paclitaxel + topotec\xe1n",cuidadosEnfermeria:["Monitorizar presi\xf3n arterial antes y durante cada infusi\xf3n (hipertensi\xf3n es efecto adverso frecuente)","Vigilar signos de f\xedstula vesicovaginal o rectovaginal (complicaci\xf3n espec\xedfica en c\xe9rvix)","Evaluar cicatrizaci\xf3n de heridas: suspender 28 d\xedas antes y despu\xe9s de cualquier cirug\xeda","Observar signos de tromboembolismo venoso: dolor e hinchaz\xf3n en miembros inferiores","Primera infusi\xf3n en 90 minutos; si bien tolerada, reducir a 60 min ciclos siguientes"]},{nombre:"Pembrolizumab",grupo:"Inhibidor de checkpoint inmunol\xf3gico (anti-PD-1)",mecanismo:"Anticuerpo monoclonal que bloquea el receptor PD-1 en linfocitos T, impidiendo su inhibici\xf3n por el tumor. Restaura la respuesta inmune anti-tumoral. Aprobado en c\xe1ncer de c\xe9rvix PD-L1 positivo recurrente/metast\xe1sico.",dosis:"200 mg IV cada 3 semanas o 400 mg cada 6 semanas",cuidadosEnfermeria:["Vigilar efectos adversos inmunomediados: colitis (diarrea), neumonitis (disnea), hepatitis, endocrinopat\xedas","Monitorizar funci\xf3n tiroidea, hep\xe1tica y suprarrenal peri\xf3dicamente","Educar sobre distinci\xf3n de efectos adversos inmunomediados vs infecciosos","Administrar en 30 minutos; no requiere premedicaci\xf3n rutinaria","Documentar fecha, n\xfamero de ciclo y dosis administrada exacta"]}],noFarmacologico:["Cirug\xeda: histerectom\xeda radical (Wertheim-Meigs) + linfadenectom\xeda p\xe9lvica en estadios IA2-IIA","Radioterapia externa (EBRT) p\xe9lvica: 45-50 Gy en 25-28 fracciones","Braquiterapia intracavitaria: refuerzo de dosis en el cuello uterino","Quimiorradioterapia concurrente con cisplatino: est\xe1ndar en estadios IB2-IVA","Conizaci\xf3n cervical (LEEP o cono fr\xedo): en estadio IA1 en mujeres que desean preservar fertilidad","Soporte nutricional durante quimiorradioterapia","Rehabilitaci\xf3n sexual y manejo de secuelas p\xe9lvicas"]},cuidadosEnfermeria:{valoracion:["Evaluar s\xedntomas: sangrado vaginal (cantidad, caracter\xedsticas), dolor p\xe9lvico, flujo anormal","Valorar estado nutricional (peso, IMC, albumina) en pacientes en tratamiento","Evaluar mucositis oral y vaginal durante quimiorradioterapia","Monitorizar funci\xf3n intestinal y vesical (proctitis, cistitis por radioterapia)","Valorar estado emocional, mecanismos de afrontamiento y red de apoyo","Evaluar adherencia al tratamiento ambulatorio"],intervenciones:["Administrar quimioterapia seg\xfan protocolo oncol\xf3gico con t\xe9cnica as\xe9ptica estricta","Manejo de n\xe1useas: antiem\xe9ticos programados (no a demanda) durante ciclos de platino","Cuidados de piel irradiada: hidratar con cremas libres de fragancias, evitar exposici\xf3n solar","Educar sobre higiene vaginal y uso de dilatadores vaginales post-radioterapia para prevenir estenosis","Vigilar neutropenia post-quimioterapia: temperatura > 38\xb0C = neutropenia febril = urgencia oncol\xf3gica","Coordinar con equipo multidisciplinario: oncolog\xeda, radiooncolog\xeda, ginecolog\xeda, psicolog\xeda"],educacionPaciente:["Explicar la importancia de completar el esquema de tratamiento (radioterapia + quimioterapia)","Signos de alarma durante tratamiento: fiebre > 38\xb0C, sangrado abundante, dificultad respiratoria","Cuidados de la piel en campo irradiado: no friccionar, evitar sol, usar ropa suelta","Importancia del seguimiento post-tratamiento con PAP/colposcop\xeda cada 3-6 meses los primeros 2 a\xf1os","Vacunaci\xf3n VPH en familiares femeni\xf1os j\xf3venes para prevenci\xf3n primaria","Recursos de apoyo psicol\xf3gico y grupos de pacientes oncol\xf3gicas"],monitorizacion:["Hemograma semanal durante quimiorradioterapia (nadir leucocitario d\xedas 10-14)","Funci\xf3n renal antes de cada ciclo de cisplatino","Peso semanal y estado nutricional durante tratamiento","Temperatura diaria durante neutropenia","Respuesta al tratamiento con RMN a las 3 meses post-tratamiento","PAP y colposcop\xeda cada 3-6 meses los 2 primeros a\xf1os, luego anual"]},npiNanda:[{codigo:"00221",nombre:"Sangrado vaginal anormal",definicion:"P\xe9rdida de sangre por el tracto genital femenino que ocurre en cantidades o momentos inusuales",caracteristicasDefinitorias:["Sangrado postcoital recurrente","Flujo vaginal serosanguinolento","Manchado intermenstrual"],factoresRelacionados:["Neoplasia cervical con friabilidad tumoral","Neoangiog\xe9nesis tumoral con vasos fr\xe1giles","Ulceraci\xf3n o necrosis tumoral"]},{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable asociada a da\xf1o tisular real o potencial",caracteristicasDefinitorias:["Dolor p\xe9lvico cr\xf3nico","Dolor durante las relaciones sexuales (dispareunia)","Facies de dolor"],factoresRelacionados:["Invasi\xf3n tumoral de tejidos p\xe9lvicos","Inflamaci\xf3n asociada al tumor","Efectos adversos del tratamiento (proctitis, cistitis)"]},{codigo:"00148",nombre:"Temor",definicion:"Respuesta a la percepci\xf3n de una amenaza, reconocida conscientemente como un peligro",caracteristicasDefinitorias:["Verbalizaci\xf3n de miedo a la muerte","Ansiedad ante los procedimientos diagn\xf3sticos y terap\xe9uticos","Insomnio","Evitaci\xf3n de informaci\xf3n sobre el diagn\xf3stico"],factoresRelacionados:["Diagn\xf3stico oncol\xf3gico reciente","Incertidumbre sobre el pron\xf3stico","Impacto en funci\xf3n sexual y reproductiva"]}],npiNic:[{codigo:"2240",nombre:"Manejo de la quimioterapia",actividades:["Verificar protocolo, dosis y v\xeda de administraci\xf3n antes de cada ciclo","Administrar premedicaci\xf3n antiem\xe9tica seg\xfan protocolo","Preparar y administrar quimioter\xe1picos con equipo de protecci\xf3n personal","Monitorizar reacciones adversas durante la infusi\xf3n","Documentar dosis administrada, tiempo de infusi\xf3n y tolerancia"]},{codigo:"6482",nombre:"Manejo ambiental: confort",actividades:["Asegurar ambiente tranquilo durante infusi\xf3n de quimioterapia","Gestionar visitas para minimizar interrupciones","Proporcionar materiales de entretenimiento durante la infusi\xf3n","Controlar temperatura ambiental para confort de la paciente"]},{codigo:"5250",nombre:"Apoyo en toma de decisiones",actividades:["Proporcionar informaci\xf3n veraz sobre opciones terap\xe9uticas y pron\xf3stico","Respetar la autonom\xeda y decisiones de la paciente sobre su tratamiento","Facilitar consultas con otros especialistas si la paciente lo solicita","Documentar consentimiento informado para cada procedimiento"]}],npiNoc:[{codigo:"1008",nombre:"Estado nutricional: ingesta alimentaria y de liquidos",indicadores:["Ingesta cal\xf3rica adecuada durante quimiorradioterapia","Peso estable o p\xe9rdida < 10% del peso basal","Albumina s\xe9rica > 3 g/dL","Sin signos de deshidrataci\xf3n"],escala:"1=No adecuado, 2=Levemente adecuado, 3=Moderadamente adecuado, 4=Sustancialmente adecuado, 5=Completamente adecuado"},{codigo:"1302",nombre:"Afrontamiento de problemas",indicadores:["Verbaliza comprensi\xf3n del diagn\xf3stico y plan terap\xe9utico","Utiliza estrategias de afrontamiento adaptativas","Mantiene roles y relaciones sociales durante el tratamiento","Accede a recursos de apoyo psicol\xf3gico disponibles"],escala:"1=Nunca demostrado, 2=Raramente demostrado, 3=A veces demostrado, 4=Frecuentemente demostrado, 5=Siempre demostrado"}],complicaciones:["F\xedstula vesicovaginal o rectovaginal (por tumor o radioterapia)","Estenosis vaginal post-radioterapia","Proctitis y cistitis r\xe1dica","Linfedema de miembros inferiores por linfadenectom\xeda + radioterapia","Neutropenia febril por quimioterapia","Nefrotoxicidad por cisplatino","Met\xe1stasis: pulm\xf3n, h\xedgado, huesos, ganglios paraa\xf3rticos","Obstrucci\xf3n ureteral bilateral con insuficiencia renal en estadios avanzados","Hemorragia tumoral masiva"],criteriosAlarma:["Sangrado vaginal activo abundante","Fiebre > 38\xb0C durante quimioterapia (neutropenia febril)","Dolor p\xe9lvico severo de nueva aparici\xf3n o que aumenta","Edema bilateral de miembros inferiores de inicio brusco","Hematuria, disuria o rectorragia (posible invasi\xf3n vesical/rectal)","Disnea o dolor tor\xe1cico (met\xe1stasis pulmonar o TEP)","Oligoanuria (obstrucci\xf3n ureteral bilateral)"],emergencyLevel:"moderado",relatedPathologyIds:["pat_placenta_previa","pat_mastitis"],isPremium:!0},{id:"pat_mastitis",nombre:"Mastitis Puerperal",bodySystemId:"reproductivo",definicion:"Proceso inflamatorio del tejido mamario que ocurre en el per\xedodo de lactancia, generalmente entre las 2 y 6 semanas postparto. Puede ser infecciosa (causada mayoritariamente por Staphylococcus aureus) o no infecciosa (por estasis de leche sin infecci\xf3n). Sin tratamiento oportuno puede evolucionar a absceso mamario.",epidemiologia:"Afecta al 10-33% de las mujeres lactantes. El 80-90% ocurre en las primeras 12 semanas postparto, con pico a las 2-3 semanas. Principal causa de destete precoz no deseado. Un 3-11% de los casos evoluciona a absceso mamario. S. aureus es el agente causal en el 50-80% de los casos, con creciente prevalencia de SARM comunitario.",factoresRiesgo:["T\xe9cnica de lactancia incorrecta (mal acople del lactante)","Pezones agrietados o lesionados (puerta de entrada bacteriana)","Estasis de leche (vaciado incompleto o irregular)","Uso de chupetes o biberones (interferencia con la succi\xf3n)","Ropa interior muy ajustada o presi\xf3n externa sobre mama","Destete abrupto","Mastitis previa","Estr\xe9s y fatiga materna","Anemia materna","Prim\xedpara (mayor dificultad t\xe9cnica en lactancia inicial)"],fisiopatologia:"La estasis de leche favorece la proliferaci\xf3n bacteriana en los conductos galact\xf3foros. Las bacterias ingresan habitualmente a trav\xe9s de fisuras en el pez\xf3n desde la flora cut\xe1nea materna o la orofaringe del lactante. S. aureus produce toxinas (leucocidinas, hemolisinas, toxina TSST-1) que desencadenan respuesta inflamatoria local: vasodilataci\xf3n, edema, infiltrado leucocitario y activaci\xf3n del complemento. La respuesta sist\xe9mica produce los s\xedntomas gripales. Sin tratamiento, la infecci\xf3n puede progresar a absceso con necrosis y licuefacci\xf3n del tejido mamario, requiriendo drenaje quir\xfargico.",signosYSintomas:{signos:["Zona mamaria eritematosa, caliente y edematosa bien delimitada (sector cuadrante)","Fiebre > 38.5\xb0C (generalmente de inicio brusco)","Taquicardia","Adenopat\xeda axilar ipsilateral sensible","Induraci\xf3n del tejido mamario afectado","Fluctuaci\xf3n palpable si hay absceso"],sintomas:["Dolor mamario intenso, localizado en un cuadrante (generalmente superior externo)","Sensaci\xf3n de tensi\xf3n y calor local","S\xedntomas gripales: escalofr\xedos, mialgias, cefalea, malestar general","Fatiga intensa desproporcionada","Enrojecimiento en franja o cu\xf1a sobre un cuadrante mamario"]},clasificacion:{nombre:"Clasificacion clinica de la mastitis",tipos:[{nombre:"Mastitis no infecciosa (estasis l\xe1ctea)",descripcion:"Inflamaci\xf3n por acumulaci\xf3n de leche sin infecci\xf3n bacteriana. Mama tensa, dolorosa y endurecida, sin fiebre o < 38\xb0C. Resoluci\xf3n con vaciado frecuente."},{nombre:"Mastitis infecciosa no complicada",descripcion:"Infecci\xf3n bacteriana del par\xe9nquima mamario. Fiebre > 38.5\xb0C, eritema localizado, dolor intenso. Responde a antibi\xf3ticos."},{nombre:"Absceso mamario",descripcion:"Colecci\xf3n purulenta encapsulada. Fluctuaci\xf3n palpable, fiebre persistente pese a antibi\xf3ticos. Requiere drenaje (quir\xfargico o ecoguiado)."},{nombre:"Mastitis granulomatosa",descripcion:"Forma rara, cr\xf3nica, no lactacional. Granulomas est\xe9riles. Diagn\xf3stico diferencial con carcinoma inflamatorio."}]},diagnostico:{anamnesis:["Semanas postparto y antecedentes de lactancia","T\xe9cnica y frecuencia de amamantamiento","Antecedentes de mastitis previa o absceso mamario","Tiempo de evoluci\xf3n del cuadro cl\xednico","Uso de antibi\xf3ticos previos","Patr\xf3n de fiebre y s\xedntomas sist\xe9micos"],examenFisico:["Inspecci\xf3n mamaria: eritema, edema, lesiones en pez\xf3n o areola","Palpaci\xf3n: induraci\xf3n, temperatura local, adenopat\xedas axilares","B\xfasqueda de fluctuaci\xf3n (absceso)","Evaluaci\xf3n de pez\xf3n: grietas, fisuras, candidiasis","Signos vitales con \xe9nfasis en temperatura y frecuencia cardiaca","Evaluaci\xf3n del lactante: acople, t\xe9cnica de succi\xf3n"],pruebas:[{nombre:"Hemograma con formula leucocitaria",descripcion:"Eval\xfaa respuesta inflamatoria sist\xe9mica. Leucocitosis con neutrofilia orienta a proceso infeccioso bacteriano. \xdatil para monitorizar respuesta al tratamiento.",valoresReferencia:"Leucocitos normales: 4.000-11.000/mm3. En mastitis: leucocitosis > 12.000 con > 80% neutr\xf3filos",cuidadosEnfermeria:["Extracci\xf3n por venopunci\xf3n perif\xe9rica, tubo con EDTA (tapa lila)","Transportar en fr\xedo si no se procesa en 2 horas","Reportar leucocitosis > 20.000 o neutropenia al m\xe9dico inmediatamente","No requiere ayuno"]},{nombre:"Cultivo de leche materna",descripcion:"Identifica el agente causal y su antibiograma. Especialmente \xfatil en mastitis grave, recurrente, sin respuesta a tratamiento emp\xedrico, o sospecha de SARM.",valoresReferencia:"Normal: < 1.000 UFC/mL. Infecci\xf3n: > 10.000 UFC/mL de un pat\xf3geno \xfanico (S. aureus, E. coli, S. epidermidis)",cuidadosEnfermeria:["Limpiar pez\xf3n y areola con agua y jab\xf3n antes de la extracci\xf3n","Desechar los primeros 5 mL de leche (contaminaci\xf3n del pez\xf3n)","Recoger en frasco est\xe9ril de boca ancha","Refrigerar a 4\xb0C si no se puede procesar en 2 horas","Enviar con datos de evoluci\xf3n y antibi\xf3ticos previos"]},{nombre:"Ecografia mamaria",descripcion:"Indicada cuando se sospecha absceso mamario (fluctuaci\xf3n, fiebre persistente > 48-72h con antibi\xf3ticos). Diferencia mastitis de absceso y permite guiar el drenaje percut\xe1neo.",valoresReferencia:"Mastitis: engrosamiento difuso del par\xe9nquima sin colecci\xf3n. Absceso: colecci\xf3n hipoecoica con refuerzo posterior",cuidadosEnfermeria:["No requiere preparaci\xf3n especial","Informar a la paciente sobre el procedimiento (no doloroso, sin radiaci\xf3n)","Si se indica drenaje ecoguiado: preparar campo est\xe9ril y material de drenaje","Registrar localizaci\xf3n y tama\xf1o de la colecci\xf3n en los registros de enfermer\xeda"]}]},tratamientoMedico:{objetivos:["Erradicar la infecci\xf3n bacteriana con antibioticoterapia eficaz","Mantener la lactancia materna siempre que sea posible","Prevenir la progresi\xf3n a absceso mamario","Aliviar el dolor y los s\xedntomas sist\xe9micos","Corregir la t\xe9cnica de lactancia para prevenir recurrencias"],farmacologico:[{nombre:"Cloxacilina",grupo:"Penicilina antiestafiloc\xf3cica (betalact\xe1mico resistente a penicilinasa)",mecanismo:"Inhibe la s\xedntesis de la pared celular bacteriana uni\xe9ndose a prote\xednas fijadoras de penicilina (PBPs). Resistente a la betalactamasa estafiloc\xf3cica. Primera l\xednea en mastitis por S. aureus sensible a meticilina (SASM).",dosis:"500 mg VO cada 6 horas x 10-14 d\xedas. En formas graves: 2 g IV cada 4-6 horas",cuidadosEnfermeria:["Administrar 30-60 minutos antes de las comidas (la absorci\xf3n disminuye con alimentos)","Verificar alergias a penicilinas antes de administrar","Instruir completar el ciclo completo aunque mejore la sintomatolog\xeda","Compatible con lactancia materna: no suspender amamantamiento","Vigilar erupciones cut\xe1neas y diarrea como efectos adversos frecuentes"]},{nombre:"Trimetoprima-Sulfametoxazol (TMP-SMX)",grupo:"Sulfonamida + inhibidor de dihidrofolato reductasa - antibi\xf3tico de segunda l\xednea",mecanismo:"Combinaci\xf3n sin\xe9rgica: sulfametoxazol inhibe la s\xedntesis de dihidropteroato y trimetoprima inhibe dihidrofolato reductasa bacteriana, bloqueando la s\xedntesis de folatos. Eficaz contra SARM comunitario.",dosis:"800/160 mg (forte) VO cada 12 horas x 5-10 d\xedas para SARM",cuidadosEnfermeria:["Administrar con abundante agua (m\xednimo 2 L/d\xeda) para prevenir cristaluria","Vigilar erupci\xf3n cut\xe1nea (puede progresar a s\xedndrome de Stevens-Johnson)","Contraindicado en embarazo (especialmente primer trimestre y cerca del parto)","Usar con precauci\xf3n en lactancia: monitorizar ictericia neonatal en prematuros","Verificar funci\xf3n renal: ajustar dosis en insuficiencia renal"]},{nombre:"Ibuprofeno",grupo:"AINE (antiinflamatorio no esteroideo)",mecanismo:"Inhibe las ciclooxigenasas COX-1 y COX-2, reduciendo la s\xedntesis de prostaglandinas, tromboxanos y prostaciclinas. Produce analgesia, antipir\xe9sis y acci\xf3n antiinflamatoria local.",dosis:"400-600 mg VO cada 6-8 horas con alimentos. M\xe1ximo 2.400 mg/d\xeda",cuidadosEnfermeria:["Administrar siempre con alimentos o leche para reducir irritaci\xf3n g\xe1strica","Compatible con lactancia materna (escasa transferencia a leche)","Vigilar s\xedntomas gastrointestinales: epigastralgia, n\xe1useas","Aplicar fr\xedo local en mama afectada entre tomas para potenciar analgesia y reducir inflamaci\xf3n","Evitar uso prolongado en pacientes con antecedentes de \xfalcera g\xe1strica"]}],noFarmacologico:["Continuar la lactancia materna en el pecho afectado (vaciado frecuente previene absceso)","Vaciado completo de la mama afectada al menos cada 2-3 horas","Aplicaci\xf3n de calor h\xfamedo 5-10 min antes de la toma para facilitar bajada de leche","Aplicaci\xf3n de fr\xedo entre tomas para reducir inflamaci\xf3n y dolor","Correcci\xf3n de la t\xe9cnica de amamantamiento con apoyo de consultora de lactancia","Reposo relativo y hidrataci\xf3n adecuada","Drenaje quir\xfargico o percut\xe1neo ecoguiado si se forma absceso"]},cuidadosEnfermeria:{valoracion:["Valorar caracter\xedsticas del \xe1rea afectada: extensi\xf3n del eritema, temperatura local, fluctuaci\xf3n","Registrar temperatura corporal y signos vitales cada 4-8 horas","Evaluar t\xe9cnica de lactancia: acople del lactante, vaciado completo, frecuencia","Inspeccionar pezones y areolas: grietas, fisuras, candidiasis","Evaluar dolor con escala EVA antes y despu\xe9s del tratamiento","Valorar estado emocional materno: ansiedad, culpabilidad, temor al abandono de lactancia"],intervenciones:["Fomentar la continuidad de la lactancia materna en el pecho afectado","Ense\xf1ar posiciones correctas de amamantamiento y t\xe9cnica de extracci\xf3n manual","Aplicar calor h\xfamedo previo a la toma y fr\xedo entre tomas seg\xfan tolerancia","Administrar antibi\xf3ticos y analg\xe9sicos seg\xfan prescripci\xf3n m\xe9dica","Masaje suave del \xe1rea indurada en direcci\xf3n al pez\xf3n durante la toma","Derivar a consultora de lactancia para correcci\xf3n de t\xe9cnica"],educacionPaciente:["Explicar que continuar amamantando es la mejor medida para prevenir absceso","Ense\xf1ar a vaciar completamente la mama afectada si el beb\xe9 no la vac\xeda","Instruir sobre higiene de pezones y t\xe9cnica de acople correcto","Importancia de completar el ciclo de antibi\xf3ticos aunque mejore en 24-48h","Signos de alarma para consultar urgente: fiebre que no cede, \xe1rea fluctuante, enrojecimiento que se expande","Prevenci\xf3n de recurrencias: correcta t\xe9cnica, evitar ropa compresiva, vaciado regular"],monitorizacion:["Temperatura cada 4-8 horas durante tratamiento","Evaluar respuesta a antibi\xf3ticos: mejor\xeda esperada en 24-48 horas","Control de hemograma a las 48-72h si no hay mejor\xeda cl\xednica","Ecograf\xeda mamaria si fiebre persiste > 48-72h con antibi\xf3ticos (descartar absceso)","Peso del lactante para verificar correcta alimentaci\xf3n durante el episodio"]},npiNanda:[{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable asociada a da\xf1o tisular real o potencial de inicio s\xfabito o lento",caracteristicasDefinitorias:["Expresi\xf3n verbal de dolor mamario intenso","Facies de dolor al palpar la mama afectada","Postura anti\xe1lgica durante la lactancia","Taquicardia asociada al dolor"],factoresRelacionados:["Inflamaci\xf3n del par\xe9nquima mamario por infecci\xf3n bacteriana","Distensi\xf3n de conductos galact\xf3foros por estasis l\xe1ctea","Lesiones en pez\xf3n que perpet\xfaan la inflamaci\xf3n"]},{codigo:"00105",nombre:"Interrupcion de la lactancia materna",definicion:"Interrupci\xf3n de la continuidad del proceso de amamantamiento debido a la incapacidad o el rechazo de proporcionar leche materna",caracteristicasDefinitorias:["Abandono de la lactancia por dolor","Vaciado incompleto de mama afectada","Verbalizaci\xf3n de deseo de mantener lactancia pero incapacidad de tolerar el dolor"],factoresRelacionados:["Dolor mamario intenso durante la toma","Desinformaci\xf3n sobre compatibilidad del tratamiento con lactancia","Fatiga y s\xedntomas gripales asociados"]},{codigo:"00004",nombre:"Riesgo de infeccion",definicion:"Vulnerable a ser invadido y multiplicado por organismos pat\xf3genos que puede comprometer la salud",caracteristicasDefinitorias:["Lesiones en pez\xf3n como puerta de entrada","Fiebre y leucocitosis presentes","Induraci\xf3n mamaria que puede progresar a absceso"],factoresRelacionados:["Pezones agrietados como puerta de entrada bacteriana","Estasis de leche como medio de cultivo","Inmunidad relativa del postparto"]}],npiNic:[{codigo:"1054",nombre:"Ayuda en la lactancia materna",actividades:["Evaluar la t\xe9cnica de amamantamiento en cada turno","Ense\xf1ar posiciones correctas: cuna, cuna cruzada, bal\xf3n de rugby, dec\xfabito lateral","Demostrar acople correcto: boca abierta, labios evertidos, ment\xf3n pegado a mama","Instruir sobre vaciado completo y frecuencia de tomas","Derivar a consultora de lactancia certificada"]},{codigo:"1400",nombre:"Manejo del dolor",actividades:["Evaluar dolor con escala EVA antes y 30 min despu\xe9s de analgesia","Administrar AINE seg\xfan prescripci\xf3n antes de las tomas","Aplicar calor h\xfamedo previo a la toma (facilita bajada de leche)","Aplicar fr\xedo local entre tomas para reducir inflamaci\xf3n","Ense\xf1ar masaje suave en direcci\xf3n al pez\xf3n durante la toma"]},{codigo:"6540",nombre:"Control de infecciones",actividades:["Administrar antibi\xf3ticos seg\xfan prescripci\xf3n y horarios exactos","Educar sobre higiene de manos antes de cada toma","Instruir sobre higiene mamaria con agua y jab\xf3n suave","Vigilar temperatura y signos de extensi\xf3n de la infecci\xf3n","Registrar respuesta al tratamiento antibi\xf3tico a las 48 horas"]}],npiNoc:[{codigo:"1211",nombre:"Nivel de ansiedad",indicadores:["Verbaliza comprensi\xf3n de su proceso y plan de cuidados","Expresa confianza en la posibilidad de continuar la lactancia","Frecuencia cardiaca dentro de la normalidad","Sin expresi\xf3n facial de angustia"],escala:"1=Grave, 2=Sustancial, 3=Moderada, 4=Leve, 5=Ninguna"},{codigo:"1000",nombre:"Establecimiento de la lactancia materna: madre",indicadores:["T\xe9cnica de acople correcta demostrada","Vaciado completo de la mama afectada en cada toma","Producci\xf3n de leche mantenida","Lactante con ganancia de peso adecuada"],escala:"1=No adecuado, 2=Levemente adecuado, 3=Moderadamente adecuado, 4=Sustancialmente adecuado, 5=Completamente adecuado"}],complicaciones:["Absceso mamario (3-11% de los casos no tratados correctamente)","F\xedstula mamaria post-absceso drenado","Mastitis cr\xf3nica recurrente","Sepsis por S. aureus (rara pero grave, especialmente por SARM)","Destete precoz no deseado","Candidiasis mamaria secundaria al tratamiento antibi\xf3tico","Cicatriz y retracci\xf3n mamaria post-absceso"],criteriosAlarma:["Fiebre > 39\xb0C que no cede con antit\xe9rmicos","\xc1rea de fluctuaci\xf3n palpable (absceso)","Fiebre persistente > 48-72h con antibi\xf3ticos correctos","Extensi\xf3n del eritema pese al tratamiento","Aparici\xf3n de pus en la leche materna","Deterioro del estado general materno","Eritema que se extiende como estr\xeda hacia axila (linfangitis)"],emergencyLevel:"leve",relatedPathologyIds:["pat_cancer_cervix","pat_placenta_previa"],isPremium:!0},{id:"pat_dpp",nombre:"Desprendimiento Prematuro de Placenta",bodySystemId:"reproductivo",definicion:"Separaci\xf3n parcial o total de la placenta normalmente insertada de su lecho uterino antes del nacimiento del feto, ocurriendo despu\xe9s de las 20 semanas de gestaci\xf3n. Tambi\xe9n conocido como Abruptio Placentae o Hematoma retroplacentario. Constituye una emergencia obst\xe9trica con alta morbimortalidad materno-fetal.",epidemiologia:"Incidencia del 0.5-1% de todos los embarazos. Responsable del 15-25% de las muertes perinatales en pa\xedses en desarrollo. Mortalidad materna < 1% en pa\xedses con atenci\xf3n obst\xe9trica adecuada, pero mortalidad perinatal del 15-20% seg\xfan extensi\xf3n del desprendimiento. Riesgo de recurrencia del 6-16% en embarazos posteriores.",factoresRiesgo:["Hipertensi\xf3n arterial cr\xf3nica o preeclampsia (causa m\xe1s frecuente, 44%)","Tabaquismo activo (riesgo x2-3)","Trauma abdominal (accidente de tr\xe1fico, violencia dom\xe9stica)","Consumo de coca\xedna (vasoespasmo intenso)","Rotura prematura de membranas","Polihidramnios con descompresi\xf3n brusca","Multiparidad (> 5 partos)","Antecedente de desprendimiento previo (riesgo x10)","Trombofilia materna (s\xedndrome antifosfolip\xeddico)","Deficiencia de \xe1cido f\xf3lico","Embarazo m\xfaltiple"],fisiopatologia:"El DPP se origina por sangrado en la decidua basal, que forma un hematoma retroplacentario que separa la placenta de la pared uterina. La causa inicial es la ruptura de arteriolas espirales deciduales, generalmente por vasculopat\xeda (hipertensi\xf3n, tabaquismo). El hematoma retroplacentario crece y puede comprimir y destruir el tejido placentario, comprometiendo el intercambio gaseoso fetal. La sangre puede disecarse hacia la cavidad amni\xf3tica (hematoma amni\xf3tico) o exteriorizarse por el cuello uterino. El \xfatero de Couvelaire ocurre cuando la sangre infiltra el miometrio, produciendo hiperton\xeda e hipomotilidad irreversibles. La liberaci\xf3n masiva de tromboplastina tisular placentaria puede desencadenar CID.",signosYSintomas:{signos:["Hiperton\xeda uterina permanente (\xfatero duro como tabla, signo cardinal)","Sangrado vaginal oscuro, no puls\xe1til (puede ser escaso aunque hemorragia interna sea masiva)","Hipotensi\xf3n y taquicardia materna desproporcionada al sangrado visible","Alteraciones en CTG: desaceleraciones tard\xedas, bradicardia fetal, taquicardia fetal compensatoria","\xdatero de Couvelaire: \xfatero viol\xe1ceo, infiltrado de sangre, hipert\xf3nico","Signos de CID: petequias, equimosis, sangrado en sitios de venopunci\xf3n"],sintomas:["Dolor abdominal de inicio brusco, intenso y constante (sin per\xedodos de alivio)","Dolor lumbar o en flanco en placentas de inserci\xf3n posterior","Sangrado vaginal oscuro (puede estar ausente en formas ocultas)","Disminuci\xf3n brusca o ausencia de movimientos fetales","N\xe1useas y v\xf3mitos asociados al dolor","Sensaci\xf3n de muerte inminente en formas graves con shock"]},clasificacion:{nombre:"Clasificacion de Page (grados de severidad)",tipos:[{nombre:"Grado 0 (asintom\xe1tico)",descripcion:"Sin s\xedntomas cl\xednicos. Diagn\xf3stico retrospectivo por hematoma retroplacentario en placenta tras el parto."},{nombre:"Grado I (leve)",descripcion:"Sangrado vaginal leve, sin hiperton\xeda significativa, madre hemodin\xe1micamente estable, feto vivo sin sufrimiento. Representa el 40% de los casos."},{nombre:"Grado II (moderado)",descripcion:"Sangrado moderado, hiperton\xeda uterina presente, signos de compromiso fetal (alteraciones en CTG), madre con taquicardia pero sin hipotensi\xf3n. 45% de los casos."},{nombre:"Grado III (grave)",descripcion:"Sangrado abundante (puede ser oculto), hiperton\xeda intensa, muerte fetal, CID en 30% de los casos, shock materno. 15% de los casos. Mortalidad materna hasta 1%."}]},diagnostico:{anamnesis:["Antecedente de HTA, preeclampsia, tabaquismo o DPP previo","Trauma abdominal reciente","Caracter\xedsticas del dolor: inicio brusco, constante, sin alivio (diferencia de contracciones)","Caracter\xedsticas del sangrado: oscuro, inicio brusco","Cambios en movimientos fetales","Edad gestacional y datos del control prenatal","Consumo de coca\xedna u otras drogas vasoactivas"],examenFisico:["Signos vitales: hipotensi\xf3n, taquicardia (desproporcionadas al sangrado visible)","Palpaci\xf3n uterina: hiperton\xeda, rigidez, dolorimiento exquisito a la palpaci\xf3n","Altura uterina: puede ser mayor de la esperada por hematoma oculto","Auscultaci\xf3n de latidos cardiacos fetales (pueden estar ausentes en grado III)","Evaluaci\xf3n del sangrado vaginal: cantidad, color (oscuro = retroplacentario)","Signos de CID: petequias, sangrado en sitios de punci\xf3n"],pruebas:[{nombre:"Monitorizaci\xf3n cardiotocogr\xe1fica (CTG) urgente",descripcion:"Evaluaci\xf3n inmediata del bienestar fetal. Patr\xf3n no tranquilizador (desaceleraciones tard\xedas, bradicardia persistente, p\xe9rdida de variabilidad) indica sufrimiento fetal agudo que puede requerir ces\xe1rea de urgencia inmediata.",valoresReferencia:"Patr\xf3n reactivo: FCF 110-160 lpm, variabilidad 5-25 lpm, aceleraciones presentes, sin desaceleraciones tard\xedas",cuidadosEnfermeria:["Aplicar CTG INMEDIATAMENTE al ingreso (prioridad m\xe1xima en DPP sospechado)","Colocar a la paciente en dec\xfabito lateral izquierdo para optimizar perfusi\xf3n uteroplacentaria","Informar al m\xe9dico inmediatamente ante cualquier alteraci\xf3n del patr\xf3n fetal","Mantener CTG continua hasta decisi\xf3n obst\xe9trica","Preparar quir\xf3fano ante patr\xf3n de sufrimiento fetal agudo"]},{nombre:"Ecografia obstetrica urgente",descripcion:"Confirma diagn\xf3stico: hematoma retroplacentario (imagen hiperecoica entre placenta y pared uterina), localizaci\xf3n placentaria, biometr\xeda fetal, l\xedquido amni\xf3tico. OJO: ecograf\xeda NORMAL no descarta DPP (30-50% de falsos negativos).",valoresReferencia:"Sin imagen de hematoma retroplacentario en ecograf\xeda normal (no descarta DPP cl\xednico)",cuidadosEnfermeria:["Ecograf\xeda es un complemento diagn\xf3stico, NO reemplaza la cl\xednica","Si la cl\xednica es de DPP grave, preparar para ces\xe1rea AUNQUE la ecograf\xeda sea normal","Registrar localizaci\xf3n placentaria y presencia de hematoma","Preparar sonda de ecograf\xeda y gel est\xe9ril para procedimiento urgente"]},{nombre:"Coagulograma urgente (TP, KPTT, fibrinogeno, PDF)",descripcion:"Detecta y monitoriza CID, complicaci\xf3n grave del DPP severo. Fibrin\xf3geno < 200 mg/dL indica CID instaurada. Productos de degradaci\xf3n del fibrin\xf3geno (PDF) elevados confirman fibrin\xf3lisis.",valoresReferencia:"Fibrin\xf3geno normal embarazo: 350-650 mg/dL. CID: fibrin\xf3geno < 150-200 mg/dL, PDF elevados, plaquetas < 100.000",cuidadosEnfermeria:["Extracci\xf3n urgente con tubo citratado (tapa celeste) para coagulograma","Repetir cada 1-2 horas en DPP grave o sospecha de CID","Comunicar INMEDIATAMENTE: fibrin\xf3geno < 200, plaquetas < 50.000, KPTT > 2x normal","Preparar hemoderivados: PFC, crioprecipitados, concentrado de plaquetas seg\xfan resultados","Registrar todos los valores con hora exacta para seguimiento de tendencia"]},{nombre:"Hemograma urgente y grupo sangu\xedneo",descripcion:"Eval\xfaa anemia (considerar hemorragia oculta retroplacentaria), trombocitopenia en CID. Tipificaci\xf3n para transfusi\xf3n urgente.",valoresReferencia:"Hb normal embarazo: > 11 g/dL; Hto > 33%; Plaquetas > 150.000/mm3",cuidadosEnfermeria:["Extracci\xf3n simult\xe1nea con canalizaci\xf3n de v\xeda venosa","Solicitar tipificaci\xf3n y pruebas cruzadas urgentes","Reservar 4-6 unidades de GR en DPP grave","Administrar anti-D si madre Rh negativo"]}]},tratamientoMedico:{objetivos:["Preservar la vida materna como prioridad absoluta","Lograr el nacimiento del feto en las mejores condiciones posibles","Prevenir y tratar la CID","Corregir el shock hipovol\xe9mico","Determinar la urgencia y v\xeda del parto seg\xfan estado materno-fetal"],farmacologico:[{nombre:"Plasma Fresco Congelado (PFC)",grupo:"Hemoderivado - repuesto de factores de coagulaci\xf3n",mecanismo:"Contiene todos los factores de coagulaci\xf3n en concentraciones fisiol\xf3gicas. Corrige la coagulopat\xeda de consumo de la CID reponiando los factores deficitarios, en especial fibrin\xf3geno y factores V y VIII.",dosis:"10-15 mL/kg IV. Dosis habitual: 4-6 unidades (cada unidad ~200-250 mL). Repetir seg\xfan coagulograma.",cuidadosEnfermeria:["Verificar compatibilidad ABO antes de administrar (no se requiere Rh)","Descongelar en ba\xf1o de agua a 37\xb0C m\xe1ximo 30 minutos antes de usar","Administrar en las primeras 2-6 horas post-descongelaci\xf3n","Infundir a trav\xe9s de filtro de transfusi\xf3n (170-260 micras)","Monitorizar reacciones transfusionales: urticaria, escalofr\xedos, hipotensi\xf3n, fiebre"]},{nombre:"Sulfato de Magnesio",grupo:"Neuroprotector fetal / Anticonvulsivante",mecanismo:"En gestaciones < 32 semanas act\xfaa como neuroprotector fetal reduciendo el riesgo de par\xe1lisis cerebral. Adem\xe1s antagoniza el calcio intracelular reduciendo la excitabilidad neuronal (prevenci\xf3n de eclampsia en DPP asociado a preeclampsia).",dosis:"Neuroprotecci\xf3n: 4 g IV en 20 min + 1 g/h hasta el parto. Preeclampsia severa: 4-6 g IV en 15-20 min + 1-2 g/h",cuidadosEnfermeria:["Control estricto de ROT cada hora: p\xe9rdida = toxicidad inminente","Diuresis m\xednima 30 mL/h: oliguria aumenta toxicidad","Tener gluconato de calcio 10% (1 g IV en 3 min) como ant\xeddoto disponible en la cabecera","No administrar si FR < 12/min o ROT ausentes","Nivel terap\xe9utico: 4-7 mEq/L; toxicidad: > 9 mEq/L"]},{nombre:"Oxitocina",grupo:"Uterot\xf3nico - hormona sint\xe9tica",mecanismo:"An\xe1logo sint\xe9tico de la hormona hipofisaria que estimula las contracciones uterinas actuando sobre receptores de membrana en el miometrio. Fundamental para alumbramiento activo y prevenci\xf3n de hemorragia postparto (principal complicaci\xf3n post-DPP).",dosis:"Alumbramiento activo: 10 UI IM o IV lento al expulsivo. HPP: 20-40 UI en 1L SF a 100-250 mL/h IV",cuidadosEnfermeria:["Administrar IV diluida SIEMPRE (nunca en bolo IV directo: hipotensi\xf3n severa)","Monitorizar tono uterino post-parto: \xfatero debe estar duro y contra\xeddo","Vigilar signos de intoxicaci\xf3n h\xeddrica con dosis altas: hiponatremia, convulsiones","Registrar cantidad de sangrado postparto (normal < 500 mL vaginal, < 1000 mL ces\xe1rea)","Ante \xfatero blando post-alumbramiento: masaje uterino + aumentar velocidad de infusi\xf3n"]}],noFarmacologico:["2 v\xedas venosas perif\xe9ricas de grueso calibre (14-16G) inmediatamente + sonda vesical","Reposici\xf3n agresiva de volumen: cristaloides 1-2 L en 15-30 min ante shock","Transfusi\xf3n de gl\xf3bulos rojos si Hb < 8 g/dL o inestabilidad hemodin\xe1mica","Transfusi\xf3n masiva si CID: PFC 1:1:1 con GR y plaquetas","Ces\xe1rea de urgencia (CODE ROJO): sufrimiento fetal agudo, DPP grado III, inestabilidad materna","Parto vaginal: si DPP leve, feto muerto, parto inminente y madre estable","Monitorizaci\xf3n invasiva: PVC y/o cat\xe9ter arterial en DPP grave con shock"]},cuidadosEnfermeria:{valoracion:["Monitorizar signos vitales cada 5-15 minutos en fase aguda","Evaluar tono uterino: hiperton\xeda persistente es signo de alarma cr\xedtico","Cuantificar sangrado vaginal: recordar que puede ser masivamente mayor el oculto","Aplicar CTG y evaluar bienestar fetal continuamente","Evaluar signos de CID: equimosis espont\xe1neas, sangrado en sitios de punci\xf3n","Medir diuresis horaria: oliguria indica shock o toxicidad por MgSO4"],intervenciones:["Activar c\xf3digo rojo obst\xe9trico inmediatamente ante DPP grave","Canalizar 2 v\xedas venosas perif\xe9ricas calibre 14-16G y colocar sonda vesical Foley","Administrar oxigenoterapia a alto flujo (10-15 L/min) con mascarilla con reservorio","Colocar en dec\xfabito lateral izquierdo para optimizar retorno venoso","Preparar quir\xf3fano para ces\xe1rea de urgencia con equipo neonatal completo","Mantener comunicaci\xf3n permanente con m\xe9dico de guardia reportando cambios hemodin\xe1micos o en CTG","Preparar hemoderivados: GR, PFC, crioprecipitados, plaquetas"],educacionPaciente:["Una vez estabilizada, explicar en qu\xe9 consisti\xf3 el episodio y por qu\xe9 se actu\xf3 con urgencia","Informar sobre el mayor riesgo de recurrencia en pr\xf3ximos embarazos (6-16%)","Si hay factor predisponente (HTA, tabaquismo): orientar sobre su control/abandono","Explicar importancia del control prenatal precoz en pr\xf3ximo embarazo","Signos de alarma en pr\xf3ximos embarazos: dolor abdominal brusco + sangrado oscuro"],monitorizacion:["Signos vitales cada 5-15 minutos en fase aguda, cada 30 min una vez estabilizada","CTG continua hasta decisi\xf3n del parto o estabilizaci\xf3n completa","Diuresis horaria (normal > 30 mL/h)","Coagulograma cada 1-2 horas en DPP grave o CID","Hemograma de control cada 4-6 horas","Signos uterinos postparto: tono, sangrado, altura uterina"]},npiNanda:[{codigo:"00206",nombre:"Riesgo de hemorragia",definicion:"Vulnerable a una disminuci\xf3n del volumen de sangre que puede comprometer la salud",caracteristicasDefinitorias:["Sangrado vaginal oscuro con hiperton\xeda uterina","Hipotensi\xf3n desproporcionada al sangrado visible","Coagulograma alterado (fibrin\xf3geno descendido)"],factoresRelacionados:["Separaci\xf3n placentaria con hematoma retroplacentario","Coagulaci\xf3n intravascular diseminada","Hemorragia oculta retroplacentaria no cuantificable"]},{codigo:"00029",nombre:"Disminucion del gasto cardiaco",definicion:"Cantidad de sangre bombeada por el coraz\xf3n en 1 minuto insuficiente para satisfacer las demandas metab\xf3licas del organismo",caracteristicasDefinitorias:["Hipotensi\xf3n arterial","Taquicardia compensatoria","Palidez cut\xe1nea y diaforesis","Oliguria"],factoresRelacionados:["Hipovolemia por hemorragia masiva retroplacentaria","Shock hemorr\xe1gico","Redistribuci\xf3n del volumen circulante"]},{codigo:"00032",nombre:"Patron respiratorio ineficaz fetal",definicion:"Intercambio gaseoso fetal comprometido por alteraci\xf3n de la perfusi\xf3n uteroplacentaria",caracteristicasDefinitorias:["Desaceleraciones tard\xedas en CTG","Bradicardia fetal sostenida","Ausencia de variabilidad en CTG","Disminuci\xf3n o ausencia de movimientos fetales"],factoresRelacionados:["Reducci\xf3n del \xe1rea placentaria funcional por hematoma","Hipoperfusi\xf3n uteroplacentaria por shock materno","Hiperton\xeda uterina que reduce flujo intervelloso"]}],npiNic:[{codigo:"4160",nombre:"Control de hemorragias",actividades:["Activar c\xf3digo rojo obst\xe9trico y convocar equipo multidisciplinario","Canalizar accesos venosos de gran calibre y reponer volumen agresivamente","Coordinar transfusi\xf3n masiva seg\xfan protocolo (GR:PFC:PLT 1:1:1)","Monitorizar signos vitales y estado de consciencia continuamente","Preparar quir\xf3fano para ces\xe1rea de urgencia ante deterioro"]},{codigo:"6772",nombre:"Vigilancia: seguridad del feto en el anteparto",actividades:["Mantener CTG continua y evaluar patr\xf3n cardiaco fetal cada 15 minutos","Colocar a la madre en dec\xfabito lateral izquierdo para maximizar flujo uteroplacentario","Administrar oxigenoterapia materna a alto flujo","Notificar inmediatamente cualquier patr\xf3n no tranquilizador al equipo obst\xe9trico","Preparar equipo de reanimaci\xf3n neonatal avanzada"]},{codigo:"4180",nombre:"Manejo de la hipovolemia",actividades:["Administrar cristaloides a 500-1000 mL en bolo IV inicial ante hipotensi\xf3n","Iniciar transfusi\xf3n de hemoderivados si Hb < 8 g/dL o shock refractario a cristaloides","Mantener PAS > 90 mmHg y diuresis > 30 mL/h como objetivos m\xednimos de reanimaci\xf3n","Monitorizar balance h\xeddrico estricto (ingresos y egresos)","Registrar respuesta hemodin\xe1mica a cada bolo de fluidos"]}],npiNoc:[{codigo:"0413",nombre:"Severidad de la perdida de sangre",indicadores:["Presi\xf3n arterial sist\xf3lica > 90 mmHg","Frecuencia cardiaca < 100 lpm","Hemoglobina > 8 g/dL","Fibrin\xf3geno > 200 mg/dL","Diuresis > 30 mL/h"],escala:"1=Grave, 2=Sustancial, 3=Moderada, 4=Leve, 5=Ninguna"},{codigo:"0401",nombre:"Estado circulatorio",indicadores:["Presi\xf3n arterial estable dentro de rangos normales","Perfusi\xf3n perif\xe9rica adecuada (relleno capilar < 2 seg)","Nivel de consciencia conservado","Diuresis adecuada sin oliguria"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Shock hipovol\xe9mico materno","Coagulaci\xf3n intravascular diseminada (CID) - 10-20% casos graves","Insuficiencia renal aguda por necrosis tubular isqu\xe9mica","\xdatero de Couvelaire con necesidad de histerectom\xeda","Muerte fetal intrauterina (50% en DPP grado III)","S\xedndrome de dificultad respiratoria neonatal por prematuridad","Necrosis cortical renal bilateral (rara pero irreversible)","Muerte materna (< 1% en pa\xedses desarrollados)"],criteriosAlarma:["Dolor abdominal intenso de inicio brusco con \xfatero r\xedgido","Sangrado vaginal oscuro con hiperton\xeda uterina","Hipotensi\xf3n (PAS < 90 mmHg) desproporcionada al sangrado visible","Bradicardia fetal sostenida < 100 lpm o ausencia de LCF","Sangrado en sitios de venopunci\xf3n (signo de CID)","Oligoanuria (diuresis < 30 mL/h)","Alteraci\xf3n del nivel de consciencia","Signos de peritonismo: abdomen en tabla, rebote"],emergencyLevel:"critico",relatedPathologyIds:["pat_placenta_previa","pat_embarazo_ectopico"],isPremium:!0},{id:"pat_melanoma",nombre:"Melanoma",bodySystemId:"tegumentario",definicion:"Neoplasia maligna originada en los melanocitos, celulas productoras de melanina localizadas principalmente en la capa basal de la epidermis. Es el cancer de piel mas agresivo y representa la principal causa de muerte por cancer cutaneo, con alta capacidad de metastasis linfatica y hematogena.",epidemiologia:"Incidencia en aumento global: 20-30 casos por 100.000 habitantes/ano en paises de alta exposicion solar. En Argentina representa el 3% de todos los canceres. Mayor incidencia en fototipos claros (I y II). Pico de incidencia entre 45-65 a\xf1os, aunque puede afectar jovenes. Mortalidad del 15-20% a 5 a\xf1os en estadios avanzados.",factoresRiesgo:["Exposicion solar acumulada y quemaduras solares en la infancia","Fototipo cutaneo I y II (piel clara, ojos azules o verdes, cabello rubio o rojo)","Antecedentes familiares de melanoma","Nevos melanociticos multiples (>50) o nevos atipicos (displasicos)","Inmunosupresion (trasplantados, VIH)","Mutacion BRAF V600E (presente en ~50% de los melanomas)","Xeroderma pigmentoso y otras genodermatosis","Uso de lampara UV o solarium","Antecedentes personales de melanoma u otro cancer de piel"],fisiopatologia:"El melanoma surge de la transformacion maligna de los melanocitos por acumulacion de mutaciones genomicas, principalmente en el gen BRAF (V600E en ~50%), NRAS (~20%) y NF1 (~15%). La mutacion BRAF V600E activa constitutivamente la via MAPK/ERK, promoviendo proliferacion celular descontrolada, resistencia a la apoptosis e invasion tisular. La progresion sigue fases: radial (horizontal, buen pronostico) y vertical (invasion dermica, mayor riesgo metastasico). La capacidad de metastasis se ve favorecida por la perdida de adhesion celular via downregulation de E-cadherina y activacion de metaloproteinas de la matriz.",signosYSintomas:{signos:["Lesion pigmentada que cumple criterios ABCDE: Asimetria, Bordes irregulares, Color heterogeneo (marron, negro, rosado, azulado), Diametro >6 mm, Evolucion rapida","Ulceracion o sangrado espontaneo de lesion preexistente","Satelitosis cutanea perilesional","Adenopatias regionales palpables en estadios avanzados","Lesion amelanotica (rosada o carne) en variante amelanotica"],sintomas:["Prurito persistente en lesion pigmentada","Cambio de forma, color o tamano de nevo preexistente","Sensation de ardor o sensibilidad local","Generalmente asintomatico en fases iniciales","Sintomas sistemicos (perdida de peso, astenia) en estadios metastasicos"]},clasificacion:{nombre:"Clasificacion AJCC 8a edicion / Breslow",tipos:[{nombre:"Estadio I (T1-T2, N0, M0)",descripcion:"Melanoma localizado, Breslow <= 2 mm sin ulceracion, sin metastasis ganglionar ni a distancia. Supervivencia a 5 a\xf1os >95%."},{nombre:"Estadio II (T3-T4, N0, M0)",descripcion:"Melanoma localizado con Breslow >2 mm o con ulceracion. Supervivencia a 5 a\xf1os 60-80%."},{nombre:"Estadio III (cualquier T, N+, M0)",descripcion:"Metastasis en ganglios linfaticos regionales o satelitosis. Supervivencia a 5 a\xf1os 40-60%."},{nombre:"Estadio IV (cualquier T, cualquier N, M1)",descripcion:"Metastasis a distancia (pulmon, higado, cerebro, hueso). Supervivencia a 5 a\xf1os <20%."}]},diagnostico:{anamnesis:["Tiempo de evolucion y cambios recientes en la lesion (ABCDE)","Antecedentes familiares de melanoma o cancer de piel","Exposicion solar acumulada, uso de solarium","Antecedentes de quemaduras solares en la infancia","Medicacion inmunosupresora actual","Revision de nevos en todo el tegumento (dermoscopia)"],examenFisico:["Dermoscopia de la lesion sospechosa (patron vascular, reticular, globular)","Mapeo corporal total de lesiones pigmentadas","Palpacion de cadenas ganglionares regionales","Evaluacion de satelitosis y lesiones en transito","Auscultacion pulmonar y palpacion hepatica en sospecha de metastasis"],pruebas:[{nombre:"Biopsia excisional con margen de 1-2 mm",descripcion:"Extirpacion completa de la lesion para estudio histopatologico. Es el gold standard diagnostico. Determina grosor de Breslow, nivel de Clark, ulceracion e indice mitotico.",valoresReferencia:"Breslow <=1 mm: bajo riesgo; 1.01-2 mm: riesgo intermedio; >2 mm: alto riesgo",cuidadosEnfermeria:["Preparar campo esteril y material de biopsia","Informar al paciente sobre el procedimiento y cuidados post-biopsia","Rotular correctamente la muestra con datos del paciente y localizacion","Indicar cuidados de herida quirurgica y signos de alarma"]},{nombre:"Biopsia de ganglio centinela (BGC)",descripcion:"Identificacion y biopsia del primer ganglio de drenaje linfatico regional. Indicada en Breslow >0.8 mm. Define estadificacion N y orienta linfadenectomia.",valoresReferencia:"Negativo (sin celulas tumorales): mejor pronostico. Positivo: estadio III, indicacion de tratamiento adyuvante.",cuidadosEnfermeria:["Preparar al paciente para procedimiento combinado quirurgico-nuclear","Coordinar con medicina nuclear para inyeccion de trazador radioactivo","Vigilar signos de linfedema postoperatorio","Educar sobre cuidados del miembro afectado"]},{nombre:"Estudio molecular BRAF/NRAS/NF1",descripcion:"Determinacion de mutaciones oncogenicas en tejido tumoral. Fundamental para seleccion de terapia dirigida (inhibidores BRAF/MEK si BRAF V600E positivo).",valoresReferencia:"BRAF V600E positivo: ~50% de melanomas. NRAS positivo: ~20%. Wild-type: inmunoterapia de eleccion.",cuidadosEnfermeria:["Asegurar correcta conservacion de la muestra en formalina","Coordinar con laboratorio de biologia molecular","Explicar al paciente la importancia del resultado para el tratamiento"]},{nombre:"PET-CT o TC de torax-abdomen-pelvis",descripcion:"Estadificacion sistemica en melanomas de estadio IIB o superior para detectar metastasis a distancia.",valoresReferencia:"Ausencia de captacion patologica: sin evidencia de metastasis. Captacion en organos: metastasis a distancia.",cuidadosEnfermeria:["Verificar ayuno de 6 horas previo a PET-CT","Controlar glucemia (debe ser <200 mg/dL para PET)","Explicar duracion del estudio y necesidad de permanecer inmovil","Instruir sobre restriccion de actividad fisica 24h antes del PET"]}]},tratamientoMedico:{objetivos:["Reseccion quirurgica completa con margenes adecuados segun Breslow","Estadificacion ganglionar y sistemica precisa","Erradicar enfermedad metastasica o controlarla a largo plazo","Mejorar supervivencia global y calidad de vida"],farmacologico:[{nombre:"Vemurafenib / Dabrafenib",grupo:"Inhibidores de BRAF (terapia dirigida)",mecanismo:"Bloquean selectivamente la kinasa BRAF V600E mutada, inhibiendo la via MAPK/ERK y suprimiendo la proliferacion tumoral en melanomas BRAF-positivos",dosis:"Vemurafenib 960 mg cada 12h oral; Dabrafenib 150 mg cada 12h oral",cuidadosEnfermeria:["Verificar mutacion BRAF V600E positiva antes de la primera dosis","Monitorizar aparicion de queratoacantomas o carcinomas espinocelulares cutaneos (efecto adverso de clase)","Vigilar fotosensibilidad: instruir uso de protector solar SPF50+ y ropa protectora","Controlar ECG periodico por riesgo de prolongacion QT","Evaluar funcion hepatica y renal basalmente y durante el tratamiento"]},{nombre:"Pembrolizumab / Nivolumab",grupo:"Inmunoterapia: inhibidores de checkpoint PD-1",mecanismo:"Anticuerpos monoclonales que bloquean el receptor PD-1 en linfocitos T, restaurando la capacidad del sistema inmune para reconocer y destruir celulas tumorales",dosis:"Pembrolizumab 200 mg IV cada 3 semanas; Nivolumab 240 mg IV cada 2 semanas",cuidadosEnfermeria:["Administrar en infusion IV lenta de 30 minutos con filtro de 0.2-5 micrones","Monitorizar reacciones inmunomediadas: colitis, neumonitis, hepatitis, tiroiditis, hipofisitis","Vigilar signos de toxicidad infusional durante y 1 hora post-infusion","Educar al paciente sobre sintomas de toxicidad inmune y necesidad de consulta inmediata","Controlar funcion tiroidea, hepatica, renal y glucemia antes de cada ciclo"]},{nombre:"Interfer\xf3n alfa-2b (adyuvante)",grupo:"Inmunomodulador citocinico",mecanismo:"Estimula la respuesta inmune antitumoral mediante activacion de celulas NK, linfocitos T citotoxicos y macrofagos; tiene efecto antiproliferativo directo",dosis:"20 MUI/m2 IV 5 dias/semana por 4 semanas, luego 10 MUI/m2 SC 3 veces/semana por 48 semanas",cuidadosEnfermeria:["Premedicar con paracetamol y difenhidramina para reducir sindrome gripal","Monitorizar hemograma completo y funcion hepatica cada 2 semanas","Vigilar sintomas depresivos (el interferon puede inducir depresion severa)","Instruir sobre tecnica de autoinyeccion subcutanea correcta","Educar sobre manejo del sindrome gripal (fiebre, mialgias, astenia)"]}],noFarmacologico:["Reseccion quirurgica ampliada: margenes de 1 cm para Breslow <=2 mm, 2 cm para >2 mm","Fotoproteccion solar estricta de por vida: SPF50+, ropa protectora, evitar exposicion 10-16h","Autoexamen cutaneo mensual y dermatoscopia periodica (cada 3-6 meses en primeros 5 a\xf1os)","Psiconcologia: acompanamiento psicologico ante diagnostico oncologico","Educacion familiar sobre autoexamen y vigilancia de nevos","Evitar solarium y fuentes artificiales de UV"]},cuidadosEnfermeria:{valoracion:["Inspeccionar todo el tegumento con dermoscopia bajo luz adecuada","Registrar caracteristicas ABCDE de cada lesion sospechosa","Evaluar presencia de adenopatias regionales palpables","Valorar estado emocional y nivel de ansiedad ante diagnostico oncologico","Identificar factores de riesgo modificables (habitos de exposicion solar)","Valorar red de apoyo social y familiar"],intervenciones:["Preparar y asistir en biopsias cutaneas con tecnica esteril","Administrar quimioterapia e inmunoterapia segun protocolo oncologico","Monitorizar toxicidades inmunomediadas de inhibidores de checkpoint","Coordinar con equipo multidisciplinario (dermatologo, onc\xf3logo, cirujano, medicina nuclear)","Implementar protocolo de fotoproteccion en la unidad","Brindar soporte emocional e informacion clara sobre el proceso diagnostico-terapeutico"],educacionPaciente:["Ense\xf1ar regla ABCDE para autoexamen mensual de lesiones cutaneas","Importancia del uso diario de protector solar SPF50+ en areas expuestas","Evitar exposicion solar entre las 10 y las 16 horas","Ropa protectora (manga larga, sombrero de ala ancha, gafas UV)","Reconocer signos de toxicidad inmunomediada y consultar de urgencia","Cumplimiento estricto del calendario de seguimiento oncologico"],monitorizacion:["Signos vitales y temperatura durante infusion de inmunoterapia","Hemograma, funcion hepatica y renal antes de cada ciclo de tratamiento","Evaluacion dermatologica de lesiones cutaneas inducidas por inhibidores BRAF","Estado nutricional y peso en pacientes con tratamiento sistemico","Funcion tiroidea mensual en pacientes con inhibidores PD-1","Evaluacion del dolor y calidad de vida en estadios avanzados"]},npiNanda:[{codigo:"00221",nombre:"Deterioro de la integridad cutanea",definicion:"Alteracion de la epidermis y/o dermis por proceso neoplasico maligno o ulceracion tumoral",caracteristicasDefinitorias:["Lesion cutanea pigmentada con criterios ABCDE positivos","Ulceracion o sangrado de lesion melanocitica","Cambios en coloracion, forma o tamano de nevo preexistente"],factoresRelacionados:["Proliferacion maligna de melanocitos","Exposicion solar acumulada sin fotoproteccion","Predisposicion genetica (mutacion BRAF)"]},{codigo:"00148",nombre:"Temor",definicion:"Respuesta emocional a la amenaza identificada percibida como peligrosa para el bienestar propio ante diagnostico de cancer",caracteristicasDefinitorias:["Expresion verbal de miedo ante diagnostico oncologico","Inquietud y nerviosismo ante procedimientos diagnosticos","Hipervigilancia sobre lesiones cutaneas"],factoresRelacionados:["Diagnostico de neoplasia maligna","Incertidumbre sobre pronostico y evolucion","Conocimiento insuficiente sobre tratamientos disponibles"]},{codigo:"00004",nombre:"Riesgo de infeccion",definicion:"Vulnerable a ser invadido por organismos patogenos por alteracion de la barrera cutanea y tratamiento inmunosupresor",caracteristicasDefinitorias:["Solucion de continuidad post-biopsia o cirug\xeda","Inmunosupresion por inmunoterapia o quimioterapia"],factoresRelacionados:["Procedimientos quirurgicos sobre piel","Tratamiento con agentes inmunomoduladores","Alteracion de la barrera cutanea por lesion tumoral"]}],npiNic:[{codigo:"3590",nombre:"Vigilancia de la piel",actividades:["Inspeccionar la piel en busca de enrojecimiento, calor excesivo, edema o ulceracion","Observar color, turgencia y caracteristicas de las lesiones cutaneas","Documentar cambios en lesiones pigmentadas con descripcion detallada y fotografia","Derivar al dermatologo ante cualquier cambio en lesiones melanociticas"]},{codigo:"5820",nombre:"Disminucion de la ansiedad",actividades:["Escuchar activamente las preocupaciones del paciente y familia","Proporcionar informacion clara y veraz sobre diagnostico y opciones terapeuticas","Derivar a psiconcologia para apoyo especializado","Fomentar expresion de emociones en un ambiente de confianza"]},{codigo:"5510",nombre:"Educacion para la salud",actividades:["Ense\xf1ar regla ABCDE y tecnica de autoexamen cutaneo mensual","Instruir sobre medidas de fotoproteccion solar diaria","Explicar importancia del seguimiento dermatologico regular","Proporcionar material educativo escrito sobre signos de alarma"]}],npiNoc:[{codigo:"1101",nombre:"Integridad tisular: piel y membranas mucosas",indicadores:["Ausencia de lesiones cutaneas nuevas o cambios en lesiones preexistentes","Cicatrizacion adecuada de sitio quirurgico","Ausencia de signos de infeccion local"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"},{codigo:"1402",nombre:"Autocontrol de la ansiedad",indicadores:["Verbaliza comprension del diagnostico y plan de tratamiento","Refiere disminucion del nivel de temor","Participa activamente en decisiones sobre su cuidado"],escala:"1=Nunca demostrado, 2=Raramente demostrado, 3=A veces demostrado, 4=Frecuentemente demostrado, 5=Siempre demostrado"}],complicaciones:["Metastasis linfatica regional (ganglio centinela positivo)","Metastasis a distancia: pulmon, higado, cerebro, hueso, piel","Linfedema por linfadenectomia regional","Toxicidad inmunomediada severa por inmunoterapia (colitis, neumonitis, hepatitis)","Resistencia secundaria a inhibidores BRAF (aparece en ~6-12 meses)","Recidiva local o en transito","Melanoma leptomeningeo (metastasis en SNC)"],criteriosAlarma:["Cambio rapido en tamano, forma o color de lesion pigmentada","Sangrado espontaneo o ulceracion de nevo","Aparicion de nodulo cutaneo satelite alrededor de lesion previa","Adenopatia regional de nueva aparicion","Fiebre, disnea o dolor toracico en paciente en tratamiento (toxicidad inmune)","Convulsiones o deficit neurologico focal (metastasis cerebral)","Perdida de peso no explicada >10% en 6 meses"],emergencyLevel:"moderado",relatedPathologyIds:["pat_carcinoma_basocelular","pat_carcinoma_espinocelular","pat_nevos_melanociticos"],isPremium:!0},{id:"pat_dermatitis_atopica",nombre:"Dermatitis Atopica",bodySystemId:"tegumentario",definicion:"Enfermedad inflamatoria cutanea cronica y recidivante, caracterizada por prurito intenso, eccema y xerosis cutanea. Forma parte de la triada atopica junto con el asma bronquial y la rinoconjuntivitis alergica. Se asocia a disfuncion de la barrera cutanea y respuesta inmune Th2 exacerbada.",epidemiologia:"Afecta al 15-20% de ni\xf1os y al 1-3% de adultos en paises industrializados. Prevalencia en aumento en las ultimas decadas. En Argentina, prevalencia estimada del 10-15% en poblacion pediatrica. El 60% debuta antes de los 12 meses, el 85% antes de los 5 a\xf1os. El 70% de los casos se resuelve en la adolescencia; el 30% persiste en la edad adulta.",factoresRiesgo:["Antecedentes familiares de atopia (asma, rinitis alergica, dermatitis atopica)","Mutacion del gen FLG (filagrina): principal factor genetico predisponente","Sensibilizacion a aeroalergenos (acaro del polvo, epitelio de animales, pollen)","Exposicion a detergentes y jabones agresivos","Clima frio y seco","Colonizacion cutanea por Staphylococcus aureus","Estres emocional (desencadena o agrava brotes)","Sudoracion excesiva","Dieta: alergia alimentaria (leche, huevo, trigo en lactantes)","Hipotesis de la higiene: escasa exposicion microbiana en la infancia"],fisiopatologia:"La fisiopatologia involucra dos mecanismos centrales: 1) Disfuncion de la barrera epid\xe9rmica: mutaciones en FLG reducen la cantidad de filagrina, proteina esencial para la formacion del estrato corneo. Esto genera perdida transepidermica de agua (TEWL aumentada), pH cutaneo elevado y penetracion facilitada de alergenos e irritantes. 2) Desregulacion inmune: la penetracion de alergenos activa celulas de Langerhans, que estimulan respuesta Th2 con produccion de IL-4, IL-5, IL-13 e IL-31. La IL-31 es el principal mediador del prurito. En la fase cronica se suma respuesta Th1. El prurito genera rascado que agrava la lesion barrera (ciclo prurigo-rascado).",signosYSintomas:{signos:["Eccema flexural: fosas antecubitales, fosas popliteas, pliegues del cuello","Xerosis generalizada (piel seca)","Eritema y edema cutaneo en zonas afectadas","Liquenificacion: engrosamiento cutaneo por rascado cronico","Exulceraciones lineales por rascado","Costras serosas o serohematicas","Signo de Dennie-Morgan: doble pliegue infraorbitario","Palidez perioral y periorbital"],sintomas:["Prurito intenso: sintoma cardinal, empeora por la noche","Ardor cutaneo","Alteracion del sueno por prurito nocturno","Irritabilidad en lactantes y ni\xf1os por prurito","Sensacion de calor en piel afectada"]},clasificacion:{nombre:"Clasificacion por edad de presentacion y gravedad (SCORAD)",tipos:[{nombre:"Dermatitis atopica del lactante (0-2 a\xf1os)",descripcion:"Afecta mejillas, cuero cabelludo, region extensora de extremidades y tronco. Predominan vesiculas y costras. Prurito intenso."},{nombre:"Dermatitis atopica infantil (2-12 a\xf1os)",descripcion:"Tipica distribucion flexural: fosas antecubitales, fosas popliteas, pliegues del cuello, munecas y tobillos."},{nombre:"Dermatitis atopica del adolescente y adulto (>12 a\xf1os)",descripcion:"Liquenificacion prominente, afectacion de manos y parpados. Curso mas cronico. Mayor impacto en calidad de vida."},{nombre:"Gravedad segun SCORAD",descripcion:"Leve: SCORAD <25; Moderada: 25-50; Grave: >50. Evalua extension, intensidad y sintomas subjetivos."}]},diagnostico:{anamnesis:["Inicio y evolucion del prurito (edad de debut, factores desencadenantes)","Antecedentes personales y familiares de atopia","Distribucion topografica de lesiones segun edad","Exposicion a alergenos o irritantes (detergentes, mascotas, polvo)","Historia de infecciones cutaneas recurrentes","Impacto en calidad de vida y sueno"],examenFisico:["Inspeccion completa de piel con valoracion de distribucion tipica por edad","Calculo de SCORAD o EASI para cuantificar gravedad","Valoracion de xerosis, liquenificacion, exulceraciones","Busqueda de signos de sobreinfeccion bacteriana (costras melicericas, exudado purulento)","Examen de mucosas y conjuntivas (conjuntivitis asociada)","Auscultacion pulmonar (asma asociada)"],pruebas:[{nombre:"IgE total serica y RAST (IgE especifica)",descripcion:"Determina sensibilizacion alergica a aeroalergenos y alimentos. No diagnostica la dermatitis atopica por si solo pero orienta el manejo.",valoresReferencia:"IgE total normal <100 UI/mL (adultos); elevada en >80% de DA moderada-grave",cuidadosEnfermeria:["Extraer muestra sanguinea sin requisito de ayuno","Registrar medicacion actual (antihistaminicos pueden afectar resultados de prick test)","Informar que resultado tarda 3-7 dias en casos de RAST multiple"]},{nombre:"Pruebas cutaneas (Prick test)",descripcion:"Identifica sensibilizacion IgE mediada a alergenos especificos. Se realiza en cara anterior del antebrazo. Complementaria al RAST.",valoresReferencia:"Positivo: hab\xf3n >=3 mm mayor que control negativo",cuidadosEnfermeria:["Suspender antihistaminicos 5-7 dias antes del estudio","Verificar que la piel del antebrazo este libre de eccema activo en la zona de prueba","Tener equipo de urgencias disponible por riesgo de reaccion anafilactica","Leer resultados a los 15-20 minutos"]},{nombre:"Cultivo de lesiones cutaneas sobreinfectadas",descripcion:"Identifica el agente infeccioso en caso de sobreinfeccion (principalmente S. aureus, S. pyogenes, herpes simple). Orienta el tratamiento antibiotico.",valoresReferencia:"Muestra ideal: exudado de lesion activa con costras. S. aureus se cultiva en >90% de lesiones activas.",cuidadosEnfermeria:["Tomar muestra con hisopo esteril de lesion activa no tratada","Realizar antes de iniciar antibiotico","Trasladar muestra en medio de transporte antes de 2 horas","Registrar tiempo entre toma y procesamiento"]}]},tratamientoMedico:{objetivos:["Restaurar y mantener la barrera cutanea con emolientes intensivos","Controlar la inflamacion y el prurito durante los brotes","Identificar y evitar desencadenantes especificos","Prevenir sobreinfecciones cutaneas","Mejorar calidad de vida y sueno del paciente y familia"],farmacologico:[{nombre:"Corticoides topicos (betametasona, triamcinolona, hidrocortisona)",grupo:"Corticosteroide topico antiinflamatorio",mecanismo:"Inhiben la fosfolipasa A2 via lipocortina, reduciendo la sintesis de prostaglandinas y leucotrienos. Suprimen la respuesta inflamatoria Th2 local.",dosis:"Potencia segun zona: baja potencia (hidrocortisona 1%) para cara y pliegues; potencia media-alta (betametasona 0.05%) para tronco y extremidades. Aplicar 1-2 veces/dia en brotes.",cuidadosEnfermeria:["Explicar riesgo de atrofia cutanea por uso prolongado, especialmente en cara y pliegues","Instruir sobre tecnica de aplicacion: capa fina sobre piel humeda post-bano","No usar en piel infectada sin cobertura antibiotica simultanea","Vigilar efecto rebote al suspender bruscamente","Educar sobre el concepto de 'terapia de fin de semana' para mantenimiento"]},{nombre:"Dupilumab",grupo:"Biol\xf3gico: anticuerpo monoclonal anti-IL-4Ra",mecanismo:"Bloquea el receptor comun de IL-4 e IL-13 (IL-4Ra), inhibiendo ambas citoquinas Th2 centrales en la patogenia de la DA moderada-grave",dosis:"600 mg SC dosis de carga, luego 300 mg SC cada 2 semanas (adultos). Aprobado en >6 a\xf1os.",cuidadosEnfermeria:["Ense\xf1ar tecnica de autoinyeccion subcutanea en muslo o abdomen","Vigilar conjuntivitis como efecto adverso mas frecuente (20-25% de pacientes)","Rotar sitios de inyeccion y dejar precalentar a temperatura ambiente 30 min antes","Informar que la mejoria es progresiva (semanas 4-16)","Registrar respuesta clinica con scores objetivos (EASI, SCORAD) en cada visita"]},{nombre:"Cetirizina / Loratadina",grupo:"Antihistaminico H1 de segunda generacion",mecanismo:"Bloquea competitivamente los receptores H1 de histamina, reduciendo el prurito histamina-dependiente. Menor sedacion que los de primera generacion.",dosis:"Cetirizina 10 mg/dia oral (adultos); Loratadina 10 mg/dia oral. En ni\xf1os ajustar por peso.",cuidadosEnfermeria:["Administrar preferentemente por la noche por el efecto sedante residual que mejora el sueno","Advertir sobre precaucion al conducir o manejar maquinaria (cetirizina tiene mas sedacion que loratadina)","Indicar que no cura la dermatitis pero alivia el prurito y mejora el sueno","Controlar en pacientes con insuficiencia renal (ajuste de dosis)"]}],noFarmacologico:["Emolientes intensivos: aplicar 2-3 veces/dia (especialmente post-bano) en todo el cuerpo","Banos tibios cortos (5-10 min) con jabon pH neutro o syndets","Identificar y evitar desencadenantes: ropa sintetica, detergentes agresivos, sudoracion excesiva","Ropa de algodon 100% directamente sobre la piel, evitar lana y sinteticos","Control de temperatura ambiental y humedad relativa (20-22\xb0C, 45-55% humedad)","Cubrir manos del lactante con manoplas por la noche para evitar rascado","Tecnica de vendaje humedo (wet-wrap) en brotes graves con supervision medica"]},cuidadosEnfermeria:{valoracion:["Calcular SCORAD o EASI para objetivar la gravedad del brote actual","Registrar distribucion y caracteristicas de las lesiones (eccema, liquenificacion, costras)","Evaluar calidad del sueno y nivel de prurito nocturno (escala NRS 0-10)","Identificar factores desencadenantes en el entorno del paciente","Valorar impacto psicologico y social (escala DLQI en adolescentes y adultos)","Evaluar conocimiento previo del cuidador o paciente sobre la enfermedad"],intervenciones:["Aplicar emolientes prescritos con tecnica correcta y registrar respuesta","Administrar corticoides topicos y terapia biologica segun prescripcion","Implementar medidas de prevencion de rascado en lactantes (guantes de algodon)","Instruir sobre bano terapeutico: agua tibia, jabon syndet, secado suave, emoliente inmediato","Coordinar con alergologia para estudio de sensibilizaciones y plan de evitacion","Brindar apoyo emocional a familia y paciente ante el caracter cronico de la enfermedad"],educacionPaciente:["Explicar el caracter cronico-recidivante y la importancia del tratamiento de mantenimiento","Demostrar aplicacion correcta de emolientes (cantidad, frecuencia, secuencia post-bano)","Instruir sobre identificacion y evitacion de desencadenantes personales","Ense\xf1ar uso correcto de corticoides topicos: potencia, zona, duracion y prevencion de efectos adversos","Plan de accion escrito para manejo de brotes (cuando iniciar tratamiento, cuando consultar)","Importancia del seguimiento regular con dermatologo y alerg\xf3logo"],monitorizacion:["SCORAD o EASI en cada visita para objetivar respuesta al tratamiento","Escala NRS de prurito diaria en pacientes hospitalizados","Vigilar signos de sobreinfeccion bacteriana o herpetica (eccema herpeticum)","Control de crecimiento en ni\xf1os con uso prolongado de corticoides topicos potentes","Seguimiento de adherencia a emolientes y corticoides topicos","Evaluacion de respuesta a dupilumab a las 16 semanas (criterio de continuacion)"]},npiNanda:[{codigo:"00174",nombre:"Riesgo de dignidad humana comprometida",definicion:"Vulnerable a la percepcion de perdida de respeto y honor por la presencia de lesiones cutaneas visibles y estigma social asociado",caracteristicasDefinitorias:["Retraimiento social por lesiones cutaneas visibles","Verbalizacion de verguenza o incomodidad por apariencia cutanea","Evitacion de actividades sociales o fisicas por prurito"],factoresRelacionados:["Lesiones cutaneas visibles y estigmatizantes","Cronicidad de la enfermedad con impacto en imagen corporal","Prurito nocturno con deterioro del sueno y funcionamiento diurno"]},{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable ocasionada por prurito intenso que causa sufrimiento actual",caracteristicasDefinitorias:["Verbalizacion de prurito intenso (NRS >6)","Conducta de rascado compulsivo","Alteracion del patron de sueno por prurito nocturno","Irritabilidad y llanto en lactantes"],factoresRelacionados:["Inflamacion cutanea con liberacion de IL-31 y mediadores del prurito","Disfuncion de barrera cutanea con activacion de nociceptores","Colonizacion por S. aureus con liberacion de toxinas pruritogenas"]},{codigo:"00108",nombre:"Deficit de autocuidado: bano",definicion:"Deterioro de la capacidad para realizar actividades de higiene corporal de forma adecuada para la piel atopica",caracteristicasDefinitorias:["Incapacidad para realizar bano terapeutico correcto","Desconocimiento de productos de higiene adecuados para piel atopica","No aplicacion sistematica de emolientes post-bano"],factoresRelacionados:["Conocimiento insuficiente sobre cuidados especificos de la piel atopica","Complejidad del regimen de emolientes","Edad del paciente (lactante dependiente del cuidador)"]}],npiNic:[{codigo:"3584",nombre:"Cuidados de la piel: tratamiento topico",actividades:["Aplicar emolientes con tecnica correcta sobre piel limpia y aun humeda","Administrar corticoides topicos con la cantidad y frecuencia prescrita","Vigilar respuesta de la piel al tratamiento topico y documentar cambios","Asegurar temperatura del agua de bano entre 34-37\xb0C"]},{codigo:"1400",nombre:"Manejo del dolor",actividades:["Valorar prurito con escala numerica 0-10 en cada turno","Administrar antihistaminicos segun prescripcion medica","Aplicar compresas frias para alivio local del prurito agudo","Identificar y eliminar factores agravantes del prurito (sudor, calor, ropa irritante)"]},{codigo:"5510",nombre:"Educacion para la salud",actividades:["Instruir sobre tecnica correcta de bano y aplicacion de emolientes","Educar sobre identificacion y evitacion de desencadenantes","Proporcionar plan de accion escrito para manejo de brotes","Ense\xf1ar uso correcto de corticoides topicos y prevencion de efectos adversos"]}],npiNoc:[{codigo:"1101",nombre:"Integridad tisular: piel y membranas mucosas",indicadores:["Reduccion del SCORAD o EASI respecto al valor basal","Disminucion de la extension del eccema activo","Ausencia de signos de sobreinfeccion cutanea"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"},{codigo:"0003",nombre:"Descanso",indicadores:["Refiere prurito nocturno disminuido (NRS <4)","Duracion del sueno de al menos 6-7 horas nocturnas","Ausencia de interrupciones frecuentes del sueno por prurito"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"}],complicaciones:["Sobreinfeccion bacteriana por S. aureus (impetiginizacion)","Eccema herpeticum (infeccion diseminada por VHS en piel atopica): urgencia dermatologica","Moluscum contagiosum diseminado","Dermatitis de contacto alergica sobreagregada","Eritrodermia atopica (afectacion >90% superficie corporal)","Retraso del crecimiento en ni\xf1os con DA grave y uso prolongado de corticoides sist\xe9micos","Impacto psicologico: ansiedad, depresion, baja autoestima"],criteriosAlarma:["Fiebre >38.5\xb0C con lesiones cutaneas (sospecha de eccema herpeticum o infeccion sistemica)","Lesiones vesiculosas umbilicadas de aparicion brusca (eccema herpeticum)","Extension brusca a >90% de superficie corporal (eritrodermia)","Signos de infeccion bacteriana grave: celulitis, adenitis, bacteriemia","Prurito intolerable con nula respuesta a tratamiento habitual","Deterioro del estado general o sepsis"],emergencyLevel:"ninguno",relatedPathologyIds:["pat_asma_bronquial","pat_rinitis_alergica","pat_urticaria"],isPremium:!0},{id:"pat_erisipela",nombre:"Erisipela",bodySystemId:"tegumentario",definicion:"Infeccion bacteriana aguda de la dermis superficial y los vasos linfaticos subcutaneos, producida principalmente por Streptococcus pyogenes (estreptococo beta-hemolitico del grupo A). Se caracteriza por una placa eritematosa, sobreelevada, de bordes netos y bien delimitados, con signos inflamatorios locales y manifestaciones sistemicas.",epidemiologia:"Incidencia de 10-100 casos por 100.000 habitantes/ano. Afecta con mayor frecuencia a adultos mayores de 40-60 a\xf1os. El miembro inferior (pierna) es el sitio mas afectado (70-80% de casos). La tasa de recurrencia es del 20-30% en los primeros 3 a\xf1os. Mortalidad baja (<1%) en inmunocompetentes, mayor en diabeticos e inmunocomprometidos.",factoresRiesgo:["Linfedema cronico (principal factor predisponente para recurrencias)","Insuficiencia venosa cronica","Diabetes mellitus","Obesidad","Traumatismos o soluciones de continuidad cutanea (puerta de entrada)","Micosis interdigital (tinea pedis): puerta de entrada frecuente","Inmunosupresion","Insuficiencia renal cronica","Antecedentes de erisipela previa","Alcoholismo cronico"],fisiopatologia:"El Streptococcus pyogenes penetra por una solucion de continuidad en la barrera cutanea (intertrigo, ulcera, fisura). La bacteria produce multiples factores de virulencia: estreptoquinasa (disuelve coagulos facilitando la difusion), hialuronidasas (degradan tejido conectivo), proteina M (antifagocitica) y toxinas eritrogenicas (responsables del eritema y fiebre). La infeccion se extiende rapidamente por los vasos linfaticos dermicos, causando linfangitis y obstruccion linfatica. La respuesta inflamatoria aguda genera los signos clasicos: calor, rubor, tumor y dolor. La bacteriemia secundaria es posible en casos graves.",signosYSintomas:{signos:["Placa eritematosa sobreelevada, brillante, caliente, tensa y de bordes netos bien delimitados","Signo del escalon: limite neto entre piel sana y afectada","Adenopatias regionales dolorosas","Linfangitis: cordones eritematosos en direccion proximal","Vesiculas, ampollas o flictenas en casos mas intensos","Petequias y purpura en casos graves","Fiebre elevada (38.5-40\xb0C)","Taquicardia proporcional a la fiebre"],sintomas:["Inicio brusco con fiebre alta, escalofrios y malestar general","Dolor local intenso en zona afectada","Sensacion de tension y calor local","Cefalea y mialgias al inicio (prodromo de 4-48h antes de la lesion cutanea)","Nauseas en casos con bacteriemia"]},clasificacion:{nombre:"Clasificacion segun evolucion y gravedad",tipos:[{nombre:"Erisipela simple",descripcion:"Placa eritematosa sobreelevada sin ampollas ni necrosis. Respuesta adecuada a antibioticoterapia oral. Sin compromiso sistemico grave."},{nombre:"Erisipela ampollosa",descripcion:"Presencia de vesiculas y ampollas en la superficie de la placa eritematosa. Puede indicar mayor virulencia bacteriana o infeccion mixta. Requiere evaluacion de ingreso hospitalario."},{nombre:"Erisipela necrotizante",descripcion:"Con areas de necrosis cutanea. Puede progresar a fasciitis necrotizante. Requiere hospitalizacion urgente y considerar desbridamiento quirurgico."},{nombre:"Erisipela recidivante",descripcion:"Tres o mas episodios en el mismo sitio. Indica persistencia de factores predisponentes, especialmente linfedema. Requiere profilaxis antibiotica."}]},diagnostico:{anamnesis:["Tiempo de evolucion y forma de inicio (tipicamente brusco con fiebre)","Antecedentes de episodios previos en el mismo sitio","Identificacion de puerta de entrada (intertrigo, herida, ulcera)","Comorbilidades: diabetes, insuficiencia venosa, linfedema, inmunosupresion","Medicacion actual (antibioticos previos, inmunosupresores)","Vacunacion contra neumococo y estreptococo (en inmunocomprometidos)"],examenFisico:["Delimitacion precisa de los bordes con marcador de piel para seguimiento evolutivo","Medicion de temperatura local y general","Evaluacion de ampollas, flictenas o areas de necrosis","Palpacion de adenopatias regionales","Examen de puerta de entrada (intertrigo interdigital, heridas)","Exploracion vascular del miembro: pulsos, insuficiencia venosa, linfedema"],pruebas:[{nombre:"Hemograma completo con formula leucocitaria",descripcion:"Evalua respuesta inflamatoria sistemica. Tipicamente leucocitosis con neutrofilia y bandas. La trombocitopenia sugiere complicacion grave.",valoresReferencia:"Leucocitos: 12.000-20.000/mm3, Neutrofilia >80%, Proteina C reactiva elevada",cuidadosEnfermeria:["Extraer muestra antes de iniciar antibiotico si es posible","Realizar hemocultivos simultaneos en casos con fiebre alta o compromiso sistemico","Registrar hora de extraccion y condicion clinica del paciente"]},{nombre:"PCR y VSG",descripcion:"Marcadores de inflamacion sistemica. Utiles para monitorizar respuesta al tratamiento. La PCR se normaliza antes que la VSG.",valoresReferencia:"PCR normal <5 mg/L; en erisipela tipicamente >50-100 mg/L. VSG normal <20 mm/h",cuidadosEnfermeria:["No requiere ayuno","Repetir cada 48-72h para evaluar respuesta al tratamiento","Registrar en grafica junto con temperatura"]},{nombre:"Hemocultivos (2 muestras)",descripcion:"Indicados en pacientes con fiebre >39\xb0C, deterioro hemodinamico, inmunosupresion o sospecha de bacteriemia. Positividad en 2-4% de casos.",valoresReferencia:"Positivo en S. pyogenes confirma diagnostico y guia tratamiento. Negativo no descarta erisipela.",cuidadosEnfermeria:["Extraer 2 series de hemocultivos (2 botellas cada una) antes de iniciar antibiotico","Respetar tecnica aseptica estricta para evitar contaminacion","Temperatura correcta de incubacion: 35-37\xb0C"]},{nombre:"Glucemia y funcion renal",descripcion:"Screening de comorbilidades que modifican el pronostico y tratamiento. La hiperglucemia empeora el pronostico infeccioso.",valoresReferencia:"Glucemia normal 70-100 mg/dL; Creatinina normal 0.6-1.2 mg/dL",cuidadosEnfermeria:["Solicitar en ayunas si es posible para glucemia","Ajuste de dosis de antibiotico segun funcion renal","Control de glucemia cada 6h en pacientes diabeticos"]}]},tratamientoMedico:{objetivos:["Erradicar la infeccion estreptococica con antibioticoterapia adecuada","Reducir la inflamacion local y los sintomas sistemicos","Prevenir complicaciones: absceso, fasciitis necrotizante, bacteriemia","Tratar y corregir los factores predisponentes para evitar recurrencias","Profilaxis antibiotica a largo plazo en casos recidivantes"],farmacologico:[{nombre:"Penicilina G sodica / Amoxicilina",grupo:"Antibiotico beta-lactamico: penicilina",mecanismo:"Inhibe la sintesis de la pared bacteriana de S. pyogenes al unirse a las proteinas fijadoras de penicilina (PBPs). S. pyogenes es uniformemente sensible a penicilinas; no hay resistencia documentada.",dosis:"Penicilina G sodica 2-4 MUI IV cada 4-6h (formas graves). Amoxicilina 500-875 mg oral cada 8h (formas leves-moderadas, 10-14 dias).",cuidadosEnfermeria:["Preguntar antecedentes de alergia a penicilinas antes de administrar","En caso de alergia: usar clindamicina o macr\xf3lidos como alternativa","Controlar aparicion de flebitis en via IV periferica","Asegurar hidratacion adecuada para eliminar el antibiotico","Evaluar respuesta clinica a las 48-72h (reduccion del eritema y fiebre)"]},{nombre:"Clindamicina",grupo:"Antibiotico lincosamida",mecanismo:"Inhibe la sintesis proteica bacteriana uniendose a la subunidad 50S del ribosoma. Alternativa en alergia a penicilinas. Efecto antiexotoxina (reduce produccion de toxinas estreptococicas).",dosis:"600-900 mg IV cada 8h o 300-450 mg oral cada 6-8h, por 10-14 dias",cuidadosEnfermeria:["Vigilar aparicion de diarrea por Clostridioides difficile (efecto adverso potencial)","Administrar con alimentos para reducir intolerancia gastrointestinal","Informar al paciente que debe consultar ante diarrea liquida o sanguinolenta","Controlar funcion hepatica en tratamientos prolongados"]},{nombre:"Ibuprofeno / Paracetamol",grupo:"AINE / Analgesico-antipiretico",mecanismo:"Ibuprofeno inhibe COX-1 y COX-2 reduciendo sintesis de prostaglandinas; efecto analgesico, antipiretico y antiinflamatorio. Paracetamol: mecanismo central analgesico y antipiretico.",dosis:"Ibuprofeno 400-600 mg oral cada 8h con comidas; Paracetamol 500-1000 mg oral o IV cada 6-8h",cuidadosEnfermeria:["Administrar ibuprofeno con alimentos para proteger la mucosa gastrica","Contraindicar ibuprofeno en insuficiencia renal o ulcera peptica activa","No superar 4 g/dia de paracetamol en adultos, menos en hepatopatas","Registrar temperatura cada 4h y respuesta antipiretica","Elevar el miembro afectado para reducir edema e inflamacion local"]}],noFarmacologico:["Reposo en cama con elevacion del miembro afectado a 30-45\xb0 sobre el nivel del corazon","Higiene y cura de la puerta de entrada identificada","Tratamiento de la micosis interdigital concomitante (tinea pedis) para eliminar puerta de entrada","Medias de compresion elastica en insuficiencia venosa cronica tras la resolucion del episodio agudo","Hidratacion y nutricion adecuada","Delimitacion con marcador del borde de la placa en el momento del ingreso para seguimiento"]},cuidadosEnfermeria:{valoracion:["Delimitar y documentar con marcador el borde de la placa eritematosa al ingreso","Medir temperatura y signos vitales cada 4-6h","Evaluar dolor local con escala NRS 0-10","Valorar presencia de ampollas, necrosis o linfangitis ascendente","Identificar y evaluar la puerta de entrada (intertrigo, heridas)","Controlar glucemia en pacientes diabeticos cada 6h"],intervenciones:["Administrar antibioticoterapia prescrita con control de alergias previas","Elevar el miembro afectado (almohadas, soporte elevador) para reducir edema","Realizar curas de la puerta de entrada con tecnica esteril","Aplicar frio local (compresas frias) para alivio del dolor e inflamacion","Monitorizar la evolucion del eritema trazando el borde cada 12h","Asegurar acceso venoso permeable y administrar antibiotico IV segun protocolo"],educacionPaciente:["Importancia de completar el ciclo antibiotico completo aunque mejore antes","Tratamiento de la micosis interdigital (tinea pedis) para eliminar puerta de entrada","Cuidado de la piel e higiene de los pies: secado correcto entre dedos","Reconocer signos de alarma: extension del eritema, fiebre mayor, aparicion de rayas rojas (linfangitis)","Uso de medias de compresion en insuficiencia venosa cronica","Profilaxis antibiotica ante episodios recurrentes (mas de 2 episodios)"],monitorizacion:["Signos vitales cada 4h: temperatura, PA, FC, frecuencia respiratoria","Evolucion del eritema: medicion del area marcada cada 12h","Hemograma y PCR a las 48-72h para evaluar respuesta","Balance hidroelectrolitico en pacientes hospitalizados","Glucemia en diabeticos: control cada 6h","Vigilar aparicion de ampollas o necrosis (progresion a fasciitis)"]},npiNanda:[{codigo:"00188",nombre:"Conducta de salud propensa a riesgo",definicion:"Deterioro de la capacidad para modificar el estilo de vida/conductas de manera consistente con el fin de mejorar el estado de salud ante factores predisponentes persistentes",caracteristicasDefinitorias:["Antecedentes de episodios previos sin correccion de factores predisponentes","Persistencia de tinea pedis como puerta de entrada","Incumplimiento de medidas de compresion venosa"],factoresRelacionados:["Conocimiento insuficiente sobre factores de riesgo y prevencion de recurrencias","Factores socioeconomicos que dificultan el acceso a calzado y medias de compresion","Comorbilidades cronicos que predisponen (linfedema, insuficiencia venosa)"]},{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable ocasionada por da\xf1o tisular real en la piel por proceso infeccioso agudo",caracteristicasDefinitorias:["Verbalizacion de dolor local intenso (NRS >6)","Posicion antalgica del miembro afectado","Expresion facial de dolor al movilizar el miembro"],factoresRelacionados:["Inflamacion aguda por infeccion estreptococica","Distension cutanea por edema","Presion sobre terminaciones nerviosas por infiltrado inflamatorio"]},{codigo:"00004",nombre:"Riesgo de infeccion",definicion:"Vulnerable a complicaciones infecciosas por inadecuada respuesta al tratamiento antibiotico o diseminacion de la infeccion",caracteristicasDefinitorias:["Placa eritematosa en extension a pesar del tratamiento","Aparicion de ampollas o necrosis","Fiebre persistente o en aumento"],factoresRelacionados:["Puerta de entrada cutanea activa no resuelta","Comorbilidades inmunosupresoras","Bacteriemia secundaria no controlada"]}],npiNic:[{codigo:"6540",nombre:"Control de infecciones",actividades:["Administrar antibiotico prescrito en tiempo y dosis correcta","Monitorizar la evolucion del eritema con marcador cutaneo cada 12h","Realizar cultivos antes de iniciar antibioticoterapia cuando sea posible","Mantener tecnica aseptica en curas y procedimientos invasivos"]},{codigo:"1400",nombre:"Manejo del dolor",actividades:["Elevar el miembro afectado a 30-45\xb0 para reducir edema y dolor","Aplicar frio local con compresas para alivio del dolor agudo","Administrar analgesicos prescritos y evaluar respuesta","Valorar dolor con escala NRS antes y 1h despues de cada analgesia"]},{codigo:"5510",nombre:"Educacion para la salud",actividades:["Instruir sobre tratamiento y prevencion de micosis interdigital","Educar sobre higiene correcta de los pies y secado adecuado entre dedos","Ense\xf1ar uso de medias de compresion en insuficiencia venosa","Explicar signos de alarma y cuando consultar de urgencia"]}],npiNoc:[{codigo:"0703",nombre:"Severidad de la infeccion",indicadores:["Reduccion del eritema y edema local en 48-72h de antibioticoterapia","Afebril en 48-72h post inicio de tratamiento","PCR y leucocitos en descenso hacia la normalizacion"],escala:"1=Grave, 2=Sustancial, 3=Moderado, 4=Leve, 5=Ninguno"},{codigo:"1605",nombre:"Control del dolor",indicadores:["Refiere reduccion del dolor local (NRS <4) con tratamiento","Puede movilizar el miembro con dolor tolerable","No requiere analgesicos de rescate frecuentes"],escala:"1=Nunca demostrado, 2=Raramente demostrado, 3=A veces demostrado, 4=Frecuentemente demostrado, 5=Siempre demostrado"}],complicaciones:["Absceso subcutaneo: fluctuacion, requiere drenaje quirurgico","Fasciitis necrotizante: progresion a planos profundos, urgencia quirurgica","Bacteriemia y sepsis estreptococica","Sindrome de shock toxico estreptococico","Glomerulonefritis post-estreptococica","Linfedema cronico post-infeccioso por fibrosis linfatica","Erisipela recidivante (3 o mas episodios)"],criteriosAlarma:["Extension del eritema mas alla del borde marcado a las 24-48h de antibiotico","Aparicion de areas de necrosis o cambio de coloracion a gris-purpura (fasciitis)","Dolor desproporcionado a la apariencia cutanea (signo clasico de fasciitis necrotizante)","Inestabilidad hemodinamica: hipotension, taquicardia >120 lpm","Fiebre >40\xb0C que no responde a antipir\xe9ticos","Crepitacion cutanea (infeccion por anaerobios)","Deterioro del estado de consciencia"],emergencyLevel:"moderado",relatedPathologyIds:["pat_celulitis","pat_fasciitis_necrotizante","pat_pie_diabetico"],isPremium:!0},{id:"pat_pie_diabetico",nombre:"Pie Diabetico",bodySystemId:"tegumentario",definicion:"Sindrome clinico multifactorial que aparece como complicacion cronica de la diabetes mellitus, caracterizado por la presencia de infeccion, ulceracion y/o destruccion de tejidos profundos del pie, asociado a neuropatia periferica y/o enfermedad arterial periferica en miembros inferiores. Representa la principal causa de amputacion no traumatica de miembros inferiores a nivel mundial.",epidemiologia:"El 15-25% de los diabeticos desarrollan una ulcera en el pie a lo largo de su vida. Constituye el 40-70% de todas las amputaciones no traumaticas. En Argentina, se estima que cada 20 minutos se realiza una amputacion por pie diabetico. La tasa de mortalidad a 5 a\xf1os post-amputacion supera el 50%. La recidiva ulcerosa es del 40% en el primer ano y del 65% en los 3 a\xf1os siguientes.",factoresRiesgo:["Diabetes mellitus de larga evolucion (>10 a\xf1os)","Mal control glucemico cronico (HbA1c >8%)","Neuropatia periferica sensitivo-motora-autonoma","Enfermedad arterial periferica (EAP)","Antecedentes de ulcera o amputacion previa (mayor factor de riesgo de recurrencia)","Deformidades del pie: hallux valgus, dedos en garra, pie de Charcot","Callosidades en zonas de presion","Tabaquismo activo (agrava EAP)","Insuficiencia renal cronica","Retinopatia diabetica (indicador de vasculopatia sistemica)"],fisiopatologia:"La ulceracion en el pie diabetico resulta de la interaccion de tres mecanismos principales: 1) Neuropatia periferica: la polineuropatia sensitiva produce perdida de la sensacion protectora del dolor, temperatura y presion; la neuropatia motora genera debilidad y atrofia muscular con deformidades (dedos en garra); la neuropatia autonoma causa anhidrosis (piel seca y fisurada) y shunts arteriovenosos que agravan la isquemia. 2) Enfermedad arterial periferica: la aterosclerosis acelerada en diabeticos afecta preferentemente arterias tibiales y peroneas, generando isquemia tisular y deterioro de la cicatrizacion. 3) Infeccion: la hiperglucemia deteriora la funcion leucocitaria (quimiotaxis, fagocitosis), facilitando la colonizacion polimicrobiana. Los tres mecanismos interactuan: la neuropatia permite el trauma sin percepcion, la vasculopatia impide la cicatrizacion y la infeccion produce progresion rapida.",signosYSintomas:{signos:["Ulcera en zona de presion (cabezas metatarsianas, talon, borde lateral del pie)","Bordes ulcerosos engrosados, callosidad periulcerosa","Fondo ulceroso con tejido de granulacion o esfacelos (tejido necrotico)","Eritema, calor, edema y exudado purulento en caso de infeccion","Pie caliente con pulsos presentes (predominio neuropatico)","Pie frio, palido o cianotico con pulsos ausentes (predominio isquemico)","Deformidades: hallux valgus, dedos en garra, pie de Charcot","Callosidades en zonas de hiperpresion"],sintomas:["Ausencia de dolor en ulceras neuropaticas (signo alarma por perdida de sensacion protectora)","Dolor en reposo o nocturno en pie isquemico","Claudicacion intermitente en enfermedad arterial periferica","Parestesias y disestesias en neuropatia activa","Sensacion de caminar sobre algodon o de tener los pies dormidos"]},clasificacion:{nombre:"Clasificacion de Wagner-Meggitt",tipos:[{nombre:"Grado 0",descripcion:"Pie de riesgo: sin ulcera pero con callosidades, deformidades o neuropatia. Prevencion primaria."},{nombre:"Grado 1",descripcion:"Ulcera superficial que afecta piel y tejido celular subcutaneo. Sin infeccion evidente."},{nombre:"Grado 2",descripcion:"Ulcera profunda que llega a tendones, capsulas articulares o hueso sin osteomielitis."},{nombre:"Grado 3",descripcion:"Ulcera profunda con osteomielitis, absceso o artritis septica. Infeccion de estructuras profundas."},{nombre:"Grado 4",descripcion:"Gangrena localizada en parte del pie (dedo o antepie). Riesgo de amputacion parcial."},{nombre:"Grado 5",descripcion:"Gangrena extensa que afecta todo el pie. Amputacion mayor frecuentemente necesaria."}]},diagnostico:{anamnesis:["Tiempo de evolucion de la diabetes y nivel de control glucemico (HbA1c)","Antecedentes de ulceras o amputaciones previas","Sintomas de neuropatia: hormigueos, disestesias, perdida de sensibilidad","Sintomas vasculares: claudicacion, dolor en reposo","Habitos: tabaquismo, cumplimiento del tratamiento diabetico","Evaluacion del calzado habitual"],examenFisico:["Inspeccion detallada de ambos pies: coloracion, temperatura, callosidades, ulceras, deformidades","Evaluacion sensitiva con monofilamento de 10 g de Semmes-Weinstein","Palpacion de pulsos: tibial posterior y pedio","Indice tobillo-brazo (ITB): normal 0.9-1.3; isquemia si <0.9","Clasificacion Wagner de la ulcera si presente","Sondaje de la ulcera para evaluar profundidad y exposicion osea (hueso visible: sospecha osteomielitis)"],pruebas:[{nombre:"HbA1c y glucemia",descripcion:"Evalua el control glucemico global. La HbA1c refleja el promedio de glucemia en los ultimos 3 meses. Es fundamental para predecir cicatrizacion y riesgo de complicaciones infecciosas.",valoresReferencia:"HbA1c objetivo <7% en DM; niveles >8% se asocian a deterioro de cicatrizacion. Glucemia en ayunas: 70-130 mg/dL objetivo en hospitalizados.",cuidadosEnfermeria:["Extraer muestra para HbA1c sin requisito de ayuno","Control de glucemia capilar cada 4-6h en hospitalizados con ulcera infectada","Registrar todos los valores en grafica y comunicar glucemias >180 o <70 mg/dL"]},{nombre:"Cultivo de ulcera (biopsia de tejido profundo)",descripcion:"Gold standard para identificar germenes en pie diabetico infectado. Se prefiere biopsia de tejido profundo o curetaje de la base ulcerosa sobre hisopado superficial. Guia el tratamiento antibiotico.",valoresReferencia:"Flora polimicrobiana frecuente: S. aureus, estreptococos, enterobacterias, Pseudomonas, anaerobios en grados avanzados.",cuidadosEnfermeria:["Limpiar la ulcera con suero fisiologico antes de tomar la muestra","Tomar muestra de tejido profundo (no hisopado superficial) para mayor sensibilidad","Enviar en medio de transporte adecuado antes de 2 horas","Realizar antes de iniciar antibiotico"]},{nombre:"Radiografia del pie",descripcion:"Primera linea de imagen para detectar osteomielitis (destruccion osea, reaccion periosteal), cuerpos extranos, gas en tejidos blandos (infeccion anaerobia) y deformidades oseas.",valoresReferencia:"Normal: sin alteraciones oseas. Osteomielitis: destruccion osea cortical, desmineralizacion focal, reaccion periosteal en 2-4 semanas.",cuidadosEnfermeria:["Trasladar al paciente sin apoyo del pie para evitar trauma adicional","Indicar al radiologo la sospecha clinica (osteomielitis, gas) para optimizar tecnica","Proteger herida con aposito durante traslado a radiologia"]},{nombre:"Indice tobillo-brazo (ITB) con Doppler",descripcion:"Evalua la perfusion arterial del pie. Fundamental para diferenciar ulcera neuropatica (ITB normal) de isquemica (ITB <0.9) y determinar viabilidad para cicatrizacion y necesidad de revascularizacion.",valoresReferencia:"Normal: 0.9-1.3. Isquemia leve: 0.7-0.9. Isquemia moderada: 0.5-0.7. Isquemia critica: <0.5. Calcificacion arterial (no compresible): >1.4.",cuidadosEnfermeria:["Posicionar al paciente en decubito supino durante 10 minutos antes de la medicion","Registrar presion sistolica en ambos brazos y tobillo-pedio de cada pierna","Calcular ITB: presion tobillo / presion brazo mas alta","ITB >1.4 puede indicar calcificacion arterial: solicitar indice dedo-brazo"]}]},tratamientoMedico:{objetivos:["Control glucemico estricto para optimizar cicatrizacion (glucemia 140-180 mg/dL en hospitalizados)","Erradicacion de la infeccion con antibioticoterapia adecuada","Desbridamiento de tejido necrotico para favorecer granulacion","Revascularizacion si hay isquemia critica (ITB <0.5)","Descarga de la ulcera (off-loading): redistribucion de presiones","Prevencion de amputacion y recurrencia"],farmacologico:[{nombre:"Amoxicilina-clavulanico / Piperacilina-tazobactam",grupo:"Antibiotico beta-lactamico con inhibidor de betalactamasas (espectro amplio)",mecanismo:"La combinacion cubre flora polimicrobiana del pie diabetico: gram positivos (incluido SASM), gram negativos y anaerobios. El acido clavulanico o tazobactam inhibe las betalactamasas bacterianas, recuperando la actividad del beta-lactamico.",dosis:"Amoxicilina-clavulanico 875/125 mg oral cada 8h (infecciones leves-moderadas). Piperacilina-tazobactam 4.5 g IV cada 6-8h (infecciones graves, hospitalizados).",cuidadosEnfermeria:["Administrar piperacilina-tazobactam IV en infusion de 30 minutos a 4 horas segun protocolo","Verificar funcion renal para ajuste de dosis (eliminacion renal)","Vigilar signos de sobreinfeccion por C. difficile (diarrea liquida)","Monitorizar signos de alergias al inicio del tratamiento","Controlar via IV periferica para signos de flebitis"]},{nombre:"Insulina (esquema intensivo)",grupo:"Hormona hipoglucemiante",mecanismo:"La insulina corrige la hiperglucemia, que deteriora la funcion leucocitaria (quimiotaxis, opsonizacion y fagocitosis disminuidas) y la capacidad de cicatrizacion. El control glucemico estricto es fundamental para el tratamiento de la infeccion.",dosis:"Insulina basal: glargina 0.2-0.3 UI/kg/dia SC. Correcciones con insulina rapida segun glucemia capilar. Objetivo: 140-180 mg/dL en hospitalizados.",cuidadosEnfermeria:["Control de glucemia capilar antes de cada comida y a las 3 AM","Rotar sitios de inyeccion subcutanea para evitar lipohipertrofia","Tener ampolla de glucag\xf3n 1 mg disponible ante hipoglucemia grave","Administrar insulina rapida de correcci\xf3n segun escala prescrita","Registro en grafica de todos los valores glucemicos y dosis de insulina"]},{nombre:"Pentoxifilina",grupo:"Hemorreologico / vasodilatador periferico",mecanismo:"Mejora la deformabilidad eritrocitaria y reduce la viscosidad sanguinea, aumentando la microcirculacion en el pie isquemico. Inhibe la agregacion plaquetaria y tiene efecto antiinflamatorio.",dosis:"400 mg oral 3 veces al dia con las comidas",cuidadosEnfermeria:["Administrar con alimentos para reducir nauseas y molestias digestivas","Contraindicado en infarto agudo de miocardio reciente y hemorragia activa","Vigilar interaccion con anticoagulantes: puede aumentar efecto anticoagulante","Informar que la respuesta clinica puede tardar 4-8 semanas en evidenciarse"]}],noFarmacologico:["Descarga ulcerosa (off-loading): yeso de contacto total (gold standard), calzado terapeutico o walker no extraible","Desbridamiento quirurgico o enzimatico del tejido necrotico y esfacelos","Cura avanzada con apositos funcionales segun tipo de ulcera (espuma, alginato, plata)","Revascularizacion: angioplastia percutanea o bypass en isquemia critica (ITB <0.5)","Educacion intensiva sobre cuidado de los pies: inspeccion diaria, calzado adecuado","Equipo multidisciplinario: diabetologo, cirujano vascular, ortopeda, podiatria, enfermeria especializada"]},cuidadosEnfermeria:{valoracion:["Inspeccion de la ulcera: tamano (cm), profundidad, bordes, fondo, exudado, signos de infeccion","Evaluacion sensitiva con monofilamento de Semmes-Weinstein","Palpacion de pulsos tibial posterior y pedio","Registro de glucemias capilares cada 4-6h","Clasificacion Wagner de la ulcera y documentacion fotografica semanal","Evaluacion del calzado y marcha del paciente"],intervenciones:["Realizar curaciones con tecnica esteril y apositos apropiados segun tipo de ulcera","Asegurar descarga efectiva del pie: instruir reposo y uso de dispositivos","Administrar antibioticoterapia e insulina segun prescripcion con controles glucemicos","Educar sobre autocuidado del pie diabetico con demostracion practica","Coordinar interconsultas multidisciplinarias (cirujano vascular, ortopeda, podiatria)","Gestionar referencia a programa de pie diabetico si disponible en el centro"],educacionPaciente:["Inspeccion diaria de ambos pies (con espejo si hay limitacion de vision o movilidad)","Lavado diario con agua tibia (no caliente), jabon neutro, secado minucioso entre dedos","Hidratacion con crema emoliente (no entre los dedos para evitar maceracion)","Corte de unas recto y suave, nunca en angulo, por pod\xf3logo si hay dificultad","Calzado adecuado: sin costuras internas, punta ancha, suela gruesa, talla exacta","No caminar descalzo, ni en interiores, ante la perdida de sensibilidad protectora"],monitorizacion:["Glucemia capilar antes de comidas y a las 3 AM en hospitalizados","Estado de la ulcera: tamano, profundidad, exudado, olor en cada curacion","Signos vitales cada 6-8h, mas frecuente en infecciones graves","HbA1c mensual en seguimiento ambulatorio","ITB trimestral en pacientes con isquemia periferica conocida","Observar signos de osteomielitis: hueso visible, profundidad repentina, falta de respuesta al tratamiento"]},npiNanda:[{codigo:"00044",nombre:"Deterioro de la integridad tisular",definicion:"Dano en la membrana mucosa, cornea, piel, fascia muscular, musculo, tend\xf3n, hueso, cartilago, capsula articular y/o ligamento en el pie diabetico",caracteristicasDefinitorias:["Ulcera en zona de presion del pie con perdida de continuidad cutanea","Fondo de ulcera con esfacelos o tejido necrotico","Exudado y signos inflamatorios locales"],factoresRelacionados:["Neuropatia diabetica sensitiva con perdida de sensacion protectora","Enfermedad arterial periferica con isquemia tisular","Hiperglucemia cronica con deterioro de la cicatrizacion"]},{codigo:"00078",nombre:"Gestion de salud ineficaz",definicion:"Patron de regulacion e integracion del regimen terapeutico de la diabetes en la vida diaria inadecuado para alcanzar los objetivos de control glucemico y prevencion de complicaciones",caracteristicasDefinitorias:["HbA1c persistentemente elevada (>8%)","Dificultad para integrar cuidados del pie en la rutina diaria","No realizacion de inspeccion diaria de los pies"],factoresRelacionados:["Complejidad del regimen terapeutico de la diabetes","Conocimiento insuficiente sobre cuidados preventivos del pie","Barreras economicas o de acceso a calzado ortopedico y materiales de cura"]},{codigo:"00115",nombre:"Riesgo de caidas",definicion:"Vulnerable a sufrir un aumento en la susceptibilidad a caer que puede causar da\xf1o fisico por neuropatia y alteracion del equilibrio",caracteristicasDefinitorias:["Perdida de sensacion propioceptiva en pies por neuropatia","Deformidades del pie que alteran la marcha","Uso de calzado inadecuado"],factoresRelacionados:["Neuropatia periferica con perdida de propiocepcion","Alteraciones del equilibrio por neuropatia motora","Deformidades oseas del pie"]}],npiNic:[{codigo:"3660",nombre:"Cuidados de las heridas",actividades:["Realizar curacion con tecnica esteril y desbridamiento segun protocolo","Seleccionar aposito apropiado segun caracteristicas de la ulcera (exudado, infeccion, profundidad)","Medir y fotografiar la ulcera en cada curacion para documentar evolucion","Irrigar la herida con suero fisiologico a presion adecuada"]},{codigo:"5606",nombre:"Ensenanza: cuidados del pie",actividades:["Instruir al paciente y cuidador en inspeccion diaria de ambos pies","Demostrar tecnica correcta de higiene y secado de los pies","Educar sobre eleccion de calzado adecuado y evitar caminar descalzo","Ense\xf1ar cuando consultar de urgencia ante cambios en el pie"]},{codigo:"2130",nombre:"Manejo de la hipoglucemia",actividades:["Monitorizar glucemia capilar segun protocolo","Administrar glucosa oral (15-20 g de hidratos simples) ante glucemia <70 mg/dL","Administrar glucagon IM/SC ante hipoglucemia grave con inconsciencia","Registrar y analizar patrones de hipoglucemia para ajuste de insulina"]}],npiNoc:[{codigo:"1103",nombre:"Curacion de la herida: por primera intension",indicadores:["Reduccion del tamano ulceroso >=50% en 4 semanas","Disminucion del exudado y ausencia de signos de infeccion activa","Aparicion de tejido de granulacion rosado en el fondo de la ulcera"],escala:"1=Ninguno, 2=Escaso, 3=Moderado, 4=Sustancial, 5=Completo"},{codigo:"2300",nombre:"Nivel de glucemia",indicadores:["Glucemias en ayunas entre 80-130 mg/dL","Glucemias postprandiales <180 mg/dL","HbA1c <7.5% en controles trimestrales"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Osteomielitis: infeccion del hueso subyacente (hueso visible en sondaje = osteomielitis hasta demostrar lo contrario)","Amputacion digital, transmetatarsiana, infracondilea o supracondilea","Sepsis por pie diabetico infectado con bacteriemia","Pie de Charcot (artropatia neuropatica): destruccion articular por carga en pie insensible","Gangrena humeda por infeccion anaerobia","Insuficiencia renal aguda por sepsis o nefrotoxicidad antibiotica","Muerte por sepsis o eventos cardiovasculares (MI, ACV) en perioperatorio de amputacion"],criteriosAlarma:["Presencia de crepitacion o gas en tejidos blandos (infeccion anaerobia, urgencia quirurgica)","Cambio de coloracion cutanea: negro, morado oscuro o gris (gangrena)","Dolor intenso en pie insensible (paradojico: infeccion grave o isquemia critica)","Fiebre >38.5\xb0C con signos de infeccion local que se extiende","Deterioro hemodinamico o sepsis","Hueso palpable o visible en fondo de ulcera (sospecha osteomielitis)","Extension rapida de eritema y edema mas alla del pie hacia la pierna"],emergencyLevel:"moderado",relatedPathologyIds:["pat_dm2","pat_erisipela","pat_irc"],isPremium:!0},{id:"pat_urticaria",nombre:"Urticaria",bodySystemId:"tegumentario",definicion:"Enfermedad cutanea caracterizada por la aparicion de habones (wheals) pruriginosos, edematosos y eritematosos, de forma y tamano variable, que desaparecen espontaneamente en menos de 24 horas sin dejar marca. Puede acompanarse de angioedema (edema de dermis profunda y tejido subcutaneo). Se debe a la degranulacion de mastocitos con liberacion de histamina y otros mediadores vasoactivos.",epidemiologia:"Prevalencia del 15-25% de la poblacion general experimenta al menos un episodio en su vida. La urticaria aguda (<6 semanas) es la forma mas frecuente. La urticaria cronica (>6 semanas) afecta al 0.5-1% de la poblacion y tiene mayor impacto en calidad de vida. Predomina en mujeres entre 20-40 a\xf1os. Hasta el 40% de los pacientes con urticaria cronica espontanea tienen angioedema asociado.",factoresRiesgo:["Atopia personal o familiar (rinitis alergica, asma, dermatitis atopica)","Infecciones agudas: viral (VEB, hepatitis A, B, C), bacteriana (H. pylori), parasitaria","Alimentos: nueces, mariscos, frutillas, huevo, leche (en urticaria alergica IgE mediada)","Farmacos: AINEs, penicilinas, sulfamidas, opioides, IECA (angioedema)","Estimulos fisicos: presion, frio, calor, esfuerzo fisico, agua (urticaria fisica)","Enfermedades autoinmunes: LES, tiroiditis de Hashimoto (urticaria cronica)","Estres emocional agudo (puede desencadenar o agravar)","Veneno de insectos (abejas, avispas): urticaria alergica aguda"],fisiopatologia:"El mecanismo central es la degranulacion de mastocitos cutaneos con liberacion de histamina, PAF (factor activador de plaquetas), leucotrienos, prostaglandinas y citoquinas proinflamatorias. Segun el mecanismo desencadenante: 1) IgE mediada: el alergeno une IgE especifica en la superficie del mastocito, provocando degranulacion inmediata. 2) No IgE mediada (pseudoalergica): AINEs, opioides o factores fisicos activan directamente el mastocito sin participacion de IgE. 3) Autoinmune: en urticaria cronica espontanea, autoanticuerpos IgG contra Fc\u03b5RI o IgE activan mastocitos. La histamina liberada actua sobre receptores H1 en capilares dermicos: vasodilatacion (eritema), aumento de permeabilidad vascular (edema = habon) y estimulacion de fibras nerviosas sensitivas (prurito). Los habones son superficiales; el angioedema refleja afectacion de capas mas profundas.",signosYSintomas:{signos:["Habones (wheals): elevaciones edematosas de la piel, centro palido, halo eritematoso, bordes definidos","Forma y tamano variable: de mm a varios cm (urticaria gigante)","Polimorfismo cutaneo: habones de distintos tamanos y formas en el mismo momento","Resolucion completa en <24h sin dejar marca (signo diferencial de vasculitis)","Dermografismo si es urticaria facticia","Angioedema: edema no eritematoso, no pruriginoso, en labios, parpados, lengua, genitales, garganta","Urticaria colinergica: micropapulas tras ejercicio o calor"],sintomas:["Prurito intenso: principal sintoma, puede ser muy incapacitante","Ardor o quemaz\xf3n en la piel afectada","Disconfort o sensacion de presion en angioedema","Disfagia o cambio de voz en angioedema de via aerea superior (URGENCIA)","Disnea y estridor en angioedema laringo-traqueal (EMERGENCIA VITAL)","Malestar general, cefalea y nauseas en urticaria generalizada intensa"]},clasificacion:{nombre:"Clasificacion por duracion y etiologia",tipos:[{nombre:"Urticaria aguda",descripcion:"Duracion <6 semanas. La mayoria de causa infecciosa o alergica. El 50% resuelve sin identificar causa. El 30% evoluciona a cronica."},{nombre:"Urticaria cronica espontanea (UCE)",descripcion:"Habones espontaneos >6 semanas, al menos 2 dias/semana. En >50% causa no identificable. El 45% tiene autoanticuerpos. Impacto significativo en calidad de vida."},{nombre:"Urticaria fisica",descripcion:"Desencadenada por estimulos fisicos especificos: dermografismo, urticaria por frio, calor, presion, vibracion, solar o acuagenica. Puede coexistir con UCE."},{nombre:"Angioedema",descripcion:"Edema profundo de dermis y tejido subcutaneo. Puede ser histaminergico (con urticaria) o bradicinico (angioedema hereditario, por IECA). El angioedema laringeo es potencialmente fatal."}]},diagnostico:{anamnesis:["Tiempo de evolucion (aguda vs cronica), frecuencia y duracion de los habones","Factores desencadenantes identificados: alimentos, farmacos, ejercicio, frio, calor, estres","Uso de AINEs o IECAs (causas frecuentes y modificables)","Antecedentes de infecciones recientes (viral o bacteriana)","Antecedentes de atopia personal y familiar","Impacto en calidad de vida (trabajo, sueno, actividades)"],examenFisico:["Descripcion de los habones: forma, tamano, distribucion, tiempo de resolucion","Evaluacion de angioedema: inspeccion de labios, parpados, lengua, garganta","Test de dermografismo (dermografometro o depresion con espatula)","Test de cubo de hielo: aplicar 10 min en antebrazo (positivo: habon en 10 min)","Auscultacion pulmonar y evaluacion via aerea en angioedema activo","Examen de piel completo para descartar otras dermatosis"],pruebas:[{nombre:"Hemograma, VSG y PCR",descripcion:"Screening inicial en urticaria cronica. La eosinofilia sugiere parasitosis o atopia. VSG y PCR elevadas orientan a infeccion o autoinmunidad subyacente.",valoresReferencia:"Eosinofilos normal <500/mm3. PCR <5 mg/L. Eosinofilia >500: pensar parasitosis, atopia, sindrome hipereosinofilico.",cuidadosEnfermeria:["Extraer muestra sanguinea sin requisito de ayuno","Registrar si el paciente usa antihistaminicos (pueden disminuir eosinofilos)","Informar al laboratorio la sospecha clinica para optimizar el reporte"]},{nombre:"IgE total y RAST especifica (panel alergenos)",descripcion:"Indicados cuando la anamnesis sugiere causa alergica especifica (alimentos, latex, veneno). No es el estudio de primera linea en urticaria cronica sin desencadenante identificado.",valoresReferencia:"IgE total normal <100 UI/mL en adultos. IgE especifica positiva: >0.35 kU/L clase I; clinicamente significativa en clase III-IV.",cuidadosEnfermeria:["No requiere ayuno","Verificar si el paciente tiene antecedentes alergicos que orienten el panel a solicitar","Suspender antihistaminicos 5-7 dias antes del prick test si es posible"]},{nombre:"Anticuerpos antitiroideos (anti-TPO, anti-tiroglobulina) y TSH",descripcion:"La tiroiditis de Hashimoto se asocia a urticaria cronica espontanea en el 14-27% de casos. La correccion del hipotiroidismo puede mejorar la urticaria.",valoresReferencia:"Anti-TPO normal <35 UI/mL. TSH normal 0.4-4.0 mU/L. Anti-TPO >35: positivo para autoinmunidad tiroidea.",cuidadosEnfermeria:["Extraer en ayunas para TSH (mas preciso)","Informar al paciente que los anticuerpos altos no implican necesariamente hipotiroidismo","Coordinar seguimiento endocrinologico si TSH alterada"]}]},tratamientoMedico:{objetivos:["Alivio inmediato del prurito y los habones","Identificar y eliminar el factor desencadenante si es posible","Tratamiento de mantenimiento en urticaria cronica para controlar los brotes","Prevenir y manejar el angioedema, especialmente el laringeo","Mejorar calidad de vida del paciente con urticaria cronica"],farmacologico:[{nombre:"Cetirizina / Levocetirizina / Bilastina",grupo:"Antihistaminico H1 de segunda generacion (primera linea)",mecanismo:"Bloqueo selectivo y de alta afinidad de los receptores H1 de histamina en celulas del endotelio vascular y nervios sensoriales dermicos, reduciendo vasodilatacion, edema y transmision del prurito. Menor efecto sedante que los de primera generacion por menor penetracion en SNC.",dosis:"Cetirizina 10 mg/dia oral; Levocetirizina 5 mg/dia oral; Bilastina 20 mg/dia oral (alejado de comidas). En urticaria cronica refractaria: hasta 4x la dosis estandar (guias EAACI).",cuidadosEnfermeria:["Administrar preferentemente por la noche para aprovechar el efecto sedante residual","Informar que el tratamiento es continuo en urticaria cronica, no a demanda","Advertir sobre precaucion al conducir con cetirizina (mas sedante que bilastina)","Ajustar dosis en insuficiencia renal: cetirizina se elimina por via renal","Evaluar respuesta clinica con UAS7 (Urticaria Activity Score 7 dias) en cada visita"]},{nombre:"Adrenalina (epinefrina) 1:1000",grupo:"Catecolamina de urgencia: agonista alfa y beta adrenergico",mecanismo:"El agonismo alfa-adrenergico produce vasoconstriccion reversiendo la vasodilatacion y edema. El agonismo beta2 produce broncodilatacion. Es el farmaco de primera linea en anafilaxia y angioedema laringeo que compromete la via aerea.",dosis:"0.3-0.5 mg (0.3-0.5 mL de adrenalina 1:1000) IM en cara anterolateral del muslo. Puede repetirse cada 5-15 min. Autoepipen: 0.3 mg en adultos, 0.15 mg en ni\xf1os <25 kg.",cuidadosEnfermeria:["Administrar SIEMPRE IM (no SC) en cara anterolateral del muslo, no en gluteo","Tener disponible en toda unidad de salud junto con material de reanimacion","Monitorizar PA, FC y SpO2 cada 5 minutos tras la administracion","Mantener al paciente en decubito con piernas elevadas (si no hay edema de via aerea)","Educar sobre autoinyector EpiPen a pacientes con antecedentes de anafilaxia"]},{nombre:"Omalizumab",grupo:"Biologico: anticuerpo monoclonal anti-IgE",mecanismo:"Se une a la region Fc de la IgE libre en sangre, impidiendo su union a receptores Fc\u03b5RI de alta afinidad en mastocitos y bas\xf3filos. Reduce drasticamente la degranulacion mastocitaria. Indicado en urticaria cronica espontanea refractaria a antihistaminicos H1.",dosis:"300 mg SC cada 4 semanas. Respuesta en 1-4 semanas en mayoria de pacientes. Continuar al menos 6 meses.",cuidadosEnfermeria:["Administrar SC en abdomen o cara anterolateral del muslo, no en zonas con lesiones activas","Observar al paciente durante 30 minutos post-inyeccion por riesgo de reaccion anafilactica (infrecuente)","Rotar sitios de inyeccion en cada dosis","Informar que la mejoria no es inmediata: evaluar respuesta a la semana 12","Mantener registro de brotes (UAS7) antes y durante el tratamiento para evaluar eficacia"]}],noFarmacologico:["Identificacion y eliminacion del desencadenante especifico si es identificable","Suspension de AINEs e IECA si son la causa (sustituir por paracetamol y ARA-II respectivamente)","Dieta de exclusion de aditivos alimentarios en urticaria cronica si se sospecha su rol (6-8 semanas)","Evitar estimulos fisicos desencadenantes (frio, presion, ejercicio en urticaria fisica)","Ropa holgada de algodon para minimizar dermografismo y urticaria por presion","Informacion escrita sobre plan de accion ante anafilaxia y uso de adrenalina"]},cuidadosEnfermeria:{valoracion:["Valorar urgencia: evaluar via aerea, respiracion y circulacion ante angioedema activo","Describir las lesiones: extension, tamano de habones, presencia de angioedema","Evaluar intensidad del prurito con escala numerica NRS 0-10","Identificar desencadenantes recientes (alimentos, farmacos, infeccion, estres)","Evaluar historia de episodios previos y antecedentes alergicos","Valorar signos vitales y signos de anafilaxia sist\xe9mica"],intervenciones:["Administrar adrenalina IM urgente en angioedema laringeo o anafilaxia","Administrar antihistaminicos orales o IV segun gravedad del cuadro","Asegurar via aerea permeable y preparar material de intubacion en angioedema grave","Aplicar compresas frias para alivio local del prurito en habones localizados","Monitorizar signos vitales y saturacion de oxigeno cada 15-30 min en fase aguda","Educar sobre identificacion de desencadenantes y plan de accion ante nueva reaccion"],educacionPaciente:["Explicar la diferencia entre urticaria aguda (autolimitada) y cronica (tratamiento prolongado)","Ense\xf1ar a identificar y evitar desencadenantes propios","Instruir sobre uso correcto del autoinyector de adrenalina (EpiPen) a pacientes en riesgo de anafilaxia","Importancia de portar siempre el autoinyector y informar a familiares sobre su uso","Uso correcto y continuo de antihistaminicos en urticaria cronica","Reconocer signos de angioedema laringeo (disfagia, ronquera, dificultad para respirar) y actuar de urgencia"],monitorizacion:["Signos vitales cada 15 min en urticaria aguda grave o anafilaxia","Saturacion de oxigeno continua en angioedema activo","UAS7 (Urticaria Activity Score de 7 dias) en controles de urticaria cronica","Evaluacion de via aerea en angioedema de cabeza y cuello","Respuesta clinica a antihistaminicos a los 30-60 minutos de la administracion","Control de PA a los 5, 15 y 30 minutos tras adrenalina IM"]},npiNanda:[{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable por prurito intenso asociado a la degranulacion mastocitaria y liberacion de histamina",caracteristicasDefinitorias:["Verbalizacion de prurito intenso (NRS >6)","Conducta de rascado compulsivo de las lesiones","Expresion facial de disconfort e irritabilidad"],factoresRelacionados:["Degranulacion mastocitaria con liberacion de histamina e IL-31","Estimulacion de fibras nerviosas sensitivas epidermicas","Exposicion a desencadenante especifico"]},{codigo:"00146",nombre:"Ansiedad",definicion:"Vaga sensacion de malestar o amenaza acompanada de respuesta auton\xf3ma cuyo origen es desconocido para el individuo, relacionada con el caracter impredecible de los brotes y el miedo a la anafilaxia",caracteristicasDefinitorias:["Inquietud y nerviosismo ante aparicion de nuevas lesiones","Miedo a sufrir un episodio de angioedema laringeo","Restriccion de actividades por temor a desencadenantes"],factoresRelacionados:["Caracter imprevisible e incontrolable de los brotes de urticaria","Antecedentes de episodio grave previo (angioedema, anafilaxia)","Conocimiento insuficiente sobre el manejo de la enfermedad"]},{codigo:"00031",nombre:"Limpieza ineficaz de las vias aereas",definicion:"Incapacidad para eliminar secreciones u obstrucciones del tracto respiratorio para mantener via aerea permeable en angioedema de via aerea superior",caracteristicasDefinitorias:["Ronquera o voz nasal en angioedema laringeo","Estridor inspiratorio (signo de alarma grave)","Disfagia y sialorrea por edema orofaringeo"],factoresRelacionados:["Edema de laringe, epiglotis o faringe por angioedema","Degranulacion mastocitaria severa con liberacion masiva de mediadores vasoactivos"]}],npiNic:[{codigo:"6412",nombre:"Manejo de la anafilaxia",actividades:["Administrar adrenalina 0.3-0.5 mg IM en cara anterolateral del muslo ante anafilaxia o angioedema laringeo","Posicionar en decubito con piernas elevadas si no hay compromiso respiratorio","Administrar oxigeno a alto flujo (8-10 L/min) con mascarilla de reservorio","Canalizar via venosa de gran calibre e iniciar fluidos segun estado hemodinamico"]},{codigo:"1400",nombre:"Manejo del dolor",actividades:["Valorar prurito con escala NRS 0-10 antes y despues del tratamiento","Administrar antihistaminicos H1 segun prescripcion y evaluar respuesta a los 30-60 minutos","Aplicar compresas frias en areas de prurito intenso para alivio local","Promover ambiente fresco y ropa de algodon holgada para reducir el prurito"]},{codigo:"5510",nombre:"Educacion para la salud",actividades:["Instruir sobre identificacion de desencadenantes y su evitacion","Ense\xf1ar uso correcto del autoinyector de adrenalina con demostracion practica","Explicar diferencias entre urticaria y angioedema, y cuando llamar a emergencias","Proporcionar plan de accion escrito ante reaccion anafilactica"]}],npiNoc:[{codigo:"2102",nombre:"Nivel del dolor",indicadores:["Refiere disminucion del prurito (NRS <4) tras antihistaminico","Reduccion de la conducta de rascado","Mejora del sueno y funcionamiento diario"],escala:"1=Grave, 2=Sustancial, 3=Moderado, 4=Leve, 5=Ninguno"},{codigo:"0410",nombre:"Estado respiratorio: permeabilidad de las vias respiratorias",indicadores:["Ausencia de estridor laringeo","Ausencia de disfagia o cambios en la voz","Frecuencia respiratoria en rango normal (12-20 rpm) y SpO2 >95%"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Angioedema laringeo: obstruccion de via aerea superior, potencialmente fatal","Anafilaxia sistemica: hipotension, broncoespasmo, colapso cardiovascular","Urticaria cronica refractaria: brotes persistentes a pesar de tratamiento de primera linea","Impacto psicologico: ansiedad, depresion, reduccion significativa de calidad de vida","Dermografismo persistente o urticaria fisica debilitante","Reacciones adversas a los antihistaminicos: sedacion, deterioro cognitivo en primera generacion"],criteriosAlarma:["Ronquera, voz nasal, disfagia o estridor (angioedema laringeo EMERGENCIA)","Dificultad respiratoria o broncoespasmo","Hipotension (PAS <90 mmHg) o sincope (anafilaxia)","Urticaria generalizada que no responde a adrenalina IM en 15 minutos","Angioedema facial o lingual de rapida progresion","Taquicardia >120 lpm con hipotension (shock anafilactico)"],emergencyLevel:"leve",relatedPathologyIds:["pat_dermatitis_atopica","pat_anafilaxia","pat_rinitis_alergica"],isPremium:!0},{id:"pat_shock_hipovolemico",nombre:"Shock Hipovolemico",bodySystemId:"cardiovascular",definicion:"Estado de hipoperfusion tisular generalizada secundario a la perdida aguda de mas del 20% del volumen circulante efectivo, que compromete el aporte de oxigeno a los tejidos y puede llevar a falla multiorganica si no se trata de forma inmediata.",epidemiologia:"Representa la forma mas frecuente de shock en el entorno hospitalario y prehospitalario. El trauma es responsable del 40-50% de los casos. La mortalidad varia entre el 10% en formas leves y hasta el 50-80% en shock clase IV sin tratamiento precoz. Afecta a todos los grupos etarios, con mayor incidencia en adultos jovenes por trauma y en adultos mayores por hemorragia digestiva.",factoresRiesgo:["Trauma severo con hemorragia mayor","Hemorragia digestiva alta o baja","Cirugia mayor con sangrado intraoperatorio","Hemorragia obstetrica (parto, postparto)","Fracturas de huesos largos o pelvis","Quemaduras extensas (>20% SCQ)","Deshidratacion severa por diarrea o vomitos","Pancreatitis aguda grave","Peritonitis con secuestro de liquidos","Uso de anticoagulantes o antiagregantes"],fisiopatologia:"La perdida aguda de volumen reduce el retorno venoso y la precarga cardiaca, disminuyendo el gasto cardiaco y la presion arterial. En respuesta, el sistema nervioso simpatico libera catecolaminas que producen taquicardia, aumento de la contractilidad miocardica y vasoconstriccion periferica para redistribuir el flujo a organos vitales (cerebro, corazon). El SRAA retiene sodio y agua. Si la hemorragia supera los mecanismos compensadores, la perfusion tisular cae, instaurandose hipoxia celular, metabolismo anaerobio, acidosis lactica y, en fase terminal, falla multiorganica. La clasificacion de la ATLS distingue cuatro clases segun el volumen perdido: clase I (<15%), clase II (15-30%), clase III (30-40%) y clase IV (>40%).",signosYSintomas:{signos:["Hipotension arterial (PAS < 90 mmHg o caida > 40 mmHg del basal)","Taquicardia (FC > 100 lpm, hasta > 140 lpm en estadios avanzados)","Piel fria, palida y sudorosa (vasoconstriccion periferica)","Llenado capilar > 2 segundos","Taquipnea (FR > 20 rpm)","Diuresis reducida (< 0.5 ml/kg/h) u oligoanuria","Presion de pulso estrecha (< 25 mmHg)","Venas yugulares planas","Glasgow disminuido en estadios avanzados"],sintomas:["Sed intensa","Ansiedad y agitacion","Sensacion de mareo o lipotimia","Debilidad generalizada","Nauseas","Vision borrosa","Confusion mental (estadios tardios)","Sensacion de frio"]},clasificacion:{nombre:"Clasificacion ATLS (American Trauma Life Support)",tipos:[{nombre:"Clase I",descripcion:"Perdida < 750 ml (<15%). FC < 100, PA normal, FR normal, diuresis >30 ml/h. Sin sintomas significativos."},{nombre:"Clase II",descripcion:"Perdida 750-1500 ml (15-30%). FC 100-120, PA normal o limite, FR 20-30, diuresis 20-30 ml/h. Ansiedad."},{nombre:"Clase III",descripcion:"Perdida 1500-2000 ml (30-40%). FC >120, PA disminuida, FR 30-40, diuresis 5-15 ml/h. Confusion."},{nombre:"Clase IV",descripcion:"Perdida >2000 ml (>40%). FC >140, PA muy baja, FR >35, diuresis minima. Letargo, riesgo vital inmediato."}]},diagnostico:{anamnesis:["Mecanismo de trauma o causa de sangrado","Cantidad estimada de perdida de sangre o liquidos","Tiempo transcurrido desde el inicio","Antecedentes de anticoagulacion o coagulopatias","Patologias previas (cardiovasculares, renales)","Medicacion actual que pueda enmascarar taquicardia (betabloqueantes)"],examenFisico:["Signos vitales completos: PA, FC, FR, temperatura, SaO2","Evaluacion del estado de conciencia (escala de Glasgow)","Inspeccion de piel: color, temperatura, humedad, llenado capilar","Evaluacion de venas yugulares (planas en hipovolemia)","Auscultacion cardiaca y pulmonar","Examen abdominal en busca de fuente de sangrado","Evaluacion de heridas, fracturas o quemaduras"],pruebas:[{nombre:"Hemograma completo con hematocrito",descripcion:"El hematocrito inicial puede ser normal si la hemodilusion no ha ocurrido aun; cae con la reposicion de liquidos",valoresReferencia:"Hto normal: 36-46% (mujer), 40-52% (hombre); Hb: 12-16 g/dL (mujer), 13-18 g/dL (hombre)",cuidadosEnfermeria:["Extraer muestra de forma simultanea al inicio de la reanimacion","Repetir cada 2-4 horas para monitorizar tendencia","Rotular urgente y enviar de inmediato al laboratorio"]},{nombre:"Lactato serico",descripcion:"Marcador de hipoperfusion tisular y metabolismo anaerobio; valores elevados indican shock severo y mal pronostico",valoresReferencia:"Normal < 2 mmol/L; Shock: > 4 mmol/L indica hipoperfusion grave",cuidadosEnfermeria:["Obtener muestra arterial o venosa segun indicacion medica","Repetir cada 2 horas para evaluar respuesta a la reanimacion","La normalizacion del lactato es objetivo terapeutico"]},{nombre:"Gases en sangre arterial",descripcion:"Evalua acidosis metabolica (pH bajo, bicarbonato bajo, deficit de base negativo) por hipoperfusion",valoresReferencia:"pH 7.35-7.45; HCO3 22-26 mEq/L; Deficit de base: -2 a +2",cuidadosEnfermeria:["Tecnica aseptica en puncion arterial (radial preferente)","Presionar minimo 5 minutos en sitio de puncion","Enviar muestra en hielo al laboratorio inmediatamente"]},{nombre:"Coagulograma (TP, KPTT, fibrinogeno)",descripcion:"Detecta coagulopatia de consumo asociada a hemorragia masiva",valoresReferencia:"TP: 11-13 seg (INR < 1.5); KPTT: 25-35 seg; Fibrinogeno: 200-400 mg/dL",cuidadosEnfermeria:["Extraer antes de transfusiones si es posible","Vigilar signos de sangrado activo en sitios de puncion","Monitorizar cada 4-6 horas en hemorragia activa"]},{nombre:"Ecografia FAST (Focused Assessment with Sonography in Trauma)",descripcion:"Detecta liquido libre intraabdominal o pericardico como causa de shock en pacientes traumatizados",valoresReferencia:"Normal: ausencia de liquido libre en espacios perihepatico, periesplenico, pelvico y pericardico",cuidadosEnfermeria:["Mantener al paciente en decubito supino durante el estudio","Asistir al medico durante el procedimiento","Registrar resultado y notificar hallazgos positivos de inmediato"]}]},tratamientoMedico:{objetivos:["Restaurar el volumen circulante efectivo de forma rapida","Controlar la fuente de sangrado o perdida de liquidos","Mantener PA media > 65 mmHg y PAS > 90 mmHg","Normalizar lactato y diuresis (> 0.5 ml/kg/h)","Prevenir la coagulopatia y la triada letal (hipotermia, acidosis, coagulopatia)"],farmacologico:[{nombre:"Solucion fisiologica al 0.9% / Ringer lactato",grupo:"Cristaloide isot\xf3nico para reposicion de volumen",mecanismo:"Expande el volumen intravascular y restaura la perfusion tisular al reponer el deficit de liquido extracelular",dosis:"Bolo inicial: 1000-2000 ml IV rapido en adultos (clase III-IV); ajustar segun respuesta hemodin\xe1mica",cuidadosEnfermeria:["Canalizar dos vias venosas perifericas de grueso calibre (14-16G) de forma inmediata","Administrar el bolo con fluidoterapia a presion o infusor rapido","Monitorizar respuesta hemodinamica (PA, FC, diuresis) cada 15 minutos","Controlar signos de sobrecarga hidrica (crepitantes pulmonares, edema)","Calentar los liquidos a 37-39\xb0C para prevenir hipotermia"]},{nombre:"Concentrado de globulos rojos (CGR)",grupo:"Hemoderivado - Terapia transfusional",mecanismo:"Repone los eritrocitos perdidos restaurando la capacidad transportadora de oxigeno de la sangre",dosis:"1-2 unidades IV; en hemorragia masiva: protocolo 1:1:1 (CGR:PFC:plaquetas)",cuidadosEnfermeria:["Verificar grupo y factor Rh y compatibilidad antes de la transfusion","Confirmar identidad del paciente con doble verificacion (nombre, numero de historia)","Monitorizar signos de reaccion transfusional (fiebre, escalofrios, urticaria, hipotension) los primeros 15 minutos","Administrar a temperatura ambiente; no calentar en microondas","Registrar hora de inicio y fin, unidad transfundida y respuesta del paciente"]},{nombre:"Noradrenalina",grupo:"Vasopresor - Catecolamina",mecanismo:"Agonista alfa-1 adrenergico que produce vasoconstriccion periferica elevando la presion arterial media; se usa cuando la reposicion de volumen no es suficiente",dosis:"0.01-3 mcg/kg/min IV en infusion continua; titular segun PA media objetivo (> 65 mmHg)",cuidadosEnfermeria:["Administrar exclusivamente por via central (CVC) para evitar necrosis por extravasacion","Monitorizar PA de forma continua (idealmente con via arterial)","Vigilar signos de isquemia distal: frialdad, cianosis, dolor en extremidades","No suspender bruscamente; reducir de forma progresiva","Registrar dosis exacta en mcg/kg/min y ajustar segun indicacion medica"]}],noFarmacologico:["Control de la hemorragia externa: compresion directa, torniquetes, vendajes de presion","Posicion de Trendelenburg modificada o elevacion de miembros inferiores 15-30\xb0","Mantenimiento de la temperatura corporal (manta termica, liquidos calentados)","Oxigenoterapia con mascarilla de alto flujo o ventilacion mecanica si precisa","Sondaje vesical para monitorizar diuresis horaria","Control quirurgico urgente de la fuente de sangrado interno","Acceso venoso central (CVC) para monitorizar PVC y administrar vasopresores"]},cuidadosEnfermeria:{valoracion:["Monitorizar signos vitales continuamente: PA, FC, FR, SaO2, temperatura","Evaluar estado de conciencia con escala de Glasgow cada hora","Registrar diuresis horaria mediante sonda vesical","Valorar color, temperatura y llenado capilar de la piel","Identificar fuente y magnitud de la perdida de volumen","Evaluar respuesta hemodinamica a la reposicion de liquidos cada 15-30 minutos"],intervenciones:["Canalizar dos vias venosas perifericas de grueso calibre (14-16G) de forma inmediata","Administrar liquidos IV y hemoderivados segun indicacion medica y respuesta clinica","Aplicar compresion directa en heridas con sangrado activo","Colocar al paciente en decubito supino con elevacion de miembros inferiores si no hay contraindicacion","Mantener temperatura corporal con mantas termicas y calentamiento de liquidos","Preparar material para intubacion orotraqueal y reanimacion cardiopulmonar","Obtener muestras de laboratorio urgentes (hemograma, gases, coagulacion, lactato)","Registrar balance hidrico estricto cada hora"],educacionPaciente:["Explicar al paciente y familia la gravedad de la situacion y los procedimientos que se realizaran","Informar sobre la importancia de mantener reposo absoluto","Orientar sobre signos de alarma que deben comunicar de inmediato","Proporcionar informacion sobre el proceso de recuperacion esperado","Abordar el estres emocional del paciente y familia con apoyo psicologico"],monitorizacion:["PA y FC continua (idealmente con via arterial invasiva en shock severo)","SaO2 con pulsioximetro continuo","Diuresis horaria (objetivo > 0.5 ml/kg/h)","Temperatura corporal cada hora","Lactato serico cada 2 horas hasta normalizacion","Hematocrito/Hb cada 2-4 horas en hemorragia activa","Balance hidrico acumulado cada 4-6 horas","Presion venosa central si CVC colocado"]},npiNanda:[{codigo:"00029",nombre:"Disminucion del gasto cardiaco",definicion:"Cantidad de sangre bombeada por el corazon en un minuto inadecuada para satisfacer las demandas metabolicas del organismo",caracteristicasDefinitorias:["Hipotension arterial","Taquicardia","Piel fria y palida","Disminucion de la diuresis","Alteracion del nivel de conciencia"],factoresRelacionados:["Perdida aguda de volumen circulante","Disminucion de la precarga cardiaca","Aumento de la resistencia vascular periferica compensatoria"]},{codigo:"00025",nombre:"Riesgo de desequilibrio del volumen de liquidos",definicion:"Vulnerable a una disminucion, aumento o rapido cambio de un espacio a otro del liquido intravascular, intersticial y/o intracelular que puede comprometer la salud",caracteristicasDefinitorias:["Perdida activa de volumen de liquidos","Hipotension ortost\xe1tica","Taquicardia compensatoria"],factoresRelacionados:["Hemorragia activa o perdida de liquidos","Traumatismo","Procedimientos quirurgicos"]},{codigo:"00032",nombre:"Patron respiratorio ineficaz",definicion:"La inspiracion y/o espiracion no proporciona una ventilacion adecuada",caracteristicasDefinitorias:["Taquipnea","Uso de musculos accesorios","SaO2 disminuida","Alteracion de la profundidad respiratoria"],factoresRelacionados:["Hipoxia tisular por hipoperfusion","Acidosis metabolica","Dolor agudo"]}],npiNic:[{codigo:"4028",nombre:"Cuidados circulatorios: insuficiencia arterial",actividades:["Monitorizar el estado hemodinamico de forma continua","Administrar liquidos IV y vasopresores segun prescripcion","Evaluar perfusion periferica (color, temperatura, llenado capilar)","Mantener acceso venoso permeable de grueso calibre","Registrar y notificar cambios hemodinamicos al medico"]},{codigo:"4180",nombre:"Manejo de la hipovolemia",actividades:["Controlar la hemorragia activa con compresion directa","Administrar reposicion de liquidos y hemoderivados segun indicacion","Colocar al paciente en posicion de Trendelenburg modificada","Monitorizar diuresis horaria mediante sondaje vesical","Calentar los liquidos administrados para evitar hipotermia"]},{codigo:"6680",nombre:"Monitorizacion de los signos vitales",actividades:["Monitorizar PA, FC, FR y temperatura de forma continua","Registrar SaO2 con pulsioximetro continuo","Detectar y notificar signos de deterioro hemodinamico","Evaluar respuesta a las intervenciones cada 15 minutos","Documentar tendencia de signos vitales para guiar la reanimacion"]}],npiNoc:[{codigo:"0401",nombre:"Estado circulatorio",indicadores:["Presion arterial sistemica en rango normal","Frecuencia cardiaca en rango normal","Perfusion tisular periferica adecuada","Diuresis horaria > 0.5 ml/kg/h","Llenado capilar < 2 segundos"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"},{codigo:"0602",nombre:"Hidratacion",indicadores:["Turgencia cutanea normal","Membranas mucosas humectadas","Diuresis en rango normal","Hematocrito en rango normal","Ausencia de sed intensa"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"}],complicaciones:["Falla multiorganica (hepatica, renal, pulmonar)","Sindrome de dificultad respiratoria aguda (SDRA)","Coagulacion intravascular diseminada (CID)","Insuficiencia renal aguda olig\xfarica","Isquemia intestinal por hipoperfusion esplacnica","Acidosis lactica grave e irreversible","Paro cardiorrespiratorio","Sindrome de respuesta inflamatoria sistemica (SIRS)"],criteriosAlarma:["PAS < 90 mmHg o caida > 40 mmHg del basal","FC > 130 lpm con deterioro clinico","Diuresis < 0.5 ml/kg/h a pesar de reposicion de liquidos","Deterioro brusco del nivel de conciencia (Glasgow < 14)","SaO2 < 90% con oxigenoterapia","Lactato > 4 mmol/L o acidosis metabolica severa (pH < 7.20)","Sangrado activo no controlable con medidas locales","Ausencia de respuesta a bolo de 2 litros de cristaloide"],emergencyLevel:"critico",isPremium:!0},{id:"pat_tamponamiento_cardiaco",nombre:"Tamponamiento Cardiaco",bodySystemId:"cardiovascular",definicion:"Emergencia cardiovascular caracterizada por la acumulacion de liquido en el espacio pericardico con aumento de la presion intrapericardica que comprime las camaras cardiacas, impide el llenado ventricular y reduce el gasto cardiaco de forma critica.",epidemiologia:"Incidencia estimada de 2 casos por cada 10,000 hospitalizaciones. Las causas mas frecuentes son neoplasias malignas (30-60% de los casos en contexto hospitalario), pericarditis idiopatica, traumatismo toracico, procedimientos invasivos cardiacos (puncion/cateterismo) e insuficiencia renal. La mortalidad sin tratamiento es cercana al 100%; con pericardiocentesis precoz, la supervivencia supera el 90%.",factoresRiesgo:["Neoplasias malignas con metastasis pericardicas (pulmon, mama, linfoma)","Traumatismo toracico cerrado o penetrante","Pericarditis viral, bacteriana o tuberculosa","Diseccion aortica tipo A","Insuficiencia renal cronica con uremia","Hipotiroidismo severo (mixedema)","Lupus eritematoso sistemico y enfermedades autoinmunes","Procedimientos cardiacos invasivos (ablacion, marcapaso, cateterismo)","Anticoagulacion con sangrado pericardico","Radioterapia mediastinal"],fisiopatologia:"El pericardio es una estructura inextensible que no permite aumentos bruscos de volumen. La acumulacion de liquido (sangre, pus, transudado) eleva la presion intrapericardica. Cuando esta presion iguala o supera la presion de llenado de las camaras cardiacas (primero auricula derecha, luego ventriculo derecho), se produce colapso diastolico. Esto impide el llenado ventricular, reduce el volumen de latido y el gasto cardiaco. El organismo compensa con taquicardia y aumento de la resistencia vascular periferica, pero si el derrame progresa sin tratamiento, la hipotension severa y el paro cardiaco son inevitables. La velocidad de acumulacion es mas determinante que el volumen total: un derrame de 150-200 ml acumulado rapidamente puede ser fatal, mientras que derrames cronicos de hasta 2 litros pueden tolerarse.",signosYSintomas:{signos:["Triada de Beck: hipotension arterial + ingurgitacion yugular + ruidos cardiacos apagados","Pulso paradojico (caida de PAS > 10 mmHg durante inspiracion)","Taquicardia sinusal compensatoria","Ingurgitacion yugular con elevacion de la PVC","Ruidos cardiacos velados o apagados en la auscultacion","Taquipnea sin crepitantes pulmonares","Alternancia electrica en el ECG (variacion de amplitud del QRS)","Cardiomegalia en radiografia de torax (imagen en bolsa de agua)"],sintomas:["Disnea progresiva","Dolor toracico que mejora al inclinarse hacia adelante","Sensacion de opresion toracica","Ansiedad y agitacion extrema","Debilidad y fatiga","Sincope o presincope","Nauseas y malestar general","Sensacion de muerte inminente"]},diagnostico:{anamnesis:["Antecedentes de neoplasia, pericarditis, traumatismo o procedimiento cardiaco reciente","Tiempo de evolucion de los sintomas (agudo vs. subagudo)","Disnea de inicio reciente o progresiva","Dolor toracico y su relacion con la postura","Antecedentes de enfermedad autoinmune o renal cronica","Medicacion anticoagulante actual"],examenFisico:["Signos vitales: PA (buscar pulso paradojico), FC, FR, SaO2","Inspeccion yugular: ingurgitacion con signo de Kussmaul","Auscultacion cardiaca: ruidos apagados o velados, ausencia de roce pericardico","Auscultacion pulmonar: campo limpio (diferencia con ICC)","Medicion del pulso paradojico (diferencia de PA entre espiraci\xf3n e inspiracion > 10 mmHg)","Evaluacion del nivel de conciencia"],pruebas:[{nombre:"Ecocardiografia (GOLD STANDARD)",descripcion:"Confirma el derrame pericardico, estima el volumen, detecta el colapso diastolico de camaras derechas y guia la pericardiocentesis",valoresReferencia:"Derrame significativo: > 20 mm en di\xe1stole; colapso de AD o VD en di\xe1stole = tamponamiento",cuidadosEnfermeria:["Preparar y asistir en la realizacion del ecocardiograma urgente a pie de cama","Mantener al paciente en posicion semisentada o de Trendelenburg segun tolerancia","Monitorizar signos vitales durante el procedimiento","Registrar hallazgos y notificar al medico de inmediato"]},{nombre:"Electrocardiograma de 12 derivaciones",descripcion:"Muestra taquicardia sinusal, bajo voltaje del QRS y alternancia electrica (variacion de amplitud latido a latido, altamente especifica)",valoresReferencia:"Bajo voltaje: amplitud QRS < 5 mm en derivaciones de los miembros; alternancia electrica = tamponamiento hasta demostrarse lo contrario",cuidadosEnfermeria:["Realizar ECG urgente a la cabecera del paciente","Correcta colocacion de electrodos evitando artefactos","Notificar hallazgos de bajo voltaje o alternancia electrica de inmediato"]},{nombre:"Radiografia de torax",descripcion:"Muestra cardiomegalia con silueta cardiaca en forma de botella o bolsa de agua; los campos pulmonares estan limpios",valoresReferencia:"Indice cardiotor\xe1cico normal < 0.5; en tamponamiento con derrame cronico: > 0.6",cuidadosEnfermeria:["Posicionar al paciente en sedestacion para la placa posteroanterior si su estado lo permite","Si inestable, realizar placa AP en cama","Transportar con monitorizacion continua si hay que desplazarse al servicio de radiologia"]},{nombre:"Presion venosa central (PVC)",descripcion:"Elevada en tamponamiento cardiaco (> 12 cmH2O); util para confirmar la causa obstructiva del shock",valoresReferencia:"Normal: 5-12 cmH2O; Tamponamiento: > 15-20 cmH2O",cuidadosEnfermeria:["Asistir en la insercion del CVC con tecnica esteril","Verificar la correcta ubicacion del cateter antes de la medicion","Registrar medicion al final de la espiracion para mayor exactitud","Monitorizar tendencia cada hora"]}]},tratamientoMedico:{objetivos:["Descomprimir el pericardio mediante pericardiocentesis urgente","Restaurar el gasto cardiaco y la perfusion sistemica","Mantener al paciente hemodinamicamente estable hasta el procedimiento definitivo","Identificar y tratar la causa subyacente del derrame","Prevenir la recurrencia"],farmacologico:[{nombre:"Solucion fisiologica al 0.9% (carga de volumen)",grupo:"Cristaloide isot\xf3nico - Medida puente",mecanismo:"Aumenta la precarga y el retorno venoso, mejorando transitoriamente el llenado ventricular hasta poder realizar la pericardiocentesis",dosis:"500-1000 ml IV en bolo rapido; medida temporal de soporte hemodinamico",cuidadosEnfermeria:["Administrar el bolo inmediatamente mientras se prepara la pericardiocentesis","Monitorizar la respuesta hemodinamica (PA, FC) cada 5 minutos","No demorar el procedimiento definitivo por la reposicion de liquidos","Canalizar dos vias venosas perifericas de grueso calibre","Tener disponible desfibrilador y material de RCP"]},{nombre:"Dobutamina",grupo:"Inotr\xf3pico - Catecolamina",mecanismo:"Agonista beta-1 que aumenta la contractilidad miocardica y la frecuencia cardiaca; mejora el gasto cardiaco en forma transitoria hasta la descompresion definitiva",dosis:"2.5-10 mcg/kg/min IV en infusion continua; titular segun respuesta hemodinamica",cuidadosEnfermeria:["Administrar por via venosa central o periferica de gran calibre","Monitorizar PA y FC continuamente durante la infusion","Vigilar la aparicion de arritmias (efecto adverso frecuente)","Preparar la infusion con calculo exacto de mcg/kg/min","Tener atropina y antiarritmicos disponibles en cabecera"]},{nombre:"Colchicina",grupo:"Antiinflamatorio - Inhibidor de la polimerizaci\xf3n de la tubulina",mecanismo:"Reduce la inflamacion pericardica inhibiendo la migracion de neutrofilos; previene la recurrencia del derrame pericardico en pericarditis",dosis:"0.5 mg cada 12 horas VO durante 3 meses (mantenimiento post-pericardiocentesis en causa inflamatoria)",cuidadosEnfermeria:["Administrar con alimentos para reducir efectos gastrointestinales","Vigilar diarrea, nauseas y dolor abdominal como efectos adversos frecuentes","Explicar al paciente la importancia de completar el tratamiento para prevenir recurrencias","Monitorizar funcion renal y hepatica en tratamientos prolongados","Verificar interacciones con estatinas y ciclosporina"]}],noFarmacologico:["Pericardiocentesis percutanea urgente guiada por ecocardiografia (tratamiento definitivo)","Ventana pericardica quirurgica si la pericardiocentesis no es tecnicamentposible o hay recurrencia","Posicion de Fowler (semi-incorporado) para mejorar el llenado cardiaco","Evitar ventilacion mecanica con presion positiva (reduce el retorno venoso y agrava el tamponamiento)","Monitorizacion invasiva continua (via arterial, PVC)","Oxigenoterapia con alto flujo","Reposo absoluto en cama hasta la descompresion"]},cuidadosEnfermeria:{valoracion:["Monitorizar signos vitales de forma continua, especialmente buscando pulso paradojico","Evaluar nivel de conciencia y signos de bajo gasto cardiaco","Inspeccionar ingurgitacion yugular y estado de las venas del cuello","Auscultar tonos cardiacos (velados o apagados) y campos pulmonares","Monitorizar diuresis horaria como indicador de perfusion renal","Evaluar el nivel de ansiedad del paciente y familia"],intervenciones:["Canalizar dos vias venosas de grueso calibre de forma inmediata","Preparar y asistir en la pericardiocentesis urgente: material esteril, jeringa de 50 ml, aguja de puncion, guia ecocardiografica","Mantener al paciente en posicion semisentada (Fowler 45\xb0)","Administrar oxigenoterapia con mascarilla de alto flujo (10-15 l/min)","Registrar ECG de 12 derivaciones de forma urgente","Preparar material de RCP avanzada a pie de cama","Administrar analgesia y ansioliticos segun prescripcion medica","Etiquetar y enviar el liquido pericardico extraido para citologia, cultivo y bioquimica"],educacionPaciente:["Explicar al paciente y familia la naturaleza de la emergencia y el procedimiento de pericardiocentesis","Informar sobre la importancia del reposo absoluto durante el episodio agudo","Tras el alta, explicar los signos de recurrencia del derrame (disnea, dolor toracico, ingurgitacion yugular)","Instruir sobre el cumplimiento del tratamiento antiinflamatorio para prevenir recurrencias","Indicar cuando acudir a urgencias de forma inmediata"],monitorizacion:["PA continua con manguito automatico o via arterial invasiva","FC y ritmo cardiaco con monitor ECG continuo","SaO2 con pulsioximetro continuo","PVC cada hora (si tiene CVC)","Diuresis horaria","Vigilar signos de recidiva del derrame pericardico tras la pericardiocentesis","Monitorizar el volumen y caracteristicas del liquido pericardico drenado"]},npiNanda:[{codigo:"00029",nombre:"Disminucion del gasto cardiaco",definicion:"Cantidad de sangre bombeada por el corazon en un minuto inadecuada para satisfacer las demandas metabolicas del organismo",caracteristicasDefinitorias:["Hipotension arterial","Taquicardia","Ruidos cardiacos apagados","Ingurgitacion yugular","Pulso paradojico > 10 mmHg"],factoresRelacionados:["Compresion extrinseca de las camaras cardiacas por liquido pericardico","Reduccion del llenado ventricular diast\xf3lico","Aumento de la presion intrapericardica"]},{codigo:"00146",nombre:"Ansiedad",definicion:"Sensacion vaga e inquietante de malestar o amenaza acompa\xf1ada de una respuesta autonoma",caracteristicasDefinitorias:["Agitacion","Sensacion de muerte inminente","Taquicardia","Disnea subjetiva","Expresion de miedo y angustia"],factoresRelacionados:["Amenaza para el estado de salud y la vida","Situacion de emergencia y entorno hospitalario desconocido","Disnea y molestia fisica"]},{codigo:"00032",nombre:"Patron respiratorio ineficaz",definicion:"La inspiracion y/o espiracion no proporciona una ventilacion adecuada",caracteristicasDefinitorias:["Disnea","Taquipnea","Uso de musculatura accesoria","SaO2 reducida"],factoresRelacionados:["Reduccion del gasto cardiaco por compresion pericardica","Hipoxia secundaria a hipoperfusion pulmonar","Dolor toracico"]}],npiNic:[{codigo:"4044",nombre:"Cuidados cardiacos agudos",actividades:["Monitorizar signos vitales y ritmo cardiaco de forma continua","Preparar y asistir en la pericardiocentesis urgente","Administrar liquidos y farmacos segun prescripcion medica","Mantener al paciente en posicion semisentada","Tener disponible material de RCP avanzada a pie de cama"]},{codigo:"5820",nombre:"Disminucion de la ansiedad",actividades:["Explicar todos los procedimientos al paciente de forma clara y tranquilizadora","Mantener presencia constante del personal de enfermeria","Usar tecnicas de comunicacion terapeutica","Involucrar a la familia si el estado del paciente lo permite","Administrar ansioliticos segun prescripcion si la ansiedad es severa"]},{codigo:"3350",nombre:"Monitorizacion respiratoria",actividades:["Monitorizar SaO2 de forma continua","Administrar oxigenoterapia con mascarilla de alto flujo","Evaluar patron respiratorio y uso de musculatura accesoria","Registrar y notificar deterioro respiratorio","Preparar material de intubacion si se requiere ventilacion invasiva"]}],npiNoc:[{codigo:"0400",nombre:"Efectividad de la bomba cardiaca",indicadores:["Presion arterial sistemica en rango normal","Frecuencia cardiaca en rango normal","Ausencia de ingurgitacion yugular","Ausencia de pulso paradojico > 10 mmHg","Tonos cardiacos audibles y normales"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"},{codigo:"1402",nombre:"Autocontrol de la ansiedad",indicadores:["Refiere disminucion de la ansiedad","Frecuencia cardiaca en rango normal","Ausencia de agitacion","Capaz de cooperar con el personal sanitario"],escala:"1=Nunca demostrado, 2=Raramente demostrado, 3=A veces demostrado, 4=Frecuentemente demostrado, 5=Siempre demostrado"}],complicaciones:["Paro cardiorrespiratorio por actividad electrica sin pulso (AESP)","Shock cardiogenico irreversible","Disociacion electromec\xe1nica","Recurrencia del derrame pericardico","Pericarditis constrictiva como secuela cronica","Fistula o laceraci\xf3n cardiaca en pericardiocentesis de urgencia","Infeccion del espacio pericardico post-procedimiento","Progresion a falla multiorganica"],criteriosAlarma:["Triada de Beck completa: hipotension + ingurgitacion yugular + ruidos apagados","Pulso paradojico > 10 mmHg","Deterioro brusco del nivel de conciencia","PAS < 80 mmHg que no responde a bolo de liquidos","FC > 130 lpm con signos de bajo gasto","SaO2 < 90% con oxigenoterapia","Alternancia electrica en ECG con hipotension","Paro cardiorrespiratorio"],emergencyLevel:"critico",isPremium:!0},{id:"pat_aneurisma_aorta",nombre:"Aneurisma de Aorta",bodySystemId:"cardiovascular",definicion:"Dilatacion patologica y permanente de la pared aortica que supera el 50% del diametro normal esperado para la edad y sexo del paciente. Segun localizacion se clasifica en aneurisma de aorta toracica (AAT) o abdominal (AAA). El riesgo de rotura aumenta exponencialmente con el diametro y representa una emergencia quirurgica con mortalidad superior al 80%.",epidemiologia:"El AAA afecta al 4-8% de los hombres mayores de 65 a\xf1os y al 1-1.5% de las mujeres de la misma edad. El AAT tiene una incidencia de 6-10 casos por 100,000 habitantes/ano. La rotura de AAA tiene una mortalidad global del 85-90% (incluyendo muertes prehospitalarias). Es la 13ra causa de muerte en EEUU. El cribado ecografico en varones fumadores mayores de 65 a\xf1os reduce la mortalidad especifica en un 40-50%.",factoresRiesgo:["Tabaquismo (factor de riesgo mas importante para AAA)","Edad avanzada (> 65 a\xf1os)","Sexo masculino","Hipertension arterial","Ateroesclerosis severa","Antecedentes familiares de aneurisma aortico","Sindrome de Marfan o Ehlers-Danlos (aneurisma toracico)","Valvula aortica bicuspide (aneurisma toracico)","Dislipemia","Traumatismo toracico o abdominal previo"],fisiopatologia:"La pared aortica normal contiene una rica malla de elastina y colageno en la media que le confiere su resistencia y elasticidad. En el aneurisma, la degradacion enzimatica de estas proteinas por metaloproteasas de la matriz (MMPs) y la inflamacion cronica de la adventicia debilitan la pared. La degeneracion quistica de la media es la causa principal en aorta toracica; la ateroesclerosis y la inflamacion predominan en la aorta abdominal. Segun la Ley de Laplace, la tension en la pared es directamente proporcional al radio: a mayor diametro, mayor tension, mayor riesgo de expansion y rotura. La rotura aortica genera hemorragia retroperitoneal masiva (aorta abdominal) o hemotorax masivo (aorta toracica), con mortalidad intraoperatoria del 30-50% incluso en centros de referencia.",signosYSintomas:{signos:["Masa pulsatil abdominal palpable en aneurisma abdominal (fosa periumbilical)","Soplo abdominal o toracico a la auscultacion","Diferencia de PA entre miembros superiores en aneurisma toracico","Ensanchamiento mediastinico en radiografia de torax (AAT)","Pulsos femorales disminuidos por compresion del aneurisma","Signos de shock hipovolemico en rotura: hipotension, taquicardia, palidez"],sintomas:["Aneurisma no roto frecuentemente ASINTOMATICO","Dolor toracico sordo o transfictivo (aneurisma toracico) irradiado a espalda o escapula","Dolor abdominal o lumbar sordo y persistente (aneurisma abdominal)","Dolor de inicio brusco, severo e intolerable: SIGNO DE ALERTA DE ROTURA INMINENTE","Disfagia por compresion esofagica (AAT)","Ronquera por compresion del nervio laringeo recurrente (AAT)","Sindrome de vena cava superior por compresion (AAT)","Nauseas y vomitos por compresion duodenal (AAA)"]},clasificacion:{nombre:"Clasificacion segun localizacion y diametro",tipos:[{nombre:"AAA peque\xf1o",descripcion:"Diametro 3-5.4 cm. Seguimiento ecografico cada 6-12 meses. Riesgo de rotura < 1%/ano."},{nombre:"AAA moderado",descripcion:"Diametro 5-5.9 cm. Considerar reparacion quirurgica electiva segun comorbilidades. Riesgo de rotura 3-15%/ano."},{nombre:"AAA grande - indicacion quirurgica",descripcion:"Diametro >= 5.5 cm en hombres o >= 5 cm en mujeres. Indicacion de cirugia electiva. Riesgo de rotura > 25%/ano."},{nombre:"AAA roto",descripcion:"Emergencia quirurgica inmediata. Mortalidad > 80% global. Trias de Szilagyi: dolor abdominal/lumbar brusco + masa pulsatil + hipotension."},{nombre:"Aneurisma aorta toracica (AAT)",descripcion:"Indica cirugia cuando > 5.5 cm (o > 5 cm en Marfan/bicuspide). Mayor riesgo de diseccion que rotura."}]},diagnostico:{anamnesis:["Antecedentes de tabaquismo (cantidad y tiempo)","Historia familiar de aneurisma aortico o muerte subita por causas cardiovasculares","Enfermedades del tejido conectivo (Marfan, Ehlers-Danlos)","HTA y tratamiento actual","Descripcion detallada del dolor: inicio, localizacion, irradiacion, intensidad","Cirugias aorticas o cardiovasculares previas"],examenFisico:["Palpacion abdominal bimanual buscando masa pulsatil expansiva a nivel periumbilical","Auscultacion de soplos abdominales o femorales","Medicion de PA en ambos brazos (diferencia > 20 mmHg es significativa en AAT)","Palpacion de pulsos perifericos (femoral, popl\xedteo, tibial posterior, pedios)","Auscultacion cardiaca y pulmonar","Signos de isquemia de miembros inferiores por embolizacion distal"],pruebas:[{nombre:"Ecografia abdominal (cribado y seguimiento de AAA)",descripcion:"Metodo de eleccion para el diagnostico y seguimiento del AAA; alta sensibilidad (98%) y especificidad (100%); no irradia",valoresReferencia:"Diametro aortico normal infrarrenal: < 3 cm; AAA: > 3 cm o > 150% del diametro normal",cuidadosEnfermeria:["Indicar ayuno de 6-8 horas para reducir el gas intestinal y mejorar la ventana ecografica","Posicionar al paciente en decubito supino","Evitar presion abdominal excesiva en aneurismas grandes","Registrar y comunicar diametros al medico responsable"]},{nombre:"Angiotomografia computarizada de aorta (angioTC)",descripcion:"Estudio de eleccion para la planificacion quirurgica y diagnostico de complicaciones; define morfologia, extension, relacion con ramas viscerales y presencia de trombo mural",valoresReferencia:"Define diametro maximo, longitud del cuello, angulacion y anatomia vascular para EVAR o cirugia abierta",cuidadosEnfermeria:["Evaluar funcion renal (creatinina) antes de administrar contraste iodado","Verificar alergias al contraste y premedicar con corticoides si precisa","Asegurar hidratacion adecuada pre y post-procedimiento","Canalizar via venosa de 18G como minimo para la inyeccion del contraste","Monitorizar al paciente durante el traslado si esta hemodinamicamente inestable"]},{nombre:"Radiografia de torax",descripcion:"En AAT: ensanchamiento mediastinico, calcificaciones en la pared aortica, desplazamiento de la traquea",valoresReferencia:"Mediastino normal < 8 cm de anchura; ensanchamiento > 8 cm en proyeccion AP es sospechoso",cuidadosEnfermeria:["Posicionar correctamente al paciente en sedestacion o decubito","Registrar los hallazgos y notificar ensanchamiento mediastinico urgente al medico","Si hay sospecha de rotura, no retrasar traslado a cirugia por esperar radiografia"]},{nombre:"Analitica urgente en rotura sospechada",descripcion:"Hemograma (anemia por hemorragia), coagulacion, grupo y crossmatch para transfusion inmediata, lactato, funcion renal",valoresReferencia:"Hb < 8 g/dL indica hemorragia significativa; lactato > 2 mmol/L indica hipoperfusion",cuidadosEnfermeria:["Extraer muestras en el menor tiempo posible, de forma simultanea a la canalizacion de vias venosas","Solicitar 6-8 unidades de CGR crossmatched y PFC si se sospecha rotura","Enviar con etiqueta urgente al laboratorio","Notificar al banco de sangre para activar el protocolo de transfusion masiva"]}]},tratamientoMedico:{objetivos:["En aneurisma no roto: controlar factores de riesgo y vigilar progression para decidir cirugia electiva","En aneurisma roto: control quirurgico inmediato de la hemorragia para salvar la vida","Mantener PA en objetivo (PAS 100-120 mmHg) para reducir tension en la pared aortica","Prevenir la expansion del aneurisma mediante control de HTA y cese del tabaquismo","Reducir el riesgo cardiovascular global"],farmacologico:[{nombre:"Metoprolol (betabloqueante)",grupo:"Betabloqueante cardioselectivo - Antihipertensivo",mecanismo:"Bloquea receptores beta-1 adrenergicos reduciendo la FC y la fuerza de contraccion cardiaca, disminuyendo el estres mecanico sobre la pared aortica (dP/dt); de primera eleccion en aneurisma toracico y sindrome de Marfan",dosis:"25-200 mg/dia VO en 1-2 tomas; en urgencia hipertensiva: metoprolol IV 5 mg cada 5 min hasta 3 dosis",cuidadosEnfermeria:["Medir PA y FC antes de cada dosis; no administrar si FC < 55 lpm o PAS < 90 mmHg","Vigilar broncoespasmo en pacientes con EPOC o asma","No suspender bruscamente para evitar efecto rebote hipertensivo","Monitorizar glucemia en diabeticos (puede enmascarar hipoglucemia)","Controlar signos de insuficiencia cardiaca descompensada"]},{nombre:"Atorvastatina",grupo:"Estatina - Hipolipemiante",mecanismo:"Inhibe la HMG-CoA reductasa reduciendo la sintesis hepatica de colesterol; posee efectos pleiotropicos antiinflamatorios y estabilizadores de placa que reducen la velocidad de expansion del aneurisma",dosis:"40-80 mg/dia VO, dosis nocturna",cuidadosEnfermeria:["Administrar preferentemente por la noche (maxima sintesis de colesterol nocturna)","Vigilar mialgia, debilidad muscular o mioglobinuria (miopatia por estatinas)","Controlar transaminasas hepaticas al inicio y durante el tratamiento","Informar al paciente que los beneficios son a largo plazo y no suspender sin consultar","Verificar interacciones con anticoagulantes y otros hipolipemiantes"]},{nombre:"Acido acetilsalicilico (AAS)",grupo:"Antiagregante plaquetario - AINE",mecanismo:"Inhibe irreversiblemente la COX-1 plaquetaria, reduciendo la agregacion plaquetaria y el riesgo de eventos tromboembolicos distales y cardiovasculares en pacientes con aneurisma y ateroesclerosis asociada",dosis:"100 mg/dia VO con alimentos",cuidadosEnfermeria:["Administrar con alimentos o con un vaso de leche para reducir la irritacion gastrica","Vigilar signos de sangrado gastrointestinal: heces oscuras, hematemesis, dolor epigastrico","Suspender 7-10 dias antes de la cirugia electiva segun indicacion del cirujano","Contraindicado en pacientes con ulcera peptica activa o coagulopatia","Informar al paciente de no combinar con AINEs sin consultar al medico"]}],noFarmacologico:["Cese absoluto del tabaquismo (reduce la tasa de expansion del aneurisma en un 30-40%)","Control estricto de la HTA (objetivo PAS 100-120 mmHg)","Dieta baja en grasas saturadas y sal","Actividad fisica moderada; evitar esfuerzos isonetricos intensos (maniobra de Valsalva)","Reparacion endovascular (EVAR) o cirugia abierta segun indicacion y anatomia","Seguimiento ecografico cada 6-12 meses en AAA peque\xf1o (3-5.4 cm)","En AAA roto: control de PA permisiva (PAS 70-90 mmHg) hasta cirugia para no aumentar la hemorragia"]},cuidadosEnfermeria:{valoracion:["Medir PA en ambos brazos; registrar diferencias significativas","Palpar pulsos perifericos: femoral, popliteo, tibial posterior, pedios","Valorar dolor abdominal o lumbar: localizacion, intensidad (EVA), irradiacion, inicio","Evaluar signos de shock (PA, FC, color, diuresis) ante sospecha de rotura","Valorar nivel de conciencia y signos neurologicos en AAT","Identificar factores de riesgo cardiovascular presentes"],intervenciones:["Monitorizar PA de forma continua en pacientes sintomaticos","Administrar antihipertensivos segun prescripcion para mantener PAS en objetivo","Vigilar y registrar caracteristicas del dolor para detectar cambio subito que indique rotura","Preparar al paciente para cirugia urgente o electiva segun indicacion","En sospecha de rotura: activar codigo de urgencia, canalizar dos vias gruesas, solicitar hemoderivados urgentes","Proporcionar apoyo emocional y educacion sobre la enfermedad y el plan terapeutico","Coordinar con cirujano vascular, anestesiologia y banco de sangre ante urgencia","Asegurar ayuno preoperatorio y administrar medicacion preoperatoria segun protocolo"],educacionPaciente:["Explicar la importancia critica del cese del tabaquismo para frenar la progression del aneurisma","Instruir sobre el control domiciliario de la PA y los valores objetivo","Indicar que deben acudir a urgencias de inmediato ante dolor abdominal o lumbar brusco e intenso","Explicar el plan de seguimiento ecografico y la importancia de no faltar a los controles","Restricciones de actividad: evitar esfuerzos que impliquen maniobra de Valsalva (levantar pesos, esfuerzo defecatorio)","Informar sobre se\xf1ales de alarma de embolizacion distal: dedos del pie frios, dolores, cambios de color"],monitorizacion:["PA en ambos brazos cada 4-8 horas (o continua si inestable)","Pulsos perifericos bilaterales cada 4-8 horas","Dolor: EVA cada 4 horas y ante cualquier cambio brusco","Diuresis horaria en pacientes con sospecha de compromiso de arterias renales","Control ecografico o de angioTC segun protocolo de seguimiento","Perfil lipidico y HbA1c en el seguimiento ambulatorio","Funcion renal periodica en tratamiento con contraste o antihipertensivos"]},npiNanda:[{codigo:"00204",nombre:"Perfusion tisular periferica ineficaz",definicion:"Disminucion de la circulacion sanguinea en los capilares perifericos que puede comprometer la salud",caracteristicasDefinitorias:["Pulsos perifericos disminuidos o ausentes","Cambios de color de la piel distal (palidez, cianosis)","Frialdad de extremidades distales","Dolor isquemico en reposo o claudicacion"],factoresRelacionados:["Obstruccion arterial por trombo mural del aneurisma","Embolizacion distal de material aterotromb\xf3tico","Compresion de arterias iliacas por el saco aneurismatico"]},{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable ocasionada por una lesion tisular real o potencial; inicio subito o lento de cualquier intensidad de leve a grave con un final anticipado",caracteristicasDefinitorias:["Informe verbal de dolor abdominal o lumbar","Gestos de dolor y cambios en la expresion facial","FC y PA elevadas","Posicion antalgica"],factoresRelacionados:["Distension y tension en la pared del aneurisma","Isquemia por compresion de estructuras adyacentes","Rotura o fisuracion de la pared aortica"]},{codigo:"00035",nombre:"Riesgo de lesion",definicion:"Vulnerable a las lesiones como consecuencia de condiciones ambientales que interaccionan con los recursos adaptativos y defensivos del individuo que puede comprometer la salud",caracteristicasDefinitorias:["Diametro del aneurisma en zona de riesgo de rotura","PA no controlada","Tabaquismo activo"],factoresRelacionados:["Debilidad estructural de la pared aortica","Factores de riesgo cardiovascular no controlados","Falta de adherencia al seguimiento medico"]}],npiNic:[{codigo:"4062",nombre:"Cuidados circulatorios: dispositivo de asistencia mecanica",actividades:["Monitorizar PA en ambos brazos y pulsos perifericos bilaterales","Vigilar signos de isquemia de miembros inferiores","Administrar antihipertensivos para mantener PA en objetivo","Registrar y notificar diferencias de PA entre brazos","Preparar al paciente para procedimientos vasculares segun indicacion"]},{codigo:"1400",nombre:"Manejo del dolor",actividades:["Evaluar el dolor con escala EVA cada 4 horas y ante cualquier cambio","Administrar analgesia segun prescripcion medica","Notificar de inmediato todo dolor abdominal o lumbar brusco e intenso","Posicionar al paciente para mayor confort","Documentar caracteristicas del dolor y respuesta al tratamiento"]},{codigo:"5510",nombre:"Educacion para la salud",actividades:["Explicar la importancia del cese del tabaquismo y como solicitarlo","Ense\xf1ar el control domiciliario de la PA y los valores objetivo","Instruir sobre signos de alarma de rotura o embolizacion","Educar sobre restricciones de actividad fisica","Motivar el cumplimiento del seguimiento ecografico periodico"]}],npiNoc:[{codigo:"0407",nombre:"Perfusion tisular: periferica",indicadores:["Pulsos perifericos presentes y simetricos","Color de la piel distal normal","Temperatura distal conservada","Ausencia de dolor isquemico en reposo","Llenado capilar < 2 segundos"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"},{codigo:"1605",nombre:"Control del riesgo: enfermedad cardiovascular",indicadores:["Controla la presion arterial segun objetivo","Cumple con el cese del tabaquismo","Acude a controles ecograficos periodicos","Toma la medicacion prescrita correctamente","Identifica signos de alarma de rotura"],escala:"1=Nunca demostrado, 2=Raramente demostrado, 3=A veces demostrado, 4=Frecuentemente demostrado, 5=Siempre demostrado"}],complicaciones:["Rotura aortica con hemorragia retroperitoneal o intracavitaria masiva","Diseccion aortica aguda","Embolizacion distal (isquemia de miembros inferiores, ri\xf1ones, intestino)","Fistula aortoent\xe9rica (comunicacion con duodeno con hemorragia digestiva masiva)","Fistula aortocava (comunicacion con vena cava inferior)","Trombosis del saco aneurismatico con oclusion aortica aguda","Insuficiencia renal por isquemia de arterias renales","Isquemia mesenterica aguda"],criteriosAlarma:["Dolor abdominal o lumbar brusco, severo e intolerable (signo de rotura inminente)","Hipotension arterial asociada a dolor abdominal","Expansion rapida del aneurisma > 5 mm en 6 meses en el seguimiento ecografico","Signos de embolizacion distal: pie frio, livedo reticularis, dedo azul","Sincope o presincope asociado a dolor abdominal","Cualquier signo de shock con masa abdominal pulsatil conocida","PA sistolica < 90 mmHg en paciente con AAA conocido","Inicio de sintomas neurologicos en aneurisma toracico (paralisis, paraplejia)"],emergencyLevel:"critico",isPremium:!0},{id:"pat_sepsis",nombre:"Sepsis",bodySystemId:"inmunologico",definicion:"Disfuncion organica potencialmente mortal causada por una respuesta desregulada del huesped a la infeccion. Se define por un aumento del puntaje SOFA >= 2 en presencia de infeccion sospechada o confirmada. El shock septico se caracteriza por hipotension que requiere vasopresores y lactato > 2 mmol/L a pesar de resucitacion adecuada con fluidos.",epidemiologia:"Incidencia global de 31,5 millones de casos anuales con aproximadamente 5,3 millones de muertes. En Argentina, es responsable del 10-15% de los ingresos a Unidades de Cuidados Intensivos. La mortalidad del shock septico oscila entre 40-60%. Es la principal causa de muerte intrahospitalaria no cardiaca.",factoresRiesgo:["Edad extrema (neonatos y ancianos)","Inmunosupresion (VIH, corticoterapia, quimioterapia)","Diabetes mellitus","Insuficiencia renal cronica","Cirrosis hepatica","Neoplasias hematologicas","Procedimientos invasivos (cateteres, ventilacion mecanica)","Cirugia reciente o trauma","Malnutricion","Hospitalizacion prolongada"],fisiopatologia:"Ante un foco infeccioso, el organismo activa una respuesta inflamatoria sist\xe9mica desproporcionada: los patogenos (bacteria, virus, hongo) o sus productos (LPS, peptidoglucano) activan receptores Toll-like en macrofagos y neutrofilos, desencadenando liberacion masiva de citocinas proinflamatorias (TNF-alfa, IL-1, IL-6). Esto produce vasodilatacion generalizada, aumento de la permeabilidad capilar y formacion de microtrombos en la microcirculacion (CID). El resultado es hipoperfusion tisular con deuda de oxigeno, metabolismo anaerobico (elevacion de lactato) y disfuncion multiorganica progresiva (pulmones, ri\xf1ones, higado, cerebro, coagulacion).",signosYSintomas:{signos:["Fiebre > 38.3 C o hipotermia < 36 C","Taquicardia > 90 lpm","Taquipnea > 22 rpm","Hipotension: PAS < 90 mmHg o PAM < 70 mmHg","Alteracion del sensorio (confusion, somnolencia)","Oliguria < 0.5 mL/kg/h durante 2 horas","Ictericia (disfuncion hepatica)","Livedo reticularis o piel marmolada","Tiempo de relleno capilar > 3 segundos","Leucocitosis > 12.000 o leucopenia < 4.000/mm3"],sintomas:["Escalofrios intensos","Debilidad y postration extrema","Nauseas y vomitos","Dolor referido al foco infeccioso","Dificultad respiratoria progresiva","Sensacion de frio a pesar de fiebre","Confusion o desorientacion","Ansiedad y agitacion"]},clasificacion:{nombre:"Criterios Sepsis-3 (2016) / Puntaje SOFA",tipos:[{nombre:"Infeccion",descripcion:"Presencia de microorganismo patogeno en tejido normalmente esteril sin respuesta sistemica significativa"},{nombre:"Sepsis",descripcion:"Disfuncion organica aguda con SOFA >= 2 secundaria a infeccion. Mortalidad ~10%"},{nombre:"Shock septico",descripcion:"Sepsis con hipotension que requiere vasopresores para mantener PAM >= 65 mmHg y lactato > 2 mmol/L a pesar de reposicion adecuada. Mortalidad > 40%"}]},diagnostico:{anamnesis:["Identificar foco infeccioso probable (pulmonar, urinario, abdominal, cutaneo)","Antecedentes de inmunosupresion o comorbilidades","Tiempo de evolucion de los sintomas","Procedimientos invasivos recientes","Hospitalizacion previa o antibioticos recientes","Viajes o exposicion a animales"],examenFisico:["Signos vitales completos (PA, FC, FR, Temp, SatO2)","Evaluacion neurologica (escala de Glasgow)","Busqueda del foco infeccioso (auscultacion pulmonar, palpacion abdominal, inspeccion de heridas y cateteres)","Evaluacion de perfusion periferica (relleno capilar, color de piel)","Medicion de diuresis","Valoracion de ingurgitacion yugular y presion venosa central"],pruebas:[{nombre:"Lactato serico",descripcion:"Marcador de hipoperfusion tisular y metabolismo anaerobico. Esencial para diagnostico de shock septico",valoresReferencia:"Normal < 2 mmol/L; Sepsis grave 2-4 mmol/L; Shock septico > 4 mmol/L",cuidadosEnfermeria:["Extraer muestra antes de iniciar fluidos si es posible","Enviar muestra inmediatamente al laboratorio (metabolismo continua ex vivo)","Registrar hora exacta de extraccion","Repetir a las 2 horas para valorar respuesta al tratamiento","Muestras arteriales son mas precisas que venosas"]},{nombre:"Hemocultivos (2 sets)",descripcion:"Identificacion del microorganismo causante para guiar antibioticoterapia definitiva",valoresReferencia:"Negativo en condiciones normales. Positividad orienta antibiotico especifico",cuidadosEnfermeria:["Extraer 2 sets (4 frascos) antes de iniciar antibioticos","Tecnica de asepsia estricta en la puncion","Inocular primero el frasco aerobio, luego el anaerobio","Volumen optimo: 10 mL por frasco en adultos","Registrar hora, sitio de extraccion y temperatura del paciente","No demorar antibioticos mas de 1 hora por esperar hemocultivos"]},{nombre:"Puntaje SOFA",descripcion:"Sequential Organ Failure Assessment: evalua disfuncion de 6 organos. Confirmacion diagnostica de sepsis",valoresReferencia:"SOFA 0-6 sin sepsis; SOFA >= 2 = sepsis; SOFA >= 11 mortalidad > 80%",cuidadosEnfermeria:["Calcular al ingreso y cada 24-48 horas","Requiere: PaO2/FiO2, plaquetas, bilirrubina, PAM, Glasgow, creatinina","Registrar todos los parametros necesarios de forma ordenada","Comunicar empeoramiento del SOFA al medico de inmediato"]},{nombre:"Procalcitonina (PCT)",descripcion:"Biomarcador de infeccion bacteriana sistemica, util para guiar duracion de antibioticoterapia",valoresReferencia:"Normal < 0.5 ng/mL; Sepsis bacteriana > 2 ng/mL; Sepsis grave > 10 ng/mL",cuidadosEnfermeria:["No requiere ayuno","Extraer junto con otros laboratorios de ingreso","Repetir a los 3-5 dias para evaluar respuesta","Caida > 80% del valor inicial orienta a descalar antibioticos"]},{nombre:"Gasometria arterial",descripcion:"Evalua oxigenacion, ventilacion y equilibrio acido-base; detecta acidosis lactica",valoresReferencia:"pH 7.35-7.45; PaO2 80-100 mmHg; PaCO2 35-45 mmHg; HCO3 22-26 mEq/L; EB -2 a +2",cuidadosEnfermeria:["Tecnica de puncion arterial radial con angulo de 45 grados","Aplicar presion 5-10 minutos post-puncion","Enviar muestra inmediatamente en hielo","Registrar FiO2 del paciente al momento de la extraccion","Vigilar sangrado en sitio de puncion"]}]},tratamientoMedico:{objetivos:["Estabilizacion hemodinamica con PAM >= 65 mmHg en primera hora","Erradicacion del foco infeccioso","Soporte de organos en disfuncion","Normalizacion del lactato (< 2 mmol/L en 6 horas)","Prevencion de disfuncion multiorganica"],farmacologico:[{nombre:"Piperacilina-Tazobactam",grupo:"Antibiotico betalactamico + inhibidor de betalactamasa (terapia empirica amplio espectro)",mecanismo:"Inhibe la sintesis de pared bacteriana; el tazobactam protege a la piperacilina de la inactivacion por betalactamasas. Cubre gram negativos incluyendo Pseudomonas y gram positivos",dosis:"4.5 g IV cada 6-8 horas en infusion extendida de 4 horas para sepsis grave",cuidadosEnfermeria:["Administrar en infusion extendida (4h) para maximizar efecto farmacodinamico PK/PD","Verificar alergias a penicilinas y cefalosporinas antes de administrar","Monitorizar funcion renal: ajustar dosis si ClCr < 40 mL/min","Vigilar signos de superinfeccion por Candida (mucosa oral, heces)","Reconstituir en 250 mL de SF o SG5%, no mezclar con aminoglucosidos","Vigilar electrolitos: contiene sodio significativo (2.35 mEq por gramo)"]},{nombre:"Norepinefrina",grupo:"Vasopresor de primera linea (catecolamina alfa y beta adrenergica)",mecanismo:"Potente agonista alfa-1 adrenergico que produce vasoconstriccion arteriolar y venosa, elevando la resistencia vascular periferica y la PAM. Minimo efecto cronotopico",dosis:"0.01-3 mcg/kg/min en infusion IV continua por via central; titular hasta PAM >= 65 mmHg",cuidadosEnfermeria:["OBLIGATORIO administrar por via central o via intraosea; nunca via periferica (riesgo de necrosis tisular)","Usar bomba de infusion de jeringa con precision de decimas de mL/h","Monitorizar PA invasiva (linea arterial) o no invasiva cada 5-15 minutos","Vigilar isquemia distal: color, temperatura y pulsos en extremidades cada hora","No suspender abruptamente; descalar de forma gradual (reducir 0.01-0.02 mcg/kg/min cada 30 min)","Vigilar extravasacion: el contacto con tejido produce necrosis severa"]},{nombre:"Cristaloides balanceados (Ringer Lactato / PlasmaLyte)",grupo:"Fluido de resucitacion (cristaloide isotonico balanceado)",mecanismo:"Expansion del volumen intravascular, restauracion de precarga cardiaca y mejora del gasto cardiaco. Los balanceados tienen menor riesgo de acidosis hipercloremica que el SF 0.9%",dosis:"Bolo inicial 30 mL/kg en primera hora para hipoperfusion; guiar resucitacion posterior por respuesta a fluidos y parametros hemodinamicos",cuidadosEnfermeria:["Administrar los primeros 30 mL/kg en 1 hora mediante infusion rapida","Evaluar respuesta a fluidos con parametros dinamicos: variacion del pulso, test de elevacion pasiva de piernas","Monitorizar signos de sobrecarga hidrica: estertores pulmonares, ingurgitacion yugular, SatO2","Registrar balance hidrico horario (ingresos y egresos)","No continuar resucitacion agresiva si hay signos de sobrecarga (evitar 'tercer espacio')","Pesar al paciente diariamente para detectar retencion de fluidos"]}],noFarmacologico:["Bundle de sepsis 1 hora: hemocultivos, lactato, antibioticos, fluidos","Control del foco: drenaje de abscesos, retiro de cateteres infectados, desbridamiento","Soporte ventilatorio segun necesidad (oxigenoterapia a mascarilla, VNI, intubacion)","Monitorizacion invasiva en UCI: linea arterial, CVC, sonda vesical con urometro","Nutricion enteral precoz (primeras 24-48 horas) si tolera","Profilaxis de trombosis venosa profunda con heparina de bajo peso molecular","Proteccion gastrica con inhibidores de bomba de protones","Control glucemico estricto (objetivo 140-180 mg/dL)"]},cuidadosEnfermeria:{valoracion:["Monitorizar signos vitales completos cada 15-30 minutos en la fase aguda","Calcular y registrar puntaje SOFA y qSOFA al ingreso y cada 24 horas","Evaluar nivel de conciencia con escala de Glasgow cada hora","Medir diuresis horaria con urometro (objetivo >= 0.5 mL/kg/h)","Valorar perfusion periferica: color, temperatura, relleno capilar cada hora","Registrar temperatura central y periferica (gradiente indica vasoconstriccion)","Evaluar dolor con escala validada (EVA, conductual en sedados)"],intervenciones:["Canalizar dos vias venosas perifericas de gran calibre (14-16 G) de forma inmediata","Colaborar con colocacion de via venosa central y linea arterial","Administrar antibioticos dentro de la primera hora del diagnostico","Asegurar permeabilidad de via aerea y administrar oxigeno suplementario","Preparar y titular vasopresores segun protocolo de UCI","Registrar balance hidrico horario y acumulado","Implementar medidas de control de infeccion: precauciones estandar y especificas","Coordinar estudios urgentes: cultivos, laboratorio, imagenes"],educacionPaciente:["Explicar al paciente y familia la gravedad y el plan de tratamiento de forma comprensible","Informar sobre la importancia de comunicar cambios en el estado de conciencia","Educar sobre se\xf1ales de alarma de deterioro","Orientar a la familia sobre el entorno de UCI y visitas","Explicar la necesidad de multiples procedimientos invasivos y su proposito"],monitorizacion:["Signos vitales cada 15-30 min en fase aguda, cada 1-2 horas en estabilizacion","Lactato arterial a las 0, 2 y 6 horas del diagnostico","Diuresis horaria con urometro","Balance hidrico cada 6-12 horas","Laboratorio: hemograma, coagulacion, funcion renal y hepatica, electrolitos cada 6-12 horas","Saturacion de oxigeno continua por pulsioximetria","Temperatura cada 2 horas","Revision del foco infeccioso cada 12-24 horas"]},npiNanda:[{codigo:"00007",nombre:"Hipertermia",definicion:"Temperatura corporal central superior al rango normal diurno a causa de un fallo en la termorregulacion",caracteristicasDefinitorias:["Temperatura corporal > 38.3 C","Piel caliente al tacto","Taquicardia","Taquipnea"],factoresRelacionados:["Proceso infeccioso sistemico","Respuesta inflamatoria desregulada","Liberacion de pirogenos endogenos (IL-1, IL-6, TNF-alfa)"]},{codigo:"00029",nombre:"Disminucion del gasto cardiaco",definicion:"Cantidad de sangre bombeada por el corazon insuficiente para satisfacer las demandas metabolicas del organismo",caracteristicasDefinitorias:["Hipotension arterial","Taquicardia compensadora","Reduccion del relleno capilar","Oliguria"],factoresRelacionados:["Vasodilatacion periferica masiva (distribucion alterada)","Hipovolemia relativa por fuga capilar","Depresion miocardica septica"]},{codigo:"00032",nombre:"Patron respiratorio ineficaz",definicion:"La inspiracion y/o espiracion no proporciona una ventilacion adecuada",caracteristicasDefinitorias:["Taquipnea > 22 rpm","Uso de musculos accesorios","Saturacion de oxigeno disminuida","Gasometria con hipoxemia"],factoresRelacionados:["Lesion pulmonar aguda por inflamacion sistemica","Acidosis metabolica con compensacion respiratoria","Fatiga muscular por hipoperfusion"]},{codigo:"00002",nombre:"Desequilibrio nutricional: ingestion inferior a las necesidades",definicion:"Ingestion de nutrientes insuficiente para satisfacer las necesidades metabolicas",caracteristicasDefinitorias:["Incapacidad para ingerir alimentos","Balance nitrogenado negativo","Perdida de masa muscular"],factoresRelacionados:["Estado hipercatabolico septico","Nauseas y vomitos asociados","Necesidad de ayuno para procedimientos"]}],npiNic:[{codigo:"6650",nombre:"Vigilancia",actividades:["Monitorizar signos vitales con la frecuencia establecida segun la gravedad","Calcular puntaje SOFA periodicamente","Detectar cambios en el nivel de conciencia","Vigilar diuresis horaria como indicador de perfusion renal"]},{codigo:"4150",nombre:"Regulacion hemodinamica",actividades:["Administrar fluidos de resucitacion segun protocolo bundle de sepsis","Titular vasopresores para mantener PAM >= 65 mmHg","Monitorizar respuesta a fluidos con parametros dinamicos","Registrar balance hidrico cada hora"]},{codigo:"6540",nombre:"Control de infecciones",actividades:["Aplicar precauciones estandar en todos los procedimientos","Asegurar administracion de antibioticos en tiempo (primera hora)","Vigilar signos de superinfeccion o infeccion por hongos","Mantener tecnica aseptica en cuidado de cateteres y accesos invasivos"]},{codigo:"3350",nombre:"Monitorizacion respiratoria",actividades:["Mantener via aerea permeable","Administrar oxigeno suplementario segun saturacion y gasometria","Preparar equipo de ventilacion mecanica si se anticipa deterioro","Registrar parametros ventilatorios y gasometria"]}],npiNoc:[{codigo:"0401",nombre:"Estado circulatorio",indicadores:["PAM >= 65 mmHg mantenida","Frecuencia cardiaca en rango normal","Relleno capilar < 3 segundos","Diuresis >= 0.5 mL/kg/h"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"},{codigo:"0680",nombre:"Eliminacion urinaria",indicadores:["Diuresis >= 0.5 mL/kg/h","Ausencia de oliguria o anuria","Creatinina en descenso o estabilizada"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"},{codigo:"0802",nombre:"Signos vitales",indicadores:["Temperatura en rango normal (36-38 C)","Frecuencia respiratoria 12-20 rpm","Saturacion de oxigeno >= 95%","Presion arterial dentro de parametros normales"],escala:"1=Desviacion grave del rango normal, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Shock septico refractario a vasopresores","Sindrome de dificultad respiratoria aguda (SDRA)","Lesion renal aguda con requerimiento de dialisis","Coagulacion intravascular diseminada (CID)","Disfuncion hepatica aguda (higado septico)","Encefalopatia septica","Insuficiencia suprarrenal relativa","Polineuropatia y miopatia del paciente critico","Bacteriemia secundaria con siembra a distancia"],criteriosAlarma:["qSOFA >= 2 (FR > 22, Glasgow < 15, PAS <= 100 mmHg)","Lactato arterial > 4 mmol/L","Hipotension que no responde a bolo de 30 mL/kg de cristaloides","Diuresis < 0.5 mL/kg/h por mas de 2 horas","Deterioro neurologico agudo (Glasgow en descenso)","Saturacion de oxigeno < 90% con oxigeno suplementario","Temperatura < 36 C (hipotermia septica, peor pronostico)","Plaquetas < 100.000/mm3 en caida rapida (CID)"],emergencyLevel:"critico",relatedPathologyIds:["pat_neumonia","pat_itu","pat_peritonitis","pat_endocarditis","pat_sdra"],isPremium:!0},{id:"pat_sindrome_compartimental",nombre:"Sindrome Compartimental",bodySystemId:"musculoesqueletico",definicion:"Condicion clinica caracterizada por el aumento de la presion dentro de un compartimento muscular osteofascial cerrado, que compromete la perfusion tisular local. La presion compartimental superior a 30 mmHg (o dentro de 30 mmHg de la presion arterial diastolica) produce isquemia muscular y nerviosa progresiva e irreversible si no se trata quirurgicamente en las primeras 6 horas.",epidemiologia:"Incidencia de 7.3 por 100.000 habitantes en Estados Unidos. Afecta principalmente adultos jovenes masculinos (3:1 respecto a mujeres) por mayor incidencia de trauma. La pierna (compartimento anterior) es la localizacion mas frecuente (45%), seguida del antebrazo. Causa prevenible de amputacion y discapacidad permanente.",factoresRiesgo:["Fractura de huesos largos (tibia, radio, cubito, femur)","Lesion por aplastamiento (crush injury)","Herida vascular con reperfusion","Quemaduras circunferenciales","Vendajes o yesos muy ajustados","Puncion arterial o venosa con hematoma","Ejercicio extremo (sindrome compartimental por esfuerzo)","Coagulopatia con sangrado en compartimento","Picaduras de serpiente con edema","Cirugia prolongada con extremidad comprimida (sindrome de posicion)"],fisiopatologia:"El compartimento muscular esta rodeado por fascia inextensible. Cualquier causa que aumente el contenido del compartimento (edema, hematoma, inflamacion) o reduzca su volumen (yeso ajustado, quemadura circunferencial) eleva la presion intracompartimental. Cuando esta supera la presion de perfusion capilar (tipicamente presion diastotica - 30 mmHg), se interrumpe el flujo sanguineo microvascular. Los musculos toleran isquemia 4-6 horas; los nervios perifericos 2-4 horas. La isquemia produce necrosis muscular (rabdomiolisis), da\xf1o axonal irreversible, contractura de Volkmann y eventual mioglobinuria con lesion renal aguda. La progresion es autopropagante: la isquemia genera mas edema que eleva aun mas la presion.",signosYSintomas:{signos:["Compartimento tenso e indurado a la palpacion","Dolor al estiramiento pasivo del musculo afectado (signo mas precoz y sensible)","Paresia o paralisis distal al compartimento","Parestesias o anestesia en territorio nervioso comprometido","Piel brillante y tensa sobre el compartimento","Presion intracompartimental > 30 mmHg o dentro de 30 mmHg de la PAD (medicion directa)","Pulsos distales frecuentemente PRESENTES (su ausencia indica isquemia arterial avanzada)"],sintomas:["Dolor severo, desproporcionado a la lesion aparente (hallazgo cardinal)","Dolor que aumenta con el movimiento pasivo de los dedos","Sensacion de presion o tension en la extremidad","Parestesias: hormigueo, adormecimiento distal","Incapacidad de mover los dedos","Sensacion de quemaz\xf3n en la extremidad"]},clasificacion:{nombre:"Clasificacion por presentacion clinica",tipos:[{nombre:"Sindrome compartimental agudo",descripcion:"Instalacion en horas tras trauma, fractura o reperfusion. Emergencia quirurgica que requiere fasciotomia inmediata"},{nombre:"Sindrome compartimental cronico por esfuerzo",descripcion:"Aparece con ejercicio repetitivo (corredores, ciclistas). Dolor y tension durante el esfuerzo que cede con el reposo. Tratamiento conservador o fasciotomia electiva"},{nombre:"Sindrome compartimental subagudo",descripcion:"Instalacion en 24-96 horas, tipicamente en quemaduras, aplastamientos o tratamiento medico de fractura. Evolucion mas lenta pero igualmente grave"}]},diagnostico:{anamnesis:["Mecanismo y tiempo del trauma o causa predisponente","Tipo de inmovilizacion aplicada (yeso, vendaje)","Tiempo de instalacion y evolucion del dolor","Presencia de parestesias o paralisis (indicadores de isquemia nerviosa)","Antecedentes de coagulopatia o uso de anticoagulantes","Historial de ejercicio extremo previo (forma cronica)"],examenFisico:["Inspeccion: piel brillante, tensa, eritema o palidez distal","Palpacion: dureza del compartimento, temperatura local","Evaluacion neurologica distal: sensibilidad, fuerza, reflejos","Evaluacion vascular distal: pulsos, relleno capilar, Doppler si duda","Prueba de estiramiento pasivo: dolor en la maniobra es el signo mas precoz","Medicion directa de presion intracompartimental con equipo de Stryker o cateter de aguja"],pruebas:[{nombre:"Medicion de presion intracompartimental",descripcion:"Estudio confirmatorio. Se inserta una aguja conectada a un manometro dentro del compartimento. Diferencial critico: delta P (PAD - PIC) <= 30 mmHg indica fasciotomia",valoresReferencia:"Normal < 10 mmHg; Alarma 20-30 mmHg; Fasciotomia indicada si PIC > 30 mmHg o delta P <= 30 mmHg",cuidadosEnfermeria:["Preparar equipo de Stryker o aguja de 18G con linea de presion","Explicar procedimiento al paciente: es doloroso pero breve","Registrar valor exacto de presion y hora de medicion","Registrar simultaneamente la presion arterial diastolica para calcular delta P","Preparar para repeticion horaria si la decision clinica es expectante","Mantener al paciente en posicion de confort (no elevar extremidad por encima del corazon)"]},{nombre:"Creatinfosfoquinasa (CPK) y mioglobina",descripcion:"Marcadores de lisis muscular (rabdomiolisis). Elevacion indica necrosis del musculo en el compartimento y riesgo de lesion renal por mioglobinuria",valoresReferencia:"CPK normal < 200 U/L; Rabdomiolisis significativa > 5.000 U/L; Riesgo renal > 15.000-20.000 U/L. Mioglobina orina: negativo normal",cuidadosEnfermeria:["Extraer muestra venosa sin torniquete prolongado para evitar falsos positivos","Repetir cada 6-8 horas en casos establecidos para monitorizar progresion","Solicitar orina en simult\xe1neo para mioglobinuria (orina color cafe oscuro o cola)","Si CPK > 5.000, alertar sobre necesidad de hidratacion agresiva para proteccion renal"]},{nombre:"Ecodoppler vascular",descripcion:"Evalua flujo vascular en vasos principales distales al compartimento. Descarta lesion arterial asociada y complementa la evaluacion clinica",valoresReferencia:"Flujo trifasico normal en arterias de extremidades; bifasico o monofasico indica compromiso distal",cuidadosEnfermeria:["Preparar gel de ultrasonido y comunicar al ecografista la sospecha diagnostica","No demorar fasciotomia esperando ecodoppler si el diagnostico clinico es claro","Documentar pulsos distales por palpacion antes del estudio","Mantener extremidad inmovilizada durante el examen"]}]},tratamientoMedico:{objetivos:["Descomprimir el compartimento con fasciotomia dentro de las primeras 6 horas","Preservar la viabilidad muscular y nerviosa","Prevenir rabdomiolisis y lesion renal aguda","Rehabilitacion funcional de la extremidad afectada"],farmacologico:[{nombre:"Morfina",grupo:"Analgesico opioide de accion central",mecanismo:"Agonista de receptores mu-opioides en SNC y medula espinal; reduce la percepcion del dolor y la respuesta emocional al mismo. No resuelve la causa del sindrome compartimental pero es indispensable para el manejo del dolor severo",dosis:"0.05-0.1 mg/kg IV lento cada 3-4 horas; o PCA (analgesia controlada por el paciente) en postoperatorio de fasciotomia",cuidadosEnfermeria:["ADVERTENCIA CRITICA: el alivio del dolor con opioides puede enmascarar la progresion del sindrome compartimental y retrasar el diagnostico","Evaluar dolor antes y 30 minutos despues de cada dosis con escala EVA","Monitorizar frecuencia respiratoria: no administrar si FR < 12 rpm","Tener naloxona (antagonista) disponible a la cabecera del paciente","Vigilar signos neurologicos distales cada hora a pesar de la analgesia","Evitar bloqueos nerviosos regionales que enmascaren signos neurologicos"]},{nombre:"Solucion fisiologica 0.9% (SF) o Ringer Lactato",grupo:"Fluido de hidratacion para prevencion de rabdomiolisis renal",mecanismo:"La hidratacion agresiva diluye la mioglobina en la luz tubular renal y aumenta la diuresis, previniendo la precipitacion de mioglobina y la oclusion tubular. El volumen urinario adecuado es el principal protector renal",dosis:"1-1.5 mL/kg/h inicialmente; ajustar para mantener diuresis 200-300 mL/h hasta que mioglobinuria desaparezca",cuidadosEnfermeria:["Colocar sonda vesical para medicion precisa de diuresis horaria","Objetivo de diuresis: 200-300 mL/h (no 0.5 mL/kg/h habitual) en rabdomiolisis","Observar color de la orina: cola o te oscuro indica mioglobinuria activa","Monitorizar electrolitos cada 6-8 horas: riesgo de hiperkalemia por lisis muscular","Registrar balance hidrico estricto; vigilar sobrecarga en pacientes con cardiopatia"]},{nombre:"Cefalosporinas de primera generacion (Cefalotina / Cefazolina)",grupo:"Antibiotico profilactico perioperatorio (betalactamico)",mecanismo:"Inhibe la sintesis de pared bacteriana de bacterias gram positivas (principalmente Staphylococcus aureus y Streptococcus). Profilaxis de infeccion de herida quirurgica en fasciotomia",dosis:"1-2 g IV 30-60 minutos antes de la incision quirurgica; repetir dosis si cirugia supera 4 horas o sangrado > 1.5 litros",cuidadosEnfermeria:["Administrar dentro de la ventana de 30-60 minutos antes de la incision quirurgica","Verificar alergias a penicilinas (reactividad cruzada 1-2%)","Registrar hora exacta de administracion para trazabilidad perioperatoria","En heridas contaminadas, el antibiotico terapeutico lo define el cirujano segun la flora esperada"]}],noFarmacologico:["Fasciotomia quirurgica de urgencia: incision de la fascia del compartimento afectado para descomprimir (tratamiento definitivo)","Retiro inmediato de vendajes, yesos y cualquier constriccion externa","Posicionar la extremidad al nivel del corazon (no elevar ni bajar: ambos empeoran la perfusion)","Cierre diferido de la fasciotomia a los 3-5 dias cuando ceda el edema","Injerto de piel si los bordes no aproximan en el cierre diferido","Rehabilitacion y fisioterapia precoz postoperatoria para prevenir contracturas","Monitorizacion continua de la extremidad post-fasciotomia (nueva elevacion de presion es posible)"]},cuidadosEnfermeria:{valoracion:["Evaluar las 6 P's del sindrome compartimental: Pain (dolor desproporcionado), Pressure (tension compartimental), Paresthesia, Paralysis, Pallor, Pulselessness (tardio)","Medir el dolor con EVA antes y despues de analgesia; documentar cambio en intensidad o caracter","Valorar sensibilidad, fuerza y movimiento de dedos distales cada hora","Inspeccionar y palpar el compartimento cada hora: dureza, temperatura, tension de la piel","Registrar color y temperatura de la extremidad distal comparando con el miembro contralateral","Evaluar y documentar pulsos distales por palpacion y Doppler cada hora"],intervenciones:["Retirar INMEDIATAMENTE vendajes, yesos y cualquier elemento constrictivo ante sospecha","Posicionar la extremidad en plano horizontal al nivel cardiaco","Administrar analgesia opioide segun indicacion medica vigilando el enmascaramiento de signos","Preparar al paciente para fasciotomia de urgencia: via venosa, ayuno, consentimiento, profilaxis antibiotica","Colocar sonda vesical para monitorizar diuresis horaria y detectar mioglobinuria","Iniciar hidratacion intravenosa agresiva ante evidencia de rabdomiolisis","Preparar campo quirurgico segun protocolo si se indica fasciotomia"],educacionPaciente:["Explicar urgencia de la situacion y necesidad de intervencion quirurgica inmediata","Instruir para comunicar de inmediato cualquier cambio en sensacion (hormigueo, adormecimiento) o incapacidad para mover dedos","Explicar la cirugia de fasciotomia: como se hace, por que es necesaria y que esperar en el postoperatorio","Advertir que la extremidad quedara con herida abierta varios dias antes del cierre definitivo","Orientar sobre la rehabilitacion necesaria postoperatoria"],monitorizacion:["Evaluacion neurovascular distal cada 30-60 minutos en sospecha, cada hora en confirmacion","Medicion de presion intracompartimental horaria si se decide manejo expectante","CPK cada 6 horas para monitorizar rabdomiolisis","Diuresis horaria con descripcion del color de la orina","Electrolitos (K+) cada 6-8 horas por riesgo de hiperkalemia en rabdomiolisis","Funcion renal (creatinina, BUN) cada 12-24 horas","Vigilar herida de fasciotomia postoperatoria: sangrado, signos de infeccion, aproximacion de bordes"]},npiNanda:[{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable ocasionada por una lesion tisular real o potencial, de inicio subito o lento, de cualquier intensidad de leve a grave, con un final anticipado o previsible",caracteristicasDefinitorias:["Expresion verbal de dolor severo (EVA 8-10)","Dolor aumenta con el estiramiento pasivo de los dedos","Facies de dolor y conductas de proteccion","Diaforesis y taquicardia asociadas al dolor"],factoresRelacionados:["Isquemia tisular por aumento de presion intracompartimental","Estiramiento de la fascia inextensible","Lesion nerviosa periferica incipiente"]},{codigo:"00204",nombre:"Perfusion tisular periferica ineficaz",definicion:"Disminucion de la circulacion sanguinea periferica que puede comprometer la salud",caracteristicasDefinitorias:["Relleno capilar enlentecido","Cambios de color y temperatura distal","Parestesias y debilidad muscular distal","Presion intracompartimental elevada"],factoresRelacionados:["Compresion de microcirculacion por aumento de presion en compartimento cerrado","Edema pos-traumatico o pos-reperfusion","Constriccion externa (yeso, vendaje)"]},{codigo:"00046",nombre:"Deterioro de la integridad cutanea",definicion:"Alteracion de la epidermis y/o la dermis",caracteristicasDefinitorias:["Piel tensa, brillante y eritematosa sobre el compartimento","Flictenas en casos avanzados","Herida quirurgica abierta post-fasciotomia"],factoresRelacionados:["Edema tisular severo","Isquemia cutanea","Herida quirurgica de fasciotomia de cierre diferido"]}],npiNic:[{codigo:"2395",nombre:"Control de la presion intracompartimental",actividades:["Evaluar los signos y sintomas del sindrome compartimental cada hora","Realizar medicion de presion intracompartimental segun protocolo","Retirar vendajes y yesos constrictivos de inmediato","Notificar al medico ante deterioro neurovascular distal"]},{codigo:"2210",nombre:"Administracion de analgesicos",actividades:["Evaluar el dolor antes y despues de la administracion con escala validada","Administrar analgesicos opioides segun prescripcion","Vigilar que la analgesia no enmascare la progresion del sindrome","Documentar eficacia y efectos adversos de cada dosis"]},{codigo:"0480",nombre:"Cuidados de la ostomia (cuidados de herida abierta post-fasciotomia)",actividades:["Realizar curaciones de la herida de fasciotomia con tecnica aseptica","Aplicar aposito humedo no adherente para proteger el musculo expuesto","Monitorizar signos de infeccion en la herida cada 8-12 horas","Preparar para cierre diferido o injerto segun indicacion del cirujano"]}],npiNoc:[{codigo:"1605",nombre:"Control del dolor",indicadores:["Dolor en escala EVA <= 3 con analgesia adecuada","Uso eficaz de medidas analgesicas","Reconoce signos de deterioro para comunicar al equipo"],escala:"1=Nunca demostrado, 2=Raramente demostrado, 3=A veces demostrado, 4=Frecuentemente demostrado, 5=Siempre demostrado"},{codigo:"0407",nombre:"Perfusion tisular: periferica",indicadores:["Relleno capilar < 3 segundos post-fasciotomia","Fuerza y sensibilidad distal recuperadas","Ausencia de dolor isquemico en reposo","Temperatura de la extremidad normalizada"],escala:"1=Desviacion grave del rango normal, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Necrosis muscular irreversible con contractura de Volkmann","Lesion nerviosa periferica permanente con deficit sensitivo-motor","Rabdomiolisis severa con lesion renal aguda","Infeccion de herida de fasciotomia (celulitis, osteomielitis, fascitis necrotizante)","Amputacion de la extremidad en casos tardios o complicados","Trombosis venosa profunda por inmovilizacion e hipoperfusion","Sindrome compartimental abdominal en casos de trauma abdominal asociado"],criteriosAlarma:["Dolor severo desproporcionado a la lesion que no cede con analgesia habitual","Parestesias o anestesia distal de instalacion aguda","Paralisis o imposibilidad de mover los dedos","Presion intracompartimental > 30 mmHg o delta P <= 30 mmHg","CPK en ascenso rapido > 5.000 U/L","Orina color cafe oscuro (mioglobinuria)","Compartimento indurado como madera a la palpacion"],emergencyLevel:"critico",relatedPathologyIds:["pat_fractura_tibial","pat_lesion_vascular","pat_rabdomiolisis","pat_lesion_renal_aguda"],isPremium:!0},{id:"pat_sindrome_hemolitico_uremico",nombre:"Sindrome Hemolitico Uremico",bodySystemId:"renal_urinario",definicion:"Microangiopatia trombotica caracterizada por la triada clasica de anemia hemolitica microangiopatica (fragmentacion de eritrocitos en la microcirculacion), trombocitopenia y lesion renal aguda. La forma tipica (SHU-STEC) es causada por la toxina Shiga producida por Escherichia coli O157:H7 u otras cepas enterohemoragicas, y representa la primera causa de insuficiencia renal aguda en pediatria.",epidemiologia:"Incidencia de 2-3 casos por 100.000 ni\xf1os menores de 5 a\xf1os por ano. El 90-95% de los casos en pediatria son tipicos (STEC-SHU) asociados a E. coli O157:H7. En Argentina, la incidencia es la mas alta del mundo (0.8-1 caso por 100.000 habitantes en toda la poblacion, con picos en verano). Es la primera causa de insuficiencia renal aguda en ni\xf1os de 1-5 a\xf1os y causa del 3-5% de los transplantes renales pediatricos.",factoresRiesgo:["Edad < 5 a\xf1os (maxima susceptibilidad)","Consumo de carne vacuna poco cocida (hamburguesas)","Consumo de leche cruda o jugos sin pasteurizar","Contacto con animales de granja o sus heces","Contacto con personas infectadas (transmision fecal-oral)","Temporada estival (picos en verano-otono)","Viajes a zonas endemicas","SHU atipico: mutaciones en genes del complemento (CFH, CFI, C3, CFB, MCP)","SHU atipico: embarazo o posparto, trasplante, medicamentos (ciclosporina, mitomicina)"],fisiopatologia:"La toxina Shiga (Stx1, Stx2) producida por STEC es absorbida en el intestino y llega via sanguinea a la microcirculacion renal (y de otros organos). Se une al receptor Gb3 (globotriaosylceramida) presente en celulas endoteliales glomerulares, tubulares y del SNC. La union inhibe la sintesis proteica celular, causando apoptosis endotelial. El endotelio lesionado activa la coagulacion intravascular localizada: se forman microtrombos de fibrina y plaquetas en capilares y arteriolas, que fragmentan los eritrocitos al pasar (esquistocitos), consumen plaquetas (trombocitopenia) y reducen el flujo glomerular (lesion renal aguda: necrosis cortical o necrosis tubular aguda). El compromiso del SNC (convulsiones, coma) ocurre en el 10-25% de los casos graves por afectacion de la microcirculacion cerebral.",signosYSintomas:{signos:["Palidez marcada por anemia hemolitica aguda","Petequias o equimosis por trombocitopenia (plaquetas < 150.000/mm3)","Edema (cara, periorbitario, extremidades) por lesion renal","Oliguria o anuria (lesion renal aguda)","Ictericia leve (hemolisis intravascular)","Hipertension arterial en fase de lesion renal","Esquistocitos en frotis de sangre periferica (signo patognomonico de microangiopatia)","Signos neurologicos: irritabilidad, convulsiones, rigidez de nuca (10-25% de casos)"],sintomas:["Prodromo diarreico (tipicamente sanguinolento) 5-10 dias antes de la triada","Dolor abdominal tipo colico intenso","Vomitos y nauseas","Astenia y decaimiento marcado","Disminucion o ausencia de la diuresis","Palidez y fatigabilidad extrema (anemia aguda)","Irritabilidad o letargo en lactantes"]},clasificacion:{nombre:"Clasificacion etiologica del SHU",tipos:[{nombre:"SHU tipico (STEC-SHU o D+SHU)",descripcion:"90-95% de los casos en pediatria. Causado por E. coli productora de toxina Shiga (O157:H7 principalmente). Precedido de diarrea sanguinolenta. Pronostico relativamente favorable aunque puede requerir dialisis"},{nombre:"SHU atipico (aSHU o D-SHU)",descripcion:"5-10% de los casos. Causado por desregulacion del complemento (mutaciones en CFH, CFI, C3, MCP) o anticuerpos anti-CFH. Sin prodromo diarreico. Peor pronostico, alta tasa de recurrencia y evolucion a insuficiencia renal cronica"},{nombre:"SHU por Streptococcus pneumoniae",descripcion:"Causa rara, predomina en menores de 2 a\xf1os. Neuraminidasa bacteriana modifica antigenos eritrocitarios y plaquetarios. CONTRAINDICADO el plasma fresco: contiene anticuerpos que empeoran el cuadro"}]},diagnostico:{anamnesis:["Antecedente de diarrea (especialmente sanguinolenta) 5-10 dias antes","Ingesta de carne poco cocida, leche o jugos sin pasteurizar","Contacto con animales de granja o personas con diarrea","Temporada del ano y zona geografica","Tiempo de evolucion de la oliguria","Historial familiar de SHU o enfermedad renal (orienta a aSHU)"],examenFisico:["Evaluar palidez, ictericia e hidratacion","Medicion de PA (hipertension frecuente en fase de lesion renal)","Palpacion abdominal (dolor, hepatoesplenomegalia)","Buscar petequias, equimosis o purpura (trombocitopenia)","Evaluacion neurologica completa: nivel de conciencia, signos meningeos, convulsiones","Medicion de diuresis con sonda vesical"],pruebas:[{nombre:"Frotis de sangre periferica",descripcion:"Estudio definitorio para diagnostico de microangiopatia. Detecta esquistocitos (eritrocitos fragmentados), criterio indispensable para confirmar anemia hemolitica microangiopatica",valoresReferencia:"Normal: ausencia de esquistocitos. Positivo si esquistocitos > 1% del total de eritrocitos. Se acepta cualquier cantidad como significativa en contexto clinico compatible",cuidadosEnfermeria:["Extraer muestra en tubo con EDTA (tapa violeta); enviar inmediatamente al laboratorio","Solicitar explicitamente 'frotis con busqueda de esquistocitos' en la orden","No agitar la muestra para evitar hemolisis artefactual","Registrar nivel de hemoglobina y recuento plaquetario simultaneamente","En el transporte, no centrifugar la muestra antes de hacer el frotis"]},{nombre:"Hemograma completo con recuento de reticulocitos",descripcion:"Confirma anemia hemolitica (Hb baja, reticulocitos elevados, LDH alta) y trombocitopenia. Primer estudio a solicitar ante sospecha de SHU",valoresReferencia:"Hb tipicamente 5-9 g/dL; Plaquetas < 150.000 (frecuentemente < 50.000); Reticulocitos elevados > 2%; LDH > 500 U/L en hemolisis activa",cuidadosEnfermeria:["Obtener muestra con minimo trauma de venopuncion para evitar hemolisis in vitro","Solicitar LDH y haptoglobina en la misma extraccion (haptoglobina baja confirma hemolisis intravascular)","Repetir hemograma cada 6-12 horas en la fase aguda para monitorizar evolucion","Registrar valores basales para seguimiento de respuesta al tratamiento","Preparar al paciente y familia para posible transfusion si Hb < 7 g/dL"]},{nombre:"Funcion renal: creatinina, BUN, ionograma, gasometria",descripcion:"Cuantifica el grado de lesion renal aguda (clasificacion KDIGO), detecta hiperkalemia, acidosis metabolica y retencion hidrica, que guian la indicacion de dialisis de urgencia",valoresReferencia:"Creatinina: en ni\xf1os, normal segun edad (0.3-0.7 mg/dL < 5 a\xf1os). BUN > 50 mg/dL. K+ > 6 mEq/L indica dialisis urgente. pH < 7.20 indica dialisis urgente",cuidadosEnfermeria:["Monitorizar electrolitos y creatinina cada 6-8 horas en la fase aguda","Vigilar signos clinicos de hiperkalemia: debilidad, parestesias, arritmias","Colocar monitoreo cardiaco continuo si K+ > 5.5 mEq/L","Registrar balance hidrico estricto y peso diario","Preparar al paciente para dialisis peritoneal o hemodi\xe1lisis si se indica: informar a la familia"]},{nombre:"Coprocultivo y PCR para STEC / toxina Shiga",descripcion:"Confirma el agente etiologico. El coprocultivo en agar MacConkey sorbitol detecta E. coli O157:H7 no fermentadora de sorbitol. La PCR detecta genes stx1 y stx2 con mayor sensibilidad",valoresReferencia:"Negativo en condiciones normales. Positividad confirma SHU tipico y orienta medidas de salud publica",cuidadosEnfermeria:["Tomar muestra de heces en la fase prodromica (primeros 5-7 dias desde inicio de diarrea): mayor rendimiento","Si el paciente ya no tiene diarrea al diagnostico, el coprocultivo puede ser negativo (no descarta SHU tipico)","Utilizar hisopo rectal si el paciente no puede defecar","Aplicar precauciones de contacto ante sospecha de STEC","Notificar al equipo de salud publica ante confirmacion: es enfermedad de declaracion obligatoria"]}]},tratamientoMedico:{objetivos:["Soporte de la funcion renal (dialisis si indicado)","Correccion de anemia (transfusion si Hb < 7 g/dL o inestabilidad hemodinamica)","Control de la hipertension arterial","Prevencion y tratamiento de complicaciones neurologicas","Manejo del equilibrio hidroelectrolitico"],farmacologico:[{nombre:"Concentrado de globulos rojos (CGR)",grupo:"Hemocomponente - tratamiento de anemia hemolitica grave",mecanismo:"Reposicion de eritrocitos perdidos por hemolisis microangiopatica para restaurar la capacidad de transporte de oxigeno. No interfiere con la fisiopatologia de la microangiopatia",dosis:"10-15 mL/kg IV a pasar en 2-4 horas; generalmente se indican 1-2 unidades en adultos o 1 unidad pediatrica ajustada al peso. Objetivo: Hb > 7 g/dL (> 8-9 si cardiopatia o sintomatologia grave)",cuidadosEnfermeria:["Verificar DOBLE IDENTIFICACION del paciente y la unidad de sangre antes de infundir (protocolo transfusional)","Administrar a traves de equipo con filtro de 170-200 micrones; nunca con suero glucosado","Monitorizar signos vitales (PA, FC, Temp, SatO2) a los 15 min del inicio y cada 30 min","Suspender inmediatamente ante reaccion transfusional: escalofrios, fiebre, urticaria, hipotension","En oliguria/anuria: infundir lentamente para evitar sobrecarga de volumen; tener furosemida lista","Registrar hemoglobina pre y post-transfusion para evaluar eficacia"]},{nombre:"Amlodipina / Nifedipina",grupo:"Antihipertensivo - antagonista de calcio dihidropiridinico",mecanismo:"Bloquea canales de calcio voltaje-dependientes en musculo liso vascular, produciendo vasodilatacion arteriolar y reduccion de la resistencia vascular periferica. Preferido en la hipertension de la lesion renal aguda por no requerir ajuste de dosis en insuficiencia renal y por su perfil de seguridad en pediatria",dosis:"Amlodipina: 0.1-0.3 mg/kg/dia VO en 1 dosis (max 10 mg/dia en adultos). Nifedipina: 0.25-0.5 mg/kg/dosis sublingual en urgencias hipertensivas (max 10 mg/dosis)",cuidadosEnfermeria:["Monitorizar PA antes y 1-2 horas despues de cada dosis","Vigilar hipotension ortostasica, especialmente en pacientes con volumen reducido","En ni\xf1os: calcular dosis por peso con precision; usar preparado liquido cuando disponible","Registrar curva de PA para ajuste de dosis por el medico","Vigilar edema de extremidades como efecto adverso de la amlodipina"]},{nombre:"Eculizumab",grupo:"Anticuerpo monoclonal anti-complemento C5 (tratamiento especifico del SHU atipico)",mecanismo:"Inhibe la escision de C5 bloqueando la generacion de C5a (anafilatoxina proinflamatoria) y del complejo de ataque a la membrana (C5b-9). Interrumpe la activacion desregulada del complemento que es la causa fisiopatologica del SHU atipico. No tiene efecto en SHU tipico por STEC",dosis:"Induccion pediatrica segun peso (300-900 mg IV); mantenimiento semanal-quincenal segun protocolo. En adultos: 900 mg/semana x 4 semanas, luego 1200 mg cada 2 semanas",cuidadosEnfermeria:["VACUNAR contra meningococo (N. meningitidis tipos A, C, W, Y y B) al menos 2 semanas antes de iniciar el tratamiento (el eculizumab aumenta radicalmente el riesgo de meningococcemia)","Si la urgencia no permite esperar la vacunacion, iniciar profilaxis antibiotica con penicilina V oral","Administrar por infusion IV lenta (25-45 minutos); vigilar reacciones de hipersensibilidad","Monitorizar recuento plaquetario y funcion renal para evaluar respuesta al tratamiento","Educar a la familia sobre signos de meningococcemia (fiebre, cefalea, petequias, rigidez de nuca)"]}],noFarmacologico:["CONTRAINDICADOS los antibioticos en SHU tipico por STEC: aumentan la liberacion de toxina Shiga y empeoran el pronostico","CONTRAINDICADOS los antidiarreicos (loperamida): retienen la bacteria y la toxina en el colon","CONTRAINDICADA la transfusion de plasma fresco en SHU por neumococo","Dialisis peritoneal o hemodialisis si: anuria > 24h, K+ > 6.5 mEq/L, acidosis metabolica severa pH < 7.15, sobrecarga hidrica sintomatica, encefalopatiauremica","Restriccion hidrica segun diuresis residual (insensibles + diuresis medida)","Dieta hipoproteica e hipopotasemica en fase olig\xfarica","Monitorizacion neurologica estrecha: EEG si convulsiones; neuroimagen si compromiso neurologico"]},cuidadosEnfermeria:{valoracion:["Monitorizar diuresis horaria con sonda vesical o pesando panales en lactantes","Evaluar signos de anemia: palidez, taquicardia, taquipnea, intolerancia al esfuerzo","Valorar signos de sangrado: petequias, equimosis, sangrado mucoso (trombocitopenia)","Vigilar estado neurologico: nivel de conciencia, irritabilidad, convulsiones cada hora","Registrar PA cada 2-4 horas o segun estado del paciente","Medir peso diario en la misma balanza a la misma hora","Evaluar signos de sobrecarga hidrica: edema, crepitantes pulmonares, ingurgitacion yugular"],intervenciones:["Aplicar precauciones de contacto estrictas (guantes y delantal en cada contacto)","Colocar sonda vesical para medicion exacta de diuresis horaria","Registrar balance hidrico estricto cada 6-12 horas","Administrar concentrado de globulos rojos segun protocolo transfusional con doble identificacion","Preparar al paciente para dialisis peritoneal o acceso vascular para hemodialisis si se indica","Implementar medidas de seguridad neurologica: proteccion ante convulsiones, cama con barandas","Notificar al equipo de salud publica por ser enfermedad de declaracion obligatoria","Educar a la familia sobre medidas de prevencion de contagio intradomiciliario"],educacionPaciente:["Explicar a la familia la enfermedad, su causa y evolucion esperada en terminos comprensibles","Instruir sobre la importancia de la medicion de diuresis en domicilio al alta","Advertir sobre la prohibicion estricta de antibioticos y antidiarreicos en SHU tipico","Educar sobre prevencion: coccion adecuada de carnes, pasteurizacion, lavado de manos","Informar sobre se\xf1ales de alarma que requieren consulta urgente: menor diuresis, edema, convulsiones","En SHU atipico: explicar necesidad de tratamiento cronico con eculizumab y riesgo de recurrencia"],monitorizacion:["Diuresis horaria en la fase aguda; cada 4-8 horas en la fase de recuperacion","Hemograma y recuento plaquetario cada 6-12 horas en fase aguda","Creatinina, BUN, electrolitos, gasometria cada 6-8 horas","LDH y haptoglobina cada 12-24 horas para monitorizar actividad hemolitica","Presion arterial cada 2-4 horas o continua si crisis hipertensiva","Peso diario en fase olig\xfarica","Frotis de sangre periferica cada 1-3 dias para evaluar desaparicion de esquistocitos (indicador de remision)","Evaluacion neurologica cada 4-8 horas"]},npiNanda:[{codigo:"00026",nombre:"Exceso de volumen de liquidos",definicion:"Aumento de la retencion de liquidos isotonicos",caracteristicasDefinitorias:["Oliguria o anuria","Edema generalizado","Aumento de peso agudo","Hipertension arterial"],factoresRelacionados:["Lesion renal aguda con reduccion del filtrado glomerular","Incapacidad renal para eliminar el exceso de sodio y agua"]},{codigo:"00006",nombre:"Hipotermia (adaptado: riesgo de desequilibrio electrolitico)",definicion:"Riesgo de cambios en los niveles de electrolitos sericos que pueden comprometer la salud",caracteristicasDefinitorias:["Hiperkalemia por lisis celular y lesion renal","Acidosis metabolica por lesion renal","Hiponatremia dilucional"],factoresRelacionados:["Lesion renal aguda con incapacidad de excretar potasio","Lisis celular masiva con liberacion de potasio intracelular","Acidosis metabolica por acumulacion de acidos organicos"]},{codigo:"00268",nombre:"Riesgo de perfusion renal ineficaz",definicion:"Vulnerable a una disminucion de la circulacion sanguinea renal que puede comprometer la salud",caracteristicasDefinitorias:["Oliguria o anuria","Elevacion de creatinina y BUN","Hipertension arterial"],factoresRelacionados:["Microtrombos en microcirculacion glomerular por microangiopatia trombotica","Lesion endotelial glomerular por toxina Shiga","Necrosis cortical o tubular aguda"]},{codigo:"00131",nombre:"Deterioro de la memoria",definicion:"Incapacidad para recordar o recuperar fragmentos de informacion o habilidades conductuales (adaptado: compromiso neurologico por SHU)",caracteristicasDefinitorias:["Irritabilidad o letargo","Convulsiones","Alteracion del sensorio"],factoresRelacionados:["Microangiopatia cerebral por toxina Shiga","Encefalopatia uremica","Hipertension arterial grave"]}],npiNic:[{codigo:"4130",nombre:"Monitorizacion de liquidos",actividades:["Registrar ingresos y egresos estrictamente cada hora en fase aguda","Pesar al paciente diariamente en la misma balanza","Monitorizar signos de sobrecarga: edema, estertores, PA elevada","Ajustar aportes liquidos a diuresis residual mas perdidas insensibles"]},{codigo:"2110",nombre:"Manejo de la hipervolemia",actividades:["Restringir la ingesta de liquidos segun diuresis y balance","Administrar diureticos si hay diuresis residual y se indica","Preparar acceso vascular para dialisis si se anticipa","Monitorizar peso y edema para evaluar respuesta al manejo"]},{codigo:"0916",nombre:"Manejo de las convulsiones",actividades:["Mantener ambiente seguro: barandas, sin objetos duros cerca","Administrar anticonvulsivantes segun prescripcion si hay convulsiones","Registrar caracteristicas de cada episodio convulsivo: duracion, tipo, lateralizacion","Notificar al equipo medico ante primer episodio convulsivo"]},{codigo:"4030",nombre:"Administracion de productos sanguineos",actividades:["Aplicar protocolo de doble identificacion antes de cada transfusion","Monitorizar signos vitales durante la transfusion","Vigilar reacciones transfusionales y actuar segun protocolo","Registrar hemoglobina pre y post transfusion"]}],npiNoc:[{codigo:"0601",nombre:"Equilibrio de liquidos",indicadores:["Peso estable sin aumento diario > 0.5 kg","Ausencia de edema generalizado","Presion arterial en rango normal para la edad","Ausencia de crepitantes pulmonares"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"},{codigo:"0621",nombre:"Eliminacion urinaria",indicadores:["Diuresis en aumento o recuperacion de diuresis normal","Creatinina en descenso progresivo","Ausencia de anuria persistente"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"},{codigo:"0706",nombre:"Estado hematologico",indicadores:["Hemoglobina > 7 g/dL mantenida","Plaquetas en aumento (recuperacion hematologica)","Ausencia de esquistocitos en frotis (remision microangiopatica)","LDH en descenso"],escala:"1=Desviacion grave del rango normal, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Insuficiencia renal cronica con requerimiento de dialisis cronica o trasplante renal","Compromiso neurologico grave: convulsiones, coma, accidente cerebrovascular (10-25%)","Miocarditis o derrame pericardico","Colitis isquemica o necrosis intestinal","Pancreatitis aguda o diabetes insulinodependiente post-SHU","Hipertension arterial cronica secuelar","Recurrencia (especialmente en SHU atipico: 50% de recurrencia post-trasplante sin profilaxis)","Muerte en fase aguda (3-5% en centros especializados, mayor en casos neurologicos graves)"],criteriosAlarma:["Anuria > 12-24 horas","K+ > 6 mEq/L (hiperkalemia con riesgo de arritmia fatal)","pH arterial < 7.20 (acidosis metabolica grave)","Convulsiones o deterioro del sensorio (compromiso neurologico)","Hb < 6 g/dL con inestabilidad hemodinamica","Hipertension arterial grave con PA > percentil 99 para la edad (riesgo de encefalopatia hipertensiva)","Signos de sobrecarga hidrica: dificultad respiratoria, estertores crepitantes"],emergencyLevel:"critico",relatedPathologyIds:["pat_lesion_renal_aguda","pat_purpura_trombocitopenica","pat_coagulacion_intravascular_diseminada","pat_enterocolitis_hemorragica"],isPremium:!0},{id:"pat_neuropatia_periferica",nombre:"Neuropatia Periferica",bodySystemId:"neurologico",definicion:"Conjunto de trastornos que afectan a los nervios perifericos (motores, sensitivos y autonomos) fuera del cerebro y la medula espinal, produciendo da\xf1o axonal o desmielinizacion con manifestaciones clinicas de debilidad muscular distal, parestesias, alteraciones sensitivas y disfuncion autonoma.",epidemiologia:"Prevalencia del 2-8% en la poblacion general; aumenta al 8-15% en mayores de 55 a\xf1os. La causa mas frecuente en paises desarrollados es la neuropatia diabetica (afecta al 50% de los diabeticos con mas de 25 a\xf1os de enfermedad). Otras causas: alcohol (segunda causa), enfermedad renal cronica, hipotiroidismo y causas hereditarias.",factoresRiesgo:["Diabetes mellitus (causa principal)","Consumo cronico de alcohol","Deficiencia de vitaminas B1, B6, B12 y E","Exposicion a toxinas (plomo, arsenicomercurio)","Quimioterapia neurotoxica (vincristina, taxanos, platino)","Enfermedad renal cronica","Hipotiroidismo","Enfermedades autoinmunes (LES, artritis reumatoidea)","Enfermedades hereditarias (Charcot-Marie-Tooth)"],fisiopatologia:"Dos mecanismos principales: da\xf1o axonal (axonopatia distal) donde el metabolismo energetico del axon se afecta primero en las porciones mas distales con degeneracion retrograda; y desmielinizacion segmentaria donde las celulas de Schwann son atacadas, enlenteciendo la velocidad de conduccion. En neuropatia diabetica: la hiperglucemia produce acumulacion de sorbitol, glucosilacion de proteinas estructurales y estres oxidativo que dantan el endoneuro y las celulas de Schwann. En las formas inflamatorias (CIDP), existe ataque inmune contra la mielina periferica.",signosYSintomas:{signos:["Debilidad muscular distal simetrica (tipo guante-calcetin en polineuropatia)","Atrofia muscular distal con deformidad del pie (pie cavo)","Hiporreflexia o arreflexia osteotendinosa","Perdida de sensibilidad en distribucion longitud-dependiente","Ulceras neuropaticas en zonas de presion (planta del pie)","Hipotension ortostatica por neuropatia autonoma","Anhidrosis distal o hiperhidrosis compensatoria"],sintomas:["Parestesias: hormigueo, quemaz\xf3n, pinchazos en pies y manos","Dolor neuropatico: ardor, alodinia, hiperalgesia","Sensacion de caminar sobre algodon o arena","Debilidad para dorsiflexion del pie (pie caido)","Inestabilidad en la marcha, especialmente de noche","Mareos al levantarse (hipotension ortostatica)","Disfuncion erectil, gastroparesia en neuropatia autonoma diabetica","Intolerancia al calor por alteracion sudomotora"]},clasificacion:{nombre:"Clasificacion por distribucion y fibra afectada",tipos:[{nombre:"Polineuropatia simetrica distal",descripcion:"Distribucion en guante-calcetin; la mas frecuente; etiologia metabolica, toxica o hereditaria"},{nombre:"Mononeuropatia",descripcion:"Afeccion de un solo nervio; causas compresivas (tunel carpiano, cubital), traumaticas o vasculiticas"},{nombre:"Mononeuropatia multiple (mononeuritis multiplex)",descripcion:"Afeccion asimetrica y escalonada de varios nervios; asociada a vasculitis, DM, sarcoidosis"},{nombre:"Polineuropatia inflamatoria desmielinizante cronica (CIDP)",descripcion:"Causa autoinmune; debilidad proximal y distal con enlentecimiento de velocidades de conduccion; tratable"},{nombre:"Neuropatia autonoma",descripcion:"Afecta nervios del sistema nervioso autonomo; manifestaciones cardiovasculares, GI y genitourinarias"}]},diagnostico:{anamnesis:["Antecedentes de diabetes, alcoholismo, IRC, hipotiroidismo","Exposicion a quimioterapia neurotoxica o toxinas industriales","Historia familiar de neuropatia hereditaria","Inicio y progresion de los sintomas (agudo sugiere inflamatorio o vasculitico)","Distribuccion: distal simetrica vs. asimetrica vs. proximal","Sintomas autonomos: mareos posturales, disfuncion erectil, diarrea/constipacion"],examenFisico:["Fuerza muscular distal y proximal (MRC 0-5)","Reflejos osteotendinosos: rotuliano y aquileo","Sensibilidad: tacto fino, dolor, temperatura, vibracion (diapason 128 Hz), propiocepcion","Test de monofilamento 10 g en pie diabetico","Inspeccion de pies: ulceras, deformidades, higiene","Test de hipotension ortostatica (PA acostado y de pie a los 1 y 3 minutos)"],pruebas:[{nombre:"Electroneuromiografia (ENMG)",descripcion:"Estudio electrodiagnostico que mide velocidades de conduccion nerviosa y potenciales de accion musculares; diferencia axonopatia de desmielinizacion",valoresReferencia:"Velocidad conduccion nervio mediano > 50 m/s; latencia distal motora < 4.4 ms",cuidadosEnfermeria:["Explicar que el estudio incluye pequenas descargas electricas y agujas finas (no es doloroso de manera intolerable)","Verificar que la piel este limpia y sin cremas o aceites","Informar al paciente que puede durar entre 30 y 90 minutos","No requiere ayuno ni suspension de medicacion habitualmente"]},{nombre:"Glucemia en ayunas y HbA1c",descripcion:"Descarta o confirma diabetes como causa de la neuropatia",valoresReferencia:"Glucemia < 100 mg/dL normal; HbA1c < 5.7% normal; DM si HbA1c >= 6.5%",cuidadosEnfermeria:["Verificar ayuno de al menos 8 horas para glucemia basal","Registrar ultima ingesta y medicacion hipoglucemiante","HbA1c no requiere ayuno"]},{nombre:"Vitamina B12 y folato sericos",descripcion:"Deficiencias frecuentes y tratables que causan neuropatia",valoresReferencia:"B12: 200-900 pg/mL; folato: 3-17 ng/mL",cuidadosEnfermeria:["No requiere ayuno especial","Si se sospecha deficit de B12 en paciente con metformina, indicar al medico","Recoger muestra antes de iniciar suplementacion para valor basal"]},{nombre:"Perfil tiroideo (TSH y T4 libre)",descripcion:"El hipotiroidismo causa neuropatia tratable por deposito de mucopolisacaridos en los nervios",valoresReferencia:"TSH: 0.4-4.0 mUI/L; T4 libre: 0.8-1.8 ng/dL",cuidadosEnfermeria:["Obtener muestra en ma\xf1ana antes de tomar levotiroxina si el paciente ya la usa","No requiere ayuno estricto"]}]},tratamientoMedico:{objetivos:["Tratar la causa subyacente cuando sea posible (control glucemico, abstinencia, suplementacion)","Aliviar el dolor neuropatico","Prevenir complicaciones (ulceras de pie, caidas)","Mantener la funcionalidad y calidad de vida"],farmacologico:[{nombre:"Pregabalina",grupo:"Modulador de canales de calcio alfa-2-delta",mecanismo:"Reduce la liberacion de neurotransmisores excitatorios (glutamato, sustancia P) en neuronas hiperexcitables del dolor neuropatico",dosis:"75-600 mg/dia en 2-3 tomas; iniciar con 75 mg/noche y titular",cuidadosEnfermeria:["Advertir sobre somnolencia y mareos al inicio del tratamiento","Ajustar dosis en insuficiencia renal segun clearance de creatinina","Vigilar aumento de peso y edema perif\xe9rico","No suspender abruptamente: reducir gradualmente","Precaucion en pacientes con riesgo de caidas (somnolencia + ataxia)"]},{nombre:"Duloxetina",grupo:"Inhibidor de la recaptacion de serotonina y noradrenalina (IRSN)",mecanismo:"Potencia las vias descendentes inhibitorias del dolor a nivel espinal aumentando la disponibilidad de serotonina y noradrenalina",dosis:"30-120 mg/dia en 1-2 tomas; comenzar con 30 mg y aumentar a las 2 semanas",cuidadosEnfermeria:["Administrar con alimentos para reducir nauseas iniciales","Monitorizar PA (puede elevarla levemente)","Vigilar ideacion suicida en las primeras semanas (efecto clase antidepresivos)","Contraindicada en insuficiencia hepatica grave","No suspender abruptamente: sindrome de discontinuacion"]},{nombre:"Cianocobalamina (Vitamina B12)",grupo:"Vitamina del complejo B / neuroprotector",mecanismo:"Cofactor esencial para la sintesis de mielina y mantenimiento de la integridad axonal; revierte la neuropatia carencial",dosis:"1000 mcg IM diaria por 7 dias, luego semanal por 4 semanas, luego mensual de mantenimiento",cuidadosEnfermeria:["Administrar por via intramuscular en el cuadrante superoexterno del gluteo","Verificar que no haya alergia a cobalaminas","Explicar que la mejor\xeda es gradual (semanas a meses)","En deficit severo, puede empeorar transitoriamente la neuropatia al inicio (desmielinizacion por remielinizacion rapida)"]}],noFarmacologico:["Control glucemico estricto en neuropatia diabetica (HbA1c < 7%)","Abstinencia total de alcohol en neuropatia alcoholica","Fisioterapia y rehabilitacion neuromotora distal","Ortesis de tobillo-pie para pie caido","Cuidados podologicos regulares y calzado terapeutico en diabeticos","Ejercicio aerobico moderado con supervision por riesgo de caidas","TENS (estimulacion electrica transcutanea) para dolor neuropatico refractario"]},cuidadosEnfermeria:{valoracion:["Escala de dolor neuropatico: DN4 o LANSS para caracterizar el dolor","Evaluacion de fuerza muscular distal (dorsiflexion del pie, prehension digital)","Test del monofilamento 10 g en 10 puntos del pie en pacientes diabeticos","Inspeccion de pies: ulceras, fisuras, callosidades, deformidades, temperatura","Evaluacion del riesgo de caidas (Tinetti, Timed Up and Go)","Estado nutricional y habitos de consumo de alcohol"],intervenciones:["Administrar analgesicos neuropaticos segun indicacion medica","Educacion en cuidado de pies a pacientes diabeticos","Implementar medidas de prevencion de caidas en el entorno hospitalario","Facilitar consulta con podologia y ortopedia para calzado adaptado","Curar ulceras neuropaticas con tecnica humeda y descarga de presion","Valorar y derivar componente depresivo o ansioso asociado al dolor cronico"],educacionPaciente:["Importancia del control glucemico para frenar la progresion de la neuropatia diabetica","Inspeccion diaria de los pies con espejo si hay perdida de sensibilidad","No caminar descalzo; uso de calzado cerrado y sin costuras internas","Manejo del agua caliente: riesgo de quemaduras por perdida de sensacion termica","Ejercicios de fisioterapia y entrenamiento del equilibrio en casa","Reconocer signos de ulcera infectada: fiebre, enrojecimiento, secrecion"],monitorizacion:["Glucemia preprandial y postprandial en neuropatia diabetica","HbA1c cada 3 meses","Inspeccion de pies en cada consulta de enfermeria","Evaluacion del dolor neuropatico con DN4 periodicamente","Control de PA ortost\xe1tica mensual (neuropatia autonoma)","Peso corporal (riesgo de aumento con pregabalina)"]},npiNanda:[{codigo:"00133",nombre:"Dolor cronico",definicion:"Experiencia sensitiva y emocional desagradable ocasionada por una lesion tisular real o potencial, de inicio subito o lento, de cualquier intensidad de leve a grave, recurrente o sin un final anticipado o previsible, de duracion mayor de 3 meses",caracteristicasDefinitorias:["Informe de dolor con caracteristicas neuropaticas: ardor, alodinia","Cambios en el patron de sueno","Fatiga","Depresion"],factoresRelacionados:["Dano a nervios perifericos","Enfermedad cronica subyacente (DM, IRC)","Proceso inflamatorio neuropatico"]},{codigo:"00155",nombre:"Riesgo de caidas",definicion:"Vulnerable a sufrir un aumento de la susceptibilidad a las caidas que puede causar da\xf1o fisico y comprometer la salud",caracteristicasDefinitorias:["Alteracion del equilibrio","Perdida de la sensibilidad propioceptiva","Debilidad muscular distal"],factoresRelacionados:["Neuropatia periferica con perdida de propiocepcion","Hipotension ortostatica","Efectos sedantes de la medicacion neuropatica"]},{codigo:"00044",nombre:"Deterioro de la integridad tisular",definicion:"Lesion de la membrana mucosa, cornea, sistema tegumentario, fascia muscular, musculo, tendon, hueso, cartilago, capsula articular y/o ligamento",caracteristicasDefinitorias:["Ulcera neuropatica en zonas de presion plantar","Tejido destruido","Perdida de la sensibilidad protectora"],factoresRelacionados:["Perdida de sensibilidad en pie","Presion sostenida por calzado inadecuado","Deterioro de la circulacion tisular"]}],npiNic:[{codigo:"1400",nombre:"Manejo del dolor",actividades:["Utilizar escala DN4 para caracterizar el dolor neuropatico","Administrar analgesicos neuropaticos segun pauta prescrita","Evaluar eficacia del tratamiento farmacologico periodicamente","Implementar tecnicas no farmacologicas: TENS, calor suave","Derivar a clinica del dolor si el control es insuficiente"]},{codigo:"6490",nombre:"Prevencion de caidas",actividades:["Identificar el riesgo de caidas mediante escala validada","Mantener entorno libre de obstaculos con iluminacion adecuada","Proporcionar calzado antideslizante","Indicar uso de dispositivos de ayuda (baston, andador) si es necesario","Ensenar tecnicas de transferencia segura"]},{codigo:"3590",nombre:"Vigilancia de la piel",actividades:["Inspeccionar la piel de los pies diariamente en busca de lesiones","Aplicar crema hidratante evitando espacios interdigitales","Vigilar temperatura, color y textura de los pies","Documentar y comunicar cualquier lesion cutanea nueva","Derivar a podologia para cuidado de callosidades y unas"]}],npiNoc:[{codigo:"2102",nombre:"Nivel del dolor",indicadores:["Intensidad del dolor neuropatico en reposo","Intensidad del dolor neuropatico con actividad","Frecuencia del dolor","Interferencia del dolor con el sueno"],escala:"1=Grave, 2=Sustancial, 3=Moderado, 4=Leve, 5=Ninguno"},{codigo:"1101",nombre:"Integridad tisular: piel y mucosas",indicadores:["Integridad de la piel en pies","Ausencia de lesiones o ulceras","Temperatura de la piel normal","Sensacion cutanea"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"}],complicaciones:["Ulcera de pie diabetico con riesgo de amputacion","Infeccion de ulcera neuropatica (celulitis, osteomielitis)","Caidas y fracturas por perdida de propiocepcion","Articulacion de Charcot (neuroartropatia destructiva)","Quemaduras por perdida de sensibilidad termica","Depresion mayor por dolor cronico incapacitante","Gastroparesia severa con malnutricion en neuropatia autonoma diabetica","Muerte subita cardiaca en neuropatia autonoma cardiovascular"],criteriosAlarma:["Ulcera de pie con signos de infeccion: fiebre, celulitis, secrecion purulenta","Debilidad proximal de instalacion rapida (descartar CIDP o GBS)","Disfagia o disnea asociada a neuropatia (compromiso de pares craneales)","Sincope recurrente por hipotension ortostatica","Perdida de peso > 10% por gastroparesia","Caidas repetidas con traumatismos"],emergencyLevel:"leve",relatedPathologyIds:["pat_dm2","pat_irc","pat_hipotiroidismo","pat_sindrome_guillain_barre"],isPremium:!0},{id:"pat_cistitis",nombre:"Cistitis",bodySystemId:"renal_urinario",definicion:"Infeccion bacteriana del tracto urinario inferior que afecta la vejiga urinaria, caracterizada por inflamacion de la mucosa vesical. Es la infeccion urinaria mas frecuente, producida predominantemente por Escherichia coli en el 80-85% de los casos.",epidemiologia:"Afecta principalmente a mujeres en edad fertil (proporcion mujer:hombre 8:1). El 50-60% de las mujeres padece al menos un episodio en su vida. Incidencia de 0.5-0.7 episodios por mujer/ano. En hombres es infrecuente y sugiere patologia estructural subyacente.",factoresRiesgo:["Sexo femenino (uretra corta)","Actividad sexual reciente","Uso de diafragma o espermicidas","Embarazo","Menopausia (deficit estrogenico)","Antecedentes de ITU recurrentes","Cateterizacion vesical","Diabetes mellitus","Inmunosupresion","Anomalias del tracto urinario"],fisiopatologia:"Los uropatogenos ascienden desde el perineo hacia la uretra y vejiga. E. coli posee fimbrias tipo 1 y P que se adhieren al urotelio, colonizando la mucosa vesical. La respuesta inflamatoria local genera edema, hiperemia y exudado que producen los sintomas irritativos. La invasion del urotelio activa cascadas inflamatorias con liberacion de citoquinas, prostaglandinas y mediadores del dolor que causan la hipersensibilidad vesical y el espasmo del detrusor.",signosYSintomas:{signos:["Orina turbia o maloliente","Hematuria macroscopica (en cistitis hemorragica)","Pu\xf1o-percusion lumbar negativa (diferencia de pielonefritis)","Sensibilidad suprapubica a la palpacion","Ausencia de fiebre alta (temperatura < 38\xb0C)"],sintomas:["Disuria (dolor o ardor al orinar)","Polaquiuria (aumento de frecuencia miccional)","Urgencia miccional imperiosa","Tenesmo vesical","Dolor suprapubico","Hematuria microscopica o macroscopica","Orina de mal olor","Nocturia"]},clasificacion:{nombre:"Clasificacion clinica de ITU baja",tipos:[{nombre:"Cistitis no complicada",descripcion:"Mujer premenopausica, no embarazada, sin anomalias urologicas ni comorbilidades"},{nombre:"Cistitis complicada",descripcion:"Asociada a factores que aumentan riesgo de fracaso terapeutico: embarazo, diabetes, anomalias urologicas, hombre, cateter"},{nombre:"Cistitis recurrente",descripcion:"3 o mas episodios en 12 meses o 2 en 6 meses"},{nombre:"Cistitis hemorragica",descripcion:"Con hematuria macroscopica significativa, puede ser secundaria a quimioterapia o radioterapia"}]},diagnostico:{anamnesis:["Inicio y duracion de sintomas urinarios","Presencia de fiebre, escalofrios, dolor lumbar (sugiere pielonefritis)","Actividad sexual reciente","Antecedentes de ITU previas y tratamientos utilizados","Medicacion actual (antibioticos recientes)","Embarazo o posibilidad de embarazo","Uso de cateter vesical"],examenFisico:["Temperatura corporal","Palpacion abdominal (sensibilidad suprapubica)","Pu\xf1o-percusion lumbar bilateral","Inspeccion del meato uretral","Tacto vaginal en caso de sospecha de vaginitis"],pruebas:[{nombre:"Tira reactiva de orina (uroan\xe1lisis)",descripcion:"Detecta nitritos (bacterias gram negativas), leucocitos (esterasa leucocitaria) y hematuria",valoresReferencia:"Nitritos positivos y/o leucocitos > 10/campo = sugestivo de ITU",cuidadosEnfermeria:["Obtener muestra de orina de chorro medio","Instruir higiene previa adecuada del meato","Leer resultados en el tiempo indicado por fabricante","Conservar tiras en envase cerrado"]},{nombre:"Urocultivo con antibiograma",descripcion:"Identifica el germen causal y su sensibilidad antibiotica. Indicado en cistitis complicada, recurrente o fracaso de tratamiento",valoresReferencia:"Significativo: > 100.000 UFC/mL en muestra de chorro medio",cuidadosEnfermeria:["Recolectar orina de chorro medio en frasco esteril","Enviar al laboratorio antes de iniciar antibiotico","Conservar a 4\xb0C si hay demora > 1 hora","Registrar hora y fecha de recoleccion"]},{nombre:"Sedimento urinario (microscopico)",descripcion:"Confirma piuria (> 5 leucocitos/campo), hematuria y bacteriuria",valoresReferencia:"Piuria: > 5 leucocitos por campo de alto poder",cuidadosEnfermeria:["Muestra de chorro medio en recipiente limpio","Procesar en menos de 2 horas o refrigerar","Evitar contaminacion con secreciones vaginales"]},{nombre:"Ecografia renal y vesical",descripcion:"Indicada en cistitis recurrente o complicada para descartar litiasis, anomalias y residuo postmiccional",valoresReferencia:"Residuo postmiccional normal < 50 mL",cuidadosEnfermeria:["Paciente con vejiga llena para estudio vesical","No requiere ayuno ni preparacion especial","Registrar hora de ultima miccion"]}]},tratamientoMedico:{objetivos:["Erradicar el agente causal","Aliviar sintomas en 48-72 horas","Prevenir ascenso a pielonefritis","Evitar recurrencias","Minimizar resistencias antibioticas"],farmacologico:[{nombre:"Fosfomicina trometamol",grupo:"Antibiotico: inhibidor de la sintesis de pared bacteriana",mecanismo:"Inhibe la enzima piruvil transferasa bloqueando el primer paso de la sintesis de peptidoglicano",dosis:"3 g dosis unica oral (sobre disuelto en agua)",cuidadosEnfermeria:["Administrar con el estomago vacio o con alimentos leves","Explicar que es dosis unica y no requiere mas tomas","Informar que los sintomas mejoran en 2-3 dias","Vigilar reacciones alergicas aunque son raras","Contraindicado en insuficiencia renal grave"]},{nombre:"Nitrofurantoina",grupo:"Antibiotico nitrofurano",mecanismo:"Genera radicales reactivos que danan el DNA bacteriano; actua selectivamente en orina",dosis:"100 mg/12h x 5-7 dias (liberacion modificada) o 50-100 mg/6h x 7 dias",cuidadosEnfermeria:["Administrar con alimentos para reducir nauseas","Advertir que la orina puede tornarse marron-amarillenta (normal)","Contraindicada en insuficiencia renal (ClCr < 45 mL/min)","Vigilar sintomas pulmonares en uso prolongado","No usar en embarazo al termino ni en neonatos"]},{nombre:"Trimetoprim-sulfametoxazol (TMP-SMX)",grupo:"Antibiotico: inhibidor del metabolismo del folato",mecanismo:"Inhibicion secuencial de la sintesis de tetrahidrofolato bacteriano",dosis:"160/800 mg/12h x 3 dias en no complicada",cuidadosEnfermeria:["Verificar resistencia local antes de prescribir (>20% contraindica uso empirico)","Asegurar adecuada hidratacion para prevenir cristaluria","Vigilar reacciones cutaneas (Stevens-Johnson raro pero grave)","Monitorizar potasio en pacientes con riesgo de hiperpotasemia","Administrar con abundante agua"]}],noFarmacologico:["Hidratacion abundante (2-3 litros de agua al dia)","Higiene perineal adecuada (limpieza de adelante hacia atras)","Miccion postcoital","Evitar retencion voluntaria de orina","Uso de ropa interior de algodon","Evitar irritantes locales (jabones perfumados, sprays)","Jugo de ar\xe1nda\xf1os (evidencia limitada pero puede reducir adherencia bacteriana)"]},cuidadosEnfermeria:{valoracion:["Evaluar frecuencia, urgencia y caracteristicas del dolor al orinar","Registrar temperatura y signos vitales","Valorar aspecto, color y olor de la orina","Cuantificar diuresis","Identificar factores precipitantes","Descartar sintomas de pielonefritis (fiebre alta, escalofrios, dolor lumbar)"],intervenciones:["Recolectar muestra de orina correctamente antes de iniciar antibioticoterapia","Administrar antibioticos segun prescripcion medica","Fomentar ingesta hidrica adecuada","Proporcionar analgesia para alivio de disuria segun indicacion","Monitorizar respuesta clinica a las 48-72 horas","Educar sobre medidas preventivas de recurrencia"],educacionPaciente:["Completar el tratamiento antibiotico aunque mejoren los sintomas","Beber al menos 2 litros de agua por dia","Orinar inmediatamente despues de las relaciones sexuales","Tecnica correcta de higiene perineal","Consultar si los sintomas no mejoran en 48-72 horas o aparece fiebre","Reconocer signos de pielonefritis que requieren consulta urgente"],monitorizacion:["Temperatura cada 6-8 horas","Diuresis y caracteristicas de orina","Respuesta a antibioticoterapia a las 48-72 horas","Aparicion de sintomas de extension a via urinaria alta","Control de urocultivo postratamiento en casos complicados o recurrentes"]},npiNanda:[{codigo:"00016",nombre:"Deterioro de la eliminacion urinaria",definicion:"Disfuncion en la eliminacion de orina",caracteristicasDefinitorias:["Disuria","Polaquiuria","Urgencia miccional","Hematuria"],factoresRelacionados:["Infeccion del tracto urinario","Inflamacion de la mucosa vesical","Irritacion de los receptores vesicales"]},{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable ocasionada por una lesion tisular real o potencial",caracteristicasDefinitorias:["Verbalizacion de dolor o ardor al orinar","Expresion facial de dolor","Conducta protectora"],factoresRelacionados:["Agentes biologicos: infeccion bacteriana","Inflamacion del urotelio","Espasmo del detrusor"]},{codigo:"00004",nombre:"Riesgo de infeccion",definicion:"Vulnerable a ser invadido y multiplicado por organismos patogenos que puede comprometer la salud",caracteristicasDefinitorias:[],factoresRelacionados:["Procedimientos invasivos (cateterizacion)","Defensa primaria inadecuada","Conocimiento insuficiente para evitar la exposicion"]}],npiNic:[{codigo:"0590",nombre:"Manejo de la eliminacion urinaria",actividades:["Monitorizar la eliminacion urinaria, incluyendo frecuencia y caracteristicas","Instruir al paciente sobre signos de infeccion urinaria","Fomentar la ingesta hidrica adecuada","Obtener muestras de orina para analisis"]},{codigo:"1400",nombre:"Manejo del dolor",actividades:["Realizar valoracion exhaustiva del dolor","Administrar analgesicos y antiespasm\xf3dicos segun prescripcion","Evaluar eficacia de las medidas de control del dolor","Aplicar calor local suprapubico para alivio del espasmo"]},{codigo:"5510",nombre:"Educacion para la salud",actividades:["Ense\xf1ar medidas preventivas de ITU recurrente","Explicar la importancia de completar el tratamiento antibiotico","Informar sobre hidratacion adecuada","Indicar signos de alarma para consulta urgente"]}],npiNoc:[{codigo:"0503",nombre:"Eliminacion urinaria",indicadores:["Patron de eliminacion en rango esperado","Ausencia de disuria","Ausencia de urgencia urinaria","Orina de color claro"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"},{codigo:"2102",nombre:"Nivel del dolor",indicadores:["Dolor referido ausente o minimo","Muecas de dolor ausentes","Frecuencia cardiaca en rango normal"],escala:"1=Grave, 2=Sustancial, 3=Moderado, 4=Leve, 5=Ninguno"}],complicaciones:["Pielonefritis aguda por ascenso de infeccion","Cistitis recurrente","Sepsis urinaria en inmunocomprometidos","Cistitis cronica","Infeccion urinaria en embarazo (riesgo de parto prematuro)","Resistencia antibiotica por uso inadecuado"],criteriosAlarma:["Fiebre > 38\xb0C (sugiere pielonefritis)","Dolor lumbar intenso","Escalofrios y temblores","Nauseas y vomitos","Ausencia de mejoria a las 48-72 horas de tratamiento","Hematuria macroscopica intensa","Signos de sepsis: taquicardia, hipotension, alteracion del sensorio"],emergencyLevel:"leve",relatedPathologyIds:["pat_pielonefritis","pat_litiasis_renal","pat_irc"],isPremium:!0},{id:"pat_necrosis_tubular",nombre:"Necrosis Tubular Aguda",bodySystemId:"renal_urinario",definicion:"Forma mas frecuente de lesion renal aguda intrinseca, caracterizada por da\xf1o y muerte celular de los tubulos renales como consecuencia de isquemia sostenida o exposicion a agentes nefrotoxicos, resultando en deterioro brusco de la funcion renal.",epidemiologia:"Representa el 50% de las causas de lesion renal aguda en pacientes hospitalizados. Incidencia del 5% en hospitalizados generales y hasta 30% en UCI. La mortalidad en UCI puede superar el 50% cuando se asocia a fallo multiorganico. Es la principal causa de dialisis aguda en pacientes criticos.",factoresRiesgo:["Shock hipovolemico, septico o cardiogenico","Cirugia mayor (cardiovascular, abdominal)","Exposicion a contrastes yodados","Aminoglucosidos, anfotericina B, cisplatino","Mioglobinuria (rabdomiolisis)","Hemoglobinuria (hemolisis masiva)","Edad avanzada","Insuficiencia renal cronica preexistente","Diabetes mellitus","Hipovolemia preexistente"],fisiopatologia:"En la NTA isquemica, la hipoperfusion renal causa deplecion de ATP en celulas tubulares, especialmente en el segmento S3 del tubulo proximal y la rama ascendente del asa de Henle (zona mas vulnerable por su alta demanda energetica y baja tension de oxigeno). Esto produce: disfuncion de bombas ionicas con entrada de calcio intracelular, generacion de radicales libres, activacion de proteasas y fosfolipasas, y muerte celular por necrosis y apoptosis. Las celulas muertas se desprenden obstruyendo los tubulos. En la NTA nefrotoxica, los toxicos se concentran en el tubulo proximal durante la reabsorcion, produciendo da\xf1o directo del citoplasma y mitocondrias.",signosYSintomas:{signos:["Oliguria (diuresis < 400 mL/24h) en fase oligurica","Elevacion de creatinina serica (> 0.3 mg/dL en 48h o > 50% en 7 dias)","Edema generalizado por retencion hidrosalina","Hipertension arterial por sobrecarga de volumen","Cilindros granulosos y celulas tubulares en sedimento urinario","Sodio urinario > 40 mEq/L (fracaso en reabsorcion tubular)"],sintomas:["Oliguria o anuria progresiva","Nauseas y vomitos","Letargo y confusion (uremia)","Debilidad muscular (hiperpotasemia)","Disnea (sobrecarga de volumen o acidosis)","Prurito (acumulo de toxinas uremicas)","Anorexia"]},clasificacion:{nombre:"Clasificacion KDIGO de Lesion Renal Aguda",tipos:[{nombre:"Estadio 1",descripcion:"Creatinina x 1.5-1.9 veces el valor basal o aumento >= 0.3 mg/dL; diuresis < 0.5 mL/kg/h por 6-12h"},{nombre:"Estadio 2",descripcion:"Creatinina x 2.0-2.9 veces el valor basal; diuresis < 0.5 mL/kg/h por >= 12h"},{nombre:"Estadio 3",descripcion:"Creatinina x 3 veces el valor basal o >= 4 mg/dL; anuria >= 12h o inicio de terapia de reemplazo renal"}]},diagnostico:{anamnesis:["Evento desencadenante: hipotension, sepsis, cirugia, nefrotoxicos","Tiempo de evolucion del descenso de diuresis","Medicacion nefrotoxica reciente (AINEs, contrastes, aminoglucosidos)","Funcion renal basal previa","Antecedentes de diabetes, HTA o enfermedad renal cronica","Signos de rabdomiolisis: orina color cola, dolor muscular, trauma"],examenFisico:["Peso diario y balance hidrico","Presion arterial y frecuencia cardiaca","Signos de hipovolemia vs sobrecarga de volumen","Edema con godet","Ingurgitacion yugular","Auscultacion pulmonar (crepitantes por edema)"],pruebas:[{nombre:"Creatinina y urea serica seriadas",descripcion:"Monitoreo de la evolucion de la funcion renal. Tasa de filtracion glomerular estimada (TFGe)",valoresReferencia:"Creatinina normal: 0.6-1.2 mg/dL; Urea: 15-40 mg/dL",cuidadosEnfermeria:["Extracciones seriadas en horarios establecidos","Registrar junto a balance hidrico y diuresis","Comunicar valores criticos al medico de inmediato"]},{nombre:"Ionograma serico completo",descripcion:"Detecta hiperpotasemia (riesgo de arritmias), hiponatremia, acidosis metabolica",valoresReferencia:"K+ 3.5-5.0 mEq/L; Na+ 135-145 mEq/L; Bicarbonato 22-26 mEq/L",cuidadosEnfermeria:["ECG urgente si K+ > 6.0 mEq/L","Comunicar hiperpotasemia grave de inmediato","No administrar soluciones con potasio sin indicacion"]},{nombre:"Sedimento urinario",descripcion:"En NTA muestra cilindros granulosos pardos, celulas tubulares epiteliales descamadas",valoresReferencia:"Cilindros granulosos = hallazgo diagnostico de NTA",cuidadosEnfermeria:["Obtener muestra fresca y procesarla en < 1 hora","Registrar hora de obtencion","Medir densidad urinaria simultaneamente"]},{nombre:"Ecografia renal doppler",descripcion:"Descarta obstruccion (causa posrenal), evalua tamano y flujo vascular renal",valoresReferencia:"Indice de resistencia normal < 0.7; ri\xf1ones de tamano normal",cuidadosEnfermeria:["Preparar al paciente en decubito supino","No requiere ayuno","Mantener sonda vesical permeable durante el estudio"]}]},tratamientoMedico:{objetivos:["Identificar y corregir la causa desencadenante","Mantener hemodinamia y perfusion renal optimas","Prevenir complicaciones metabolicas (hiperpotasemia, acidosis, sobrecarga)","Iniciar terapia de reemplazo renal si indicado","Proteger funcion renal residual"],farmacologico:[{nombre:"Furosemida",grupo:"Diuretico de asa",mecanismo:"Inhibe el cotransportador NKCC2 en el asa de Henle; convierte NTA oligurica en no oligurica facilitando manejo hidrico",dosis:"40-200 mg IV en bolo; perfusion continua 10-40 mg/h si hay respuesta inicial",cuidadosEnfermeria:["Monitorizar diuresis horaria tras la dosis","Controlar electrolitos especialmente potasio y sodio","Administrar lentamente IV (no mas de 4 mg/min) para evitar ototoxicidad","Vigilar hipotension por depleccion de volumen","Registrar balance hidrico estricto"]},{nombre:"Bicarbonato de sodio",grupo:"Alcalinizante sistemico",mecanismo:"Corrige la acidosis metabolica por acumulo de acidos no volatiles; reduce hiperpotasemia al desplazar K+ intracelularmente",dosis:"1-2 mEq/kg IV segun gasometria; infusion continua segun brecha anionico",cuidadosEnfermeria:["Administrar diluido en solucion glucosada (no en NaCl 0.9%)","Monitorizar pH y bicarbonato serico con gasometrias seriadas","Vigilar signos de hipocalcemia (tetania) por alcalinizacion","No mezclar con calcio (precipita)","Controlar sobrecarga de sodio en pacientes con oliguria"]},{nombre:"Gluconato de calcio",grupo:"Estabilizador de membrana cardiaca",mecanismo:"Antagoniza los efectos de la hiperpotasemia sobre la membrana cardiaca estabilizando el potencial de accion",dosis:"1 g IV lento (10 mL de solucion al 10%) en 2-5 min; repetir si ECG no normaliza",cuidadosEnfermeria:["Uso urgente en hiperpotasemia grave (K+ > 6.5 mEq/L o cambios en ECG)","Monitorizar ECG continuamente durante la infusion","Administrar lentamente para evitar bradicardia y paro cardiaco","Efecto dura 30-60 min: preparar medidas definitivas de descenso de potasio","No mezclar con bicarbonato en la misma via"]}],noFarmacologico:["Balance hidrico estricto con objetivo euvolemico","Restriccion de potasio en la dieta (< 2 g/dia)","Restriccion proteica moderada (0.6-0.8 g/kg/dia) salvo en catabolismo","Restriccion de fosforo","Terapia de reemplazo renal (hemodialisis o CRRT) si: K+ > 6.5, pH < 7.1, sobrecarga refractaria, uremia sintomatica","Evitar nefrotoxicos adicionales","Ajuste de dosis de medicamentos segun TFG"]},cuidadosEnfermeria:{valoracion:["Medicion horaria de diuresis con sonda vesical","Balance hidrico cada 6-12 horas","Peso corporal diario en ayunas","Monitoreo de signos vitales con PAM objetivo > 65 mmHg","Evaluacion de nivel de consciencia (encefalopatia uremica)","Vigilar signos de hiperpotasemia: debilidad muscular, arritmias"],intervenciones:["Instalar y mantener sonda vesical permeable para monitoreo de diuresis horaria","Administrar fluidos segun balance y prescripcion medica","Administrar medicacion nefroprotectora y correctora segun indicacion","Preparar y asistir en sesiones de hemodialisis o CRRT","Restringir aporte de potasio y fosforo","Monitorizar ECG en hiperpotasemia"],educacionPaciente:["Explicar la naturaleza y evolucion esperada de la NTA","Importancia del control estricto de liquidos y dieta","Reconocer signos de alarma: debilidad muscular severa, palpitaciones, confusion","Adherencia a restricciones dieteticas de potasio y fosforo","Seguimiento ambulatorio de funcion renal tras el alta"],monitorizacion:["Diuresis horaria","Creatinina y ionograma cada 6-12 horas en fase aguda","ECG en hiperpotasemia","Gasometria arterial para control de acidosis","Presion arterial y frecuencia cardiaca continua","Peso diario y balance hidrico"]},npiNanda:[{codigo:"00023",nombre:"Retencion urinaria",definicion:"Vaciamiento incompleto de la vejiga",caracteristicasDefinitorias:["Oliguria o anuria","Diuresis inferior a 0.5 mL/kg/h","Ausencia de miccion espontanea"],factoresRelacionados:["Dano tubular renal por isquemia o nefrotoxicos","Obstruccion intratubular por celulas descamadas","Reduccion de la filtracion glomerular"]},{codigo:"00025",nombre:"Riesgo de desequilibrio del volumen de liquidos",definicion:"Vulnerable a una disminucion, aumento o desplazamiento rapido de los liquidos intravasculares, intersticiales y/o intracelulares",caracteristicasDefinitorias:[],factoresRelacionados:["Oliguria con retencion hidrosalina","Perdidas extrarrenales concurrentes","Terapia diuretica"]},{codigo:"00195",nombre:"Riesgo de desequilibrio electrolitico",definicion:"Vulnerable a cambios en los niveles de electrolitos sericos que pueden comprometer la salud",caracteristicasDefinitorias:[],factoresRelacionados:["Insuficiencia renal","Incapacidad de excretar potasio y acidos","Tratamiento diuretico"]}],npiNic:[{codigo:"4200",nombre:"Terapia intravenosa",actividades:["Administrar fluidos IV segun prescripcion y balance hidrico","Monitorizar respuesta hemodinamica a la fluidoterapia","Vigilar signos de sobrecarga de volumen","Mantener via venosa permeable para medicacion urgente"]},{codigo:"4130",nombre:"Monitoreo de liquidos",actividades:["Medir diuresis horaria con precision","Registrar balance hidrico cada 6 horas","Pesar al paciente diariamente","Controlar presion venosa central si disponible"]},{codigo:"2080",nombre:"Manejo de liquidos y electrolitos",actividades:["Monitorizar niveles de electrolitos serico","Corregir desequilibrios segun protocolo","Restringir potasio en dieta y liquidos","Preparar para terapia de reemplazo renal si indicado"]}],npiNoc:[{codigo:"0601",nombre:"Equilibrio hidrico",indicadores:["Presion arterial en rango esperado","Peso corporal estable","Ausencia de edema periferico","Diuresis en rango normal"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"},{codigo:"0602",nombre:"Hidratacion",indicadores:["Turgencia cutanea normal","Membranas mucosas humectadas","Hematocrito en rango normal"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"}],complicaciones:["Hiperpotasemia grave con arritmias letales","Acidosis metabolica grave","Sobrecarga de volumen con edema pulmonar agudo","Encefalopatia uremica","Pericarditis uremica","Sepsis","Progresion a enfermedad renal cronica","Muerte en pacientes criticos con fallo multiorganico"],criteriosAlarma:["Anuria (diuresis < 100 mL/24h)","Potasio > 6.0 mEq/L","Cambios en ECG por hiperpotasemia (ondas T picudas, ensanchamiento QRS)","pH arterial < 7.2","Creatinina > 4 mg/dL o aumento > 0.5 mg/dL/hora","Signos de edema pulmonar agudo","Deterioro del nivel de consciencia"],emergencyLevel:"critico",relatedPathologyIds:["pat_irc","pat_sepsis","pat_shock_hipovolemico"],isPremium:!0},{id:"pat_mola_hidatiforme",nombre:"Mola Hidatiforme",bodySystemId:"reproductivo",definicion:"Enfermedad trofoblastica gestacional caracterizada por proliferacion anormal del trofoblasto con degeneracion hidropica de las vellosidades coriales. Representa el extremo benigno del espectro de la enfermedad trofoblastica gestacional, aunque puede progresar a coriocarcinoma.",epidemiologia:"Incidencia en paises occidentales: 1 por 1000-1500 embarazos. Mayor incidencia en Asia (1/100-500). En Argentina, aproximadamente 1/1000 gestaciones. El riesgo de progresion a neoplasia trofoblastica gestacional es del 15-20% para mola completa y 1-5% para mola parcial.",factoresRiesgo:["Edad materna extrema (< 20 o > 40 a\xf1os)","Antecedente de embarazo molar previo (riesgo x10)","Dieta deficiente en vitamina A y carotenos","Grupos sanguineos especificos","Antecedentes de abortos espontaneos","Origen asiatico o latinoamericano"],fisiopatologia:"La mola completa resulta de la fecundacion de un ovulo sin nucleo por un espermatozoide que duplica su material genetico (cariotipo 46XX o 46XY, todo de origen paterno). No hay tejido embrionario. La mola parcial resulta de fecundacion de un ovulo normal por dos espermatozoides (triploide 69XXY). Las vellosidades hidr\xf3picas se forman por acumulo de liquido intravellositario y proliferacion trofoblastica. La produccion masiva de hCG produce manifestaciones clinicas y puede causar luteinizacion bilateral de los ovarios (quistes tecalute\xednicos).",signosYSintomas:{signos:["Utero mayor de lo esperado para la edad gestacional (mola completa)","Utero igual o menor de lo esperado (mola parcial)","Quistes tecaluteinicos en ecografia (30% mola completa)","Beta-hCG muy elevada (> 100.000 mUI/mL en mola completa)","Imagen en 'tormenta de nieve' en ecografia","Ausencia de latido fetal (mola completa)"],sintomas:["Sangrado vaginal en primer trimestre (sintoma mas frecuente, 97%)","Nauseas y vomitos intensos (hiperemesis por hCG elevada)","Dolor pelvico","Expulsion de vesiculas (patognomonico)","Signos de preeclampsia precoz (< 20 semanas)","Hipertiroidismo clinico (hCG estimula receptor TSH)"]},clasificacion:{nombre:"Clasificacion histologica OMS",tipos:[{nombre:"Mola completa",descripcion:"Sin embrion ni tejido fetal. Todas las vellosidades hidr\xf3picas. Cariotipo 46XX diandrico. Alto riesgo de malignizacion (15-20%)"},{nombre:"Mola parcial",descripcion:"Con tejido fetal o embrionario. Solo algunas vellosidades hidr\xf3picas. Cariotipo triploide 69XXY. Menor riesgo de malignizacion (1-5%)"},{nombre:"Mola invasora",descripcion:"Invasion miometrial o parametrial. Puede producir metastasis. Forma de neoplasia trofoblastica gestacional"}]},diagnostico:{anamnesis:["Fecha de ultima menstruacion y edad gestacional estimada","Caracteristicas del sangrado vaginal","Expulsion de material vesicular","Intensidad de nauseas y vomitos","Sintomas de hipertiroidismo o preeclampsia","Antecedentes de embarazo molar previo"],examenFisico:["Altura uterina (comparar con edad gestacional)","Auscultacion de latidos fetales","Presion arterial (buscar preeclampsia precoz)","Palpacion de masas ov\xe1ricas (quistes tecaluteinicos)","Signos de hipertiroidismo: taquicardia, temblor, exoftalmos"],pruebas:[{nombre:"Beta-hCG cuantitativa seriada",descripcion:"Marcador diagnostico y de seguimiento fundamental. Valores muy elevados sugieren mola completa",valoresReferencia:"Embarazo normal 10-12 sem: 20.000-100.000 mUI/mL; Mola completa: > 100.000 mUI/mL frecuente",cuidadosEnfermeria:["Extraer muestra antes de la evacuacion molar","Registrar fecha exacta para calculo de curva de descenso","Coordinar seguimiento seriado post-evacuacion","Conservar muestra refrigerada si no se procesa en el momento"]},{nombre:"Ecografia transvaginal",descripcion:"Imagen caracteristica en tormenta de nieve. Ausencia de embrion en mola completa. Detecta quistes tecaluteinicos",valoresReferencia:"Hallazgo diagnostico: masa heterogenea intrauterina sin saco gestacional normal",cuidadosEnfermeria:["Explicar el procedimiento a la paciente","Asegurar vejiga semivacia para ecografia transvaginal","Proporcionar apoyo emocional durante el estudio","Registrar hallazgos en historia clinica"]},{nombre:"Hemograma completo y grupo y factor",descripcion:"Evalua anemia por sangrado; grupo sanguineo para posible necesidad de transfusion e inmunoglobulina anti-D",valoresReferencia:"Hb > 10 g/dL deseable para el procedimiento de evacuacion",cuidadosEnfermeria:["Extraer antes de la evacuacion","Preparar banco de sangre por posible necesidad transfusional","Administrar inmunoglobulina anti-D en pacientes Rh negativo"]},{nombre:"Radiografia de torax",descripcion:"Descarta metastasis pulmonares previas a la evacuacion y en seguimiento",valoresReferencia:"Sin lesiones metastasicas = estadio I (enfermedad confinada al utero)",cuidadosEnfermeria:["Verificar ausencia de embarazo viable antes de la radiografia","Proteger con delantal plomado zonas no estudiadas","Registrar resultado para comparacion en seguimiento"]}]},tratamientoMedico:{objetivos:["Evacuar completamente el tejido molar del utero","Monitorizar beta-hCG hasta negativizacion completa","Detectar precozmente progresion a neoplasia trofoblastica gestacional","Preservar fertilidad cuando sea posible","Controlar complicaciones medicas asociadas"],farmacologico:[{nombre:"Oxitocina",grupo:"Oxitocico y uterotonicos",mecanismo:"Estimula contraccion del musculo liso uterino reduciendo sangrado post-evacuacion",dosis:"20-40 UI en 1000 mL de suero fisiologico IV, 125-250 mL/hora durante y post-evacuacion",cuidadosEnfermeria:["Iniciar infusion durante la evacuacion quirurgica segun protocolo","Monitorizar tono uterino y sangrado vaginal","Controlar signos de intoxicacion acuosa (hiponatremia): cefalea, confusion","Vigilar presion arterial: puede causar hipotension en bolo rapido","Registrar cantidad de sangrado durante y post-procedimiento"]},{nombre:"Metotrexato",grupo:"Antimetabolito (quimioterapia)",mecanismo:"Inhibe la dihidrofolato reductasa bloqueando la sintesis de DNA en celulas trofoblasticas de rapida division",dosis:"50 mg/m2 IM semanal o 1 mg/kg IM dias 1,3,5,7 alternado con acido folinico",cuidadosEnfermeria:["Solo se administra ante criterios de neoplasia trofoblastica gestacional post-evacuacion","Controlar hemograma antes de cada ciclo (nadir leucocitario dia 7-10)","Evaluar mucositis oral (estomatitis es efecto adverso frecuente)","Verificar funcion hepatica y renal antes de cada dosis","Educar sobre medidas anticonceptivas obligatorias durante el tratamiento"]},{nombre:"Misoprostol",grupo:"Analogo de prostaglandina E1",mecanismo:"Produce maduracion y dilatacion cervical y contracciones uterinas facilitando la evacuacion",dosis:"400-800 mcg sublingual u oral 2-4 horas previas a la aspiracion uterina",cuidadosEnfermeria:["Administrar con agua segun via indicada","Advertir sobre calambres uterinos esperados","Monitorizar sangrado vaginal tras la administracion","Controlar temperatura (puede causar fiebre transitoria)","Registrar hora de administracion para calcular tiempo hasta el procedimiento"]}],noFarmacologico:["Evacuacion uterina por aspiracion al vacio (metodo de eleccion)","Anticoncepcion rigurosa al menos 12 meses post-evacuacion","Seguimiento seriado de beta-hCG semanal hasta negativizacion, luego mensual 6-12 meses","Histerectomia en pacientes sin deseo reproductivo o hemorragia no controlable","Apoyo psicologico para duelo gestacional","Registro detallado de la curva de descenso de hCG"]},cuidadosEnfermeria:{valoracion:["Evaluar sangrado vaginal: cantidad, color, presencia de vesiculas","Monitorizar signos vitales con especial atencion a PA (riesgo de preeclampsia)","Valorar nivel de ansiedad y estado emocional de la paciente","Revisar resultados de beta-hCG y ecografia","Identificar signos de hipertiroidismo o preeclampsia asociados"],intervenciones:["Preparar a la paciente para la evacuacion uterina (consentimiento, via venosa, ayuno)","Administrar uterotonicos segun prescripcion durante y post-procedimiento","Monitorizar sangrado post-evacuacion y tono uterino","Administrar inmunoglobulina anti-D si Rh negativo","Proporcionar apoyo emocional y explicar el proceso de seguimiento","Coordinar y educar sobre la importancia del seguimiento seriado de beta-hCG"],educacionPaciente:["Importancia critica del seguimiento de beta-hCG durante al menos 6-12 meses","Necesidad de anticoncepcion estricta durante el periodo de seguimiento","Reconocer signos de alerta: sangrado abundante, dolor pelvico, disnea (metastasis pulmonar)","Explicar que la mayoria de casos tiene excelente pronostico con tratamiento adecuado","Posibilidad de embarazo normal luego del periodo de seguimiento completo"],monitorizacion:["Beta-hCG semanal hasta negativizacion (objetivo: < 5 mUI/mL)","Signos vitales cada 4 horas en el postoperatorio inmediato","Sangrado vaginal postevacuacion cuantificado","Signos de complicaciones: perforacion uterina, hemorragia, infeccion","Radiografia de torax si hCG no desciende adecuadamente"]},npiNanda:[{codigo:"00206",nombre:"Riesgo de sangrado",definicion:"Vulnerable a una disminucion del volumen sanguineo que puede comprometer la salud",caracteristicasDefinitorias:[],factoresRelacionados:["Embarazo molar con sangrado","Procedimiento de evacuacion uterina","Coagulopatia asociada a embarazo molar masivo"]},{codigo:"00146",nombre:"Ansiedad",definicion:"Sensacion vaga e intranquilizadora de malestar o amenaza acompanada de una respuesta autonoma",caracteristicasDefinitorias:["Expresion de preocupacion por el embarazo","Llanto","Inquietud"],factoresRelacionados:["Diagnostico de patologia gestacional","Amenaza de perdida gestacional","Incertidumbre sobre fertilidad futura"]},{codigo:"00004",nombre:"Riesgo de infeccion",definicion:"Vulnerable a ser invadido y multiplicado por organismos patogenos que puede comprometer la salud",caracteristicasDefinitorias:[],factoresRelacionados:["Procedimiento invasivo uterino","Tejido necrotico retenido","Inmunosupresion relativa del embarazo"]}],npiNic:[{codigo:"4160",nombre:"Control de hemorragias",actividades:["Monitorizar signos vitales y cantidad de sangrado vaginal","Mantener via venosa permeable para transfusion si necesario","Administrar uterotonicos segun prescripcion","Preparar para intervencion quirurgica urgente si hemorragia masiva"]},{codigo:"5270",nombre:"Apoyo emocional",actividades:["Proporcionar escucha activa y empatia","Explicar el diagnostico y pronostico con lenguaje comprensible","Facilitar expresion de emociones","Derivar a apoyo psicologico si necesario"]},{codigo:"5510",nombre:"Educacion para la salud",actividades:["Ense\xf1ar sobre la importancia del seguimiento de hCG","Explicar metodos anticonceptivos indicados","Informar sobre signos de alerta de recurrencia o malignizacion","Orientar sobre plazos para nuevo embarazo"]}],npiNoc:[{codigo:"0413",nombre:"Severidad de la perdida de sangre",indicadores:["Perdida de sangre visible minima","Presion arterial sistolica estable","Hemoglobina en rango normal","Hematocrito en rango normal"],escala:"1=Grave, 2=Sustancial, 3=Moderado, 4=Leve, 5=Ninguno"},{codigo:"1302",nombre:"Afrontamiento de problemas",indicadores:["Verbaliza aceptacion de la situacion","Busca informacion sobre el diagnostico","Utiliza apoyo social disponible"],escala:"1=Nunca demostrado, 2=Raramente demostrado, 3=A veces demostrado, 4=Frecuentemente demostrado, 5=Constantemente demostrado"}],complicaciones:["Hemorragia uterina masiva","Progresion a mola invasora (15% mola completa)","Progresion a coriocarcinoma (2-3%)","Metastasis pulmonares, cerebrales o hepaticas","Perforacion uterina durante evacuacion","Preeclampsia precoz con complicaciones","Hipertiroidismo por estimulacion de hCG","Embolia de celulas trofoblasticas"],criteriosAlarma:["Hemorragia vaginal masiva","Signos de shock hipovolemico: hipotension, taquicardia, palidez","PA > 140/90 antes de las 20 semanas (preeclampsia precoz)","Disnea o hemoptisis (metastasis pulmonar)","Cefalalgia intensa o convulsiones","hCG en meseta o ascenso tras evacuacion (criterio de neoplasia trofoblastica)"],emergencyLevel:"moderado",relatedPathologyIds:["pat_eclampsia","pat_aborto"],isPremium:!0},{id:"pat_eclampsia",nombre:"Eclampsia",bodySystemId:"reproductivo",definicion:"Aparicion de convulsiones tonico-clonicas generalizadas en una paciente con preeclampsia, no atribuibles a otra causa neurologica. Constituye una emergencia obstetrica con riesgo vital materno y fetal.",epidemiologia:"Incidencia de 1.5-10 por 10.000 partos en paises desarrollados; hasta 1/100 partos en paises de bajos recursos. Representa la segunda causa de muerte materna en Argentina. El 50% ocurre durante el embarazo, 25% intraparto y 25% en el puerperio (hasta 6 semanas postparto).",factoresRiesgo:["Preeclampsia severa no controlada","Nuliparidad","Embarazo multiple","Edad extrema (menor de 18 o mayor de 35 a\xf1os)","Obesidad","Diabetes mellitus","Hipertension arterial cronica","Antecedente de eclampsia previa","Enfermedad renal cronica","Trombofilias"],fisiopatologia:"La fisiopatologia se basa en la placentacion anormal con invasion trofoblastica deficiente de arterias espirales, generando isquemia placentaria. Esto activa disfuncion endotelial sistemica con vasoconstriccion, aumento de permeabilidad vascular y activacion de la coagulacion. En el sistema nervioso central, la hipertension severa supera la autorregulacion cerebral causando hiperperfusion, edema vasogenico y convulsiones. El sindrome HELLP puede coexistir.",signosYSintomas:{signos:["PA mayor o igual a 160/110 mmHg","Convulsiones tonico-clonicas generalizadas","Coma postcritico","Hiperreflexia y clonus","Edema generalizado incluyendo cara y manos","Proteinuria mayor de 5 g/24h","Oliguria"],sintomas:["Cefalea intensa frontal u occipital refractaria a analgesicos","Epigastralgia o dolor en hipocondrio derecho","Nauseas y vomitos","Escotomas o vision borrosa y fotopsia","Tinnitus","Confusion o agitacion preconvulsiva"]},clasificacion:{nombre:"Clasificacion segun momento de presentacion",tipos:[{nombre:"Eclampsia antenatal",descripcion:"Convulsiones durante el embarazo, antes del parto"},{nombre:"Eclampsia intraparto",descripcion:"Convulsiones durante el trabajo de parto. Requiere resolucion obstetrica urgente"},{nombre:"Eclampsia postparto",descripcion:"Convulsiones dentro de las 48h del puerperio o hasta 6 semanas postparto (eclampsia tardia)"},{nombre:"Eclampsia con HELLP",descripcion:"Asociada al sindrome HELLP: hemolisis, enzimas hepaticas elevadas, plaquetopenia"}]},diagnostico:{anamnesis:["Antecedentes de preeclampsia diagnosticada","Inicio y caracteristicas de las convulsiones","Sintomas prodromicos: cefalea, epigastralgia, vision borrosa","Edad gestacional y numero de fetos","Medicacion antihipertensiva y anticonvulsivante previa","Antecedente de convulsiones previas al embarazo"],examenFisico:["Medicion urgente de presion arterial","Evaluacion del nivel de consciencia con Escala de Glasgow","Evaluacion de reflejos osteotendinosos (hiperreflexia, clonus)","Fondo de ojo (edema de papila, retinopatia)","Evaluacion de edema","Auscultacion cardiopulmonar"],pruebas:[{nombre:"Hemograma con recuento de plaquetas",descripcion:"Detecta plaquetopenia del sindrome HELLP y hemolisis microangiopatica",valoresReferencia:"Plaquetas menor de 100.000/uL indica HELLP; menor de 50.000 riesgo hemorragico grave",cuidadosEnfermeria:["Extraer urgente con otros estudios","Comunicar plaquetopenia critica de inmediato al equipo medico","Preparar para posible transfusion de plaquetas"]},{nombre:"Hepatograma (TGO, TGP, LDH, bilirrubina)",descripcion:"Elevado en sindrome HELLP. LDH elevada indica hemolisis microangiopatica",valoresReferencia:"TGO/TGP mayor de 2x valor normal mas LDH mayor de 600 UI/L mas plaquetas menor de 100.000 = HELLP",cuidadosEnfermeria:["Extraer junto a hemograma urgente","Registrar valores basales para seguimiento seriado","Comunicar valores criticos al equipo medico"]},{nombre:"Proteinuria en orina (tira o relacion albumina/creatinina)",descripcion:"Confirma el componente renal de la preeclampsia/eclampsia",valoresReferencia:"Proteinuria significativa: mayor de 300 mg/24h o relacion albumina/creatinina mayor de 30 mg/mmol",cuidadosEnfermeria:["Obtener muestra de orina espontanea o por sonda vesical","Registrar diuresis horaria","Comunicar oliguria (menor de 0.5 mL/kg/h)"]},{nombre:"Tomografia o RMN cerebral",descripcion:"Indicada si convulsiones atipicas, focalidad neurologica o no respuesta a tratamiento. Puede mostrar PRES (encefalopatia posterior reversible)",valoresReferencia:"Normal sin lesion estructural o con edema vasogenico occipital reversible",cuidadosEnfermeria:["Asegurar estabilidad hemodinamica antes del traslado al servicio de imagen","Acompanar a la paciente durante el traslado","Verificar ausencia de contraindicaciones para contraste yodado"]}]},tratamientoMedico:{objetivos:["Controlar y prevenir convulsiones recurrentes","Estabilizar la presion arterial en rango seguro","Resolver el embarazo cuando corresponda segun edad gestacional","Prevenir complicaciones maternas y fetales graves","Monitorizar funcion organica materna y bienestar fetal"],farmacologico:[{nombre:"Sulfato de magnesio",grupo:"Anticonvulsivante y neuroprotector",mecanismo:"Antagonista del receptor NMDA; reduce la excitabilidad neuronal y previene convulsiones eclampsicas. Produce vasodilatacion cerebral",dosis:"Carga: 4-6 g IV en 15-20 min; mantenimiento: 1-2 g/h en infusion continua durante 24-48h postparto",cuidadosEnfermeria:["Controlar reflejo patelar cada hora (abolicion indica toxicidad)","Monitorizar frecuencia respiratoria cada 15 min (menor de 12/min indica toxicidad)","Mantener gluconato de calcio 1 g IV como antidoto disponible al pie de cama","Medir diuresis horaria (retencion aumenta niveles sericos de magnesio)","Niveles terapeuticos: 4-7 mEq/L; toxicidad a partir de 8 mEq/L"]},{nombre:"Labetalol",grupo:"Antihipertensivo alfa y betabloqueante",mecanismo:"Bloqueo combinado alfa1 y beta1/beta2 produciendo vasodilatacion sin taquicardia refleja",dosis:"20 mg IV en bolo; repetir 40-80 mg cada 10 min hasta maximo 300 mg; o infusion 1-2 mg/min",cuidadosEnfermeria:["Monitorizar PA cada 5 min durante el ajuste de dosis","Objetivo de PA: 140-150/90-100 mmHg (no bajar bruscamente por riesgo fetal)","Vigilar bradicardia materna y fetal","Contraindicado en asma y bloqueo AV de alto grado","Monitorizar frecuencia cardiaca fetal mediante cardiotocografia"]},{nombre:"Nifedipina",grupo:"Antagonista de calcio dihidropiridinico",mecanismo:"Bloquea canales de calcio tipo L en musculo liso vascular produciendo vasodilatacion arterial",dosis:"10-20 mg oral cada 30 min hasta control tensional; luego 30-60 mg/dia de liberacion sostenida",cuidadosEnfermeria:["No usar sublingual si se administra sulfato de magnesio (riesgo de hipotension grave)","Monitorizar PA cada 15 min en la fase de ajuste","Vigilar cefalea y rubor facial como efectos adversos frecuentes","Registrar respuesta tensional a cada dosis administrada"]}],noFarmacologico:["Decubito lateral izquierdo para evitar compresion de vena cava","Via aerea permeable: aspiracion, canula de Guedel, oxigeno 8-10 L/min","Proteccion ante caidas y traumatismos durante la convulsion","Resolucion del embarazo: parto vaginal o cesarea segun condiciones","Monitoreo fetal continuo (cardiotocografia)","UCI obstetrica o de adultos segun gravedad materna","Balance hidrico estricto con restriccion si oliguria"]},cuidadosEnfermeria:{valoracion:["Monitorizar PA continua o cada 5-15 min segun fase clinica","Evaluar nivel de consciencia con escala de Glasgow","Valorar reflejos osteotendinosos (hiperreflexia, clonus)","Monitorizar saturacion de oxigeno con pulsioximetro","Registrar diuresis horaria mediante sonda vesical","Evaluar bienestar fetal mediante cardiotocografia"],intervenciones:["Posicionar en decubito lateral izquierdo","Proteger via aerea y administrar oxigeno suplementario","Administrar sulfato de magnesio segun protocolo institucional","Canalizar via venosa periferica gruesa (minimo 18G)","Preparar para resolucion obstetrica urgente","Mantener gluconato de calcio como antidoto al pie de cama"],educacionPaciente:["Explicar a la familia la gravedad y el plan de tratamiento","Informar sobre la necesidad de resolucion del embarazo","Explicar el seguimiento tensional obligatorio en el puerperio","Indicar signos de alarma postparto: cefalea, vision borrosa, edema"],monitorizacion:["PA cada 5-15 min en fase aguda","Frecuencia respiratoria y reflejo patelar cada hora (toxicidad magnesio)","Diuresis horaria","Cardiotocografia fetal continua","Plaquetas, hepatograma y LDH cada 6-12 horas si HELLP","Nivel de consciencia continuo"]},npiNanda:[{codigo:"00015",nombre:"Riesgo de perfusion tisular cerebral ineficaz",definicion:"Vulnerable a una disminucion en la circulacion del tejido cerebral que puede comprometer la salud",caracteristicasDefinitorias:[],factoresRelacionados:["Hipertension severa","Vasoespasmo cerebral","Edema cerebral vasogenico"]},{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable ocasionada por una lesion tisular real o potencial",caracteristicasDefinitorias:["Cefalea intensa","Epigastralgia","Expresion facial de dolor"],factoresRelacionados:["Vasoespasmo","Distension hepatica","Hipertension endocraneal"]},{codigo:"00146",nombre:"Ansiedad",definicion:"Sensacion vaga e intranquilizadora de malestar o amenaza acompanada de una respuesta autonoma",caracteristicasDefinitorias:["Agitacion preconvulsiva","Expresion de miedo","Llanto"],factoresRelacionados:["Amenaza de vida materna y fetal","Hospitalizacion urgente","Diagnostico grave"]}],npiNic:[{codigo:"2690",nombre:"Precauciones para evitar convulsiones",actividades:["Acolchar barandas de la cama","Mantener via aerea permeable y equipo de aspiracion disponible","Administrar sulfato de magnesio segun protocolo","Monitorizar nivel de consciencia y reflejos osteotendinosos"]},{codigo:"4162",nombre:"Manejo de la hipertension",actividades:["Administrar antihipertensivos segun prescripcion medica","Monitorizar PA segun frecuencia indicada","Evaluar respuesta tensional a la medicacion","Registrar PA con objetivo terapeutico"]},{codigo:"6656",nombre:"Vigilancia: seguridad",actividades:["Observacion continua de la paciente","Proteccion fisica durante convulsiones para evitar traumatismos","Mantener ambiente tranquilo con poca estimulacion luminosa y sonora","Comunicar cambios al equipo medico de inmediato"]}],npiNoc:[{codigo:"0909",nombre:"Estado neurologico",indicadores:["Consciencia conservada","Ausencia de convulsiones","Orientacion en tiempo espacio y persona"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"},{codigo:"0401",nombre:"Estado circulatorio",indicadores:["PA sistolica en rango terapeutico","PA diastolica en rango terapeutico","Ausencia de signos de hipoperfusion fetal"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Accidente cerebrovascular hemorragico o isquemico","Sindrome HELLP","Coagulacion intravascular diseminada (CID)","Edema agudo de pulmon","Insuficiencia renal aguda","Abruptio placentae","Muerte fetal intrauterina","Muerte materna"],criteriosAlarma:["Convulsion tonico-clonica generalizada","PA mayor de 160/110 mmHg refractaria a medicacion","Coma o deterioro rapido del nivel de consciencia","Plaquetas menores de 50.000/uL","Oliguria menor de 30 mL/hora refractaria","Signos de edema agudo de pulmon","Alteraciones visuales o cefalea que no cede con analgesicos"],emergencyLevel:"critico",relatedPathologyIds:["pat_mola_hidatiforme","pat_hta"],isPremium:!0},{id:"pat_fascitis_necrotizante",nombre:"Fascitis Necrotizante",bodySystemId:"tegumentario",definicion:"Infeccion necrotizante grave de los tejidos blandos que compromete la fascia y el tejido subcutaneo con necrosis progresiva, causada habitualmente por bacterias sinergicas. Se caracteriza por rapida progresion, toxicidad sistemica severa y alta mortalidad si no se trata quirurgicamente en forma urgente.",epidemiologia:"Incidencia de 0.4-4 casos por 100.000 habitantes/ano. Mortalidad del 25-35% incluso con tratamiento optimo, y hasta 70-80% sin desbridamiento quirurgico precoz. Predomina en adultos mayores, diabeticos e inmunocomprometidos. El tipo I (polimicrobiano) es el mas frecuente (70-80%).",factoresRiesgo:["Diabetes mellitus (factor de riesgo mas frecuente)","Obesidad","Inmunosupresion","Cirrosis hepatica","Insuficiencia renal cronica","Enfermedad vascular periferica","Traumatismo o herida previa en el area","Cirugia reciente","Uso de drogas intravenosas","Edad avanzada"],fisiopatologia:"Las bacterias (Streptococcus pyogenes tipo II, o flora polimicrobiana incluyendo anaerobios tipo I) penetran por una solucion de continuidad cutanea, a veces minima o inaparente. Se diseminan rapidamente a lo largo de los planos fasciales avascular donde la respuesta inmune es limitada. Las toxinas bacterianas (estreptolisinas, hialuronidasas, toxinas superantigenas) producen vasoconstriccion local, trombosis de peque\xf1os vasos, hipoperfusion tisular y necrosis progresiva. La gas-produccion por anaerobios genera crepitacion palpable. La liberacion masiva de citoquinas pro-inflamatorias produce shock septico y fallo multiorganico.",signosYSintomas:{signos:["Dolor desproporcionado a los hallazgos cutaneos visibles (signo cardinal precoz)","Edema que supera los bordes del eritema cutaneo","Crepitacion subcutanea (gas en tejidos, patognomonico pero tardio)","Bulas o vesiculas con contenido seroso o hematico","Necrosis cutanea con coloracion violacea o negra (signo tardio grave)","Fiebre alta con taquicardia","Signos de sepsis: hipotension, taquicardia, taquipnea"],sintomas:["Dolor intenso desproporcionado al aspecto de la herida (90%)","Evolucion rapida de los sintomas (horas a dias)","Anestesia local paradojica (necrosis nerviosa, signo tardio ominoso)","Malestar general intenso, astenia","Fiebre alta y escalofrios","Nauseas y vomitos","Confusion o delirio (sepsis o toxinas)"]},clasificacion:{nombre:"Clasificacion microbiologica",tipos:[{nombre:"Tipo I: polimicrobiana",descripcion:"La mas frecuente (70-80%). Flora mixta aerobia-anaerobia. Predomina en tronco y region perineal (gangrena de Fournier). Asociada a diabetes y cirugia abdominal"},{nombre:"Tipo II: monomicrobiana",descripcion:"Streptococcus beta-hemolitico grupo A (S. pyogenes). Ocurre en jovenes sin comorbilidades. Puede asociar sindrome de shock toxico estreptococico"},{nombre:"Tipo III: por Vibrio vulnificus",descripcion:"Asociado a exposicion a agua de mar o mariscos en pacientes con hepatopatia. Progresion extremadamente rapida"},{nombre:"Gangrena de Fournier",descripcion:"Fascitis necrotizante del perineo y genitales externos. Alta mortalidad. Polimicrobiana"}]},diagnostico:{anamnesis:["Inicio y velocidad de progresion del cuadro local","Antecedente de herida, picadura, cirugia o trauma previo","Comorbilidades: diabetes, cirrosis, inmunosupresion","Medicacion actual: inmunosupresores, corticoides","Antecedentes de AINE (pueden enmascarar la clinica)","Signos sistemicos de sepsis"],examenFisico:["Inspeccion detallada del area afectada buscando limites del eritema","Palpacion buscando crepitacion subcutanea","Evaluacion de la sensibilidad del area (hipoestesia o anestesia sugiere necrosis nerviosa)","Signos vitales completos con busqueda de criterios de sepsis","Examen de toda la superficie corporal (buscar otras puertas de entrada)","Evaluacion de signos de fallo multiorganico"],pruebas:[{nombre:"Hemograma con formula leucocitaria",descripcion:"Leucocitosis con desviacion izquierda. Plaquetopenia en CID. Anemia por hemolisis o hemorragia",valoresReferencia:"Leucocitos: 10.000-40.000/uL con bandemia mayor de 10%; plaquetas mayores de 150.000/uL normales",cuidadosEnfermeria:["Extraer de manera urgente con hemocultivos antes de antibioticos","Registrar temperatura al momento de la extraccion","Comunicar leucocitosis extrema o plaquetopenia al medico"]},{nombre:"Hemocultivos (2 pares antes de antibioticos)",descripcion:"Identifican bacteriemia en el 15-20% de casos. Orientan el tratamiento antibiotico dirigido",valoresReferencia:"Negativos en condicion normal",cuidadosEnfermeria:["Extraer 2 pares (aerobio y anaerobio) antes de la primera dosis de antibiotico","Tecnica aseptica estricta para evitar contaminacion","Registrar hora exacta de extraccion en cada frasco","Transportar a temperatura ambiente al laboratorio de microbiologia"]},{nombre:"Tomografia computada con contraste IV",descripcion:"Detecta gas en tejidos blandos (patognomonico), extension de la infeccion y planos fasciales comprometidos. Score LRINEC (mayor de 6 = alta sospecha)",valoresReferencia:"Presencia de gas en tejidos blandos = indicacion quirurgica urgente",cuidadosEnfermeria:["Preparar via venosa para contraste IV","Verificar funcion renal y alergia a contrastes","NO demorar la cirugia por la realizacion de la TC si el diagnostico clinico es claro","Acompanar al paciente critico durante el traslado"]},{nombre:"Lactato serico",descripcion:"Marcador de hipoperfusion tisular y severidad. Mayor de 2 mmol/L indica inicio de sepsis grave",valoresReferencia:"Normal menor de 2 mmol/L; mayor de 4 mmol/L indica shock septico",cuidadosEnfermeria:["Extraer en tubo con fluoruro o procesar inmediatamente","Resultado urgente: comunicar al medico si mayor de 2 mmol/L","Repetir a las 2-6 horas para evaluar aclaramiento de lactato"]}]},tratamientoMedico:{objetivos:["Desbridamiento quirurgico urgente y amplio de todo tejido necrotico","Antibioticoterapia empirica de amplio espectro precoz","Estabilizacion hemodinamica y resolucion del shock septico","Control del foco con reintervenciones programadas cada 24-48 horas","Reconstruccion tisular posterior cuando el tejido este limpio"],farmacologico:[{nombre:"Piperacilina-tazobactam",grupo:"Antibiotico betalactamico con inhibidor de betalactamasas",mecanismo:"Inhibe la sintesis de pared bacteriana con cobertura ampliada a gram negativos, anaerobios y algunos gram positivos productores de betalactamasas",dosis:"4.5 g IV cada 6-8 horas (infusion extendida en 4 horas mejora la farmacodinamia)",cuidadosEnfermeria:["Verificar alergias a penicilinas antes de la primera dosis","Administrar siempre en infusion IV diluida (nunca en bolo directo)","Monitorizar funcion renal para ajuste de dosis","Vigilar signos de sobreinfeccion por Candida","Registrar hora de primera dosis (antibiotico debe iniciarse en la primera hora)"]},{nombre:"Clindamicina",grupo:"Antibiotico lincosamida",mecanismo:"Inhibe la sintesis proteica bacteriana; suprime la produccion de toxinas de Streptococcus pyogenes (efecto anti-toxina). Excelente cobertura anaerobia",dosis:"600-900 mg IV cada 8 horas en combinacion con piperacilina-tazobactam",cuidadosEnfermeria:["Administrar diluida en solucion fisiologica en 20-30 min","Vigilar diarrea asociada a Clostridioides difficile","Monitorizar funcion hepatica en tratamientos prolongados","Explicar que se usa especificamente para suprimir las toxinas del streptococo"]},{nombre:"Noradrenalina",grupo:"Vasopresor catecolaminergico",mecanismo:"Agonista alfa1 adrenergico que produce vasoconstriccion elevando la presion arterial media en el shock septico",dosis:"0.01-3 mcg/kg/min en infusion continua IV, titulando hasta PAM mayor de 65 mmHg",cuidadosEnfermeria:["Administrar por via venosa central de preferencia (riesgo de necrosis tisular extravasacion)","Monitorizar PAM de manera continua con linea arterial si disponible","Titular segun objetivo de PAM mayor de 65 mmHg","Vigilar perfusion periferica: frialdad, llenado capilar","Nunca suspender bruscamente; descender gradualmente"]}],noFarmacologico:["Desbridamiento quirurgico urgente: principal pilar del tratamiento","Reintervencion programada cada 24-48 horas hasta tejido limpio","Cierre de herida por segunda intencion o injertos en fase de reconstruccion","Terapia de presion negativa (VAC) en heridas extensas","Oxigenoterapia hiperbarica como adjuvante si disponible","Cuidados intensivos multiorganicos","Nutricion enteral precoz para soporte del catabolismo"]},cuidadosEnfermeria:{valoracion:["Evaluar y documentar area afectada con marcador cutaneo para detectar progresion rapida","Monitorizar signos vitales cada 15-30 min en fase aguda","Valorar nivel de consciencia y signos de shock septico","Cuantificar diuresis horaria como indicador de perfusion organica","Evaluar dolor con escala numerica y documentar su desproporcion con el aspecto visual","Vigilar aparicion de crepitacion subcutanea en areas adyacentes"],intervenciones:["Marcar con marcador permanente los limites del eritema con fecha y hora para monitorizar progresion","Canalizar vias venosas perifericas gruesas (2 vias 16G minimo) y central si necesario","Administrar antibioticos en la primera hora del diagnostico","Preparar al paciente para cirugia urgente: ayuno, consentimiento, pruebas preoperatorias","Administrar fluidos segun protocolo de sepsis (30 mL/kg en primera hora si hipotension)","Aplicar curaciones asepticas con solucion salina en herida postoperatoria"],educacionPaciente:["Explicar a la familia la gravedad y urgencia del tratamiento quirurgico","Informar sobre la necesidad de multiples intervenciones quirurgicas","Educar sobre el proceso de recuperacion prolongado y cicatrizacion","Control glucemico estricto en diabeticos como medida preventiva a largo plazo","Reconocer signos de infeccion en heridas que requieran consulta urgente"],monitorizacion:["Limites de eritema marcados y evaluados cada 1-2 horas","Signos vitales cada 15-30 min en fase aguda, cada 1-2 horas en UCI","Diuresis horaria","Lactato seriado cada 2-6 horas","Hemograma, funcion renal y hepatica cada 12-24 horas","Estado de la herida postoperatoria en cada curacion"]},npiNanda:[{codigo:"00046",nombre:"Deterioro de la integridad cutanea",definicion:"Alteracion de la epidermis, dermis o ambas",caracteristicasDefinitorias:["Destruccion de capas de la piel","Tejido necrotico","Herida con bordes irregulares y tejido no viable"],factoresRelacionados:["Infeccion bacteriana invasiva y necrotizante","Alteracion de la circulacion local por trombosis","Inmunosupresion"]},{codigo:"00031",nombre:"Limpieza ineficaz de las vias aereas",definicion:"Incapacidad para eliminar las secreciones u obstrucciones del tracto respiratorio para mantener las vias aereas permeables",caracteristicasDefinitorias:["Disnea en contexto de sepsis grave","Taquipnea","Saturacion de oxigeno disminuida"],factoresRelacionados:["Sepsis con disfuncion respiratoria","Sedacion para procedimientos","SDRA asociado a sepsis"]},{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable ocasionada por una lesion tisular real o potencial",caracteristicasDefinitorias:["Dolor desproporcionado al aspecto visible","Expresion facial de dolor","Posicion antialgica"],factoresRelacionados:["Inflamacion tisular extensa","Isquemia por trombosis vascular","Destruccion tisular progresiva"]}],npiNic:[{codigo:"3660",nombre:"Cuidado de las heridas",actividades:["Realizar curaciones asepticas con tecnica correcta","Evaluar y documentar el estado de la herida en cada curacion","Aplicar terapia de presion negativa (VAC) segun indicacion","Monitorizar signos de infeccion en la herida postoperatoria"]},{codigo:"6550",nombre:"Proteccion contra las infecciones",actividades:["Administrar antibioticos en tiempo y dosis indicados","Mantener tecnica aseptica estricta en todos los procedimientos","Monitorizar signos sistemicos de sepsis","Obtener cultivos de herida en cada curacion"]},{codigo:"4150",nombre:"Regulacion hemodinamica",actividades:["Administrar fluidos IV segun protocolo de sepsis","Titular vasopresores para PAM mayor de 65 mmHg","Monitorizar diuresis como indicador de perfusion","Valorar respuesta a la reanimacion con fluidos"]}],npiNoc:[{codigo:"1101",nombre:"Integridad tisular: piel y membranas mucosas",indicadores:["Temperatura tisular normal","Ausencia de necrosis","Granulacion progresiva en la herida"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"},{codigo:"0703",nombre:"Severidad de la infeccion",indicadores:["Temperatura corporal en rango normal","Leucocitos en rango normal","Ausencia de eritema progresivo","Cultivos negativos"],escala:"1=Grave, 2=Sustancial, 3=Moderado, 4=Leve, 5=Ninguno"}],complicaciones:["Shock septico con fallo multiorganico","Sindrome de dificultad respiratoria aguda (SDRA)","Coagulacion intravascular diseminada","Insuficiencia renal aguda","Amputacion del miembro afectado","Muerte (mortalidad 25-35% con tratamiento optimo)","Sindrome de shock toxico estreptococico (tipo II)","Secuelas esteticas y funcionales graves"],criteriosAlarma:["Dolor desproporcionado al aspecto visual de la herida","Crepitacion subcutanea palpable","Progresion rapida del eritema en horas","Aparicion de bulas o necrosis cutanea","Shock septico: hipotension refractaria, lactato mayor de 4 mmol/L","Ausencia de sensibilidad en area eritematosa (necrosis nerviosa)","Fiebre alta con deterioro clinico rapido"],emergencyLevel:"critico",relatedPathologyIds:["pat_sepsis","pat_celulitis"],isPremium:!0},{id:"pat_stevens_johnson",nombre:"Sindrome de Stevens-Johnson",bodySystemId:"tegumentario",definicion:"Reaccion cutaneo-mucosa grave de hipersensibilidad, principalmente inducida por farmacos, caracterizada por necrosis y desprendimiento epidermico que afecta menos del 10% de la superficie corporal total (SCT). Forma parte del espectro de reacciones con necrosis epidermica toxico (NET), cuyo extremo mas grave implica mas del 30% de SCT.",epidemiologia:"Incidencia de 1-6 casos por millon de habitantes/ano. Mortalidad del 5-10% para SJS y hasta 30-35% para NET. Los farmacos son responsables del 70-80% de los casos. Predominio en adultos. Los pacientes HIV positivos tienen riesgo 1000 veces mayor. Tiempo de inicio tipico: 4-28 dias tras el inicio del farmaco causante.",factoresRiesgo:["Farmacos: sulfonamidas, alopurinol, antiepil\xe9pticos (fenitoina, carbamazepina, lamotrigina), AINEs (oxicams), antibioticos betalactamicos, nevirapina","Infeccion previa por Mycoplasma pneumoniae (causa infecciosa mas frecuente en ni\xf1os)","Infeccion por VIH","Radioterapia concomitante con antiepil\xe9pticos","Variantes geneticas HLA-B*1502 (carbamazepina en asiaticos), HLA-B*5801 (alopurinol)","Enfermedad reumatologica de base","Inmunosupresion"],fisiopatologia:"La patogenia implica una respuesta inmunologica citotoxica mediada por linfocitos T CD8+ que reconocen el farmaco o sus metabolitos presentados en el contexto del complejo mayor de histocompatibilidad. Los queratinocitos son el blanco principal: la apoptosis masiva mediada por Fas-FasL, perforina y granzima B, y TNF-alfa produce la necrosis epidermica. La separacion epidermico-dermica genera ampollas y el signo de Nikolsky positivo. La perdida de barrera cutanea provoca hipovolemia, infecciones secundarias y desequilibrios metabolicos similares a quemaduras.",signosYSintomas:{signos:["Maculopapulas eritemato-purpuricas diana atipicas o confluentes","Desprendimiento epidermico menor del 10% SCT (SJS) o 10-30% (solapamiento SJS-NET)","Signo de Nikolsky positivo (desprendimiento al frote)","Erosiones y pseudomembranas en mucosas oral, ocular y genital","Conjuntivitis con pseudomembranas","Fiebre alta al inicio del cuadro","Lesiones en diana atipica o purpura no palpable"],sintomas:["Prodromo gripal: fiebre, malestar general, odinofagia (1-3 dias previos)","Quemaz\xf3n o dolor cutaneo intenso antes del desprendimiento","Odinofagia y disfagia por lesiones orales","Fotofobia y lagrimeo por conjuntivitis","Disuria por lesiones genitales","Anorexia y astenia marcadas","Ojos rojos y dolorosos"]},clasificacion:{nombre:"Clasificacion por extension del desprendimiento epidermico (Bastuji-Garin)",tipos:[{nombre:"Eritema Multiforme Mayor (EM mayor)",descripcion:"Lesiones en diana tipicas, afeccion mucosa en 1 o 2 sitios, menos del 10% SCT. Generalmente postinfeccioso"},{nombre:"Sindrome de Stevens-Johnson (SJS)",descripcion:"Maculopapulas purpuricas o lesiones en diana atipicas, mucosas en 2 o mas sitios, desprendimiento menor del 10% SCT. Principalmente farmacoinducido"},{nombre:"Solapamiento SJS-NET",descripcion:"Desprendimiento del 10-30% SCT. Pronostico intermedio"},{nombre:"Necrolisis Epidermica Toxica (NET o sindrome de Lyell)",descripcion:"Desprendimiento mayor del 30% SCT. Mortalidad 30-35%"}]},diagnostico:{anamnesis:["Listado completo de farmacos iniciados en las 4 semanas previas (enfasis en las primeras 2 semanas)","Farmacos de alto riesgo: alopurinol, antiepil\xe9pticos, sulfonamidas, nevirapina, AINEs tipo oxicam","Infecciones recientes: Mycoplasma, herpes simple","Antecedentes de reacciones cutaneas a farmacos previas","Estado inmunologico (VIH, inmunosupresores)","Etnia y antecedentes familiares de reacciones a antiepil\xe9pticos"],examenFisico:["Evaluacion de la superficie corporal afectada (SCT con regla de los 9)","Signo de Nikolsky en areas de eritema","Inspeccion de todas las mucosas: oral, ocular, nasal, genital, anal","Evaluacion de conjuntivas (pseudomembranas)","Signos vitales (fiebre, taquicardia, hipotension)","Estado de hidratacion"],pruebas:[{nombre:"Biopsia de piel (punch de 3-4 mm)",descripcion:"Confirma el diagnostico histologico: necrosis de queratinocitos en toda la epidermis, vesiculacion subepidermica, infiltrado linfohistiocitario",valoresReferencia:"Hallazgo caracteristico: necrosis epidermica confluente con separacion dermoepidermica",cuidadosEnfermeria:["Asistir al medico en la toma de la biopsia en area con bula intacta","Conservar la muestra en formol al 10% para histologia","Enviar muestra adicional en solucion fisiologica para inmunofluorescencia directa","Cubrir el sitio de biopsia con aposito no adhesivo"]},{nombre:"Hemograma, funcion renal y hepatica",descripcion:"Evalua la gravedad sistemica y las complicaciones organicas. Leucopenia es frecuente y de mal pronostico",valoresReferencia:"Score SCORTEN: leucocitos menores de 4000/uL suma 1 punto (mortalidad aumentada)",cuidadosEnfermeria:["Extraer urgente en fase diagnostica","Repetir cada 24-48 horas para monitorizar evolucion","Comunicar leucopenia grave, insuficiencia renal o hepatica al medico"]},{nombre:"Score SCORTEN (puntaje pronostico)",descripcion:"Predice mortalidad: edad mayor de 40 a\xf1os, malignidad, FC mayor de 120, SCT mayor de 10%, urea mayor de 28 mg/dL, glucosa mayor de 252 mg/dL, bicarbonato menor de 20 mEq/L. 0-1 puntos = 3.2% mortalidad; 5+ puntos = 90%",valoresReferencia:"SCORTEN 0-1: 3.2%; 2: 12.1%; 3: 35.3%; 4: 58.3%; 5 o mas: 90% mortalidad",cuidadosEnfermeria:["Colaborar en la recoleccion de datos para el calculo del score","Documentar SCT afectada con precision","Informar al equipo el score calculado para triaje de UCI"]},{nombre:"Cultivos de heridas y mucosas",descripcion:"Detecta sobreinfeccion bacteriana, principal causa de muerte. S. aureus y P. aeruginosa son los germenes mas frecuentes",valoresReferencia:"Cultivos negativos en ausencia de sobreinfeccion",cuidadosEnfermeria:["Tomar muestras de heridas con tecnica aseptica en cada curacion","Cultivos de conjuntiva ocular si hay secrecion purulenta","Evitar antibioticos profilacticos sin cultivo positivo","Registrar aspecto y caracteristicas de las lesiones en cada toma"]}]},tratamientoMedico:{objetivos:["Suspender inmediatamente el farmaco causante","Manejo de soporte en unidad de quemados o UCI","Prevenir y tratar infecciones secundarias","Mantener balance hidroelectrolitico y nutricional","Proteger mucosas oculares para prevenir secuelas visuales"],farmacologico:[{nombre:"Ciclosporina A",grupo:"Inmunomodulador inhibidor de calcineurina",mecanismo:"Inhibe la activacion de linfocitos T CD8+ citotoxicos, la principal celula efectora en SJS/NET. Reduce la produccion de perforina y granzima que destruyen queratinocitos",dosis:"3-5 mg/kg/dia IV o VO dividido en 2 dosis por 7-14 dias",cuidadosEnfermeria:["Monitorizar funcion renal y presion arterial (nefrotoxicidad e hipertension)","Vigilar niveles sericos de ciclosporina si disponibles (valle 100-200 ng/mL)","Administrar en ayunas o con alimentos leves siempre a la misma hora","Vigilar signos de infeccion oportunista (inmunosupresion adicional)","No mezclar con jugo de pomelo (inhibe metabolismo)"]},{nombre:"Corticoides sistemicos (Metilprednisolona)",grupo:"Corticosteroide antiinflamatorio (uso controvertido)",mecanismo:"Suprime la respuesta inflamatoria mediada por linfocitos T; su uso es debatido por riesgo de complicaciones infecciosas y retraso en la epitelizacion",dosis:"0.5-1 mg/kg/dia IV en pulsos cortos (3-5 dias) solo en fase temprana de expansion",cuidadosEnfermeria:["Solo en indicacion medica expresa y fase muy temprana del cuadro","Controlar glucemia (hiperglucemia corticoidea)","Vigilar signos de infeccion: los corticoides pueden enmascarar la fiebre","Monitorizar presion arterial y balance hidrico","Preparar para posible suspension si hay progresion de lesiones"]},{nombre:"Morfina o fentanilo",grupo:"Analgesico opiode",mecanismo:"Analgesia central por union a receptores mu-opioide; fundamental para el control del dolor severo en las curaciones y el manejo general",dosis:"Morfina: 0.1 mg/kg IV cada 4-6 horas o PCA; Fentanilo: 1-2 mcg/kg IV en procedimientos",cuidadosEnfermeria:["Evaluar dolor con escala numerica antes y despues de cada administracion","Premedicar antes de las curaciones para reducir el dolor del procedimiento","Vigilar depresion respiratoria y sedacion excesiva","Mantener naloxona disponible como antidoto","Registrar respuesta analgesica y ajustar segun necesidad"]}],noFarmacologico:["Suspension inmediata del farmaco causante (paso mas critico)","Traslado a unidad de quemados o UCI dermatologica especializada","Curaciones con material no adhesivo y soluciones suaves (vaselina, ringer lactato)","Ambiente termico controlado 30-32\xb0C para compensar perdida de calor","Nutricion enteral precoz (igual que quemados: requerimientos aumentados)","Cuidados oculares intensivos: lubricacion, separacion de adherencias diarias","Evaluacion oftalmologica diaria para prevenir simbl\xe9faron","Apoyo psicologico para el trauma de la enfermedad"]},cuidadosEnfermeria:{valoracion:["Evaluar y documentar SCT afectada con regla de los 9 o diagrama de Lund-Browder","Inspeccion diaria de todas las mucosas: oral, ocular, genital","Monitorizar signos vitales cada 4-6 horas","Valorar dolor con escala numerica en reposo y durante curaciones","Registrar ingesta y diuresis para balance hidrico","Evaluar signos de sobreinfeccion en heridas"],intervenciones:["Realizar curaciones asepticas con material no adherente (ap\xf3sitos de vaselina, Mepitel)","Administrar analgesia adecuada antes de las curaciones","Aplicar colirios lubricantes y separar adherencias conjuntivales segun protocolo oftalmologico","Mantener temperatura ambiental elevada para compensar hipotermia","Administrar nutricion enteral precoz segun prescripcion","Aislar al paciente para prevenir infecciones nosocomiales"],educacionPaciente:["Explicar al paciente y familia la causa del cuadro y la necesidad de suspender el farmaco de por vida","Indicar que el farmaco causante debe anotarse en la historia clinica y comunicarse a todos los profesionales de salud","Informar sobre la importancia del seguimiento oftalmologico para prevenir secuelas visuales","Explicar el proceso de recuperacion prolongado y las posibles secuelas cutaneas y mucosas"],monitorizacion:["SCT afectada diariamente","Signos vitales cada 4-6 horas","Balance hidrico estricto cada 6-8 horas","Hemograma y bioquimica cada 24-48 horas","Cultivos de herida cada 2-3 dias","Evaluacion oftalmica diaria"]},npiNanda:[{codigo:"00046",nombre:"Deterioro de la integridad cutanea",definicion:"Alteracion de la epidermis, dermis o ambas",caracteristicasDefinitorias:["Desprendimiento epidermico","Erosiones cutaneas extensas","Ampollas con signo de Nikolsky positivo"],factoresRelacionados:["Reaccion de hipersensibilidad a farmaco","Necrosis epidermica inmunomediada","Destruccion de la union dermoepidermica"]},{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable ocasionada por una lesion tisular real o potencial",caracteristicasDefinitorias:["Dolor intenso en piel afectada","Dolor al contacto minimo (alodinia)","Expresion facial de dolor en curaciones"],factoresRelacionados:["Destruccion de terminaciones nerviosas cutaneas","Erosiones en mucosas","Procedimientos de cuidado de heridas"]},{codigo:"00004",nombre:"Riesgo de infeccion",definicion:"Vulnerable a ser invadido y multiplicado por organismos patogenos que puede comprometer la salud",caracteristicasDefinitorias:[],factoresRelacionados:["Perdida de la barrera cutanea","Inmunosupresion farmacologica","Erosiones mucosas como puerta de entrada"]}],npiNic:[{codigo:"3660",nombre:"Cuidado de las heridas",actividades:["Utilizar ap\xf3sitos no adhesivos para cubrir areas denudadas","Realizar curaciones con tecnica aseptica estricta","Documentar extension y aspecto de las lesiones en cada curacion","Administrar premedicacion analgesica antes de los cambios de aposito"]},{codigo:"1400",nombre:"Manejo del dolor",actividades:["Evaluar dolor con escala numerica en reposo y durante procedimientos","Administrar opioides antes de las curaciones segun prescripcion","Utilizar tecnicas no farmacologicas: distraccion, presencia de familiar","Evaluar respuesta analgesica y ajustar tratamiento"]},{codigo:"1160",nombre:"Monitoreo nutricional",actividades:["Calcular requerimientos caloricos aumentados (similar a quemaduras)","Iniciar nutricion enteral precoz segun prescripcion","Pesar al paciente diariamente","Monitorizar tolerancia a la nutricion enteral"]}],npiNoc:[{codigo:"1101",nombre:"Integridad tisular: piel y membranas mucosas",indicadores:["Progresiva reepitelizacion de las lesiones","Ausencia de extension de nuevas lesiones","Mucosas en proceso de cicatrizacion"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"},{codigo:"2102",nombre:"Nivel del dolor",indicadores:["Dolor en reposo tolerable con analgesicos","Dolor durante curaciones manejable con premedicacion","Ausencia de expresion facial de dolor en reposo"],escala:"1=Grave, 2=Sustancial, 3=Moderado, 4=Leve, 5=Ninguno"}],complicaciones:["Sobreinfeccion bacteriana (S. aureus, P. aeruginosa): principal causa de muerte","Sepsis y shock septico","Neumonitis por lesiones en mucosa bronquial","Secuelas oculares: simbl\xe9faron, ojo seco, ceguera (en hasta 35% de NET)","Estenosis esofagica o uretral por cicatrizacion de mucosas","Hipovolemia y desequilibrio electrolitico","Sindrome de dificultad respiratoria aguda","Secuelas cutaneas: cicatrices, hiperpigmentacion, unas distr\xf3ficas"],criteriosAlarma:["Progresion rapida del area de desprendimiento epidermico","Fiebre persistente con leucopenia (sepsis bacteriana)","Signos de sepsis: hipotension, taquicardia, alteracion del sensorio","Compromiso ocular con disminucion de agudeza visual","Dificultad respiratoria por compromiso de via aerea","Score SCORTEN mayor de 3 (mortalidad mayor de 35%)","Oliguria o signos de fallo renal agudo"],emergencyLevel:"critico",relatedPathologyIds:["pat_quemaduras"],isPremium:!0},{id:"pat_enfermedad_injerto",nombre:"Enfermedad Injerto contra Huesped",bodySystemId:"inmunologico",definicion:"Complicacion inmunologica del trasplante alog\xe9nico de celulas hematopoyeticas (y ocasionalmente de otros trasplantes de organos solidos o transfusiones) en la que los linfocitos T del donante reconocen los tejidos del receptor como extra\xf1os y los atacan, causando da\xf1o multiorganico.",epidemiologia:"Ocurre en el 30-70% de los receptores de trasplante alog\xe9nico de m\xe9dula osea o celulas madre hematopoyeticas. La forma aguda aparece en los primeros 100 dias post-trasplante; la cronica puede presentarse hasta a\xf1os despues. Es la primera causa de mortalidad no relacionada con recaida en el trasplante alog\xe9nico.",factoresRiesgo:["Incompatibilidad HLA entre donante y receptor","Donante no emparentado (mayor riesgo que donante familiar)","Disparidad de sexo (donante femenina receptor masculino)","Edad avanzada del receptor","Infecciones virales previas (CMV, EBV)","Tipo de acondicionamiento: mieloablativo vs reducida intensidad","Fuente de celulas: sangre periferica mayor riesgo que m\xe9dula osea","EICH previa aguda grave"],fisiopatologia:"El proceso ocurre en tres fases. Primera: el acondicionamiento (quimioterapia/radioterapia) dana los tejidos del receptor liberando citoquinas proinflamatorias (TNF-alfa, IL-1) que activan celulas presentadoras de antigenos del huesped. Segunda: los linfocitos T del donante reconocen aloantigenos del receptor a traves del TCR, se activan y proliferan. Tercera: los linfocitos T efectores y citoquinas generadas (IFN-gama, TNF) atacan directamente los tejidos diana: piel, tracto gastrointestinal, higado y pulmones. La forma cronica tiene mecanismo similar a enfermedades autoinmunes con componente de linfocitos B.",signosYSintomas:{signos:["Rash cutaneo maculopapular que puede progresar a eritrodermia (EICH aguda)","Ictericia por colestasis hepatica","Diarrea acuosa o sanguinolenta (compromiso intestinal)","Xeroftalmia y queratoconjuntivitis seca (EICH cronica)","Esclerodermia-like con fibrosis cutanea (EICH cronica)","Bronquiolitis obliterante en pulmon (EICH cronica)","Citopenias por fallo medular o autoinmunidad"],sintomas:["Prurito y dolor cutaneo","Nauseas, vomitos y diarrea","Dolor abdominal","Ictericia con coluria y acolia","Xerostomia y mucositis oral","Debilidad y fatiga marcada","Disnea progresiva (compromiso pulmonar)"]},clasificacion:{nombre:"Clasificacion temporal y clinica",tipos:[{nombre:"EICH aguda clasica",descripcion:"Aparece en los primeros 100 dias post-trasplante. Afecta principalmente piel (estadio 1-4), higado y tracto gastrointestinal"},{nombre:"EICH aguda tardia",descripcion:"Misma presentacion pero despues del dia 100, generalmente tras suspension de inmunosupresion"},{nombre:"EICH cronica clasica",descripcion:"Despues del dia 100, sin manifestaciones previas de EICH aguda"},{nombre:"EICH cronica solapada",descripcion:"Manifestaciones cronicas que aparecen mientras el paciente tiene EICH aguda activa"}]},diagnostico:{anamnesis:["Fecha del trasplante y tipo (alog\xe9nico relacionado o no relacionado)","Tipo de acondicionamiento recibido","Regimen de profilaxis de EICH (ciclosporina, tacrolimus, metotrexato)","Aparicion de sintomas cutaneos, gastrointestinales o hepaticos","Infecciones virales recientes (CMV, EBV)","Cambios recientes en el tratamiento inmunosupresor"],examenFisico:["Evaluacion completa de la piel (porcentaje de SCT afectada)","Ictericia y hepatomegalia","Auscultacion pulmonar (crepitantes en bronquiolitis obliterante)","Evaluacion de mucosas oral y ocular","Signos de compromiso gastrointestinal","Estado nutricional"],pruebas:[{nombre:"Biopsia de organo afectado (piel, recto o higado)",descripcion:"Gold standard para confirmacion histologica. Muestra apoptosis de queratinocitos, satelitosis linfocitica, da\xf1o de criptas intestinales",valoresReferencia:"Grado 1-4 segun extension del da\xf1o histologico",cuidadosEnfermeria:["Asistir en la toma de biopsia con tecnica aseptica","Conservar muestra en formol al 10% para histologia","Registrar fecha, sitio exacto y aspecto macrosc\xf3pico de la lesion biopsiada","Aplicar aposito compresivo en el sitio de biopsia"]},{nombre:"Hepatograma completo (TGO, TGP, GGT, fosfatasa alcalina, bilirrubinas)",descripcion:"Eleva en EICH hepatica. El patron tipico es colestasico con elevacion predominante de bilirrubina directa y fosfatasa alcalina",valoresReferencia:"Bilirrubina total normal menor de 1.2 mg/dL; elevacion mayor de 2 mg/dL en EICH estadio 2 hepatico",cuidadosEnfermeria:["Extraer en ayunas de 4-6 horas","Monitorizar tendencia seriada cada 2-3 dias","Registrar junto al resto de la evaluacion clinica multiorganica"]},{nombre:"PCR CMV y EBV cuantitativo en sangre",descripcion:"Las infecciones virales pueden desencadenar o simular EICH y deben descartarse o tratarse concomitantemente",valoresReferencia:"CMV: menor de 1000 copias/mL; EBV: menor de 1000 copias/mL en inmunocompetentes",cuidadosEnfermeria:["Extraer en tubo EDTA para PCR","Procesamiento urgente dado el riesgo de enfermedad por CMV en inmunocomprometidos","Notificar cargas virales detectables al medico de inmediato"]},{nombre:"Colonoscopia con biopsias multiples",descripcion:"Indicada en EICH gastrointestinal con diarrea profusa. Visualiza ulceraciones, denudamiento mucoso. Biopsias de ciego y colon",valoresReferencia:"Hallazgo: apoptosis de celulas del epitelio de las criptas, destruccion cr\xedptica",cuidadosEnfermeria:["Preparacion intestinal segun protocolo (con precaucion en diarrea severa)","Monitorizar signos vitales durante el procedimiento","Vigilar complicaciones postprocedimiento: sangrado, perforacion","Mantener el paciente con via venosa permeable durante el estudio"]}]},tratamientoMedico:{objetivos:["Controlar la respuesta alog\xe9nica del donante","Preservar el efecto injerto contra leucemia (GVL)","Prevenir y tratar infecciones oportunistas","Mantener soporte nutricional y de organos","Mejorar la calidad de vida en EICH cronica"],farmacologico:[{nombre:"Metilprednisolona",grupo:"Corticosteroide: tratamiento de primera linea EICH",mecanismo:"Suprime la proliferacion y funcion de linfocitos T; inhibe produccion de citoquinas proinflamatorias reduciendo el ataque alog\xe9nico a los tejidos",dosis:"1-2 mg/kg/dia IV en EICH aguda grado 2-4; pulsos de 500 mg-1 g IV en formas graves",cuidadosEnfermeria:["Monitorizar glucemia cada 6 horas (hiperglucemia corticoidea frecuente)","Administrar omeprazol para proteccion gastrica","Vigilar presion arterial y retencion hidrica","Profilaxis antiinfecciosa concomitante (TMP-SMX, antifungicos, antivirales)","Educar sobre el descenso gradual de dosis: no suspender bruscamente"]},{nombre:"Tacrolimus",grupo:"Inmunosupresor inhibidor de calcineurina",mecanismo:"Inhibe la calcineurina bloqueando la transcripcion del gen de IL-2, citoquina clave para la activacion y proliferacion de linfocitos T",dosis:"Profilaxis: 0.03 mg/kg/dia IV o 0.1-0.15 mg/kg/dia VO con niveles meta 5-15 ng/mL",cuidadosEnfermeria:["Monitorizar niveles sericos en valle (antes de la siguiente dosis)","Controlar funcion renal y potasio (nefrotoxicidad e hiperpotasemia)","Vigilar presion arterial (hipertension frecuente)","Monitorizar glucemia (diabetes mellitus post-trasplante)","Advertir sobre interacciones con azoles (aumentan niveles)"]},{nombre:"Ruxolitinib",grupo:"Inhibidor de JAK1/JAK2",mecanismo:"Bloquea las vias de se\xf1alizacion JAK/STAT involucradas en la activacion de linfocitos T y la produccion de citoquinas proinflamatorias en EICH refractaria a esteroides",dosis:"5-10 mg/12h VO en EICH aguda refractaria; 10 mg/12h en EICH cronica",cuidadosEnfermeria:["Monitorizar hemograma (trombocitopenia y anemia frecuentes)","Vigilar reactivacion de infecciones virales: CMV, EBV, BK virus","Controlar lipidos sericos (hipercolesterolemia)","Administrar con o sin alimentos a la misma hora cada dia","Educacion sobre no suspender bruscamente (riesgo de recaida brusca)"]}],noFarmacologico:["Fototerapia UVB o PUVA para EICH cutanea cronica","Fotoaferesis extracoporea (ECP) en EICH cronica refractaria","Soporte nutricional enteral o parenteral en EICH gastrointestinal","Lubricacion ocular intensiva en EICH cronica con xeroftalmia","Fisioterapia para prevenir contracturas en EICH esclerodermoide","Profilaxis antiinfecciosa universal: TMP-SMX, aciclovir, antifungico"]},cuidadosEnfermeria:{valoracion:["Evaluar piel diariamente: extension, tipo de lesiones, eritrodermia","Monitorizar deposiciones: frecuencia, volumen, sangrado","Evaluar ictericia y signos de compromiso hepatico","Valorar estado nutricional y tolerancia oral","Monitorizar signos de infeccion en paciente inmunocomprometido","Evaluar calidad de vida y estado psicologico"],intervenciones:["Administrar inmunosupresores en horarios exactos y monitorizar niveles","Mantener aislamiento protector segun protocolo institucional","Aplicar emolientes cutaneos y cuidados de piel en EICH cutanea","Administrar nutricion enteral o parenteral segun prescripcion","Administrar profilaxis antiinfecciosa segun protocolo del servicio","Realizar balance hidrico estricto en EICH gastrointestinal"],educacionPaciente:["Explicar el concepto de EICH y que es esperable en el trasplante alog\xe9nico","Importancia de la adherencia estricta a la medicacion inmunosupresora","Reconocer signos de EICH: rash, diarrea, ictericia, para consulta precoz","Medidas de proteccion frente a infecciones oportunistas","Importancia del seguimiento ambulatorio frecuente post-trasplante"],monitorizacion:["Piel diariamente con documentacion fotografica si es posible","Deposiciones: frecuencia y volumen cada turno","Hepatograma y funcion renal cada 2-3 dias","Niveles de tacrolimus o ciclosporina semanalmente","PCR CMV y EBV semanal o bisemanal segun protocolo","Signos vitales cada 6-8 horas"]},npiNanda:[{codigo:"00046",nombre:"Deterioro de la integridad cutanea",definicion:"Alteracion de la epidermis, dermis o ambas",caracteristicasDefinitorias:["Rash maculopapular","Eritrodermia","Lesiones ampollosas en formas graves"],factoresRelacionados:["Ataque inmunologico de linfocitos T alog\xe9nicos","Inflamacion cutanea mediada por citoquinas","Inmunosupresion que favorece infecciones secundarias"]},{codigo:"00002",nombre:"Desequilibrio nutricional: inferior a las necesidades corporales",definicion:"Ingestion de nutrientes insuficiente para satisfacer las necesidades metabolicas",caracteristicasDefinitorias:["Diarrea con malabsorcion","Mucositis oral que impide ingesta","Perdida de peso"],factoresRelacionados:["EICH gastrointestinal con da\xf1o de mucosa","Anorexia por quimioterapia previa","Malabsorcion por destruccion de vellosidades intestinales"]},{codigo:"00004",nombre:"Riesgo de infeccion",definicion:"Vulnerable a ser invadido y multiplicado por organismos patogenos que puede comprometer la salud",caracteristicasDefinitorias:[],factoresRelacionados:["Inmunosupresion profunda por tratamiento de EICH","Alteracion de barreras mucosas","Neutropenia post-trasplante"]}],npiNic:[{codigo:"6550",nombre:"Proteccion contra las infecciones",actividades:["Mantener aislamiento protector segun protocolo","Administrar profilaxis antiinfecciosa prescrita","Monitorizar signos de infeccion oportunista","Limitar visitas y uso de mascarillas en visitantes"]},{codigo:"1080",nombre:"Manejo de la quimioterapia",actividades:["Administrar inmunosupresores en tiempo y dosis exactos","Monitorizar niveles sericos de inmunosupresores","Vigilar efectos adversos de cada farmaco","Educar al paciente sobre la adherencia al tratamiento"]},{codigo:"1160",nombre:"Monitoreo nutricional",actividades:["Evaluar tolerancia oral y registrar ingesta diaria","Administrar nutricion enteral o parenteral segun prescripcion","Pesar al paciente diariamente","Monitorizar albumina y proteinas s\xe9ricas"]}],npiNoc:[{codigo:"0703",nombre:"Severidad de la infeccion",indicadores:["Temperatura en rango normal","Ausencia de signos de infeccion oportunista","Cultivos negativos"],escala:"1=Grave, 2=Sustancial, 3=Moderado, 4=Leve, 5=Ninguno"},{codigo:"1101",nombre:"Integridad tisular: piel y membranas mucosas",indicadores:["Reduccion progresiva del eritema cutaneo","Mucosa oral sin ulceraciones activas","Ausencia de nuevas lesiones"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"}],complicaciones:["Infecciones oportunistas graves (CMV, Aspergillus, Pneumocystis jirovecii)","Fallo hepatico agudo","Perforacion intestinal en EICH gastrointestinal grave","Bronquiolitis obliterante con insuficiencia respiratoria cronica","Sindrome nefrotico por EICH renal","Recaida de la enfermedad de base (perdida del efecto GVL)","Muerte por EICH grave refractaria o infecciones asociadas"],criteriosAlarma:["Diarrea mayor de 1 litro al dia (EICH gastrointestinal grado 3-4)","Bilirrubina total mayor de 6 mg/dL","Eritrodermia mayor del 50% SCT","Signos de sepsis en paciente inmunocomprometido","Deterioro respiratorio rapido (bronquiolitis obliterante aguda)","Ausencia de respuesta a corticoides a los 5-7 dias (EICH refractaria)"],emergencyLevel:"moderado",relatedPathologyIds:["pat_leucemia","pat_sepsis"],isPremium:!0},{id:"pat_artritis_septica",nombre:"Artritis Septica",bodySystemId:"musculoesqueletico",definicion:"Infeccion bacteriana del espacio articular, generalmente producida por via hematogena, que causa inflamacion aguda con riesgo de destruccion rapida del cartilago y la articulacion si no se trata de manera urgente. Constituye una emergencia reumatologica y quirurgica.",epidemiologia:"Incidencia de 2-10 casos por 100.000 habitantes/ano. Hasta 28/100.000 en pacientes con artritis reumatoide. Mortalidad del 10-15% y secuelas articulares permanentes en el 25-50% de los casos. La rodilla es la articulacion mas frecuentemente afectada (50%), seguida de cadera (20%), tobillo, hombro y muneca.",factoresRiesgo:["Artritis reumatoide (factor de riesgo principal)","Diabetes mellitus","Inmunosupresion","Alcoholismo","Cirrosis hepatica","Infeccion cutanea adyacente","Protesis articular previa","Cirugia articular reciente","Artrocentesis o infiltracion previa","Bacteriemia por foco a distancia (endocarditis, ITU, celulitis)"],fisiopatologia:"Las bacterias llegan a la articulacion principalmente por via hematogena desde un foco infeccioso a distancia. La sinovial es altamente vascularizada y carece de membrana basal limitante, lo que facilita la siembra bacteriana. Una vez en el espacio articular, las bacterias desencadenan una respuesta inflamatoria aguda con reclutamiento masivo de neutrofilos. Las enzimas proteoliticas (colagenasas, elastasas) liberadas por los neutrofilos y las bacterias destruyen el cartilago articular en horas. La presion intraarticular elevada compromete la vascularizacion de la cabeza femoral (riesgo de necrosis avascular en artritis septica de cadera en ni\xf1os).",signosYSintomas:{signos:["Articulacion caliente, tumefacta y eritematosa","Derrame articular (signo del choque rotuliano positivo en rodilla)","Impotencia funcional articular marcada","Fiebre mayor de 38.5\xb0C con escalofrios","Leucocitosis con desviacion izquierda","Liquido sinovial purulento con mas de 50.000 leucocitos/uL (generalmente mayor de 100.000)"],sintomas:["Dolor articular intenso de instalacion aguda en horas o dias","Imposibilidad de mover la articulacion afectada","Fiebre alta con escalofrios","Malestar general y astenia","Anorexia","Calor local intenso","Aumento de volumen articular progresivo"]},clasificacion:{nombre:"Clasificacion microbiologica",tipos:[{nombre:"No gonoccocica (adultos)",descripcion:"Staphylococcus aureus (50-70%), incluyendo MRSA. Streptococcus spp., gram negativos en inmunodeprimidos. Mas grave y destructiva"},{nombre:"Gonococica",descripcion:"Neisseria gonorrhoeae en adultos jovenes sexualmente activos. Mejor pronostico, raramente destruye la articulacion"},{nombre:"Hematogena del nino",descripcion:"S. aureus, Streptococcus agalactiae en neonatos. Riesgo de necrosis avascular en cadera"},{nombre:"Iatrogenica",descripcion:"Post-artrocentesis, post-cirugia. Staphylococcus coagulasa negativo en protesis"}]},diagnostico:{anamnesis:["Inicio, velocidad y caracteristicas del dolor articular","Fiebre y sintomas sistemicos asociados","Antecedentes de artritis reumatoide, gota u otras artropatias","Procedimientos articulares recientes o cirugia","Focos infecciosos a distancia: piel, urinario, dental, pulmonar","Medicacion inmunosupresora"],examenFisico:["Inspeccion de la articulacion: eritema, edema, deformidad","Palpacion: calor intenso, fluctuacion del derrame","Movilidad activa y pasiva (limitacion marcada)","Signos articulares en rodilla: choque rotuliano, bostezo articular","Evaluacion de articulaciones adyacentes","Busqueda de focos infecciosos a distancia (piel, uretral, etc.)"],pruebas:[{nombre:"Artrocentesis con analisis del liquido sinovial (URGENTE)",descripcion:"Es el estudio diagnostico central e imprescindible. El liquido sinovial purulento (mayor de 50.000 leucocitos, mayor de 90% PMN) con Gram y cultivo positivos confirma el diagnostico",valoresReferencia:"Normal: menor de 200 leucocitos/uL; Artritis septica: mayor de 50.000 (tipicamente mayor de 100.000) leucocitos/uL con predominio de PMN",cuidadosEnfermeria:["Preparar material esteril para artrocentesis urgente","Asistir al medico con tecnica aseptica estricta","Enviar muestras urgente: celulas (EDTA), glucosa/proteinas (bioquimica), Gram y cultivo (frasco esteril)","Registrar aspecto del liquido: claro, turbio, purulento, hematico","Aplicar vendaje compresivo tras el procedimiento"]},{nombre:"Hemocultivos (2 pares)",descripcion:"Positivos en el 50% de los casos. Fundamentales para identificar el germen y orientar tratamiento antibiotico",valoresReferencia:"Negativos en condicion normal",cuidadosEnfermeria:["Extraer antes de la primera dosis de antibiotico","Tecnica aseptica rigurosa en la extraccion","2 pares: 1 aerobio + 1 anaerobio de 2 sitios distintos","Registrar hora de extraccion en cada frasco"]},{nombre:"Radiografia simple de la articulacion afectada",descripcion:"Inicialmente puede ser normal o mostrar solo partes blandas aumentadas. Util para descartar fracturas, osteomielitis o calcificaciones (gota)",valoresReferencia:"En fases tempranas normal; tardiamente: destruccion articular, pinzamiento del espacio articular",cuidadosEnfermeria:["Posicionar al paciente con cuidado extremo dado el dolor intenso","Solicitar proyecciones anteroposterior y lateral","Comparar con articulacion contralateral si es necesario"]},{nombre:"Ecografia articular",descripcion:"Detecta derrame articular (especialmente en cadera), guia artrocentesis en articulaciones profundas. Util cuando la artrocentesis directa es dificil",valoresReferencia:"Presencia de derrame articular mayor de 2 mm es anormal en cadera",cuidadosEnfermeria:["No requiere preparacion especial","Preparar equipo de artrocentesis por si se realiza guiada por ecografia","Registrar hallazgos del informe ecografico en historia clinica"]}]},tratamientoMedico:{objetivos:["Drenaje articular urgente (artrocentesis o quirurgico)","Antibioticoterapia empirica precoz ajustada a cultivos","Preservar la funcion articular","Tratar el foco infeccioso primario","Prevenir la destruccion articular irreversible"],farmacologico:[{nombre:"Cloxacilina",grupo:"Antibiotico betalactamico penicilinasa-resistente",mecanismo:"Inhibe la sintesis de pared bacteriana; resistente a betalactamasas estafilococicas, cubriendo S. aureus sensible a meticilina (MSSA)",dosis:"2 g IV cada 4-6 horas (12 g/dia); minimo 3-4 semanas de tratamiento total",cuidadosEnfermeria:["Verificar alergia a penicilinas antes de la primera dosis","Administrar en infusion IV lenta de 30-60 min","Monitorizar funcion hepatica (hepatotoxicidad en tratamientos prolongados)","Verificar cultivos y antibiograma para posible cambio a tratamiento oral tras mejoria clinica","Vigilar via venosa para evitar flebitis"]},{nombre:"Vancomicina",grupo:"Antibiotico glucopeptido",mecanismo:"Inhibe la sintesis del peptidoglicano en la pared bacteriana; activo frente a S. aureus resistente a meticilina (MRSA) y otros gram positivos resistentes",dosis:"15-20 mg/kg IV cada 8-12h con ajuste segun niveles (AUC/MIC objetivo 400-600)",cuidadosEnfermeria:["Administrar en infusion lenta de 1-2 horas para evitar sindrome del hombre rojo","Monitorizar niveles en valle (antes de 4a dosis) y AUC si disponible","Controlar funcion renal cada 48-72 horas (nefrotoxicidad)","Vigilar ototoxicidad: tinnitus, hipoacusia en tratamientos prolongados","Asegurar acceso venoso adecuado (preferir via central para cursos prolongados)"]},{nombre:"Naproxeno u otro AINE",grupo:"Antiinflamatorio no esteroideo",mecanismo:"Inhibe COX-1 y COX-2 reduciendo la produccion de prostaglandinas y la inflamacion articular; util como coadyuvante analgesico y antiinflamatorio",dosis:"500 mg oral cada 12 horas con las comidas",cuidadosEnfermeria:["Administrar siempre con alimentos o protector gastrico","Contraindicado en insuficiencia renal, hepatica o antecedente de ulcera peptica","Monitorizar funcion renal en tratamiento prolongado","Evaluar respuesta antiinflamatoria: disminucion del eritema y calor articular","No usar como unico tratamiento: el drenaje y los antibioticos son el pilar fundamental"]}],noFarmacologico:["Artrocentesis evacuadora diaria o lavado articular artroscopico urgente","Cirugia de lavado y drenaje articular abierto si no mejora en 5-7 dias o en cadera","Inmovilizacion articular en posicion funcional en fase aguda","Fisioterapia precoz una vez controlada la infeccion","Elevacion del miembro afectado para reducir edema","Reposo articular relativo en fase aguda"]},cuidadosEnfermeria:{valoracion:["Evaluar articulacion afectada: grado de tumefaccion, calor, eritema y dolor","Monitorizar temperatura corporal y signos vitales","Cuantificar el dolor con escala numerica antes y despues de artrocentesis","Evaluar movilidad articular activa y pasiva","Vigilar signos de sepsis sistemica","Revisar resultado de analisis del liquido sinovial"],intervenciones:["Preparar y asistir en artrocentesis urgente con tecnica aseptica estricta","Administrar antibioticos en la primera hora del diagnostico","Inmovilizar la articulacion afectada en posicion funcional","Elevar el miembro afectado para reducir inflamacion","Administrar analgesicos segun prescripcion","Iniciar fisioterapia progresiva segun indicacion medica"],educacionPaciente:["Explicar la urgencia del tratamiento para preservar la funcion articular","Completar el curso completo de antibioticos aunque haya mejoria clinica","Reconocer signos de recaida o complicacion: reaparicion de dolor, fiebre","Importancia de la fisioterapia en la recuperacion de la movilidad articular","Identificar y tratar factores de riesgo: control glucemico, cuidado de piel"],monitorizacion:["Articulacion afectada: eritema, calor y edema dos veces al dia","Temperatura corporal cada 6-8 horas","Funcion renal y hepatica cada 48-72 horas (toxicidad antibioticos)","Niveles de vancomicina si corresponde","Respuesta clinica a los 3-5 dias de tratamiento","Movilidad articular durante la fase de fisioterapia"]},npiNanda:[{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable ocasionada por una lesion tisular real o potencial",caracteristicasDefinitorias:["Verbalizacion de dolor articular intenso","Impotencia funcional","Posicion antialgica del miembro afectado"],factoresRelacionados:["Inflamacion articular por infeccion bacteriana","Derrame articular a presion","Destruccion del cartilago"]},{codigo:"00085",nombre:"Deterioro de la movilidad fisica",definicion:"Limitacion del movimiento fisico independiente e intencionado del cuerpo o de una o mas extremidades",caracteristicasDefinitorias:["Rango de movimiento disminuido","Dificultad para realizar actividades de la vida diaria","Marcha alterada"],factoresRelacionados:["Dolor articular severo","Inflamacion articular","Inmovilizacion terapeutica"]},{codigo:"00004",nombre:"Riesgo de infeccion",definicion:"Vulnerable a ser invadido y multiplicado por organismos patogenos que puede comprometer la salud",caracteristicasDefinitorias:[],factoresRelacionados:["Artrocentesis repetida como via de entrada","Inmunosupresion","Diabetes mellitus"]}],npiNic:[{codigo:"1400",nombre:"Manejo del dolor",actividades:["Evaluar dolor con escala numerica antes y despues de cada intervencion","Administrar analgesicos segun prescripcion medica","Aplicar medidas no farmacologicas: frio local en fase aguda, elevacion","Inmovilizar articulacion en posicion de confort"]},{codigo:"0840",nombre:"Terapia de ejercicios: movilidad articular",actividades:["Iniciar movilizacion pasiva precoz una vez controlada la infeccion","Progresar a ejercicios activos asistidos segun tolerancia","Coordinar con fisioterapia para programa de rehabilitacion","Evaluar rango de movimiento antes y despues de cada sesion"]},{codigo:"6550",nombre:"Proteccion contra las infecciones",actividades:["Mantener tecnica aseptica en todos los procedimientos articulares","Administrar antibioticos en tiempo y forma prescritos","Monitorizar respuesta al tratamiento antibiotico","Obtener cultivos si hay signos de recaida o empeoramiento"]}],npiNoc:[{codigo:"2102",nombre:"Nivel del dolor",indicadores:["Dolor en reposo menor de 3/10","Ausencia de facies de dolor en reposo","Capaz de tolerar la movilizacion pasiva"],escala:"1=Grave, 2=Sustancial, 3=Moderado, 4=Leve, 5=Ninguno"},{codigo:"0206",nombre:"Movimiento articular: rodilla (u otra articulacion afectada)",indicadores:["Flexo-extension dentro de rangos funcionales","Ausencia de contractura articular","Marcha normal o compensada"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"}],complicaciones:["Destruccion articular irreversible con artritis cronica","Osteomielitis por extension contigua","Necrosis avascular de la cabeza femoral (artritis septica de cadera en ni\xf1os)","Bacteriemia y sepsis","Endocarditis infecciosa","Limitacion permanente de la movilidad articular","Necesidad de protesis articular de rescate"],criteriosAlarma:["Articulacion intensamente dolorosa, caliente y tumefacta con fiebre","Ausencia de mejoria clinica tras 48-72 horas de antibioticos","Liquido sinovial con mayor de 100.000 leucocitos/uL","Signos de sepsis sistemica","Afectacion de la articulacion de la cadera (urgencia quirurgica)","Hemocultivos positivos","Extension a osteomielitis en imagen"],emergencyLevel:"moderado",relatedPathologyIds:["pat_osteomielitis","pat_artritis_reumatoide","pat_sepsis"],isPremium:!0},{id:"pat_distrofia_muscular",nombre:"Distrofia Muscular",bodySystemId:"musculoesqueletico",definicion:"Grupo heterogeneo de enfermedades geneticas hereditarias caracterizadas por degeneracion progresiva e irreversible de la fibra muscular esqueletica, con debilidad muscular proximal progresiva y perdida de la funcion motora. La forma mas frecuente y grave es la distrofia muscular de Duchenne (DMD).",epidemiologia:"La DMD afecta 1/3500 varones nacidos vivos. La distrofia de Becker 1/18.000. Las distrofias de cinturas (LGMD) tienen prevalencia combinada de 1-5/100.000. Son las enfermedades neuromusculares mas frecuentes en la infancia. La DMD es letal antes de los 30 a\xf1os sin ventilacion asistida.",factoresRiesgo:["Herencia ligada al cromosoma X (DMD, Becker): varones afectados","Madre portadora del gen DMD/BMD mutado","Herencia autos\xf3mica recesiva (LGMD tipo 2, distrofias de cinturas)","Herencia autos\xf3mica dominante (distrofia miot\xf3nica, LGMD tipo 1)","Mutacion de novo (33% de casos de DMD sin antecedentes familiares)","Consanguinidad para formas recesivas"],fisiopatologia:"En la DMD, mutaciones en el gen DMD (Xp21) causan ausencia total de distrofina, proteina estructural que conecta el citoesqueleto de actina con la matriz extracelular a traves del complejo de glicoproteinas asociadas a distrofina. Sin distrofina, la membrana muscular es fragilizada y se rompe durante las contracciones, permitiendo entrada de calcio extracelular que activa proteasas (calpainas) y apoptosis. El ciclo repetido de da\xf1o-regeneracion agota la capacidad regenerativa del musculo (celulas satelite), que es reemplazado por tejido fibroso y adiposo. En la distrofia de Becker, la distrofina esta presente pero acortada y parcialmente funcional (fenotipo mas leve).",signosYSintomas:{signos:["Seudohipertrofia de gemelos (reemplazo muscular por tejido fibroadiposo)","Signo de Gowers positivo (usa manos para levantarse del suelo)","Marcha en puntillas y lordosis lumbar exagerada","Esc\xe1pulas aladas","Escoliosis progresiva","CK serica muy elevada (10-100 veces el valor normal en DMD)","Contracturas articulares progresivas"],sintomas:["Debilidad muscular proximal progresiva (cinturas pelvica y escapular)","Dificultad para correr, saltar o subir escaleras","Caidas frecuentes","Dificultad para levantarse del suelo","Fatiga muscular con el esfuerzo","En fases avanzadas: dificultad para respirar (insuficiencia ventilatoria)","Disfagia en etapas tardias"]},clasificacion:{nombre:"Clasificacion por gen y patron de herencia",tipos:[{nombre:"Distrofia de Duchenne (DMD)",descripcion:"Ligada al X. Inicio antes de los 5 a\xf1os. Ausencia total de distrofina. Perdida de marcha a los 12 a\xf1os. Afectacion cardiaca y respiratoria. Mortalidad en 2da-3ra decada sin soporte ventilatorio"},{nombre:"Distrofia de Becker (BMD)",descripcion:"Ligada al X. Inicio mas tardio. Distrofina presente pero defectuosa. Fenotipo mas leve. Conservan marcha hasta los 40-50 a\xf1os"},{nombre:"Distrofias de cinturas (LGMD)",descripcion:"Autosomicas, recesivas o dominantes. Debilidad en cinturas pelvica y escapular. Heterogeneas (mas de 30 genes). Variable gravedad"},{nombre:"Distrofia facioescapulohumeral (FSHD)",descripcion:"Autos\xf3mica dominante. Debut en adolescencia. Afecta cara, escapulas y humero. Progresion lenta. Esperanza de vida normal"}]},diagnostico:{anamnesis:["Edad de inicio de los sintomas motores","Descripcion de las dificultades motoras: caidas, subir escaleras, levantarse del suelo","Antecedentes familiares de debilidad muscular","Historia de CK elevada en controles previos","Retrasos en hitos del desarrollo motor","Sintomas respiratorios o cardiacos asociados"],examenFisico:["Evaluacion de la fuerza muscular segmentaria (escala MRC 0-5)","Signo de Gowers","Patron de afectacion muscular: proximal vs distal, facial","Seudohipertrofia de gemelos","Contracturas articulares y rango de movimiento","Evaluacion de la columna vertebral (escoliosis)","Auscultacion cardiaca y evaluacion respiratoria"],pruebas:[{nombre:"Creatinquinasa (CK) serica",descripcion:"Marcador de da\xf1o muscular. En DMD esta extremadamente elevada desde el nacimiento. Decrece con la perdida de masa muscular en fases avanzadas",valoresReferencia:"Normal hombre menor de 200 UI/L; DMD tipica: 10.000-100.000 UI/L (50-100 veces el valor normal)",cuidadosEnfermeria:["Extraer en reposo, sin ejercicio previo de 24-48 horas","Anotar actividad fisica reciente que puede elevar CK levemente en personas sanas","CK muy elevada en nino varon con debilidad proximal: comunicar al medico"]},{nombre:"Biopsia muscular con inmunohistoquimica para distrofina",descripcion:"Gold standard historico: ausencia de distrofina en DMD, reduccion en Becker. Actualmente complementada o reemplazada por genetica molecular",valoresReferencia:"Presencia normal de distrofina en membrana sarcoplasm\xe1tica",cuidadosEnfermeria:["Asistir en el procedimiento bajo anestesia local o sedacion segun edad","Conservar la muestra fresca o en nitr\xf3geno liquido segun indicacion del laboratorio","Informar al paciente y familia sobre el proceso de la biopsia y resultados esperados"]},{nombre:"Estudio genetico molecular del gen DMD (MLPA y secuenciacion)",descripcion:"Detecta deleciones (65%), duplicaciones (7%) y mutaciones puntuales en el gen DMD. Necesario para consejo genetico y elegibilidad a terapias de precision (exon skipping, readthrough)",valoresReferencia:"Sin mutaciones patogenicas en poblacion general",cuidadosEnfermeria:["Extraer muestra de sangre periferica en tubo EDTA","Explicar a la familia que el resultado puede tardar semanas","Ofrecer acompanyamiento durante la comunicacion del resultado genetico","Informar sobre la importancia del consejo genetico familiar"]},{nombre:"Ecocardiograma",descripcion:"La miocardiopatia dilatada afecta al 90% de los pacientes con DMD mayores de 18 a\xf1os. Evaluacion basal a los 6 a\xf1os y cada 2 a\xf1os hasta los 10, luego anual",valoresReferencia:"Fraccion de eyeccion normal mayor del 55%; detectar dilatacion ventricular izquierda",cuidadosEnfermeria:["Posicionar en decubito lateral izquierdo para mejor ventana ecografica","Registrar el valor de FEVI para comparacion en seguimiento","Coordinar con cardiologia pediatrica o de adultos segun edad"]}]},tratamientoMedico:{objetivos:["Preservar la funcion motora el mayor tiempo posible","Prevenir y tratar complicaciones: escoliosis, contracturas, cardiomiopatia, insuficiencia respiratoria","Mejorar la calidad de vida","Acceso a terapias de modificacion de la enfermedad cuando aplique","Soporte psicologico y social al paciente y familia"],farmacologico:[{nombre:"Deflazacort o Prednisona",grupo:"Corticosteroide: estandar de cuidado en DMD",mecanismo:"Mecanismo no completamente elucidado: se postula supresion de la inflamacion muscular, estabilizacion de la membrana muscular y modulacion de la expresion del gen de la distrofina residual",dosis:"Deflazacort: 0.9 mg/kg/dia VO (maximo 36 mg/dia); Prednisona: 0.75 mg/kg/dia. Inicio recomendado cuando el nino esta en su plateau de fuerza (5-7 a\xf1os)",cuidadosEnfermeria:["Administrar con el desayuno para reducir efectos gastricos","Monitorizar peso y talla mensualmente (obesidad y retraso del crecimiento frecuentes)","Vigilar presion arterial y glucemia (efectos corticoideos)","Suplementar con calcio y vitamina D para prevencion de osteoporosis","Vigilar cataratas posteriores subcapsulares con control oftalmologo anual"]},{nombre:"Enalapril o carvedilol",grupo:"Cardioprotector: IECA o betabloqueante",mecanismo:"Los IECA reducen la poscarga y la remodelacion cardiaca en la miocardiopatia dilatada. Los betabloqueantes reducen la FC y mejoran la eficiencia cardiaca",dosis:"Enalapril: 0.1 mg/kg/dia, incrementar hasta 0.5 mg/kg/dia; Carvedilol: 0.1-0.5 mg/kg/dia segun tolerancia",cuidadosEnfermeria:["Iniciar cuando la FEVI sea menor del 55% o a partir de los 10 a\xf1os como prevencion","Monitorizar presion arterial antes de cada dosis","Controlar potasio y funcion renal periodicamente","Vigilar hipotension sintomatica especialmente en pacientes postrados","Registrar FEVI en cada ecocardiograma de seguimiento"]},{nombre:"Ataluren (PTC124)",grupo:"Agente de readthrough de codon de parada prematuro",mecanismo:"Facilita la lectura ribos\xf3mica a traves de mutaciones sin sentido (nonsense) en el ARN mensajero del gen DMD, permitiendo la produccion de distrofina funcional. Indicado solo en pacientes con mutacion nonsense (10-15% de DMD)",dosis:"10 mg/kg ma\xf1ana, 10 mg/kg al mediodia, 20 mg/kg por la noche, con las comidas",cuidadosEnfermeria:["Verificar que el paciente tiene mutacion nonsense en el gen DMD (no es eficaz en deleciones)","Administrar siempre con alimentos para mejorar la absorcion","Monitorizar funcion renal periodicamente","Registrar distancia caminada en 6 min como medida de eficacia terapeutica","Educar sobre la importancia de la adherencia estricta en terapias de modificacion de enfermedad"]}],noFarmacologico:["Fisioterapia regular: estiramientos, fortalecimiento de musculatura no afectada, hidroterapia","Ortesis de miembros inferiores (AFO nocturnas) para prevenir contracturas","Ventilacion no invasiva (BiPAP) cuando CVF menor del 50% o desaturacion nocturna","Tos asistida mecanica cuando la tos es ineficaz (flujo de tos menor de 270 L/min)","Cirugia de Achilles para correccion de equinismo","Cirugia de escoliosis cuando angulo de Cobb mayor de 20-25 grados","Silla de ruedas motorizada cuando la marcha no es segura","Nutricion adecuada para prevenir obesidad corticoidea y desnutricion en fases avanzadas"]},cuidadosEnfermeria:{valoracion:["Evaluar fuerza muscular con escala MRC en grupos musculares proximal y distal","Monitorizar la funcion respiratoria: capacidad vital forzada (CVF), flujo de tos","Evaluar la degluci\xf3n y el estado nutricional","Valorar el estado emocional del paciente y la familia (impacto psicosocial)","Revisar adherencia a fisioterapia, ortesis y medicacion","Vigilar signos de insuficiencia cardiaca o respiratoria"],intervenciones:["Administrar corticoides con el desayuno y vigilar efectos adversos sistematicamente","Coordinar y reforzar la adhesion al programa de fisioterapia","Asistir en el manejo de la ventilacion no invasiva: ajuste de mascarilla, tolerancia","Educar en tecnicas de tos asistida manual o mecanica","Evaluar necesidad de adaptaciones del hogar y ayudas tecnicas","Coordinar con equipo multidisciplinar: neurologo, cardiologo, neum\xf3logo, nutricionista"],educacionPaciente:["Explicar la naturaleza progresiva de la enfermedad y el objetivo de cada tratamiento","Importancia de la fisioterapia diaria y el uso correcto de las ortesis","Reconocer signos de insuficiencia respiratoria: apneas nocturnas, cefalea matutina, disnea","Importancia del seguimiento cardiologico anual y del ecocardiograma","Informar sobre asociaciones de pacientes y recursos de apoyo psicosocial"],monitorizacion:["Fuerza muscular y capacidad funcional: test de 6 minutos, tiempo de levantarse del suelo","CVF y flujo de tos cada 6 meses","Ecocardiograma anual","Peso, talla y tensi\xf3n arterial mensual en pacientes con corticoides","Glucemia y densitometria osea anual en corticoterapia prolongada","CK serica anual como seguimiento"]},npiNanda:[{codigo:"00085",nombre:"Deterioro de la movilidad fisica",definicion:"Limitacion del movimiento fisico independiente e intencionado del cuerpo o de una o mas extremidades",caracteristicasDefinitorias:["Disminucion progresiva del rango de movimiento","Debilidad muscular proximal","Incapacidad para realizar actividades de la vida diaria de forma independiente"],factoresRelacionados:["Degeneracion progresiva de la fibra muscular","Contracturas articulares","Reemplazo muscular por tejido fibroso"]},{codigo:"00032",nombre:"Patron respiratorio ineficaz",definicion:"La inspiracion o espiracion no proporciona una ventilacion adecuada",caracteristicasDefinitorias:["Disnea de esfuerzo","Reduccion de la CVF","Uso de musculos accesorios de la respiracion"],factoresRelacionados:["Debilidad de musculos respiratorios","Escoliosis restrictiva","Progresion de la enfermedad"]},{codigo:"00188",nombre:"Tendencia a adoptar conductas de riesgo para la salud",definicion:"Deterioro de la capacidad para modificar el estilo de vida o conducta de manera que mejore el nivel de bienestar",caracteristicasDefinitorias:["Dificultad para adherirse al programa de fisioterapia","Negacion de la evolucion de la enfermedad","Reduccion de la actividad preventiva"],factoresRelacionados:["Enfermedad cronica progresiva","Impacto psicologico del diagnostico","Demandas del regimen terapeutico complejo"]}],npiNic:[{codigo:"0840",nombre:"Terapia de ejercicios: movilidad articular",actividades:["Ense\xf1ar y supervisar programa de estiramientos diarios","Promover hidroterapia para mantenimiento de fuerza y rango articular","Aplicar ortesis segun indicacion para prevenir contracturas","Coordinar con fisioterapia para programa individualizado"]},{codigo:"3140",nombre:"Manejo de la via aerea",actividades:["Ense\xf1ar tecnicas de tos asistida al paciente y familia","Monitorizar saturacion de oxigeno y CVF periodicamente","Asistir en el ajuste y tolerancia de la ventilacion no invasiva","Educar sobre signos de insuficiencia respiratoria que requieren consulta urgente"]},{codigo:"5270",nombre:"Apoyo emocional",actividades:["Proporcionar escucha activa al paciente y familia","Facilitar el duelo adaptativo ante la enfermedad progresiva","Derivar a psicologia y grupos de apoyo de enfermedades neuromusculares","Validar las emociones del paciente y reforzar sus capacidades"]}],npiNoc:[{codigo:"0208",nombre:"Movilidad",indicadores:["Mantenimiento del rango de movimiento funcional","Deambulacion conservada segun estadio","Transferencias realizadas con ayuda tecnica adecuada"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"},{codigo:"0403",nombre:"Estado respiratorio: ventilacion",indicadores:["CVF mayor del 50% del predicho","Saturacion de oxigeno mayor del 94% en reposo","Ausencia de disnea en reposo"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Insuficiencia respiratoria restrictiva: causa principal de muerte","Miocardiopatia dilatada con insuficiencia cardiaca","Escoliosis progresiva con restriccion ventilatoria adicional","Perdida de la marcha (a los 12 a\xf1os en DMD sin tratamiento)","Osteoporosis y fracturas por corticoides y inmovilidad","Disfagia y desnutricion en fases avanzadas","Impacto psicologico: depresion, ansiedad, aislamiento social"],criteriosAlarma:["CVF menor del 50% del valor predicho (indicacion de ventilacion no invasiva)","Saturacion de oxigeno menor del 94% en reposo","Apneas nocturnas o cefalea matutina (hipoventilacion nocturna)","FEVI menor del 45% (indicacion de tratamiento cardiaco agresivo)","Flujo de tos menor de 270 L/min (ineficaz para eliminar secreciones)","Escoliosis con angulo de Cobb mayor de 25 grados (indicacion quirurgica)","Perdida subita de habilidades motoras (descartar fractura o complicacion)"],emergencyLevel:"leve",relatedPathologyIds:["pat_esclerosis_lateral_amiotrofica"],isPremium:!0},{id:"pat_tormenta_tiroidea",nombre:"Tormenta Tiroidea",bodySystemId:"endocrino",definicion:"Crisis tirotoxica grave y potencialmente fatal que representa la expresion mas severa del hipertiroidismo descompensado, caracterizada por fiebre >40\xb0C, taquicardia >140 lpm, agitacion extrema, diaforesis profusa e insuficiencia cardiaca de alto gasto. Constituye una emergencia medica con mortalidad del 10-30% incluso con tratamiento optimo.",epidemiologia:"Incidencia de 0.57-0.76 por 100.000 habitantes por ano. Representa el 1-2% de los ingresos por hipertiroidismo. Predomina en mujeres (70-80% de los casos) entre 40-60 a\xf1os. La mortalidad ha disminuido del 100% (sin tratamiento) al 10-30% con manejo intensivo moderno. El 10% de los pacientes con tormenta tiroidea no tienen diagnostico previo de hipertiroidismo.",factoresRiesgo:["Enfermedad de Graves no tratada o mal controlada","Bocio multinodular toxico","Cirugia tiroidea o de otro tipo en paciente hipertiroideo","Administracion de yodo radioactivo sin pretratamiento","Infeccion o sepsis intercurrente","Trauma fisico severo o quemaduras","Parto o cesarea en paciente tirotoxica","Interrupcion brusca de antitiroideos","Administracion de medios de contraste yodados","Amiodarona en paciente con tiroides autonoma","Infarto agudo de miocardio o embolismo pulmonar","Estres emocional severo"],fisiopatologia:"La tormenta tiroidea no se explica unicamente por niveles mas altos de hormonas tiroideas (T3/T4), sino por un aumento brusco de la fraccion libre de T3/T4 junto con hipersensibilidad adrenergica. Las hormonas tiroideas en exceso activan receptores beta-adrenergicos, aumentan el metabolismo basal y la termogenesis, producen vasodilatacion periferica y aumentan el gasto cardiaco. La hiperthermia intensa deteriora la funcion enzimatica y produce disfuncion multiorganica. La insuficiencia suprarrenal relativa contribuye al colapso hemodinamico. La activacion de citocinas proinflamatorias amplifica la cascada de da\xf1o tisular.",signosYSintomas:{signos:["Fiebre > 40\xb0C (hiperthermia grave, cardinal)","Taquicardia sinusal > 140 lpm","Fibrilacion auricular de alta respuesta ventricular","Presion diferencial ampliada","Diaforesis profusa","Temblor fino de manos","Bocio palpable (en Graves)","Exoftalmos (en Graves)","Hipertension sistolica con hipotension diastolica","Signos de insuficiencia cardiaca (crepitantes, ingurgitacion yugular)","Ictericia (hepatotoxicidad por hiperthermia)"],sintomas:["Agitacion psicomotriz extrema","Confusion y desorientacion","Palpitaciones intensas","Intolerancia al calor","Debilidad muscular proximal severa","Nauseas, vomitos y diarrea","Dolor abdominal difuso","Ansiedad y psicosis aguda","Sed intensa","Disnea de esfuerzo y reposo"]},clasificacion:{nombre:"Score de Burch-Wartofsky (BPS)",tipos:[{nombre:"Tormenta tiroidea inminente",descripcion:"BPS 25-44 puntos: manejo agresivo obligatorio, alto riesgo de progresion"},{nombre:"Tormenta tiroidea establecida",descripcion:"BPS >= 45 puntos: crisis tirotoxica franca, UCI obligatoria, mortalidad elevada"},{nombre:"Tormenta tiroidea con falla multiorganica",descripcion:"BPS >= 45 + disfuncion de 2 o mas organos (cardiaco, hepatico, neurologico): maxima gravedad"}]},diagnostico:{anamnesis:["Antecedentes de hipertiroidismo previo o bocio","Tratamiento antitiroideos vigente o reciente suspension","Exposicion a contraste yodado o amiodarona","Cirugia o procedimiento invasivo reciente","Infeccion reciente como factor desencadenante","Historia de Enfermedad de Graves o bocio multinodular","Sintomas de hipertiroidismo de larga data no diagnosticado","Parto reciente o embarazo en curso"],examenFisico:["Temperatura rectal o timpanica (no axilar \u2014 subestima)","Frecuencia cardiaca y ritmo cardiaco","Presion arterial y presion de pulso","Estado neurologico: nivel de conciencia, agitacion, confusion","Palpacion tiroidea: tamano, nodulos, soplo tiroideo","Signos oculares: exoftalmos, quemosis (Graves)","Auscultacion cardiaca y pulmonar (ICC)","Estado de hidratacion y diuresis","Busqueda de foco infeccioso desencadenante"],pruebas:[{nombre:"TSH ultrasensibie y T4 libre",descripcion:"TSH suprimida (<0.01 mU/L) con T4L francamente elevada. El diagnostico es clinico (BPS) \u2014 no esperar resultados para iniciar tratamiento",valoresReferencia:"TSH normal: 0.4-4.0 mU/L; T4L normal: 0.8-1.8 ng/dL. En tormenta: TSH indetectable, T4L >3-4 ng/dL",cuidadosEnfermeria:["Extraccion urgente, rotular como URGENTE","No retrasar tratamiento esperando resultado","Registrar hora exacta de extraccion","Informar al laboratorio para procesamiento prioritario"]},{nombre:"T3 libre (FT3)",descripcion:"Elevada. En algunos casos la T3 es el determinante principal de la toxicidad clinica (T3-toxicosis)",valoresReferencia:"Normal: 2.3-4.2 pg/mL. En tormenta: frecuentemente >10 pg/mL",cuidadosEnfermeria:["Solicitar junto con TSH y T4L","Informar resultado inmediatamente al medico"]},{nombre:"Hemograma completo",descripcion:"Leucocitosis con neutrofilia orienta a infeccion desencadenante. Puede haber leucopenia por antitiroideos (agranulocitosis)",valoresReferencia:"Leucocitos normales: 4.500-11.000/mm3",cuidadosEnfermeria:["Extraccion urgente","Vigilar leucopenia grave (<1.000 neutrofilos) si recibe antitiroideos","Alertar medico si neutrofilos <500/mm3 (agranulocitosis)"]},{nombre:"Perfil hepatico (TGO, TGP, GGT, bilirrubinas)",descripcion:"La hiperthermia severa produce da\xf1o hepatocelular directo. Ictericia indica mal pronostico",valoresReferencia:"TGO normal: 10-40 U/L; TGP normal: 7-56 U/L; Bilirrubina total < 1.2 mg/dL",cuidadosEnfermeria:["Observar coloracion de piel y escleras (ictericia)","Registrar color de orina (coluria)","Repetir a las 24-48h para evaluar progresion"]},{nombre:"Glucemia, electrolitos e ionograma",descripcion:"La hiperglucemia es frecuente por hipercatabolismo. Hipopotasemia por perdidas digestivas y diaforesis",valoresReferencia:"Glucemia 70-110 mg/dL; Na 136-145 mEq/L; K 3.5-5.0 mEq/L",cuidadosEnfermeria:["Control horario de glucemia en UCI","Reposicion de potasio segun ionograma","Vigilar arritmias asociadas a hipopotasemia"]},{nombre:"ECG de 12 derivaciones y monitoreo continuo",descripcion:"Detecta taquicardia sinusal, fibrilacion auricular, flutter, bloqueos y signos de isquemia por taquicardia extrema",valoresReferencia:"FC normal 60-100 lpm; PR 0.12-0.20 s. En tormenta: FC >140, FA frecuente",cuidadosEnfermeria:["Instalar monitor cardiaco continuo inmediatamente","Desfibrilador disponible a la cabecera","Registrar FC y ritmo cada 30 minutos","Alertar ante aparicion de FA o arritmias ventriculares"]},{nombre:"Cortisol plasmatico",descripcion:"Descarta insuficiencia suprarrenal relativa que agrava el cuadro. El estres metabolico puede agotar las reservas adrenales",valoresReferencia:"Normal en estres: > 18-20 mcg/dL. Valores < 15 mcg/dL sugieren insuficiencia relativa",cuidadosEnfermeria:["Extraccion matutina o en momento de maxima crisis","No demorar hidrocortisona si hay alta sospecha"]}]},tratamientoMedico:{objetivos:["Bloquear la sintesis de nuevas hormonas tiroideas en forma inmediata","Inhibir la liberacion de T3/T4 almacenadas (yodo administrado DESPUES de antitiroideos)","Bloquear los efectos adrenergicos perifericos (propranolol)","Controlar la hiperthermia con medios fisicos y farmacologicos","Corregir la insuficiencia suprarrenal relativa","Tratar el factor desencadenante","Soporte hemodinamico y ventilatorio segun necesidad"],farmacologico:[{nombre:"Propiltiouracilo (PTU)",grupo:"Antitiroideo tionamida de primera linea en tormenta",mecanismo:"Inhibe la peroxidasa tiroidea bloqueando la sintesis de T4 y T3. Adicionalmente inhibe la conversion periferica de T4 a T3 activa (ventaja sobre metimazol en crisis aguda)",dosis:"600-1000 mg dosis de carga oral o SNG, luego 200-300 mg cada 6-8 horas",cuidadosEnfermeria:["Administrar ANTES del yodo (al menos 1-2 horas antes)","Si no puede deglutir, triturar y administrar por SNG","Vigilar hepatotoxicidad: ictericia, dolor en hipocondrio derecho","Monitorizar hemograma semanal por riesgo de agranulocitosis","Registrar hora exacta de primera dosis \u2014 el orden PTU \u2192 yodo es critico","Contraindicado en embarazo avanzado (segundo/tercer trimestre)"]},{nombre:"Solucion de Lugol (yoduro de potasio)",grupo:"Yodo inorganico \u2014 bloqueo de liberacion tiroidea",mecanismo:"El exceso de yodo inhibe paradojicamente la sintesis y liberacion de hormonas tiroideas (efecto Wolff-Chaikoff). Reduce la vascularizacion tiroidea",dosis:"5-10 gotas cada 6-8 horas VO o via SNG. Solucion saturada de yoduro de potasio (SSKI): 5 gotas cada 6h",cuidadosEnfermeria:["NUNCA administrar antes del PTU \u2014 esperar minimo 1-2 horas post-PTU","Diluir en jugo o agua para mejorar palatabilidad","Vigilar reacciones de hipersensibilidad al yodo","Monitorizar funcion tiroidea cada 24-48 horas","Preparar dosis exacta con gotero estandarizado"]},{nombre:"Propranolol",grupo:"Betabloqueante no selectivo \u2014 control adrenergico",mecanismo:"Bloquea receptores beta-1 y beta-2 adrenergicos, reduciendo FC, PA y temblor. Inhibe conversion periferica de T4 a T3",dosis:"IV: 0.5-1 mg IV lento cada 15 min hasta control de FC (max 10 mg); VO: 60-120 mg cada 4-6 horas. En FA con ICC preferir esmolol IV titulable",cuidadosEnfermeria:["Monitorizar PA y FC antes y 15 minutos post-dosis IV","Contraindicado en broncoespasmo activo, bloqueo AV y ICC descompensada severa","Tener atropina disponible ante bradicardia extrema","Reducir dosis en insuficiencia hepatica","Registrar FC objetivo: < 100 lpm","En asmaticos usar esmolol IV (selectivo beta-1) como alternativa"]},{nombre:"Hidrocortisona",grupo:"Corticosteroide \u2014 manejo de insuficiencia suprarrenal relativa",mecanismo:"Cubre la posible insuficiencia suprarrenal relativa inducida por el hipercatabolismo. Adicionalmente inhibe la conversion periferica de T4 a T3",dosis:"100 mg IV en bolo, luego 100 mg IV cada 8 horas. Reduccion progresiva segun evolucion clinica",cuidadosEnfermeria:["Administrar por via IV en acceso venoso central o periferico calibroso","Vigilar glucemia (corticoides elevan glucemia)","Control de electrolitos: sodio y potasio","Monitorizar PA \u2014 puede contribuir a estabilizacion hemodinamica","Registrar balance hidrico estricto"]},{nombre:"Paracetamol (acetaminofeno)",grupo:"Antipiretico \u2014 manejo de hiperthermia",mecanismo:"Inhibicion central de prostaglandinas, reduciendo set point termico. NO usar aspirina (displaza T4 de proteinas transportadoras, agravando toxicidad)",dosis:"500-1000 mg IV o VO cada 6-8 horas. Complementar con mantas de enfriamiento fisico",cuidadosEnfermeria:["NUNCA administrar aspirina ni AINEs en tormenta tiroidea","Aplicar mantas de enfriamiento, compresas frias en axilas e ingles","Registrar temperatura cada 30-60 minutos","Mantener temperatura < 38.5\xb0C como objetivo","Vigilar hepatotoxicidad por paracetamol en contexto de da\xf1o hepatico previo","Hidratar adecuadamente para favorecer termolisis"]}],noFarmacologico:["Ingreso inmediato en UCI o unidad de cuidados intermedios","Monitoreo cardiaco continuo con desfibrilador disponible","Acceso venoso central para medicacion vasoactiva y medicion de PVC","Enfriamiento fisico activo: mantas de enfriamiento, bolsas de hielo en axilas, ingles y cuello","Hidratacion IV agresiva: 3-4 L/dia con solucion glucosada para cubrir hipercatabolismo","Oxigenoterapia para mantener SatO2 > 95%","Sonda urinaria para control estricto de diuresis horaria","Nutricion enteral precoz por SNG si hay alteracion de consciencia","Identificar y tratar el factor desencadenante (antibioticos si hay infeccion)","Plasmaferesis en casos refractarios al tratamiento convencional","Tiroidectomia de urgencia como ultimo recurso en fracasos terapeuticos"]},cuidadosEnfermeria:{valoracion:["Signos vitales completos cada 15-30 minutos: PA, FC, FR, temperatura (rectal), SatO2","Aplicar score de Burch-Wartofsky al ingreso y cada 6 horas","Estado neurologico: nivel de conciencia, agitacion, orientacion (Glasgow)","Evaluacion de signos de ICC: crepitantes, ingurgitacion yugular, edemas","Balance hidrico horario: ingresos vs diuresis","Valoracion de piel: diaforesis, temperatura, color, hidratacion","Vigilancia de signos de desencadenante infeccioso: heridas, focos ocultos"],intervenciones:["Instalar monitoreo cardiaco continuo y desfibrilador a la cabecera","Colocar acceso venoso central o dos vias perifericas calibrosas","Administrar medicacion en orden estricto: PTU \u2192 esperar 1-2h \u2192 Lugol","Aplicar tecnicas de enfriamiento fisico activo (mantas frias, bolsas de hielo)","Mantener ambiente fresco, disminuir temperatura ambiental","Administrar hidratacion IV segun indicacion y monitorizar respuesta","Colocar sonda vesical para control de diuresis horaria","Administrar oxigeno segun SatO2 y trabajo respiratorio","Preparar bandeja de intubacion: deterioro neurologico puede requerir VAM","Restringir estimulos ambientales: luz tenue, ruidos minimos, visitas limitadas","Registrar cada intervencion y respuesta en hoja de enfermeria UCI"],educacionPaciente:["Explicar al paciente y familia la gravedad de la situacion y necesidad de UCI","Instruir sobre importancia de NO suspender antitiroideos una vez estabilizado","Educar sobre signos de recaida: fiebre, palpitaciones, agitacion","Explicar necesidad de tratamiento definitivo: yodo radioactivo o cirugia","Ense\xf1ar identificacion de factores desencadenantes a evitar","Informar sobre seguimiento endocrinologico estrecho post-alta"],monitorizacion:["FC y ritmo cardiaco cada 15 minutos en fase aguda","Temperatura cada 30-60 minutos hasta estabilizacion","Glucemia horaria (hipercatabolismo + corticoides)","Ionograma cada 6-12 horas (hipopotasemia frecuente)","Funcion hepatica cada 24-48 horas (hepatotoxicidad por hiperthermia)","Hemograma diario por riesgo de agranulocitosis (antitiroideos)","TSH, T3L y T4L cada 24-48 horas para evaluar respuesta al tratamiento","Diuresis horaria \u2014 objetivo > 0.5 mL/kg/hora","Score de Burch-Wartofsky cada 6 horas para evaluar progresion o mejoria"]},npiNanda:[{codigo:"00007",nombre:"Hipertermia",definicion:"Temperatura corporal central superior a los limites normales diurnos como consecuencia de un fallo de la termorregulacion",caracteristicasDefinitorias:["Temperatura corporal > 40\xb0C","Piel caliente y ruborizada","Diaforesis profusa","Taquicardia","Taquipnea"],factoresRelacionados:["Hipercatabolismo por exceso de hormonas tiroideas","Activacion adrenergica masiva","Fallo de los mecanismos normales de termorregulacion"]},{codigo:"00029",nombre:"Disminucion del gasto cardiaco",definicion:"Cantidad de sangre bombeada por el corazon en un minuto insuficiente para satisfacer las demandas metabolicas del organismo",caracteristicasDefinitorias:["Taquicardia > 140 lpm","Fibrilacion auricular","Hipotension","Signos de insuficiencia cardiaca de alto gasto"],factoresRelacionados:["Estimulacion adrenergica por exceso de hormonas tiroideas","Aumento del consumo miocardico de oxigeno","Arritmias supraventriculares"]},{codigo:"00128",nombre:"Confusion aguda",definicion:"Aparicion brusca de trastornos reversibles de la conciencia, atencion, cognicion y percepcion que se desarrollan en un corto periodo de tiempo",caracteristicasDefinitorias:["Agitacion psicomotriz","Desorientacion en tiempo y espacio","Alteracion del nivel de conciencia","Conducta inapropiada"],factoresRelacionados:["Efectos neurologicos del exceso de hormonas tiroideas","Hiperthermia severa","Desequilibrio electrolitico"]}],npiNic:[{codigo:"3786",nombre:"Tratamiento de la fiebre",actividades:["Monitorizar temperatura cada 30-60 minutos","Aplicar mantas de enfriamiento y compresas frias","Administrar antipireticos segun prescripcion (paracetamol, NO aspirina)","Mantener hidratacion adecuada para favorecer termolisis","Registrar respuesta al tratamiento antipiretico"]},{codigo:"4040",nombre:"Cuidados cardiacos",actividades:["Monitoreo cardiaco continuo con alarmas activas","Registro de ECG ante cambios de ritmo","Administrar betabloqueantes segun prescripcion y respuesta","Mantener desfibrilador a la cabecera","Informar inmediatamente sobre FA, taquicardia ventricular u otras arritmias"]},{codigo:"6680",nombre:"Monitorizacion de los signos vitales",actividades:["Registrar PA, FC, FR y temperatura cada 15-30 minutos en fase critica","Notificar cambios significativos inmediatamente al medico","Utilizar monitorizacion invasiva (linea arterial) si hay inestabilidad hemodinamica","Documentar tendencias de signos vitales en grafica de UCI"]}],npiNoc:[{codigo:"0800",nombre:"Termorregulacion",indicadores:["Temperatura corporal en rango normal (36-37.5\xb0C)","Ausencia de escalofrios o diaforesis anormal","Sin signos de hiperthermia"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"},{codigo:"0400",nombre:"Efectividad de la bomba cardiaca",indicadores:["Frecuencia cardiaca < 100 lpm","Ritmo sinusal","PA en rango objetivo","Ausencia de signos de bajo gasto"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"},{codigo:"0902",nombre:"Comunicacion",indicadores:["Orientado en tiempo, espacio y persona","Sin agitacion psicomotriz","Respuesta coherente a estimulos"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"}],complicaciones:["Fibrilacion auricular con respuesta ventricular rapida","Insuficiencia cardiaca de alto gasto y edema pulmonar","Tormenta arrihmica y muerte subita cardiaca","Insuficiencia hepatica aguda por hiperthermia","Insuficiencia suprarrenal aguda","Rhabdomiolisis por hiperthermia severa e hiperactividad muscular","Insuficiencia renal aguda","Coagulacion intravascular diseminada (CID)","Encefalopatia metabolica y coma","Muerte (mortalidad 10-30% con tratamiento optimo)"],criteriosAlarma:["Temperatura > 40\xb0C que no cede con antipireticos","FC > 150 lpm o aparicion de fibrilacion auricular","Deterioro del nivel de conciencia o agitacion extrema","Hipotension arterial (PAS < 90 mmHg)","Score de Burch-Wartofsky >= 45 puntos","Signos de insuficiencia cardiaca aguda: crepitantes, disnea, ingurgitacion yugular","Ictericia (hepatotoxicidad por hiperthermia)","Oliguria o anuria (insuficiencia renal aguda)"],emergencyLevel:"critico",relatedPathologyIds:["pat_hipertiroidismo","pat_icc","pat_fa","pat_insuficiencia_suprarrenal"],isPremium:!0},{id:"pat_anemia_megaloblastica",nombre:"Anemia Megaloblastica",bodySystemId:"hematologico",definicion:"Anemia macroctica causada por deficit de vitamina B12 (cobalamina) o acido folico, que genera alteracion en la sintesis de ADN y division celular defectuosa, produciendo eritrocitos de gran tamano (megaloblastos) y eritropoyesis ineficaz en medula osea.",epidemiologia:"La anemia perniciosa (deficit de B12 autoinmune) afecta al 0.1% de la poblacion general y al 1.9% de mayores de 60 a\xf1os. El deficit de folato es mas frecuente en embarazadas, alcoholicos y pacientes con malabsorcion. En Argentina, el deficit de B12 afecta al 40% de los vegetarianos estrictos no suplementados.",factoresRiesgo:["Dieta vegetariana o vegana sin suplementacion","Gastrectomia o cirugia bariatrica","Anemia perniciosa (autoinmune)","Gastritis atrofica cronica","Malabsorcion intestinal (enfermedad celiaca, Crohn)","Alcoholismo cronico","Embarazo y lactancia","Uso prolongado de metformina o inhibidores de bomba de protones","Edad avanzada","Infeccion por Helicobacter pylori"],fisiopatologia:"La vitamina B12 y el acido folico son cofactores esenciales para la sintesis de timidina y la replicacion del ADN. Su deficit produce una division celular defectuosa: los nucleos maduran lentamente mientras el citoplasma crece normalmente, generando celulas grandes (megaloblastos). La eritropoyesis ineficaz provoca hemolisis intramedular y pancitopenia. El deficit de B12 ademas afecta la mielinizacion neuronal por alteracion en la sintesis de mielina, produciendo neuropatia subaguda combinada de medula espinal (degeneracion de cordones posteriores y laterales).",signosYSintomas:{signos:["Macrocitosis: VCM > 100 fl","Megaloblastos en medula osea","Hipersegmentacion de neutrofilos (>5 lobulos)","Glositis (lengua roja, lisa, dolorosa)","Ictericia leve por hemolisis intramedular","Esplenomegalia leve","Ataxia por neuropatia subaguda combinada (deficit B12)","Palidez mucocutanea"],sintomas:["Astenia y fatiga progresiva","Disnea de esfuerzo","Palpitaciones","Parestesias en manos y pies (hormigueo, adormecimiento)","Dificultad para caminar y coordinacion","Deterioro cognitivo y depresion (en deficit B12 severo)","Anorexia y perdida de peso","Diarrea o constipacion"]},clasificacion:{nombre:"Clasificacion segun deficit causante",tipos:[{nombre:"Deficit de vitamina B12",descripcion:"Causado por anemia perniciosa, gastrectomia, malabsorcion ileal o dieta vegana. Puede producir neuropatia severa incluso sin anemia significativa"},{nombre:"Deficit de acido folico",descripcion:"Causado por ingesta insuficiente, alcoholismo, embarazo, malabsorcion o farmacos (metotrexato, fenitoina). No produce neuropatia"},{nombre:"Deficit combinado B12 y folato",descripcion:"Presenta manifestaciones de ambos, con riesgo elevado de neuropatia y pancitopenia severa"},{nombre:"Anemia perniciosa",descripcion:"Forma autoinmune por anticuerpos anti-celulas parietales y anti-factor intrinseco, con gastritis atrofica. Requiere tratamiento de por vida"}]},diagnostico:{anamnesis:["Habitos alimentarios (veganismo, alcoholismo)","Antecedentes de cirugia gastrica o intestinal","Historia familiar de anemia perniciosa","Uso de metformina, IBP o anticonvulsivantes","Sintomas neurologicos: parestesias, dificultad para caminar","Antecedentes de enfermedad autoinmune tiroidea o DM1"],examenFisico:["Palidez de piel y mucosas","Inspeccion de lengua: glositis de Hunter (lisa, roja, atrofica)","Evaluacion neurologica: sensibilidad vibratoria y propioceptiva","Test de Romberg para evaluar ataxia sensitiva","Palpacion abdominal: esplenomegalia","Evaluacion cognitiva basica"],pruebas:[{nombre:"Hemograma completo con frotis de sangre periferica",descripcion:"Revela macrocitosis (VCM >100 fl), pancitopenia e hipersegmentacion neutrofilica. El frotis confirma morfologia megaloblastica",valoresReferencia:"VCM normal: 80-100 fl. VCM >100 fl: macrocitosis. Hb: 12-16 g/dL mujer, 13-18 g/dL hombre",cuidadosEnfermeria:["Obtener muestra en tubo con EDTA","Procesar en menos de 4 horas para evitar alteracion morfologica","Registrar aspecto de la muestra y anotar medicacion actual del paciente"]},{nombre:"Vitamina B12 serica",descripcion:"Confirma deficit de cobalamina. Niveles bajos indican deficit absoluto; niveles limites requieren dosaje de acido metilmalonico",valoresReferencia:"Normal: 200-900 pg/mL. Deficit: < 200 pg/mL. Zona gris: 200-300 pg/mL",cuidadosEnfermeria:["Extraer muestra en ayunas","Proteger el tubo de la luz solar (la vitamina B12 es fotosensible)","Anotar si el paciente recibio suplementos de B12 en los ultimos 30 dias"]},{nombre:"Folato serico y eritrocitario",descripcion:"El folato eritrocitario refleja el estado de los ultimos 3 meses y es mas confiable que el folato serico (que varia con la ingesta reciente)",valoresReferencia:"Folato serico: 2.7-17 ng/mL. Folato eritrocitario: 140-628 ng/mL",cuidadosEnfermeria:["Ayuno de al menos 8 horas para folato serico","Evitar hemolisis en la muestra","Registrar ingesta reciente de acido folico o multivitaminicos"]},{nombre:"Acido metilmalonico (AMM) y homocisteina plasmatica",descripcion:"Marcadores funcionales de deficit de B12 y folato respectivamente. Se elevan antes que los niveles sericos caigan. AMM elevado es especifico de deficit B12",valoresReferencia:"AMM: 0.07-0.27 umol/L. Homocisteina: 5-15 umol/L. Elevados en deficit",cuidadosEnfermeria:["Muestra en ayunas","Centrifugar y procesar de forma inmediata","Congelar si no se procesa en menos de 2 horas"]},{nombre:"Anticuerpos anti-factor intrinseco y anti-celulas parietales",descripcion:"Confirman anemia perniciosa autoinmune. Los anti-factor intrinseco son altamente especificos (95%) aunque poco sensibles (50%)",valoresReferencia:"Resultado negativo = ausencia de autoanticuerpos (normal)",cuidadosEnfermeria:["No requiere preparacion especial","Explicar al paciente el significado del estudio autoinmune","Registrar antecedentes de otras enfermedades autoinmunes"]},{nombre:"Mielograma (aspirado de medula osea)",descripcion:"Reservado para casos dudosos. Muestra megaloblastos, precursores gigantes de la serie mieloide y metamielocitos gigantes",valoresReferencia:"Hallazgo patologico: presencia de megaloblastos y precursores gigantes",cuidadosEnfermeria:["Preparar campo esteril para puncion de cresta iliaca posterior","Administrar analgesia y ansiolitico segun indicacion medica","Vigilar sitio de puncion durante 30 minutos post-procedimiento","Aplicar ap\xf3sito compresivo y controlar sangrado"]}]},tratamientoMedico:{objetivos:["Corregir el deficit de vitamina B12 o acido folico","Revertir la anemia y normalizar parametros hematologicos","Prevenir o detener la progresion de la neuropatia por deficit B12","Identificar y tratar la causa subyacente","Suplementacion de por vida en anemia perniciosa"],farmacologico:[{nombre:"Cianocobalamina (Vitamina B12) intramuscular",grupo:"Vitamina del complejo B - Cianocobalamina",mecanismo:"Repone los depositos de cobalamina; actua como cofactor en la sintesis de ADN, metabolismo de acidos grasos y mantenimiento de la vaina de mielina neuronal",dosis:"1000 mcg IM diario por 7 dias, luego semanal por 4 semanas, luego mensual de por vida (en anemia perniciosa)",cuidadosEnfermeria:["Administrar via intramuscular profunda en gluteo o deltoides","Rotar sitios de inyeccion para evitar fibrosis local","Alertar al paciente sobre posible reaccion local (dolor, enrojecimiento)","Monitorizar potasio los primeros dias (riesgo de hipopotasemia por recuperacion medular rapida)","Explicar que los sintomas neurologicos pueden mejorar lentamente en semanas o meses"]},{nombre:"Acido folico oral",grupo:"Vitamina B9 - Folato sintetico",mecanismo:"Suplementa el folato necesario para la sintesis de timidilato y replicacion del ADN; corrige la eritropoyesis ineficaz por deficit de folato",dosis:"5 mg/dia oral por 4 meses (o hasta correccion de causa). En embarazo: 400-800 mcg/dia preventivo",cuidadosEnfermeria:["Administrar con alimentos para mejorar tolerancia gastrointestinal","NUNCA administrar folato como unico tratamiento sin descartar deficit de B12 (puede enmascarar anemia y permitir progresion de neuropatia)","Vigilar respuesta hematologica: reticulocitosis al 5-7 dia indica respuesta adecuada","Educar sobre fuentes alimentarias de folato: legumbres, vegetales de hoja verde, citricos"]},{nombre:"Hidroxocobalamina",grupo:"Vitamina del complejo B - Cobalamina de deposito",mecanismo:"Forma de deposito de vitamina B12 con mayor vida media que la cianocobalamina; se une a proteinas plasmaticas y se libera lentamente",dosis:"1000 mcg IM en dias alternos por 2 semanas, luego cada 3 meses (mantenimiento)",cuidadosEnfermeria:["Preferida sobre cianocobalamina en pacientes fumadores o con insuficiencia renal","Mantener cadena de frio: conservar entre 8-15 grados Celsius","Registrar fecha y sitio de cada inyeccion en historia clinica","Educar al paciente sobre la necesidad de tratamiento indefinido en anemia perniciosa"]}],noFarmacologico:["Educacion nutricional: fuentes de B12 (carnes, pescado, huevos, lacteos) y folato (legumbres, vegetales verdes)","Cesacion del alcohol en pacientes alcoholicos","Revision y ajuste de farmacos que interfieren (metformina, IBP, metotrexato)","Rehabilitacion neurologica en casos con neuropatia establecida","Seguimiento gastroenterologico por mayor riesgo de cancer gastrico en anemia perniciosa"]},cuidadosEnfermeria:{valoracion:["Evaluar nivel de fatiga y capacidad funcional con escala ECOG o Barthel","Valorar signos neurologicos: sensibilidad vibratoria (diapason), propriocepcion, marcha","Inspeccionar mucosa oral y lengua (glositis)","Registrar habitos alimentarios y consumo de alcohol","Evaluar riesgo de caidas por ataxia sensitiva","Valorar estado cognitivo basico en adultos mayores"],intervenciones:["Administrar vitamina B12 IM o acido folico oral segun prescripcion","Implementar medidas de seguridad por riesgo de caidas (barandas, alfombras antideslizantes)","Asistencia en actividades de la vida diaria durante fase aguda","Coordinacion de consulta con neurologo si hay deficit neurologico significativo","Control de hemograma a la semana de inicio de tratamiento para verificar reticulocitosis","Educar sobre necesidad de tratamiento prolongado o de por vida"],educacionPaciente:["Explicar la diferencia entre deficit de B12 y folato y su tratamiento especifico","Ense\xf1ar fuentes alimentarias ricas en B12 y folato","Instruir sobre la importancia de no suspender las inyecciones en anemia perniciosa","Advertir que mejorar la anemia no implica resolucion de neuropatia (proceso mas lento)","En embarazadas: suplementacion preventiva con acido folico antes de la concepcion","Reconocer signos de alarma: empeoramiento neurologico, confusion, caidas"],monitorizacion:["Hemograma y reticulocitos al 5-7 dia de inicio de tratamiento","Control de potasio en los primeros 3-5 dias (hipopotasemia por recuperacion medular)","Hemograma mensual hasta normalizacion de valores","B12 serica a los 2-3 meses de tratamiento","Evaluacion neurologica cada 3 meses si habia compromiso neuronal","Endoscopia digestiva alta periodica en anemia perniciosa (riesgo de carcinoma gastrico)"]},npiNanda:[{codigo:"00093",nombre:"Fatiga",definicion:"Sensacion abrumadora y sostenida de agotamiento y disminucion de la capacidad para el trabajo mental y fisico al nivel habitual",caracteristicasDefinitorias:["Incapacidad para mantener el nivel habitual de actividad fisica","Verbaliza agotamiento persistente","Letargia e indiferencia hacia el entorno","Disnea de esfuerzo por anemia"],factoresRelacionados:["Anemia por eritropoyesis ineficaz","Hipoxia tisular por disminucion de hemoglobina","Deficit nutricional de vitamina B12 o acido folico","Estado de enfermedad cronica"]},{codigo:"00047",nombre:"Riesgo de deterioro de la integridad cutanea",definicion:"Vulnerable a alteracion en la epidermis o dermis que puede comprometer la salud",caracteristicasDefinitorias:["Palidez mucocutanea intensa","Glositis con mucosa oral fragil","Alteracion de la sensibilidad por neuropatia periferica"],factoresRelacionados:["Deficit nutricional de vitamina B12","Alteracion de la perfusion tisular por anemia","Neuropatia sensitiva periferica con perdida de sensibilidad protectora"]},{codigo:"00035",nombre:"Riesgo de lesion",definicion:"Vulnerable a lesion fisica como consecuencia de condiciones ambientales que interactuan con los recursos adaptativos y defensivos del individuo",caracteristicasDefinitorias:["Ataxia sensitiva por deficit de B12","Parestesias que alteran la sensibilidad protectora","Debilidad muscular por anemia severa"],factoresRelacionados:["Neuropatia subaguda combinada por deficit de vitamina B12","Alteracion del equilibrio y la propiocepcion","Debilidad generalizada secundaria a anemia severa"]}],npiNic:[{codigo:"6490",nombre:"Prevencion de caidas",actividades:["Evaluar el riesgo de caidas con escala validada (Morse o Downton)","Instalar barandas en cama y bano","Asegurar iluminacion adecuada en habitacion y pasillos","Instruir al paciente a solicitar asistencia para deambular","Educar sobre uso de calzado cerrado y antideslizante"]},{codigo:"2300",nombre:"Administracion de medicacion",actividades:["Preparar y administrar vitamina B12 IM con tecnica aseptica","Rotar los sitios de inyeccion y registrar cada administracion","Verificar la correcta identificacion del paciente antes de cada dosis","Monitorizar sitio de inyeccion por reacciones locales","Educar sobre la importancia de no suspender el tratamiento"]},{codigo:"1100",nombre:"Manejo de la nutricion",actividades:["Evaluar el estado nutricional y habitos alimentarios","Derivar a nutricionista para plan alimentario personalizado","Proporcionar lista de alimentos ricos en B12 y folato","Monitorizar ingesta diaria durante hospitalizacion","Reforzar la educacion sobre fuentes alimentarias en cada consulta"]}],npiNoc:[{codigo:"0005",nombre:"Tolerancia a la actividad",indicadores:["Frecuencia cardiaca en reposo dentro de rango normal","Saturacion de oxigeno con actividad > 90%","Ausencia de fatiga con actividades cotidianas","Hemoglobina dentro de valores normales"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"},{codigo:"1902",nombre:"Control del riesgo",indicadores:["Identifica factores de riesgo personales de deficit vitaminico","Adopta conductas para reducir el riesgo (dieta, adherencia al tratamiento)","Reconoce signos neurologicos de alarma","Acude a controles periodicos programados"],escala:"1=Nunca demostrado, 2=Raramente demostrado, 3=A veces demostrado, 4=Frecuentemente demostrado, 5=Siempre demostrado"},{codigo:"1004",nombre:"Estado nutricional",indicadores:["Ingesta de vitamina B12 y folato adecuada","Valores de hemoglobina y VCM en rango normal","Niveles sericos de B12 y folato normalizados","Peso corporal estable"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Neuropatia subaguda combinada de medula espinal (irreversible si no se trata a tiempo)","Pancitopenia severa con riesgo de infecciones y hemorragias","Insuficiencia cardiaca de alto gasto por anemia severa","Deterioro cognitivo y demencia por deficit cronico de B12","Mayor riesgo de carcinoma gastrico en anemia perniciosa","Complicaciones obstettricas: defectos del tubo neural por deficit de folato en el embarazo","Tromboembolismo venoso por hiperhomocisteinemia"],criteriosAlarma:["Hemoglobina < 7 g/dL con sintomas cardiovasculares (taquicardia, hipotension, disnea en reposo)","Aparicion o empeoramiento brusco de deficit neurologico (paralisis, perdida de control de esfinteres)","Pancitopenia severa: neutrofilos < 500/mm3 o plaquetas < 20.000/mm3","Confusion aguda o deterioro cognitivo rapido","Convulsiones asociadas a anemia severa","Signos de insuficiencia cardiaca descompensada por anemia"],emergencyLevel:"leve",relatedPathologyIds:["pat_anemia_ferropenica","pat_gastritis_cronica","pat_neuropatia_periferica","pat_celiaca"],isPremium:!0},{id:"pat_aplasia_medular",nombre:"Aplasia Medular",bodySystemId:"hematologico",definicion:"Insuficiencia de la medula osea caracterizada por la destruccion o ausencia del tejido hematopoyetico, con incapacidad para producir cantidades suficientes de celulas sanguineas, resultando en pancitopenia (anemia, leucopenia y trombocitopenia) que compromete seriamente la vida del paciente.",epidemiologia:"Incidencia de 2-6 casos por millon de habitantes por ano en paises occidentales, con mayor prevalencia en Asia (hasta 3 veces mas frecuente). Presenta distribucion bimodal: pico en adultos jovenes de 15-25 a\xf1os y en mayores de 60 a\xf1os. Afecta por igual a ambos sexos. En Argentina, representa una causa importante de fallo medular adquirido.",factoresRiesgo:["Exposicion a agentes quimicos (benceno, solventes organicos)","Radioterapia o exposicion a radiaciones ionizantes","Farmacos (cloranfenicol, sulfonamidas, antiepilecticos, AINEs)","Infecciones virales (hepatitis no A no B, parvovirus B19, VIH, CMV, VEB)","Enfermedades autoinmunes (lupus eritematoso sistemico)","Embarazo (aplasia asociada al embarazo, rara)","Antecedentes familiares (aplasia hereditaria: anemia de Fanconi)","Transfusiones previas multiples","Origen asiatico"],fisiopatologia:"En la mayoria de los casos (70-80%) la aplasia medular adquirida es de mecanismo autoinmune: linfocitos T autorreactivos reconocen antigenos de celulas hematopoyeticas y destruyen las celulas progenitoras CD34+ mediante apoptosis mediada por Fas/FasL y secrecion de interferon-gamma y TNF-alfa. La perdida de celulas madre hematopoyeticas reduce la produccion de los tres linajes celulares: eritrocitos (anemia), leucocitos granulocitos (leucopenia, neutropenia con riesgo infeccioso) y plaquetas (trombocitopenia con riesgo hemorragico). La medula osea es reemplazada por tejido adiposo.",signosYSintomas:{signos:["Palidez cutaneo-mucosa marcada (anemia)","Petequias y equimosis espontaneas (trombocitopenia)","Purpura en piel y mucosas","Fiebre (infeccion secundaria a neutropenia)","Hepatoesplenomegalia leve en algunos casos","Taquisistolia compensatoria","Hemorragia en fondos de ojo en casos graves"],sintomas:["Astenia y fatiga profunda (anemia)","Disnea de esfuerzo","Palpitaciones","Sangrado espontaneo: epistaxis, gingivorragia, menorragia","Hematomas ante minimos traumatismos","Infecciones recurrentes y de dificil control","Ulceras orales y faringitis frecuentes","Palidez progresiva"]},clasificacion:{nombre:"Clasificacion de gravedad (criterios de Camitta modificados)",tipos:[{nombre:"Aplasia No Severa (AMNS)",descripcion:"Pancitopenia sin cumplir criterios de severa. Neutrofilos > 0.5 x10^9/L, plaquetas > 20 x10^9/L"},{nombre:"Aplasia Severa (AMS)",descripcion:"Al menos 2 de: neutrofilos < 0.5 x10^9/L, plaquetas < 20 x10^9/L, reticulocitos < 1%. Celularidad medular < 25%"},{nombre:"Aplasia Muy Severa (AMMS)",descripcion:"Criterios de AMS mas neutrofilos < 0.2 x10^9/L. Maximo riesgo infeccioso y hemorragico"}]},diagnostico:{anamnesis:["Exposicion a toxicos, farmacos o radiaciones (6 meses previos)","Antecedentes infecciosos recientes (hepatitis, virosis)","Historia familiar de citopenias o malformaciones congenitas","Tiempo de evolucion de los sintomas hemorragicos e infecciosos","Transfusiones previas y numero de unidades","Enfermedades autoinmunes conocidas"],examenFisico:["Inspeccion de piel y mucosas: petequias, equimosis, palidez","Exploracion de adenopatias y organomegalia","Fondo de ojo: hemorragias retinianas","Auscultacion cardiaca: soplo anemico funcional","Exploracion de sitios de posibles hemorragias internas","Evaluacion de signos infecciosos activos"],pruebas:[{nombre:"Hemograma completo con formula y reticulocitos",descripcion:"Confirma pancitopenia: anemia (Hb < 8 g/dL en casos graves), neutropenia (< 0.5 x10^9/L), trombocitopenia (< 20 x10^9/L). Reticulocitos bajos (< 1%) confirman fallo medular",valoresReferencia:"Hb normal 12-18 g/dL; Neutrofilos > 1.8 x10^9/L; Plaquetas 150-400 x10^9/L; Reticulocitos 0.5-1.5%",cuidadosEnfermeria:["Usar tecnica aseptica estricta en extraccion (riesgo infeccioso elevado)","Aplicar presion prolongada en sitio de puncion (5-10 min) por riesgo hemorragico","Observar sitio de puncion durante 30 min post-extraccion","Registrar resultado y notificar valores criticos de inmediato"]},{nombre:"Biopsia de medula osea (BMO)",descripcion:"Estudio diagnostico definitivo. Muestra medula hipoplasica con < 25% de celularidad hematopoyetica, reemplazada por adipocitos. Descarta sindrome mielodisplasico y leucemia",valoresReferencia:"Medula osea normal: celularidad 30-70% segun edad",cuidadosEnfermeria:["Preparar material de biopsia de cresta iliaca posterior","Explicar procedimiento y obtener consentimiento informado","Posicionar en decubito prono o lateral segun preferencia del medico","Vigilar sitio de puncion post-procedimiento por 4-6 horas","Control de signos vitales cada 30 min la primera hora post-biopsia","Valorar dolor post-procedimiento y administrar analgesia segun prescripcion"]},{nombre:"Citometria de flujo en sangre periferica",descripcion:"Detecta poblacion PNH (hemoglobinuria paroxistica nocturna) presente en 30-50% de aplasias medulares, con implicancias terapeuticas",valoresReferencia:"Ausencia de clon PNH (CD55/CD59 en eritrocitos y granulocitos > 95%)",cuidadosEnfermeria:["Muestra en tubo con EDTA, procesamiento rapido (< 24h)","No refrigerar la muestra","Registrar fecha de extraccion en el tubo"]},{nombre:"Estudios virologicos (VEB, CMV, Parvovirus B19, Hepatitis A-B-C, VIH)",descripcion:"Identifican etiologia infecciosa. El hepatitis-associated aplastic anemia es una entidad definida que ocurre 2-3 meses post-hepatitis aguda",valoresReferencia:"Serologias negativas = sin exposicion activa",cuidadosEnfermeria:["Extraer muestra venosa en ayunas si se combina con otras determinaciones","Identificar correctamente los tubos por tipo de estudio","Conservar suero a -20\xb0C si no se procesa en 24h"]},{nombre:"HLA tipificacion (paciente y hermanos)",descripcion:"Imprescindible para evaluar trasplante de medula osea. Identifica donante compatibles en pacientes menores de 40 a\xf1os con aplasia severa",valoresReferencia:"Compatibilidad HLA 10/10 o 9/10 para trasplante no relacionado",cuidadosEnfermeria:["Coordinar extraccion simultanea de paciente y familiares","Tubo especifico para HLA (EDTA de 10 mL)","Enviar a laboratorio de referencia con cadena de frio"]}]},tratamientoMedico:{objetivos:["Restaurar la hematopoyesis normal","Prevenir complicaciones infecciosas y hemorragicas","Alcanzar independencia transfusional","Curar la enfermedad cuando sea posible (trasplante)"],farmacologico:[{nombre:"Globulina Antitimocitica (ATG) equina + Ciclosporina",grupo:"Inmunosupresion: tratamiento estandar en no candidatos a trasplante",mecanismo:"La ATG destruye linfocitos T autorreactivos responsables de la destruccion medular. La ciclosporina inhibe IL-2 y proliferacion de linfocitos T, sosteniendo la supresion autoinmune",dosis:"ATG equina 40 mg/kg/dia IV por 4 dias. Ciclosporina 5 mg/kg/dia VO dividida en 2 tomas por minimo 6 meses",cuidadosEnfermeria:["Premedicar con metilprednisolona, antihistaminico y paracetamol 30 min antes de ATG","Infundir ATG en 12-18 horas con filtro especial de 0.2 micrones","Monitorizar signos de anafilaxia durante infusion: urticaria, broncoespasmo, hipotension","Vigilar fiebre, escalofrios, rash durante y post-infusion (reaccion serica)","Controlar niveles de ciclosporina en sangre (rango terapeutico 200-400 ng/mL)","Monitorizar funcion renal y PA (ciclosporina es nefrotoxica e hipertensiva)","Registrar diuresis horaria durante infusion de ATG"]},{nombre:"Eltrombopag",grupo:"Agonista del receptor de trombopoyetina (TPO-RA)",mecanismo:"Estimula el receptor de trombopoyetina en celulas progenitoras CD34+, promoviendo proliferacion y diferenciacion hematopoyetica multilinaje. Se agrega a ATG+CsA para mejorar respuesta",dosis:"150 mg/dia VO en ayunas (reducir a 75 mg/dia en poblacion asiatica). Iniciar el dia 14 post-ATG",cuidadosEnfermeria:["Administrar con el estomago vacio (4h sin comidas ricas en calcio, magnesio, aluminio)","No administrar con anti\xe1cidos, productos lacteos ni suplementos de hierro en forma simultanea","Controlar funcion hepatica mensualmente (hepatotoxicidad)","Vigilar trombosis (efecto adverso potencial al aumentar plaquetas)","Monitorizar hemograma semanal para evaluar respuesta hematopoyetica"]},{nombre:"G-CSF (Filgrastim)",grupo:"Factor estimulante de colonias granulocitarias",mecanismo:"Estimula la produccion, maduracion y activacion de neutrofilos a partir de celulas progenitoras. Reduce el periodo de neutropenia severa y el riesgo de infecciones bacterianas graves",dosis:"5-10 mcg/kg/dia SC o IV hasta neutrofilos > 1.0 x10^9/L",cuidadosEnfermeria:["Administrar en sitio de inyeccion rotatorio (abdomen, muslo, brazo)","Advertir sobre dolor oseo (efecto adverso mas frecuente): analgesia con paracetamol","Controlar hemograma diario para ajuste de dosis","Conservar el farmaco refrigerado (2-8\xb0C), no congelar","Vigilar esplenomegalia por estimulacion de produccion mieloide"]}],noFarmacologico:["Trasplante alog\xe9nico de m\xe9dula \xf3sea (TMO): tratamiento curativo de elecci\xf3n en menores de 40 a\xf1os con aplasia severa y donante HLA compatible","Soporte transfusional: concentrados de hematicos (umbral Hb < 7-8 g/dL) y de plaquetas (umbral < 10 x10^9/L o < 20 con sangrado activo)","Aislamiento protector en neutropenia severa: habitacion individual con filtro HEPA","Dieta cocida y sin productos frescos crudos durante neutropenia severa","Higiene oral rigurosa con colutorio de clorhexidina para prevenir infecciones","Evitar procedimientos invasivos innecesarios (sondas, punciones) mientras persiste trombocitopenia"]},cuidadosEnfermeria:{valoracion:["Hemograma diario: vigilar tendencia de neutrofilos, plaquetas y hemoglobina","Evaluar signos de hemorragia activa: epistaxis, hemoptisis, melena, hematuria, petequias nuevas","Valorar signos de infeccion: fiebre > 38\xb0C en neutropenico es emergencia infecciosa","Monitorizar signos vitales cada 4-8 horas segun gravedad","Evaluar tolerancia a la actividad y grado de fatiga (escala de Piper o EVA)","Valorar estado nutricional y tolerancia oral"],intervenciones:["Implementar precauciones de aislamiento protector (mascarilla, guantes, bata en neutropenia severa)","Tecnica aseptica estricta en todos los procedimientos invasivos","Administrar transfusiones segun protocolo: verificar compatibilidad, premeditar con antihistaminicos, vigilar reacciones transfusionales","Administrar farmacoterapia inmunosupresora y factores de crecimiento segun prescripcion","Prevenir sangrado: evitar punciones arteriales innecesarias, uso de presion prolongada, no administrar inyecciones IM con plaquetas < 50 x10^9/L","Educacion sobre signos de alarma: fiebre, sangrado, disnea"],educacionPaciente:["Explicar la importancia del aislamiento protector y las precauciones de higiene","Ense\xf1ar reconocimiento de signos de infeccion: fiebre > 38\xb0C requiere consulta inmediata","Instruir sobre signos de sangrado que requieren atencion urgente: sangrado que no cede en 10 min","Evitar contacto con personas enfermas, lugares concurridos y animales durante neutropenia","Importancia de la adherencia a ciclosporina y controles de niveles sericos","Dieta segura durante neutropenia: alimentos cocidos, evitar crudos, frutas lavadas solo con cascara intacta"],monitorizacion:["Hemograma completo diario durante hospitalizacion","Temperatura cada 4-6 horas: fiebre en neutropenico = emergencia","Signos vitales cada 4 horas en fase aguda","Diuresis diaria y balance hidrico","Funcion renal y hepatica 2-3 veces por semana (toxicidad de ciclosporina y ATG)","Niveles de ciclosporina en sangre semanalmente","Inspecccion diaria de piel, mucosas y sitios de puncion"]},npiNanda:[{codigo:"00206",nombre:"Riesgo de sangrado",definicion:"Vulnerable a una disminucion del volumen de sangre que puede comprometer la salud",caracteristicasDefinitorias:["Trombocitopenia severa (plaquetas < 20 x10^9/L)","Petequias y equimosis espontaneas","Epistaxis y gingivorragia recurrentes"],factoresRelacionados:["Trombocitopenia por fallo medular","Procedimientos invasivos en paciente con coagulopatia","Deficiencia de factores de coagulacion asociada"]},{codigo:"00004",nombre:"Riesgo de infeccion",definicion:"Vulnerable a ser invadido y multiplicado por organismos patogenos que pueden comprometer la salud",caracteristicasDefinitorias:["Neutropenia severa (neutrofilos < 0.5 x10^9/L)","Fiebre recurrente sin foco identificado","Ulceras orales frecuentes"],factoresRelacionados:["Neutropenia grave secundaria a fallo medular","Tratamiento inmunosupresor (ATG, ciclosporina)","Ruptura de barrera cutanea por procedimientos invasivos"]},{codigo:"00093",nombre:"Fatiga",definicion:"Sensacion agobiante y sostenida de agotamiento y disminucion de la capacidad para el trabajo mental y fisico habitual",caracteristicasDefinitorias:["Verbaliza cansancio extremo","Incapacidad para mantener actividades habituales","Disnea ante minimos esfuerzos"],factoresRelacionados:["Anemia grave por insuficiencia medular","Enfermedad cronica","Tratamiento inmunosupresor"]}],npiNic:[{codigo:"4010",nombre:"Prevencion de hemorragias",actividades:["Vigilar signos y sintomas de hemorragia: petequias, equimosis, epistaxis, melena","Evitar punciones arteriales innecesarias; aplicar presion durante 10 min en sitios de puncion venosa","No administrar inyecciones intramusculares con plaquetas < 50 x10^9/L","Administrar transfusiones de plaquetas segun umbral prescrito","Instruir al paciente para evitar actividades con riesgo de traumatismo","Evitar uso de AINEs, aspirina y otros antiagregantes"]},{codigo:"6550",nombre:"Proteccion contra infecciones",actividades:["Implementar aislamiento protector en neutropenia < 0.5 x10^9/L","Uso estricto de tecnica aseptica en todos los procedimientos","Monitorizar temperatura cada 4-6 horas: notificar fiebre > 38\xb0C de inmediato","Limitar visitas y excluir personas con infecciones activas","Higiene oral con colutorio de clorhexidina 3 veces al dia","Administrar profilaxis antiinfecciosa prescrita (fluconazol, trimetoprim-sulfametoxazol)"]},{codigo:"0180",nombre:"Manejo de la energia",actividades:["Planificar actividades con periodos de reposo intercalados","Establecer prioridades en actividades diarias segun tolerancia","Administrar transfusiones de concentrado de hematicos segun umbral de hemoglobina","Monitorizar respuesta a la actividad: saturacion O2, FC, disnea","Fomentar autocuidado progresivo segun estado hematologico"]}],npiNoc:[{codigo:"0413",nombre:"Severidad de la perdida de sangre",indicadores:["Ausencia de hemorragia activa","Recuento plaquetario en rango seguro (> 20 x10^9/L)","Presion arterial estable","Hemoglobina en valor objetivo (> 7-8 g/dL)"],escala:"1=Grave, 2=Sustancial, 3=Moderada, 4=Leve, 5=Sin evidencia"},{codigo:"0702",nombre:"Estado inmune",indicadores:["Recuento de neutrofilos en rango de seguridad (> 0.5 x10^9/L)","Ausencia de infecciones activas","Temperatura corporal en rango normal","Cultivos negativos"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"},{codigo:"0007",nombre:"Nivel de fatiga",indicadores:["Refiere disminucion del cansancio","Capacidad para realizar actividades basicas de la vida diaria","Saturacion de oxigeno en reposo > 95%","Frecuencia cardiaca en reposo < 100 lpm"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"}],complicaciones:["Sepsis por bacterias gram-negativas (Pseudomonas, Enterobacterias) en neutropenia grave","Aspergilosis invasiva y otras infecciones fungicas oportunistas","Hemorragia intracraneal (trombocitopenia < 5 x10^9/L)","Hemorragia digestiva mayor","Aloinmunizacion transfusional (refractariedad a transfusiones de plaquetas)","Hemoglobinuria Paroxistica Nocturna (HPN): clonacion de celulas PNH","Transformacion a sindrome mielodisplasico o leucemia mieloide aguda (< 15% a 10 a\xf1os)","Sobrecarga de hierro por transfusiones multiples","Enfermedad injerto contra huesped (EICH) post-trasplante alog\xe9nico"],criteriosAlarma:["Fiebre > 38\xb0C en paciente neutropenico (< 0.5 x10^9/L): emergencia infecciosa","Sangrado activo que no cede en 10-15 minutos","Cefalea intensa o subita (riesgo de hemorragia intracraneal)","Alteracion del sensorio o convulsiones","Disnea aguda severa con hipoxemia","Epistaxis masiva o hemoptisis","Presion arterial < 90/60 mmHg con taquicardia (sepsis)"],emergencyLevel:"moderado",relatedPathologyIds:["pat_leucemia","pat_linfoma","pat_anemia","pat_sepsis"],isPremium:!0},{id:"pat_celiaquia",nombre:"Enfermedad Celiaca",bodySystemId:"digestivo",definicion:"Enteropatia autoinmune sist\xe9mica desencadenada por la ingestion de gluten (proteina presente en trigo, cebada y centeno) en individuos geneticamente predispuestos, caracterizada por inflamacion cronica de la mucosa del intestino delgado, atrofia vellositaria y malabsorcion de nutrientes, con anticuerpos anti-transglutaminasa tisular positivos.",epidemiologia:"Afecta al 1-2% de la poblacion mundial, con prevalencia de 1:100 en paises occidentales. En Argentina se estima una prevalencia similar aunque con alto subdiagnostico. Es mas frecuente en mujeres (relacion 2:1). Puede debutar a cualquier edad, con dos picos: infancia (6-24 meses) y adultez (30-50 a\xf1os). El 80-90% de los casos permanece sin diagnostico por presentaciones atipicas.",factoresRiesgo:["Predisposicion genetica HLA-DQ2 y HLA-DQ8","Antecedentes familiares de primer grado con celiaqu\xeda","Diabetes mellitus tipo 1 (riesgo 5-10%)","Sindrome de Down (riesgo 5-12%)","Sindrome de Turner","Tiroiditis autoinmune de Hashimoto","Deficit de IgA serica","Introduccion precoz de gluten en la infancia","Infecciones intestinales en la primera infancia","Lactancia materna ausente o de corta duracion"],fisiopatologia:"La ingestion de gluten produce peptidos (gliadinas) que atraviesan el epitelio intestinal y son desamidados por la transglutaminasa tisular (tTG). Estos peptidos se unen a moleculas HLA-DQ2/DQ8 en celulas presentadoras de antigeno, activando linfocitos T CD4+ que liberan interferon-gamma y otras citoquinas proinflamatorias. La respuesta inmune causa da\xf1o epitelial con hiperplasia de criptas, atrofia de vellosidades intestinales (clasificacion de Marsh) y aumento de linfocitos intraepiteliales. La malabsorcion resultante afecta hierro, folatos, calcio, vitamina D, vitamina B12 y acidos grasos esenciales.",signosYSintomas:{signos:["Distension abdominal","Heces voluminosas, palidas y fetidas (esteatorrea)","Perdida de peso","Talla baja en ni\xf1os","Aftas orales recurrentes","Dermatitis herpetiforme (vesiculas pruriginosas en codos, rodillas, gl\xfateos)","Palidez por anemia","Hipoplasia del esmalte dental"],sintomas:["Diarrea cronica (3 o mas deposiciones blandas diarias)","Dolor abdominal tipo colico","Meteorismo y flatulencia excesiva","Fatiga cronica e irritabilidad","Nauseas y vomitos ocasionales","Anorexia (especialmente en ni\xf1os)","Parestesias por deficit de vitamina B12","Artralgias y mialgias","Amenorrea o irregularidades menstruales","Infertilidad o abortos de repeticion","Depresion y ansiedad","Cefalea cronica"]},clasificacion:{nombre:"Clasificacion histologica de Marsh-Oberhuber",tipos:[{nombre:"Marsh 0",descripcion:"Mucosa normal. Sin cambios histologicos."},{nombre:"Marsh 1",descripcion:"Aumento de linfocitos intraepiteliales (> 25 por cada 100 enterocitos). Vellosidades y criptas normales."},{nombre:"Marsh 2",descripcion:"Hiperplasia de criptas con aumento de linfocitos intraepiteliales. Vellosidades conservadas."},{nombre:"Marsh 3a",descripcion:"Atrofia vellositaria leve. Vellosidades acortadas con hiperplasia de criptas."},{nombre:"Marsh 3b",descripcion:"Atrofia vellositaria subtotal. Vellosidades muy acortadas."},{nombre:"Marsh 3c",descripcion:"Atrofia vellositaria total. Mucosa plana, maxima expresion del da\xf1o."}]},diagnostico:{anamnesis:["Tiempo de evolucion de la diarrea cronica y caracteristicas de las heces","Antecedentes familiares de celiaqu\xeda o enfermedades autoinmunes","Relacion de los sintomas con la ingesta de alimentos con gluten","Historia de dermatitis herpetiforme","Antecedentes de abortos espontaneos o infertilidad","Retraso de crecimiento en ni\xf1os","Enfermedades autoinmunes asociadas (DM1, tiroiditis)","Sintomas neurologicos: parestesias, ataxia, cefalea"],examenFisico:["Evaluacion del estado nutricional: peso, talla, IMC","Palpacion abdominal: distension, hipersensibilidad","Inspeccion de piel y mucosas: palidez, dermatitis herpetiforme, aftas","Valoracion de edemas (hipoalbuminemia)","Exploracion musculoesqueletica: artralgias, signos de osteomalacia","En ni\xf1os: curvas de crecimiento y desarrollo puberal"],pruebas:[{nombre:"Anticuerpos anti-transglutaminasa tisular IgA (anti-tTG IgA)",descripcion:"Prueba serologica de primera eleccion. Alta sensibilidad (95%) y especificidad (97%) para celiaqu\xeda en pacientes con ingesta de gluten",valoresReferencia:"Negativo: < 7 U/mL; Positivo: >= 10 U/mL (var\xeda segun laboratorio)",cuidadosEnfermeria:["El paciente NO debe haber iniciado dieta sin gluten antes de la extraccion","Solicitar simultaneamente IgA serica total para descartar deficit de IgA","Muestra de sangre venosa en tubo sin anticoagulante","Informar que un resultado positivo requiere biopsia confirmatoria"]},{nombre:"Anticuerpos anti-endomisio IgA (AEm IgA)",descripcion:"Alta especificidad (> 98%), util como prueba confirmatoria serologica complementaria",valoresReferencia:"Negativo / Positivo (resultado cualitativo por inmunofluorescencia)",cuidadosEnfermeria:["Mantener ingesta de gluten hasta realizarse el estudio","Muestra venosa estandar","Resultado puede demorar 5-7 dias por tecnica de inmunofluorescencia"]},{nombre:"Biopsia duodenal por endoscopia",descripcion:"Gold standard diagnostico. Se toman 4-6 biopsias de duodeno distal y 2 del bulbo duodenal con clasificacion de Marsh",valoresReferencia:"Normal: vellosidades largas, relacion vellosidad/cripta >= 3:1; Patologico: atrofia (Marsh 3a-3c)",cuidadosEnfermeria:["Ayuno de 8 horas previo al procedimiento","Retirar protesis dentales si las tuviera","Canalizar via venosa para sedacion","Vigilar signos vitales post-procedimiento durante 30-60 minutos","Informar que puede haber leve dolor de garganta despues","No iniciar dieta sin gluten antes de la biopsia"]},{nombre:"Hemograma completo",descripcion:"Detecta anemia ferropenica o macroc\xedtica por deficit de hierro, acido folico o vitamina B12 secundarios a malabsorcion",valoresReferencia:"Hb: 12-16 g/dL (mujer), 13-18 g/dL (hombre); VCM: 80-100 fL",cuidadosEnfermeria:["Obtener muestra en ayunas si se solicita perfil completo","Documentar tratamientos previos con hierro o vitaminas","Aplicar presion en sitio de puncion por al menos 2 minutos"]},{nombre:"Perfil bioquimico y vitaminas",descripcion:"Evalua deficiencias nutricionales: hierro serico, ferritina, acido folico, vitamina B12, vitamina D, calcio, albumina",valoresReferencia:"Ferritina: 20-200 ng/mL; B12: 200-900 pg/mL; Vitamina D: 30-100 ng/mL; Albumina: 3.5-5.0 g/dL",cuidadosEnfermeria:["Ayuno de 8-12 horas previo","Registrar suplementacion vitaminica actual","Transportar muestra de vitamina D en tubo de plastica oscuro o protegida de la luz"]},{nombre:"Densitometria osea (DEXA)",descripcion:"Evalua osteopenia u osteoporosis secundaria a malabsorcion cronica de calcio y vitamina D",valoresReferencia:"T-score: Normal > -1.0; Osteopenia -1.0 a -2.5; Osteoporosis < -2.5",cuidadosEnfermeria:["Retirar objetos metalicos antes del estudio","No realizar si hay estudios de contraste recientes (bario)","Registrar altura y peso exactos para interpretacion del informe"]}]},tratamientoMedico:{objetivos:["Eliminar completamente el gluten de la dieta de por vida","Resolver los sintomas digestivos y sistemicos","Recuperar la integridad de la mucosa intestinal","Corregir las deficiencias nutricionales","Prevenir complicaciones a largo plazo (linfoma, osteoporosis)"],farmacologico:[{nombre:"Hierro ferrico / Ferroso",grupo:"Suplemento de hierro oral",mecanismo:"Repone depositos de hierro agotados por malabsorcion cronica. El hierro ferrico (III) se reduce a ferroso (II) en el duodeno para ser absorbido via DMT1",dosis:"Hierro ferroso: 100-200 mg/dia de hierro elemental en 2-3 tomas; Hierro ferrico: 100 mg/dia en dosis unica",cuidadosEnfermeria:["Administrar en ayunas o 1 hora antes de las comidas para mayor absorcion","Si hay intolerancia gastrointestinal, administrar con alimentos (reduce absorcion pero mejora tolerancia)","No administrar con calcio, tetraciclinas, anti\xe1cidos ni te/cafe (quelacion)","Advertir que las heces se volvern oscuras o negras (normal)","Controlar hemograma y ferritina a las 4-8 semanas para evaluar respuesta","Vigilar constipacion (efecto adverso frecuente)"]},{nombre:"Acido folico",grupo:"Vitamina del grupo B (B9)",mecanismo:"Repone folatos deficientes por malabsorcion en yeyuno proximal, esencial para sintesis de DNA y eritropoyesis normal",dosis:"5 mg/dia VO durante 4 meses inicialmente; luego reevaluar segun niveles",cuidadosEnfermeria:["Administrar con o sin alimentos (buena tolerancia gastrointestinal)","Controlar niveles de folato serico a los 3 meses","En mujeres en edad fertil, mantener suplementacion preventiva","No reemplaza la dieta sin gluten como tratamiento principal"]},{nombre:"Vitamina D3 (Colecalciferol)",grupo:"Vitamina liposoluble / Suplemento oseo",mecanismo:"Corrige hipovitaminosis D por malabsorcion de grasas, fundamental para absorcion de calcio intestinal y homeostasis osea",dosis:"Colecalciferol 1000-4000 UI/dia segun niveles sericos; asociar calcio 1000-1500 mg/dia",cuidadosEnfermeria:["Administrar con las comidas (vitamina liposoluble, requiere grasas para absorcion)","Controlar 25-OH vitamina D serico a los 3 meses de iniciado el tratamiento","Vigilar hipercalcemia si dosis altas: nauseas, poliuria, confusion","Asociar siempre con calcio elemental para optima remodelacion osea","Informar al paciente que la exposicion solar moderada colabora con la sintesis de vitamina D"]}],noFarmacologico:["Dieta estrictamente sin gluten de por vida (trigo, cebada, centeno y todos sus derivados)","Leer etiquetas de todos los alimentos procesados (gluten oculto en salsas, embutidos, medicamentos)","Usar utensilios y superficies exclusivos para preparacion de alimentos sin gluten (evitar contaminacion cruzada)","Consumir avena certificada sin gluten en cantidades moderadas si es tolerada","Alimentos naturalmente libres de gluten: arroz, maiz, papa, mandioca, legumbres, carnes, frutas y verduras","Seguimiento con nutricionista especializada en celiaqu\xeda","Apoyo psicologico para adaptacion al cambio dietario cronico","Educacion familiar para garantizar dieta sin gluten en el hogar"]},cuidadosEnfermeria:{valoracion:["Evaluar caracteristicas de las deposiciones: frecuencia, consistencia, presencia de esteatorrea","Registrar peso y evaluar estado nutricional (IMC, circunferencia de brazo)","Valorar sintomas asociados: dolor abdominal, distension, fatiga","Indagar adherencia a la dieta sin gluten","Evaluar piel y mucosas: palidez, dermatitis herpetiforme, aftas","Identificar deficit de conocimiento sobre la enfermedad y la dieta","En ni\xf1os: valorar curva de crecimiento y desarrollo"],intervenciones:["Educar al paciente y familia sobre la dieta estrictamente sin gluten","Coordinar interconsulta con nutricionista especialista en celiaqu\xeda","Administrar suplementos vitam\xednicos y minerales segun prescripcion","Controlar y registrar peso semanalmente durante la fase aguda","Vigilar balance hidrico en casos de diarrea severa","Brindar apoyo emocional ante el impacto del diagnostico de enfermedad cronica","Conectar al paciente con grupos de soporte de celiaqu\xeda (ACELA en Argentina)"],educacionPaciente:["Explicar que la celiaqu\xeda es una condicion de por vida y que la unica terapia es la dieta sin gluten","Ensenar a identificar gluten oculto en etiquetas de alimentos, medicamentos y cosmeticos","Explicar la contaminacion cruzada y como evitarla en el hogar y restaurantes","Informar sobre la importancia del control serologico periodico (anti-tTG) para evaluar adherencia","Educar sobre complicaciones del incumplimiento: riesgo de linfoma intestinal, osteoporosis","Ense\xf1ar a comunicar el diagnostico en entornos sociales (restaurantes, reuniones)","Instruir sobre lectura obligatoria de etiquetas: buscar leyenda 'Sin TACC'"],monitorizacion:["Anti-tTG IgA cada 6 meses el primer a\xf1o de dieta sin gluten, luego anual","Hemograma y perfil de hierro cada 3-6 meses hasta normalizacion","Vitamina D y calcio serico a los 3 y 6 meses","Densitometria osea al diagnostico y cada 2 a\xf1os en osteopenia","Peso semanal durante recuperacion nutricional","Biopsia duodenal de control a los 12-24 meses para verificar recuperacion de vellosidades"]},npiNanda:[{codigo:"00002",nombre:"Nutricion desequilibrada: inferior a las necesidades corporales",definicion:"Ingesta de nutrientes insuficiente para satisfacer las necesidades metabolicas, secundaria a malabsorcion intestinal por da\xf1o de la mucosa celiaca",caracteristicasDefinitorias:["Perdida de peso involuntaria","Diarrea cronica con esteatorrea","Debilidad y fatiga","Valores de albumina, ferritina, vitamina D y folatos disminuidos"],factoresRelacionados:["Malabsorcion por atrofia vellositaria intestinal","Diarrea cronica","Conocimiento insuficiente sobre la dieta sin gluten","Acceso limitado a alimentos sin gluten"]},{codigo:"00011",nombre:"Estre\xf1imiento / Diarrea",definicion:"Cambio en el patron de eliminacion intestinal caracterizado por deposiciones frecuentes, blandas o liquidas con contenido graso, asociado a malabsorcion celiaca",caracteristicasDefinitorias:["Mas de 3 deposiciones blandas o liquidas por dia","Heces voluminosas, palidas y fetidas","Distension abdominal y dolor colico","Urgencia fecal"],factoresRelacionados:["Atrofia vellositaria con malabsorcion de grasas e hidratos","Hipermotilidad intestinal","Ingestion inadvertida de gluten"]},{codigo:"00126",nombre:"Conocimiento deficiente",definicion:"Ausencia o deficiencia de informacion cognitiva relacionada con la dieta sin gluten, identificacion de fuentes ocultas de gluten y manejo de la enfermedad celiaca",caracteristicasDefinitorias:["Verbaliza desconocimiento sobre alimentos permitidos y prohibidos","Incumplimiento inadvertido de la dieta sin gluten","Interrogantes sobre etiquetado de alimentos"],factoresRelacionados:["Diagnostico reciente de celiaqu\xeda","Complejidad del regimen dietetico","Falta de acceso a informacion clara y confiable"]}],npiNic:[{codigo:"1100",nombre:"Manejo de la nutricion",actividades:["Realizar evaluacion nutricional completa al ingreso","Planificar menu sin gluten en coordinacion con nutricionista","Verificar que todos los alimentos hospitalarios sean libres de gluten","Administrar suplementos de hierro, folatos y vitamina D segun prescripcion","Registrar ingesta alimentaria diaria y tolerancia"]},{codigo:"5614",nombre:"Ensenanza: dieta prescrita",actividades:["Explicar el fundamento de la dieta sin gluten como unico tratamiento","Proporcionar lista escrita de alimentos permitidos y prohibidos","Ensenar a leer etiquetas nutricionales e identificar 'Sin TACC'","Educar sobre contaminacion cruzada en cocina y restaurantes","Conectar con asociacion celiaca local para recursos y apoyo"]},{codigo:"0430",nombre:"Manejo intestinal",actividades:["Registrar frecuencia, caracteristicas y consistencia de las deposiciones","Mantener adecuada hidratacion oral o parenteral segun necesidad","Evaluar dolor abdominal y distension mediante escala numerica","Informar cambios significativos en patron intestinal al equipo medico"]}],npiNoc:[{codigo:"1004",nombre:"Estado nutricional",indicadores:["Peso corporal estable o en aumento progresivo","Albumina serica en rango normal (3.5-5.0 g/dL)","Ausencia de diarrea o esteatorrea","Niveles de vitaminas y minerales en rango normal"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"},{codigo:"1814",nombre:"Conocimiento: dieta prescrita",indicadores:["Identifica alimentos con gluten que debe evitar","Demuestra lectura correcta de etiquetas nutricionales","Describe estrategias para evitar contaminacion cruzada","Verbaliza importancia del cumplimiento de por vida"],escala:"1=Ningun conocimiento, 2=Conocimiento escaso, 3=Conocimiento moderado, 4=Conocimiento sustancial, 5=Conocimiento extenso"},{codigo:"0501",nombre:"Eliminacion intestinal",indicadores:["Frecuencia de deposiciones dentro de patron normal (1-3/dia)","Consistencia de heces formada","Ausencia de dolor abdominal colico","Ausencia de esteatorrea"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"}],complicaciones:["Linfoma de celulas T asociado a enteropatia (EATL) en adultos con celiaqu\xeda no tratada","Osteoporosis y fracturas patologicas por malabsorcion de calcio y vitamina D","Infertilidad y abortos espontaneos de repeticion","Neuropatia celiaca (ataxia por gluten, neuropatia periferica)","Anemia ferropenica o megaloblastica refractaria al tratamiento oral","Yeyunitis ulcerativa (complicacion rara pero grave)","Adenocarcinoma de intestino delgado (raro)","Esprue refractario tipo I y II (no responde a dieta sin gluten)"],criteriosAlarma:["Perdida de peso mayor al 10% del peso habitual en 3 meses","Sangre en heces (melena o hematoquecia)","Diarrea severa con signos de deshidratacion","Dolor abdominal intenso de inicio subito","Fiebre persistente sin foco claro","Distension abdominal progresiva con semiologia de obstruccion","Sintomas neurologicos: ataxia de inicio subito, convulsiones","No respuesta a la dieta sin gluten estricta tras 6-12 meses (sospechar esprue refractario)"],emergencyLevel:"leve",relatedPathologyIds:["pat_dm1","pat_anemia_ferropenica","pat_osteoporosis","pat_hashimoto","pat_sii"],isPremium:!0},{id:"pat_trombofilia",nombre:"Trombofilia",bodySystemId:"hematologico",definicion:"Estado de hipercoagulabilidad hereditario o adquirido que predispone al desarrollo de eventos tromboticos venosos o arteriales recurrentes. Las trombofilias hereditarias incluyen mutaciones en factores de la coagulacion (Factor V Leiden, mutacion del gen de protrombina G20210A) y deficiencias de inhibidores naturales (proteina C, proteina S, antitrombina III). Las adquiridas incluyen el sindrome antifosfolipidico (SAF).",epidemiologia:"El Factor V Leiden es la trombofilia hereditaria mas frecuente: prevalencia del 3-8% en poblacion caucasica, responsable del 20-25% de los casos de TVP. La mutacion del gen de protrombina G20210A afecta al 1-4% de la poblacion general. El deficit de antitrombina III es mas raro (0.02-0.2%) pero el de mayor riesgo trombotico. El sindrome antifosfolipidico afecta al 1-5% de la poblacion y al 15-20% de los jovenes con primer episodio de TVP. La trombosis venosa profunda ocurre en 1-2 por 1000 personas/ano en la poblacion general, aumentando significativamente en trombofilias.",factoresRiesgo:["Factor V Leiden (mutacion R506Q en el gen F5)","Mutacion protrombina G20210A","Deficit de proteina C (hereditario o adquirido)","Deficit de proteina S","Deficit de antitrombina III","Sindrome antifosfolipidico (anticuerpos anticardiolipina, anti-beta2 glicoproteina I, anticoagulante lupico)","Embarazo y puerperio","Anticonceptivos orales con estrogenos","Terapia hormonal de reemplazo","Inmovilizacion prolongada (cirugia, hospitalizacion, viajes largos)","Neoplasias malignas activas","Obesidad (IMC > 30)","Tabaquismo","Hiperhomocisteinemia","Enfermedad inflamatoria intestinal","Sindrome nefrotico","Policitemia vera y otras neoplasias mieloproliferativas"],fisiopatologia:"La triada de Virchow describe los tres mecanismos de trombogenesis: estasis sanguineo, lesion endotelial e hipercoagulabilidad. En las trombofilias hereditarias, el desequilibrio entre factores procoagulantes e inhibidores naturales favorece la formacion de trombos. El Factor V Leiden es resistente a la degradacion por la proteina C activada, perpetuando la generacion de trombina. La mutacion de protrombina G20210A aumenta los niveles plasmaticos de protrombina, elevando la generacion de trombina. Los deficits de proteina C, proteina S y antitrombina III eliminan mecanismos clave de frenado de la coagulacion. En el SAF, los anticuerpos antifosfolipidos activan plaquetas, celulas endoteliales y el complemento, generando un estado protrombogenico tanto venoso como arterial. Los trombos venosos se forman preferentemente en el sistema venoso profundo de miembros inferiores y pueden embolizar hacia la circulacion pulmonar (tromboembolismo pulmonar).",signosYSintomas:{signos:["Edema unilateral de miembro inferior (TVP)","Eritema y calor local en zona de TVP","Signo de Homans positivo (dolor a la dorsiflexion del pie, poco especifico)","Circulacion colateral venosa superficial visible","Taquicardia e hipoxemia en TEP","Signos de hipertension pulmonar en TEP masivo (ingurgitacion yugular, hipotension)","Livedo reticularis en sindrome antifosfolipidico","Necrosis cutanea por trombosis microvascular"],sintomas:["Dolor sordo o pesadez en miembro inferior afectado (TVP)","Disnea de inicio brusco (TEP)","Dolor pleuritico (TEP con infarto pulmonar)","Hemoptisis (TEP con infarto pulmonar)","Cefalea intensa o sintomas neurologicos focales (trombosis venosa cerebral)","Dolor abdominal intenso (trombosis mesent\xe9rica o portal)","Abortos espontaneos de repeticion en primer trimestre o perdida fetal tardia (SAF obstetrico)","Historia de trombosis sin factores de riesgo aparentes en jovenes","Trombosis en sitios inusuales: sinusoides hepaticos, venas cerebrales, mesent\xe9ricas"]},clasificacion:{nombre:"Clasificacion segun mecanismo y origen",tipos:[{nombre:"Trombofilia hereditaria de alto riesgo",descripcion:"Deficit de antitrombina III, deficit de proteina C o proteina S, Factor V Leiden homocigoto, doble heterocigoto Factor V Leiden + mutacion protrombina. Riesgo trombotico anual > 10%."},{nombre:"Trombofilia hereditaria de bajo-moderado riesgo",descripcion:"Factor V Leiden heterocigoto, mutacion protrombina G20210A heterocigota. Riesgo trombotico aumentado 3-8 veces respecto a la poblacion general."},{nombre:"Sindrome antifosfolipidico (SAF)",descripcion:"Trombofilia adquirida autoinmune. Criterios de clasificacion de Sapporo: trombosis o morbilidad obstetrica + anticuerpos antifosfolipidos positivos en 2 determinaciones con 12 semanas de intervalo."},{nombre:"Trombofilia adquirida no inmune",descripcion:"Neoplasias malignas activas, embarazo, sindrome nefrotico, policitemia vera, hiperhomocisteinemia, uso de estrogenos."},{nombre:"Trombofilia combinada",descripcion:"Coexistencia de mas de un defecto trombofilico, hereditario y/o adquirido. Mayor riesgo trombotico acumulativo."}]},diagnostico:{anamnesis:["Historia de episodios tromboticos previos: numero, localizacion, edad de primer evento","Antecedentes familiares de TVP, TEP o abortos de repeticion","Factores desencadenantes del evento trombotico (cirugia, inmovilizacion, viaje, embarazo)","Historia obstetrica: abortos espontaneos, perdidas fetales, preeclampsia severa, RCIU","Medicacion actual: anticonceptivos orales, TRH, heparina","Enfermedades asociadas: lupus, neoplasias, sindrome nefrotico","Etnia (Factor V Leiden mas prevalente en caucasicos)"],examenFisico:["Examen de miembros inferiores: edema, calor, eritema, signo de Homans","Auscultacion cardiopulmonar: taquicardia, frote pleural en TEP","Inspeccion de piel: livedo reticularis, necrosis cutanea, ulceras venosas cronicas","Palpacion abdominal: hepatomegalia en trombosis portal, circulacion colateral abdominal","Valoracion neurologica si hay sospecha de trombosis venosa cerebral"],pruebas:[{nombre:"Estudio de trombofilia hereditaria (panel completo)",descripcion:"Incluye: mutacion Factor V Leiden (PCR), mutacion protrombina G20210A (PCR), actividad de proteina C, actividad de proteina S libre, actividad de antitrombina III, resistencia a la proteina C activada",valoresReferencia:"Proteina C: 70-140%; Proteina S libre: 60-130% (H), 55-120% (M premenopausia); Antitrombina III: 80-120%; Resistencia a PCA: ratio > 2.0 normal",cuidadosEnfermeria:["El estudio NUNCA debe realizarse durante el evento trombotico agudo (resultados falseados)","Suspender anticoagulacion oral (warfarina) al menos 2-4 semanas antes (reduce proteina C y S)","Suspender heparina al menos 24h antes para antitrombina III","Realizar en estado estable, al menos 3 meses despues del evento trombotico agudo","Muestra citratada (tubo celeste) para actividades funcionales","Las mutaciones geneticas pueden medirse en cualquier momento (no se ven afectadas por anticoagulacion)"]},{nombre:"Anticuerpos antifosfolipidos (SAF)",descripcion:"Triple panel: anticoagulante lupico (AL), anticuerpos anticardiolipina IgG e IgM (aCL), anticuerpos anti-beta2 glicoproteina I IgG e IgM (anti-b2GPI). Deben ser positivos en 2 determinaciones con al menos 12 semanas de intervalo",valoresReferencia:"AL: negativo (positivo indica SAF); aCL IgG/IgM: < 40 GPL/MPL; anti-b2GPI: < 20 U/mL",cuidadosEnfermeria:["Repetir la determinacion a las 12 semanas para confirmar positividad persistente","El anticoagulante lupico puede verse afectado por la anticoagulacion: comunicar al laboratorio el tratamiento actual","Muestra procesada rapidamente (centrifugacion dentro de 1-2h de la extraccion)","Registrar en la orden si el paciente esta anticoagulado (interfiere con algunas tecnicas)"]},{nombre:"Dimero-D",descripcion:"Producto de degradacion de la fibrina. Muy sensible (> 95%) pero poco especifico para TVP/TEP. Util para DESCARTAR trombosis (valor negativo tiene alto valor predictivo negativo)",valoresReferencia:"Normal: < 500 mcg/L (0.5 mg/L). En mayores de 50 a\xf1os usar formula: edad x 10 mcg/L como limite",cuidadosEnfermeria:["Resultado NEGATIVO con baja probabilidad clinica descarta TVP/TEP sin necesidad de imagen","Resultado positivo NO confirma trombosis (elevado en infeccion, inflamacion, embarazo, cirugia)","Muestra de sangre venosa en tubo con citrato o EDTA segun protocolo del laboratorio","Resultado urgente en sospecha de TEP: solicitar procesamiento prioritario"]},{nombre:"Eco-Doppler venoso de miembros inferiores",descripcion:"Estudio de imagen de primera eleccion para diagnostico de TVP. Evalua compresibilidad venosa, flujo y presencia de trombo. Alta sensibilidad (95%) y especificidad (98%) para TVP proximal",valoresReferencia:"Normal: venas compresibles con flujo bifasico espontaneo. Patologico: falta de compresibilidad, ausencia de flujo, visualizacion de trombo ecogenico",cuidadosEnfermeria:["No requiere preparacion especial ni ayuno","Posicionar el miembro inferior con leve elevacion si hay edema intenso","Coordinar estudio urgente si hay alta sospecha de TVP proximal o TEP concomitante","Si el estudio es negativo pero la sospecha clinica es alta, repetir a los 5-7 dias"]},{nombre:"Angiotomografia computada de torax (AngioTC pulmonar)",descripcion:"Gold standard para diagnostico de tromboembolismo pulmonar. Detecta trombos desde arterias pulmonares principales hasta ramas subsegmentarias",valoresReferencia:"Normal: sin defectos de relleno en arterias pulmonares. Patologico: defecto de relleno intraluminal (trombo)",cuidadosEnfermeria:["Verificar funcion renal antes del contraste (creatinina < 1.5 mg/dL)","Verificar alergias a medios de contraste yodado","Canalizar acceso venoso de alto flujo (al menos 18G) para inyeccion rapida de contraste","Advertir sobre sensacion de calor y urgencia miccional transitoria durante la inyeccion","Si la situacion clinica lo permite, realizar sin demora en TEP de alto riesgo"]}]},tratamientoMedico:{objetivos:["Tratar el episodio trombotico agudo con anticoagulacion efectiva","Prevenir la recurrencia con anticoagulacion extendida segun perfil de riesgo","Prevenir el sindrome postrombotico","Identificar y corregir factores de riesgo adquiridos modificables","Profilaxis antitromb\xf3tica en situaciones de alto riesgo (cirugia, embarazo)"],farmacologico:[{nombre:"Rivaroxaban (o Apixaban)",grupo:"Anticoagulante oral directo (ACOD) - Inhibidor directo del factor Xa",mecanismo:"Inhibe directamente el factor Xa, bloqueando la conversion de protrombina a trombina y la formacion de coagulo de fibrina. Sin necesidad de monitoreo de INR",dosis:"Rivaroxaban para TVP/TEP: 15 mg c/12h x 21 dias, luego 20 mg/dia. Apixaban: 10 mg c/12h x 7 dias, luego 5 mg c/12h",cuidadosEnfermeria:["Administrar rivaroxaban con alimentos (mejora absorcion del 20 mg); apixaban puede tomarse con o sin comidas","NO requiere monitoreo rutinario de INR","Vigilar signos de sangrado: hematomas, melena, hematuria, sangrado gingival, hemoptisis","CONTRAINDICADO en embarazo (usar heparina de bajo peso molecular en gestantes)","Verificar funcion renal: contraindicado si clearance de creatinina < 15 mL/min","Suspender 24-48h antes de procedimientos invasivos","Antidoto de rivaroxaban: Andexanet alfa (si disponible)"]},{nombre:"Heparina de bajo peso molecular (HBPM) - Enoxaparina",grupo:"Anticoagulante parenteral - Inhibidor indirecto del factor Xa y IIa",mecanismo:"Potencia la accion de la antitrombina III, inhibiendo principalmente el factor Xa (y en menor medida la trombina/IIa), inhibiendo la amplificacion de la cascada de coagulacion",dosis:"Terapeutica TVP/TEP: Enoxaparina 1 mg/kg SC c/12h o 1.5 mg/kg SC c/24h. Profilactica: 40 mg SC/dia (o 20 mg/dia en riesgo bajo)",cuidadosEnfermeria:["Administrar SC en area periumbilical, alternando lados; introducir aguja en 90\xb0 (pliegue cutaneo en piel delgada)","NO frotar el sitio de inyeccion despues de administrar (aumenta hematoma local)","Rotar sistematicamente los sitios de inyeccion para evitar lipohipertrofia","Monitorizar recuento plaquetario a los 5-10 dias (sospechar TIH: trombocitopenia inducida por heparina)","En insuficiencia renal severa (CrCl < 30 mL/min): ajustar dosis o usar heparina no fraccionada","Antidoto: sulfato de protamina (revierte 60-70% del efecto anti-Xa)"]},{nombre:"Warfarina",grupo:"Anticoagulante oral - Antagonista de vitamina K (AVK)",mecanismo:"Inhibe la vitamina K epoxido reductasa, bloqueando la carboxilacion de los factores dependientes de vitamina K (II, VII, IX, X, proteina C y S). Efecto anticoagulante indirecto con inicio retardado (2-5 dias)",dosis:"Iniciar con 5 mg/dia VO, ajustar segun INR objetivo (generalmente 2.0-3.0). En valvulas mecanicas o SAF de alto riesgo: INR 2.5-3.5",cuidadosEnfermeria:["Monitorizar INR regularmente: al inicio cada 2-3 dias hasta estabilizacion, luego mensual","Educar sobre alimentos ricos en vitamina K que reducen el efecto (verduras de hoja verde: espinaca, brocoli, repollo): no prohibir, pero mantener consumo constante","Registrar todos los medicamentos que interactuan (aumentan INR: antibioticos, AINEs, amiodarona; disminuyen: rifampicina, antiepil\xe9pticos)","Vigilar signos de sobreanticoagulacion (INR > 4): sangrado espontaneo, hematuria, melena","Antidoto: vitamina K1 oral (1-5 mg) o IV en emergencia; plasma fresco congelado en sangrado grave","CONTRAINDICADO en embarazo primer y tercer trimestre (teratogenico)"]}],noFarmacologico:["Medias de compresion graduada (30-40 mmHg) para prevencion del sindrome postrombotico","Deambulacion precoz tras TVP (no reposo absoluto, contrario a creencia antigua)","Evitar factores de riesgo modificables: sedentarismo, tabaquismo, obesidad","Suspension de anticonceptivos orales con estrogenos y evaluacion de alternativas","Hidratacion adecuada en viajes largos y movilizacion periodica (ejercicios de piernas)","Educacion sobre profilaxis en situaciones de riesgo (vuelos largos, hospitalizacion)","Uso de medias de compresion durante vuelos mayores a 4 horas","Evaluacion genetica familiar en trombofilias hereditarias de alto riesgo"]},cuidadosEnfermeria:{valoracion:["Evaluar miembros inferiores: edema, calor, eritema, dolor a la palpacion","Monitorizar signos vitales con especial atencion a taquicardia e hipoxemia (sospecha TEP)","Valorar intensidad del dolor con escala numerica (0-10)","Revisar historia trombotica personal y familiar","Identificar factores de riesgo adquiridos activos (inmovilizacion, neoplasia, embarazo)","Evaluar conocimiento sobre anticoagulacion y riesgo de sangrado"],intervenciones:["Administrar anticoagulacion segun prescripcion (HBPM SC o ACOD oral) con tecnica correcta","Colocar medias de compresion graduada en miembro afectado","Elevar miembro inferior 20-30\xb0 para reducir edema","Fomentar deambulacion precoz bajo indicacion medica","Vigilar sitios de puncion y signos de sangrado activo en pacientes anticoagulados","Monitorizar INR en pacientes con warfarina o anti-Xa en indicaciones especiales","Coordinar estudio de imagen urgente ante sospecha de TEP"],educacionPaciente:["Explicar la necesidad de anticoagulacion y su duracion (generalmente 3-12 meses o indefinida segun causa)","Ensenar signos de alarma de sangrado: hematoma extenso, orina rojiza, heces negras, hemoptisis","Ense\xf1ar tecnica correcta de autoinyeccion de HBPM si es indicada ambulatoriamente","Instruir sobre interacciones de warfarina con alimentos y medicamentos","Indicar no automedicarse con AINEs ni aspirina sin consulta medica (aumenta riesgo de sangrado)","Informar que debe comunicar el tratamiento anticoagulante a todo profesional de salud antes de cualquier procedimiento","Educar sobre uso correcto de medias de compresion: colocarlas al levantarse antes de caminar"],monitorizacion:["INR cada 2-3 dias al inicio de warfarina hasta INR estable en rango terapeutico, luego mensual","Hemograma: recuento plaquetario al inicio y a los 5-10 dias con HBPM (vigilar TIH)","Dimero-D y eco-Doppler de control a los 3 meses de tratamiento","Control de funcion renal cada 6 meses en pacientes con ACOD","Estudio de trombofilia completo a los 3 meses del evento agudo (fuera de anticoagulacion para estudios funcionales)","Vigilancia de signos y sintomas de TEP durante la evolucion aguda de TVP"]},npiNanda:[{codigo:"00291",nombre:"Riesgo de trombosis venosa profunda",definicion:"Vulnerable a la formacion de un coagulo de sangre en una o mas venas profundas, generalmente en las piernas, que puede comprometer la salud, asociado a estado de hipercoagulabilidad hereditario o adquirido",caracteristicasDefinitorias:["Historia de episodios tromboticos previos","Estudio de trombofilia positivo (Factor V Leiden, SAF, deficit de inhibidores)","Presencia de factores de riesgo adquiridos activos"],factoresRelacionados:["Mutacion Factor V Leiden o protrombina G20210A","Deficit de proteina C, S o antitrombina III","Anticuerpos antifosfolipidos positivos (SAF)","Inmovilizacion prolongada","Embarazo o uso de anticonceptivos estrogenicos"]},{codigo:"00004",nombre:"Riesgo de infeccion / Riesgo de sangrado",definicion:"Vulnerable a una disminucion del volumen sanguineo que puede comprometer la salud, en el contexto del uso de medicamentos anticoagulantes para el tratamiento y prevencion de eventos tromboticos",caracteristicasDefinitorias:["Recibe tratamiento anticoagulante (HBPM, ACOD, warfarina)","INR supraterapeutico (> 3.5)","Hematuria, melena o hematoma espontaneo"],factoresRelacionados:["Tratamiento anticoagulante","Interacciones farmacologicas con anticoagulantes orales","Incumplimiento del monitoreo de INR","Insuficiencia renal que potencia efecto de ACOD"]},{codigo:"00146",nombre:"Ansiedad",definicion:"Sensacion vaga e inquietante de malestar o amenaza acompanada de respuesta autonoma ante el diagnostico de trombofilia, la necesidad de anticoagulacion cronica y el riesgo de recurrencia trombotica",caracteristicasDefinitorias:["Verbaliza preocupacion por el riesgo de nuevos episodios tromboticos","Miedo a complicaciones hemorragicas de la anticoagulacion","Inquietud ante la enfermedad cronica y sus restricciones"],factoresRelacionados:["Diagnostico de enfermedad trombofilica cronica","Historia de episodios tromboticos potencialmente fatales","Incertidumbre sobre la duracion del tratamiento anticoagulante","Impacto en planes reproductivos (SAF obstetrico)"]}],npiNic:[{codigo:"4110",nombre:"Prevencion de trombosis venosa profunda",actividades:["Aplicar medias de compresion graduada desde el inicio de la hospitalizacion","Fomentar deambulacion precoz y ejercicios activos de miembros inferiores","Administrar profilaxis con HBPM segun indicacion medica en pacientes de riesgo","Mantener adecuada hidratacion para reducir la viscosidad sanguinea","Evaluar diariamente miembros inferiores en busca de signos de TVP"]},{codigo:"4040",nombre:"Cuidados cardiacos",actividades:["Monitorizar frecuencia cardiaca, saturacion de O2 y PA en sospecha de TEP","Preparar para angioTC pulmonar urgente ante deterioro hemodinamico","Administrar anticoagulacion terapeutica segun prescripcion sin demora","Mantener via venosa periferica de alto flujo ante riesgo de TEP masivo","Registrar y reportar inmediatamente taquicardia sinusal nueva o hipoxemia"]},{codigo:"2314",nombre:"Administracion de medicacion: intravenosa/subcutanea",actividades:["Administrar HBPM SC con tecnica correcta: pliegue cutaneo, aguja 90\xb0, no frotar","Rotar sistematicamente los sitios de inyeccion subcutanea","Verificar dosis segun peso corporal actual del paciente","Monitorizar plaquetas a los 5-10 dias de inicio de HBPM (TIH)","Tener disponible el antidoto (protamina para HBPM, vitamina K para warfarina) en la unidad"]}],npiNoc:[{codigo:"0413",nombre:"Severidad de la perdida de sangre",indicadores:["Ausencia de hematuria macroscopica","Ausencia de melena o rectorragia","Presion arterial estable","INR dentro del rango terapeutico objetivo"],escala:"1=Grave, 2=Sustancial, 3=Moderada, 4=Leve, 5=Ninguna"},{codigo:"0204",nombre:"Consecuencias de la inmovilidad: fisiologicas",indicadores:["Ausencia de nuevos episodios de TVP durante la hospitalizacion","Deambulacion precoz sin complicaciones","Edema de miembros inferiores disminuido","Saturacion de oxigeno > 94% en reposo"],escala:"1=Grave, 2=Sustancial, 3=Moderada, 4=Leve, 5=Ninguna"},{codigo:"1902",nombre:"Control del riesgo",indicadores:["Identifica sus factores de riesgo trombotico personales","Describe correctamente como y cuando tomar su anticoagulante","Reconoce signos de alarma de TVP/TEP y sangrado","Asiste regularmente a controles de INR o funcion renal"],escala:"1=Nunca demostrado, 2=Raramente demostrado, 3=A veces demostrado, 4=Frecuentemente demostrado, 5=Constantemente demostrado"}],complicaciones:["Tromboembolismo pulmonar (TEP): complicacion aguda mas grave, potencialmente fatal","Sindrome postrombotico: edema cronico, dolor, ulceras venosas por insuficiencia venosa cronica post-TVP","Hipertension pulmonar tromboembolica cronica (HPTEC) por TEP no resuelto","Trombosis venosa cerebral: hipertension endocraneana, deficit neurologico focal, convulsiones","Trombosis splancnica: trombosis portal, mesent\xe9rica o hepatica con isquemia intestinal","Sindrome de Budd-Chiari (trombosis de venas hepaticas)","Abortos de repeticion y complicaciones obstetricosas en SAF (preeclampsia severa, RCIU, perdida fetal)","Sangrado mayor por anticoagulacion (intracraneal, gastrointestinal)","Trombocitopenia inducida por heparina (TIH) con trombosis paradojal"],criteriosAlarma:["Disnea subita, taquicardia e hipoxemia (sospecha de TEP: requiere angioTC urgente)","Hipotension severa con signos de cor pulmonale agudo (TEP masivo: emergencia vital)","Cefalea intensa, vision borrosa, vomitos, deficit neurologico focal (trombosis venosa cerebral)","Dolor abdominal intenso con nauseas (trombosis mesent\xe9rica o sindrome de Budd-Chiari)","Sangrado activo no controlable en paciente anticoagulado (revertir anticoagulacion urgente)","INR > 8 o INR terapeutico con sangrado activo","Dolor isquemico en miembro con signos de isquemia arterial aguda (embolia paradojal)","Flegmasia cerulea dolens (TVP masiva con edema total del miembro: emergencia vascular)"],emergencyLevel:"moderado",relatedPathologyIds:["pat_tvp","pat_tep","pat_saf","pat_lupus","pat_neoplasias"],isPremium:!0},{id:"pat_hemotorax",nombre:"Hemotorax",bodySystemId:"respiratorio",definicion:"Acumulacion de sangre en la cavidad pleural, generalmente secundaria a traumatismo toracico, cirugia o complicacion de patologia vascular, que compromete la expansion pulmonar y puede generar inestabilidad hemodinamica severa.",epidemiologia:"Se presenta en el 25-75% de los traumatismos toracicos cerrados y penetrantes. Es una de las emergencias toracicas mas frecuentes en servicios de urgencias. El hemotorax masivo (> 1500 mL) representa el 20% de los casos y tiene una mortalidad del 5-10% si no se trata rapidamente.",factoresRiesgo:["Traumatismo toracico cerrado (accidentes de transito, caidas)","Heridas penetrantes (arma blanca, arma de fuego)","Procedimientos invasivos (colocacion de via central, toracocentesis)","Cirugia toracica o cardiovascular","Anticoagulacion","Neoplasias pleurales o pulmonares","Diseccion aortica","Coagulopatias","Malformaciones arteriovenosas pulmonares"],fisiopatologia:"La sangre acumulada en el espacio pleural comprime el pulmon ipsilateral, reduciendo la superficie de intercambio gaseoso y causando atelectasia. La perdida de volumen sanguineo genera hipovolemia y puede derivar en shock hipovolemico. Si el hemotorax no es drenado, la sangre coagula en 24-48 horas formando un hemotorax coagulado que dificulta la reexpansion pulmonar y puede infectarse, evolucionando a empiema o fibrotorax. La complicacion mas grave es el hemotorax masivo que desplaza el mediastino comprometiendo el retorno venoso.",signosYSintomas:{signos:["Matidez a la percusion en hemitorax afectado","Disminucion o abolicion del murmullo vesicular unilateral","Hipotension arterial (PAS < 90 mmHg en hemotorax masivo)","Taquicardia compensadora","Taquipnea (FR > 25 rpm)","Desviacion traqueal contralateral en hemotorax masivo","Ingurgitacion yugular si hay componente compresivo","Disminucion de la expansion toracica ipsilateral","Cianosis en casos graves"],sintomas:["Disnea progresiva o brusca","Dolor toracico ipsilateral","Sensacion de ahogo","Ansiedad e inquietud","Debilidad generalizada","Mareos o sincope por hipovolemia","Sed intensa en casos de hemorragia activa"]},clasificacion:{nombre:"Clasificacion por volumen de sangre acumulada",tipos:[{nombre:"Hemotorax minimo",descripcion:"< 300 mL. Puede ser asintomatico, detectable solo por Rx o ecografia"},{nombre:"Hemotorax moderado",descripcion:"300-1500 mL. Disnea moderada, matidez basal, hipotension leve"},{nombre:"Hemotorax masivo",descripcion:"> 1500 mL o > 1/3 del volumen sanguineo. Shock hipovolemico, emergencia vital inmediata"},{nombre:"Hemotorax coagulado",descripcion:"Sangre coagulada en espacio pleural. Riesgo de fibrotorax y empiema si no se drena"}]},diagnostico:{anamnesis:["Mecanismo de trauma (cerrado vs penetrante, energia involucrada)","Tiempo de evolucion desde el evento","Antecedentes de anticoagulacion o coagulopatia","Procedimientos invasivos recientes","Antecedentes oncologicos o vasculares","Medicacion habitual"],examenFisico:["Inspeccion: asimetria toracica, heridas, equimosis","Palpacion: crepitacion osea, enfisema subcutaneo","Percusion: matidez en hemitorax afectado","Auscultacion: ausencia o reduccion del murmullo vesicular","Signos vitales completos: PA, FC, FR, SatO2, temperatura","Evaluacion del estado hemodinamico (AVPU, relleno capilar)","Inspection de venas del cuello (distension vs colapsadas)"],pruebas:[{nombre:"Radiografia de torax (Rx torax)",descripcion:"Primera imagen en urgencias. Identifica opacidad homogenea con borramiento de seno costofrenico. Sensibilidad 40-70% para peque\xf1os hemotorax en proyeccion AP supina",valoresReferencia:"Opacidad basal > 200 mL es detectable; desplazamiento mediastinico en masivos",cuidadosEnfermeria:["Inmovilizar columna cervical si hay trauma hasta descartar lesion","Retirar objetos metalicos del torax","Posicionar en decubito supino si es AP urgente","Registrar hora de la placa para seguimiento"]},{nombre:"Ecografia FAST (Focused Assessment with Sonography in Trauma)",descripcion:"Metodo de eleccion en urgencias para detectar liquido pleural. Sensibilidad > 90% para hemotorax. Identifica la zona de transicion pleural (signo de la columna vertebral, seno costofrenico)",valoresReferencia:"Presencia de imagen anecoica en espacio pleural indica liquido patologico",cuidadosEnfermeria:["Preparar gel y sonda convex o linear segun protocolo","Posicionar al paciente segun indicacion medica","Asistir en la interpretacion documentando hallazgos","Garantizar acceso venoso durante el procedimiento"]},{nombre:"Tomografia computada de torax (TAC)",descripcion:"Gold standard para cuantificacion y localizacion. Diferencia hemotorax de derrame pleural simple (UH 35-70 en sangre fresca). Identifica lesiones asociadas",valoresReferencia:"Densidad de Hounsfield: hemotorax agudo 35-70 UH; agua 0 UH; pus 0-15 UH",cuidadosEnfermeria:["Verificar alergias al contraste yodado","Canalizar via venosa permeable de calibre adecuado (18G o mayor)","Monitorizar PA y SatO2 durante el traslado","Tener carro de paros disponible en pacientes inestables"]},{nombre:"Hemograma completo y coagulacion",descripcion:"Cuantifica perdida hematica (Hb, Hto) y detecta coagulopatia asociada (TP, KPTT, fibrinogeno)",valoresReferencia:"Hb objetivo > 7-8 g/dL; Hto > 21%; fibrinogeno > 150 mg/dL en traumatizado",cuidadosEnfermeria:["Extraer muestra antes de la transfusion","Identificar y rotular correctamente las muestras","Enviar con urgencia al laboratorio indicando contexto clinico","Reservar 4 unidades de globulos rojos en banco de sangre"]},{nombre:"Gasometria arterial",descripcion:"Evalua eficiencia del intercambio gaseoso e identifica hipoxemia e hipercapnia",valoresReferencia:"PaO2 > 80 mmHg; PaCO2 35-45 mmHg; pH 7.35-7.45; SatO2 > 95%",cuidadosEnfermeria:["Utilizar jeringa heparinizada","Obtener muestra de arteria radial con tecnica de Allen previo","Aplicar compresion 5-10 minutos post-puncion","Transportar en hielo si demora > 15 minutos al laboratorio"]}]},tratamientoMedico:{objetivos:["Evacuar la sangre del espacio pleural para reexpandir el pulmon","Restaurar la estabilidad hemodinamica","Controlar la fuente de sangrado","Prevenir complicaciones (empiema, fibrotorax)","Mantener SatO2 > 95% y PaO2 > 80 mmHg"],farmacologico:[{nombre:"Cloruro de sodio 0.9% / Ringer Lactato",grupo:"Cristaloides para resucitacion",mecanismo:"Expansion del volumen intravascular para restaurar la precarga y el gasto cardiaco en el contexto de hipovolemia por hemorragia",dosis:"Bolo 500-1000 mL IV en 15-30 min; ajustar segun respuesta hemodinamica. Estrategia de hipotension permisiva: PAS 80-90 mmHg hasta control del sangrado",cuidadosEnfermeria:["Colocar dos vias venosas perifericas de grueso calibre (16G o 14G)","Registrar balance hidrico estricto cada hora","Monitorizar PA, FC y diuresis (objetivo > 0.5 mL/kg/h) continuamente","Vigilar signos de sobrecarga de volumen (crepitantes, edema)","Calentar los fluidos si hay riesgo de hipotermia"]},{nombre:"Acido tranexamico",grupo:"Antifibrinolitico",mecanismo:"Inhibe la activacion del plasminogeno y la plasmina, reduciendo la fibrinolisis y estabilizando el coagulo. Reduce mortalidad en trauma hemorragico si se administra en las primeras 3 horas",dosis:"1 g IV en 10 minutos (dosis de carga), luego 1 g IV en 8 horas. DEBE administrarse dentro de las 3 horas del trauma (protocolo CRASH-2)",cuidadosEnfermeria:["Verificar tiempo transcurrido desde el trauma (contraindicado > 3 horas por riesgo trombotico)","Administrar diluido en 100 mL de SF a velocidad controlada","Vigilar reacciones alergicas (hipotension, broncoespasmo)","Monitorizar signos de trombosis (TVP, TEP) en el seguimiento","Registrar hora exacta de administracion en la historia clinica"]},{nombre:"Morfina",grupo:"Analgesico opioide",mecanismo:"Agonista de receptores mu-opioides en SNC y periferia. Produce analgesia, reduccion de la ansiedad y disminucion de la demanda respiratoria, facilitando la cooperacion del paciente durante procedimientos",dosis:"2-4 mg IV cada 4-6 horas o en infusion continua segun escala de dolor. Titular hasta EVA < 4",cuidadosEnfermeria:["Monitorizar frecuencia respiratoria antes y despues de cada dosis (suspender si FR < 12 rpm)","Tener naloxona disponible como antidoto (0.4 mg IV)","Valorar nivel de consciencia y escala de sedacion de Ramsay","Prevenir estrenimineto con dieta y laxantes segun protocolo","Registrar EVA antes y 30 minutos despues de la administracion"]}],noFarmacologico:["Toracocentesis evacuadora en hemotorax minimo estable","Colocacion de tubo de toracostomia (drenaje pleural) calibre 28-36 Fr en hemitorax afectado \u2014 tratamiento definitivo estandar","Videotoracoscopia (VATS) para hemotorax coagulado o persistente","Toracotomia de emergencia si drenaje > 1500 mL inicial o > 200 mL/h por 4 horas","Oxigenoterapia de alto flujo con mascarilla (FiO2 100% en trauma grave)","Inmovilizacion y estabilizacion de fracturas costales","Posicion semisentada 30-45 grados si hemodinamica lo permite","Monitorizacion hemodinamica invasiva en UCI si inestable"]},cuidadosEnfermeria:{valoracion:["Monitorizar signos vitales cada 15-30 min o continuamente si es critico (PA, FC, FR, SatO2, temperatura)","Evaluar el nivel de consciencia y estado neurologico (GCS)","Valorar caracteristicas del dolor toracico (EVA, localizacion, irradiacion)","Inspeccionar el sitio de insercion del drenaje pleural (signos de infeccion, enfisema subcutaneo)","Registrar debito del drenaje pleural: volumen, color y caracteristicas del liquido drenado","Evaluar expansion toracica bilateral y auscultacion pulmonar"],intervenciones:["Mantener permeable el tubo de toracostomia (verificar oscilacion en la camara de agua cada turno)","Mantener el sistema de drenaje pleural por debajo del nivel del torax del paciente","Nunca pinzar el tubo de drenaje pleural salvo indicacion medica expresa","Realizar curacion del sitio de insercion con tecnica esteril cada 48 horas","Administrar oxigenoterapia y vigilar SatO2 con pulsioximetria continua","Canalizar y mantener accesos venosos permeables","Preparar y colaborar en la colocacion del tubo de toracostomia con material esteril","Administrar analgesia pautada y valorar su efectividad"],educacionPaciente:["Explicar la funcion del tubo de drenaje y la importancia de no moverse bruscamente","Instruir sobre como informar inmediatamente si siente dolor, disnea brusca o ve burbujas en el sistema","Ense\xf1ar respiracion diafragmatica y ejercicios de expansion toracica progresiva","Explicar la importancia del reposo relativo durante el drenaje","Educar sobre signos de alarma al alta: fiebre, disnea, dolor toracico, enrojecimiento en el sitio de cierre"],monitorizacion:["Debito del drenaje pleural horario (registrar si > 200 mL/h \u2014 alertar al medico)","SatO2 continua con pulsioximetria","PA, FC y FR cada 15-30 min en fase aguda","Balance hidrico estricto cada hora","Hemograma y coagulacion cada 6-12 horas en la fase aguda","Rx torax de control a las 24 horas post-drenaje y segun evolucion","Temperatura cada 6 horas para detectar infeccion"]},npiNanda:[{codigo:"00032",nombre:"Patron respiratorio ineficaz",definicion:"La inspiracion y/o espiracion no proporciona una ventilacion adecuada",caracteristicasDefinitorias:["Disnea","Taquipnea (FR > 25 rpm)","Uso de musculos accesorios de la respiracion","Disminucion del murmullo vesicular","SatO2 < 95%"],factoresRelacionados:["Compresion pulmonar por sangre en espacio pleural","Dolor toracico que limita la expansion","Trauma de la pared toracica"]},{codigo:"00029",nombre:"Disminucion del gasto cardiaco",definicion:"La cantidad de sangre bombeada por el corazon es inadecuada para satisfacer las demandas metabolicas del organismo",caracteristicasDefinitorias:["Hipotension arterial","Taquicardia","Piel palida, fria y sudorosa","Disminucion de la diuresis","Alteracion del nivel de consciencia"],factoresRelacionados:["Hipovolemia por hemorragia al espacio pleural","Compresion mediastinica con obstruccion del retorno venoso"]},{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable ocasionada por una lesion tisular real o potencial, con inicio subito o lento, de cualquier intensidad de leve a grave, con un final anticipado o previsible",caracteristicasDefinitorias:["Informe verbal de dolor toracico (EVA > 6)","Expresion facial de dolor","Postura antialgica","Taquicardia y taquipnea asociadas al dolor"],factoresRelacionados:["Trauma de la pared toracica","Irritacion pleural por la sangre acumulada","Procedimiento de drenaje pleural"]}],npiNic:[{codigo:"3350",nombre:"Monitorizacion respiratoria",actividades:["Monitorizar FR, profundidad y esfuerzo respiratorio","Registrar SatO2 con pulsioximetria continua","Auscultar ruidos respiratorios bilaterales en cada valoracion","Valorar uso de musculos accesorios y retracciones intercostales","Notificar cambios agudos en la funcion respiratoria al medico"]},{codigo:"4028",nombre:"Manejo del tubo de toracostomia",actividades:["Verificar que el sistema de drenaje este sellado y por debajo del nivel del torax","Registrar debito horario: volumen, color y consistencia","Verificar oscilacion del liquido en la camara de agua con la respiracion","Realizar curacion con tecnica esteril del sitio de insercion","Mantener la permeabilidad del tubo sin maniobras de ordeno rutinarias"]},{codigo:"4180",nombre:"Manejo de la hipovolemia",actividades:["Administrar fluidos intravenosos segun prescripcion medica","Monitorizar signos de respuesta a la reposicion de volumen","Registrar balance hidrico estricto","Gestionar la transfusion de hemoderivados segun indicacion","Evaluar perfusion periferica: relleno capilar, temperatura, diuresis"]}],npiNoc:[{codigo:"0402",nombre:"Estado respiratorio: intercambio gaseoso",indicadores:["SatO2 > 95%","PaO2 en rango normal (> 80 mmHg)","Ausencia de cianosis","FR en rango normal (12-20 rpm)","Expansion toracica simetrica"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"},{codigo:"0401",nombre:"Estado circulatorio",indicadores:["PA sistolica > 90 mmHg","FC en rango normal (60-100 lpm)","Diuresis > 0.5 mL/kg/h","Relleno capilar < 2 segundos","Piel normocoloreada y normotermia"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"},{codigo:"2102",nombre:"Nivel del dolor",indicadores:["EVA < 4 con analgesia","Ausencia de expresion facial de dolor en reposo","Frecuencia respiratoria no limitada por dolor","Capacidad de toser y respirar profundo"],escala:"1=Grave, 2=Sustancial, 3=Moderado, 4=Leve, 5=Ninguno"}],complicaciones:["Shock hipovolemico y paro cardiaco","Hemotorax coagulado con atelectasia persistente","Empiema pleural por infeccion secundaria de la sangre acumulada","Fibrotorax con restriccion ventilatoria cronica","Insuficiencia respiratoria aguda","Neumonia por hipoventilacion","Lesion de organos toracicos asociados (pulmon, aorta, corazon)"],criteriosAlarma:["Debito del drenaje pleural > 200 mL en una hora","Debito inicial > 1500 mL al colocar el drenaje (indicacion de toracotomia)","Hipotension refractaria a la reposicion de volumen (PAS < 90 mmHg)","Desaturacion aguda (SatO2 < 90%) con oxigenoterapia","Desviacion traqueal contralateral (tension hemodinamica)","Ausencia de oscilacion en la camara de agua del drenaje (obstruccion)","Fiebre > 38.5 C + purulencia en el drenaje (empiema)","Perdida de nivel de consciencia"],emergencyLevel:"critico",relatedPathologyIds:["pat_neumotorax","pat_tep","pat_shock_hipovolemico","pat_neumonia","pat_trauma_toracico"],isPremium:!0},{id:"pat_hiperplasia_prostatica",nombre:"Hiperplasia Prostatica Benigna",bodySystemId:"renal_urinario",definicion:"Crecimiento benigno no maligno de la glandula prostatica que produce obstruccion al vaciamiento vesical, con sintomas del tracto urinario inferior (STUI), siendo la causa mas frecuente de obstruccion urinaria en el varon mayor de 50 a\xf1os.",epidemiologia:"La prevalencia aumenta con la edad: afecta al 50% de los varones a los 60 a\xf1os y al 90% a los 80 a\xf1os. Es la segunda causa mas frecuente de cirugia en varones mayores. Genera mas de 1,8 millones de consultas medicas anuales solo en EE.UU. La retencion urinaria aguda afecta al 1-2% de los varones con HPB por anyo.",factoresRiesgo:["Edad avanzada (principal factor de riesgo)","Niveles elevados de androgenos (dihidrotestosterona \u2014 DHT)","Antecedentes familiares de HPB o cancer de prostata","Obesidad y sindrome metabolico","Sedentarismo","Dieta rica en grasas y carnes rojas","Inflamacion cronica prostatica","Diabetes mellitus tipo 2","Uso de anticolinergicos, simpaticomim\xe9ticos o calcioantagonistas (agravan la retencion)"],fisiopatologia:"La prostata normal pesa 20-25 g. Con la edad, la reduccion de la relacion testosterona/estrogeno favorece la accion de la DHT (derivada de la testosterona por accion de la 5-alfa-reductasa) sobre los receptores androgenicos del estroma prostatico, estimulando la proliferacion celular. La hiperplasia ocurre principalmente en la zona de transicion (periuretral), comprimiendo la uretra prost\xe1tica y generando un componente obstructivo estatico. Ademas, la estimulacion de receptores alfa1-adrenergicos en el cuello vesical y la capsula prostatica produce contraccion del musculo liso (componente dinamico). La obstruccion cronica genera cambios compensatorios en la vejiga: hipertrofia del detrusor con trabeculacion, formacion de diverticulos, e inestabilidad del detrusor que produce sintomas de llenado. A largo plazo se produce da\xf1o del detrusor, residuo post-mictional elevado e insuficiencia renal obstructiva.",signosYSintomas:{signos:["Prostata aumentada de tamano a la tacto rectal (superficie lisa, elastica, surco medio palpable \u2014 diferencia con cancer)","Globo vesical palpable y doloroso en retencion urinaria aguda","Residuo post-mictional > 100 mL en ecografia","Flujo maximo (Qmax) < 10 mL/s en flujometria (obstruccion severa)","Hematuria microscopica en tira reactiva","Elevacion de creatinina en casos de uropatia obstructiva bilateral"],sintomas:["Sintomas obstructivos: chorro urinario debil o interrumpido, inicio dificultoso (duda miccional), sensacion de vaciado incompleto, goteo post-mictional","Sintomas irritativos/de llenado: polaquiuria (> 8 micciones/dia), nocturia (> 2 episodios/noche), urgencia miccional, urgencia-incontinencia","Retencion urinaria aguda: incapacidad total y dolorosa para orinar \u2014 emergencia urologica","Dolor suprapubico en retencion aguda","Infecciones urinarias de repeticion","Hematuria macroscopica (venas varicosas periuretrales)","Puntuacion IPSS (International Prostate Symptom Score): leve 0-7, moderado 8-19, grave 20-35"]},clasificacion:{nombre:"Clasificacion por IPSS (Sintomas) y por peso prostatico",tipos:[{nombre:"HPB leve",descripcion:"IPSS 0-7. Sintomas minimos, Qmax > 15 mL/s. Manejo expectante con vigilancia activa"},{nombre:"HPB moderada",descripcion:"IPSS 8-19. Sintomas que afectan calidad de vida. Inicio de tratamiento farmacologico"},{nombre:"HPB grave",descripcion:"IPSS 20-35. Sintomas severos, Qmax < 10 mL/s, residuo post-mictional elevado. Considerar cirugia"},{nombre:"Retencion urinaria aguda (RUA)",descripcion:"Incapacidad total para orinar. Emergencia urologica que requiere sondaje vesical inmediato"},{nombre:"HPB complicada",descripcion:"Con litiasis vesical, infeccion urinaria de repeticion, hematuria recurrente o insuficiencia renal obstructiva. Indicacion quirurgica absoluta"}]},diagnostico:{anamnesis:["Aplicar cuestionario IPSS para cuantificar la severidad de los sintomas","Diario mictional de 72 horas (frecuencia, volumen, episodios de urgencia y nocturia)","Antecedentes de infecciones urinarias, litiasis, cirugia pelvica o uretral","Medicacion actual (anticolinergicos, diureticos, simpaticomim\xe9ticos)","Antecedentes familiares de HPB o cancer de prostata","Funcion sexual: disfuncion erectil (frecuentemente coexiste)"],examenFisico:["Tacto rectal: tamano prostatico estimado (> 40 g sugiere HPB), consistencia (elastica), regularidad de la superficie, presencia del surco medio","Exploracion abdominal: globo vesical suprapubico en retencion","Palpacion de flancos: buscar ptosis renal o hidronefrosis","Examen genital externo: meato uretral, fimosis, lesiones","Exploracion neurologica basica: tono del esfinter anal, sensibilidad perineal"],pruebas:[{nombre:"Analisis de orina y urocultivo",descripcion:"Descarta infeccion urinaria, hematuria de origen tumoral y glucosuria. El urocultivo orienta el tratamiento antibiotico si hay infeccion",valoresReferencia:"Orina normal: < 5 leucocitos/campo, < 3 hematies/campo, nitritos negativos. Urocultivo: < 100.000 UFC/mL",cuidadosEnfermeria:["Instruir tecnica correcta de recogida de orina de chorro medio con limpieza previa del glande","Recoger en recipiente esteril y enviar al laboratorio en menos de 2 horas","Si hay sonda vesical: obtener muestra del puerto de recogida con jeringa esteril (nunca de la bolsa)","Registrar aspecto, color y olor de la orina en la historia clinica"]},{nombre:"PSA (Antigeno Prostatico Especifico) total y libre",descripcion:"Marcador prostatico inespecifico. Eleva en HPB, prostatitis y cancer. El cociente PSA libre/total ayuda a diferenciar (< 15% orienta a malignidad). No es diagnostico exclusivo de cancer",valoresReferencia:"PSA total < 4 ng/mL normal; 4-10 zona gris; > 10 alto riesgo. Cociente libre/total < 0.15 sugiere cancer",cuidadosEnfermeria:["Extraer muestra ANTES del tacto rectal o la flujometria (pueden elevar el PSA falsamente)","No realizar si hay infeccion urinaria activa (esperar 4-6 semanas tras tratamiento)","Indicar al paciente que evite actividad sexual o ejercicio intenso en las 24-48 horas previas","Informar que la biopsia prostatica invalida el PSA por semanas"]},{nombre:"Ecografia abdomino-pelvica y transrectal (TRUS)",descripcion:"Estima el volumen prostatico (HPB si > 30 mL), mide el residuo post-mictional (RPM), evalua la vejiga (trabeculacion, diverticulos, litiasis) y descarta hidronefrosis",valoresReferencia:"Volumen prostatico normal: 20-30 mL; RPM aceptable: < 50 mL; significativo: > 100 mL",cuidadosEnfermeria:["Solicitar que el paciente llegue con vejiga llena para medir volumen vesical y RPM","Para TRUS: preparacion intestinal previa segun protocolo del centro","Posicionar en decubito lateral izquierdo con rodillas flexionadas para TRUS","Lubricar y calentar el transductor para mayor confort del paciente"]},{nombre:"Flujometria urinaria (uroflujometria)",descripcion:"Mide el flujo miccional maximo (Qmax) y el patron del flujo. Permite cuantificar el grado de obstruccion funcional. Se complementa con medicion post-mictional del residuo",valoresReferencia:"Qmax normal: > 15 mL/s; obstruccion leve: 10-15 mL/s; obstruccion moderada-severa: < 10 mL/s. Volumen miccional valido: > 150 mL",cuidadosEnfermeria:["Solicitar que el paciente llegue con deseo miccional normal (vejiga comoda, no urgente)","Instruir sobre la tecnica: orinar normalmente en el uroflujo sin interrumpir el chorro","Garantizar privacidad en el entorno para evitar inhibicion mictional","Registrar el volumen miccional y el tiempo de miccion para calculo del Qmax"]},{nombre:"Creatinina y BUN sericos",descripcion:"Evalua la funcion renal para descartar insuficiencia renal obstructiva (uropatia obstructiva bilateral por HPB avanzada). Fundamental antes de cirugia",valoresReferencia:"Creatinina: 0.7-1.2 mg/dL; BUN: 7-20 mg/dL; TFG estimada > 60 mL/min/1.73m2",cuidadosEnfermeria:["No requiere ayuno ni preparacion especial","Registrar diuresis de 24 horas si se sospecha obstruccion renal bilateral","Correlacionar con ecografia renal para valorar hidronefrosis bilateral","Alertar al medico si creatinina > 1.5 mg/dL con HPB severa"]}]},tratamientoMedico:{objetivos:["Reducir el tamano prostatico y relajar el cuello vesical","Aliviar los sintomas del tracto urinario inferior (IPSS < 8)","Prevenir la retencion urinaria aguda y sus complicaciones","Preservar la funcion renal","Mejorar la calidad de vida del paciente"],farmacologico:[{nombre:"Tamsulosina",grupo:"Alfabloqueante selectivo alfa1-A",mecanismo:"Bloquea selectivamente los receptores alfa1-A adrenergicos en el cuello vesical, la capsula prostatica y la uretra prost\xe1tica, relajando el musculo liso y reduciendo el componente dinamico de la obstruccion. Accion rapida (dias)",dosis:"0.4 mg VO una vez al dia, preferentemente 30 minutos despues del desayuno",cuidadosEnfermeria:["Advertir sobre el riesgo de hipotension ortostatica, especialmente al inicio del tratamiento","Recomendar levantarse lentamente desde el decubito (sentarse en el borde de la cama 1-2 min antes de ponerse de pie)","Informar sobre el sindrome de iris flacido intraoperatorio (IFIS) si se programa cirugia ocular \u2014 comunicar al oftalmologo","Monitorizar PA en las primeras dosis en pacientes con hipotension basal","Administrar siempre tras el desayuno para minimizar el efecto hipotensivo"]},{nombre:"Finasterida",grupo:"Inhibidor de la 5-alfa-reductasa (tipo II)",mecanismo:"Inhibe la conversion de testosterona a DHT (dihidrotestosterona) en el tejido prostatico, reduciendo el estimulo androgenico del crecimiento prostatico. Reduce el volumen de la prostata un 20-25% a los 6 meses. Reduce el PSA un 50% (considerar para interpretacion)",dosis:"5 mg VO una vez al dia. Efecto a partir de 6 meses de tratamiento continuo. Util en prostatas > 40 mL",cuidadosEnfermeria:["Informar que el beneficio clinico no se observa antes de 6 meses de tratamiento (adherencia critica)","Advertir sobre efectos adversos sexuales: disminucion de la libido, disfuncion erectil, disminucion del volumen del eyaculado","El PSA se reduce el 50% con finasterida: multiplicar por 2 el PSA medido bajo tratamiento para interpretarlo correctamente","Contraindicado en mujeres en edad fertil (teratogenico): las mujeres embarazadas no deben manipular comprimidos triturados","Fomentar adherencia informando sobre el beneficio a largo plazo en la prevencion de la retencion y cirugia"]},{nombre:"Solifenacina",grupo:"Antimuscarinco (anticolinergico) \u2014 para sintomas de llenado",mecanismo:"Bloquea los receptores muscarinico M3 en el detrusor vesical, reduciendo la hiperactividad del musculo detrusor responsable de la urgencia, polaquiuria y nocturia. Se usa en combinacion con alfabloqueante cuando predominan los sintomas de llenado",dosis:"5 mg VO una vez al dia. Se puede aumentar a 10 mg si hay respuesta insuficiente tras 4-8 semanas",cuidadosEnfermeria:["Medir el residuo post-mictional antes de iniciar (contraindicado si RPM > 200 mL por riesgo de retencion urinaria aguda)","Vigilar signos de retencion urinaria: disminucion de la diuresis, dolor suprapubico, globo vesical","Advertir sobre efectos anticolinergicos: boca seca, estrenimineto, vision borrosa, confusion en ancianos","Contraindicado en glaucoma de angulo cerrado no tratado","Fomentar hidratacion adecuada y dieta rica en fibra para prevenir estrenimineto"]}],noFarmacologico:["Vigilancia activa (watchful waiting) en IPSS leve sin complicaciones","Medidas higienico-dieteticas: reducir ingesta de liquidos en las 2-3 horas antes de dormir, limitar cafeina y alcohol","Tecnicas de relajacion vesical y doble miccion","Entrenamiento vesical (aumento progresivo del intervalo entre micciones)","Sondaje vesical de Foley 16-18 Fr en retencion urinaria aguda","RTUP (Reseccion Transurretral de Prostata) \u2014 cirugia estandar gold en HPB moderada-severa o complicada","Ablacion laser (Holmium Laser Enucleation \u2014 HoLEP) en prostatas > 80 mL","Embolizacion de arterias prostaticas (EAP) como alternativa minima invasiva","Rehabilitacion del suelo pelvico para el control de la incontinencia post-quirurgica"]},cuidadosEnfermeria:{valoracion:["Aplicar escala IPSS al ingreso y en cada control ambulatorio para cuantificar la severidad","Evaluar patron mictional: frecuencia, urgencia, nocturia, caracteristicas del chorro, vaciado incompleto","Valorar signos de retencion urinaria aguda: globo vesical, dolor suprapubico, ausencia de miccion en > 6 horas","Revisar el residuo post-mictional por ecografia o sondaje si hay sospecha de vaciado incompleto","Evaluar integridad de la piel en zona perineal (maceracion, dermatitis por incontinencia)","Valorar impacto en la calidad de vida: sueno, actividad social, bienestar emocional"],intervenciones:["Sondaje vesical de urgencia en retencion urinaria aguda con tecnica esteril (sonda Foley 16-18 Fr)","Registro de diuresis y caracteristicas de la orina (color, aspecto, olor) cada 8 horas en hospitalizados","Mantener la permeabilidad del sistema de sonda-bolsa colectora cerrada","Cuidado del meato uretral en pacientes sondados: limpieza con agua y jabon una vez al dia","Administrar analgesicos y antiespasm\xf6dicos pautados para el dolor en retencion","Educar en tecnicas de relajacion para facilitar la miccion (ruido del agua, posicion comoda, privacidad)"],educacionPaciente:["Explicar la diferencia entre HPB (benigna) y cancer de prostata para reducir la ansiedad","Ense\xf1ar el autorregistro del diario mictional para el seguimiento ambulatorio","Instruir sobre los cambios de estilo de vida: reducir cafe, alcohol y liquidos nocturnos","Informar sobre los efectos adversos de los farmacos (hipotension con tamsulosina, efectos sexuales con finasterida)","Indicar acudir a urgencias inmediatamente si no puede orinar, tiene dolor suprapubico intenso o fiebre con ardor al orinar","Explicar que el PSA puede ser bajo con finasterida y la importancia de los controles urologicos anuales"],monitorizacion:["Diuresis horaria en casos de retencion aguda o post-cirugia (objetivo > 0.5 mL/kg/h)","Balance hidrico en hospitalizados","IPSS en cada visita ambulatoria para evaluar respuesta al tratamiento","Residuo post-mictional ecografico cada 6-12 meses en tratamiento conservador","PSA anual tras inicio de tratamiento con finasterida (ajustar multiplicando x2)","Creatinina y sedimento urinario cada 6-12 meses para descartar uropatia obstructiva","Control de PA en cada visita en pacientes con alfabloqueantes"]},npiNanda:[{codigo:"00016",nombre:"Deterioro de la eliminacion urinaria",definicion:"Disfuncion en la eliminacion urinaria",caracteristicasDefinitorias:["Retencion urinaria parcial o total","Chorro urinario debil o interrumpido","Sensacion de vaciado incompleto","Polaquiuria y nocturia","Urgencia miccional"],factoresRelacionados:["Obstruccion mecanica de la uretra prost\xe1tica por tejido hiperplasico","Hiperactividad del detrusor vesical secundaria a obstruccion cronica","Perdida de contractilidad del detrusor en estadios avanzados"]},{codigo:"00023",nombre:"Retencion urinaria",definicion:"Vaciamiento incompleto de la vejiga",caracteristicasDefinitorias:["Incapacidad para orinar (retencion completa) o residuo post-mictional elevado (retencion cronica)","Globo vesical palpable y doloroso","Disuria o ausencia de miccion","Distension abdominal suprapubica"],factoresRelacionados:["Obstruccion del cuello vesical por HPB","Hipoactividad del detrusor en estadios avanzados","Ansiedad e inhibicion psicogena de la miccion"]},{codigo:"00060",nombre:"Interrupcion de los procesos familiares",definicion:"Cambio en las relaciones y/o funcionamiento familiar",caracteristicasDefinitorias:["Cambios en la participacion en actividades sociales y familiares","Afectacion de la vida sexual de la pareja","Ansiedad del paciente relacionada con el diagnostico","Cambios en los patrones habituales de sueno por nocturia"],factoresRelacionados:["Sintomas urinarios que limitan la vida social y el sueno","Incertidumbre sobre la evolucion y el tratamiento","Efectos adversos sexuales del tratamiento farmacologico"]}],npiNic:[{codigo:"0590",nombre:"Manejo de la eliminacion urinaria",actividades:["Monitorizar el patron mictional y las caracteristicas de la orina","Medir el residuo post-mictional si se sospecha vaciado incompleto","Instruir tecnicas de doble miccion y relajacion del suelo pelvico","Administrar medicacion para facilitar la miccion segun prescripcion","Documentar el balance hidrico y la frecuencia mictional"]},{codigo:"0580",nombre:"Sondaje vesical",actividades:["Realizar el sondaje vesical con tecnica esteril en la retencion urinaria aguda","Seleccionar el calibre adecuado (Foley 16-18 Fr en adulto)","Registrar el volumen de orina drenado al colocar la sonda","Mantener el sistema cerrado y por debajo del nivel de la vejiga","Realizar cuidados del meato uretral diariamente"]},{codigo:"5618",nombre:"Ensenanza: procedimiento/tratamiento",actividades:["Explicar el mecanismo de la HPB y la razon del tratamiento elegido","Informar sobre el efecto esperado y el tiempo de inicio de accion de los farmacos","Instruir sobre los efectos adversos y cuando consultar","Ensenar el autocuidado del sondaje si el paciente lleva sonda domiciliaria","Proporcionar informacion escrita sobre signos de alarma"]}],npiNoc:[{codigo:"0503",nombre:"Eliminacion urinaria",indicadores:["Patron de eliminacion dentro de los limites normales (< 8 micciones/dia)","Flujo urinario adecuado (Qmax > 15 mL/s)","Residuo post-mictional < 50 mL","Ausencia de urgencia incontinencia","Nocturia <= 1 episodio por noche"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=Sin compromiso"},{codigo:"1824",nombre:"Conocimiento: manejo de la enfermedad cronica",indicadores:["Describe los signos y sintomas de la HPB y sus complicaciones","Identifica los factores que agravan los sintomas (cafe, alcohol, liquidos nocturnos)","Describe correctamente el regimen farmacologico","Reconoce signos de alarma que requieren atencion medica urgente","Realiza correctamente el autoregistro del diario mictional"],escala:"1=Ningun conocimiento, 2=Conocimiento escaso, 3=Conocimiento moderado, 4=Conocimiento sustancial, 5=Conocimiento extenso"}],complicaciones:["Retencion urinaria aguda (emergencia urologica)","Infecciones urinarias de repeticion y prostatitis","Insuficiencia renal obstructiva bilateral (uropatia obstructiva)","Litiasis vesical por estasis urinaria","Hematuria macroscopica por venas varicosas periuretrales","Diverticulos vesicales con estasis e infeccion","Incontinencia urinaria por rebosamiento","Impacto en la calidad de vida: trastornos del sueno, depresion, limitacion social"],criteriosAlarma:["Retencion urinaria aguda: incapacidad total para orinar con globo vesical doloroso (urgencia urologica)","Hematuria macroscopica con coagulos (obstruccion del cateter, clot retention)","Fiebre + dolor lumbar bilateral + disuria (pielonefritis obstructiva \u2014 sepsis urologica)","Creatinina en aumento con HPB severa (uropatia obstructiva bilateral)","Ausencia de miccion en las ultimas 6-8 horas con globo vesical","Dolor suprapubico intenso no aliviado con analgesicos habituales","Hematuria macroscopica en paciente con anticoagulacion"],emergencyLevel:"leve",relatedPathologyIds:["pat_irc","pat_itu","pat_cancer_prostata","pat_litiasis_urinaria","pat_incontinencia_urinaria"],isPremium:!0},{id:"pat_tce",nombre:"Traumatismo Craneoencefalico",bodySystemId:"traumatologico",definicion:"Lesion cerebral adquirida causada por una fuerza mecanica externa sobre el craneo que produce alteracion temporal o permanente de la funcion cerebral. Incluye lesion primaria (impacto directo) y lesion secundaria (hipoxia, hipotension, edema, herniacion). Es una de las principales causas de morbimortalidad en jovenes y adultos.",epidemiologia:"Incidencia de 200-300 casos por 100.000 habitantes/a\xf1o. Principal causa de muerte en menores de 45 a\xf1os. Los accidentes de transito son la causa mas frecuente (50-60%), seguidos de caidas (20-30%). Mortalidad del TCE severo: 30-50%. Relacion hombre/mujer 3:1.",factoresRiesgo:["Accidentes de transito (motociclistas sin casco)","Caidas en adultos mayores y ni\xf1os","Violencia interpersonal y agresiones","Deportes de contacto sin proteccion","Consumo de alcohol y sustancias psicoactivas","Edad extrema (ni\xf1os menores de 5 a\xf1os y mayores de 65)","Uso de anticoagulantes (mayor riesgo de hemorragia)","Coagulopatias previas","Actividades laborales de riesgo (construccion, mineria)"],fisiopatologia:"La lesion primaria ocurre en el momento del impacto e incluye contusion cerebral, laceracion, hematomas y lesion axonal difusa. La doctrina de Monro-Kellie establece que el volumen intracraneal es fijo (cerebro 80%, LCR 10%, sangre 10%); el aumento de cualquier componente eleva la presion intracraneal (PIC). La lesion secundaria se desarrolla en horas-dias e incluye edema cerebral citoxico y vasogenico, isquemia por hipoperfusion, cascada inflamatoria con liberacion de glutamato (excitotoxicidad), produccion de radicales libres y apoptosis neuronal. La herniacion transtentorial es la complicacion mas temida: el uncus temporal comprime el tronco encefalico causando midriasis ipsilateral y coma. La autorregulacion cerebral se pierde cuando la PIC supera los 20-25 mmHg, comprometiendo la presion de perfusion cerebral (PPC = PAM - PIC).",signosYSintomas:{signos:["Alteracion del nivel de conciencia (GCS < 15)","Anisocoria (midriasis unilateral por herniacion uncal)","Triada de Cushing (hipertension, bradicardia, patron respiratorio irregular)","Otorragia u otorraquia (fractura de pe\xf1asco)","Rinorraquia (fractura de base de craneo anterior)","Signo de Battle (equimosis mastoidea)","Ojos de mapache (equimosis periorbitaria bilateral)","Deficit motor focal (hemiparesia/hemiplejia)","Convulsiones postraumaticas"],sintomas:["Cefalea intensa y progresiva","Nauseas y vomitos en proyectil","Amnesia del evento (retrograda y anterograda)","Confusion y desorientacion","Somnolencia progresiva","Vision doble o borrosa","Mareos y vertigo"]},clasificacion:{nombre:"Clasificacion segun Escala de Coma de Glasgow (GCS)",tipos:[{nombre:"TCE Leve",descripcion:"GCS 14-15. Paciente alerta u obnubilado. Perdida de conciencia < 30 min. Amnesia < 24 horas. Observacion 24-48h"},{nombre:"TCE Moderado",descripcion:"GCS 9-13. Alteracion de conciencia prolongada. Deficit neurologico focal posible. Requiere internacion y TAC seriada"},{nombre:"TCE Severo",descripcion:"GCS 3-8. Coma. Requiere intubacion orotraqueal, monitorizacion de PIC e internacion en UCI. Alta mortalidad"},{nombre:"TCE con lesion focal",descripcion:"Hematoma epidural, subdural, contusion o hemorragia intraparenquimatosa identificables en TAC"}]},diagnostico:{anamnesis:["Mecanismo de lesion (impacto directo, aceleracion-desaceleracion, rotacional)","Tiempo transcurrido desde el evento","Perdida de conciencia y su duracion","Uso de anticoagulantes o antiplaquetarios","Consumo de alcohol u otras sustancias","Antecedentes de TCE previo o cirugia craneal","Intervalo lucido (sugiere hematoma epidural)"],examenFisico:["Escala de Coma de Glasgow (apertura ocular, respuesta verbal, respuesta motora)","Evaluacion pupilar bilateral (tama\xf1o, simetria, reactividad a la luz)","Examen de pares craneales","Evaluacion de fuerza y sensibilidad en 4 extremidades","Inspeccion de craneo (heridas, hundimientos, crepitacion)","Busqueda de signos de fractura de base de craneo","Patron respiratorio (Cheyne-Stokes, hiperventilacion central)"],pruebas:[{nombre:"Tomografia computarizada (TAC) de craneo sin contraste",descripcion:"Estudio de eleccion inicial. Detecta hemorragias, fracturas, edema cerebral, efecto de masa y desviacion de linea media. Criterio quirurgico: desviacion > 5 mm",valoresReferencia:"Normal: sin colecciones, sin desviacion de linea media, cisternas basales permeables, PIC estimada normal",cuidadosEnfermeria:["Estabilizar al paciente antes del traslado (ABCDE)","Inmovilizacion cervical hasta descartar lesion asociada","Monitorizar constantes vitales durante el traslado","Acompa\xf1ar al paciente con equipo de reanimacion"]},{nombre:"Monitorizacion de presion intracraneal (PIC)",descripcion:"Cateter intraventricular (gold standard) o sensor intraparenquimatoso. Indicada en TCE severo (GCS <= 8) con TAC anormal. Permite drenaje terapeutico de LCR",valoresReferencia:"PIC normal: 5-15 mmHg. Hipertension intracraneal: > 20-25 mmHg. PPC objetivo: > 60-70 mmHg",cuidadosEnfermeria:["Mantener transductor a nivel del tragus (referencia cero)","Verificar morfologia de la onda de PIC","Registrar PIC y PPC cada hora","Tecnica aseptica estricta en manipulacion del cateter","Vigilar signos de infeccion en sitio de insercion"]},{nombre:"Resonancia magnetica cerebral",descripcion:"Superior a TAC para detectar lesion axonal difusa, contusiones peque\xf1as y lesiones de fosa posterior. No es estudio inicial de urgencia",valoresReferencia:"Normal: sin focos hemorragicos, sin edema, sin lesion axonal",cuidadosEnfermeria:["Verificar ausencia de material ferromagnetico (clips, marcapasos)","Paciente debe estar estable hemodinamicamente","Sedacion puede ser necesaria en pacientes agitados"]}]},tratamientoMedico:{objetivos:["Prevenir y tratar la lesion cerebral secundaria","Mantener PIC < 20-22 mmHg y PPC > 60-70 mmHg","Asegurar oxigenacion y perfusion cerebral adecuadas","Identificar y evacuar lesiones con indicacion quirurgica","Prevenir complicaciones (convulsiones, infecciones, TVP)"],farmacologico:[{nombre:"Manitol 20%",grupo:"Diuretico osmotico",mecanismo:"Crea gradiente osmotico que extrae agua del parenquima cerebral hacia el espacio intravascular, reduciendo el edema cerebral y la PIC. Efecto en 15-30 minutos",dosis:"0.25-1 g/kg IV en bolo, cada 4-6 horas. No superar osmolaridad serica de 320 mOsm/L",cuidadosEnfermeria:["Administrar por via periferica gruesa o via central","Utilizar filtro en linea para cristales","Monitorizar osmolaridad serica cada 6 horas","Control estricto de diuresis (puede producir diuresis masiva)","Vigilar signos de deshidratacion e hipotension","Monitorizar electrolitos (sodio, potasio)"]},{nombre:"Solucion salina hipertonica (SSH 3-7.5%)",grupo:"Agente osmotico",mecanismo:"Reduce edema cerebral por gradiente osmotico. Ventaja sobre manitol: expande volemia (util en pacientes hipotensos). No tiene techo de osmolaridad tan restrictivo",dosis:"SSH 3%: 150-250 mL IV en 20 min. SSH 7.5%: 2 mL/kg en bolo. Objetivo: Na serico 145-155 mEq/L",cuidadosEnfermeria:["Administrar exclusivamente por via central (SSH > 3%)","Monitorizar sodio serico cada 4-6 horas","Vigilar signos de mielinolisis pontina por correccion rapida","Control de PIC post-administracion","Registrar balance hidrico estricto"]},{nombre:"Levetiracetam (Keppra)",grupo:"Anticonvulsivante",mecanismo:"Modula liberacion de neurotransmisores mediante union a proteina SV2A en vesiculas sinapticas. Profilaxis de convulsiones postraumaticas tempranas (primeros 7 dias)",dosis:"500-1000 mg IV/VO cada 12 horas. Ajustar en insuficiencia renal",cuidadosEnfermeria:["Administrar IV diluido en 100 mL de SF en 15 min","Vigilar somnolencia e irritabilidad (efectos adversos comunes)","Monitorizar funcion renal para ajuste de dosis","No suspender bruscamente (riesgo de convulsiones de rebote)"]}],noFarmacologico:["Cabecera elevada a 30 grados con cabeza en linea media (favorece drenaje venoso yugular)","Normotermia estricta (tratar fiebre agresivamente, objetivo < 37.5\xb0C)","Normoglucemia (objetivo 80-180 mg/dL, evitar hipo e hiperglucemia)","Normocapnia (PaCO2 35-40 mmHg; hiperventilacion solo como puente en herniacion)","Sedoanalgesia con propofol o midazolam + fentanilo en pacientes intubados","Evitar hipotension (PAS > 100 mmHg en todo momento)","Prevencion de trombosis venosa profunda (medias compresivas, heparina precoz)"],quirurgico:["Craneotomia evacuadora de hematoma epidural (indicada si > 30 mL o grosor > 15 mm)","Craneotomia para hematoma subdural agudo (indicada si grosor > 10 mm o desviacion de linea media > 5 mm)","Craniectomia descompresiva (retiro de fragmento oseo para permitir expansion cerebral en HIC refractaria)","Drenaje ventricular externo (DVE) para drenaje de LCR y control de PIC","Reparacion de fracturas deprimidas (si hundimiento > grosor del craneo)"]},cuidadosEnfermeria:{valoracion:["Evaluacion neurologica horaria con GCS completa","Control pupilar bilateral cada hora (tama\xf1o, simetria, reactividad)","Monitorizar PIC y calcular PPC si cateter disponible","Evaluar patron respiratorio y necesidad de via aerea avanzada","Valorar signos de deterioro neurologico (triada de Cushing)","Inspeccionar heridas craneales, otorragia y rinorraquia"],intervenciones:["Mantener cabecera a 30\xb0 con cabeza en posicion neutra","Asegurar via aerea permeable y oxigenacion adecuada (SpO2 > 95%)","Administrar terapia osmotica segun indicacion y monitorizar respuesta","Minimizar estimulacion ambiental (luz tenue, ruido bajo, aspiracion breve)","Prevenir aumento de PIC: evitar maniobra de Valsalva, flexion cervical, fiebre","Cuidado de DVE: mantener nivel prescrito, registrar drenaje horario","Prevencion de ulceras por presion con cambios posturales cuidadosos"],educacionPaciente:["Explicar a la familia el estado neurologico y pronostico con lenguaje claro","Instruir sobre signos de alarma al alta (cefalea progresiva, vomitos, confusion)","Ense\xf1ar cuidados de herida quirurgica si aplica","Explicar la importancia del seguimiento neurologico ambulatorio","Educar sobre prevencion: uso de casco, cinturon de seguridad, prevencion de caidas","Rehabilitacion cognitiva y fisica: expectativas reales y adherencia"],monitorizacion:["GCS y pupilas cada 1-2 horas (mas frecuente si inestable)","PIC continua con alarma > 20 mmHg","Signos vitales cada hora (PA, FC, FR, SpO2, temperatura)","Glucemia capilar cada 4-6 horas","Osmolaridad serica y sodio cada 6 horas si recibe terapia osmotica","Balance hidrico estricto cada 4 horas"]},npiNanda:[{codigo:"00201",nombre:"Riesgo de perfusion tisular cerebral ineficaz",definicion:"Vulnerable a una disminucion de la circulacion tisular cerebral que puede comprometer la salud",caracteristicasDefinitorias:["Alteracion del nivel de conciencia","Cambios pupilares","Deficit neurologico focal","Deterioro cognitivo agudo"],factoresRelacionados:["Hipertension intracraneal","Edema cerebral","Hipotension arterial","Hipoxemia","Lesion cerebral traumatica"]},{codigo:"00085",nombre:"Deterioro de la movilidad fisica",definicion:"Limitacion del movimiento independiente e intencionado del cuerpo o de una o mas extremidades",caracteristicasDefinitorias:["Dificultad para realizar movimientos voluntarios","Hemiparesia o hemiplejia","Inestabilidad postural","Disminucion de la fuerza muscular"],factoresRelacionados:["Da\xf1o neurologico por TCE","Sedacion prolongada","Inmovilizacion por tratamiento"]},{codigo:"00049",nombre:"Disminucion de la capacidad adaptativa intracraneal",definicion:"Compromiso de los mecanismos de compensacion intracraneal que normalmente mantienen la PIC dentro de rangos normales ante estimulos internos y externos",caracteristicasDefinitorias:["Elevacion desproporcionada de PIC ante estimulos minimos","Ondas de PIC patologicas (ondas plateau)","Aumento de PIC > 20 mmHg sostenido"],factoresRelacionados:["Edema cerebral","Hematoma intracraneal","Obstruccion del drenaje de LCR"]}],npiNic:[{codigo:"2550",nombre:"Mejora de la perfusion cerebral",actividades:["Monitorizar PIC y calcular PPC","Mantener cabecera elevada 30\xb0 con cabeza en linea media","Administrar agentes osmoticos segun prescripcion","Evitar hipotermia, hipertermia, hipoxia e hipotension","Minimizar estimulos que aumenten PIC"]},{codigo:"2620",nombre:"Monitorizacion neurologica",actividades:["Evaluar GCS de forma sistematica y periodica","Monitorizar tama\xf1o, simetria y reactividad pupilar","Evaluar funcion motora y sensitiva","Detectar signos precoces de herniacion cerebral","Documentar tendencias en el estado neurologico"]},{codigo:"2540",nombre:"Manejo del edema cerebral",actividades:["Administrar terapia osmotica (manitol, SSH) segun protocolo","Monitorizar osmolaridad serica y electrolitos","Mantener normocapnia (PaCO2 35-40 mmHg)","Controlar temperatura corporal (evitar fiebre)","Coordinar con neurocirugia ante HIC refractaria"]}],npiNoc:[{codigo:"0909",nombre:"Estado neurologico",indicadores:["Nivel de conciencia (GCS)","Tama\xf1o y reactividad pupilar","Funcion motora y sensitiva","Patron respiratorio adecuado","PIC dentro de rangos normales"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"},{codigo:"0802",nombre:"Signos vitales",indicadores:["PA sistolica y diastolica en rango","Frecuencia cardiaca regular","Frecuencia respiratoria normal","Temperatura corporal en rango"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Herniacion cerebral (transtentorial, subfalcial, amigdalar)","Hematoma epidural o subdural diferido","Convulsiones postraumaticas tempranas y tardias","Hidrocefalia postraumatica","Fistula de LCR (rinorraquia, otorraquia) con riesgo de meningitis","Diabetes insipida central (da\xf1o hipotalamo-hipofisario)","Coagulopatia por consumo (liberacion de tromboplastina cerebral)","Sindrome de secrecion inadecuada de ADH (SIADH)"],criteriosAlarma:["Deterioro de GCS >= 2 puntos respecto al basal","Midriasis unilateral fija (herniacion inminente)","Triada de Cushing (hipertension + bradicardia + respiracion irregular)","PIC > 25 mmHg sostenida por mas de 5 minutos","Convulsion tonica-clonica generalizada","Poliuria > 300 mL/h (sospecha de diabetes insipida)","Aparicion de deficit motor nuevo"],emergencyLevel:"critico",relatedPathologyIds:["pat_acv","pat_politraumatismo","pat_lesion_medular","pat_epilepsia"],isPremium:!1},{id:"pat_politraumatismo",nombre:"Politraumatismo",bodySystemId:"traumatologico",definicion:"Lesion simultanea de dos o mas regiones corporales o sistemas organicos, siendo al menos una de ellas potencialmente mortal. Se define por un Injury Severity Score (ISS) mayor o igual a 16. Es una emergencia medica que requiere abordaje sistematico y multidisciplinario.",epidemiologia:"Constituye la primera causa de muerte en menores de 40 a\xf1os a nivel mundial. Tercera causa de muerte global. En Argentina, los accidentes de transito causan mas de 5.000 muertes anuales. Distribucion trimodal de muerte: inmediata (50%, en el lugar), precoz (30%, primeras horas) y tardia (20%, dias-semanas por sepsis y FMO).",factoresRiesgo:["Accidentes de transito (principal causa: 60-70%)","Caidas de altura","Violencia con armas de fuego o arma blanca","Accidentes laborales industriales","Actividades deportivas de alto riesgo","Consumo de alcohol (presente en 30-50% de los casos)","Edad joven (15-44 a\xf1os: grupo mas afectado)","Sexo masculino (relacion 3:1)","Falta de uso de cinturon de seguridad o casco"],fisiopatologia:"El impacto traumatico genera da\xf1o tisular masivo con liberacion de mediadores inflamatorios (TNF-alfa, IL-1, IL-6), activacion del complemento y cascada de coagulacion. Se produce la triada letal: hipotermia (por exposicion y reposicion con fluidos frios), acidosis metabolica (por hipoperfusion tisular y metabolismo anaerobio con acumulacion de lactato) y coagulopatia (consumo de factores, hemodilusion, hipotermia que inhibe la cascada). La respuesta sistemica inflamatoria (SIRS) puede progresar a disfuncion multiorganica (FMO). El shock hemorragico es la causa de muerte prevenible mas frecuente: la hemorragia no controlada produce hipoperfusion tisular, da\xf1o celular irreversible y muerte.",signosYSintomas:{signos:["Taquicardia (FC > 100 lpm, signo precoz de hipovolemia)","Hipotension arterial (PAS < 90 mmHg, signo tardio de shock)","Taquipnea (FR > 20 rpm)","Alteracion del nivel de conciencia (GCS < 15)","Piel palida, fria, sudorosa (vasoconstriccion periferica)","Llenado capilar > 2 segundos","Deformidades oseas visibles o crepitacion","Heridas abiertas, hemorragia externa activa","Distension abdominal (hemorragia intraabdominal)"],sintomas:["Dolor intenso generalizado o localizado","Dificultad respiratoria","Sed intensa (signo de hipovolemia)","Ansiedad y agitacion","Sensacion de frio","Debilidad generalizada","Incapacidad para movilizarse"]},clasificacion:{nombre:"Clasificacion segun Injury Severity Score (ISS) y tipo de trauma",tipos:[{nombre:"Politraumatismo cerrado",descripcion:"Sin solucion de continuidad en piel. Causas: accidentes viales, caidas, aplastamiento. Riesgo de lesiones ocultas"},{nombre:"Politraumatismo penetrante",descripcion:"Con lesion abierta (arma blanca, arma de fuego). Mayor riesgo de lesion visceral directa y contaminacion"},{nombre:"ISS 16-24 (moderado-severo)",descripcion:"Multiples lesiones significativas. Requiere hospitalizacion y manejo multidisciplinario"},{nombre:"ISS >= 25 (critico)",descripcion:"Lesiones multiples que amenazan la vida. Alta mortalidad. Requiere cirugia de control de da\xf1os"}]},diagnostico:{anamnesis:["Mecanismo de lesion detallado (cinematica del trauma)","Velocidad estimada del impacto","Uso de dispositivos de seguridad (cinturon, casco, airbag)","Tiempo desde el evento (hora dorada)","Tratamiento prehospitalario recibido","Antecedentes medicos y alergias (SAMPLE: Sintomas, Alergias, Medicacion, Patologias, Libaciones, Eventos)","Estado de conciencia en el lugar del accidente"],examenFisico:["Evaluacion primaria ATLS sistematica: A (via aerea con control cervical), B (respiracion), C (circulacion con control de hemorragias), D (deficit neurologico), E (exposicion)","Evaluacion secundaria cefalocaudal completa","Log-roll para inspeccion de espalda y columna","Tacto rectal y sondaje vesical (si no hay contraindicacion)","Evaluacion del pulso en 4 extremidades","Estabilidad pelvica (maniobra de compresion lateral unica)"],pruebas:[{nombre:"FAST (Focused Assessment with Sonography in Trauma)",descripcion:"Ecografia rapida en 4 puntos (hepatorrenal, esplenorrenal, pelvis, pericardico) para detectar liquido libre intraabdominal o pericardico. Se realiza en sala de emergencia sin mover al paciente",valoresReferencia:"Negativo: sin liquido libre. Positivo: liquido libre en cualquier ventana. FAST positivo + inestabilidad = laparotomia urgente",cuidadosEnfermeria:["Facilitar acceso al abdomen (retirar ropa)","Mantener monitorizacion continua durante el estudio","Preparar para quirofano si FAST positivo y paciente inestable","Documentar resultado y hora del estudio"]},{nombre:"Tomografia computarizada corporal total (body CT)",descripcion:"TAC de craneo, columna cervical, torax, abdomen y pelvis con contraste IV. Gold standard en paciente estable hemodinamicamente. Detecta lesiones ocultas",valoresReferencia:"Normal: sin focos hemorragicos, sin neumotorax, sin fracturas, organos sin lesion parenquimatosa",cuidadosEnfermeria:["Solo en paciente hemodinamicamente estable","Mantener inmovilizacion cervical durante traslado","Via periferica gruesa (18G) para contraste IV","Monitorizar signos vitales durante el estudio","Preparar equipo de reanimacion por si deterioro"]},{nombre:"Laboratorio de trauma (panel completo)",descripcion:"Hemograma, grupo y factor, coagulograma, gasometria arterial con lactato, ionograma, funcion renal, amilasa, prueba cruzada. Acido tranexamico requiere lactato y coagulacion basal",valoresReferencia:"Hb > 7 g/dL, plaquetas > 50.000, INR < 1.5, lactato < 2 mmol/L, pH > 7.35, BE > -6",cuidadosEnfermeria:["Extraer muestras al momento de colocar via periferica","Solicitar grupo y factor con prueba cruzada urgente","Identificar correctamente las muestras (riesgo de error con multiples pacientes)","Solicitar resultados con caracter urgente"]}]},tratamientoMedico:{objetivos:["Controlar hemorragia activa (causa prevenible de muerte numero 1)","Revertir la triada letal (hipotermia, acidosis, coagulopatia)","Mantener perfusion tisular adecuada (lactato < 2, BE normal)","Identificar y tratar todas las lesiones (primarias y ocultas)","Prevenir disfuncion multiorganica","Resucitacion con control de da\xf1os (damage control resuscitation)"],farmacologico:[{nombre:"Acido tranexamico (CRASH-2)",grupo:"Antifibrinolitico",mecanismo:"Inhibe la fibrinolisis al bloquear la union de plasminogeno a fibrina. El estudio CRASH-2 demostro reduccion de mortalidad en trauma hemorragico si se administra dentro de las primeras 3 horas",dosis:"1 g IV en 10 min (primera dosis), seguido de 1 g IV en infusion en 8 horas. DEBE iniciarse dentro de las primeras 3 horas del trauma",cuidadosEnfermeria:["Administrar la primera dosis lo mas pronto posible (idealmente prehospitalario)","No administrar si han pasado mas de 3 horas desde el trauma (puede ser perjudicial)","Diluir en 100 mL de SF o Ringer para infusion","Vigilar signos de trombosis (TEP, TVP)","Registrar hora exacta de administracion"]},{nombre:"Hemoderivados (protocolo de transfusion masiva)",grupo:"Terapia transfusional",mecanismo:"Reposicion de globulos rojos, plasma fresco congelado, plaquetas y crioprecipitado en relacion 1:1:1 para restablecer capacidad de transporte de O2 y hemostasia. Reposicion balanceada frente a la antigua reposicion con cristaloides",dosis:"Protocolo de transfusion masiva: GR:PFC:Plaquetas en relacion 1:1:1. Activar cuando se anticipan > 10 unidades de GR en 24h o > 4 unidades en 1 hora",cuidadosEnfermeria:["Verificar grupo sanguineo y compatibilidad (O negativo si urgencia extrema)","Usar calentador de fluidos para prevenir hipotermia","Monitorizar signos de reaccion transfusional","Control de calcio ionizado (citrato de hemoderivados quela calcio)","Registrar unidades transfundidas con hora exacta"]},{nombre:"Noradrenalina",grupo:"Vasopresor catecolaminergico",mecanismo:"Agonista alfa-1 predominante con efecto beta-1 leve. Produce vasoconstriccion y aumento de PA. Solo usar DESPUES de reposicion volemica adecuada",dosis:"0.01-0.5 mcg/kg/min en infusion continua. Titular segun PAM objetivo >= 65 mmHg",cuidadosEnfermeria:["Administrar exclusivamente por via central","Dilucion estandar: 8 mg en 250 mL de dextrosa 5%","Monitorizar PA invasiva (linea arterial) idealmente","Vigilar extravasacion (necrosis tisular)","No usar como reemplazo de reposicion volemica"]}],noFarmacologico:["Inmovilizacion cervical hasta descartar lesion de columna","Control de hemorragia externa con presion directa y torniquetes","Hipotension permisiva (PAS 80-90 mmHg) hasta control quirurgico de hemorragia","Calentamiento activo (manta termica, fluidos calentados a 39\xb0C)","Fijador pelvico externo o sabana pelvica en fractura de pelvis","Via aerea definitiva (intubacion orotraqueal) si GCS <= 8 o compromiso de via aerea"],quirurgico:["Cirugia de control de da\xf1os (damage control surgery): control de hemorragia y contaminacion, packing, cierre temporal, estabilizacion en UCI, cirugia definitiva a las 24-48h","Laparotomia exploratoria urgente (FAST +, inestabilidad hemodinamica)","Toracotomia de emergencia (taponamiento cardiaco, hemorragia masiva toracica)","Fijacion externa de fracturas de pelvis y huesos largos","Esplenectomia o empaquetamiento hepatico segun lesion"]},cuidadosEnfermeria:{valoracion:["Evaluacion primaria ABCDE rapida y sistematica","Monitorizar signos vitales continuos (PA, FC, FR, SpO2, T\xb0)","Evaluar nivel de conciencia con GCS cada 15-30 minutos","Cuantificar hemorragia visible y estimar perdida sanguinea","Valorar llenado capilar y perfusion periferica","Control de temperatura central (evitar hipotermia < 35\xb0C)"],intervenciones:["Colocar dos vias perifericas gruesas (14-16G) en miembros superiores","Iniciar reposicion volemica con solucion tibia segun indicacion","Administrar acido tranexamico dentro de las primeras 3 horas","Mantener permeabilidad de via aerea y asistir intubacion si necesario","Inmovilizar fracturas inestables con ferulas antes de traslado","Colocar sonda vesical y nasogastrica (si no contraindicadas)","Preparar quirofano y banco de sangre con anticipacion"],educacionPaciente:["Informar a la familia sobre el estado del paciente y plan de tratamiento","Explicar la necesidad de cirugia y procedimientos invasivos","Ense\xf1ar prevencion de accidentes (cinturon, casco, manejo responsable)","Instruir sobre el proceso de rehabilitacion y tiempos esperados","Brindar apoyo emocional y derivar a salud mental si necesario","Explicar cuidados domiciliarios al alta (heridas, medicacion, signos de alarma)"],monitorizacion:["Signos vitales continuos con monitor multiparametrico","Diuresis horaria (objetivo > 0.5 mL/kg/h como indicador de perfusion renal)","Gasometria arterial seriada con lactato (marcador de perfusion tisular)","Hemoglobina y coagulacion cada 2-4 horas en fase aguda","Temperatura central cada hora (prevenir hipotermia)","Balance hidrico estricto cada hora"]},npiNanda:[{codigo:"00206",nombre:"Riesgo de sangrado",definicion:"Vulnerable a una disminucion del volumen de sangre que puede comprometer la salud",caracteristicasDefinitorias:["Hemorragia activa visible","Caida de hemoglobina","Taquicardia e hipotension","Palidez y llenado capilar lento"],factoresRelacionados:["Trauma con lesion vascular","Coagulopatia por consumo","Hipotermia que inhibe coagulacion","Procedimientos quirurgicos"]},{codigo:"00205",nombre:"Riesgo de shock",definicion:"Vulnerable a un aporte sanguineo inadecuado a los tejidos corporales que puede conducir a una disfuncion celular que constituye una amenaza para la vida",caracteristicasDefinitorias:["Hipotension arterial","Taquicardia compensadora","Oliguria","Acidosis metabolica con lactato elevado"],factoresRelacionados:["Hipovolemia por hemorragia","Perdida masiva de sangre","Respuesta inflamatoria sistemica"]},{codigo:"00032",nombre:"Patron respiratorio ineficaz",definicion:"Inspiracion y/o espiracion que no proporciona una ventilacion adecuada",caracteristicasDefinitorias:["Disnea","Taquipnea","Uso de musculos accesorios","Disminucion de murmullo vesicular"],factoresRelacionados:["Neumotorax traumatico","Contusion pulmonar","Dolor toracico por fracturas costales","Alteracion del nivel de conciencia"]}],npiNic:[{codigo:"4026",nombre:"Reduccion de la hemorragia",actividades:["Aplicar presion directa sobre sitios de sangrado activo","Colocar torniquete en extremidades si hemorragia no controlable","Administrar hemoderivados segun protocolo de transfusion masiva","Monitorizar hemoglobina y coagulacion seriada","Preparar para intervencion quirurgica si hemorragia interna"]},{codigo:"4260",nombre:"Prevencion del shock",actividades:["Canalizar dos vias perifericas gruesas y reponer volumen","Monitorizar signos precoces de shock (taquicardia, llenado capilar)","Mantener temperatura corporal > 36\xb0C","Administrar vasopresores si hipotension refractaria a volumen","Evaluar diuresis como marcador de perfusion"]},{codigo:"6200",nombre:"Cuidados en emergencia",actividades:["Realizar evaluacion primaria ABCDE sistematica","Coordinar equipo multidisciplinario de trauma","Priorizar intervenciones segun amenaza vital","Documentar procedimientos, tiempos y respuesta del paciente","Activar protocolo de transfusion masiva cuando indicado"]}],npiNoc:[{codigo:"0413",nombre:"Severidad de la perdida de sangre",indicadores:["Perdida de sangre visible controlada","Hemoglobina estable","PA mantenida en rango aceptable","Ausencia de sangrado activo"],escala:"1=Grave, 2=Sustancial, 3=Moderado, 4=Leve, 5=Ninguno"},{codigo:"0802",nombre:"Signos vitales",indicadores:["PA sistolica > 90 mmHg","FC < 100 lpm","FR 12-20 rpm","Temperatura > 36\xb0C","SpO2 > 95%"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Shock hemorragico irreversible","Sindrome de disfuncion multiorganica (FMO)","Sindrome de distres respiratorio agudo (SDRA)","Coagulacion intravascular diseminada (CID)","Sepsis y shock septico","Sindrome compartimental abdominal","Tromboembolismo pulmonar","Rabdomiolisis con insuficiencia renal aguda"],criteriosAlarma:["PAS < 90 mmHg que no responde a 2 litros de cristaloides","FC > 120 lpm sostenida","Lactato > 4 mmol/L o en ascenso","Hemoglobina < 7 g/dL con sangrado activo","Deterioro de GCS >= 2 puntos","Diuresis < 0.5 mL/kg/h por 2 horas consecutivas","Temperatura < 35\xb0C (hipotermia)"],emergencyLevel:"critico",relatedPathologyIds:["pat_tce","pat_trauma_toracico","pat_trauma_abdominal","pat_fracturas_extremidades","pat_shock_hipovolemico"],isPremium:!1},{id:"pat_quemaduras",nombre:"Quemaduras",bodySystemId:"traumatologico",definicion:"Lesion tisular causada por agentes termicos, quimicos, electricos o por radiacion que produce destruccion de las capas de la piel y potencialmente de estructuras profundas. Su gravedad depende de la extension (% de superficie corporal quemada - SCQ), profundidad y localizacion.",epidemiologia:"Incidencia global de 11 millones de casos/a\xf1o que requieren atencion medica. Las quemaduras causan aproximadamente 180.000 muertes anuales en el mundo. En Argentina, se registran 50.000-100.000 casos/a\xf1o. Los ni\xf1os menores de 5 a\xf1os y adultos mayores son los grupos mas vulnerables. Las escaldaduras son la causa mas frecuente en pediatria.",factoresRiesgo:["Edad extrema (ni\xf1os < 5 a\xf1os y adultos > 65 a\xf1os)","Exposicion laboral a agentes termicos o quimicos","Incendios domiciliarios (principal causa de muerte por quemaduras)","Escaldaduras por liquidos calientes (primera causa en pediatria)","Contacto con electricidad de alta tension","Abuso infantil (quemaduras intencionales: patron en guante o calcetin)","Epilepsia (convulsiones cerca de fuentes de calor)","Consumo de alcohol y drogas","Condiciones de vivienda precaria"],fisiopatologia:"La quemadura produce tres zonas concentricas descritas por Jackson: zona de coagulacion (centro, necrosis irreversible), zona de estasis (circundante, vasodilatacion e isquemia potencialmente reversible, objetivo del tratamiento) y zona de hiperemia (periferica, vasodilatacion, recupera espontaneamente). Cuando la SCQ supera el 20-25%, se produce respuesta inflamatoria sistemica con aumento de permeabilidad capilar masiva, perdida de plasma al intersticio (edema), hipovolemia y shock por quemadura. La perdida de la barrera cutanea predispone a infecciones, evaporacion excesiva e hipotermia. En las primeras 24-48h predomina la fase de reanimacion (reposicion de liquidos segun formula de Parkland), y luego la fase hipermetabolica con catabolismo proteico severo.",signosYSintomas:{signos:["Eritema, ampollas o escaras segun profundidad","Edema local o generalizado (en quemaduras extensas)","Escara rigida, seca, acartonada (quemadura profunda)","Taquicardia (por dolor, hipovolemia o respuesta inflamatoria)","Hipotension en quemaduras extensas (> 20% SCQ)","Estridor laringeo, holl\xedn en nares o esputo carbonaceo (lesion inhalatoria)","Disminucion del murmullo vesicular (edema pulmonar o lesion inhalatoria)","Pulsos perifericos disminuidos en quemaduras circunferenciales"],sintomas:["Dolor intenso en quemaduras superficiales (terminaciones nerviosas intactas)","Ausencia de dolor en quemaduras profundas (destruccion de terminaciones nerviosas)","Sed intensa (por perdida de liquidos)","Ansiedad y agitacion","Dificultad respiratoria (si hay lesion inhalatoria)","Escalofrios y sensacion de frio"]},clasificacion:{nombre:"Clasificacion segun profundidad de la quemadura",tipos:[{nombre:"Primer grado (epidermica)",descripcion:"Solo afecta epidermis. Eritema doloroso sin ampollas. Ejemplo: quemadura solar. Cura en 3-7 dias sin cicatriz"},{nombre:"Segundo grado superficial (dermica superficial)",descripcion:"Epidermis y dermis papilar. Ampollas con base rosada, dolor intenso, blanquea a la presion. Cura en 10-21 dias"},{nombre:"Segundo grado profundo (dermica profunda)",descripcion:"Epidermis y dermis reticular. Ampollas con base palida, dolor disminuido, no blanquea bien. Requiere injerto frecuentemente"},{nombre:"Tercer grado (espesor total)",descripcion:"Destruccion de todas las capas de piel. Escara blanca, marron o negra, indolora, textura acartonada. Siempre requiere injerto"}]},diagnostico:{anamnesis:["Agente causal (termico, quimico, electrico, radiacion)","Tiempo de exposicion al agente","Ambiente cerrado o abierto (riesgo de lesion inhalatoria)","Hora exacta de la quemadura (para calculo de Parkland)","Primeros auxilios realizados (enfriamiento con agua)","Antecedentes: edad, comorbilidades, medicacion","Mecanismo compatible con maltrato en ni\xf1os (descartar)"],examenFisico:["Estimacion de SCQ con Regla de los 9 de Wallace (adultos) o tabla de Lund-Browder (ni\xf1os)","Evaluacion de profundidad de cada area quemada","Evaluacion de via aerea: edema facial, vibrisas quemadas, hollin, estridor, disfon\xeda","Busqueda de quemaduras circunferenciales (riesgo de sindrome compartimental)","Evaluacion de pulsos perifericos distales en extremidades quemadas","Examen neurologico (quemaduras electricas: arritmias y lesion muscular profunda)"],pruebas:[{nombre:"Laboratorio inicial de gran quemado",descripcion:"Hemograma, ionograma, funcion renal, gasometria, lactato, CPK (quemaduras electricas), carboxihemoglobina (si exposicion a humo), coagulacion, albumina",valoresReferencia:"Hto puede estar elevado por hemoconcentracion. CPK > 5000 U/L sugiere rabdomiolisis. COHb > 10% confirma intoxicacion por CO. Albumina < 2 g/dL indica perdida proteica severa",cuidadosEnfermeria:["Extraer muestras al canalizar via periferica","Solicitar carboxihemoglobina si sospecha de inhalacion de humo","Solicitar CPK seriada en quemaduras electricas","Repetir laboratorio cada 6-8 horas en fase de reanimacion"]},{nombre:"Fibrobroncoscopia",descripcion:"Gold standard para diagnostico de lesion inhalatoria. Visualiza edema, eritema, hollin y necrosis de mucosa de via aerea. Indicada ante sospecha clinica de lesion por inhalacion",valoresReferencia:"Normal: mucosa rosada sin edema. Patologica: eritema, edema, depositos de hollin, ulceracion de mucosa",cuidadosEnfermeria:["Paciente debe estar intubado o con via aerea asegurada","Preparar equipo de intubacion de emergencia","Monitorizar SpO2 continuamente durante el procedimiento","Vigilar broncoespasmo post-procedimiento"]},{nombre:"Electrocardiograma de 12 derivaciones",descripcion:"Obligatorio en quemaduras electricas. La corriente electrica puede causar arritmias fatales, da\xf1o miocardico y trastornos de conduccion",valoresReferencia:"Normal: ritmo sinusal, sin arritmias. Patologico: FA, TV, FV, bloqueos, cambios ST",cuidadosEnfermeria:["Realizar ECG inmediato en toda quemadura electrica","Monitorizar con telemetria por 24-48 horas minimo","Vigilar aparicion de arritmias tardias","Tener desfibrilador disponible"]}]},tratamientoMedico:{objetivos:["Mantener via aerea permeable (intubar precozmente si lesion inhalatoria)","Reanimacion hemodinamica con fluidos segun formula de Parkland","Prevencion de infeccion de herida por quemadura","Manejo adecuado del dolor","Soporte nutricional hipercalorico e hiperproteico","Cobertura cutanea definitiva lo antes posible"],farmacologico:[{nombre:"Ringer Lactato (Formula de Parkland)",grupo:"Cristaloide isot\xf3nico para reanimacion",mecanismo:"Repone volumen intravascular perdido por aumento de permeabilidad capilar. La formula de Parkland calcula: 4 mL x kg peso x % SCQ en primeras 24h; mitad en primeras 8h desde la quemadura, mitad restante en las siguientes 16h",dosis:"4 mL x kg x % SCQ en 24h. Ejemplo: 70 kg, 40% SCQ = 11.200 mL. Primeras 8h: 5.600 mL. Siguientes 16h: 5.600 mL. Ajustar segun diuresis objetivo",cuidadosEnfermeria:["Calcular volumen total y velocidad de infusion horaria","El tiempo se cuenta desde la HORA de la quemadura, no desde el ingreso","Objetivo de diuresis: 0.5-1 mL/kg/h en adultos, 1 mL/kg/h en ni\xf1os","Sonda vesical para control horario de diuresis","Ajustar goteo segun respuesta (diuresis es el mejor indicador)","Calentar fluidos a 39\xb0C para prevenir hipotermia"]},{nombre:"Sulfadiazina de plata 1% (crema topica)",grupo:"Antibiotico topico para quemaduras",mecanismo:"Libera iones de plata con accion bactericida de amplio espectro contra gram positivos, gram negativos y hongos. Forma pseudoescara protectora sobre la herida",dosis:"Aplicar capa de 2-3 mm sobre la superficie quemada cada 12-24 horas, previa limpieza de la herida",cuidadosEnfermeria:["Aplicar con tecnica aseptica y guantes esteriles","Retirar crema anterior con suero fisiologico tibio antes de reaplicar","Vigilar leucopenia transitoria (efecto adverso de sulfadiazina)","No utilizar en cara (usar bacitracina en su lugar)","Contraindicada en alergia a sulfonamidas y en embarazo a termino"]},{nombre:"Morfina IV",grupo:"Opioide analgesico mayor",mecanismo:"Agonista de receptores mu opioides. Produce analgesia potente. Las quemaduras superficiales son extremadamente dolorosas y requieren analgesia agresiva",dosis:"Adultos: 0.1 mg/kg IV en bolo, titular cada 5-10 min segun dolor. Infusion continua: 1-5 mg/h. PCA (analgesia controlada por paciente) si disponible",cuidadosEnfermeria:["Evaluar dolor con escala EVA antes y despues de administrar","Monitorizar FR (depresion respiratoria si FR < 10 rpm)","Tener naloxona disponible como antidoto","Administrar IV exclusivamente en gran quemado (absorcion IM erratica por edema)","Prevenir constipacion con laxantes profilacticos"]}],noFarmacologico:["Enfriamiento inicial con agua corriente (15-20\xb0C) por 20 minutos dentro de las primeras 3 horas","No aplicar hielo, pasta dental, mantequilla ni remedios caseros","Curacion con tecnica aseptica: limpieza, desbridamiento de tejido necrotico, cobertura","Elevacion de extremidades quemadas para reducir edema","Soporte nutricional precoz: formula de Curreri (25 kcal/kg + 40 kcal/%SCQ/dia)","Prevencion de hipotermia (ambiente a 28-33\xb0C, sabanas termicas)","Rehabilitacion temprana: movilizacion y ferulaje en posicion funcional"],quirurgico:["Escarotomia: incision de escara constrictiva en quemaduras circunferenciales para restaurar circulacion distal (urgencia en < 6h si pulsos ausentes)","Fasciotomia: liberacion de sindrome compartimental asociado a quemaduras electricas profundas","Escarectomia tangencial: reseccion del tejido necrotico hasta tejido viable sangrante","Injerto de piel autologa: cobertura definitiva con piel del propio paciente (autoinjerto laminar o mallado)","Cobertura temporal con aloinjerto, xenoinjerto o sustitutos dermicos"]},cuidadosEnfermeria:{valoracion:["Evaluar extension (regla de los 9 de Wallace) y profundidad de la quemadura","Monitorizar signos vitales cada hora en fase de reanimacion","Control estricto de diuresis horaria (indicador principal de reanimacion adecuada)","Evaluar via aerea continuamente (edema puede progresar en 24-48h)","Valorar dolor con escala adecuada (EVA, FLACC en ni\xf1os)","Evaluar pulsos perifericos en extremidades con quemaduras circunferenciales"],intervenciones:["Administrar fluidos IV segun formula de Parkland y ajustar por diuresis","Realizar curaciones con tecnica esteril segun protocolo del centro de quemados","Administrar analgesia anticipada antes de curaciones","Mantener posicion funcional de articulaciones con ferulas","Prevencion de infeccion: aislamiento protector, tecnica aseptica estricta","Cuidado emocional: apoyo psicologico, presencia familiar cuando sea posible"],educacionPaciente:["Ense\xf1ar cuidado de heridas y signos de infeccion al alta","Explicar la importancia de la rehabilitacion y uso de prendas compresivas","Instruir sobre proteccion solar permanente de areas injertadas","Educar sobre prevencion de quemaduras en el hogar (especialmente con ni\xf1os)","Brindar informacion sobre apoyo psicologico y grupos de pares","Explicar el proceso de cicatrizacion y expectativas esteticas realistas"],monitorizacion:["Diuresis horaria (meta 0.5-1 mL/kg/h adulto, 1 mL/kg/h ni\xf1o)","Signos vitales cada hora en primeras 48h","Balance hidrico estricto cada 4 horas","Temperatura central cada 2 horas (hipotermia frecuente)","Laboratorio seriado: hemoglobina, electrolitos, albumina, funcion renal","Cultivos de herida semanales o ante sospecha de infeccion"]},npiNanda:[{codigo:"00044",nombre:"Deterioro de la integridad tisular",definicion:"Da\xf1o a las membranas mucosas, tegumentaria o subcutanea",caracteristicasDefinitorias:["Destruccion de capas de la piel","Eritema, ampollas o escaras","Exposicion de tejido subcutaneo","Exudado de la herida"],factoresRelacionados:["Agente termico, quimico o electrico","Exposicion a temperaturas extremas","Destruccion de la barrera cutanea"]},{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable asociada a da\xf1o tisular real",caracteristicasDefinitorias:["Expresion facial de dolor","Conducta de proteccion de area quemada","Taquicardia y diaforesis","Verbalizacion del dolor"],factoresRelacionados:["Lesion tisular por quemadura","Exposicion de terminaciones nerviosas","Procedimientos de curacion"]},{codigo:"00028",nombre:"Riesgo de deficit de volumen de liquidos",definicion:"Vulnerable a experimentar disminucion del volumen de liquido intravascular, intersticial o intracelular que puede comprometer la salud",caracteristicasDefinitorias:["Aumento de permeabilidad capilar","Perdida de plasma al intersticio","Hemoconcentracion","Taquicardia e hipotension"],factoresRelacionados:["Quemadura extensa (> 20% SCQ)","Perdida de liquidos por evaporacion","Edema masivo por aumento de permeabilidad"]}],npiNic:[{codigo:"3661",nombre:"Cuidado de las heridas: quemaduras",actividades:["Realizar curacion con tecnica aseptica y material esteril","Aplicar agente topico prescrito (sulfadiazina de plata u otro)","Evaluar herida: profundidad, extension, signos de infeccion","Desbridar tejido necrotico segun indicacion","Mantener ambiente humedo de cicatrizacion"]},{codigo:"4120",nombre:"Manejo de liquidos",actividades:["Calcular requerimientos segun formula de Parkland","Administrar fluidos IV a velocidad calculada","Ajustar goteo segun diuresis horaria","Monitorizar signos de sobrecarga o deficit de volumen","Registrar balance hidrico estricto"]},{codigo:"1400",nombre:"Manejo del dolor",actividades:["Evaluar dolor con escala validada antes y despues de intervenciones","Administrar analgesia anticipada antes de curaciones","Implementar medidas no farmacologicas (distraccion, musica, realidad virtual)","Titular opioides segun respuesta y efectos adversos","Documentar patron de dolor y respuesta a tratamiento"]}],npiNoc:[{codigo:"1102",nombre:"Curacion de la herida: por segunda intencion",indicadores:["Reduccion del tama\xf1o de la herida","Formacion de tejido de granulacion","Ausencia de signos de infeccion","Reepitelizacion progresiva"],escala:"1=Ninguno, 2=Escaso, 3=Moderado, 4=Sustancial, 5=Extenso"},{codigo:"2102",nombre:"Nivel del dolor",indicadores:["Dolor referido (escala EVA)","Expresion facial de dolor","Inquietud y agitacion","Frecuencia cardiaca en rango"],escala:"1=Grave, 2=Sustancial, 3=Moderado, 4=Leve, 5=Ninguno"}],complicaciones:["Shock hipovolemico por perdida masiva de plasma","Infeccion de herida por quemadura y sepsis (causa principal de muerte tardia)","Sindrome compartimental por quemaduras circunferenciales","Lesion inhalatoria con insuficiencia respiratoria aguda","Intoxicacion por monoxido de carbono o cianuro","Insuficiencia renal aguda por rabdomiolisis (quemaduras electricas)","Cicatrices hipertroficas y queloides","Contracturas articulares"],criteriosAlarma:["SCQ > 20% en adultos o > 10% en ni\xf1os y ancianos","Quemaduras de via aerea: estridor, disfon\xeda, esputo carbonaceo","Quemaduras circunferenciales en extremidades o torax","Quemadura electrica de alta tension","Diuresis < 0.5 mL/kg/h a pesar de reposicion adecuada","Signos de infeccion: fiebre, cambio de coloracion o exudado purulento en herida","Mioglobinuria (orina oscura en quemaduras electricas)"],emergencyLevel:"critico",relatedPathologyIds:["pat_politraumatismo","pat_shock_hipovolemico","pat_ira","pat_sepsis"],isPremium:!1},{id:"pat_lesion_medular",nombre:"Lesion Medular Traumatica",bodySystemId:"traumatologico",definicion:"Da\xf1o a la medula espinal causado por un traumatismo que produce alteracion temporal o permanente de la funcion motora, sensitiva y autonomica por debajo del nivel de la lesion. Puede ser completa (perdida total de funcion) o incompleta (preservacion parcial de funcion por debajo del nivel lesional).",epidemiologia:"Incidencia mundial de 10-83 casos por millon de habitantes/a\xf1o. En Argentina, se estiman 2.000-3.000 nuevos casos anuales. Predominio en varones jovenes (15-35 a\xf1os), relacion hombre/mujer 4:1. Causas: accidentes de transito (40-50%), caidas (20-30%), violencia (10-15%), deportes (5-10%). Nivel cervical es el mas frecuente (55%). Mortalidad en el primer a\xf1o: 5-7% en paises desarrollados.",factoresRiesgo:["Accidentes de transito a alta velocidad","Zambullidas en aguas poco profundas","Caidas de altura (laboral, domiciliaria)","Deportes de contacto o extremos","Violencia con armas de fuego","Edad avanzada (caidas con espondilosis cervical previa)","Estenosis espinal preexistente","Osteoporosis (fracturas vertebrales con trauma menor)"],fisiopatologia:"La lesion primaria ocurre por compresion, flexion, extension, rotacion o distraccion de la columna vertebral que da\xf1a la medula. La lesion secundaria involucra edema medular, isquemia por da\xf1o vascular, liberacion de glutamato (excitotoxicidad), ingreso masivo de calcio intracelular, formacion de radicales libres y apoptosis neuronal progresiva. El shock medular (fase aguda) produce arreflexia flacida completa por debajo de la lesion que puede durar dias a semanas. El shock neurogenico ocurre en lesiones por encima de T6: la perdida del tono simpatico produce bradicardia e hipotension por vasodilatacion (a diferencia del shock hipovolemico donde hay taquicardia). Meses despues, la disreflexia autonomica puede presentarse en lesiones por encima de T6: un estimulo nocivo por debajo de la lesion (vejiga distendida, fecaloma) desencadena respuesta simpatica masiva con hipertension severa, bradicardia, cefalea y riesgo de ACV.",signosYSintomas:{signos:["Perdida de fuerza muscular por debajo del nivel de lesion","Perdida de sensibilidad por debajo del nivel de lesion","Arreflexia en fase de shock medular, luego espasticidad","Hipotension con bradicardia (shock neurogenico en lesiones cervicales/toracicas altas)","Priapismo (signo de lesion medular completa)","Patron respiratorio alterado (paralisis diafragmatica si lesion C3-C5)","Retencion urinaria (vejiga neurogenica)","Ileo paralitico (perdida de motilidad intestinal)"],sintomas:["Dolor en region de la fractura vertebral","Hormigueo o parestesias en extremidades","Debilidad o paralisis de extremidades","Incapacidad para mover piernas o brazos","Sensacion de entumecimiento","Dificultad respiratoria (lesiones cervicales)"]},clasificacion:{nombre:"Clasificacion ASIA (American Spinal Injury Association)",tipos:[{nombre:"ASIA A - Completa",descripcion:"Sin funcion motora ni sensitiva en segmentos sacros S4-S5. Pronostico de recuperacion: minimo"},{nombre:"ASIA B - Sensitiva incompleta",descripcion:"Preservacion sensitiva pero no motora por debajo del nivel, incluyendo S4-S5. Pronostico de recuperacion motora: 15-30%"},{nombre:"ASIA C - Motora incompleta (debil)",descripcion:"Funcion motora preservada por debajo del nivel pero mas de la mitad de musculos clave con fuerza < 3/5"},{nombre:"ASIA D - Motora incompleta (util)",descripcion:"Funcion motora preservada por debajo del nivel con al menos la mitad de musculos clave con fuerza >= 3/5. Mejor pronostico funcional"}]},diagnostico:{anamnesis:["Mecanismo de lesion (hiperflexion, hiperextension, carga axial, rotacion)","Presencia de deficit neurologico desde el inicio","Dolor cervical o dorsolumbar post-trauma","Parestesias o debilidad en extremidades","Perdida de control de esfinteres","Antecedentes de patologia espinal previa"],examenFisico:["Evaluacion ASIA estandarizada: fuerza en 10 musculos clave bilaterales (C5 a S1)","Evaluacion sensitiva en 28 dermatomas bilaterales (tacto fino y pinprick)","Determinacion del nivel neurologico de la lesion","Evaluacion de funcion sacra: sensibilidad perianal, contraccion voluntaria del esfinter anal","Reflejos: osteotendinosos, bulbocavernoso (fin del shock medular), cremasterico","Evaluacion de patron respiratorio y capacidad vital forzada"],pruebas:[{nombre:"Radiografia de columna vertebral",descripcion:"Estudio inicial para detectar fracturas, luxaciones y malalienamiento. Incluye AP, lateral y transoral (C1-C2) en columna cervical. Limitada en visualizacion de medula",valoresReferencia:"Normal: alineacion vertebral conservada, espacios intervertebrales regulares, sin fracturas",cuidadosEnfermeria:["Mantener inmovilizacion cervical durante todo el estudio","No flexionar ni rotar el cuello del paciente","Utilizar tecnica de log-roll para posicionar","Retirar collar solo si estudio autorizado por medico"]},{nombre:"TAC de columna vertebral",descripcion:"Superior a Rx para detallar fracturas, fragmentos oseos en canal medular y estabilidad vertebral. Estudio de eleccion en politraumatizados con TAC corporal total",valoresReferencia:"Normal: sin fracturas, canal medular permeable, facetas articulares alineadas",cuidadosEnfermeria:["Mantener inmovilizacion durante todo el estudio","Monitorizar signos vitales (riesgo de shock neurogenico)","Verificar estabilidad hemodinamica antes de trasladar","Acompa\xf1ar con monitor y equipo de via aerea"]},{nombre:"Resonancia magnetica de columna",descripcion:"Gold standard para evaluar medula espinal, discos, ligamentos y compresion medular. Identifica edema medular, hemorragia intramedular y hernias discales traumaticas",valoresReferencia:"Normal: medula de calibre y se\xf1al normales, sin compresion, ligamentos intactos. Patologico: se\xf1al hiperintensa en T2 indica edema; hipointensa en T2 indica hemorragia (peor pronostico)",cuidadosEnfermeria:["Verificar contraindicaciones para RM (material ferromagnetico, marcapasos)","Mantener monitorizacion hemodinamica durante el estudio","Sedacion puede ser necesaria en pacientes agitados","Estudio puede durar 30-45 minutos: vigilar estabilidad"]}]},tratamientoMedico:{objetivos:["Estabilizar la columna y prevenir da\xf1o medular adicional","Mantener perfusion medular adecuada (PAM > 85-90 mmHg primera semana)","Prevenir y tratar complicaciones del shock neurogenico","Rehabilitacion precoz para maximizar funcion residual","Manejo de vejiga e intestino neurogenico"],farmacologico:[{nombre:"Noradrenalina o dopamina",grupo:"Vasopresores",mecanismo:"Contrarrestan la hipotension del shock neurogenico (perdida del tono simpatico) mediante vasoconstriccion y aumento de PA. Objetivo: PAM > 85-90 mmHg en la primera semana para optimizar perfusion medular",dosis:"Noradrenalina: 0.01-0.3 mcg/kg/min IV. Dopamina: 5-20 mcg/kg/min IV. Titular segun PAM",cuidadosEnfermeria:["Administrar por via central exclusivamente","Monitorizar PA invasiva (linea arterial) si disponible","Vigilar bradicardia asociada al shock neurogenico","Tener atropina disponible para bradicardia severa (FC < 40)","Registrar PAM horaria como objetivo principal"]},{nombre:"Atropina",grupo:"Anticolinergico",mecanismo:"Bloquea receptores muscarinicos, aumentando la frecuencia cardiaca. Indicada para bradicardia sintomatica del shock neurogenico (predominio vagal por perdida del tono simpatico)",dosis:"0.5-1 mg IV en bolo, repetir cada 3-5 minutos si necesario. Maximo: 3 mg",cuidadosEnfermeria:["Tener jeringa precargada en cabecera del paciente con lesion cervical","Monitorizar ECG continuo","Vigilar respuesta en FC post-administracion","Precaucion: puede causar retencion urinaria (ya presente en lesion medular)"]},{nombre:"Heparina de bajo peso molecular (enoxaparina)",grupo:"Anticoagulante profilactico",mecanismo:"Inhibe factor Xa para prevenir trombosis venosa profunda. Los pacientes con lesion medular tienen riesgo extremadamente alto de TVP/TEP (hasta 40% sin profilaxis) por estasis venosa, inmovilidad y hipercoagulabilidad",dosis:"Enoxaparina 40 mg SC cada 24h. Iniciar dentro de las 72h post-lesion si no hay contraindicacion hemorragica",cuidadosEnfermeria:["Administrar en tejido subcutaneo abdominal, rotar sitios","No aspirar ni frotar post-inyeccion","Vigilar signos de sangrado (hematomas, melena, epistaxis)","Controlar recuento plaquetario (riesgo de HIT)","Combinar con medias compresivas y dispositivos de compresion neumatica"]}],noFarmacologico:["Inmovilizacion con collar cervical rigido y tabla espinal hasta estabilizacion definitiva","Manejo de via aerea: intubacion precoz si lesion cervical alta (C3-C5 compromete diafragma)","Programa de cateterismo intermitente limpio cada 4-6 horas (vejiga neurogenica)","Programa intestinal: dieta rica en fibra, estimulacion digital, supositorios cada 48h","Prevencion de ulceras por presion: cambios posturales cada 2 horas, colchon especial","Rehabilitacion kinesiologica precoz: movilizacion pasiva y activa asistida","Soporte psicologico y acompa\xf1amiento familiar desde fase aguda"],quirurgico:["Descompresion medular urgente (dentro de 24h si compresion medular progresiva)","Fijacion y artrodesis vertebral (estabilizacion instrumentada de columna inestable)","Reduccion cerrada de luxaciones cervicales con halo craneal y traccion","Laminectomia descompresiva en canal estrecho con compresion posterior"]},cuidadosEnfermeria:{valoracion:["Evaluacion neurologica con escala ASIA cada turno en fase aguda","Monitorizar PA y FC continuamente (shock neurogenico)","Evaluar patron respiratorio y capacidad vital (lesiones cervicales)","Valorar funcion vesical: distension abdominal, globo vesical residual","Valorar funcion intestinal: presencia de peristaltismo, distension","Inspeccionar piel en prominencias oseas cada turno"],intervenciones:["Mantener inmovilizacion de columna hasta estabilizacion quirurgica","Administrar vasopresores para mantener PAM > 85 mmHg","Realizar cateterismo vesical intermitente cada 4-6 horas","Implementar programa intestinal con horario regular","Cambios posturales cada 2 horas con tecnica de log-roll","Prevencion de TVP: medias compresivas + heparina + ejercicios pasivos","Mantener via aerea permeable: aspiracion de secreciones, tos asistida"],educacionPaciente:["Ense\xf1ar autocateterismo vesical intermitente cuando sea posible","Instruir sobre manejo intestinal autonomo","Educar sobre prevencion y deteccion de ulceras por presion","Explicar signos de disreflexia autonomica y actuacion inmediata","Ense\xf1ar ejercicios de fortalecimiento y transferencias","Informar sobre recursos de rehabilitacion y reinsercion social","Apoyo emocional: duelo por la perdida funcional, derivar a psicologia"],monitorizacion:["Signos vitales cada hora en fase aguda (PA, FC, FR, SpO2, T\xb0)","Balance hidrico cada 4 horas","Evaluacion neurologica ASIA cada 8-12 horas","Volumen de cateterismo vesical (objetivo < 500 mL por cateterizacion)","Inspeccion cutanea cada turno en prominencias oseas","Capacidad vital forzada diaria en lesiones cervicales"]},npiNanda:[{codigo:"00085",nombre:"Deterioro de la movilidad fisica",definicion:"Limitacion del movimiento fisico independiente e intencionado del cuerpo o de una o mas extremidades",caracteristicasDefinitorias:["Incapacidad para mover extremidades inferiores o las cuatro extremidades","Disminucion de la fuerza muscular","Espasticidad o flacidez muscular","Dependencia total para movilidad"],factoresRelacionados:["Lesion medular con da\xf1o de vias motoras","Paralisis por debajo del nivel de lesion","Espasticidad muscular"]},{codigo:"00016",nombre:"Deterioro de la eliminacion urinaria",definicion:"Disfuncion en la eliminacion de orina",caracteristicasDefinitorias:["Retencion urinaria","Incontinencia por rebosamiento","Infecciones urinarias recurrentes","Ausencia de sensacion de vejiga llena"],factoresRelacionados:["Vejiga neurogenica por lesion medular","Perdida de control voluntario del esfinter","Disinergia detrusor-esfinter"]},{codigo:"00047",nombre:"Riesgo de deterioro de la integridad cutanea",definicion:"Vulnerable a una alteracion en epidermis y/o dermis que puede comprometer la salud",caracteristicasDefinitorias:["Inmovilidad prolongada","Perdida de sensibilidad","Humedad por incontinencia"],factoresRelacionados:["Presion sostenida en prominencias oseas","Perdida de sensibilidad protectora","Inmovilidad por paralisis","Alteracion de la circulacion"]}],npiNic:[{codigo:"0840",nombre:"Cambio de posicion",actividades:["Realizar cambios posturales cada 2 horas con tecnica de log-roll","Utilizar almohadas para alinear columna y proteger prominencias","Inspeccionar piel en cada cambio de posicion","Documentar posicion y hora en registro de enfermeria","Coordinar con fisioterapia para movilizacion segura"]},{codigo:"0580",nombre:"Sondaje vesical intermitente",actividades:["Realizar cateterismo con tecnica aseptica cada 4-6 horas","Registrar volumen de orina obtenido en cada cateterismo","Evaluar residuo post-miccional si hay miccion espontanea","Ense\xf1ar autocateterismo al paciente cuando sea viable","Vigilar signos de infeccion urinaria"]},{codigo:"2660",nombre:"Manejo de la disreflexia autonomica",actividades:["Reconocer signos: hipertension subita, cefalea, sudoracion, rubor facial","Sentar al paciente inmediatamente (reduce PA por efecto gravitacional)","Buscar y eliminar estimulo desencadenante (vejiga distendida, fecaloma, ropa ajustada)","Vaciar vejiga con sondaje si esta distendida","Administrar nifedipina sublingual si PA no desciende y notificar al medico"]}],npiNoc:[{codigo:"0208",nombre:"Movilidad",indicadores:["Mantenimiento de posicion corporal","Movimiento articular en rangos preservados","Capacidad de transferencia (cama-silla)","Ambulacion con dispositivos de ayuda si aplica"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"},{codigo:"1101",nombre:"Integridad tisular: piel y membranas mucosas",indicadores:["Piel intacta en prominencias oseas","Temperatura cutanea normal","Hidratacion cutanea adecuada","Ausencia de lesiones por presion"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"}],complicaciones:["Disreflexia autonomica (emergencia hipertensiva en lesiones sobre T6)","Trombosis venosa profunda y tromboembolismo pulmonar","Ulceras por presion (sacro, trocanteres, talones, isquiones)","Infecciones urinarias recurrentes y litiasis renal","Neumonias por hipoventilacion y acumulacion de secreciones","Osificacion heterotopica (formacion de hueso en tejidos blandos)","Dolor neuropatico cronico por debajo de la lesion","Depresion y trastorno de adaptacion"],criteriosAlarma:["Hipertension subita > 200/100 mmHg con cefalea (disreflexia autonomica)","Deterioro del nivel neurologico (progresion del nivel de lesion)","Dificultad respiratoria progresiva (fallo diafragmatico en lesion cervical)","Fiebre con orina turbia o maloliente (infeccion urinaria complicada)","Signos de TEP: disnea subita, dolor toracico, desaturacion","Lesion cutanea en prominencia osea que no blanquea (UPP grado I)"],emergencyLevel:"critico",relatedPathologyIds:["pat_tce","pat_politraumatismo","pat_fracturas_extremidades","pat_tvp"],isPremium:!1},{id:"pat_trauma_toracico",nombre:"Trauma Toracico",bodySystemId:"traumatologico",definicion:"Lesion traumatica de la pared toracica y/o su contenido (pulmones, corazon, grandes vasos, esofago, arbol traqueobronquial y diafragma) causada por mecanismo cerrado o penetrante. Es responsable del 25% de las muertes por trauma. La mayoria se resuelve con tubo de drenaje toracico sin necesidad de toracotomia.",epidemiologia:"Presente en el 50% de los politraumatismos. Causa directa del 25% de las muertes por trauma. El 85% se maneja con drenaje toracico y medidas de soporte. Solo el 10-15% requiere toracotomia. Las fracturas costales son la lesion mas frecuente. El neumotorax a tension y el taponamiento cardiaco son las emergencias letales mas importantes, ambas diagnosticables clinicamente sin necesidad de imagen.",factoresRiesgo:["Accidentes de transito (impacto frontal con volante, aplastamiento)","Caidas de altura","Heridas por arma blanca o arma de fuego en torax","Explosiones (onda expansiva causa blast pulmonar)","Deportes de contacto y violencia interpersonal","Edad avanzada (mayor fragilidad costal, menor reserva pulmonar)","EPOC o patologia pulmonar preexistente","Uso de anticoagulantes (mayor riesgo de hemotorax)"],fisiopatologia:"El trauma toracico altera la mecanica respiratoria y/o la funcion cardiovascular. El neumotorax a tension se produce cuando el aire entra al espacio pleural por un mecanismo valvular unidireccional: el pulmon se colapsa, el mediastino se desvia al lado contralateral comprimiendo el pulmon sano y las venas cavas, reduciendo el retorno venoso y causando shock obstructivo rapidamente fatal. El hemotorax resulta de hemorragia en espacio pleural por lesion de vasos intercostales, parenquima pulmonar o grandes vasos. El taponamiento cardiaco se produce por acumulacion de sangre en pericardio (tan poco como 150-200 mL pueden ser fatales) que comprime las camaras cardiacas impidiendo el llenado diastolico. El torax inestable (volet costal) ocurre cuando tres o mas costillas se fracturan en dos puntos cada una, creando un segmento flotante con movimiento paradojico que compromete la ventilacion; sin embargo, la contusion pulmonar subyacente es la principal causa de insuficiencia respiratoria.",signosYSintomas:{signos:["Ausencia de murmullo vesicular unilateral (neumotorax, hemotorax)","Hipotension con ingurgitacion yugular (taponamiento cardiaco, neumotorax a tension)","Desviacion traqueal contralateral (neumotorax a tension)","Enfisema subcutaneo (crepitacion palpable en piel)","Movimiento paradojico de pared toracica (torax inestable)","Matidez a la percusion (hemotorax) o timpanismo (neumotorax)","Triada de Beck: hipotension, ingurgitacion yugular, tonos cardiacos apagados (taponamiento)","Taquicardia y taquipnea"],sintomas:["Disnea (sintoma mas frecuente)","Dolor toracico que aumenta con la respiracion","Dificultad para respirar profundamente","Sensacion de presion en el pecho","Ansiedad y sensacion de muerte inminente"]},clasificacion:{nombre:"Clasificacion segun lesion predominante",tipos:[{nombre:"Neumotorax a tension",descripcion:"Emergencia letal. Aire a presion en espacio pleural con colapso pulmonar y desviacion mediastinal. Diagnostico CLINICO, tratamiento INMEDIATO con descompresion con aguja (2do espacio intercostal linea medioclavicular)"},{nombre:"Hemotorax masivo",descripcion:"Acumulacion > 1500 mL de sangre en espacio pleural o drenaje > 200 mL/h por 2-4 horas. Requiere drenaje toracico y posible toracotomia"},{nombre:"Taponamiento cardiaco",descripcion:"Sangre en pericardio que impide llenado cardiaco. Triada de Beck clasica. Tratamiento: pericardiocentesis de emergencia o toracotomia"},{nombre:"Torax inestable (volet costal)",descripcion:"Fractura de 3+ costillas consecutivas en 2 puntos. Segmento flotante con respiracion paradojica. La contusion pulmonar subyacente determina la gravedad"}]},diagnostico:{anamnesis:["Mecanismo de trauma (cerrado vs penetrante, velocidad, arma utilizada)","Localizacion del impacto o la herida","Tiempo transcurrido desde el evento","Dificultad respiratoria progresiva o subita","Dolor toracico y su relacion con la respiracion","Hemoptisis (sugiere lesion pulmonar o via aerea)"],examenFisico:["Inspeccion: asimetria toracica, heridas, movimiento paradojico, uso de musculos accesorios","Palpacion: crepitacion costal, enfisema subcutaneo, desviacion traqueal","Percusion: matidez (hemotorax/derrame) o timpanismo (neumotorax)","Auscultacion: murmullo vesicular bilateral, tonos cardiacos","Evaluacion de ingurgitacion yugular (aumentada en taponamiento y neumotorax a tension)","Saturacion de oxigeno y patron respiratorio"],pruebas:[{nombre:"Radiografia de torax anteroposterior",descripcion:"Estudio inicial en trauma toracico. Detecta neumotorax (> 10%), hemotorax (> 200 mL), fracturas costales, ensanchamiento mediastinal (sospecha de lesion aortica). Se realiza en posicion supina en el paciente traumatizado",valoresReferencia:"Normal: pulmones expandidos bilateralmente, senos costodiafragmaticos libres, mediastino de ancho normal, sin fracturas",cuidadosEnfermeria:["Mantener inmovilizacion cervical si no descartada lesion","Radiografia portatil en sala de emergencia (no trasladar paciente inestable)","Evaluar resultado inmediatamente con equipo de trauma","Preparar equipo de drenaje toracico si hallazgos patologicos"]},{nombre:"EFAST (Extended FAST)",descripcion:"Ecografia rapida que incluye ventanas pulmonares para detectar neumotorax (ausencia de deslizamiento pleural) y hemotorax, ademas de las ventanas abdominales y pericardica. Sensibilidad > 95% para neumotorax",valoresReferencia:"Normal: deslizamiento pleural bilateral presente, sin derrame pleural ni pericardico. Patologico: ausencia de sliding (neumotorax), coleccion en senos (hemotorax), derrame pericardico",cuidadosEnfermeria:["Facilitar acceso al torax (retirar ropa)","Puede realizarse simultaneamente con la reanimacion","Documentar hallazgos y comunicar al equipo","Preparar para intervencion segun resultado"]},{nombre:"Tomografia computarizada de torax con contraste",descripcion:"Estudio mas sensible para neumotorax oculto, contusion pulmonar, lesion de grandes vasos y fracturas. Solo en paciente hemodinamicamente estable",valoresReferencia:"Normal: parenquima pulmonar sin opacidades, sin colecciones pleurales, aorta y vasos de calibre normal, sin fracturas",cuidadosEnfermeria:["Solo trasladar si paciente estable hemodinamicamente","Via periferica gruesa para contraste IV","Monitorizar durante el traslado y el estudio","Comunicar alergia a contraste iodado si existe"]}]},tratamientoMedico:{objetivos:["Identificar y tratar lesiones inmediatamente letales (neumotorax a tension, taponamiento cardiaco, hemotorax masivo)","Restaurar la mecanica respiratoria y el intercambio gaseoso","Controlar la hemorragia intratoracica","Mantener estabilidad hemodinamica","Analgesia efectiva para permitir ventilacion adecuada"],farmacologico:[{nombre:"Bloqueo intercostal con bupivacaina",grupo:"Anestesico local de larga duracion",mecanismo:"Bloquea la conduccion nerviosa intercostal, proporcionando analgesia de 6-12 horas. Mejora la mecanica respiratoria al permitir respiracion profunda y tos efectiva, reduciendo riesgo de atelectasia y neumonia",dosis:"Bupivacaina 0.5%: 2-3 mL por nivel intercostal, bloqueando el nervio afectado y los adyacentes superior e inferior. Maximo: 2 mg/kg",cuidadosEnfermeria:["Verificar ausencia de alergia a anestesicos locales tipo amida","Monitorizar signos de toxicidad sistemica (mareo, tinnitus, convulsiones)","Evaluar eficacia analgesica post-bloqueo con escala de dolor","Vigilar neumotorax iatrogeno post-procedimiento (complicacion rara)"]},{nombre:"Ketorolac",grupo:"AINE (antiinflamatorio no esteroideo)",mecanismo:"Inhibe la ciclooxigenasa (COX-1 y COX-2) reduciendo la sintesis de prostaglandinas. Potente analgesico con efecto ahorrador de opioides en dolor por fracturas costales",dosis:"30 mg IV cada 6-8 horas. Maximo 5 dias de uso. Reducir a 15 mg en ancianos o insuficiencia renal",cuidadosEnfermeria:["Administrar IV lento en 15 segundos minimo","Vigilar sangrado gastrointestinal y funcion renal","Contraindicado en insuficiencia renal, ulcera peptica activa y coagulopatia","Combinar con opioide para analgesia multimodal"]},{nombre:"Morfina IV titulada",grupo:"Opioide analgesico mayor",mecanismo:"Agonista mu opioide para analgesia potente. En trauma toracico, el dolor mal controlado limita la ventilacion y causa atelectasia, neumonia y fallo respiratorio",dosis:"2-4 mg IV cada 5-10 min hasta control del dolor. Infusion continua: 1-3 mg/h. PCA si disponible",cuidadosEnfermeria:["Monitorizar FR (suspender si FR < 10 rpm)","Tener naloxona disponible (0.4 mg IV)","Evaluar dolor con EVA antes y despues de dosis","Balance entre analgesia y depresion respiratoria","Vigilar sedacion excesiva con escala de Ramsay"]}],noFarmacologico:["Descompresion con aguja (14G, 2do espacio intercostal, linea medioclavicular) en neumotorax a tension (antes de Rx)","Tubo de drenaje toracico (28-32 Fr) en 5to espacio intercostal, linea axilar media","Oxigenoterapia con FiO2 segun necesidad (canula nasal, mascara o ARM)","Ventilacion mecanica no invasiva o invasiva si insuficiencia respiratoria","Posicion semisentada para facilitar la mecanica respiratoria","Kinesioterapia respiratoria precoz: inspirometria incentivada, tos asistida"],quirurgico:["Toracotomia de emergencia (taponamiento cardiaco no respondedor, hemorragia masiva, lesion de grandes vasos)","Toracotomia de resucitacion en paro cardiaco traumatico por herida penetrante","Videotoracoscopia (VATS) para hemotorax retenido o fuga aerea persistente","Fijacion quirurgica de fracturas costales (torax inestable severo con ventilacion mecanica prolongada)","Pericardiocentesis de emergencia guiada por ecografia (puente a toracotomia en taponamiento)"]},cuidadosEnfermeria:{valoracion:["Evaluar patron respiratorio: FR, profundidad, simetria, uso de musculos accesorios","Auscultar campos pulmonares bilateralmente cada hora","Monitorizar SpO2 continua y gasometria arterial segun indicacion","Evaluar dolor con escala EVA y su impacto en la ventilacion","Inspeccionar heridas penetrantes y su evolucion","Vigilar debito del tubo de drenaje toracico (cantidad, color, oscilacion)"],intervenciones:["Mantener permeabilidad del tubo de drenaje toracico (orde\xf1ar si coagulos)","Registrar debito del drenaje cada hora (volumen y caracteristicas)","Administrar analgesia pautada y rescate para permitir ventilacion efectiva","Fomentar kinesioterapia respiratoria: inspirometria incentivada cada 1-2 horas","Mantener sello de agua del drenaje (nunca elevar frasco por encima del torax)","Aspirar secreciones si paciente en ventilacion mecanica"],educacionPaciente:["Ense\xf1ar ejercicios respiratorios y uso de inspirometro incentivado","Explicar la importancia de la tos efectiva a pesar del dolor","Instruir sobre cuidados del drenaje toracico si se va a domicilio con el","Educar sobre signos de alarma: dificultad respiratoria, fiebre, dolor que empeora","Explicar el proceso de recuperacion y tiempos esperados","Instruir sobre limitacion de actividad fisica y retorno gradual"],monitorizacion:["SpO2 continua y gasometria arterial seriada","Debito del drenaje toracico cada hora (alertar si > 200 mL/h)","Radiografia de torax de control post-drenaje y diaria","Signos vitales cada hora en fase aguda (PA, FC, FR, T\xb0)","Evaluacion del dolor cada 2-4 horas"]},npiNanda:[{codigo:"00032",nombre:"Patron respiratorio ineficaz",definicion:"Inspiracion y/o espiracion que no proporciona una ventilacion adecuada",caracteristicasDefinitorias:["Disnea","Taquipnea","Uso de musculos accesorios","Disminucion de la expansion toracica","Respiracion superficial por dolor"],factoresRelacionados:["Dolor por fracturas costales","Neumotorax o hemotorax","Torax inestable","Contusion pulmonar"]},{codigo:"00030",nombre:"Deterioro del intercambio gaseoso",definicion:"Exceso o deficit en la oxigenacion y/o eliminacion de dioxido de carbono a traves de la membrana alveolocapilar",caracteristicasDefinitorias:["Hipoxemia (PaO2 < 60 mmHg)","Hipercapnia","Cianosis central","Disnea y agitacion"],factoresRelacionados:["Contusion pulmonar con shunt intrapulmonar","Colapso pulmonar por neumotorax","Hemotorax que comprime parenquima","Atelectasia por hipoventilacion"]},{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable asociada a da\xf1o tisular real o potencial",caracteristicasDefinitorias:["Expresion facial de dolor","Proteccion del area afectada","Taquicardia","Restriccion voluntaria de la respiracion"],factoresRelacionados:["Fracturas costales","Lesion de tejidos blandos de pared toracica","Tubo de drenaje toracico in situ"]}],npiNic:[{codigo:"3350",nombre:"Monitorizacion respiratoria",actividades:["Auscultar campos pulmonares bilateralmente cada hora","Monitorizar SpO2 continua y correlacionar con clinica","Evaluar patron respiratorio: frecuencia, profundidad, simetria","Solicitar gasometria arterial ante cambios en oxigenacion","Detectar signos precoces de insuficiencia respiratoria"]},{codigo:"1872",nombre:"Cuidado del drenaje toracico",actividades:["Verificar integridad del sistema de drenaje (conexiones, sello de agua)","Registrar debito horario: volumen, color, presencia de burbujeo","Mantener frasco recolector por debajo del nivel del torax","Evaluar oscilacion del nivel de agua con la respiracion (confirma permeabilidad)","Clampar solo cuando se indica (cambio de frasco) nunca de rutina"]},{codigo:"1400",nombre:"Manejo del dolor",actividades:["Evaluar dolor con escala EVA sistematicamente","Administrar analgesia pautada + rescates (no esperar que el paciente pida)","Implementar analgesia multimodal (AINE + opioide + bloqueo regional)","Evaluar impacto del dolor en la mecanica respiratoria","Coordinar administracion de analgesia con kinesioterapia respiratoria"]}],npiNoc:[{codigo:"0415",nombre:"Estado respiratorio",indicadores:["Frecuencia respiratoria en rango normal (12-20 rpm)","SpO2 > 95%","Expansion toracica simetrica","Murmullo vesicular presente bilateralmente","Ausencia de disnea en reposo"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"},{codigo:"2102",nombre:"Nivel del dolor",indicadores:["Dolor referido (EVA < 4 en reposo)","Capacidad de respirar profundamente","Capacidad de toser efectivamente","Ausencia de restriccion ventilatoria por dolor"],escala:"1=Grave, 2=Sustancial, 3=Moderado, 4=Leve, 5=Ninguno"}],complicaciones:["Neumotorax a tension (letal si no se descomprime)","Hemotorax masivo con shock hemorragico","Taponamiento cardiaco","Contusion pulmonar con SDRA","Contusion miocardica con arritmias","Rotura traumatica de aorta toracica","Empiema (infeccion de hemotorax retenido)","Neumonia nosocomial post-traumatica"],criteriosAlarma:["Ausencia unilateral de murmullo vesicular con inestabilidad hemodinamica (neumotorax a tension)","Debito del drenaje toracico > 200 mL/h por 2-4 horas (hemotorax masivo: indicacion quirurgica)","Triada de Beck: hipotension + yugulares ingurgitadas + ruidos cardiacos apagados (taponamiento)","SpO2 < 90% a pesar de oxigenoterapia","Enfisema subcutaneo rapidamente progresivo","Inestabilidad hemodinamica refractaria a reposicion"],emergencyLevel:"critico",relatedPathologyIds:["pat_politraumatismo","pat_neumotorax","pat_hemotorax","pat_insuficiencia_respiratoria"],isPremium:!1},{id:"pat_trauma_abdominal",nombre:"Trauma Abdominal",bodySystemId:"traumatologico",definicion:"Lesion de la pared abdominal y/o su contenido visceral (organos solidos y huecos) causada por trauma cerrado o penetrante. Es una causa frecuente de hemorragia interna oculta y peritonitis. El diagnostico precoz es clave ya que los hallazgos clinicos iniciales pueden ser sutiles, especialmente en pacientes con alteracion de conciencia.",epidemiologia:"Presente en el 20-30% de los politraumatismos. El bazo y el higado son los organos mas frecuentemente lesionados en trauma cerrado (40% y 35% respectivamente). En trauma penetrante, el intestino delgado es el mas afectado. La mortalidad del trauma hepatico severo alcanza el 50%. Los accidentes de transito y la violencia son las principales causas.",factoresRiesgo:["Accidentes de transito (impacto con volante, cinturon de seguridad mal colocado)","Heridas por arma blanca en abdomen","Heridas por arma de fuego (alta energia, multiples lesiones)","Caidas de altura con impacto abdominal","Maltrato infantil (lesion hepatica o esplenica por golpe)","Deportes de contacto (impacto directo en abdomen)","Esplenomegalia previa (bazo mas vulnerable a ruptura)","Uso de anticoagulantes (mayor sangrado ante lesion menor)"],fisiopatologia:"En trauma cerrado, la lesion se produce por compresion directa (aplastamiento de organos contra columna vertebral), desaceleracion (desgarro de ped\xedculos vasculares por inercia, como la lesion de arteria esplenica o venas hepaticas) o aumento subito de presion intraabdominal (ruptura de visceras huecas). Los organos solidos (bazo, higado, ri\xf1ones) sangran profusamente al romperse su capsula. Los organos huecos (intestino, vejiga, estomago) producen peritonitis por fuga de contenido. En trauma penetrante, la lesion depende de la trayectoria del agente (arma blanca: lesion predecible, arma de fuego: cavitacion temporal y permanente con da\xf1o impredecible). El peritoneo puede contener inicialmente 1-1.5 L de sangre antes de que aparezcan signos clinicos evidentes, lo que convierte al abdomen en una cavidad potencialmente silenciosa y letal.",signosYSintomas:{signos:["Defensa abdominal voluntaria e involuntaria (rigidez de pared)","Dolor a la descompresion (signo de Blumberg positivo: peritonitis)","Distension abdominal progresiva","Ausencia de ruidos hidroaereos (ileo paralitico)","Signo de Kehr (dolor referido en hombro izquierdo por irritacion diafragmatica, sugiere lesion esplenica)","Equimosis periumbilical (signo de Cullen) o en flancos (signo de Grey-Turner): hemorragia retroperitoneal","Marca del cinturon de seguridad en abdomen (sospechar lesion intestinal)","Hipotension con taquicardia (hemorragia intraabdominal)"],sintomas:["Dolor abdominal difuso o localizado","Nauseas y vomitos","Sensacion de distension abdominal","Dolor referido en hombros (irritacion diafragmatica)","Incapacidad para tolerar la palpacion abdominal"]},clasificacion:{nombre:"Clasificacion segun mecanismo y organo afectado",tipos:[{nombre:"Trauma cerrado (no penetrante)",descripcion:"Sin solucion de continuidad en peritoneo. Organos mas afectados: bazo (40%), higado (35%). Diagnostico con FAST y TAC. Alta sospecha de lesiones ocultas"},{nombre:"Trauma penetrante por arma blanca",descripcion:"Lesion predecible segun trayectoria. Organos mas afectados: higado (40%), intestino delgado (30%). Exploracion local de herida para determinar si penetra peritoneo"},{nombre:"Trauma penetrante por arma de fuego",descripcion:"Alta energia con cavitacion. Lesiones multiples e impredecibles. Organos: intestino delgado (50%), colon (40%), higado (30%). Generalmente requiere laparotomia"},{nombre:"Manejo no operatorio (NOM)",descripcion:"Seleccion de pacientes hemodinamicamente estables con lesion de organo solido (bazo, higado) para observacion y TAC seriadas. Exito > 85% en lesiones esplenicas y hepaticas grado I-III"}]},diagnostico:{anamnesis:["Mecanismo de lesion detallado (cinematica del trauma)","Tipo de arma si penetrante (calibre, largo de hoja)","Uso de cinturon de seguridad y tipo de vehiculo","Tiempo desde el evento","Dolor abdominal y su evolucion temporal","Ultima ingesta (riesgo de aspiracion si requiere cirugia)"],examenFisico:["Inspeccion: heridas, equimosis, distension, marcas de cinturon","Palpacion: defensa muscular, dolor a la descompresion, masas palpables","Percusion: matidez en flancos (liquido libre), timpanismo (aire libre)","Auscultacion: presencia o ausencia de ruidos hidroaereos","Exploracion de heridas penetrantes (no introducir instrumentos a ciegas)","Tacto rectal: sangre (lesion intestinal), tono del esfinter, posicion prostatica"],pruebas:[{nombre:"FAST (Focused Assessment with Sonography in Trauma)",descripcion:"Ecografia en 4 puntos para detectar liquido libre intraperitoneal. Sensibilidad 85-95% para hemoperitoneo > 200 mL. FAST positivo + inestabilidad hemodinamica = laparotomia urgente sin TAC",valoresReferencia:"Negativo: sin liquido libre. Positivo: banda anecoica entre organos. Indeterminado: repetir en 30 minutos",cuidadosEnfermeria:["Facilitar acceso al abdomen rapidamente","Mantener monitorizacion durante el estudio","Comunicar resultado inmediatamente al cirujano","Si positivo e inestable: preparar para quirofano de urgencia"]},{nombre:"Tomografia computarizada de abdomen y pelvis con contraste IV",descripcion:"Gold standard en paciente estable. Identifica tipo y grado de lesion de organos solidos (escala AAST), liquido libre, aire libre, lesiones vasculares con extravasacion de contraste (blush). Permite decision de manejo operatorio vs no operatorio",valoresReferencia:"Normal: organos sin laceracion ni hematoma, sin liquido libre, sin aire libre. Grados de lesion (AAST): I-V para cada organo",cuidadosEnfermeria:["Solo en paciente hemodinamicamente estable (PAS > 90 mmHg respondiendo a fluidos)","Via periferica gruesa para contraste IV","Monitorizar signos vitales durante y despues del estudio","Comunicar alergia a contraste iodado","Preparar para quirofano si hallazgos lo ameritan"]},{nombre:"Lavado peritoneal diagnostico (LPD)",descripcion:"Infusion de 1L de SF en peritoneo y aspiracion posterior. Positivo si GR > 100.000/mm3, GB > 500/mm3, amilasa elevada, presencia de bilis o contenido intestinal. Reservado para centros sin FAST ni TAC disponible",valoresReferencia:"Positivo: GR > 100.000/mm3, GB > 500/mm3, amilasa > 175 U/L, presencia de bilis, fibras alimentarias o materia fecal",cuidadosEnfermeria:["Vaciar vejiga con sonda vesical antes del procedimiento","Colocar sonda nasogastrica para descomprimir estomago","Asistir al medico con tecnica esteril","Enviar muestra a laboratorio con caracter urgente"]}]},tratamientoMedico:{objetivos:["Identificar y controlar hemorragia intraabdominal","Determinar necesidad de cirugia urgente vs manejo no operatorio","Prevenir peritonitis por perforacion de viscera hueca","Mantener estabilidad hemodinamica","Monitorizar pacientes en manejo no operatorio con reevaluacion clinica e imagenologica seriada"],farmacologico:[{nombre:"Acido tranexamico",grupo:"Antifibrinolitico",mecanismo:"Reduce mortalidad por hemorragia traumatica al inhibir fibrinolisis. Administrar dentro de las primeras 3 horas del trauma segun protocolo CRASH-2",dosis:"1 g IV en 10 minutos, seguido de 1 g IV en 8 horas. No administrar si > 3 horas del trauma",cuidadosEnfermeria:["Administrar primera dosis lo antes posible","Registrar hora del trauma y hora de administracion","Vigilar signos de trombosis","Diluir en 100 mL de SF para infusion"]},{nombre:"Antibioticos de amplio espectro",grupo:"Antibioticoterapia profilactica/terapeutica",mecanismo:"Cobertura contra flora intestinal en lesion de viscera hueca (gram negativos y anaerobios). Previenen sepsis abdominal y formacion de abscesos",dosis:"Piperacilina-tazobactam 4.5 g IV cada 6h, o metronidazol 500 mg IV cada 8h + ceftriaxona 2 g IV cada 24h. Iniciar preoperatorio si sospecha de perforacion",cuidadosEnfermeria:["Administrar primera dosis antes de cirugia (profilaxis)","Verificar alergias a penicilina o cefalosporinas","Monitorizar temperatura y leucocitos como respuesta","Ajustar segun cultivos si se obtienen muestras intraoperatorias"]},{nombre:"Cristaloides y hemoderivados",grupo:"Reposicion volemica",mecanismo:"Ringer Lactato o solucion fisiologica para reposicion inicial. Hemoderivados (GR, PFC, plaquetas 1:1:1) ante hemorragia significativa. Hipotension permisiva hasta control quirurgico",dosis:"Bolo inicial 1-2 L de RL tibio. Hemoderivados si no responde o hemorragia activa. Objetivo: PAS 80-90 mmHg (hipotension permisiva) hasta hemostasia quirurgica",cuidadosEnfermeria:["Dos vias perifericas gruesas (14-16G)","Calentar fluidos a 39\xb0C con calentador","Monitorizar respuesta a volumen cada 15 min","Solicitar sangre O negativo si urgencia extrema","Balance hidrico estricto"]}],noFarmacologico:["Manejo no operatorio (NOM) en lesiones esplenicas y hepaticas grado I-III con estabilidad hemodinamica","Reposo absoluto en cama durante NOM con monitorizacion hemodinamica continua","TAC de control a las 24-48h en pacientes en NOM","Sonda nasogastrica si sospecha de ileo o lesion gastrica","Sonda vesical para control de diuresis horaria","Nada por boca hasta evaluar necesidad de cirugia"],quirurgico:["Laparotomia exploratoria urgente: FAST + e inestable, peritonitis generalizada, evisceraci\xf3n, o herida por arma de fuego","Cirugia de control de da\xf1os: packing hepatico, esplenectomia rapida, ligadura de vasos, cierre temporal de abdomen","Esplenectomia (parcial o total) en lesion esplenica severa. Post-esplenectomia: vacunacion contra neumococo, meningococo, H. influenzae","Rafia intestinal o reseccion con anastomosis en lesion de viscera hueca","Angioembolizacion selectiva para sangrado arterial activo (blush en TAC) en paciente estable"]},cuidadosEnfermeria:{valoracion:["Evaluar abdomen cada 30-60 min: distension, dolor, defensa, ruidos intestinales","Monitorizar signos vitales continuos (PA, FC, FR, SpO2)","Control de diuresis horaria como indicador de perfusion renal","Evaluar signos de sangrado oculto: taquicardia progresiva, palidez, caida de Hb","Valorar heridas penetrantes: sangrado activo, evisceraci\xf3n","Inspeccionar marcas de cinturon, equimosis, abrasiones"],intervenciones:["Canalizar dos vias perifericas gruesas y extraer muestras para laboratorio y banco de sangre","Colocar sonda vesical y nasogastrica segun indicacion","Mantener nada por boca hasta decision quirurgica","Cubrir evisceraci\xf3n con gasas humedas en solucion fisiologica tibia (no reintroducir)","Preparar al paciente para quirofano con consentimiento informado urgente","Administrar antibioticos profilacticos segun indicacion"],educacionPaciente:["Explicar a la familia el plan de tratamiento (operatorio vs observacion)","Instruir sobre signos de alarma post-alta: dolor abdominal que empeora, fiebre, mareo","Educar sobre restriccion de actividad fisica durante recuperacion (6-8 semanas)","En caso de esplenectomia: explicar vacunacion obligatoria y riesgo de sepsis post-esplenectomia","Ense\xf1ar cuidados de herida quirurgica y cuando consultar","Importancia de control ambulatorio con imagenes de seguimiento"],monitorizacion:["Signos vitales cada 15-30 min en fase aguda, luego cada hora","Hemoglobina seriada cada 4-6 horas en primeras 24-48h","Diuresis horaria (objetivo > 0.5 mL/kg/h)","Examen abdominal seriado por el mismo evaluador (detectar cambios sutiles)","Balance hidrico estricto cada 4 horas"]},npiNanda:[{codigo:"00206",nombre:"Riesgo de sangrado",definicion:"Vulnerable a una disminucion del volumen de sangre que puede comprometer la salud",caracteristicasDefinitorias:["Hemorragia intraabdominal oculta o activa","Caida de hemoglobina en controles seriados","Taquicardia e hipotension progresivas","Distension abdominal creciente"],factoresRelacionados:["Lesion de organo solido (bazo, higado)","Lesion vascular mesenterica","Coagulopatia por consumo"]},{codigo:"00004",nombre:"Riesgo de infeccion",definicion:"Vulnerable a la invasion y multiplicacion de organismos patogenos que pueden comprometer la salud",caracteristicasDefinitorias:["Contaminacion peritoneal por contenido intestinal","Herida abierta en abdomen","Procedimientos invasivos multiples"],factoresRelacionados:["Perforacion de viscera hueca","Procedimientos quirurgicos abdominales","Cateterizaciones multiples (SV, SNG, via central)"]},{codigo:"00025",nombre:"Riesgo de desequilibrio del volumen de liquidos",definicion:"Vulnerable a una disminucion, aumento o rapido cambio entre compartimientos del volumen de liquido intravascular, intersticial o intracelular",caracteristicasDefinitorias:["Hemorragia activa o potencial","Tercer espacio post-quirurgico","Reposicion masiva de fluidos"],factoresRelacionados:["Hemorragia por lesion visceral","Respuesta inflamatoria con fuga capilar","Reposicion volemica agresiva"]}],npiNic:[{codigo:"6650",nombre:"Vigilancia",actividades:["Monitorizar signos vitales con frecuencia establecida","Realizar examen abdominal seriado buscando cambios","Controlar hemoglobina seriada y tendencia","Evaluar diuresis como indicador de perfusion","Comunicar cambios significativos al equipo quirurgico inmediatamente"]},{codigo:"4030",nombre:"Administracion de hemoderivados",actividades:["Verificar compatibilidad (grupo, factor, prueba cruzada)","Administrar hemoderivados con filtro y calentador","Monitorizar signos de reaccion transfusional cada 15 min","Registrar unidades, hora de inicio y finalizacion","Controlar calcio ionico post-transfusion masiva"]},{codigo:"2900",nombre:"Asistencia quirurgica",actividades:["Preparar al paciente para quirofano (consentimiento, laboratorio, banco de sangre)","Verificar ayuno e identificacion del paciente","Completar checklist de seguridad quirurgica (OMS)","Comunicar alergias y antecedentes relevantes al equipo quirurgico","Preparar insumos anticipados para cirugia de control de da\xf1os"]}],npiNoc:[{codigo:"0413",nombre:"Severidad de la perdida de sangre",indicadores:["Hemoglobina estable o en ascenso","PA mantenida sin vasopresores","Ausencia de distension abdominal progresiva","Diuresis > 0.5 mL/kg/h"],escala:"1=Grave, 2=Sustancial, 3=Moderado, 4=Leve, 5=Ninguno"},{codigo:"0703",nombre:"Severidad de la infeccion",indicadores:["Temperatura < 38\xb0C","Leucocitos en rango normal","Herida sin signos de infeccion","Ausencia de colecciones intraabdominales"],escala:"1=Grave, 2=Sustancial, 3=Moderado, 4=Leve, 5=Ninguno"}],complicaciones:["Shock hemorragico por hemorragia intraabdominal no controlada","Peritonitis difusa por perforacion de viscera hueca","Abscesos intraabdominales post-operatorios","Sindrome compartimental abdominal (PIA > 20 mmHg con disfuncion organica)","Fistulas enterocutaneas post-quirurgicas","Sepsis post-esplenectomia fulminante (OPSI: infeccion abrumadora)","Ileo paralitico prolongado","Adherencias intestinales y obstruccion tardia"],criteriosAlarma:["FAST positivo con inestabilidad hemodinamica (laparotomia urgente)","Peritonitis generalizada (abdomen en tabla)","Caida de hemoglobina > 2 g/dL en 4 horas","Necesidad de > 4 unidades de GR en primeras 2 horas","Evisceraci\xf3n traumatica","Distension abdominal progresiva con deterioro hemodinamico","Fiebre > 38.5\xb0C con dolor abdominal creciente post-NOM"],emergencyLevel:"critico",relatedPathologyIds:["pat_politraumatismo","pat_trauma_toracico","pat_shock_hipovolemico","pat_peritonitis"],isPremium:!1},{id:"pat_fracturas_extremidades",nombre:"Fracturas de Extremidades",bodySystemId:"traumatologico",definicion:"Perdida de la continuidad osea parcial o total en huesos de miembros superiores o inferiores causada por un traumatismo que supera la resistencia mecanica del hueso. Pueden comprometer estructuras neurovasculares adyacentes y requerir desde inmovilizacion con yeso hasta cirugia reconstructiva compleja.",epidemiologia:"Las fracturas de extremidades son las lesiones traumaticas mas frecuentes. Incidencia de 11-12 por 1.000 habitantes/a\xf1o. Distribucion bimodal: jovenes (trauma de alta energia: accidentes, deportes) y ancianos (trauma de baja energia: caidas con osteoporosis). La fractura de femur proximal en ancianos tiene mortalidad del 20-30% al a\xf1o. Las fracturas abiertas representan el 5-10% del total y tienen riesgo elevado de infeccion y no union.",factoresRiesgo:["Accidentes de transito (trauma de alta energia)","Caidas en adultos mayores (osteoporosis: principal factor)","Actividades deportivas de alto impacto","Osteoporosis (reduce resistencia osea significativamente)","Deficiencia de vitamina D y calcio","Uso cronico de corticoides (osteoporosis secundaria)","Tumores oseos primarios o metastasis (fracturas patologicas)","Violencia interpersonal","Accidentes laborales"],fisiopatologia:"La fractura ocurre cuando la fuerza aplicada supera la resistencia mecanica del hueso. Los mecanismos incluyen: fuerza directa (impacto en el sitio de fractura), fuerza indirecta (transmision a distancia: caida sobre mano produce fractura de colles en radio distal o fractura de clavicula), traccion (avulsion por insercion muscular o ligamentaria), fatiga (microfracturas por estres repetitivo). Al producirse la fractura, hay rotura de vasos intraoseos con formacion de hematoma. La cascada de reparacion osea incluye: fase inflamatoria (dias 1-7, hematoma, reclutamiento celular), fase de callo blando (semanas 2-3, tejido fibrocartilaginoso), fase de callo duro (semanas 4-16, osificacion), y remodelacion (meses-a\xf1os). Las fracturas abiertas (clasificacion de Gustilo-Anderson) tienen exposicion del foco fracturario al exterior con riesgo de contaminacion e infeccion. El sindrome compartimental es la complicacion aguda mas temida: el edema y la hemorragia post-fractura aumentan la presion dentro de un compartimiento fascial cerrado, comprimiendo vasos y nervios, causando isquemia irreversible en 6-8 horas si no se realiza fasciotomia.",signosYSintomas:{signos:["Deformidad visible del miembro (angulacion, rotacion, acortamiento)","Crepitacion osea a la palpacion (no buscar activamente)","Edema y equimosis en foco de fractura","Impotencia funcional (incapacidad de mover o cargar peso)","Movilidad anormal en sitio de fractura","Acortamiento de la extremidad (fracturas de femur)","Exposicion de fragmentos oseos en fracturas abiertas","Pulsos perifericos ausentes o disminuidos (compromiso vascular)"],sintomas:["Dolor intenso localizado que aumenta con el movimiento","Sensacion de crujido al momento del trauma","Incapacidad de mover la extremidad afectada","Hormigueo o entumecimiento distal (compromiso nervioso)","Sensacion de inestabilidad en la extremidad"]},clasificacion:{nombre:"Clasificacion de Gustilo-Anderson (fracturas abiertas)",tipos:[{nombre:"Tipo I",descripcion:"Herida < 1 cm, limpia, de adentro hacia afuera. Fractura simple. Contaminacion minima. Bajo riesgo de infeccion (0-2%)"},{nombre:"Tipo II",descripcion:"Herida 1-10 cm, contaminacion moderada. Da\xf1o de tejidos blandos moderado sin colgajos. Riesgo de infeccion 2-10%"},{nombre:"Tipo IIIA",descripcion:"Herida > 10 cm, alta energia, pero cobertura de tejidos blandos adecuada. Fracturas segmentarias. Riesgo de infeccion 10-25%"},{nombre:"Tipo IIIB y IIIC",descripcion:"IIIB: perdida extensa de tejidos blandos con exposicion osea, requiere colgajo. IIIC: lesion vascular que requiere reparacion. Riesgo de infeccion 25-50%. Alta tasa de amputacion"}]},diagnostico:{anamnesis:["Mecanismo de lesion (alta o baja energia, directo o indirecto)","Localizacion exacta del dolor","Capacidad de mover la extremidad y cargar peso post-trauma","Momento del ultimo consumo de alimentos (si requiere cirugia)","Antecedentes: osteoporosis, fracturas previas, tratamiento con corticoides","Estado de vacunacion antitetanica (en fracturas abiertas)"],examenFisico:["Inspeccion: deformidad, edema, equimosis, heridas abiertas, exposicion osea","Palpacion suave: dolor exquisito localizado, crepitacion (no provocar intencionalmente)","Evaluacion neurovascular distal: pulsos, llenado capilar, sensibilidad, movilidad de dedos","Evaluacion de compartimientos musculares: dolor al estiramiento pasivo (sindrome compartimental)","Evaluacion de articulaciones proximal y distal a la fractura","Evaluar piel en busca de heridas abiertas (clasificar Gustilo si fractura expuesta)"],pruebas:[{nombre:"Radiografia de la extremidad afectada (2 proyecciones minimo)",descripcion:"Estudio inicial obligatorio. Se solicitan dos proyecciones (AP y lateral) incluyendo la articulacion proximal y distal. Permite clasificar el tipo de fractura, desplazamiento y planificar tratamiento",valoresReferencia:"Normal: cortical intacta, trabeculado regular, alineacion anatomica. Patologico: linea de fractura, desplazamiento, conminucion, perdida de alineacion",cuidadosEnfermeria:["Inmovilizar la extremidad antes de trasladar a radiologia","No retirar ferula para la radiografia (se puede ver a traves del yeso)","Incluir articulacion superior e inferior en la placa","Manejar al paciente con cuidado para no aumentar el dolor"]},{nombre:"Tomografia computarizada de la fractura",descripcion:"Indicada en fracturas articulares, de pelvis, meseta tibial y pil\xf3n tibial para planificacion quirurgica. Superior para evaluar conminucion y depresion articular",valoresReferencia:"Detalla patron de fractura, numero de fragmentos, compromiso articular y desplazamiento en 3D",cuidadosEnfermeria:["Mantener inmovilizacion durante el estudio","Analgesia previa si movilizacion causa dolor intenso","Estudio no urgente, puede diferirse si paciente inestable"]},{nombre:"Medicion de presion intracompartimental",descripcion:"Indicada ante sospecha de sindrome compartimental. Se introduce aguja conectada a transductor en el compartimiento afectado. Presion > 30 mmHg o delta P (PAD - Pcompartimental) < 30 mmHg indica fasciotomia urgente",valoresReferencia:"Normal: < 10 mmHg. Alerta: 20-30 mmHg. Critico: > 30 mmHg o delta P < 30 mmHg \u2192 fasciotomia urgente",cuidadosEnfermeria:["Reconocer signos clinicos precoces: dolor desproporcionado, dolor al estiramiento pasivo de dedos","No esperar las 5 P clasicas (Pain, Pallor, Pulselessness, Paresthesia, Paralysis): los pulsos se pierden ULTIMO","Retirar inmediatamente vendajes compresivos o yesos que puedan estar contribuyendo","Comunicar urgentemente al traumatologo ante sospecha"]}]},tratamientoMedico:{objetivos:["Reduccion anatomica de la fractura (alinear fragmentos)","Fijacion estable que permita movilizacion precoz","Preservar la funcion neurovascular de la extremidad","Prevenir y detectar sindrome compartimental precozmente","Prevenir infeccion en fracturas abiertas (antibioticos + lavado quirurgico)"],farmacologico:[{nombre:"Cefazolina",grupo:"Cefalosporina de primera generacion (antibiotico profilactico)",mecanismo:"Cobertura contra Staphylococcus aureus y Streptococcus, principales patogenos en infecciones de fracturas abiertas. Profilaxis obligatoria en toda fractura abierta y en fijacion quirurgica",dosis:"Gustilo I-II: Cefazolina 2 g IV, luego 1 g cada 8h por 24-48h. Gustilo III: agregar gentamicina 5 mg/kg/dia + metronidazol 500 mg IV cada 8h si contaminacion con tierra",cuidadosEnfermeria:["Administrar primera dosis dentro de las primeras 3 horas del trauma","Verificar alergia a penicilina/cefalosporinas (usar clindamicina si alergia)","En cirugia: administrar 30-60 min antes de la incision","No prolongar profilaxis mas de 72h (aumenta resistencia sin beneficio)"]},{nombre:"Ketorolac + Tramadol (analgesia multimodal)",grupo:"AINE + Opioide debil",mecanismo:"Ketorolac inhibe COX con potente efecto analgesico; Tramadol actua en receptores mu y recaptacion de serotonina/noradrenalina. Combinacion reduce necesidad de opioides mayores",dosis:"Ketorolac 30 mg IV cada 8h (max 5 dias). Tramadol 50-100 mg IV/VO cada 6-8h. Maximo: tramadol 400 mg/dia",cuidadosEnfermeria:["Evaluar dolor con EVA antes y despues de administrar","Vigilar efectos adversos de tramadol: nauseas, mareos, somnolencia","Ketorolac: vigilar sangrado GI y funcion renal","Administrar rescate con morfina si dolor no controlado"]},{nombre:"Enoxaparina (tromboprofilaxis)",grupo:"Heparina de bajo peso molecular",mecanismo:"Inhibe factor Xa para prevenir TVP. Las fracturas de extremidades inferiores y la inmovilizacion aumentan significativamente el riesgo tromboembolico",dosis:"40 mg SC cada 24h. Iniciar 6-12h post-cirugia. Mantener hasta deambulacion completa o 4-6 semanas en fractura de cadera/femur",cuidadosEnfermeria:["Administrar en tejido subcutaneo abdominal alternando lados","No aspirar ni frotar post-inyeccion","Vigilar signos de sangrado o hematomas","Combinar con medias compresivas y movilizacion precoz","Controlar plaquetas semanalmente (riesgo de HIT)"]}],noFarmacologico:["Inmovilizacion inicial con ferula en posicion funcional antes del tratamiento definitivo","Protocolo RICE en primeras 48h: Reposo, hielo (Ice) 20 min cada 2h, Compresion, Elevacion de la extremidad","Reduccion cerrada e inmovilizacion con yeso o ferula en fracturas estables no desplazadas","Elevacion de la extremidad por encima del nivel del corazon para reducir edema","Rehabilitacion kinesiologica precoz: movilizacion articular temprana, fortalecimiento progresivo","Soporte nutricional: adecuada ingesta de calcio (1000-1200 mg/dia) y vitamina D (800-1000 UI/dia)"],quirurgico:["Reduccion abierta y fijacion interna (RAFI) con placas, tornillos o clavos intramedulares para fracturas desplazadas o articulares","Fijacion externa: para fracturas abiertas Gustilo III, fracturas con da\xf1o severo de tejidos blandos o control de da\xf1os en politraumatismo","Fasciotomia urgente en sindrome compartimental (incision de todas las fascias del compartimiento afectado)","Lavado quirurgico y desbridamiento de fracturas abiertas (idealmente dentro de las 6 horas)","Artroplastia (protesis): indicada en fracturas de cuello femoral desplazadas en ancianos"]},cuidadosEnfermeria:{valoracion:["Evaluacion neurovascular distal cada 1-2 horas post-inmovilizacion o cirugia: pulsos, sensibilidad, movilidad, llenado capilar, color y temperatura","Evaluar dolor con escala EVA y correlacionar con hallazgos (dolor desproporcionado = alarma)","Inspeccionar inmovilizacion (yeso, ferula): presion excesiva, bordes cortantes, humedad","Valorar edema distal y comparar con extremidad contralateral","Evaluar herida quirurgica o sitio de fractura abierta: sangrado, signos de infeccion","Valorar estado emocional y capacidad de autocuidado"],intervenciones:["Elevar extremidad afectada sobre almohadas por encima del nivel cardiaco","Aplicar hielo envuelto en tela por 20 min cada 2 horas en primeras 48h","Vigilar circulacion distal estrictamente tras colocacion de yeso (las primeras 24-48h son criticas)","Alinear extremidad en posicion funcional y evitar presion sobre prominencias oseas","Asistir en movilizacion temprana segun indicacion medica (transferencias, uso de muletas)","Curacion de herida quirurgica con tecnica aseptica"],educacionPaciente:["Ense\xf1ar signos de alarma en yeso: dolor que no cede, hormigueo, dedos morados, frios o sin movimiento \u2192 consultar urgente","Instruir sobre cuidados del yeso: mantener seco, no introducir objetos dentro, elevar extremidad","Ense\xf1ar uso correcto de muletas o andador segun prescripcion de carga","Educar sobre importancia de la rehabilitacion y ejercicios de rango articular","Instruir sobre prevencion de TVP: movilizar dedos y tobillo frecuentemente","Explicar tiempos de consolidacion esperados segun localizacion"],monitorizacion:["Evaluacion neurovascular distal cada 1-2 horas en primeras 24-48h post-reduccion/cirugia","Control de dolor cada 4 horas con escala EVA","Vigilancia de signos de sindrome compartimental: las 6 P (Pain out of proportion, Pressure, Paresthesia, Paralysis, Pallor, Pulselessness)","Hemoglobina de control si fractura de femur o sangrado significativo","Temperatura y signos de infeccion en fracturas abiertas"]},npiNanda:[{codigo:"00132",nombre:"Dolor agudo",definicion:"Experiencia sensitiva y emocional desagradable asociada a da\xf1o tisular real o potencial",caracteristicasDefinitorias:["Expresion verbal y facial de dolor","Proteccion de la extremidad afectada","Taquicardia por dolor","Dificultad para el movimiento"],factoresRelacionados:["Fractura osea con edema y espasmo muscular","Lesion de tejidos blandos perilesionales","Procedimientos de reduccion e inmovilizacion"]},{codigo:"00085",nombre:"Deterioro de la movilidad fisica",definicion:"Limitacion del movimiento fisico independiente e intencionado del cuerpo o de una o mas extremidades",caracteristicasDefinitorias:["Inmovilizacion por ferula o yeso","Incapacidad de cargar peso en extremidad afectada","Limitacion del rango de movimiento articular","Dependencia para actividades de la vida diaria"],factoresRelacionados:["Fractura osea","Inmovilizacion terapeutica","Dolor al movimiento"]},{codigo:"00086",nombre:"Riesgo de disfuncion neurovascular periferica",definicion:"Vulnerable a una alteracion en la circulacion, sensibilidad o movimiento de una extremidad que puede comprometer la salud",caracteristicasDefinitorias:["Fractura con edema significativo","Inmovilizacion con yeso cerrado","Disminucion de pulsos distales"],factoresRelacionados:["Compresion por edema dentro de compartimiento fascial","Inmovilizacion externa constrictiva","Lesion vascular por fragmentos oseos"]}],npiNic:[{codigo:"2660",nombre:"Manejo de la sensibilidad periferica alterada",actividades:["Evaluar pulsos distales, llenado capilar, sensibilidad y movilidad cada hora","Comparar con extremidad contralateral","Aflojar vendajes si signos de compromiso neurovascular","Elevar extremidad para reducir edema","Comunicar inmediatamente cambios al medico"]},{codigo:"0910",nombre:"Inmovilizacion",actividades:["Mantener alineacion anatomica de la extremidad","Verificar integridad de la inmovilizacion (yeso, ferula, traccion)","Proteger prominencias oseas bajo el yeso con almohadillado","Vigilar que la inmovilizacion no sea constrictiva","Instruir al paciente sobre cuidados de la inmovilizacion"]},{codigo:"1400",nombre:"Manejo del dolor",actividades:["Evaluar dolor con escala EVA sistematicamente","Administrar analgesia multimodal segun prescripcion","Aplicar hielo local (crioterapia) en primeras 48h","Posicionar extremidad para minimizar dolor (elevacion, alineacion)","Investigar dolor desproporcionado o progresivo como signo de alarma (sindrome compartimental)"]}],npiNoc:[{codigo:"0407",nombre:"Perfusion tisular: periferica",indicadores:["Pulsos distales palpables y simetricos","Llenado capilar < 2 segundos","Sensibilidad conservada en dedos","Color y temperatura de piel normal","Movilidad activa de dedos"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"},{codigo:"2102",nombre:"Nivel del dolor",indicadores:["Dolor referido controlado (EVA < 4)","Capacidad de participar en rehabilitacion","Patron de sue\xf1o no alterado por dolor","Sin necesidad de rescates frecuentes de opioides"],escala:"1=Grave, 2=Sustancial, 3=Moderado, 4=Leve, 5=Ninguno"}],complicaciones:["Sindrome compartimental (emergencia quirurgica: fasciotomia dentro de 6h)","Embolia grasa (12-72h post-fractura de huesos largos: petequias, hipoxemia, confusion)","Trombosis venosa profunda y tromboembolismo pulmonar","Infeccion de sitio quirurgico y osteomielitis (especialmente fracturas abiertas)","Pseudoartrosis (falta de consolidacion > 6 meses)","Consolidacion viciosa (consolidacion en mala posicion)","Lesion neurovascular por fragmentos oseos desplazados","Rigidez articular post-inmovilizacion prolongada"],criteriosAlarma:["Dolor desproporcionado que no cede con analgesia (sindrome compartimental)","Dolor al estiramiento pasivo de dedos (signo mas precoz de sindrome compartimental)","Ausencia de pulsos distales (compromiso vascular: emergencia)","Parestesias o paralisis distal de inicio agudo","Fiebre > 38.5\xb0C con eritema y secrecion en herida (infeccion)","Disnea subita con petequias axilares 24-72h post-fractura (embolia grasa)","Yeso mojado, roto o que causa presion excesiva"],emergencyLevel:"moderado",relatedPathologyIds:["pat_politraumatismo","pat_tvp","pat_tep","pat_osteoporosis"],isPremium:!1},{id:"pat_ahogamiento",nombre:"Ahogamiento (Sumersion)",bodySystemId:"traumatologico",definicion:"Proceso de deterioro respiratorio por sumersion o inmersion en un medio liquido. Puede ser fatal o no fatal, con un espectro que va desde la tos transitoria hasta el paro cardiorrespiratorio y la muerte. La asfixia por sumersion provoca hipoxia sistematica que afecta principalmente al cerebro y los pulmones. Es una de las principales causas de muerte accidental en ni\xf1os menores de 5 a\xf1os.",epidemiologia:"Tercera causa de muerte por lesion no intencional a nivel mundial, con aproximadamente 236.000 muertes anuales segun la OMS. Incidencia mayor en ni\xf1os de 1-4 a\xf1os y adolescentes varones de 15-24 a\xf1os. En Argentina, es la segunda causa de muerte accidental en menores de 15 a\xf1os. El 80% de las victimas son varones. La tasa de mortalidad es mayor en paises de ingresos bajos y medios.",factoresRiesgo:["Edad extrema (ni\xf1os menores de 5 a\xf1os, adultos mayores)","Sexo masculino (relacion 3:1)","Consumo de alcohol y drogas recreativas","Falta de supervision de menores en piletas y espejos de agua","No saber nadar o sobreestimar la capacidad de natacion","Epilepsia u otras condiciones con riesgo de perdida de conciencia","Trauma cervical por zambullida en aguas poco profundas","Hipotermia por inmersion prolongada en agua fria","Sindrome de QT largo y otras arritmias cardiacas","Ausencia de cercos perimetrales en piletas"],fisiopatologia:"La sumersion desencadena laringoespasmo reflejo inicial seguido de aspiracion de liquido (agua dulce o salada). El agua aspirada inactiva el surfactante pulmonar, colapsa los alveolos y genera atelectasias difusas. El resultado es un shunt intrapulmonar masivo con hipoxemia refractaria. El agua dulce se absorbe rapidamente hacia la circulacion (hipotonica), diluyendo el surfactante y causando edema alveolar. El agua salada (hipertonica) arrastra liquido hacia los alveolos por gradiente osmotico. Ambos mecanismos convergen en sindrome de distres respiratorio agudo (SDRA). La hipoxia prolongada causa da\xf1o cerebral isquemico-hipoxicocon muerte neuronal en 4-6 minutos sin oxigeno. La inmersion en agua fria (<20\xb0C) puede activar el reflejo de inmersion mamifero (bradicardia, vasoconstriccion periferica, redistribucion sanguinea a organos vitales), lo que en ni\xf1os peque\xf1os puede conferir neuroproteccion parcial. La acidosis metabolica, la hiperpotasemia y las arritmias cardiacas completan el cuadro fisiopatologico.",signosYSintomas:{signos:["Cianosis periferica y central","Taquipnea o apnea segun severidad","Estertores crepitantes bilaterales difusos","Hipotension arterial y taquicardia compensadora","Hipotermia (temperatura central < 35\xb0C)","Alteracion del nivel de conciencia (desde confusion hasta coma)","Bradicardia o asistolia en casos severos","Espuma rosada en via aerea (edema pulmonar)","Midriasis bilateral en paro cardiorrespiratorio"],sintomas:["Disnea intensa y sensacion de asfixia","Tos persistente con expectoracion espumosa","Dolor toracico opresivo","Cefalea y confusion","Nauseas y vomitos (por ingestion de agua)","Ansiedad extrema y agitacion"]},clasificacion:{nombre:"Clasificacion de Szpilman (grados de severidad por ahogamiento)",tipos:[{nombre:"Grado 1 (Rescate)",descripcion:"Tos sin espuma en via aerea. Auscultacion pulmonar normal. Paciente consciente y orientado. Observacion minima 6-8 horas"},{nombre:"Grado 2 (Leve)",descripcion:"Estertores crepitantes en algunos campos pulmonares. Paciente consciente. SpO2 > 90% con oxigeno suplementario"},{nombre:"Grado 3 (Moderado)",descripcion:"Edema pulmonar agudo sin hipotension. Estertores difusos bilaterales. Espuma en via aerea. Requiere ventilacion no invasiva o invasiva"},{nombre:"Grado 4 (Grave)",descripcion:"Edema pulmonar agudo con hipotension arterial. Requiere ventilacion mecanica invasiva y soporte vasoactivo. Internacion en UCI"},{nombre:"Grado 5 (Muy grave)",descripcion:"Paro respiratorio aislado. Pulso presente pero sin esfuerzo ventilatorio. Requiere ventilacion asistida inmediata"},{nombre:"Grado 6 (Paro cardiorrespiratorio)",descripcion:"Paro cardiorrespiratorio. Sin pulso ni respiracion. RCP inmediata. Mortalidad muy elevada. Regla: nadie esta muerto hasta que este caliente y muerto"}]},diagnostico:{anamnesis:["Tipo de liquido (agua dulce, salada, clorada, contaminada)","Tiempo estimado de sumersion","Temperatura del agua (fria vs templada)","Posibilidad de trauma cervical asociado (zambullida)","Maniobras de rescate y RCP realizadas en el lugar","Antecedentes de epilepsia, arritmias o consumo de sustancias","Edad de la victima y circunstancias del evento"],examenFisico:["ABCDE sistematico con inmovilizacion cervical si sospecha de trauma","Evaluacion de via aerea y patron respiratorio","Auscultacion pulmonar bilateral (estertores, silencio respiratorio)","Valoracion neurologica con Escala de Glasgow","Temperatura central (rectal o esofagica, NO axilar)","Evaluacion cardiovascular (ritmo, perfusion periferica)","Busqueda de lesiones traumaticas asociadas"],pruebas:[{nombre:"Gasometria arterial",descripcion:"Evalua grado de hipoxemia, hipercapnia y acidosis metabolica. Es el estudio mas importante para determinar severidad del compromiso respiratorio y guiar la ventilacion mecanica",valoresReferencia:"PaO2 > 80 mmHg, PaCO2 35-45 mmHg, pH 7.35-7.45, HCO3 22-26 mEq/L, Lactato < 2 mmol/L",cuidadosEnfermeria:["Obtener muestra de arteria radial con tecnica aseptica","Comprimir sitio de puncion por 5 minutos minimo","Transportar muestra en hielo y procesar en menos de 15 minutos","Registrar FiO2 y modo ventilatorio al momento de la extraccion"]},{nombre:"Radiografia de torax",descripcion:"Puede mostrar edema pulmonar difuso bilateral, atelectasias, infiltrados alveolares o neumonia aspirativa. Puede ser normal inicialmente y empeorar en 24-48 horas (ahogamiento secundario)",valoresReferencia:"Normal: campos pulmonares claros, sin infiltrados, sin derrame pleural",cuidadosEnfermeria:["Radiografia portatil si el paciente esta inestable","Repetir a las 6-12 horas aunque la inicial sea normal","Correlacionar con clinica y gasometria"]},{nombre:"Electrocardiograma de 12 derivaciones",descripcion:"Detecta arritmias por hipoxia, hipotermia e hiperpotasemia. Puede mostrar bradicardia sinusal, fibrilacion ventricular, ondas J de Osborn (si hipotermia asociada) o prolongacion del QT",valoresReferencia:"Ritmo sinusal, FC 60-100 lpm, sin arritmias, QTc < 450 ms",cuidadosEnfermeria:["Secar la piel del paciente para buena adherencia de electrodos","Monitoreo continuo en las primeras 24 horas","Alertar ante cualquier arritmia nueva"]}]},tratamientoMedico:{objetivos:["Restaurar oxigenacion y ventilacion adecuadas","Corregir hipotermia de forma gradual y controlada","Prevenir y tratar el da\xf1o cerebral hipoxicoisquemico","Tratar el SDRA y mantener estabilidad hemodinamica","Observacion minima de 24 horas incluso en casos aparentemente leves"],farmacologico:[{nombre:"Oxigeno suplementario / Ventilacion mecanica",grupo:"Soporte ventilatorio",mecanismo:"Corrige la hipoxemia causada por el shunt intrapulmonar y las atelectasias. La PEEP (presion positiva al final de la espiracion) recluta alveolos colapsados y mejora la oxigenacion. En casos severos se usa ventilacion protectora con Vt bajo (6 mL/kg)",dosis:"O2 al 100% inicial, titular segun SpO2 objetivo 94-98%. PEEP inicial 5-10 cmH2O, titular segun oxigenacion. FiO2 la menor posible para SpO2 > 94%",cuidadosEnfermeria:["Monitorizar SpO2 continua y gasometria seriada","Aspirar secreciones y espuma de via aerea","Posicion semisentada 30\xb0 si no hay contraindicacion","Vigilar signos de barotrauma en ventilacion mecanica","Registrar parametros ventilatorios cada hora"]},{nombre:"Epinefrina (Adrenalina)",grupo:"Catecolamina / Vasopresor",mecanismo:"Agonista alfa y beta adrenergico. En paro cardiorrespiratorio por ahogamiento, aumenta la presion de perfusion coronaria y cerebral, mejora el tono vascular y estimula la contractilidad miocardica. Indicada solo en paro cardiaco",dosis:"1 mg IV/IO cada 3-5 minutos durante RCP. En ni\xf1os: 0.01 mg/kg (0.1 mL/kg de solucion 1:10.000). No administrar si temperatura central < 30\xb0C hasta completar recalentamiento",cuidadosEnfermeria:["Administrar por via IV o intraosea exclusivamente","Verificar temperatura central antes de administrar (no dar si < 30\xb0C)","Monitorizar ritmo cardiaco continuo durante administracion","Preparar dosis exactas para evitar errores en emergencia"]},{nombre:"Solucion salina normal (ClNa 0.9%) tibia",grupo:"Cristaloide isotonicopara recalentamiento",mecanismo:"Expande volemia y contribuye al recalentamiento activo interno cuando se administra a 40-42\xb0C. Corrige la hipovolemia relativa por vasoconstriccion hipotermicay la deshidratacion por inmersion prolongada",dosis:"Bolos de 250-500 mL IV a 40-42\xb0C. Volumen total segun estado hemodinamico. En ni\xf1os: 20 mL/kg en bolos",cuidadosEnfermeria:["Calentar los fluidos a 40-42\xb0C antes de infundir (usar calentador de fluidos)","Monitorizar temperatura central durante el recalentamiento","Objetivo de recalentamiento: 1-2\xb0C por hora","Vigilar signos de sobrecarga hidrica (estertores, ingurgitacion yugular)","Control estricto de balance hidrico"]}],noFarmacologico:["Rescate acuatico seguro: prioridad a ventilaciones (5 ventilaciones de rescate antes de compresiones)","RCP con enfasis en ventilacion (a diferencia del protocolo estandar de compresiones primero)","Recalentamiento pasivo: retirar ropa mojada, cubrir con mantas termicas","Recalentamiento activo externo: mantas de aire caliente, compresas calientes en axilas, ingles y cuello","Recalentamiento activo interno en hipotermia severa: lavado gastrico, vesical o peritoneal con solucion tibia","ECMO (oxigenacion por membrana extracorporea) en paro cardiaco refractario con hipotermia severa","Posicion de recuperacion en paciente consciente con ventilacion espontanea","Inmovilizacion cervical si sospecha de lesion por zambullida"],quirurgico:["Toracostomia con tubo si neumotorax por barotrauma o reanimacion","Canulacion para ECMO en centros con disponibilidad (hipotermia severa con paro refractario)","Traqueostomia si ventilacion mecanica prolongada anticipada","Fijacion quirurgica de fracturas cervicales si lesion asociada por zambullida"]},cuidadosEnfermeria:{valoracion:["Evaluar nivel de conciencia con Escala de Glasgow cada hora","Monitorizar temperatura central (rectal o esofagica, NUNCA axilar en hipotermia)","Auscultacion pulmonar bilateral frecuente (progresion de estertores)","Valorar patron respiratorio y trabajo respiratorio","Evaluar coloracion de piel y llenado capilar","Control de SpO2 continuo y gasometria seriada","Valorar estado emocional y nivel de ansiedad del paciente y familia"],intervenciones:["Mantener via aerea permeable y aspirar secreciones espumosas","Administrar oxigeno humidificado y calentado","Retirar toda la ropa mojada y secar al paciente","Aplicar medidas de recalentamiento segun grado de hipotermia","Manejar al paciente con movimientos suaves (evitar fibrilacion ventricular por estimulo mecanico en hipotermia)","Canalizar dos vias perifericas gruesas","Preparar equipo de intubacion y RCP avanzada","Mantener observacion minima de 24 horas incluso si el paciente parece asintomatico"],educacionPaciente:["Explicar el riesgo de deterioro tardio (ahogamiento secundario en 24-72 horas)","Ense\xf1ar a la familia signos de alarma post-alta: tos persistente, dificultad respiratoria, somnolencia","Educar sobre prevencion: cercos en piletas, supervision de ni\xf1os, no nadar bajo efectos de alcohol","Importancia de aprender RCP basica para la poblacion general","No zambullirse en aguas de profundidad desconocida","Uso de chalecos salvavidas en actividades nauticas"],monitorizacion:["SpO2 continua y gasometria arterial seriada (cada 4-6 horas o segun evolucion)","Temperatura central cada 30 minutos durante recalentamiento activo","Signos vitales cada hora (PA, FC, FR, temperatura)","Diuresis horaria (objetivo > 0.5 mL/kg/h)","Monitoreo cardiaco continuo por 24 horas minimo","Radiografia de torax de control a las 6, 12 y 24 horas","Glasgow cada 2-4 horas en las primeras 24 horas"]},npiNanda:[{codigo:"00030",nombre:"Deterioro del intercambio de gases",definicion:"Exceso o deficit en la oxigenacion y/o eliminacion de dioxido de carbono en la membrana alveolocapilar",caracteristicasDefinitorias:["Hipoxemia (PaO2 < 60 mmHg)","Cianosis central y periferica","Taquipnea y disnea","Confusion y agitacion por hipoxia"],factoresRelacionados:["Inactivacion de surfactante pulmonar por aspiracion de liquido","Atelectasias difusas","Edema pulmonar no cardiogenico","Shunt intrapulmonar"]},{codigo:"00005",nombre:"Riesgo de desequilibrio de temperatura corporal",definicion:"Vulnerable a una falla en el mantenimiento de la temperatura corporal dentro de rangos normales que puede comprometer la salud",caracteristicasDefinitorias:["Temperatura central < 35\xb0C","Escalofrios o ausencia de ellos (hipotermia severa)","Bradicardia","Piel fria y palida"],factoresRelacionados:["Inmersion prolongada en agua fria","Ropa mojada","Perdida de mecanismos de termorregulacion","Exposicion ambiental"]},{codigo:"00201",nombre:"Riesgo de perfusion tisular cerebral ineficaz",definicion:"Vulnerable a una disminucion de la circulacion tisular cerebral que puede comprometer la salud",caracteristicasDefinitorias:["Alteracion del nivel de conciencia","Disminucion del Glasgow","Convulsiones","Pupilas fijas y dilatadas en casos severos"],factoresRelacionados:["Hipoxia cerebral prolongada por sumersion","Paro cardiorrespiratorio","Hipotermia severa","Acidosis metabolica"]}],npiNic:[{codigo:"3140",nombre:"Manejo de la via aerea",actividades:["Aspirar secreciones espumosas de via aerea","Colocar via aerea orofaringea si esta inconsciente","Preparar intubacion endotraqueal si Glasgow < 8","Administrar oxigeno humidificado y calentado","Monitorizar patron respiratorio y esfuerzo ventilatorio"]},{codigo:"3900",nombre:"Regulacion de la temperatura",actividades:["Monitorizar temperatura central cada 30 minutos","Aplicar medidas de recalentamiento pasivo y activo segun protocolo","Administrar liquidos intravenosos calentados a 40-42\xb0C","Evitar maniobras bruscas que desencadenen arritmias","Documentar curva termica y respuesta al recalentamiento"]},{codigo:"6200",nombre:"Cuidados en la emergencia",actividades:["Activar codigo de emergencia y equipo de reanimacion","Iniciar RCP con enfasis en ventilaciones si aplica","Establecer acceso vascular rapido (IV o intraoseo)","Coordinar con UCI para internacion","Documentar cronologia de eventos y maniobras realizadas"]}],npiNoc:[{codigo:"0402",nombre:"Estado respiratorio: intercambio gaseoso",indicadores:["PaO2 dentro de rangos normales","SpO2 > 94% con soporte de oxigeno adecuado","Ausencia de cianosis","Patron respiratorio eficaz","Resolucion progresiva de infiltrados pulmonares"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"},{codigo:"0800",nombre:"Termorregulacion",indicadores:["Temperatura central 36-37.5\xb0C","Ausencia de escalofrios","Frecuencia cardiaca en rango normal","Perfusion periferica adecuada"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"}],complicaciones:["Sindrome de distres respiratorio agudo (SDRA)","Encefalopatia hipoxico-isquemica con da\xf1o neurologico permanente","Ahogamiento secundario (deterioro respiratorio 24-72 horas post-evento)","Edema pulmonar no cardiogenico persistente","Fibrilacion ventricular por hipotermia","Neumonia aspirativa por contenido gastrico o agua contaminada","Coagulacion intravascular diseminada (CID)","Insuficiencia renal aguda por rabdomiolisis o hipoperfusion"],criteriosAlarma:["SpO2 < 90% a pesar de oxigeno suplementario","Deterioro del nivel de conciencia (disminucion de Glasgow >= 2 puntos)","Temperatura central < 30\xb0C (hipotermia severa con riesgo de FV)","Paro cardiorrespiratorio","Aparicion de espuma rosada en via aerea (edema pulmonar grave)","Convulsiones","Bradicardia severa < 40 lpm o arritmias malignas"],emergencyLevel:"critico",relatedPathologyIds:["pat_hipotermia","pat_sdra","pat_paro_cardiorrespiratorio","pat_tce","pat_lesion_medular"],isPremium:!1},{id:"pat_amputacion_traumatica",nombre:"Amputacion Traumatica",bodySystemId:"traumatologico",definicion:"Perdida parcial o completa de una extremidad o segmento corporal (dedos, mano, antebrazo, pierna) causada por un mecanismo traumatico externo como maquinaria industrial, accidentes de transito, explosiones o heridas por arma cortante. Constituye una emergencia que requiere atencion inmediata tanto del mu\xf1on como de la parte amputada para evaluar la posibilidad de reimplantacion microquirurgica.",epidemiologia:"Incidencia estimada de 8-14 por 100.000 habitantes/a\xf1o. Predomina en varones (relacion 4:1) de 20-50 a\xf1os. Las causas mas frecuentes son accidentes laborales con maquinaria (40-50%), accidentes de transito (25-30%), explosiones (10%) y agresiones (5-10%). Los dedos de la mano son el segmento mas frecuentemente amputado (70% de los casos). La tasa de reimplantacion exitosa varia del 50-90% segun el mecanismo, nivel de amputacion y tiempo de isquemia.",factoresRiesgo:["Trabajo con maquinaria industrial sin proteccion adecuada","Accidentes de transito (motociclismo, atropellamiento)","Manipulacion de explosivos o pirotecnia","Trabajo en agricultura con maquinaria de corte","Heridas por arma de fuego o arma blanca","Deportes extremos y actividades recreativas de riesgo","Catastrofes naturales y derrumbes","Falta de elementos de proteccion personal en el trabajo"],fisiopatologia:"La amputacion traumatica produce seccion de todas las estructuras anatomicas del segmento afectado: piel, musculo, tendones, nervios, vasos sanguineos y hueso. La hemorragia puede ser masiva y potencialmente mortal, especialmente en amputaciones proximales (por encima de la rodilla o codo). La vasoconstriccion refleja y la retraccion de los vasos ayudan parcialmente a controlar el sangrado. El segmento amputado sufre isquemia progresiva: el musculo tolera 6 horas de isquemia caliente (a temperatura ambiente) y hasta 12 horas de isquemia fria (preservado en hielo). Los nervios y tendones son mas resistentes (hasta 24 horas en frio). La lesion por aplastamiento (crush) produce mayor da\xf1o tisular que el corte limpio, con edema masivo, rabdomiolisis y menor probabilidad de reimplantacion exitosa. La respuesta inflamatoria sistemica puede desencadenar coagulopatia por consumo y sindrome de respuesta inflamatoria sistemica (SRIS) en amputaciones mayores.",signosYSintomas:{signos:["Separacion parcial o completa del segmento corporal","Hemorragia activa que puede ser arterial (pulsatil, roja brillante) o venosa","Exposicion de estructuras profundas (hueso, tendones, vasos)","Palidez y frialdad distal al sitio de lesion en amputacion incompleta","Shock hipovolemico en amputaciones mayores (taquicardia, hipotension, palidez)","Contaminacion de la herida con cuerpos extra\xf1os","Ausencia de pulsos distales en amputacion incompleta","Deformidad evidente del miembro afectado"],sintomas:["Dolor intenso en el sitio de amputacion","Sensacion de miembro fantasma (percepcion del segmento amputado)","Mareos y lipotimia por perdida sanguinea","Ansiedad extrema y panico","Nauseas y vomitos por dolor y shock","Parestesias en zona proximal a la lesion"]},clasificacion:{nombre:"Clasificacion de amputaciones traumaticas",tipos:[{nombre:"Amputacion completa",descripcion:"Separacion total del segmento sin conexion de tejidos blandos. Mayor posibilidad de reimplantacion si el corte es limpio y el tiempo de isquemia es corto"},{nombre:"Amputacion incompleta (subtotal)",descripcion:"Mantenimiento de un puente de tejido blando < 25% de la circunferencia. Puede conservar flujo vascular parcial. Revascularizacion urgente"},{nombre:"Amputacion por corte limpio (guillotina)",descripcion:"Bordes netos, minima contusion tisular. Mayor probabilidad de reimplantacion exitosa (hasta 90%)"},{nombre:"Amputacion por aplastamiento (crush)",descripcion:"Da\xf1o tisular extenso, bordes irregulares, lesion vascular intimal. Menor probabilidad de reimplantacion. Mayor riesgo de infeccion"},{nombre:"Amputacion por avulsion",descripcion:"Arrancamiento del segmento con traccion. Da\xf1o vascular y nervioso extenso en longitud. Peor pronostico para reimplantacion"}]},diagnostico:{anamnesis:["Mecanismo exacto de la lesion (corte, aplastamiento, avulsion, explosion)","Tiempo transcurrido desde la amputacion","Condiciones de preservacion de la parte amputada","Mano dominante del paciente (relevante para decision de reimplante)","Ocupacion y actividades habituales del paciente","Antecedentes de tabaquismo, diabetes o enfermedad vascular","Medicacion actual (anticoagulantes, antiplaquetarios)","Estado de vacunacion antitetanica"],examenFisico:["Evaluacion primaria ABCDE (priorizar control de hemorragia)","Clasificacion del tipo de amputacion (completa vs incompleta, limpia vs crush)","Valoracion del mu\xf1on: nivel, viabilidad de tejidos, contaminacion","Evaluacion neurovascular proximal a la lesion","Inspeccion de la parte amputada: integridad, contaminacion, temperatura","Busqueda de lesiones asociadas (fracturas, lesiones vasculares a distancia)","Evaluacion del estado hemodinamico global"],pruebas:[{nombre:"Radiografia del mu\xf1on y de la parte amputada",descripcion:"Define nivel oseo de la amputacion, detecta cuerpos extra\xf1os metalicos, evalua fracturas asociadas y planifica abordaje quirurgico. Se realiza tanto al mu\xf1on como al segmento amputado",valoresReferencia:"Evaluar nivel de seccion osea, presencia de fragmentos, cuerpos extra\xf1os y estado articular",cuidadosEnfermeria:["No retirar apositos compresivos para la radiografia","Enviar la parte amputada junto con el paciente","Mantener la parte amputada preservada durante el estudio","Priorizar estabilizacion hemodinamica sobre estudios de imagen"]},{nombre:"Laboratorio de urgencia (hemograma, coagulacion, grupo y factor, CPK)",descripcion:"Hemograma para evaluar perdida sanguinea, coagulograma para descartar coagulopatia, grupo y factor para preparar hemoderivados, CPK para detectar rabdomiolisis por aplastamiento",valoresReferencia:"Hb > 7 g/dL para reimplante, Plaquetas > 100.000, TP e INR normales, CPK < 1000 U/L",cuidadosEnfermeria:["Extraer muestras junto con canalizacion de via periferica","Solicitar grupo y factor de forma urgente","Reservar minimo 2 unidades de globulos rojos","Repetir CPK a las 6 y 12 horas si mecanismo de aplastamiento"]},{nombre:"Angiografia o angiotomografia del miembro",descripcion:"Evalua estado vascular proximal y distal, identifica vasos disponibles para anastomosis microquirurgica. Indicada en amputaciones incompletas o cuando se planifica reimplantacion",valoresReferencia:"Permeabilidad de arterias y venas principales del miembro afectado",cuidadosEnfermeria:["Verificar funcion renal antes del contraste (creatinina)","Canalizar via gruesa para inyeccion de contraste","Hidratar previamente si la funcion renal lo permite","No retrasar la cirugia por este estudio si la indicacion quirurgica es clara"]}]},tratamientoMedico:{objetivos:["Control inmediato de la hemorragia","Preservacion adecuada de la parte amputada para posible reimplantacion","Estabilizacion hemodinamica del paciente","Reimplantacion microquirurgica cuando este indicada y sea viable","Prevencion de infeccion y promocion de cicatrizacion del mu\xf1on","Rehabilitacion funcional y adaptacion a protesis si reimplante no es viable"],farmacologico:[{nombre:"Antibioticoterapia profilactica (Ampicilina-Sulbactam o Cefalotina + Metronidazol)",grupo:"Antibioticos de amplio espectro",mecanismo:"Cobertura de flora cutanea (cocos gram positivos), bacilos gram negativos y anaerobios. Prevencion de infeccion de herida traumatica contaminada y gangrena gaseosa",dosis:"Ampicilina-Sulbactam 1.5-3 g IV cada 6-8 horas. Alternativa: Cefalotina 1 g IV cada 6 h + Metronidazol 500 mg IV cada 8 h. Duracion: 48-72 horas, prolongar si contaminacion severa",cuidadosEnfermeria:["Administrar primera dosis lo antes posible (idealmente en la primera hora)","Verificar alergias a betalactamicos antes de administrar","Monitorizar signos de reaccion alergica durante la infusion","Ajustar dosis segun funcion renal","Registrar hora exacta de administracion"]},{nombre:"Toxoide tetanico e inmunoglobulina antitetanica",grupo:"Inmunizacion activa y pasiva",mecanismo:"El toxoide estimula la produccion de anticuerpos contra la toxina de Clostridium tetani. La inmunoglobulina proporciona inmunidad pasiva inmediata. Indicado en toda herida traumatica contaminada",dosis:"Toxoide tetanico 0.5 mL IM (refuerzo si ultima dosis > 5 a\xf1os). Inmunoglobulina antitetanica 250-500 UI IM si esquema incompleto o desconocido",cuidadosEnfermeria:["Verificar estado de vacunacion del paciente","Administrar toxoide e inmunoglobulina en sitios anatomicos diferentes","Registrar lote y fecha de administracion","Informar al paciente sobre efectos locales esperados"]},{nombre:"Analgesia multimodal (Tramadol + Ketorolac o Morfina en dolor severo)",grupo:"Analgesicos opioides y no opioides",mecanismo:"Tramadol: agonista mu debil e inhibidor de recaptacion de serotonina y noradrenalina. Ketorolac: AINE con potente efecto analgesico. Morfina: agonista mu puro para dolor severo. El enfoque multimodal reduce la necesidad de opioides y mejora el control del dolor",dosis:"Tramadol 50-100 mg IV cada 6-8 h. Ketorolac 30 mg IV cada 8 h (maximo 5 dias). Morfina 2-5 mg IV cada 4 h si dolor severo (EVA > 7). Titular segun respuesta",cuidadosEnfermeria:["Evaluar dolor con escala EVA antes y despues de cada dosis","Monitorizar frecuencia respiratoria con opioides (alerta si FR < 12)","Vigilar sedacion excesiva y nauseas","No administrar ketorolac si coagulopatia o sangrado activo","Ofrecer analgesia preventiva antes de curaciones"]}],noFarmacologico:["Control de hemorragia: presion directa con aposito compresivo; torniquete solo si hemorragia no controlable","Preservacion de parte amputada: envolver en gasa humedecida con solucion fisiologica, colocar en bolsa sellada, depositar sobre hielo (NUNCA contacto directo del tejido con hielo)","Elevacion del mu\xf1on por encima del nivel del corazon","Irrigacion copiosa de la herida con solucion fisiologica","Inmovilizacion del mu\xf1on con ferula acolchada","Apoyo psicologico inmediato y acompa\xf1amiento emocional","Rehabilitacion temprana y adaptacion funcional"],quirurgico:["Reimplantacion microquirurgica: anastomosis arterial, venosa, reparacion de tendones y nervios (indicada si < 6 h de isquemia caliente o < 12 h de isquemia fria, corte limpio, paciente estable)","Regularizacion del mu\xf1on: desbridamiento de tejido no viable, cobertura osea adecuada, cierre primario o colgajo","Fasciotomia profilactica post-reimplante para prevenir sindrome compartimental","Injerto de nervio si defecto nervioso > 3 cm","Colgajos de cobertura si imposibilidad de cierre primario del mu\xf1on"]},cuidadosEnfermeria:{valoracion:["Evaluacion hemodinamica: PA, FC, llenado capilar, nivel de conciencia","Valoracion del mu\xf1on: sangrado, coloracion, temperatura, edema","Estado neurovascular distal en amputaciones incompletas (pulsos, sensibilidad, movilidad)","Valoracion del dolor con escala EVA cada 2 horas","Evaluacion del estado emocional: ansiedad, duelo, negacion","Estado de la parte amputada: preservacion adecuada, temperatura, tiempo de isquemia","Control de perdidas sanguineas (apositos, drenajes)"],intervenciones:["Control de hemorragia con compresion directa y vendaje compresivo","Preservar la parte amputada segun protocolo (gasa humeda, bolsa sellada, hielo indirecto)","Elevar el mu\xf1on y mantener inmovilizado","Cuidado de herida con tecnica aseptica estricta","Post-reimplante: monitorizar perfusion del segmento reimplantado cada hora (color, temperatura, llenado capilar, pulso con Doppler)","Vendaje de mu\xf1on en forma de espiga para modelado (preparacion para protesis)","Facilitar acompa\xf1amiento psicologico y de salud mental","Coordinar con equipo de rehabilitacion desde el ingreso"],educacionPaciente:["Explicar el proceso de cicatrizacion y tiempos esperados de recuperacion","Ense\xf1ar cuidados del mu\xf1on: higiene, vendaje, inspeccion diaria","Informar sobre dolor de miembro fantasma: es real, es frecuente y tiene tratamiento","Orientar sobre opciones protesicas y proceso de rehabilitacion","Ense\xf1ar ejercicios de rango de movimiento y fortalecimiento del mu\xf1on","Derivar a grupos de apoyo y salud mental","Educar sobre prevencion de accidentes laborales y uso de proteccion"],monitorizacion:["Signos vitales cada 15 minutos durante estabilizacion inicial, luego cada hora","Control de hemoglobina seriada cada 6-8 horas en las primeras 24 horas","Post-reimplante: evaluacion del segmento reimplantado cada hora por 72 horas (color, temperatura, llenado capilar, Doppler)","Balance hidrico estricto","Temperatura corporal cada 4 horas (detectar infeccion temprana)","EVA de dolor cada 2-4 horas"]},npiNanda:[{codigo:"00046",nombre:"Deterioro de la integridad cutanea",definicion:"Alteracion de la epidermis y/o dermis causada por agente traumatico externo con perdida de segmento corporal",caracteristicasDefinitorias:["Destruccion de capas de la piel y tejidos profundos","Exposicion de estructuras anatomicas (hueso, tendones)","Herida abierta con bordes irregulares o netos","Sangrado activo"],factoresRelacionados:["Trauma mecanico directo","Fuerza de aplastamiento o cizallamiento","Avulsion tisular"]},{codigo:"00206",nombre:"Riesgo de sangrado",definicion:"Vulnerable a una disminucion del volumen de sangre que puede comprometer la salud",caracteristicasDefinitorias:["Hemorragia activa por mu\xf1on","Taquicardia compensadora","Hipotension arterial","Palidez y frialdad periferica"],factoresRelacionados:["Seccion de vasos sanguineos mayores","Coagulopatia por consumo","Trauma tisular extenso"]},{codigo:"00118",nombre:"Trastorno de la imagen corporal",definicion:"Confusion en la imagen mental del yo fisico del individuo tras la perdida de un segmento corporal",caracteristicasDefinitorias:["Expresiones de sentimientos negativos sobre el cuerpo","Temor al rechazo social","No mirar la parte afectada","Preocupacion por la perdida funcional"],factoresRelacionados:["Perdida traumatica de extremidad o segmento","Cambio en la funcionalidad","Alteracion de la autoimagen"]}],npiNic:[{codigo:"4030",nombre:"Administracion de hemoderivados",actividades:["Verificar grupo y factor del paciente y compatibilidad","Controlar signos vitales antes, durante y despues de la transfusion","Vigilar signos de reaccion transfusional (fiebre, urticaria, disnea)","Administrar a velocidad adecuada segun indicacion","Registrar volumen transfundido y respuesta del paciente"]},{codigo:"3660",nombre:"Cuidado de heridas",actividades:["Realizar curaciones con tecnica aseptica estricta","Evaluar caracteristicas de la herida: color, olor, exudado, bordes","Irrigar con solucion fisiologica abundante","Aplicar vendaje adecuado al tipo de herida y fase de cicatrizacion","Documentar evolucion de la herida con mediciones y fotografias"]},{codigo:"5270",nombre:"Apoyo emocional",actividades:["Proporcionar ambiente seguro para expresion de sentimientos","Escuchar activamente y validar emociones del paciente","Facilitar el proceso de duelo por la perdida corporal","Derivar a profesional de salud mental si requiere","Incluir a la familia en el proceso de apoyo emocional"]}],npiNoc:[{codigo:"1101",nombre:"Integridad tisular: piel y membranas mucosas",indicadores:["Cicatrizacion del mu\xf1on en tiempo esperado","Ausencia de signos de infeccion","Perfusion tisular adecuada del mu\xf1on","Cierre progresivo de la herida"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"},{codigo:"1200",nombre:"Imagen corporal",indicadores:["Aceptacion progresiva del cambio corporal","Disposicion a mirar y tocar el mu\xf1on","Participacion activa en el cuidado del mu\xf1on","Adaptacion a dispositivos protesicos"],escala:"1=Nunca positivo, 2=Raramente positivo, 3=A veces positivo, 4=Frecuentemente positivo, 5=Siempre positivo"}],complicaciones:["Shock hipovolemico por hemorragia masiva","Infeccion del mu\xf1on (celulitis, osteomielitis, gangrena gaseosa)","Dolor de miembro fantasma (presente en 50-80% de los amputados)","Fracaso de reimplantacion (trombosis vascular, necrosis del segmento)","Sindrome compartimental post-reimplante","Contractura en flexion del mu\xf1on","Neuroma doloroso en el mu\xf1on","Sindrome de estres postraumatico (TEPT)"],criteriosAlarma:["Hemorragia activa no controlable con presion directa","Signos de shock hipovolemico (FC > 120, PAS < 90, alteracion de conciencia)","Parte amputada con tiempo de isquemia caliente > 6 horas","Post-reimplante: palidez, frialdad o cianosis del segmento reimplantado","Fiebre > 38.5\xb0C con signos de infeccion local (secrecion purulenta, crepitacion)","Dolor progresivo e intenso en mu\xf1on no aliviado con analgesia (sospecha de sindrome compartimental)","Mioglobinuria (orina oscura) sugiriendo rabdomiolisis"],emergencyLevel:"critico",relatedPathologyIds:["pat_shock_hipovolemico","pat_politraumatismo","pat_fracturas","pat_sindrome_compartimental"],isPremium:!1},{id:"pat_hipotermia",nombre:"Hipotermia",bodySystemId:"traumatologico",definicion:"Disminucion de la temperatura corporal central por debajo de 35\xb0C, causada por exposicion ambiental prolongada al frio, inmersion en agua fria, o condiciones medicas predisponentes. La hipotermia afecta progresivamente todos los sistemas organicos, con especial impacto en el sistema cardiovascular y neurologico. Es una emergencia potencialmente mortal que requiere recalentamiento controlado y soporte vital avanzado.",epidemiologia:"Causa aproximadamente 1.500 muertes anuales en Estados Unidos y cifras similares en Europa. Incidencia mayor en climas frios, pero puede ocurrir en cualquier latitud (incluso en ambientes templados en personas vulnerables). Poblacion de riesgo: personas en situacion de calle (40% de los casos), adultos mayores, recien nacidos y deportistas de monta\xf1a. Mortalidad del 12-33% en hipotermia moderada y del 40-80% en hipotermia severa. En Argentina, los casos se concentran en Patagonia y zonas cordilleranas en invierno.",factoresRiesgo:["Exposicion prolongada al frio ambiental sin proteccion adecuada","Inmersion en agua fria (ahogamiento, naufragio)","Edad extrema (recien nacidos y adultos mayores > 65 a\xf1os)","Consumo de alcohol (vasodilatacion periferica, alteracion de termorregulacion, conducta de riesgo)","Personas en situacion de calle","Hipotiroidismo e insuficiencia suprarrenal","Desnutricion y caquexia","Uso de drogas sedantes, neurolepticos u opioides","Trauma mayor con shock y perdida sanguinea","Lesion medular (perdida de termorregulacion autonomica)"],fisiopatologia:"La temperatura corporal se mantiene normalmente entre 36.5-37.5\xb0C mediante el equilibrio entre produccion (metabolismo, escalofrios, ejercicio) y perdida de calor (radiacion, conduccion, conveccion, evaporacion). Cuando la perdida supera la produccion, la temperatura central desciende. En la fase inicial (35-32\xb0C), el organismo activa mecanismos compensadores: escalofrios intensos, vasoconstriccion periferica, taquicardia y aumento del metabolismo. Por debajo de 32\xb0C los escalofrios cesan, el metabolismo basal cae un 6-7% por cada grado, y la frecuencia cardiaca disminuye progresivamente. La conduccion cardiaca se enlentece, apareciendo las caracteristicas ondas J de Osborn en el ECG (deflexion positiva en la union del QRS con el segmento ST). Por debajo de 28\xb0C el miocardio se vuelve extremadamente irritable, con alto riesgo de fibrilacion ventricular espontanea o desencadenada por estimulos minimos (movimientos bruscos, manipulacion del paciente, canalizacion de via central). La actividad enzimatica se reduce, prolongando la vida media de los farmacos. El flujo sanguineo cerebral disminuye un 6-7% por grado, lo que paradojicamente confiere cierta neuroproteccion (reduccion del consumo de oxigeno cerebral). Esta es la base de la regla: nadie esta muerto hasta que este caliente y muerto.",signosYSintomas:{signos:["Temperatura central < 35\xb0C (medida rectal o esofagica)","Escalofrios intensos (presentes en hipotermia leve, ausentes en severa)","Bradicardia progresiva (puede llegar a < 30 lpm)","Ondas J de Osborn en electrocardiograma","Piel fria, palida y cianotica","Rigidez muscular generalizada (simula rigor mortis)","Hipotension arterial progresiva","Respiracion superficial y lenta (bradipnea)","Pupilas dilatadas y poco reactivas en hipotermia severa","Arreflexia en casos severos"],sintomas:["Sensacion intensa de frio y malestar general","Confusion progresiva y desorientacion","Habla arrastrada y dificultad para articular","Somnolencia progresiva que evoluciona a coma","Torpeza y falta de coordinacion motora","Comportamiento paradojico: desvestimiento paradojico (el paciente se quita la ropa)"]},clasificacion:{nombre:"Clasificacion de hipotermia segun temperatura central",tipos:[{nombre:"Hipotermia leve (Grado I)",descripcion:"Temperatura central 32-35\xb0C. Paciente consciente con escalofrios. Taquicardia, taquipnea, vasoconstriccion. Confuso pero cooperador. Tratamiento: recalentamiento pasivo"},{nombre:"Hipotermia moderada (Grado II)",descripcion:"Temperatura central 28-32\xb0C. Escalofrios ausentes. Bradicardia progresiva. Ondas J de Osborn en ECG. Alteracion de conciencia (estupor). Riesgo de arritmias. Tratamiento: recalentamiento activo externo"},{nombre:"Hipotermia severa (Grado III)",descripcion:"Temperatura central < 28\xb0C. Coma. Rigidez muscular. Alto riesgo de fibrilacion ventricular espontanea. Pupilas pueden estar fijas y dilatadas (NO indica muerte cerebral). Tratamiento: recalentamiento activo interno. ECMO si disponible"},{nombre:"Hipotermia profunda / Paro cardiaco (Grado IV)",descripcion:"Temperatura central < 24\xb0C o paro cardiaco. Ausencia de signos vitales. RCP prolongada hasta recalentamiento. Nadie esta muerto hasta que este caliente y muerto. ECMO es el tratamiento de eleccion"}]},diagnostico:{anamnesis:["Tiempo y condiciones de exposicion al frio","Tipo de exposicion: ambiental vs inmersion en agua","Temperatura ambiental y condiciones climaticas","Consumo de alcohol u otras sustancias","Antecedentes de hipotiroidismo, insuficiencia suprarrenal o diabetes","Medicacion habitual (betabloqueantes, sedantes, neurolepticos)","Posibilidad de trauma asociado","Actividades realizadas antes de la exposicion (monta\xf1ismo, naufragio)"],examenFisico:["Medicion de temperatura central con termometro de baja lectura (rectal o esofagico, NUNCA axilar)","Evaluacion del nivel de conciencia y Glasgow","Frecuencia cardiaca y ritmo (bradicardia esperada, buscar arritmias)","Patron respiratorio (bradipnea esperada)","Evaluacion de piel: color, temperatura, llenado capilar","Presencia o ausencia de escalofrios (indicador de severidad)","Busqueda de congelacion localizada en extremidades, nariz y orejas","Evaluacion de rigidez muscular"],pruebas:[{nombre:"Electrocardiograma de 12 derivaciones",descripcion:"Fundamental para detectar ondas J de Osborn (patognomonicas de hipotermia), bradicardia sinusal, prolongacion de intervalos PR, QRS y QT, fibrilacion auricular y riesgo de fibrilacion ventricular. Las ondas J son proporcionales al grado de hipotermia",valoresReferencia:"Normal: ritmo sinusal 60-100 lpm. En hipotermia: bradicardia sinusal, ondas J de Osborn, intervalos prolongados. FV < 28\xb0C",cuidadosEnfermeria:["Secar bien la piel antes de colocar electrodos","Monitoreo cardiaco continuo obligatorio","No realizar maniobras bruscas durante la colocacion (riesgo de FV)","Alertar ante cambios de ritmo subitos"]},{nombre:"Gasometria arterial con correccion por temperatura",descripcion:"Evalua acidosis metabolica y respiratoria. Los valores de pH y gases varian con la temperatura: se debe solicitar correccion por temperatura del paciente o interpretar con metodo alfa-stat (sin corregir). La acidosis metabolica con lactato elevado indica hipoperfusion tisular",valoresReferencia:"pH corregido 7.35-7.45, PaO2 > 60 mmHg, PaCO2 35-45 mmHg, Lactato < 2 mmol/L (elevado indica mal pronostico)",cuidadosEnfermeria:["Solicitar correccion por temperatura al laboratorio","Puncion arterial con cuidado de no estimular arritmias","Registrar temperatura central al momento de la extraccion","Seriada cada 2-4 horas durante recalentamiento"]},{nombre:"Laboratorio completo (hemograma, electrolitos, coagulacion, glucemia, CPK, amilasa)",descripcion:"La hipotermia causa hemoconcentracion, hiperpotasemia (predictor de mortalidad si K > 12 mEq/L), coagulopatia (el coagulograma puede ser normal in vitro porque se procesa a 37\xb0C, pero in vivo hay coagulopatia), hipoglucemia o hiperglucemia, elevacion de CPK por rabdomiolisis y amilasa por pancreatitis",valoresReferencia:"K < 5.5 mEq/L (K > 12 = criterio de irreversibilidad), Glucemia 80-180 mg/dL, INR < 1.5, CPK < 1000 U/L",cuidadosEnfermeria:["Extraer muestras sin torniquete prolongado (falsa hiperpotasemia)","Solicitar potasio de urgencia (predictor pronostico clave)","Monitorizar glucemia capilar cada 2 horas","Repetir laboratorio cada 4-6 horas durante recalentamiento"]}]},tratamientoMedico:{objetivos:["Recalentar al paciente de forma gradual y controlada (1-2\xb0C por hora)","Prevenir y tratar arritmias cardiacas (especialmente FV)","Corregir alteraciones metabolicas (acidosis, hiperpotasemia, hipoglucemia)","Mantener estabilidad hemodinamica durante el recalentamiento","Manejar al paciente con extrema delicadeza para evitar desencadenar FV"],farmacologico:[{nombre:"Solucion salina normal tibia (ClNa 0.9% a 40-42\xb0C)",grupo:"Cristaloide isotonico para recalentamiento interno",mecanismo:"Contribuye al recalentamiento activo interno al aportar calor directamente al compartimiento intravascular. Corrige la hipovolemia por vasodilatacion durante el recalentamiento (shock por recalentamiento). Los liquidos frios empeoran la hipotermia",dosis:"Bolos de 250-500 mL a 40-42\xb0C. Volumen total segun respuesta hemodinamica. En ni\xf1os: 20 mL/kg en bolos. Usar calentador de fluidos en linea",cuidadosEnfermeria:["SIEMPRE calentar los fluidos antes de administrar (40-42\xb0C)","Usar calentador de fluidos en linea si disponible","Monitorizar temperatura central cada 30 minutos","Vigilar signos de sobrecarga hidrica durante recalentamiento","No administrar Ringer lactato (el higado hipotermico no metaboliza el lactato)"]},{nombre:"Epinefrina (en paro cardiaco por hipotermia)",grupo:"Catecolamina / Vasopresor",mecanismo:"Agonista adrenergico alfa y beta. En hipotermia severa, la respuesta a catecolaminas esta disminuida y el riesgo de arritmias aumenta. Se limita su uso: NO administrar si la temperatura central es < 30\xb0C. Entre 30-35\xb0C, espaciar las dosis al doble del intervalo habitual. Solo usar cuando la temperatura supere los 30\xb0C",dosis:"1 mg IV cada 3-5 min en RCP estandar. Si temperatura < 30\xb0C: NO administrar hasta recalentamiento. Si 30-35\xb0C: espaciar a 1 mg cada 6-10 min. Retomar dosis normales cuando temperatura > 35\xb0C",cuidadosEnfermeria:["Verificar temperatura central ANTES de cada dosis","NO administrar si temperatura < 30\xb0C (corazon no responde y acumula farmacos)","Espaciar dosis al doble si temperatura 30-35\xb0C","Monitorizar ritmo cardiaco continuo","Registrar cada dosis con temperatura central correspondiente"]},{nombre:"Dextrosa al 50% (si hipoglucemia)",grupo:"Suplemento de glucosa",mecanismo:"Corrige la hipoglucemia que ocurre por agotamiento de las reservas de glucogeno hepatico tras escalofrios prolongados. El cerebro hipotermico es especialmente vulnerable a la hipoglucemia. Tambien puede haber hiperglucemia por resistencia a la insulina inducida por hipotermia",dosis:"25-50 mL de Dextrosa al 50% IV (equivale a 12.5-25 g de glucosa). En ni\xf1os: Dextrosa al 10%, 2-4 mL/kg. Titular segun glucemia capilar",cuidadosEnfermeria:["Verificar glucemia capilar antes de administrar","Administrar por via central o vena gruesa (la Dextrosa 50% es hipertonica e irritante)","Monitorizar glucemia cada 30 minutos tras la administracion","No corregir hiperglucemia leve con insulina (la insulina es ineficaz en hipotermia)"]}],noFarmacologico:["Recalentamiento pasivo (hipotermia leve): retirar ropa mojada, cubrir con mantas secas, ambiente calido, bebidas calientes si consciente","Recalentamiento activo externo (hipotermia moderada): mantas de aire caliente forzado (Bair Hugger), compresas calientes en axilas, ingles y cuello (zonas de grandes vasos)","Recalentamiento activo interno (hipotermia severa): liquidos IV tibios, lavado vesical, gastrico o peritoneal con solucion a 40-42\xb0C","ECMO o bypass cardiopulmonar (hipotermia severa con paro cardiaco): recalentamiento mas rapido y efectivo, permite soporte circulatorio simultaneo","Manipulacion extremadamente cuidadosa del paciente (movimientos minimos y suaves para evitar desencadenar FV)","NO desfibrilar si temperatura < 30\xb0C (miocardio refractario); intentar un maximo de 3 descargas, si no responde esperar a recalentar > 30\xb0C","RCP prolongada: continuar hasta que el paciente este caliente (> 32\xb0C) o hasta que se determine irreversibilidad (K > 12 mEq/L)"],quirurgico:["Canulacion para ECMO venoarterial en hipotermia severa con paro cardiaco refractario","Lavado peritoneal con solucion tibia a 40-42\xb0C a traves de cateteres intraperitoneales","Lavado pleural bilateral con solucion tibia (alternativa si no hay ECMO)","Toracostomia si neumotorax por RCP prolongada o barotrauma"]},cuidadosEnfermeria:{valoracion:["Medicion de temperatura central con termometro de baja lectura (rectal o esofagico, NUNCA axilar ni oral)","Evaluacion del nivel de conciencia y Glasgow (la respuesta pupilar puede estar abolida sin indicar muerte cerebral)","Monitoreo cardiaco continuo (buscar ondas J, bradicardia, arritmias)","Evaluacion de escalofrios (su ausencia indica hipotermia moderada-severa)","Valoracion de piel: color, temperatura, presencia de congelacion localizada","Estado hemodinamico: PA, FC (puede requerir palpacion prolongada para detectar pulso lento)","Evaluacion de rigidez muscular (no confundir con rigor mortis)"],intervenciones:["Retirar toda la ropa mojada con tijera (minimizar movimientos)","Aplicar recalentamiento segun grado de hipotermia (pasivo, activo externo, activo interno)","Manejar al paciente horizontalmente y con movimientos MINIMOS (prevenir FV)","NO frotar ni masajear la piel (riesgo de FV y da\xf1o tisular)","Administrar liquidos IV calentados a 40-42\xb0C exclusivamente","Mantener monitoreo cardiaco continuo con alarmas activadas","Preparar equipo de desfibrilacion y RCP avanzada","Si paro cardiaco: RCP continua hasta recalentamiento > 32\xb0C o criterio de irreversibilidad"],educacionPaciente:["Explicar que la recuperacion puede ser completa incluso tras hipotermia severa","Ense\xf1ar medidas de prevencion: vestimenta adecuada en capas, proteccion de extremidades","Educar sobre signos tempranos de hipotermia: escalofrios, confusion, torpeza","Importancia de no consumir alcohol antes de exposicion al frio","Ense\xf1ar primeros auxilios basicos: retirar ropa mojada, abrigar, buscar refugio","Informar sobre poblaciones vulnerables: adultos mayores, ni\xf1os, personas con enfermedades cronicas"],monitorizacion:["Temperatura central cada 30 minutos durante recalentamiento activo","ECG continuo con alarma para arritmias (especialmente FV y bradicardia severa)","Signos vitales cada 15-30 minutos durante fase critica","Glucemia capilar cada 2 horas","Potasio serico cada 2-4 horas (predictor pronostico clave)","Gasometria arterial seriada con correccion por temperatura","Diuresis horaria (objetivo > 0.5 mL/kg/h)"]},npiNanda:[{codigo:"00006",nombre:"Hipotermia",definicion:"Temperatura corporal central por debajo de los rangos normales diurnos debido a fallo de la termorregulacion",caracteristicasDefinitorias:["Temperatura central < 35\xb0C","Escalofrios (leve) o ausencia de escalofrios (severa)","Piel fria al tacto","Cianosis en lechos ungueales","Bradicardia"],factoresRelacionados:["Exposicion prolongada a ambiente frio","Inmersion en agua fria","Ropa mojada o inadecuada","Consumo de alcohol","Edad extrema","Enfermedades endocrinas"]},{codigo:"00029",nombre:"Disminucion del gasto cardiaco",definicion:"Cantidad de sangre bombeada por el corazon insuficiente para satisfacer las demandas metabolicas del organismo",caracteristicasDefinitorias:["Bradicardia progresiva","Hipotension arterial","Llenado capilar lento","Oliguria"],factoresRelacionados:["Depresion miocardica por hipotermia","Arritmias cardiacas","Alteracion de la conduccion cardiaca","Disminucion de la contractilidad"]},{codigo:"00038",nombre:"Riesgo de trauma fisico",definicion:"Vulnerable a una lesion corporal accidental que puede comprometer la salud",caracteristicasDefinitorias:["Falta de coordinacion motora","Confusion y desorientacion","Disminucion de la sensibilidad al dolor","Conducta paradojica (desvestimiento)"],factoresRelacionados:["Alteracion del nivel de conciencia","Perdida de coordinacion","Disminucion de sensibilidad periferica","Hipotermia cerebral"]}],npiNic:[{codigo:"3900",nombre:"Regulacion de la temperatura",actividades:["Monitorizar temperatura central cada 30 minutos","Aplicar metodo de recalentamiento apropiado al grado de hipotermia","Administrar liquidos intravenosos calentados a 40-42\xb0C","Retirar ropa mojada y cubrir con mantas secas","Registrar curva termica y correlacionar con estado clinico"]},{codigo:"4040",nombre:"Cuidados cardiacos: agudos",actividades:["Mantener monitoreo ECG continuo con alarmas","Minimizar estimulacion cardiaca (movimientos suaves, evitar via central si posible)","Preparar desfibrilador y farmacos de RCP","NO desfibrilar si temperatura < 30\xb0C (maximo 3 intentos)","Administrar vasoactivos con precaucion y dosis ajustadas"]},{codigo:"6680",nombre:"Monitorizacion de signos vitales",actividades:["Controlar PA, FC y FR cada 15-30 minutos","Verificar pulso durante al menos 60 segundos (bradicardia extrema puede simular ausencia de pulso)","Monitorizar SpO2 continua","Evaluar ritmo cardiaco y buscar ondas J de Osborn","Correlacionar signos vitales con temperatura central"]}],npiNoc:[{codigo:"0800",nombre:"Termorregulacion",indicadores:["Temperatura central en rango normal (36-37.5\xb0C)","Ausencia de escalofrios","Piel tibia y bien perfundida","Frecuencia cardiaca en rango normal","Estado de conciencia normal"],escala:"1=Gravemente comprometido, 2=Sustancialmente comprometido, 3=Moderadamente comprometido, 4=Levemente comprometido, 5=No comprometido"},{codigo:"0802",nombre:"Signos vitales",indicadores:["PA sistolica y diastolica en rango","Frecuencia cardiaca 60-100 lpm","Frecuencia respiratoria 12-20 rpm","Temperatura central 36-37.5\xb0C"],escala:"1=Desviacion grave, 2=Desviacion sustancial, 3=Desviacion moderada, 4=Desviacion leve, 5=Sin desviacion"}],complicaciones:["Fibrilacion ventricular espontanea o inducida por manipulacion","Shock por recalentamiento (vasodilatacion periferica subita con caida de PA)","Coagulopatia (la hipotermia inhibe la cascada de coagulacion in vivo)","Pancreatitis aguda por hipotermia","Rabdomiolisis con insuficiencia renal aguda","Edema pulmonar por redistribucion durante recalentamiento","Acidosis metabolica severa con hiperlactacidemia","Encefalopatia hipoxico-isquemica si paro cardiaco prolongado"],criteriosAlarma:["Temperatura central < 28\xb0C (riesgo inminente de FV)","Fibrilacion ventricular o asistolia","Potasio serico > 12 mEq/L (criterio de irreversibilidad)","Ausencia de respuesta a RCP prolongada con temperatura > 32\xb0C","Acidosis severa pH < 6.8 refractaria al tratamiento","Bradicardia extrema < 30 lpm con hipotension refractaria","Desvestimiento paradojico (signo de hipotermia moderada-severa que puede confundirse con otra causa)"],emergencyLevel:"critico",relatedPathologyIds:["pat_ahogamiento","pat_paro_cardiorrespiratorio","pat_shock","pat_politraumatismo","pat_congelacion"],isPremium:!1}]},784,[]);
__d(function(o,i,e,a,n,r,c){n.exports=[{id:"cardiovascular",nombre:"Sistema Cardiovascular",descripcion:"Corazon, vasos sanguineos y circulacion. Incluye patologias como hipertension, insuficiencia cardiaca, infarto y arritmias.",color:"#E55050",icon:"heart-pulse",pathologyCount:16},{id:"respiratorio",nombre:"Sistema Respiratorio",descripcion:"Vias aereas, pulmones e intercambio gaseoso. Incluye EPOC, asma, neumonia y embolia pulmonar.",color:"#54A0FF",icon:"lungs",pathologyCount:13},{id:"neurologico",nombre:"Sistema Neurologico",descripcion:"Cerebro, medula espinal y nervios perifericos. Incluye ACV, epilepsia, Parkinson y meningitis.",color:"#6C5CE7",icon:"brain",pathologyCount:13},{id:"digestivo",nombre:"Sistema Digestivo",descripcion:"Tracto gastrointestinal, higado, pancreas y vesicula. Incluye ulcera peptica, cirrosis y pancreatitis.",color:"#F78B3D",icon:"stomach",pathologyCount:13},{id:"endocrino",nombre:"Sistema Endocrino",descripcion:"Glandulas y hormonas. Incluye diabetes mellitus, hipo/hipertiroidismo e insuficiencia suprarrenal.",color:"#E0A030",icon:"scale-balance",pathologyCount:12},{id:"renal_urinario",nombre:"Sistema Renal y Urinario",descripcion:"Ri\xf1ones, ureteres, vejiga y uretra. Incluye insuficiencia renal, infeccion urinaria y litiasis.",color:"#FDAD5A",icon:"kidney",pathologyCount:14},{id:"musculoesqueletico",nombre:"Sistema Musculoesqueletico",descripcion:"Huesos, articulaciones, musculos y tejido conectivo. Incluye fracturas, artritis y osteoporosis.",color:"#00B894",icon:"bone",pathologyCount:13},{id:"hematologico",nombre:"Sistema Hematologico",descripcion:"Sangre y organos hematopoyeticos. Incluye anemias, leucemias y trastornos de coagulacion.",color:"#C44569",icon:"water",pathologyCount:13},{id:"inmunologico",nombre:"Sistema Inmunologico",descripcion:"Defensa del organismo. Incluye VIH/SIDA, lupus, artritis reumatoide y reacciones alergicas.",color:"#2ECC71",icon:"shield-plus-outline",pathologyCount:12},{id:"tegumentario",nombre:"Sistema Tegumentario",descripcion:"Piel, cabello y u\xf1as. Incluye ulceras por presion, quemaduras, dermatitis y heridas.",color:"#E8A87C",icon:"hand-back-right-outline",pathologyCount:12},{id:"reproductivo",nombre:"Sistema Reproductivo",descripcion:"Organos reproductivos masculinos y femeninos. Incluye preeclampsia, cancer de mama y prostatitis.",color:"#FD79A8",icon:"human-pregnant",pathologyCount:12},{id:"traumatologico",nombre:"Traumatologia y Emergencias",descripcion:"Lesiones por trauma, quemaduras y emergencias traumaticas. Incluye TCE, politraumatismo, fracturas y lesion medular.",color:"#FF6348",icon:"ambulance",pathologyCount:10}]},785,[]);
__d(function(e,a,i,o,n,l,r){n.exports=[{id:"scale_glasgow",nombre:"Escala de Coma de Glasgow",abreviatura:"GCS",descripcion:"Escala neurol\xf3gica que valora el nivel de conciencia mediante tres par\xe1metros: apertura ocular, respuesta verbal y respuesta motora.",tipo:"components",categoria:"neurologia",componentes:[{nombre:"Apertura ocular",opciones:[{label:"Ninguna",value:1},{label:"Al dolor",value:2},{label:"A la voz",value:3},{label:"Espont\xe1nea",value:4}]},{nombre:"Respuesta verbal",opciones:[{label:"Ninguna",value:1},{label:"Sonidos incomprensibles",value:2},{label:"Palabras inapropiadas",value:3},{label:"Confusa",value:4},{label:"Orientada",value:5}]},{nombre:"Respuesta motora",opciones:[{label:"Ninguna",value:1},{label:"Extensi\xf3n anormal (descerebraci\xf3n)",value:2},{label:"Flexi\xf3n anormal (decorticaci\xf3n)",value:3},{label:"Retirada al dolor",value:4},{label:"Localiza el dolor",value:5},{label:"Obedece \xf3rdenes",value:6}]}],interpretaciones:[{rango:[3,8],label:"Traumatismo craneoencef\xe1lico grave",color:"#DC2626",descripcion:"Coma profundo. Requiere intubaci\xf3n, ventilaci\xf3n mec\xe1nica y manejo en UCI. Evaluar necesidad de TAC urgente e intervenci\xf3n neuroquir\xfargica."},{rango:[9,12],label:"Traumatismo craneoencef\xe1lico moderado",color:"#EA580C",descripcion:"Alteraci\xf3n significativa del nivel de conciencia. Requiere monitorizaci\xf3n estrecha, TAC cerebral y valoraci\xf3n neuroquir\xfargica."},{rango:[13,15],label:"Traumatismo craneoencef\xe1lico leve",color:"#16A34A",descripcion:"Nivel de conciencia conservado o levemente alterado. Observaci\xf3n cl\xednica y seguimiento neurol\xf3gico peri\xf3dico."}],rangoTotal:[3,15],contextoClinico:"Utilizada en urgencias, UCI y servicios de neurolog\xeda para evaluar el nivel de conciencia en pacientes con traumatismo craneoencef\xe1lico, ictus u otras lesiones neurol\xf3gicas. Se debe reevaluar peri\xf3dicamente para detectar cambios en el estado neurol\xf3gico.",referencia:"Teasdale G, Jennett B. Assessment of coma and impaired consciousness: a practical scale. Lancet. 1974;2(7872):81-84."},{id:"scale_apgar",nombre:"Test de APGAR",abreviatura:"APGAR",descripcion:"Evaluaci\xf3n r\xe1pida del estado cl\xednico del reci\xe9n nacido al minuto y a los 5 minutos de vida, valorando cinco par\xe1metros vitales.",tipo:"components",categoria:"neonatologia",componentes:[{nombre:"Apariencia (color de piel)",opciones:[{label:"Cianosis generalizada o palidez",value:0},{label:"Acrocianosis (cuerpo rosado, extremidades azules)",value:1},{label:"Completamente rosado",value:2}]},{nombre:"Pulso (frecuencia card\xedaca)",opciones:[{label:"Ausente",value:0},{label:"Menor de 100 lpm",value:1},{label:"Mayor o igual a 100 lpm",value:2}]},{nombre:"Gesticulaci\xf3n (irritabilidad refleja)",opciones:[{label:"Sin respuesta",value:0},{label:"Mueca o llanto d\xe9bil ante est\xedmulo",value:1},{label:"Llanto vigoroso, tos o estornudo",value:2}]},{nombre:"Actividad (tono muscular)",opciones:[{label:"Fl\xe1cido, sin tono",value:0},{label:"Cierta flexi\xf3n de extremidades",value:1},{label:"Movimientos activos, buena flexi\xf3n",value:2}]},{nombre:"Respiraci\xf3n (esfuerzo respiratorio)",opciones:[{label:"Ausente",value:0},{label:"Llanto d\xe9bil, irregular o jadeo",value:1},{label:"Llanto fuerte y vigoroso",value:2}]}],interpretaciones:[{rango:[0,3],label:"Depresi\xf3n severa",color:"#DC2626",descripcion:"Requiere reanimaci\xf3n neonatal inmediata. Iniciar ventilaci\xf3n con presi\xf3n positiva, valorar intubaci\xf3n y compresiones tor\xe1cicas seg\xfan protocolo NRP."},{rango:[4,6],label:"Depresi\xf3n moderada",color:"#EA580C",descripcion:"Requiere intervenci\xf3n activa: estimulaci\xf3n t\xe1ctil, aspiraci\xf3n de secreciones, ox\xedgeno suplementario y valorar ventilaci\xf3n con presi\xf3n positiva."},{rango:[7,10],label:"Normal",color:"#16A34A",descripcion:"Reci\xe9n nacido en buenas condiciones. Continuar con cuidados rutinarios: secado, contacto piel con piel y lactancia materna precoz."}],rangoTotal:[0,10],contextoClinico:"Se aplica a todo reci\xe9n nacido al minuto y a los 5 minutos de vida en la sala de partos. Si la puntuaci\xf3n a los 5 minutos es menor de 7, se repite cada 5 minutos hasta los 20 minutos.",referencia:"Apgar V. A proposal for a new method of evaluation of the newborn infant. Curr Res Anesth Analg. 1953;32(4):260-267."},{id:"scale_norton",nombre:"Escala de Norton",abreviatura:"Norton",descripcion:"Escala que eval\xfaa el riesgo de desarrollar \xfalceras por presi\xf3n (UPP) mediante cinco par\xe1metros cl\xednicos del paciente.",tipo:"components",categoria:"riesgo_ulceras",componentes:[{nombre:"Estado f\xedsico general",opciones:[{label:"Muy malo",value:1},{label:"Malo (pobre)",value:2},{label:"Regular (mediano)",value:3},{label:"Bueno",value:4}]},{nombre:"Estado mental",opciones:[{label:"Estuporoso / comatoso",value:1},{label:"Confuso",value:2},{label:"Ap\xe1tico",value:3},{label:"Alerta / orientado",value:4}]},{nombre:"Actividad",opciones:[{label:"Encamado",value:1},{label:"Sentado (silla de ruedas)",value:2},{label:"Camina con ayuda",value:3},{label:"Ambulante (independiente)",value:4}]},{nombre:"Movilidad",opciones:[{label:"Inm\xf3vil",value:1},{label:"Muy limitada",value:2},{label:"Ligeramente limitada",value:3},{label:"Completa",value:4}]},{nombre:"Incontinencia",opciones:[{label:"Urinaria y fecal",value:1},{label:"Urinaria habitual",value:2},{label:"Ocasional",value:3},{label:"Ninguna (continente)",value:4}]}],interpretaciones:[{rango:[5,9],label:"Riesgo muy alto",color:"#DC2626",descripcion:"Requiere medidas intensivas de prevenci\xf3n: colch\xf3n antiescaras, cambios posturales cada 2 horas, protecci\xf3n de prominencias \xf3seas, nutrici\xf3n hiperproteica y vigilancia continua de la piel."},{rango:[10,12],label:"Riesgo alto",color:"#EA580C",descripcion:"Implementar protocolo de prevenci\xf3n completo: superficies especiales de manejo de presi\xf3n (SEMP), cambios posturales frecuentes, hidrataci\xf3n cut\xe1nea y control nutricional."},{rango:[13,14],label:"Riesgo medio",color:"#F59E0B",descripcion:"Medidas preventivas b\xe1sicas: cambios posturales regulares, hidrataci\xf3n de la piel, vigilancia de zonas de riesgo y educaci\xf3n al paciente/familia."},{rango:[15,20],label:"Riesgo m\xednimo / sin riesgo",color:"#16A34A",descripcion:"Bajo riesgo de \xfalceras por presi\xf3n. Mantener medidas higi\xe9nicas habituales y reevaluar si cambia la situaci\xf3n cl\xednica del paciente."}],rangoTotal:[5,20],contextoClinico:"Aplicar al ingreso hospitalario y reevaluar peri\xf3dicamente en pacientes encamados, con movilidad reducida o en unidades de larga estancia. Es m\xe1s sencilla que la escala de Braden pero menos espec\xedfica.",referencia:"Norton D, McLaren R, Exton-Smith AN. An Investigation of Geriatric Nursing Problems in Hospital. London: Churchill Livingstone; 1962."},{id:"scale_braden",nombre:"Escala de Braden",abreviatura:"Braden",descripcion:"Escala de valoraci\xf3n del riesgo de \xfalceras por presi\xf3n que eval\xfaa seis subescalas. A menor puntuaci\xf3n, mayor riesgo.",tipo:"components",categoria:"riesgo_ulceras",componentes:[{nombre:"Percepci\xf3n sensorial",opciones:[{label:"Completamente limitada: no responde a est\xedmulos dolorosos",value:1},{label:"Muy limitada: solo responde a est\xedmulos dolorosos",value:2},{label:"Ligeramente limitada: responde a \xf3rdenes verbales pero no siempre comunica molestias",value:3},{label:"Sin limitaciones: responde y comunica adecuadamente",value:4}]},{nombre:"Humedad (exposici\xf3n de la piel)",opciones:[{label:"Constantemente h\xfameda: la piel permanece h\xfameda casi siempre",value:1},{label:"Muy h\xfameda: la piel est\xe1 frecuentemente h\xfameda",value:2},{label:"Ocasionalmente h\xfameda: la piel est\xe1 h\xfameda a veces",value:3},{label:"Raramente h\xfameda: la piel est\xe1 seca habitualmente",value:4}]},{nombre:"Actividad",opciones:[{label:"Encamado: confinado en cama",value:1},{label:"En silla: capacidad de deambulaci\xf3n muy limitada",value:2},{label:"Deambula ocasionalmente: con o sin ayuda, distancias cortas",value:3},{label:"Deambula frecuentemente: fuera de la habitaci\xf3n al menos 2 veces/d\xeda",value:4}]},{nombre:"Movilidad",opciones:[{label:"Completamente inm\xf3vil: no realiza ning\xfan cambio de posici\xf3n",value:1},{label:"Muy limitada: realiza cambios de posici\xf3n m\xednimos ocasionalmente",value:2},{label:"Ligeramente limitada: realiza cambios frecuentes aunque peque\xf1os",value:3},{label:"Sin limitaciones: realiza cambios mayores y frecuentes",value:4}]},{nombre:"Nutrici\xf3n",opciones:[{label:"Muy pobre: nunca come una comida completa, ingesta proteica inadecuada",value:1},{label:"Probablemente inadecuada: rara vez come una comida completa",value:2},{label:"Adecuada: come m\xe1s de la mitad de las comidas, ingesta proteica adecuada",value:3},{label:"Excelente: come la mayor\xeda de las comidas, nunca rechaza alimentos",value:4}]},{nombre:"Fricci\xf3n y cizallamiento",opciones:[{label:"Problema: requiere asistencia m\xe1xima para moverse, deslizamiento frecuente",value:1},{label:"Problema potencial: se mueve con dificultad, necesita ayuda m\xednima",value:2},{label:"Sin problema aparente: se mueve de forma independiente, buen control muscular",value:3}]}],interpretaciones:[{rango:[6,9],label:"Riesgo muy alto",color:"#DC2626",descripcion:"M\xe1xima prioridad preventiva. Superficie especial de apoyo din\xe1mica, cambios posturales cada 2 horas, protecci\xf3n de prominencias \xf3seas, suplementaci\xf3n nutricional y cuidados intensivos de la piel."},{rango:[10,12],label:"Riesgo alto",color:"#EA580C",descripcion:"Protocolo de prevenci\xf3n intensivo: colch\xf3n antiescaras, cambios posturales cada 2-3 horas, \xe1cidos grasos hiperoxigenados en zonas de riesgo y valoraci\xf3n nutricional."},{rango:[13,14],label:"Riesgo moderado",color:"#F59E0B",descripcion:"Medidas preventivas activas: cambios posturales regulares, hidrataci\xf3n cut\xe1nea, vigilancia de zonas de presi\xf3n y educaci\xf3n al paciente/cuidador."},{rango:[15,18],label:"Riesgo bajo",color:"#16A34A",descripcion:"Medidas preventivas b\xe1sicas: cuidados habituales de la piel, movilizaci\xf3n activa y reevaluaci\xf3n peri\xf3dica."},{rango:[19,23],label:"Sin riesgo significativo",color:"#16A34A",descripcion:"No precisa medidas especiales de prevenci\xf3n. Reevaluar si cambia la situaci\xf3n cl\xednica del paciente."}],rangoTotal:[6,23],contextoClinico:"Escala de referencia para la prevenci\xf3n de \xfalceras por presi\xf3n. Aplicar al ingreso y reevaluar cada 24-72 horas en pacientes hospitalizados, o semanalmente en residencias y atenci\xf3n domiciliaria.",referencia:"Bergstrom N, Braden BJ, Laguzza A, Holman V. The Braden Scale for predicting pressure sore risk. Nurs Res. 1987;36(4):205-210."},{id:"scale_news2",nombre:"National Early Warning Score 2",abreviatura:"NEWS2",descripcion:"Sistema de puntuaci\xf3n de alerta temprana que eval\xfaa seis par\xe1metros fisiol\xf3gicos para identificar precozmente el deterioro cl\xednico del paciente adulto.",tipo:"components",categoria:"sepsis",componentes:[{nombre:"Frecuencia respiratoria (rpm)",opciones:[{label:"12-20 rpm",value:0},{label:"9-11 rpm",value:1},{label:"21-24 rpm",value:2},{label:"\u22648 o \u226525 rpm",value:3}]},{nombre:"Saturaci\xf3n de ox\xedgeno (SpO\u2082)",opciones:[{label:"\u226596%",value:0},{label:"94-95%",value:1},{label:"92-93%",value:2},{label:"\u226491%",value:3}]},{nombre:"Presi\xf3n arterial sist\xf3lica (mmHg)",opciones:[{label:"111-219 mmHg",value:0},{label:"101-110 mmHg",value:1},{label:"91-100 mmHg",value:2},{label:"\u226490 o \u2265220 mmHg",value:3}]},{nombre:"Frecuencia card\xedaca (lpm)",opciones:[{label:"51-90 lpm",value:0},{label:"41-50 o 91-110 lpm",value:1},{label:"111-130 lpm",value:2},{label:"\u226440 o \u2265131 lpm",value:3}]},{nombre:"Nivel de conciencia (ACVPU)",opciones:[{label:"Alerta (A)",value:0},{label:"Confusi\xf3n de nueva aparici\xf3n (C)",value:3},{label:"Responde a voz (V)",value:3},{label:"Responde a dolor (P)",value:3},{label:"No responde (U)",value:3}]},{nombre:"Temperatura (\xb0C)",opciones:[{label:"36.1-38.0 \xb0C",value:0},{label:"35.1-36.0 \xb0C o 38.1-39.0 \xb0C",value:1},{label:"\u226539.1 \xb0C",value:2},{label:"\u226435.0 \xb0C",value:3}]}],interpretaciones:[{rango:[0,4],label:"Riesgo cl\xednico bajo",color:"#16A34A",descripcion:"Monitorizaci\xf3n rutinaria. Reevaluar cada 4-6 horas como m\xednimo. Si puntuaci\xf3n individual de 3 en un par\xe1metro, aumentar frecuencia de monitorizaci\xf3n."},{rango:[5,6],label:"Riesgo cl\xednico medio",color:"#F59E0B",descripcion:"Respuesta cl\xednica urgente. Avisar al equipo m\xe9dico con competencia en atenci\xf3n aguda. Monitorizaci\xf3n cada hora como m\xednimo."},{rango:[7,18],label:"Riesgo cl\xednico alto",color:"#DC2626",descripcion:"Respuesta cl\xednica emergente. Activar equipo de respuesta r\xe1pida o equipo de cuidados cr\xedticos. Monitorizaci\xf3n continua y considerar traslado a UCI."}],rangoTotal:[0,18],contextoClinico:"Herramienta estandarizada para la detecci\xf3n precoz del deterioro cl\xednico en pacientes adultos hospitalizados. Se utiliza en plantas de hospitalizaci\xf3n, urgencias y servicios de emergencia prehospitalaria.",referencia:"Royal College of Physicians. National Early Warning Score (NEWS) 2: Standardising the assessment of acute-illness severity in the NHS. London: RCP; 2017."},{id:"scale_aldrete",nombre:"Escala de Aldrete modificada",abreviatura:"Aldrete",descripcion:"Escala de valoraci\xf3n postanest\xe9sica que determina si un paciente puede ser dado de alta de la Unidad de Recuperaci\xf3n Postanest\xe9sica (URPA).",tipo:"components",categoria:"postanestesia",componentes:[{nombre:"Actividad muscular",opciones:[{label:"Incapaz de mover extremidades",value:0},{label:"Mueve 2 extremidades voluntariamente",value:1},{label:"Mueve 4 extremidades voluntariamente",value:2}]},{nombre:"Respiraci\xf3n",opciones:[{label:"Apnea",value:0},{label:"Disnea, respiraci\xf3n limitada o taquipnea",value:1},{label:"Capaz de respirar profundamente y toser libremente",value:2}]},{nombre:"Circulaci\xf3n (PA sist\xf3lica)",opciones:[{label:"PA sist\xf3lica \xb150 mmHg del valor preanest\xe9sico",value:0},{label:"PA sist\xf3lica \xb120-49 mmHg del valor preanest\xe9sico",value:1},{label:"PA sist\xf3lica \xb120 mmHg del valor preanest\xe9sico",value:2}]},{nombre:"Conciencia",opciones:[{label:"No responde",value:0},{label:"Se despierta al llamarlo",value:1},{label:"Completamente despierto y orientado",value:2}]},{nombre:"Saturaci\xf3n de ox\xedgeno (SpO\u2082)",opciones:[{label:"SpO\u2082 <90% con O\u2082 suplementario",value:0},{label:"SpO\u2082 90-91% con O\u2082 suplementario",value:1},{label:"SpO\u2082 \u226592% con aire ambiente",value:2}]}],interpretaciones:[{rango:[0,5],label:"No apto para alta de URPA",color:"#DC2626",descripcion:"El paciente requiere vigilancia continua en la URPA. Mantener monitorizaci\xf3n hemodin\xe1mica y respiratoria estricta. Reevaluar cada 15 minutos."},{rango:[6,7],label:"Vigilancia estrecha",color:"#F59E0B",descripcion:"El paciente a\xfan no cumple criterios \xf3ptimos de alta. Continuar vigilancia en URPA y reevaluar cada 15-30 minutos hasta alcanzar puntuaci\xf3n \u22658."},{rango:[8,10],label:"Apto para alta de URPA",color:"#16A34A",descripcion:"El paciente cumple criterios de alta de la Unidad de Recuperaci\xf3n Postanest\xe9sica. Puede ser trasladado a planta con indicaciones postoperatorias."}],rangoTotal:[0,10],contextoClinico:"Se aplica en la Unidad de Recuperaci\xf3n Postanest\xe9sica (URPA) para evaluar la recuperaci\xf3n del paciente tras anestesia general o regional. Se valora al ingreso en URPA y cada 15 minutos hasta el alta.",referencia:"Aldrete JA. The post-anesthesia recovery score revisited. J Clin Anesth. 1995;7(1):89-91."},{id:"scale_nihss",nombre:"Escala NIHSS simplificada",abreviatura:"NIHSS",descripcion:"Versi\xf3n simplificada de la escala del National Institutes of Health Stroke Scale para la valoraci\xf3n r\xe1pida de la gravedad del ictus.",tipo:"components",categoria:"neurologia",componentes:[{nombre:"Nivel de conciencia",opciones:[{label:"Alerta, responde correctamente",value:0},{label:"Somnoliento, responde con estimulaci\xf3n menor",value:1},{label:"Estuporoso, requiere estimulaci\xf3n repetida",value:2},{label:"Coma, no responde o solo reflejos",value:3}]},{nombre:"Mirada conjugada",opciones:[{label:"Normal",value:0},{label:"Paresia parcial de la mirada",value:1},{label:"Desviaci\xf3n forzada de la mirada",value:2}]},{nombre:"Campo visual",opciones:[{label:"Sin d\xe9ficit campim\xe9trico",value:0},{label:"Hemianopsia parcial",value:1},{label:"Hemianopsia completa",value:2},{label:"Ceguera bilateral",value:3}]},{nombre:"Paresia facial",opciones:[{label:"Movimiento normal y sim\xe9trico",value:0},{label:"Paresia menor (asimetr\xeda al sonre\xedr)",value:1},{label:"Paresia parcial (par\xe1lisis facial inferior)",value:2},{label:"Par\xe1lisis completa (sin movimiento facial)",value:3}]},{nombre:"Motor miembros superiores",opciones:[{label:"Sin claudicaci\xf3n (mantiene 10 seg)",value:0},{label:"Claudicaci\xf3n (cae antes de 10 seg sin llegar a cama)",value:1},{label:"Esfuerzo contra gravedad pero no mantiene",value:2},{label:"Sin esfuerzo contra gravedad, cae",value:3},{label:"Sin movimiento",value:4}]},{nombre:"Motor miembros inferiores",opciones:[{label:"Sin claudicaci\xf3n (mantiene 5 seg)",value:0},{label:"Claudicaci\xf3n (cae antes de 5 seg sin llegar a cama)",value:1},{label:"Esfuerzo contra gravedad pero no mantiene",value:2},{label:"Sin esfuerzo contra gravedad, cae",value:3},{label:"Sin movimiento",value:4}]},{nombre:"Lenguaje",opciones:[{label:"Normal, sin afasia",value:0},{label:"Afasia leve a moderada (se comunica con dificultad)",value:1},{label:"Afasia severa (expresi\xf3n fragmentaria)",value:2},{label:"Afasia global o mutismo",value:3}]},{nombre:"Disartria",opciones:[{label:"Articulaci\xf3n normal",value:0},{label:"Disartria leve a moderada (se entiende con dificultad)",value:1},{label:"Disartria severa o anartria (ininteligible o mudo)",value:2}]}],interpretaciones:[{rango:[0,4],label:"Ictus menor",color:"#16A34A",descripcion:"D\xe9ficit neurol\xf3gico leve. Valorar tratamiento seg\xfan protocolo de ictus minor. Monitorizaci\xf3n neurol\xf3gica y prevenci\xf3n secundaria."},{rango:[5,15],label:"Ictus moderado",color:"#F59E0B",descripcion:"D\xe9ficit neurol\xf3gico moderado. Candidato a tratamiento de reperfusi\xf3n (fibrin\xf3lisis IV o trombectom\xeda mec\xe1nica) si est\xe1 dentro de ventana terap\xe9utica. Ingreso en Unidad de Ictus."},{rango:[16,20],label:"Ictus moderado-grave",color:"#EA580C",descripcion:"D\xe9ficit neurol\xf3gico importante. Considerar trombectom\xeda mec\xe1nica. Manejo en Unidad de Ictus o UCI. Alto riesgo de complicaciones."},{rango:[21,24],label:"Ictus grave",color:"#DC2626",descripcion:"D\xe9ficit neurol\xf3gico severo con pron\xf3stico grave. Manejo intensivo, control de complicaciones y decisiones sobre limitaci\xf3n del esfuerzo terap\xe9utico."}],rangoTotal:[0,24],contextoClinico:"Se aplica en urgencias ante sospecha de ictus para cuantificar la gravedad del d\xe9ficit neurol\xf3gico y guiar las decisiones de tratamiento de reperfusi\xf3n. Se reeval\xfaa a las 24 horas y al alta.",referencia:"Brott T, Adams HP Jr, Olinger CP, et al. Measurements of acute cerebral infarction: a clinical examination scale. Stroke. 1989;20(7):864-870."},{id:"scale_rass",nombre:"Escala de Agitaci\xf3n-Sedaci\xf3n de Richmond",abreviatura:"RASS",descripcion:"Escala de 10 puntos que valora el nivel de sedaci\xf3n y agitaci\xf3n del paciente cr\xedtico, desde sedaci\xf3n profunda hasta agitaci\xf3n extrema.",tipo:"selector",categoria:"sedacion",componentes:[{nombre:"Nivel de sedaci\xf3n-agitaci\xf3n",opciones:[{label:"No despertable: sin respuesta a la voz ni a la estimulaci\xf3n f\xedsica",value:-5},{label:"Sedaci\xf3n profunda: sin respuesta a la voz, movimiento o apertura ocular a la estimulaci\xf3n f\xedsica",value:-4},{label:"Sedaci\xf3n moderada: movimiento o apertura ocular a la voz, sin contacto visual",value:-3},{label:"Sedaci\xf3n ligera: se despierta brevemente a la voz, contacto visual <10 seg",value:-2},{label:"Somnoliento: no completamente alerta, pero despierta con la voz, contacto visual >10 seg",value:-1},{label:"Alerta y tranquilo",value:0},{label:"Inquieto: ansioso o aprensivo, sin movimientos agresivos o vigorosos",value:1},{label:"Agitado: movimientos frecuentes sin prop\xf3sito, lucha con el ventilador",value:2},{label:"Muy agitado: se retira tubos o cat\xe9teres, agresivo",value:3},{label:"Combativo: violento, peligro inmediato para el personal",value:4}]}],interpretaciones:[{rango:[-5,-5],label:"No despertable",color:"#DC2626",descripcion:"Sedaci\xf3n excesiva. Valorar reducir o suspender sedantes. Evaluar causas org\xe1nicas de la no respuesta. Monitorizaci\xf3n neurol\xf3gica."},{rango:[-4,-4],label:"Sedaci\xf3n profunda",color:"#DC2626",descripcion:"Solo indicada en situaciones espec\xedficas (SDRA severo, estatus epil\xe9ptico). Valorar necesidad de mantener este nivel o reducir sedaci\xf3n."},{rango:[-3,-3],label:"Sedaci\xf3n moderada",color:"#EA580C",descripcion:"Nivel que puede ser adecuado en las primeras horas de ventilaci\xf3n mec\xe1nica o en procedimientos invasivos. Evaluar transici\xf3n a sedaci\xf3n m\xe1s ligera."},{rango:[-2,-1],label:"Sedaci\xf3n ligera",color:"#F59E0B",descripcion:"Nivel objetivo habitual de sedaci\xf3n en UCI. El paciente puede colaborar y se facilita el destete de la ventilaci\xf3n mec\xe1nica."},{rango:[0,0],label:"Alerta y tranquilo",color:"#16A34A",descripcion:"Estado \xf3ptimo. El paciente est\xe1 despierto, tranquilo y cooperador. Es el objetivo ideal de sedaci\xf3n en la mayor\xeda de pacientes."},{rango:[1,1],label:"Inquieto",color:"#F59E0B",descripcion:"Inquietud leve. Identificar y tratar posibles causas (dolor, ansiedad, delirium, falta de sue\xf1o). Valorar medidas no farmacol\xf3gicas."},{rango:[2,2],label:"Agitado",color:"#EA580C",descripcion:"Agitaci\xf3n moderada. Buscar causas reversibles (dolor, hipoxia, retenci\xf3n urinaria, abstinencia). Considerar tratamiento farmacol\xf3gico si no hay causa tratable."},{rango:[3,4],label:"Muy agitado / Combativo",color:"#DC2626",descripcion:"Agitaci\xf3n severa con riesgo para el paciente y personal. Requiere intervenci\xf3n farmacol\xf3gica inmediata y medidas de seguridad. Descartar causas org\xe1nicas urgentes."}],rangoTotal:[-5,4],contextoClinico:"Escala de referencia en UCI para monitorizar el nivel de sedaci\xf3n-agitaci\xf3n del paciente cr\xedtico. Se eval\xfaa junto con la escala CAM-ICU para el diagn\xf3stico de delirium. Objetivo habitual: RASS entre -2 y 0.",referencia:"Sessler CN, Gosnell MS, Grap MJ, et al. The Richmond Agitation-Sedation Scale: validity and reliability in adult intensive care unit patients. Am J Respir Crit Care Med. 2002;166(10):1338-1344."},{id:"scale_eva",nombre:"Escala Visual Anal\xf3gica del Dolor",abreviatura:"EVA",descripcion:"Escala unidimensional que permite al paciente cuantificar la intensidad de su dolor en una l\xednea de 0 (sin dolor) a 10 (peor dolor imaginable).",tipo:"selector",categoria:"dolor",componentes:[{nombre:"Intensidad del dolor",opciones:[{label:"Sin dolor",value:0},{label:"Dolor muy leve, apenas perceptible",value:1},{label:"Dolor leve, molestia menor",value:2},{label:"Dolor leve, tolerable y no interfiere con actividades",value:3},{label:"Dolor moderado, interfiere con algunas actividades",value:4},{label:"Dolor moderado, interfiere con muchas actividades",value:5},{label:"Dolor moderado-severo, interfiere con la vida diaria",value:6},{label:"Dolor severo, dificulta la concentraci\xf3n",value:7},{label:"Dolor muy severo, afecta severamente las actividades",value:8},{label:"Dolor insoportable, requiere atenci\xf3n inmediata",value:9},{label:"Peor dolor imaginable, completamente incapacitante",value:10}]}],interpretaciones:[{rango:[0,0],label:"Sin dolor",color:"#16A34A",descripcion:"El paciente no refiere dolor. Mantener reevaluaci\xf3n peri\xf3dica."},{rango:[1,3],label:"Dolor leve",color:"#16A34A",descripcion:"Dolor tolerable que generalmente no requiere analgesia o puede tratarse con analg\xe9sicos no opioides (paracetamol, AINEs). Primer escal\xf3n de la OMS."},{rango:[4,6],label:"Dolor moderado",color:"#F59E0B",descripcion:"Requiere tratamiento analg\xe9sico activo. Segundo escal\xf3n de la OMS: analg\xe9sicos no opioides \xb1 opioides d\xe9biles (tramadol, code\xedna). Reevaluar en 30-60 minutos."},{rango:[7,10],label:"Dolor severo",color:"#DC2626",descripcion:"Dolor intenso que requiere intervenci\xf3n urgente. Tercer escal\xf3n de la OMS: opioides potentes (morfina, fentanilo). Reevaluar en 15-30 minutos tras administraci\xf3n."}],rangoTotal:[0,10],contextoClinico:"Quinta constante vital. Se aplica en toda valoraci\xf3n de enfermer\xeda y seguimiento del paciente con dolor. Reevaluar tras cada intervenci\xf3n analg\xe9sica para verificar eficacia del tratamiento.",referencia:"Huskisson EC. Measurement of pain. Lancet. 1974;2(7889):1127-1131."},{id:"scale_mallampati",nombre:"Clasificaci\xf3n de Mallampati",abreviatura:"Mallampati",descripcion:"Clasificaci\xf3n de la v\xeda a\xe9rea que predice la dificultad de intubaci\xf3n orotraqueal seg\xfan la visualizaci\xf3n de las estructuras far\xedngeas con la boca abierta.",tipo:"selector",categoria:"via_aerea",componentes:[{nombre:"Clase de Mallampati",opciones:[{label:"Clase I: paladar blando, \xfavula, fauces y pilares visibles completamente",value:1},{label:"Clase II: paladar blando, \xfavula y fauces visibles",value:2},{label:"Clase III: solo paladar blando y base de \xfavula visibles",value:3},{label:"Clase IV: solo paladar duro visible, paladar blando no visible",value:4}]}],interpretaciones:[{rango:[1,1],label:"Clase I - Intubaci\xf3n f\xe1cil",color:"#16A34A",descripcion:"Visualizaci\xf3n completa de las estructuras. Se prev\xe9 intubaci\xf3n sin dificultad con laringoscopia directa. Cormack-Lehane grado I esperado."},{rango:[2,2],label:"Clase II - Intubaci\xf3n probable sin dificultad",color:"#16A34A",descripcion:"Buena visualizaci\xf3n de estructuras. Intubaci\xf3n probablemente exitosa con laringoscopia directa convencional."},{rango:[3,3],label:"Clase III - Intubaci\xf3n posiblemente dif\xedcil",color:"#F59E0B",descripcion:"Visualizaci\xf3n limitada. Mayor probabilidad de intubaci\xf3n dif\xedcil. Tener preparado dispositivo supragl\xf3tico y videolaringoscopio como alternativa."},{rango:[4,4],label:"Clase IV - Intubaci\xf3n previsiblemente dif\xedcil",color:"#DC2626",descripcion:"No se visualizan estructuras far\xedngeas. Alto riesgo de intubaci\xf3n dif\xedcil. Planificar v\xeda a\xe9rea dif\xedcil: fibroscopio, videolaringoscopio, considerar intubaci\xf3n con paciente despierto."}],rangoTotal:[1,4],contextoClinico:"Se valora en la consulta preanest\xe9sica y antes de cualquier procedimiento que requiera intubaci\xf3n orotraqueal. Debe combinarse con otros predictores de v\xeda a\xe9rea dif\xedcil (distancia tiromentoniana, apertura oral, movilidad cervical).",referencia:"Mallampati SR, Gatt SP, Gugino LD, et al. A clinical sign to predict difficult tracheal intubation: a prospective study. Can Anaesth Soc J. 1985;32(4):429-434."},{id:"scale_asa",nombre:"Clasificaci\xf3n ASA del Estado F\xedsico",abreviatura:"ASA",descripcion:"Sistema de clasificaci\xf3n de la American Society of Anesthesiologists que eval\xfaa el estado f\xedsico del paciente antes de la cirug\xeda para estimar el riesgo anest\xe9sico.",tipo:"selector",categoria:"asa",componentes:[{nombre:"Estado f\xedsico ASA",opciones:[{label:"ASA I: Paciente sano, sin patolog\xeda previa",value:1},{label:"ASA II: Enfermedad sist\xe9mica leve, sin limitaci\xf3n funcional (p. ej., HTA controlada, DM controlada, obesidad leve, tabaquismo)",value:2},{label:"ASA III: Enfermedad sist\xe9mica grave con limitaci\xf3n funcional (p. ej., DM con complicaciones, ICC compensada, EPOC moderada, obesidad m\xf3rbida)",value:3},{label:"ASA IV: Enfermedad sist\xe9mica grave que amenaza la vida (p. ej., ICC descompensada, insuficiencia renal en di\xe1lisis, sepsis, IAM reciente)",value:4},{label:"ASA V: Paciente moribundo que no se espera que sobreviva sin la intervenci\xf3n (p. ej., aneurisma a\xf3rtico roto, TCE con herniaci\xf3n, fallo multiorg\xe1nico)",value:5},{label:"ASA VI: Paciente con muerte cerebral declarada, donante de \xf3rganos",value:6}]}],interpretaciones:[{rango:[1,1],label:"ASA I - Paciente sano",color:"#16A34A",descripcion:"Sin comorbilidades. Riesgo anest\xe9sico m\xednimo. No fumador, no o m\xednimo consumo de alcohol."},{rango:[2,2],label:"ASA II - Enfermedad sist\xe9mica leve",color:"#16A34A",descripcion:"Enfermedad leve sin limitaci\xf3n funcional significativa. Incluye fumador activo, bebedor social, embarazo, obesidad (30<IMC<40), HTA o DM bien controladas."},{rango:[3,3],label:"ASA III - Enfermedad sist\xe9mica grave",color:"#F59E0B",descripcion:"Limitaci\xf3n funcional sustantiva. Riesgo anest\xe9sico moderado. Puede requerir optimizaci\xf3n preoperatoria y planificaci\xf3n anest\xe9sica espec\xedfica."},{rango:[4,4],label:"ASA IV - Amenaza vital constante",color:"#EA580C",descripcion:"Alto riesgo anest\xe9sico y quir\xfargico. Requiere valoraci\xf3n exhaustiva y optimizaci\xf3n preoperatoria. Discusi\xf3n riesgo-beneficio con paciente y familia."},{rango:[5,5],label:"ASA V - Paciente moribundo",color:"#DC2626",descripcion:"No se espera supervivencia sin cirug\xeda. Riesgo extremo. La cirug\xeda es el \xfaltimo recurso terap\xe9utico."},{rango:[6,6],label:"ASA VI - Muerte cerebral",color:"#DC2626",descripcion:"Paciente con muerte cerebral declarada cuya cirug\xeda es para la extracci\xf3n de \xf3rganos para donaci\xf3n."}],rangoTotal:[1,6],contextoClinico:"Se asigna en la consulta preanest\xe9sica a todo paciente que va a ser sometido a un procedimiento anest\xe9sico. Se a\xf1ade el sufijo 'E' si la cirug\xeda es de emergencia (p. ej., ASA III-E).",referencia:"American Society of Anesthesiologists. ASA Physical Status Classification System. Last approved October 2019."},{id:"scale_wells",nombre:"Escala de Wells para TVP/TEP",abreviatura:"Wells",descripcion:"Modelo de predicci\xf3n cl\xednica que estima la probabilidad pretest de trombosis venosa profunda (TVP) o tromboembolismo pulmonar (TEP) mediante criterios cl\xednicos ponderados.",tipo:"checklist",categoria:"trombosis",componentes:[{nombre:"C\xe1ncer activo (tratamiento en curso, en los \xfaltimos 6 meses o paliativo)",opciones:[{label:"No",value:0},{label:"S\xed",value:1}]},{nombre:"Par\xe1lisis, paresia o inmovilizaci\xf3n reciente de MMII",opciones:[{label:"No",value:0},{label:"S\xed",value:1}]},{nombre:"Encamamiento >3 d\xedas o cirug\xeda mayor en las \xfaltimas 12 semanas",opciones:[{label:"No",value:0},{label:"S\xed",value:1}]},{nombre:"Dolor localizado a lo largo del sistema venoso profundo",opciones:[{label:"No",value:0},{label:"S\xed",value:1}]},{nombre:"Edema en toda la pierna",opciones:[{label:"No",value:0},{label:"S\xed",value:1}]},{nombre:"Hinchaz\xf3n de pantorrilla >3 cm respecto a la contralateral",opciones:[{label:"No",value:0},{label:"S\xed",value:1}]},{nombre:"Edema con f\xf3vea (mayor en la pierna sintom\xe1tica)",opciones:[{label:"No",value:0},{label:"S\xed",value:1}]},{nombre:"Venas superficiales colaterales (no varicosas)",opciones:[{label:"No",value:0},{label:"S\xed",value:1}]},{nombre:"TVP previa documentada",opciones:[{label:"No",value:0},{label:"S\xed",value:1}]},{nombre:"Diagn\xf3stico alternativo tan o m\xe1s probable que TVP",opciones:[{label:"No",value:0},{label:"S\xed (resta puntos)",value:-2}]}],interpretaciones:[{rango:[-2,0],label:"Baja probabilidad",color:"#16A34A",descripcion:"Probabilidad de TVP ~5%. Solicitar d\xedmero D: si es negativo, se descarta TVP. Si es positivo, realizar ecograf\xeda Doppler venosa."},{rango:[1,2],label:"Probabilidad moderada",color:"#F59E0B",descripcion:"Probabilidad de TVP ~17%. Solicitar d\xedmero D y ecograf\xeda Doppler venosa. Si d\xedmero D negativo con baja sospecha, se puede descartar."},{rango:[3,9],label:"Alta probabilidad",color:"#DC2626",descripcion:"Probabilidad de TVP ~53%. Realizar ecograf\xeda Doppler venosa de forma urgente. Considerar inicio de anticoagulaci\xf3n emp\xedrica mientras se confirma diagn\xf3stico."}],rangoTotal:[-2,9],contextoClinico:"Se aplica en urgencias ante sospecha cl\xednica de trombosis venosa profunda para estratificar el riesgo y guiar las pruebas diagn\xf3sticas. Debe combinarse con d\xedmero D y ecograf\xeda Doppler seg\xfan el resultado.",referencia:"Wells PS, Anderson DR, Bormanis J, et al. Value of assessment of pretest probability of deep-vein thrombosis in clinical management. Lancet. 1997;350(9094):1795-1798."},{id:"scale_qsofa",nombre:"Quick SOFA",abreviatura:"qSOFA",descripcion:"Herramienta de cribado r\xe1pido para identificar pacientes con sospecha de infecci\xf3n que tienen alto riesgo de mala evoluci\xf3n (sepsis) fuera de la UCI.",tipo:"checklist",categoria:"sepsis",componentes:[{nombre:"Frecuencia respiratoria \u226522 rpm",opciones:[{label:"No",value:0},{label:"S\xed",value:1}]},{nombre:"Presi\xf3n arterial sist\xf3lica \u2264100 mmHg",opciones:[{label:"No",value:0},{label:"S\xed",value:1}]},{nombre:"Alteraci\xf3n del nivel de conciencia (GCS <15)",opciones:[{label:"No",value:0},{label:"S\xed",value:1}]}],interpretaciones:[{rango:[0,1],label:"Bajo riesgo",color:"#16A34A",descripcion:"Bajo riesgo de mala evoluci\xf3n. No descarta sepsis. Continuar vigilancia cl\xednica y reevaluar si hay deterioro. Completar estudio si hay sospecha cl\xednica de infecci\xf3n."},{rango:[2,3],label:"Alto riesgo de sepsis",color:"#DC2626",descripcion:"Alto riesgo de mortalidad hospitalaria. Activar protocolo de sepsis: hemocultivos, lactato s\xe9rico, antibioterapia emp\xedrica precoz y fluidoterapia agresiva en la primera hora. Valorar ingreso en UCI."}],rangoTotal:[0,3],contextoClinico:"Herramienta de cribado a pie de cama para identificar r\xe1pidamente pacientes con sospecha de infecci\xf3n y riesgo de sepsis fuera de la UCI. No es diagn\xf3stica, sino una se\xf1al de alarma para iniciar evaluaci\xf3n y tratamiento urgente.",referencia:"Singer M, Deutschman CS, Seymour CW, et al. The Third International Consensus Definitions for Sepsis and Septic Shock (Sepsis-3). JAMA. 2016;315(8):801-810."},{id:"scale_morse",nombre:"Escala de Ca\xeddas de Morse",abreviatura:"MFS",descripcion:"Escala de valoraci\xf3n del riesgo de ca\xeddas en pacientes hospitalizados. Eval\xfaa seis factores de riesgo para identificar pacientes que requieren medidas preventivas.",tipo:"components",categoria:"caidas",componentes:[{nombre:"Antecedente de ca\xeddas (\xfaltimos 3 meses)",opciones:[{label:"No",value:0},{label:"S\xed",value:25}]},{nombre:"Diagn\xf3stico secundario",opciones:[{label:"No",value:0},{label:"S\xed",value:15}]},{nombre:"Ayuda para deambulaci\xf3n",opciones:[{label:"Ninguna / reposo en cama / ayuda de enfermer\xeda",value:0},{label:"Muletas / bast\xf3n / andador",value:15},{label:"Se apoya en muebles",value:30}]},{nombre:"Terapia intravenosa / dispositivo IV",opciones:[{label:"No",value:0},{label:"S\xed",value:20}]},{nombre:"Marcha",opciones:[{label:"Normal / reposo en cama / silla de ruedas",value:0},{label:"D\xe9bil",value:10},{label:"Alterada / tambaleante",value:20}]},{nombre:"Estado mental",opciones:[{label:"Consciente de sus limitaciones",value:0},{label:"Sobrevalora sus capacidades / olvida limitaciones",value:15}]}],interpretaciones:[{rango:[0,24],label:"Riesgo bajo",color:"#16A34A",descripcion:"Medidas est\xe1ndar de seguridad: cama en posici\xf3n baja, frenos activados, luz nocturna, timbre al alcance."},{rango:[25,44],label:"Riesgo moderado",color:"#F59E0B",descripcion:"Implementar protocolo de prevenci\xf3n: identificaci\xf3n visual (pulsera/cartel), acompa\xf1amiento en deambulaci\xf3n, revisi\xf3n de medicaci\xf3n, calzado antideslizante."},{rango:[45,125],label:"Riesgo alto",color:"#DC2626",descripcion:"Todas las medidas anteriores m\xe1s: valoraci\xf3n frecuente, posible sensor de movimiento, fisioterapia, revisi\xf3n de f\xe1rmacos de riesgo (sedantes, hipotensores, diur\xe9ticos). Considerar contenci\xf3n si agitaci\xf3n."}],rangoTotal:[0,125],contextoClinico:"Escala m\xe1s utilizada internacionalmente para valorar el riesgo de ca\xeddas en pacientes hospitalizados. Debe reevaluarse al ingreso, en cada turno y ante cambios en el estado del paciente. Las ca\xeddas son un indicador de calidad asistencial.",referencia:"Morse JM, Morse RM, Tylko SJ. Development of a scale to identify the fall-prone patient. Canadian Journal on Aging. 1989;8(4):366-377."},{id:"scale_barthel",nombre:"\xcdndice de Barthel",abreviatura:"IB",descripcion:"Escala de valoraci\xf3n funcional que mide la capacidad para realizar actividades b\xe1sicas de la vida diaria (ABVD). Eval\xfaa el grado de independencia del paciente.",tipo:"components",categoria:"funcional",componentes:[{nombre:"Alimentaci\xf3n",opciones:[{label:"Incapaz",value:0},{label:"Necesita ayuda (cortar, extender mantequilla)",value:5},{label:"Independiente",value:10}]},{nombre:"Ba\xf1o",opciones:[{label:"Dependiente",value:0},{label:"Independiente",value:5}]},{nombre:"Aseo personal",opciones:[{label:"Necesita ayuda",value:0},{label:"Independiente (cara, pelo, dientes, afeitado)",value:5}]},{nombre:"Vestirse",opciones:[{label:"Dependiente",value:0},{label:"Necesita ayuda (al menos la mitad)",value:5},{label:"Independiente (incluye botones, cremalleras)",value:10}]},{nombre:"Control de heces",opciones:[{label:"Incontinente",value:0},{label:"Accidente ocasional",value:5},{label:"Continente",value:10}]},{nombre:"Control de orina",opciones:[{label:"Incontinente o sondado",value:0},{label:"Accidente ocasional",value:5},{label:"Continente",value:10}]},{nombre:"Uso del retrete",opciones:[{label:"Dependiente",value:0},{label:"Necesita alguna ayuda",value:5},{label:"Independiente",value:10}]},{nombre:"Traslado cama-sill\xf3n",opciones:[{label:"Incapaz / no se mantiene sentado",value:0},{label:"Gran ayuda (persona fuerte o dos)",value:5},{label:"M\xednima ayuda (supervisi\xf3n o peque\xf1a ayuda)",value:10},{label:"Independiente",value:15}]},{nombre:"Deambulaci\xf3n",opciones:[{label:"Inm\xf3vil o <50 metros",value:0},{label:"Independiente en silla de ruedas >50 m",value:5},{label:"Camina con ayuda (persona) >50 m",value:10},{label:"Independiente >50 m (puede usar bast\xf3n)",value:15}]},{nombre:"Subir escaleras",opciones:[{label:"Incapaz",value:0},{label:"Necesita ayuda (f\xedsica o verbal)",value:5},{label:"Independiente",value:10}]}],interpretaciones:[{rango:[0,20],label:"Dependencia total",color:"#DC2626",descripcion:"Paciente totalmente dependiente para ABVD. Requiere cuidados integrales de enfermer\xeda, valorar institucionalizaci\xf3n o recursos sociosanitarios. Plan de cuidados individualizado."},{rango:[21,60],label:"Dependencia severa",color:"#EA580C",descripcion:"Necesita ayuda importante en la mayor\xeda de actividades. Rehabilitaci\xf3n activa, prevenci\xf3n de \xfalceras por presi\xf3n, movilizaci\xf3n precoz. Valorar cuidador principal."},{rango:[61,90],label:"Dependencia moderada",color:"#F59E0B",descripcion:"Requiere asistencia en algunas actividades. Programa de rehabilitaci\xf3n para mejorar independencia. Fomentar autonom\xeda progresiva."},{rango:[91,99],label:"Dependencia escasa",color:"#3B82F6",descripcion:"Pr\xe1cticamente independiente. Supervisi\xf3n m\xednima, refuerzo de actividades con peque\xf1a dificultad."},{rango:[100,100],label:"Independiente",color:"#16A34A",descripcion:"Independiente para todas las ABVD. No implica vivir solo; significa autonom\xeda funcional."}],rangoTotal:[0,100],contextoClinico:"Escala de referencia para valoraci\xf3n funcional en geriatr\xeda, rehabilitaci\xf3n y atenci\xf3n domiciliaria. Se eval\xfaa al ingreso, peri\xf3dicamente y al alta. Un descenso >20 puntos indica deterioro funcional significativo. Ampliamente usada como criterio de resultado en rehabilitaci\xf3n.",referencia:"Mahoney FI, Barthel DW. Functional evaluation: the Barthel Index. Maryland State Medical Journal. 1965;14:61-65."},{id:"scale_flacc",nombre:"Escala FLACC",abreviatura:"FLACC",descripcion:"Escala de valoraci\xf3n del dolor en pacientes pedi\xe1tricos (2 meses-7 a\xf1os) o no comunicativos, basada en la observaci\xf3n de cinco par\xe1metros conductuales.",tipo:"components",categoria:"dolor_pediatrico",componentes:[{nombre:"Face (Cara)",opciones:[{label:"Sin expresi\xf3n particular, sonrisa",value:0},{label:"Mueca o ce\xf1o fruncido ocasional, retra\xeddo",value:1},{label:"Temblor frecuente del ment\xf3n, mand\xedbula apretada",value:2}]},{nombre:"Legs (Piernas)",opciones:[{label:"Posici\xf3n normal o relajada",value:0},{label:"Inquietas, agitadas, tensas",value:1},{label:"Pataleo o piernas encogidas",value:2}]},{nombre:"Activity (Actividad)",opciones:[{label:"Acostado tranquilo, posici\xf3n normal, se mueve con facilidad",value:0},{label:"Se retuerce, se balancea, tenso",value:1},{label:"Arqueado, r\xedgido o con sacudidas",value:2}]},{nombre:"Cry (Llanto)",opciones:[{label:"No llora (despierto o dormido)",value:0},{label:"Gemidos o lloriqueos, queja ocasional",value:1},{label:"Llanto constante, gritos o sollozos frecuentes",value:2}]},{nombre:"Consolability (Consolabilidad)",opciones:[{label:"Contento, relajado",value:0},{label:"Se tranquiliza con contacto, abrazo, voz; distra\xedble",value:1},{label:"Dif\xedcil de consolar",value:2}]}],interpretaciones:[{rango:[0,0],label:"Sin dolor",color:"#16A34A",descripcion:"No se observan signos de dolor. Continuar vigilancia y reevaluar si hay cambios en procedimientos o estado cl\xednico."},{rango:[1,3],label:"Dolor leve \u2013 disconfort",color:"#3B82F6",descripcion:"Considerar medidas no farmacol\xf3gicas: contenci\xf3n, succi\xf3n no nutritiva, contacto piel con piel, distracci\xf3n."},{rango:[4,6],label:"Dolor moderado",color:"#F59E0B",descripcion:"Iniciar analgesia seg\xfan prescripci\xf3n (paracetamol, ibuprofeno). Reevaluar en 30-60 minutos tras intervenci\xf3n. Combinar con medidas no farmacol\xf3gicas."},{rango:[7,10],label:"Dolor severo",color:"#DC2626",descripcion:"Analgesia urgente requerida. Considerar opioides si dolor no controlado. Alertar al equipo m\xe9dico. Reevaluar frecuentemente cada 15-30 minutos."}],rangoTotal:[0,10],contextoClinico:"Escala est\xe1ndar de dolor para ni\xf1os de 2 meses a 7 a\xf1os y pacientes no comunicativos (intubados, con alteraci\xf3n cognitiva). Se valora observando al paciente durante 1-5 minutos. Reevaluar antes y despu\xe9s de intervenciones analg\xe9sicas. FLACC = Face, Legs, Activity, Cry, Consolability.",referencia:"Merkel SI, Voepel-Lewis T, Shayevitz JR, Malviya S. The FLACC: a behavioral scale for scoring postoperative pain in young children. Pediatric Nursing. 1997;23(3):293-297."},{id:"scale_must",nombre:"MUST \u2013 Screening Nutricional",abreviatura:"MUST",descripcion:"Herramienta de cribado nutricional universal (Malnutrition Universal Screening Tool) para identificar pacientes adultos con riesgo de desnutrici\xf3n o desnutrici\xf3n establecida.",tipo:"components",categoria:"nutricion",componentes:[{nombre:"IMC (\xcdndice de Masa Corporal)",opciones:[{label:">20 kg/m\xb2 (>30 si obeso)",value:0},{label:"18.5\u201320 kg/m\xb2",value:1},{label:"<18.5 kg/m\xb2",value:2}]},{nombre:"P\xe9rdida de peso involuntaria (\xfaltimos 3-6 meses)",opciones:[{label:"<5%",value:0},{label:"5\u201310%",value:1},{label:">10%",value:2}]},{nombre:"Efecto de enfermedad aguda",opciones:[{label:"No hay enfermedad aguda que afecte ingesta >5 d\xedas",value:0},{label:"Ingesta nula o casi nula >5 d\xedas (o riesgo de no ingesta)",value:2}]}],interpretaciones:[{rango:[0,0],label:"Riesgo bajo",color:"#16A34A",descripcion:"Cuidados rutinarios. Reevaluar semanalmente en hospitalizados, mensualmente en residencias, anualmente en comunidad. Continuar con dieta normal."},{rango:[1,1],label:"Riesgo medio",color:"#F59E0B",descripcion:"Observar: documentar ingesta alimentaria durante 3 d\xedas. Si la ingesta es adecuada, continuar observando. Si es inadecuada, iniciar plan nutricional. Reevaluar semanalmente."},{rango:[2,6],label:"Riesgo alto",color:"#DC2626",descripcion:"Tratar: derivar a nutricionista/dietista. Iniciar suplementos nutricionales orales. Considerar alimentaci\xf3n enteral si no tolera v\xeda oral. Monitorizar ingesta y peso. Reevaluar plan semanalmente."}],rangoTotal:[0,6],contextoClinico:"Herramienta de cribado recomendada por ESPEN y NICE para todos los pacientes al ingreso hospitalario. R\xe1pida de aplicar (3-5 min). Se debe complementar con valoraci\xf3n nutricional completa en pacientes con riesgo medio-alto. La desnutrici\xf3n hospitalaria afecta al 20-40% de los pacientes ingresados.",referencia:"Stratton RJ, Hackston A, Longmore D, et al. Malnutrition in hospital outpatients and inpatients: prevalence, concurrent validity and ease of use of the 'malnutrition universal screening tool' (MUST) for adults. British Journal of Nutrition. 2004;92(5):799-808."}]},786,[]);
__d(function(a,i,e,o,r,n,s){r.exports=[{id:"lab_hemoglobina",nombre:"Hemoglobina",abreviatura:"Hb",categoria:"hematologia",rangos:{adultoHombre:{min:13.5,max:17.5,unidad:"g/dL"},adultoMujer:{min:12,max:16,unidad:"g/dL"},pediatrico:{min:11,max:16,unidad:"g/dL"}},significadoAlto:"Puede indicar policitemia, deshidrataci\xf3n, enfermedad pulmonar cr\xf3nica o cardiopat\xedas cong\xe9nitas cian\xf3ticas.",significadoBajo:"Indica anemia de diversa etiolog\xeda (ferrop\xe9nica, megalobl\xe1stica, hemol\xedtica), hemorragia aguda o cr\xf3nica, o estados de sobrehidrataci\xf3n.",farmacosAlteran:["Eritropoyetina","Metotrexato","Zidovudina","Cloranfenicol","Hierro IV"],implicacionesEnfermeria:["Monitorizar signos de anemia: palidez, taquicardia, disnea y fatiga","Controlar signos vitales antes y durante transfusiones sangu\xedneas","Educar al paciente sobre alimentos ricos en hierro si hay d\xe9ficit","Vigilar signos de sangrado activo en valores descendentes"]},{id:"lab_hematocrito",nombre:"Hematocrito",abreviatura:"Hto",categoria:"hematologia",rangos:{adultoHombre:{min:40,max:54,unidad:"%"},adultoMujer:{min:36,max:48,unidad:"%"},pediatrico:{min:33,max:45,unidad:"%"}},significadoAlto:"Sugiere hemoconcentraci\xf3n por deshidrataci\xf3n, policitemia vera o eritrocitosis secundaria a hipoxia cr\xf3nica.",significadoBajo:"Indica anemia, hemorragia, sobrehidrataci\xf3n o destrucci\xf3n acelerada de eritrocitos (hem\xf3lisis).",farmacosAlteran:["Eritropoyetina","Diur\xe9ticos","Fluidos IV","Quimioterapia","Anticoagulantes"],implicacionesEnfermeria:["Evaluar estado de hidrataci\xf3n del paciente junto con el valor","Correlacionar con hemoglobina para valorar la severidad de la anemia","Monitorizar balance h\xeddrico en pacientes con valores alterados"]},{id:"lab_leucocitos",nombre:"Leucocitos",abreviatura:"WBC",categoria:"hematologia",rangos:{adulto:{min:4500,max:11e3,unidad:"c\xe9lulas/\xb5L"},pediatrico:{min:5e3,max:15e3,unidad:"c\xe9lulas/\xb5L"}},significadoAlto:"Leucocitosis: puede indicar infecci\xf3n bacteriana, inflamaci\xf3n, estr\xe9s, leucemia o respuesta a corticoides.",significadoBajo:"Leucopenia: sugiere inmunosupresi\xf3n, aplasia medular, infecciones virales graves o efecto de quimioterapia.",farmacosAlteran:["Corticosteroides","Quimioterapia","Antibi\xf3ticos","Litio","Filgrastim"],implicacionesEnfermeria:["Implementar precauciones de aislamiento en leucopenia severa (<1000/\xb5L)","Vigilar signos de infecci\xf3n: fiebre, escalofr\xedos, eritema","Monitorizar temperatura cada 4 horas en pacientes neutrop\xe9nicos","Educar al paciente sobre medidas de higiene y prevenci\xf3n de infecciones"]},{id:"lab_plaquetas",nombre:"Plaquetas",abreviatura:"PLT",categoria:"hematologia",rangos:{adulto:{min:15e4,max:4e5,unidad:"c\xe9lulas/\xb5L"},pediatrico:{min:15e4,max:45e4,unidad:"c\xe9lulas/\xb5L"}},significadoAlto:"Trombocitosis: puede asociarse a infecciones, inflamaci\xf3n cr\xf3nica, d\xe9ficit de hierro, esplenectom\xeda o trastornos mieloproliferativos.",significadoBajo:"Trombocitopenia: riesgo de sangrado; causas incluyen PTI, CID, hiperesplenismo, quimioterapia o f\xe1rmacos.",farmacosAlteran:["Heparina","Quimioterapia","\xc1cido valproico","AINEs","Vancomicina"],implicacionesEnfermeria:["Vigilar signos de sangrado: petequias, equimosis, epistaxis, hematuria","Evitar punciones innecesarias y aplicar presi\xf3n prolongada en sitios de punci\xf3n","Alertar si plaquetas <50000 (riesgo de sangrado) o <20000 (sangrado espont\xe1neo)","Instruir al paciente a usar cepillo dental suave y maquinilla el\xe9ctrica"]},{id:"lab_eritrocitos",nombre:"Eritrocitos",abreviatura:"RBC",categoria:"hematologia",rangos:{adultoHombre:{min:4.5,max:5.5,unidad:"millones/\xb5L"},adultoMujer:{min:4,max:5,unidad:"millones/\xb5L"},pediatrico:{min:3.8,max:5.5,unidad:"millones/\xb5L"}},significadoAlto:"Eritrocitosis: puede deberse a policitemia vera, hipoxia cr\xf3nica (EPOC, altitud), deshidrataci\xf3n o tumores productores de eritropoyetina.",significadoBajo:"Sugiere anemia de cualquier tipo, hemorragia, hem\xf3lisis o insuficiencia medular.",farmacosAlteran:["Eritropoyetina","Metotrexato","Cloranfenicol","Zidovudina","Hidroxiurea"],implicacionesEnfermeria:["Correlacionar con hemoglobina y hematocrito para evaluar anemia","Valorar s\xedntomas de hipoxia tisular: disnea, fatiga, mareos","Controlar dieta y suplementaci\xf3n en anemias carenciales"]},{id:"lab_vcm",nombre:"Volumen Corpuscular Medio",abreviatura:"VCM",categoria:"hematologia",rangos:{adulto:{min:80,max:100,unidad:"fL"},pediatrico:{min:70,max:95,unidad:"fL"}},significadoAlto:"Macrocitosis: asociada a d\xe9ficit de vitamina B12 o \xe1cido f\xf3lico, alcoholismo, hipotiroidismo o s\xedndromes mielodispl\xe1sicos.",significadoBajo:"Microcitosis: sugiere anemia ferrop\xe9nica, talasemia o anemia de enfermedad cr\xf3nica.",farmacosAlteran:["Metotrexato","Fenito\xedna","Zidovudina","Hidroxiurea","Trimetoprim"],implicacionesEnfermeria:["Utilizar el VCM para orientar el tipo de anemia y guiar la educaci\xf3n al paciente","Correlacionar con niveles de hierro, B12 y \xe1cido f\xf3lico seg\xfan corresponda","Informar al m\xe9dico sobre cambios significativos en el VCM durante tratamientos"]},{id:"lab_hcm",nombre:"Hemoglobina Corpuscular Media",abreviatura:"HCM",categoria:"hematologia",rangos:{adulto:{min:27,max:33,unidad:"pg"}},significadoAlto:"Hipercrom\xeda: puede asociarse a anemias megalobl\xe1sticas por d\xe9ficit de B12 o folato, o esferocitosis hereditaria.",significadoBajo:"Hipocrom\xeda: indica deficiencia de hierro o talasemia; los eritrocitos contienen menos hemoglobina de lo normal.",farmacosAlteran:["Hierro oral/IV","\xc1cido f\xf3lico","Vitamina B12","Metotrexato","Fenito\xedna"],implicacionesEnfermeria:["Complementar la valoraci\xf3n con VCM y CHCM para clasificar anemias","Educar sobre la importancia de la adherencia al tratamiento con hierro o vitaminas","Monitorizar respuesta al tratamiento con controles seriados"]},{id:"lab_reticulocitos",nombre:"Reticulocitos",abreviatura:"Ret",categoria:"hematologia",rangos:{adulto:{min:.5,max:2.5,unidad:"%"}},significadoAlto:"Indica respuesta medular activa: recuperaci\xf3n de anemia, hemorragia reciente, hem\xf3lisis o respuesta a tratamiento con hierro/EPO.",significadoBajo:"Sugiere producci\xf3n medular inadecuada: aplasia medular, anemia megalobl\xe1stica, infiltraci\xf3n tumoral o efecto de quimioterapia.",farmacosAlteran:["Eritropoyetina","Hierro IV","Quimioterapia","Cloranfenicol","\xc1cido f\xf3lico"],implicacionesEnfermeria:["Utilizar como indicador de respuesta al tratamiento antian\xe9mico","Esperar elevaci\xf3n a los 5-7 d\xedas de inicio de tratamiento con hierro","Informar valores bajos persistentes al equipo m\xe9dico"]},{id:"lab_glucosa",nombre:"Glucosa en ayunas",abreviatura:"Glu",categoria:"bioquimica",rangos:{adulto:{min:70,max:100,unidad:"mg/dL"},pediatrico:{min:60,max:100,unidad:"mg/dL"}},significadoAlto:"Hiperglucemia: puede indicar diabetes mellitus, estr\xe9s metab\xf3lico, pancreatitis, s\xedndrome de Cushing o efecto farmacol\xf3gico.",significadoBajo:"Hipoglucemia: riesgo de da\xf1o neurol\xf3gico; causas incluyen sobredosis de insulina, ayuno prolongado, insuficiencia hep\xe1tica o insulinoma.",farmacosAlteran:["Insulina","Metformina","Corticosteroides","Tiazidas","Betabloqueantes"],implicacionesEnfermeria:["Verificar que la muestra sea en ayunas de al menos 8 horas","Monitorizar glucemia capilar seg\xfan protocolo en pacientes diab\xe9ticos","Vigilar signos de hipoglucemia: sudoraci\xf3n, temblor, confusi\xf3n, taquicardia","Educar al paciente sobre el autocontrol gluc\xe9mico y dieta"]},{id:"lab_sodio",nombre:"Sodio",abreviatura:"Na",categoria:"bioquimica",rangos:{adulto:{min:135,max:145,unidad:"mEq/L"},pediatrico:{min:135,max:145,unidad:"mEq/L"}},significadoAlto:"Hipernatremia: indica deshidrataci\xf3n, diabetes ins\xedpida, exceso de ingesta de sodio o p\xe9rdida de agua libre.",significadoBajo:"Hiponatremia: puede causar edema cerebral; asociada a SIADH, insuficiencia card\xedaca, cirrosis, diur\xe9ticos o polidipsia.",farmacosAlteran:["Diur\xe9ticos tiaz\xeddicos","Furosemida","Litio","Carbamazepina","SSRIs"],implicacionesEnfermeria:["Monitorizar estado neurol\xf3gico: confusi\xf3n, letargia, convulsiones","Controlar balance h\xeddrico estricto y peso diario","Corregir lentamente (<10 mEq/L en 24h) para evitar mielin\xf3lisis pontina","Vigilar edema perif\xe9rico y signos de sobrecarga h\xeddrica"]},{id:"lab_potasio",nombre:"Potasio",abreviatura:"K",categoria:"bioquimica",rangos:{adulto:{min:3.5,max:5,unidad:"mEq/L"},pediatrico:{min:3.5,max:5.5,unidad:"mEq/L"}},significadoAlto:"Hiperpotasemia: riesgo de arritmias letales; causas incluyen insuficiencia renal, acidosis, rabdomi\xf3lisis o exceso de suplementos.",significadoBajo:"Hipopotasemia: riesgo de arritmias, debilidad muscular e \xedleo; asociada a v\xf3mitos, diarrea, diur\xe9ticos o alcalosis.",farmacosAlteran:["IECA/ARA-II","Espironolactona","Furosemida","Insulina","Digoxina"],implicacionesEnfermeria:["Monitorizaci\xf3n card\xedaca continua si K >6.0 o <3.0 mEq/L","Verificar funci\xf3n renal antes de administrar suplementos de potasio","Administrar potasio IV diluido y lento (nunca en bolo directo)","Vigilar ECG: ondas T picudas (hiperK) o aplanadas con onda U (hipoK)"]},{id:"lab_calcio",nombre:"Calcio s\xe9rico",abreviatura:"Ca",categoria:"bioquimica",rangos:{adulto:{min:8.5,max:10.5,unidad:"mg/dL"},pediatrico:{min:8.8,max:10.8,unidad:"mg/dL"}},significadoAlto:"Hipercalcemia: puede causar arritmias, confusi\xf3n y coma; asociada a hiperparatiroidismo, met\xe1stasis \xf3seas o intoxicaci\xf3n por vitamina D.",significadoBajo:"Hipocalcemia: causa tetania, espasmos y convulsiones; asociada a hipoparatiroidismo, d\xe9ficit de vitamina D o pancreatitis aguda.",farmacosAlteran:["Tiazidas","Furosemida","Bifosfonatos","Vitamina D","Corticosteroides"],implicacionesEnfermeria:["Valorar signos de Chvostek y Trousseau en hipocalcemia","Monitorizar ECG: QT prolongado (hipoCa) o QT corto (hiperCa)","Asegurar ingesta adecuada de vitamina D para absorci\xf3n del calcio","Mantener precauciones de seguridad por riesgo de convulsiones"]},{id:"lab_magnesio",nombre:"Magnesio",abreviatura:"Mg",categoria:"bioquimica",rangos:{adulto:{min:1.5,max:2.5,unidad:"mg/dL"}},significadoAlto:"Hipermagnesemia: causa hipotensi\xf3n, bradicardia, depresi\xf3n respiratoria y arreflexia; frecuente en insuficiencia renal.",significadoBajo:"Hipomagnesemia: causa arritmias, temblores y convulsiones; asociada a alcoholismo, diarrea cr\xf3nica y uso de diur\xe9ticos.",farmacosAlteran:["Sulfato de magnesio IV","Omeprazol","Furosemida","Aminogluc\xf3sidos","Cisplatino"],implicacionesEnfermeria:["Vigilar reflejos rotulianos durante infusi\xf3n de magnesio IV (preeclampsia)","Monitorizar ECG por riesgo de arritmias en ambas alteraciones","Valorar nivel de conciencia y funci\xf3n respiratoria con niveles altos","Corregir hipomagnesemia antes de tratar hipopotasemia resistente"]},{id:"lab_fosforo",nombre:"F\xf3sforo",abreviatura:"P",categoria:"bioquimica",rangos:{adulto:{min:2.5,max:4.5,unidad:"mg/dL"},pediatrico:{min:4,max:7,unidad:"mg/dL"}},significadoAlto:"Hiperfosfatemia: frecuente en insuficiencia renal cr\xf3nica; causa calcificaciones ect\xf3picas y prurito. Relaci\xf3n inversa con calcio.",significadoBajo:"Hipofosfatemia: causa debilidad muscular, insuficiencia respiratoria y hem\xf3lisis; asociada a realimentaci\xf3n, anti\xe1cidos y alcoholismo.",farmacosAlteran:["Anti\xe1cidos con aluminio","Vitamina D","Sevel\xe1mero","Insulina","Corticosteroides"],implicacionesEnfermeria:["Administrar quelantes de f\xf3sforo con las comidas en insuficiencia renal","Vigilar s\xedndrome de realimentaci\xf3n en pacientes desnutridos","Monitorizar niveles conjuntos de calcio y f\xf3sforo"]},{id:"lab_acido_urico",nombre:"\xc1cido \xfarico",abreviatura:"AU",categoria:"bioquimica",rangos:{adultoHombre:{min:3.4,max:7,unidad:"mg/dL"},adultoMujer:{min:2.4,max:6,unidad:"mg/dL"}},significadoAlto:"Hiperuricemia: riesgo de gota, litiasis renal y nefropat\xeda; asociada a dieta rica en purinas, s\xedndrome de lisis tumoral o insuficiencia renal.",significadoBajo:"Hipouricemia: poco frecuente; puede asociarse a s\xedndrome de Fanconi, enfermedad de Wilson o uso de uricos\xfaricos.",farmacosAlteran:["Alopurinol","Tiazidas","Aspirina a dosis bajas","Quimioterapia","Losart\xe1n"],implicacionesEnfermeria:["Fomentar ingesta h\xeddrica abundante (>2L/d\xeda) para prevenir litiasis","Educar sobre dieta baja en purinas: limitar carnes rojas, mariscos y alcohol","Monitorizar funci\xf3n renal en pacientes con hiperuricemia cr\xf3nica"]},{id:"lab_proteinas_totales",nombre:"Prote\xednas totales",abreviatura:"PT",categoria:"bioquimica",rangos:{adulto:{min:6,max:8.3,unidad:"g/dL"}},significadoAlto:"Hiperproteinemia: asociada a deshidrataci\xf3n, mieloma m\xfaltiple, infecciones cr\xf3nicas o enfermedades autoinmunes.",significadoBajo:"Hipoproteinemia: indica desnutrici\xf3n, s\xedndrome nefr\xf3tico, insuficiencia hep\xe1tica, enteropat\xeda perdedora de prote\xednas o quemaduras extensas.",farmacosAlteran:["Corticosteroides","Estr\xf3genos","Insulina","Hormona de crecimiento","Andr\xf3genos"],implicacionesEnfermeria:["Evaluar estado nutricional y valorar necesidad de soporte nutricional","Monitorizar presencia de edema por disminuci\xf3n de presi\xf3n onc\xf3tica","Correlacionar con alb\xfamina s\xe9rica para valoraci\xf3n nutricional completa"]},{id:"lab_tp_inr",nombre:"Tiempo de Protrombina / INR",abreviatura:"TP/INR",categoria:"coagulacion",rangos:{adulto:{min:.8,max:1.2,unidad:"INR"}},significadoAlto:"INR elevado: mayor riesgo de sangrado; indica deficiencia de factores de coagulaci\xf3n, hepatopat\xeda, d\xe9ficit de vitamina K o efecto de anticoagulantes orales.",significadoBajo:"INR bajo en paciente anticoagulado indica efecto terap\xe9utico insuficiente y mayor riesgo tromb\xf3tico.",farmacosAlteran:["Warfarina","Acenocumarol","Antibi\xf3ticos","Amiodarona","AINEs"],implicacionesEnfermeria:["Rango terap\xe9utico con anticoagulantes orales: INR 2.0-3.0 (v\xe1lvulas mec\xe1nicas: 2.5-3.5)","Vigilar signos de sangrado: hematuria, melenas, epistaxis, equimosis","Educar al paciente sobre interacciones con alimentos ricos en vitamina K","Tener disponible vitamina K y plasma fresco congelado como ant\xeddotos"]},{id:"lab_ttpa",nombre:"Tiempo de Tromboplastina Parcial Activada",abreviatura:"TTPa",categoria:"coagulacion",rangos:{adulto:{min:25,max:35,unidad:"segundos"}},significadoAlto:"TTPa prolongado: indica deficiencia de factores VIII, IX, XI, XII, hemofilia, CID, presencia de anticoagulante l\xfapico o efecto de heparina.",significadoBajo:"TTPa acortado: puede indicar hipercoagulabilidad, trombofilia o fase temprana de CID.",farmacosAlteran:["Heparina no fraccionada","Warfarina","Dabigatr\xe1n","\xc1cido tranex\xe1mico","Factor VII recombinante"],implicacionesEnfermeria:["Objetivo terap\xe9utico con heparina: TTPa 1.5-2.5 veces el valor control","Extraer muestra del brazo contrario a la infusi\xf3n de heparina","Tener disponible protamina como ant\xeddoto de heparina","Monitorizar cada 6 horas durante infusi\xf3n continua de heparina"]},{id:"lab_fibrinogeno",nombre:"Fibrin\xf3geno",abreviatura:"Fib",categoria:"coagulacion",rangos:{adulto:{min:200,max:400,unidad:"mg/dL"}},significadoAlto:"Hiperfibrinogenemia: reactante de fase aguda; elevado en infecciones, inflamaci\xf3n, embarazo, neoplasias y postquir\xfargico.",significadoBajo:"Hipofibrinogenemia: riesgo de sangrado; asociada a CID, fibrin\xf3lisis, hepatopat\xeda grave, transfusi\xf3n masiva o afibrinogenemia cong\xe9nita.",farmacosAlteran:["\xc1cido tranex\xe1mico","Estr\xf3genos","Trombol\xedticos","\xc1cido valproico","L-asparaginasa"],implicacionesEnfermeria:["Valor cr\xedtico <100 mg/dL: alertar inmediatamente al equipo m\xe9dico","Preparar crioprecipitado o concentrado de fibrin\xf3geno si hay sangrado activo","Monitorizar en conjunto con TP, TTPa y plaquetas en sospecha de CID"]},{id:"lab_dimero_d",nombre:"D\xedmero D",abreviatura:"DD",categoria:"coagulacion",rangos:{adulto:{min:0,max:500,unidad:"ng/mL"}},significadoAlto:"Elevado en trombosis venosa profunda, embolia pulmonar, CID, cirug\xeda reciente, embarazo, infecciones y neoplasias. Alta sensibilidad pero baja especificidad.",significadoBajo:"Valores normales tienen alto valor predictivo negativo para descartar eventos tromboemb\xf3licos.",farmacosAlteran:["Anticoagulantes","Trombol\xedticos","Estr\xf3genos","Heparina","\xc1cido tranex\xe1mico"],implicacionesEnfermeria:["Utilizado principalmente para descartar TEP/TVP (alto valor predictivo negativo)","Correlacionar siempre con la cl\xednica del paciente por su baja especificidad","Valorar signos de TVP: edema unilateral, dolor y enrojecimiento en extremidad"]},{id:"lab_tiempo_sangrado",nombre:"Tiempo de sangrado",abreviatura:"TS",categoria:"coagulacion",rangos:{adulto:{min:1,max:9,unidad:"minutos"}},significadoAlto:"Prolongado: indica disfunci\xf3n plaquetaria, enfermedad de von Willebrand, trombocitopenia severa o efecto de antiagregantes.",significadoBajo:"No tiene significado cl\xednico relevante; la hemostasia primaria funciona adecuadamente.",farmacosAlteran:["Aspirina","Clopidogrel","AINEs","Ticagrelor","Dipiridamol"],implicacionesEnfermeria:["Realizar prueba antes de procedimientos invasivos en pacientes con riesgo","Suspender antiagregantes seg\xfan protocolo prequir\xfargico (aspirina 7 d\xedas, clopidogrel 5 d\xedas)","Aplicar presi\xf3n sostenida en sitios de punci\xf3n si est\xe1 prolongado"]},{id:"lab_alt",nombre:"Alanina Aminotransferasa",abreviatura:"ALT/GPT",categoria:"hepatico",rangos:{adulto:{min:7,max:56,unidad:"U/L"}},significadoAlto:"Indica da\xf1o hepatocelular: hepatitis viral o t\xf3xica, esteatosis, cirrosis, isquemia hep\xe1tica o hepatotoxicidad por f\xe1rmacos. M\xe1s espec\xedfica del h\xedgado que la AST.",significadoBajo:"No tiene significado cl\xednico relevante. Valores muy bajos pueden verse en d\xe9ficit de piridoxina (vitamina B6).",farmacosAlteran:["Paracetamol","Estatinas","Isoniazida","Metotrexato","Amiodarona"],implicacionesEnfermeria:["Monitorizar en pacientes que inician estatinas, antituberculosos o antiepil\xe9pticos","Alertar si ALT >3 veces el l\xedmite superior normal con s\xedntomas","Educar al paciente sobre evitar alcohol y hepatot\xf3xicos","Correlacionar con AST: ratio AST/ALT >2 sugiere hepatopat\xeda alcoh\xf3lica"]},{id:"lab_ast",nombre:"Aspartato Aminotransferasa",abreviatura:"AST/GOT",categoria:"hepatico",rangos:{adulto:{min:10,max:40,unidad:"U/L"}},significadoAlto:"Indica da\xf1o celular hep\xe1tico o muscular: hepatitis, infarto de miocardio, rabdomi\xf3lisis, hem\xf3lisis o miopat\xeda por estatinas.",significadoBajo:"No tiene significado cl\xednico relevante. Puede verse en uremia o d\xe9ficit de vitamina B6.",farmacosAlteran:["Paracetamol","Estatinas","Isoniazida","Eritromicina","Anticonvulsivantes"],implicacionesEnfermeria:["No es espec\xedfica del h\xedgado; correlacionar con ALT y GGT","En sospecha de IAM, correlacionar con troponina y CK-MB","Monitorizar junto con CK en pacientes con miopat\xeda por estatinas"]},{id:"lab_bilirrubina_total",nombre:"Bilirrubina total",abreviatura:"BT",categoria:"hepatico",rangos:{adulto:{min:.1,max:1.2,unidad:"mg/dL"}},significadoAlto:"Hiperbilirrubinemia: causa ictericia visible >2.5 mg/dL; indica hem\xf3lisis, hepatopat\xeda, obstrucci\xf3n biliar o s\xedndrome de Gilbert.",significadoBajo:"No tiene significado cl\xednico relevante.",farmacosAlteran:["Rifampicina","Atazanavir","Paracetamol","Anabolizantes","Eritromicina"],implicacionesEnfermeria:["Valorar ictericia en piel, mucosas y escler\xf3ticas","Diferenciar bilirrubina directa/indirecta para orientar la causa","Monitorizar color de orina (coluria) y heces (acolia) como indicadores","Vigilar prurito asociado a colestasis y aplicar medidas de confort"]},{id:"lab_bilirrubina_directa",nombre:"Bilirrubina directa (conjugada)",abreviatura:"BD",categoria:"hepatico",rangos:{adulto:{min:0,max:.3,unidad:"mg/dL"}},significadoAlto:"Indica colestasis intrahep\xe1tica o extrahep\xe1tica: obstrucci\xf3n biliar por c\xe1lculos, tumores, hepatitis colest\xe1sica o cirrosis biliar primaria.",significadoBajo:"No tiene significado cl\xednico relevante.",farmacosAlteran:["Anticonceptivos orales","Eritromicina","Clorpromazina","Anabolizantes","Rifampicina"],implicacionesEnfermeria:["Correlacionar con fosfatasa alcalina y GGT en sospecha de colestasis","Vigilar signos de obstrucci\xf3n biliar: acolia, coluria, prurito","Preparar al paciente para estudios de imagen (ecograf\xeda, CPRE) si procede"]},{id:"lab_fosfatasa_alcalina",nombre:"Fosfatasa Alcalina",abreviatura:"FA",categoria:"hepatico",rangos:{adulto:{min:44,max:147,unidad:"U/L"},pediatrico:{min:100,max:400,unidad:"U/L"}},significadoAlto:"Elevada en colestasis, met\xe1stasis hep\xe1ticas, enfermedad de Paget, hiperparatiroidismo, fracturas en consolidaci\xf3n y crecimiento \xf3seo infantil.",significadoBajo:"Rara vez cl\xednicamente significativo; puede verse en hipotiroidismo, anemia perniciosa o d\xe9ficit de zinc.",farmacosAlteran:["Anticonvulsivantes","Anticonceptivos orales","Alopurinol","Antibi\xf3ticos","Metotrexato"],implicacionesEnfermeria:["Valores elevados en ni\xf1os y adolescentes son normales por el crecimiento \xf3seo","Diferenciar origen hep\xe1tico u \xf3seo con GGT (si GGT normal, origen \xf3seo)","Monitorizar en pacientes con patolog\xeda \xf3sea o hepatobiliar"]},{id:"lab_ggt",nombre:"Gamma-Glutamil Transferasa",abreviatura:"GGT",categoria:"hepatico",rangos:{adulto:{min:9,max:48,unidad:"U/L"}},significadoAlto:"Elevada en enfermedad hepatobiliar, alcoholismo cr\xf3nico, pancreatitis, uso de anticonvulsivantes y colestasis. Muy sensible a la ingesta de alcohol.",significadoBajo:"No tiene significado cl\xednico relevante.",farmacosAlteran:["Fenito\xedna","Carbamazepina","Barbit\xfaricos","Rifampicina","Paracetamol"],implicacionesEnfermeria:["\xdatil como marcador de consumo de alcohol: se eleva con ingesta cr\xf3nica","Ayuda a confirmar origen hep\xe1tico de la fosfatasa alcalina elevada","Monitorizar en pacientes con antecedentes de alcoholismo","Educar al paciente sobre abstinencia alcoh\xf3lica si GGT est\xe1 elevada"]},{id:"lab_creatinina",nombre:"Creatinina s\xe9rica",abreviatura:"Cr",categoria:"renal",rangos:{adultoHombre:{min:.7,max:1.3,unidad:"mg/dL"},adultoMujer:{min:.6,max:1.1,unidad:"mg/dL"}},significadoAlto:"Indica deterioro de la funci\xf3n renal: insuficiencia renal aguda o cr\xf3nica, deshidrataci\xf3n, obstrucci\xf3n urinaria, rabdomi\xf3lisis o nefrotoxicidad.",significadoBajo:"Puede verse en desnutrici\xf3n severa, p\xe9rdida de masa muscular (caquexia) o embarazo por aumento del filtrado glomerular.",farmacosAlteran:["AINEs","Aminogluc\xf3sidos","Vancomicina","IECA/ARA-II","Medios de contraste yodados"],implicacionesEnfermeria:["Calcular el aclaramiento de creatinina para ajustar dosis de f\xe1rmacos nefrot\xf3xicos","Asegurar hidrataci\xf3n adecuada antes de administrar contraste yodado","Monitorizar diuresis horaria en pacientes con insuficiencia renal aguda","Alertar si creatinina se duplica respecto al valor basal del paciente"]},{id:"lab_bun_urea",nombre:"BUN / Urea",abreviatura:"BUN",categoria:"renal",rangos:{adulto:{min:7,max:20,unidad:"mg/dL"},pediatrico:{min:5,max:18,unidad:"mg/dL"}},significadoAlto:"Azoemia: indica insuficiencia renal, deshidrataci\xf3n, hemorragia digestiva, dieta hiperproteica, catabolismo aumentado o insuficiencia card\xedaca.",significadoBajo:"Puede indicar enfermedad hep\xe1tica severa (menor s\xedntesis de urea), desnutrici\xf3n proteica o sobrehidrataci\xf3n.",farmacosAlteran:["AINEs","Aminogluc\xf3sidos","Corticosteroides","Tetraciclinas","Diur\xe9ticos"],implicacionesEnfermeria:["Calcular ratio BUN/Creatinina: >20:1 sugiere causa prerrenal (deshidrataci\xf3n)","Monitorizar balance h\xeddrico y peso diario","Valorar estado de hidrataci\xf3n: turgencia cut\xe1nea, mucosas, presi\xf3n arterial","Correlacionar con creatinina para diferenciar causa renal vs prerrenal"]},{id:"lab_acido_urico_renal",nombre:"\xc1cido \xfarico (perfil renal)",abreviatura:"AU",categoria:"renal",rangos:{adultoHombre:{min:3.4,max:7,unidad:"mg/dL"},adultoMujer:{min:2.4,max:6,unidad:"mg/dL"}},significadoAlto:"Hiperuricemia con riesgo de nefropat\xeda por uratos, litiasis renal y gota; frecuente en ERC, s\xedndrome de lisis tumoral y uso de diur\xe9ticos.",significadoBajo:"Puede indicar tubulopat\xeda renal con p\xe9rdida excesiva de \xe1cido \xfarico o efecto de f\xe1rmacos uricos\xfaricos.",farmacosAlteran:["Alopurinol","Febuxostat","Tiazidas","Ciclosporina","Rasburicasa"],implicacionesEnfermeria:["Hidratar abundantemente en s\xedndrome de lisis tumoral para prevenir nefropat\xeda","Monitorizar funci\xf3n renal en pacientes con hiperuricemia cr\xf3nica","Administrar alopurinol profil\xe1ctico antes de quimioterapia seg\xfan protocolo"]},{id:"lab_tfg",nombre:"Tasa de Filtrado Glomerular",abreviatura:"TFG",categoria:"renal",rangos:{adulto:{min:90,max:120,unidad:"mL/min/1.73m\xb2"}},significadoAlto:"TFG >120 puede verse en embarazo o fase inicial de nefropat\xeda diab\xe9tica (hiperfiltraci\xf3n glomerular).",significadoBajo:"Indica enfermedad renal cr\xf3nica: G1 >90, G2 60-89, G3a 45-59, G3b 30-44, G4 15-29, G5 <15 (di\xe1lisis).",farmacosAlteran:["IECA/ARA-II","AINEs","Aminogluc\xf3sidos","Metformina","Medios de contraste"],implicacionesEnfermeria:["Clasificar el estadio de ERC seg\xfan TFG para ajustar cuidados","Ajustar dosis de f\xe1rmacos de eliminaci\xf3n renal seg\xfan TFG","Contraindicar metformina si TFG <30 mL/min/1.73m\xb2","Derivar a nefrolog\xeda si TFG <30 para planificar terapia sustitutiva"]},{id:"lab_cistatina_c",nombre:"Cistatina C",abreviatura:"CysC",categoria:"renal",rangos:{adulto:{min:.6,max:1,unidad:"mg/L"}},significadoAlto:"Indica disminuci\xf3n de la funci\xf3n renal; m\xe1s preciso que la creatinina en ancianos, obesos y pacientes con masa muscular alterada.",significadoBajo:"Rara vez cl\xednicamente significativo; puede verse en hipertiroidismo.",farmacosAlteran:["Corticosteroides","Ciclosporina","AINEs","Aminogluc\xf3sidos","Cisplatino"],implicacionesEnfermeria:["\xdatil cuando la creatinina no es fiable (amputados, ancianos, caqu\xe9cticos)","No se afecta por la masa muscular, dieta ni g\xe9nero","Solicitar cuando hay discrepancia entre creatinina y cl\xednica del paciente"]},{id:"lab_troponina",nombre:"Troponina I",abreviatura:"TnI",categoria:"cardiaco",rangos:{adulto:{min:0,max:.04,unidad:"ng/mL"}},significadoAlto:"Elevada: indica da\xf1o mioc\xe1rdico; diagn\xf3stico de IAM si se acompa\xf1a de cl\xednica y ECG. Tambi\xe9n se eleva en miocarditis, TEP masiva, sepsis grave e insuficiencia renal.",significadoBajo:"Valores normales ayudan a descartar IAM con alto valor predictivo negativo.",farmacosAlteran:["Doxorrubicina","5-Fluorouracilo","Trastuzumab","Coca\xedna","Simpaticomim\xe9ticos"],implicacionesEnfermeria:["Extraer muestra seriada: al ingreso, a las 3h y 6h para detectar curva de elevaci\xf3n","No retrasar la extracci\xf3n por espera de ayuno; es una urgencia diagn\xf3stica","Monitorizaci\xf3n electrocardiogr\xe1fica continua si troponina elevada","Asegurar acceso venoso y preparar tratamiento de reperfusi\xf3n si IAM confirmado"]},{id:"lab_ck_mb",nombre:"Creatina Quinasa MB",abreviatura:"CK-MB",categoria:"cardiaco",rangos:{adulto:{min:0,max:5,unidad:"ng/mL"}},significadoAlto:"Elevada en infarto agudo de miocardio (pico a las 12-24h), miocarditis, cardioversi\xf3n, cirug\xeda card\xedaca o rabdomi\xf3lisis severa.",significadoBajo:"Valores normales ayudan a descartar da\xf1o mioc\xe1rdico reciente.",farmacosAlteran:["Estatinas","Fibratos","Doxorrubicina","Coca\xedna","Antipsic\xf3ticos"],implicacionesEnfermeria:["Se eleva a las 4-8h del IAM y normaliza en 48-72h; \xfatil para detectar reinfarto","Complementar siempre con troponina para mayor especificidad","Diferenciar de CK total elevada por causa muscular (ejercicio, inyecciones IM)"]},{id:"lab_bnp",nombre:"P\xe9ptido Natriur\xe9tico Cerebral",abreviatura:"BNP",categoria:"cardiaco",rangos:{adulto:{min:0,max:100,unidad:"pg/mL"}},significadoAlto:"Indica insuficiencia card\xedaca descompensada; valores correlacionan con la severidad. Tambi\xe9n se eleva en TEP, hipertensi\xf3n pulmonar y fibrilaci\xf3n auricular.",significadoBajo:"Ayuda a descartar insuficiencia card\xedaca como causa de disnea (alto valor predictivo negativo).",farmacosAlteran:["Sacubitrilo/valsart\xe1n","IECA","Diur\xe9ticos","Betabloqueantes","Nesiritida"],implicacionesEnfermeria:["BNP <100 pg/mL: IC improbable; >400 pg/mL: IC muy probable","Monitorizar peso diario y balance h\xeddrico en pacientes con BNP elevado","Valorar disnea, ortopnea, edema perif\xe9rico y crepitantes pulmonares","\xdatil para monitorizar respuesta al tratamiento de la insuficiencia card\xedaca"]},{id:"lab_pro_bnp",nombre:"Pro-P\xe9ptido Natriur\xe9tico Cerebral N-terminal",abreviatura:"NT-proBNP",categoria:"cardiaco",rangos:{adulto:{min:0,max:300,unidad:"pg/mL"}},significadoAlto:"Elevado en insuficiencia card\xedaca (valores ajustados por edad: <50 a\xf1os >450, 50-75 a\xf1os >900, >75 a\xf1os >1800 pg/mL). Tambi\xe9n en ERC y sepsis.",significadoBajo:"Valores normales descartan IC con alta sensibilidad. No se afecta por sacubitrilo (a diferencia del BNP).",farmacosAlteran:["IECA","ARA-II","Betabloqueantes","Diur\xe9ticos","Espironolactona"],implicacionesEnfermeria:["Interpretar seg\xfan edad del paciente por los diferentes puntos de corte","Preferido sobre BNP en pacientes tratados con sacubitrilo/valsart\xe1n","Monitorizar tendencia: descenso >30% indica buena respuesta al tratamiento","Correlacionar con cl\xednica y no interpretar de forma aislada"]},{id:"lab_ldh",nombre:"Lactato Deshidrogenasa",abreviatura:"LDH",categoria:"cardiaco",rangos:{adulto:{min:140,max:280,unidad:"U/L"}},significadoAlto:"Elevada en infarto de miocardio (tard\xedo), hem\xf3lisis, embolia pulmonar, hepatopat\xeda, linfoma, anemia megalobl\xe1stica y destrucci\xf3n tisular generalizada.",significadoBajo:"Rara vez cl\xednicamente significativo.",farmacosAlteran:["Anest\xe9sicos","Aspirina","Fluorouracilo","Metotrexato","Narc\xf3ticos"],implicacionesEnfermeria:["Marcador inespec\xedfico de da\xf1o tisular; correlacionar con otros marcadores espec\xedficos","En sospecha de hem\xf3lisis, correlacionar con haptoglobina y bilirrubina indirecta","Monitorizar como marcador pron\xf3stico en linfomas y tumores germinales"]},{id:"lab_tsh",nombre:"Hormona Estimulante de la Tiroides",abreviatura:"TSH",categoria:"endocrino",rangos:{adulto:{min:.4,max:4,unidad:"mUI/L"}},significadoAlto:"Indica hipotiroidismo primario; tambi\xe9n se eleva en tiroiditis de Hashimoto, d\xe9ficit de yodo o tras suspender levotiroxina.",significadoBajo:"Indica hipertiroidismo (enfermedad de Graves, bocio multinodular t\xf3xico) o supresi\xf3n por exceso de hormona tiroidea ex\xf3gena.",farmacosAlteran:["Levotiroxina","Amiodarona","Litio","Metimazol","Propiltiouracilo"],implicacionesEnfermeria:["Administrar levotiroxina en ayunas, 30-60 minutos antes del desayuno","Monitorizar TSH cada 6-8 semanas tras ajuste de dosis de levotiroxina","Vigilar signos de hipotiroidismo: fatiga, aumento de peso, bradicardia, intolerancia al fr\xedo","Vigilar signos de hipertiroidismo: taquicardia, p\xe9rdida de peso, temblor, ansiedad"]},{id:"lab_t4_libre",nombre:"Tiroxina Libre",abreviatura:"T4L",categoria:"endocrino",rangos:{adulto:{min:.8,max:1.8,unidad:"ng/dL"}},significadoAlto:"Indica hipertiroidismo, tiroiditis aguda (fase tirot\xf3xica), sobredosis de levotiroxina o amiodarona.",significadoBajo:"Indica hipotiroidismo; si TSH tambi\xe9n baja, sospechar hipotiroidismo central (hipofisario).",farmacosAlteran:["Levotiroxina","Amiodarona","Propranolol","Corticosteroides","Heparina"],implicacionesEnfermeria:["Interpretar siempre junto con TSH para diagn\xf3stico correcto","TSH alta + T4L baja = hipotiroidismo primario","TSH baja + T4L alta = hipertiroidismo","No extraer muestra justo despu\xe9s de tomar levotiroxina (falso elevado)"]},{id:"lab_t3",nombre:"Triyodotironina",abreviatura:"T3",categoria:"endocrino",rangos:{adulto:{min:80,max:200,unidad:"ng/dL"}},significadoAlto:"Elevada en hipertiroidismo (especialmente T3-tirotoxicosis), fase aguda de tiroiditis o exceso de tratamiento tiroideo.",significadoBajo:"Disminuida en hipotiroidismo, s\xedndrome del eutiroideo enfermo (enfermedad no tiroidea grave), desnutrici\xf3n o ayuno prolongado.",farmacosAlteran:["Levotiroxina","Amiodarona","Propranolol","Anticonvulsivantes","Estr\xf3genos"],implicacionesEnfermeria:["Solicitar T3 cuando TSH baja pero T4L normal (descartar T3-tirotoxicosis)","Valores bajos en pacientes cr\xedticos no siempre indican hipotiroidismo (s\xedndrome del enfermo eutiroideo)","Monitorizar frecuencia card\xedaca y presi\xf3n arterial en T3 elevada"]},{id:"lab_cortisol",nombre:"Cortisol s\xe9rico",abreviatura:"Cort",categoria:"endocrino",rangos:{adulto:{min:6,max:23,unidad:"\xb5g/dL"}},significadoAlto:"Indica s\xedndrome de Cushing, estr\xe9s agudo, depresi\xf3n, alcoholismo o tratamiento cr\xf3nico con corticoides ex\xf3genos.",significadoBajo:"Indica insuficiencia suprarrenal (enfermedad de Addison), hipopituitarismo o suspensi\xf3n brusca de corticoides.",farmacosAlteran:["Prednisona","Dexametasona","Ketoconazol","Estr\xf3genos","Opioides"],implicacionesEnfermeria:["Extraer muestra por la ma\xf1ana (6-8 AM) por el ritmo circadiano del cortisol","Nunca suspender corticoides bruscamente: reducir gradualmente para evitar crisis addisoniana","Vigilar signos de crisis suprarrenal: hipotensi\xf3n, hipoglucemia, confusi\xf3n","Educar al paciente con corticoterapia cr\xf3nica sobre la necesidad de portar identificaci\xf3n m\xe9dica"]},{id:"lab_hba1c",nombre:"Hemoglobina Glucosilada",abreviatura:"HbA1c",categoria:"endocrino",rangos:{adulto:{min:4,max:5.6,unidad:"%"}},significadoAlto:"Indica mal control gluc\xe9mico en los \xfaltimos 2-3 meses. HbA1c 5.7-6.4% = prediabetes; \u22656.5% = diabetes mellitus.",significadoBajo:"Puede verse en anemias hemol\xedticas, hemorragia reciente, embarazo o hemoglobinopat\xedas (falso resultado bajo).",farmacosAlteran:["Insulina","Metformina","Sulfonilureas","An\xe1logos GLP-1","Inhibidores SGLT2"],implicacionesEnfermeria:["Objetivo terap\xe9utico general en diabetes: HbA1c <7% (individualizar seg\xfan paciente)","No requiere ayuno para su determinaci\xf3n","Monitorizar cada 3 meses en pacientes con diabetes no controlada","Educar que refleja el promedio gluc\xe9mico de 2-3 meses, no un valor puntual"]},{id:"lab_insulina",nombre:"Insulina en ayunas",abreviatura:"Ins",categoria:"endocrino",rangos:{adulto:{min:2.6,max:24.9,unidad:"\xb5UI/mL"}},significadoAlto:"Hiperinsulinemia: indica resistencia a la insulina, s\xedndrome metab\xf3lico, obesidad, insulinoma o fase temprana de DM tipo 2.",significadoBajo:"Indica diabetes tipo 1 (destrucci\xf3n de c\xe9lulas beta), DM2 avanzada con agotamiento pancre\xe1tico o insuficiencia pancre\xe1tica exocrina.",farmacosAlteran:["Insulina ex\xf3gena","Sulfonilureas","Metformina","Corticosteroides","Tiazidas"],implicacionesEnfermeria:["Asegurar extracci\xf3n en ayunas de al menos 8 horas","Calcular \xedndice HOMA-IR junto con glucosa para evaluar resistencia a insulina","Correlacionar con p\xe9ptido C para diferenciar insulina end\xf3gena de ex\xf3gena"]},{id:"lab_ph_urinario",nombre:"pH urinario",abreviatura:"pH-U",categoria:"orina",rangos:{adulto:{min:4.5,max:8,unidad:""}},significadoAlto:"Orina alcalina (>8.0): infecci\xf3n urinaria por Proteus, dieta vegetariana, alcalosis metab\xf3lica, acidosis tubular renal o v\xf3mitos prolongados.",significadoBajo:"Orina \xe1cida (<4.5): dieta hiperproteica, acidosis metab\xf3lica, diabetes descompensada, diarrea severa o deshidrataci\xf3n.",farmacosAlteran:["Bicarbonato s\xf3dico","Acetazolamida","\xc1cido asc\xf3rbico","Cloruro am\xf3nico","Citrato pot\xe1sico"],implicacionesEnfermeria:["Considerar pH urinario al interpretar sedimento y prevenci\xf3n de litiasis","Alcalinizar orina con bicarbonato para prevenir nefropat\xeda por metotrexato","Recoger muestra de orina fresca; la orina en reposo se alcaliniza"]},{id:"lab_densidad_urinaria",nombre:"Densidad urinaria",abreviatura:"Dens",categoria:"orina",rangos:{adulto:{min:1.005,max:1.03,unidad:""}},significadoAlto:"Orina concentrada: deshidrataci\xf3n, SIADH, insuficiencia card\xedaca, proteinuria masiva o glucosuria.",significadoBajo:"Orina diluida: diabetes ins\xedpida, ingesta h\xeddrica excesiva, insuficiencia renal cr\xf3nica (incapacidad de concentrar orina) o uso de diur\xe9ticos.",farmacosAlteran:["Diur\xe9ticos","Desmopresina","Medios de contraste","Manitol","Glucosa IV"],implicacionesEnfermeria:["Correlacionar con estado de hidrataci\xf3n del paciente","Densidad fija ~1.010 indica p\xe9rdida de capacidad de concentraci\xf3n renal","Monitorizar en pacientes con sospecha de diabetes ins\xedpida"]},{id:"lab_proteinas_orina",nombre:"Prote\xednas en orina",abreviatura:"Prot-U",categoria:"orina",rangos:{adulto:{min:0,max:150,unidad:"mg/24h"}},significadoAlto:"Proteinuria: indica da\xf1o glomerular (>3.5 g/24h = s\xedndrome nefr\xf3tico), nefropat\xeda diab\xe9tica, preeclampsia, mieloma m\xfaltiple o nefritis.",significadoBajo:"Valores normales indican funci\xf3n glomerular adecuada; no hay significado cl\xednico en proteinuria baja.",farmacosAlteran:["IECA/ARA-II","AINEs","Aminogluc\xf3sidos","Litio","Ciclosporina"],implicacionesEnfermeria:["Instruir sobre recolecci\xf3n correcta de orina de 24 horas","Usar tira reactiva como cribado; confirmar con proteinuria cuantitativa","Monitorizar en pacientes diab\xe9ticos e hipertensos como marcador de nefropat\xeda","Los IECA/ARA-II tienen efecto nefroprotector al reducir proteinuria"]},{id:"lab_glucosa_orina",nombre:"Glucosa en orina",abreviatura:"Glu-U",categoria:"orina",rangos:{adulto:{min:0,max:15,unidad:"mg/dL"}},significadoAlto:"Glucosuria: aparece cuando la glucemia supera el umbral renal (~180 mg/dL). Indica diabetes descompensada, glucosuria renal o efecto de iSGLT2.",significadoBajo:"La ausencia de glucosa en orina es normal; valores de 0-15 mg/dL se consideran no detectables.",farmacosAlteran:["Inhibidores SGLT2","Corticosteroides","Tiazidas","\xc1cido asc\xf3rbico","Cefalosporinas"],implicacionesEnfermeria:["Tener en cuenta que iSGLT2 (dapagliflozina, empagliflozina) producen glucosuria terap\xe9utica","No usar glucosuria como \xfanico m\xe9todo de control en diabetes","Vigilar riesgo de infecciones urinarias en pacientes con glucosuria persistente"]},{id:"lab_microalbuminuria",nombre:"Microalbuminuria",abreviatura:"mAlb",categoria:"orina",rangos:{adulto:{min:0,max:30,unidad:"mg/g creatinina"}},significadoAlto:"Microalbuminuria (30-300 mg/g): marcador precoz de nefropat\xeda diab\xe9tica e hipertensiva. Macroalbuminuria (>300 mg/g): indica da\xf1o glomerular establecido.",significadoBajo:"Valores normales (<30 mg/g) indican ausencia de da\xf1o glomerular significativo.",farmacosAlteran:["IECA/ARA-II","AINEs","Aminogluc\xf3sidos","Inhibidores SGLT2","Finerenona"],implicacionesEnfermeria:["Cribado anual en pacientes diab\xe9ticos e hipertensos","Preferir muestra de primera orina de la ma\xf1ana (ratio alb\xfamina/creatinina)","Iniciar IECA/ARA-II ante microalbuminuria positiva en diab\xe9ticos","Evitar recoger muestra durante menstruaci\xf3n, infecci\xf3n urinaria o ejercicio intenso"]},{id:"lab_ph_arterial",nombre:"pH arterial",abreviatura:"pH",categoria:"gasometria",rangos:{adulto:{min:7.35,max:7.45,unidad:""}},significadoAlto:"Alcalemia (>7.45): alcalosis respiratoria (hiperventilaci\xf3n) o metab\xf3lica (v\xf3mitos, diur\xe9ticos). Puede causar tetania e irritabilidad neuromuscular.",significadoBajo:"Acidemia (<7.35): acidosis respiratoria (retenci\xf3n de CO2) o metab\xf3lica (cetoacidosis, acidosis l\xe1ctica, insuficiencia renal). pH <7.20 es potencialmente letal.",farmacosAlteran:["Bicarbonato s\xf3dico","Acetazolamida","Diur\xe9ticos del asa","Salicilatos","Metformina"],implicacionesEnfermeria:["pH <7.20 o >7.60: situaci\xf3n de emergencia que requiere intervenci\xf3n inmediata","Interpretar siempre junto con PaCO2 y HCO3 para determinar el trastorno primario","Verificar que la muestra sea arterial y se analice en menos de 15 minutos","Transportar la muestra en hielo y sin burbujas de aire"]},{id:"lab_pao2",nombre:"Presi\xf3n Parcial de Ox\xedgeno",abreviatura:"PaO2",categoria:"gasometria",rangos:{adulto:{min:80,max:100,unidad:"mmHg"}},significadoAlto:"Hiperoxemia: generalmente por FiO2 elevada. En neonatos prematuros, PaO2 alta aumenta riesgo de retinopat\xeda.",significadoBajo:"Hipoxemia: indica insuficiencia respiratoria. PaO2 <60 mmHg = insuficiencia respiratoria parcial; requiere oxigenoterapia. Causas: neumon\xeda, SDRA, TEP, EPOC.",farmacosAlteran:["Ox\xedgeno suplementario","Broncodilatadores","Sedantes/opioides","Anest\xe9sicos","\xd3xido n\xedtrico"],implicacionesEnfermeria:["Registrar FiO2 del paciente al momento de la extracci\xf3n","Calcular PaO2/FiO2 (\xedndice de Kirby): <300 = lesi\xf3n pulmonar; <200 = SDRA","Monitorizar saturaci\xf3n de O2 con pulsioximetr\xeda de forma continua","Ajustar oxigenoterapia seg\xfan objetivo de PaO2 del paciente"]},{id:"lab_paco2",nombre:"Presi\xf3n Parcial de Di\xf3xido de Carbono",abreviatura:"PaCO2",categoria:"gasometria",rangos:{adulto:{min:35,max:45,unidad:"mmHg"}},significadoAlto:"Hipercapnia (>45 mmHg): indica hipoventilaci\xf3n (EPOC, depresi\xf3n respiratoria, fatiga muscular) = acidosis respiratoria.",significadoBajo:"Hipocapnia (<35 mmHg): indica hiperventilaci\xf3n (ansiedad, dolor, TEP, compensaci\xf3n de acidosis metab\xf3lica) = alcalosis respiratoria.",farmacosAlteran:["Opioides","Benzodiazepinas","Broncodilatadores","Salicilatos","Progesterona"],implicacionesEnfermeria:["En pacientes con EPOC cr\xf3nico, tolerar PaCO2 m\xe1s alta (hipercapnia permisiva)","Monitorizar patr\xf3n respiratorio: frecuencia, profundidad y esfuerzo","Alertar si PaCO2 >50 mmHg con acidosis: posible necesidad de ventilaci\xf3n mec\xe1nica","Evaluar nivel de conciencia en hipercapnia progresiva (narcosis por CO2)"]},{id:"lab_hco3",nombre:"Bicarbonato",abreviatura:"HCO3",categoria:"gasometria",rangos:{adulto:{min:22,max:26,unidad:"mEq/L"}},significadoAlto:"HCO3 >26: alcalosis metab\xf3lica (v\xf3mitos, aspiraci\xf3n g\xe1strica, diur\xe9ticos) o compensaci\xf3n renal de acidosis respiratoria cr\xf3nica.",significadoBajo:"HCO3 <22: acidosis metab\xf3lica (cetoacidosis, acidosis l\xe1ctica, diarrea severa, insuficiencia renal) o compensaci\xf3n de alcalosis respiratoria.",farmacosAlteran:["Bicarbonato s\xf3dico","Acetazolamida","Diur\xe9ticos tiaz\xeddicos","Furosemida","Topiramato"],implicacionesEnfermeria:["Calcular ani\xf3n gap (Na - Cl - HCO3) para clasificar la acidosis metab\xf3lica","Ani\xf3n gap >12: cetoacidosis, acidosis l\xe1ctica, intoxicaciones","Ani\xf3n gap normal: diarrea, acidosis tubular renal, f\xedstulas intestinales","Monitorizar nivel de conciencia y patr\xf3n respiratorio (Kussmaul en acidosis severa)"]},{id:"lab_saturacion_o2",nombre:"Saturaci\xf3n de Ox\xedgeno Arterial",abreviatura:"SaO2",categoria:"gasometria",rangos:{adulto:{min:95,max:100,unidad:"%"}},significadoAlto:"100% generalmente indica ox\xedgeno suplementario. En pacientes con EPOC, SaO2 100% puede indicar oxigenoterapia excesiva.",significadoBajo:"SaO2 <90% indica hipoxemia significativa (equivale a PaO2 ~60 mmHg en la curva de disociaci\xf3n). Requiere intervenci\xf3n inmediata.",farmacosAlteran:["Ox\xedgeno suplementario","Opioides","Sedantes","Broncodilatadores","\xd3xido n\xedtrico"],implicacionesEnfermeria:["Objetivo en EPOC: SaO2 88-92% (evitar supresi\xf3n del est\xedmulo hip\xf3xico)","Objetivo general: SaO2 \u226594% (\u226592% si riesgo de hipercapnia)","La pulsioximetr\xeda puede ser inexacta con esmalte de u\xf1as, hipotermia o mala perfusi\xf3n","Correlacionar pulsioximetr\xeda con gasometr\xeda arterial en casos dudosos"]},{id:"lab_lactato",nombre:"Lactato",abreviatura:"Lac",categoria:"gasometria",rangos:{adulto:{min:.5,max:2,unidad:"mmol/L"},pediatrico:{min:.5,max:2.2,unidad:"mmol/L"}},significadoAlto:"Hiperlactatemia: puede indicar hipoperfusi\xf3n tisular, sepsis, shock, isquemia mesent\xe9rica, insuficiencia hep\xe1tica grave o efecto de metformina. Lactato >4 mmol/L se asocia a mortalidad elevada en sepsis.",significadoBajo:"Sin relevancia cl\xednica significativa en valores bajos.",farmacosAlteran:["Metformina","Epinefrina","Linezolid","Nucle\xf3sidos antirretrovirales","Propofol (infusi\xf3n prolongada)"],implicacionesEnfermeria:["Monitorizar lactato seriado cada 2-4h en sepsis/shock para evaluar respuesta al tratamiento","Objetivo de resucitaci\xf3n: aclaramiento de lactato >10% en primeras 6 horas","Lactato >4 mmol/L: alertar al equipo m\xe9dico inmediatamente","Asegurar extracci\xf3n venosa sin torniquete prolongado (falso aumento)","Correlacionar con signos de perfusi\xf3n: relleno capilar, diuresis, nivel de conciencia"]},{id:"lab_procalcitonina",nombre:"Procalcitonina",abreviatura:"PCT",categoria:"bioquimica",rangos:{adulto:{min:0,max:.05,unidad:"ng/mL"}},significadoAlto:"PCT >0.5 ng/mL sugiere infecci\xf3n bacteriana sist\xe9mica. PCT >2 ng/mL alta probabilidad de sepsis bacteriana. PCT >10 ng/mL asociada a shock s\xe9ptico o fallo multiorg\xe1nico. \xdatil para diferenciar infecci\xf3n bacteriana de viral.",significadoBajo:"Valores <0.1 ng/mL hacen improbable una infecci\xf3n bacteriana sist\xe9mica. \xdatil para guiar la suspensi\xf3n de antibi\xf3ticos.",farmacosAlteran:["Antibi\xf3ticos (disminuyen si efectivos)","OKT3","Alemtuzumab","Granulocyte-CSF"],implicacionesEnfermeria:["Monitorizar PCT seriada para guiar duraci\xf3n de antibioterapia (descenso >80% apoya suspensi\xf3n)","PCT <0.25 ng/mL: considerar suspensi\xf3n de antibi\xf3ticos (consenso con equipo m\xe9dico)","No se eleva significativamente en infecciones virales ni autoinmunes (valor diferencial)","Extraer muestra antes de iniciar antibi\xf3ticos cuando sea posible"]},{id:"lab_magnesio",nombre:"Magnesio",abreviatura:"Mg",categoria:"bioquimica",rangos:{adultoHombre:{min:1.7,max:2.2,unidad:"mg/dL"},adultoMujer:{min:1.7,max:2.2,unidad:"mg/dL"},pediatrico:{min:1.7,max:2.1,unidad:"mg/dL"}},significadoAlto:"Hipermagnesemia: puede causar hipotensi\xf3n, bradicardia, depresi\xf3n respiratoria, arreflexia y paro card\xedaco. Frecuente en insuficiencia renal con suplementos de Mg o anti\xe1cidos.",significadoBajo:"Hipomagnesemia: causa arritmias (torsades de pointes), convulsiones, tetania, debilidad muscular. Frecuente en alcoholismo, diur\xe9ticos, malabsorci\xf3n. Dificulta la correcci\xf3n de hipopotasemia e hipocalcemia.",farmacosAlteran:["Diur\xe9ticos de asa","Inhibidores de bomba de protones","Aminogluc\xf3sidos","Cisplatino","Ciclosporina","Sulfato de magnesio IV"],implicacionesEnfermeria:["Monitorizar ECG en hipo/hipermagnesemia: buscar prolongaci\xf3n QT, arritmias","Administrar sulfato de magnesio IV lento (riesgo de hipotensi\xf3n y paro si r\xe1pido)","Controlar reflejo rotuliano durante infusi\xf3n de MgSO4 (eclampsia): ausencia indica toxicidad","Vigilar en pacientes con diur\xe9ticos cr\xf3nicos: solicitar Mg junto con K+","Hipomagnesemia refractaria: corregir Mg antes de intentar corregir K+ o Ca2+"]},{id:"lab_bnp",nombre:"NT-proBNP",abreviatura:"NT-proBNP",categoria:"cardiaco",rangos:{adulto:{min:0,max:125,unidad:"pg/mL"}},significadoAlto:"Elevaci\xf3n proporcional a la severidad de la insuficiencia card\xedaca. >300 pg/mL en <50 a\xf1os, >900 en 50-75 a\xf1os, >1800 en >75 a\xf1os sugiere IC aguda. Tambi\xe9n se eleva en TEP, sepsis, insuficiencia renal y fibrilaci\xf3n auricular.",significadoBajo:"Valores dentro de rango descartan IC con alto valor predictivo negativo. \xdatil en urgencias para diferenciar disnea card\xedaca de pulmonar.",farmacosAlteran:["IECA/ARA-II (disminuyen)","Sacubitrilo-valsart\xe1n (aumenta BNP, no NT-proBNP)","Betabloqueantes","Diur\xe9ticos","Nesiritida"],implicacionesEnfermeria:["Monitorizar NT-proBNP seriado para evaluar respuesta al tratamiento de IC","Considerar edad al interpretar: umbrales diagn\xf3sticos aumentan con la edad","Correlacionar con peso diario, balance h\xeddrico y signos de congesti\xf3n","Valores muy elevados: alertar sobre posible descompensaci\xf3n aguda","En pacientes obesos los valores pueden estar falsamente bajos"]},{id:"lab_dimero_d",nombre:"D-d\xedmero",abreviatura:"DD",categoria:"coagulacion",rangos:{adulto:{min:0,max:500,unidad:"ng/mL"}},significadoAlto:"Indica activaci\xf3n de coagulaci\xf3n y fibrin\xf3lisis. Elevado en TVP, TEP, CID, sepsis, cirug\xeda reciente, neoplasias, embarazo. Alto valor predictivo negativo: DD normal descarta TVP/TEP en pacientes con baja probabilidad cl\xednica (Wells).",significadoBajo:"Sin relevancia cl\xednica. Valor normal con alta probabilidad cl\xednica no descarta trombosis.",farmacosAlteran:["Anticoagulantes (disminuyen)","Fibrinol\xedticos (aumentan transitoriamente)","Anticonceptivos orales (elevan)"],implicacionesEnfermeria:["Interpretar siempre junto con escalas cl\xednicas (Wells para TVP/TEP)","En >50 a\xf1os aplicar corte ajustado: edad \xd7 10 ng/mL (ej. 65 a\xf1os \u2192 650 ng/mL)","DD negativo con baja probabilidad cl\xednica: seguro excluir TEP sin imagen","Vigilar signos de TVP: edema unilateral, dolor gemelar, signo de Homans","En sospecha de CID: solicitar DD junto con fibrin\xf3geno, plaquetas y TP"]},{id:"lab_ferritina",nombre:"Ferritina",abreviatura:"Fer",categoria:"hematologia",rangos:{adultoHombre:{min:20,max:250,unidad:"ng/mL"},adultoMujer:{min:10,max:120,unidad:"ng/mL"},pediatrico:{min:7,max:140,unidad:"ng/mL"}},significadoAlto:"Sobrecarga de hierro (hemocromatosis, transfusiones repetidas), inflamaci\xf3n cr\xf3nica, hepatopat\xeda, neoplasias, s\xedndrome hemofagoc\xedtico. Ferritina >500 ng/mL en inflamaci\xf3n; >1000 ng/mL buscar hemocromatosis o hemofagocitosis.",significadoBajo:"Ferritina <10-15 ng/mL confirma ferropenia (marcador m\xe1s espec\xedfico de d\xe9ficit de hierro). Causa de anemia ferrop\xe9nica: p\xe9rdidas GI, menorragia, malabsorci\xf3n, dieta insuficiente.",farmacosAlteran:["Hierro oral/IV","Deferoxamina (quelante)","Eritropoyetina","Transfusiones sangu\xedneas"],implicacionesEnfermeria:["Ferritina <15 ng/mL: d\xe9ficit de hierro confirmado, educar sobre suplementaci\xf3n","Tomar hierro oral en ayunas con vitamina C (mejora absorci\xf3n)","Ferritina elevada + anemia: sospechar anemia de enfermedad cr\xf3nica (no dar hierro)","Monitorizar en pacientes politransfundidos: riesgo de sobrecarga f\xe9rrica"]},{id:"lab_fosforo",nombre:"F\xf3sforo",abreviatura:"P",categoria:"renal",rangos:{adulto:{min:2.5,max:4.5,unidad:"mg/dL"},pediatrico:{min:4,max:7,unidad:"mg/dL"}},significadoAlto:"Hiperfosfatemia: com\xfan en enfermedad renal cr\xf3nica (ERC), rabdomi\xf3lisis, lisis tumoral, hipoparatiroidismo. Causa calcificaciones metast\xe1sicas (producto Ca\xd7P >55). Principal causa de hiperparatiroidismo secundario en ERC.",significadoBajo:"Hipofosfatemia: causa debilidad muscular, insuficiencia respiratoria (debilidad diafragm\xe1tica), rabdomi\xf3lisis, hem\xf3lisis. Frecuente en s\xedndrome de realimentaci\xf3n, alcalosis respiratoria, hiperparatiroidismo.",farmacosAlteran:["Quelantes de f\xf3sforo (sevelamer, carbonato c\xe1lcico)","Vitamina D","Insulina","Fosfato s\xf3dico/pot\xe1sico IV","Anti\xe1cidos con aluminio"],implicacionesEnfermeria:["En ERC: monitorizar f\xf3sforo junto con calcio, PTH y vitamina D","Educar sobre dieta baja en f\xf3sforo: evitar procesados, refrescos de cola, l\xe1cteos excesivos","Administrar quelantes de f\xf3sforo CON las comidas (no entre comidas)","En s\xedndrome de realimentaci\xf3n: monitorizar P cada 6-12h las primeras 72h","Hipofosfatemia severa (<1 mg/dL): reposici\xf3n IV lenta, vigilar hipocalcemia"]},{id:"lab_acido_urico",nombre:"\xc1cido \xdarico",abreviatura:"AU",categoria:"renal",rangos:{adultoHombre:{min:3.4,max:7,unidad:"mg/dL"},adultoMujer:{min:2.4,max:6,unidad:"mg/dL"},pediatrico:{min:2,max:5.5,unidad:"mg/dL"}},significadoAlto:"Hiperuricemia: riesgo de gota (artritis aguda por cristales de urato), nefrolitiasis \xfarica, nefropat\xeda por uratos (lisis tumoral). Se asocia a s\xedndrome metab\xf3lico, HTA y enfermedad cardiovascular.",significadoBajo:"Hipouricemia: generalmente sin relevancia cl\xednica. Puede verse en s\xedndrome de Fanconi, SIADH, xantinuria hereditaria o tratamiento excesivo con uricos\xfaricos.",farmacosAlteran:["Alopurinol","Febuxostat","Diur\xe9ticos tiaz\xeddicos (aumentan)","Losart\xe1n (disminuye)","Rasburicasa","\xc1cido acetilsalic\xedlico (dosis-dependiente)"],implicacionesEnfermeria:["En crisis gotosa: aplicar fr\xedo local, elevar articulaci\xf3n, no manipular","Fomentar ingesta h\xeddrica >2L/d\xeda para prevenir litiasis renal","Educar sobre dieta baja en purinas: limitar carnes rojas, mariscos, alcohol (cerveza)","En lisis tumoral: hidrataci\xf3n vigorosa + rasburicasa o alopurinol profil\xe1ctico","Monitorizar funci\xf3n renal en pacientes con hiperuricemia cr\xf3nica"]}]},787,[]);
__d(function(a,i,e,o,n,r,s){n.exports=[{id:"proto_acls",nombre:"ACLS - Paro Card\xedaco",abreviatura:"ACLS",descripcion:"Protocolo de soporte vital cardiovascular avanzado para el manejo del paro cardiorrespiratorio en adultos, incluyendo ritmos desfibrilables (FV/TV sin pulso) y no desfibrilables (asistolia/AESP).",categoria:"cardiaco",prioridad:"critico",banderasRojas:["Ausencia de pulso carot\xeddeo","Ausencia de respiraci\xf3n o respiraci\xf3n ag\xf3nica","P\xe9rdida s\xfabita de conciencia","Cianosis generalizada","Midriasis bilateral arreactiva"],pasos:[{orden:1,tiempo:"0-1 min",accion:"Confirmar paro card\xedaco e iniciar RCP de alta calidad",detalles:"Verificar ausencia de pulso (m\xe1x. 10 seg). Iniciar compresiones tor\xe1cicas 100-120/min, profundidad 5-6 cm. Relaci\xf3n 30:2 sin v\xeda a\xe9rea avanzada. Minimizar interrupciones (<10 seg).",critico:!0},{orden:2,tiempo:"1-2 min",accion:"Conectar monitor/desfibrilador y analizar ritmo",detalles:"Colocar parches de desfibrilaci\xf3n en posici\xf3n anterolateral. Analizar ritmo sin interrumpir compresiones m\xe1s de 10 segundos.",critico:!0,decision:{pregunta:"\xbfRitmo desfibrilable (FV/TV sin pulso)?",si:"Proceder a desfibrilaci\xf3n inmediata (paso 3)",no:"Continuar RCP, administrar epinefrina inmediatamente (paso 4) y reevaluar cada 2 min"}},{orden:3,tiempo:"2-3 min",accion:"Desfibrilaci\xf3n (si ritmo desfibrilable)",detalles:"Descarga bif\xe1sica 120-200 J (seg\xfan fabricante) o monof\xe1sica 360 J. Reanudar RCP inmediatamente despu\xe9s de la descarga durante 2 minutos sin verificar pulso.",critico:!0},{orden:4,tiempo:"3-5 min",accion:"Administrar Epinefrina",detalles:"En ritmo no desfibrilable: administrar lo antes posible. En ritmo desfibrilable: administrar despu\xe9s de la 2\xaa descarga. Repetir cada 3-5 minutos.",critico:!0,farmacos:[{nombre:"Epinefrina",dosis:"1 mg IV/IO cada 3-5 min",via:"IV/IO"}]},{orden:5,tiempo:"5-7 min",accion:"Asegurar v\xeda a\xe9rea avanzada",detalles:"Intubaci\xf3n endotraqueal o dispositivo supragl\xf3tico. Una vez colocada: ventilaciones continuas cada 6 seg (10/min) sin sincronizar con compresiones. Verificar capnograf\xeda (ETCO2).",critico:!1},{orden:6,tiempo:"5-10 min",accion:"Administrar Amiodarona (si FV/TV refractaria)",detalles:"Considerar despu\xe9s de la 3\xaa descarga si persiste FV/TV sin pulso. Si no hay amiodarona disponible, usar lidoca\xedna como alternativa.",critico:!0,farmacos:[{nombre:"Amiodarona",dosis:"300 mg IV/IO en bolo (1\xaa dosis); 150 mg IV/IO (2\xaa dosis)",via:"IV/IO"},{nombre:"Lidoca\xedna (alternativa)",dosis:"1-1.5 mg/kg IV/IO (1\xaa dosis); 0.5-0.75 mg/kg IV/IO (2\xaa dosis)",via:"IV/IO"}]},{orden:7,tiempo:"Cada 2 min",accion:"Reevaluar ritmo y buscar causas reversibles (5H y 5T)",detalles:"5H: Hipovolemia, Hipoxia, Hidrogeni\xf3n (acidosis), Hipo/Hiperpotasemia, Hipotermia. 5T: Neumot\xf3rax a Tensi\xf3n, Taponamiento card\xedaco, T\xf3xicos, Trombosis pulmonar, Trombosis coronaria.",critico:!0,decision:{pregunta:"\xbfSe identific\xf3 causa reversible?",si:"Tratar causa espec\xedfica de forma simult\xe1nea con RCP",no:"Continuar ciclos de RCP y reevaluar cada 2 minutos"}},{orden:8,tiempo:"Continuo",accion:"Cuidados post-paro card\xedaco (si hay RCE)",detalles:"Retorno de circulaci\xf3n espont\xe1nea (RCE): mantener PAS >90 mmHg, SpO2 94-99%, normocapnia, ECG 12 derivaciones, considerar manejo dirigido de temperatura (32-36\xb0C por 24h), angiograf\xeda coronaria si sospecha de SCA.",critico:!1,farmacos:[{nombre:"Norepinefrina",dosis:"0.1-0.5 mcg/kg/min en infusi\xf3n continua",via:"IV"}]}],resumenFarmacos:[{nombre:"Epinefrina",dosis:"1 mg IV/IO cada 3-5 min",via:"IV/IO",indicacion:"Vasopresor de primera l\xednea en paro card\xedaco para todos los ritmos"},{nombre:"Amiodarona",dosis:"300 mg IV/IO (1\xaa dosis); 150 mg IV/IO (2\xaa dosis)",via:"IV/IO",indicacion:"Antiarr\xedtmico en FV/TV sin pulso refractaria a desfibrilaci\xf3n"},{nombre:"Lidoca\xedna",dosis:"1-1.5 mg/kg IV/IO (1\xaa dosis); 0.5-0.75 mg/kg IV/IO (2\xaa dosis)",via:"IV/IO",indicacion:"Alternativa a amiodarona en FV/TV refractaria"},{nombre:"Norepinefrina",dosis:"0.1-0.5 mcg/kg/min en infusi\xf3n continua",via:"IV",indicacion:"Soporte hemodin\xe1mico post-RCE si hipotensi\xf3n persistente"}],notasEnfermeria:["Garantizar compresiones de alta calidad: profundidad 5-6 cm, frecuencia 100-120/min, permitir retroceso completo del t\xf3rax y minimizar interrupciones.","Registrar todos los tiempos: inicio de RCP, cada dosis de medicamento, cada descarga, y hora de RCE o cese de esfuerzos.","Monitorizar capnograf\xeda continua (ETCO2): valores <10 mmHg indican RCP de baja calidad; aumento s\xfabito >40 mmHg sugiere RCE.","Preparar infusi\xf3n de epinefrina o norepinefrina anticipadamente para soporte post-RCE.","Rotar al personal que realiza compresiones cada 2 minutos para evitar fatiga y mantener la calidad."]},{id:"proto_anafilaxia",nombre:"Anafilaxia",descripcion:"Protocolo de manejo de la reacci\xf3n anafil\xe1ctica severa, una emergencia m\xe9dica potencialmente mortal mediada por hipersensibilidad tipo I que requiere intervenci\xf3n inmediata con epinefrina.",categoria:"otro",prioridad:"critico",banderasRojas:["Edema de v\xeda a\xe9rea (estridor, voz ronca, disfagia)","Hipotensi\xf3n o shock distributivo","Broncoespasmo severo con sibilancias difusas","Urticaria generalizada con compromiso respiratorio o hemodin\xe1mico","Exposici\xf3n reciente a al\xe9rgeno conocido con deterioro r\xe1pido"],pasos:[{orden:1,tiempo:"0-1 min",accion:"Retirar al\xe9rgeno y administrar Epinefrina IM",detalles:"Administrar epinefrina IM en cara anterolateral del muslo. Es el f\xe1rmaco de primera l\xednea; NO debe retrasarse. Puede repetirse cada 5-15 minutos si no hay mejor\xeda.",critico:!0,farmacos:[{nombre:"Epinefrina",dosis:"0.3-0.5 mg IM (soluci\xf3n 1:1000 = 1 mg/mL). Pedi\xe1trico: 0.01 mg/kg IM (m\xe1x. 0.3 mg)",via:"IM"}]},{orden:2,tiempo:"0-2 min",accion:"Posicionar paciente y asegurar v\xeda a\xe9rea",detalles:"Posici\xf3n de Trendelenburg si hay hipotensi\xf3n. Posici\xf3n semisentada si hay distr\xe9s respiratorio. Administrar O2 al 100% con mascarilla de alto flujo (15 L/min). Preparar equipo de intubaci\xf3n.",critico:!0},{orden:3,tiempo:"1-3 min",accion:"Establecer acceso IV y administrar l\xedquidos",detalles:"Dos accesos venosos de gran calibre (14-16G). Bolo r\xe1pido de cristaloides. Puede requerir 1-2 litros adicionales en la primera hora si hay hipotensi\xf3n refractaria.",critico:!0,farmacos:[{nombre:"Soluci\xf3n Salina Normal (SSN 0.9%)",dosis:"500-1000 mL IV en bolo r\xe1pido (adultos); 20 mL/kg IV (pedi\xe1trico)",via:"IV"}]},{orden:4,tiempo:"3-5 min",accion:"Administrar broncodilatador si broncoespasmo",detalles:"Nebulizar salbutamol si hay sibilancias o broncoespasmo. Puede administrarse de forma continua en casos severos.",farmacos:[{nombre:"Salbutamol",dosis:"2.5-5 mg nebulizado cada 20 min o nebulizaci\xf3n continua",via:"Nebulizaci\xf3n"}]},{orden:5,tiempo:"5-10 min",accion:"Administrar corticosteroide IV",detalles:"Previene la fase tard\xeda de la anafilaxia (puede ocurrir 4-8 horas despu\xe9s). No sustituye a la epinefrina.",farmacos:[{nombre:"Hidrocortisona",dosis:"200 mg IV (adultos); 4 mg/kg IV (pedi\xe1trico, m\xe1x. 200 mg)",via:"IV"},{nombre:"Metilprednisolona (alternativa)",dosis:"1-2 mg/kg IV (m\xe1x. 125 mg)",via:"IV"}]},{orden:6,tiempo:"5-10 min",accion:"Administrar antihistam\xednicos",detalles:"Anti-H1 y anti-H2 como adyuvantes. NO reemplazan a la epinefrina como primera l\xednea.",farmacos:[{nombre:"Difenhidramina",dosis:"25-50 mg IV lento (adultos); 1 mg/kg IV (pedi\xe1trico, m\xe1x. 50 mg)",via:"IV"},{nombre:"Ranitidina",dosis:"50 mg IV en 100 mL de SSN a pasar en 15-20 min",via:"IV"}]},{orden:7,tiempo:"15-20 min",accion:"Reevaluar respuesta y considerar infusi\xf3n de epinefrina",detalles:"Si hipotensi\xf3n refractaria tras 2-3 dosis IM de epinefrina, iniciar infusi\xf3n IV continua. Monitorizar ECG continuo.",critico:!0,farmacos:[{nombre:"Epinefrina (infusi\xf3n)",dosis:"1-10 mcg/min IV en infusi\xf3n continua (titular seg\xfan respuesta)",via:"IV"}],decision:{pregunta:"\xbfEl paciente responde a las dosis IM de epinefrina?",si:"Mantener observaci\xf3n m\xednima de 6-8 horas por riesgo de reacci\xf3n bif\xe1sica",no:"Iniciar infusi\xf3n continua de epinefrina IV y considerar ingreso en UCI"}}],resumenFarmacos:[{nombre:"Epinefrina IM",dosis:"0.3-0.5 mg IM cada 5-15 min seg\xfan necesidad",via:"IM",indicacion:"Primera l\xednea en anafilaxia; vasoconstrictor y broncodilatador"},{nombre:"Epinefrina IV (infusi\xf3n)",dosis:"1-10 mcg/min IV en infusi\xf3n continua",via:"IV",indicacion:"Anafilaxia refractaria a dosis IM"},{nombre:"Salbutamol",dosis:"2.5-5 mg nebulizado cada 20 min",via:"Nebulizaci\xf3n",indicacion:"Broncoespasmo asociado a anafilaxia"},{nombre:"Hidrocortisona",dosis:"200 mg IV",via:"IV",indicacion:"Prevenci\xf3n de fase tard\xeda de anafilaxia"},{nombre:"Difenhidramina",dosis:"25-50 mg IV",via:"IV",indicacion:"Antihistam\xednico H1 adyuvante para s\xedntomas cut\xe1neos"},{nombre:"Ranitidina",dosis:"50 mg IV",via:"IV",indicacion:"Antihistam\xednico H2 adyuvante"},{nombre:"SSN 0.9%",dosis:"500-1000 mL IV en bolo r\xe1pido",via:"IV",indicacion:"Reposici\xf3n de volumen en shock anafil\xe1ctico"}],notasEnfermeria:["La epinefrina IM es el tratamiento de primera l\xednea; NUNCA debe retrasarse su administraci\xf3n en espera de otros f\xe1rmacos.","Monitorizar al paciente un m\xednimo de 6-8 horas por riesgo de reacci\xf3n bif\xe1sica (recurrencia de s\xedntomas sin nueva exposici\xf3n).","Registrar el al\xe9rgeno sospechoso, la hora de exposici\xf3n y la evoluci\xf3n temporal de los s\xedntomas.","Educar al paciente sobre el uso de autoinyector de epinefrina al alta y la necesidad de portar identificaci\xf3n de alergias.","Vigilar signos de edema de glotis: estridor, disfon\xeda, disfagia, babeo; preparar equipo de v\xeda a\xe9rea quir\xfargica."]},{id:"proto_crisis_hipertensiva",nombre:"Crisis Hipertensiva",descripcion:"Protocolo para el manejo de la emergencia hipertensiva (PA >180/120 mmHg con da\xf1o a \xf3rgano blanco) y la urgencia hipertensiva. El objetivo es la reducci\xf3n controlada de la PA para evitar isquemia.",categoria:"cardiaco",prioridad:"urgente",banderasRojas:["PA >180/120 mmHg con cefalea intensa, alteraci\xf3n visual o confusi\xf3n","Dolor tor\xe1cico o disnea (sospecha de disecci\xf3n a\xf3rtica o EAP)","D\xe9ficit neurol\xf3gico focal (sospecha de ACV)","Hematuria, oliguria o elevaci\xf3n de creatinina","Fondo de ojo con hemorragias, exudados o papiledema"],pasos:[{orden:1,tiempo:"0-5 min",accion:"Evaluaci\xf3n inicial y clasificaci\xf3n",detalles:"Confirmar PA en ambos brazos con manguito adecuado. Determinar si es emergencia hipertensiva (da\xf1o a \xf3rgano blanco) o urgencia hipertensiva (sin da\xf1o a \xf3rgano). ECG, anal\xedtica (creatinina, electrolitos, troponina), radiograf\xeda de t\xf3rax.",critico:!0,decision:{pregunta:"\xbfHay evidencia de da\xf1o a \xf3rgano blanco?",si:"Es EMERGENCIA hipertensiva \u2192 reducci\xf3n IV controlada en UCI (paso 3)",no:"Es URGENCIA hipertensiva \u2192 reducci\xf3n oral gradual en 24-48h (paso 2)"}},{orden:2,tiempo:"5-30 min",accion:"Manejo de urgencia hipertensiva (sin da\xf1o a \xf3rgano)",detalles:"Reducir PA gradualmente en 24-48 horas con antihipertensivos orales. Ambiente tranquilo, reposo. Objetivo: reducir PA un 20-25% en las primeras horas.",farmacos:[{nombre:"Captopril",dosis:"25 mg VO sublingual, puede repetirse en 30 min",via:"VO/SL"},{nombre:"Amlodipino",dosis:"5-10 mg VO",via:"VO"}]},{orden:3,tiempo:"5-15 min",accion:"Iniciar terapia IV para emergencia hipertensiva",detalles:"Meta: reducir PA no m\xe1s del 25% en la primera hora, luego a 160/100 mmHg en 2-6 horas. Reducci\xf3n excesiva puede causar isquemia cerebral o coronaria. Seleccionar f\xe1rmaco seg\xfan etiolog\xeda.",critico:!0,farmacos:[{nombre:"Labetalol",dosis:"20 mg IV en 2 min, luego 20-80 mg IV cada 10 min (m\xe1x. 300 mg) o infusi\xf3n 0.5-2 mg/min",via:"IV"}]},{orden:4,tiempo:"15-30 min",accion:"Alternativas seg\xfan etiolog\xeda y respuesta",detalles:"Si no hay respuesta a labetalol, considerar alternativas. Nicardipina en infusi\xf3n es preferible si se requiere titulaci\xf3n precisa. Nitroprusiato en emergencia refractaria (precauci\xf3n: toxicidad por cianuro).",farmacos:[{nombre:"Nicardipina",dosis:"5 mg/h IV en infusi\xf3n, titular cada 5-15 min en incrementos de 2.5 mg/h (m\xe1x. 15 mg/h)",via:"IV"},{nombre:"Nitroprusiato de sodio",dosis:"0.25-10 mcg/kg/min IV en infusi\xf3n continua (proteger de la luz)",via:"IV"}]},{orden:5,tiempo:"30-60 min",accion:"Monitoreo continuo y ajuste de tratamiento",detalles:"PA cada 5-15 minutos durante infusi\xf3n. Monitoreo neurol\xf3gico frecuente. Evaluar diuresis horaria. Ajustar infusi\xf3n para mantener PA en rango objetivo.",critico:!0},{orden:6,tiempo:"2-6 horas",accion:"Transici\xf3n a terapia oral",detalles:"Una vez estabilizada la PA IV, iniciar antihipertensivos orales con superposici\xf3n antes de suspender infusi\xf3n. No reducir PA a valores normales en las primeras 24-48h.",farmacos:[{nombre:"Labetalol oral",dosis:"200-400 mg VO cada 8-12h",via:"VO"}]}],resumenFarmacos:[{nombre:"Labetalol IV",dosis:"20 mg IV en bolo, luego 20-80 mg IV cada 10 min o infusi\xf3n 0.5-2 mg/min",via:"IV",indicacion:"Primera l\xednea en emergencia hipertensiva (excepto contraindicaciones de betabloqueantes)"},{nombre:"Nicardipina",dosis:"5-15 mg/h IV en infusi\xf3n continua",via:"IV",indicacion:"Alternativa a labetalol; preferida en ACV y si hay contraindicaci\xf3n de betabloqueantes"},{nombre:"Nitroprusiato de sodio",dosis:"0.25-10 mcg/kg/min IV en infusi\xf3n",via:"IV",indicacion:"Crisis refractaria a otros agentes; uso m\xe1ximo 48-72h por toxicidad de cianuro"},{nombre:"Captopril",dosis:"25 mg VO/SL",via:"VO/SL",indicacion:"Urgencia hipertensiva sin da\xf1o a \xf3rgano blanco"},{nombre:"Amlodipino",dosis:"5-10 mg VO",via:"VO",indicacion:"Urgencia hipertensiva, reducci\xf3n gradual oral"}],notasEnfermeria:["NO reducir la PA de forma abrupta; la reducci\xf3n excesiva puede causar isquemia cerebral, coronaria o renal.","Monitorizar PA con l\xednea arterial o PANI cada 5-15 min durante infusi\xf3n IV de antihipertensivos.","Vigilar signos de hipoperfusi\xf3n: confusi\xf3n, dolor tor\xe1cico, oliguria, deterioro neurol\xf3gico.","El nitroprusiato debe protegerse de la luz con cubierta opaca y no usar por m\xe1s de 48-72 horas.","Registrar balance h\xeddrico estricto y diuresis horaria durante el manejo agudo."]},{id:"proto_iam_stemi",nombre:"IAM con Elevaci\xf3n del ST (STEMI)",abreviatura:"STEMI",descripcion:"Protocolo de manejo del infarto agudo de miocardio con elevaci\xf3n del segmento ST. El objetivo primario es la reperfusi\xf3n lo m\xe1s r\xe1pida posible (puerta-bal\xf3n <90 min o puerta-aguja <30 min).",categoria:"cardiaco",prioridad:"critico",banderasRojas:["Dolor tor\xe1cico opresivo >20 min que no cede con nitroglicerina","Elevaci\xf3n del ST \u22651 mm en \u22652 derivaciones contiguas o BRIHH nuevo","Diaforesis, n\xe1useas, disnea con dolor precordial","Hipotensi\xf3n o signos de shock cardiog\xe9nico","Arritmias ventriculares (TV/FV) en contexto de dolor tor\xe1cico"],pasos:[{orden:1,tiempo:"0-5 min",accion:"ECG 12 derivaciones e identificaci\xf3n de STEMI",detalles:"ECG en los primeros 10 minutos del contacto. Identificar elevaci\xf3n del ST, territorio afectado. Activar c\xf3digo infarto/equipo de hemodin\xe1mica. Monitorizaci\xf3n continua.",critico:!0},{orden:2,tiempo:"0-5 min",accion:"MONA: Morfina, Ox\xedgeno, Nitroglicerina, Aspirina",detalles:"Aspirina masticada inmediatamente (si no hay alergia). O2 solo si SpO2 <90%. Nitroglicerina si PAS >90 mmHg y no hay IAM de VD. Morfina si dolor persiste tras nitroglicerina.",critico:!0,farmacos:[{nombre:"Aspirina (AAS)",dosis:"300 mg VO masticada (carga)",via:"VO"},{nombre:"Nitroglicerina",dosis:"0.4 mg SL cada 5 min (m\xe1x. 3 dosis); si persiste dolor: 5-200 mcg/min IV",via:"SL/IV"},{nombre:"Morfina",dosis:"2-4 mg IV cada 5-15 min seg\xfan dolor (si NTG no alivia)",via:"IV"},{nombre:"Ox\xedgeno",dosis:"2-4 L/min por c\xe1nula nasal (solo si SpO2 <90%)",via:"Inhalatoria"}]},{orden:3,tiempo:"5-10 min",accion:"Anticoagulaci\xf3n y segundo antiagregante",detalles:"Iniciar heparina. Agregar segundo antiagregante plaquetario (clopidogrel, ticagrelor o prasugrel seg\xfan disponibilidad y riesgo hemorr\xe1gico).",critico:!0,farmacos:[{nombre:"Heparina no fraccionada",dosis:"60 UI/kg IV en bolo (m\xe1x. 4000 UI), luego 12 UI/kg/h (m\xe1x. 1000 UI/h). Ajustar seg\xfan TTPa",via:"IV"},{nombre:"Clopidogrel",dosis:"300-600 mg VO (carga)",via:"VO"}]},{orden:4,tiempo:"10-30 min",accion:"Estrategia de reperfusi\xf3n",detalles:"ICP primaria es preferida si est\xe1 disponible en <120 min. Si ICP no disponible en tiempo, considerar fibrinolisis en <30 min del diagn\xf3stico.",critico:!0,decision:{pregunta:"\xbfAngioplastia primaria disponible en <120 minutos?",si:"Trasladar a hemodin\xe1mica para ICP primaria (puerta-bal\xf3n <90 min)",no:"Administrar fibrinol\xedtico si <12h de inicio de s\xedntomas y sin contraindicaciones (paso 5)"}},{orden:5,tiempo:"Seg\xfan decisi\xf3n",accion:"Fibrinolisis (si ICP no disponible)",detalles:"Administrar dentro de los primeros 30 min del diagn\xf3stico. Contraindicaciones absolutas: sangrado activo, ACV hemorr\xe1gico previo, cirug\xeda mayor <3 semanas. Evaluar criterios de reperfusi\xf3n a los 60-90 min.",farmacos:[{nombre:"Tenecteplasa (TNK)",dosis:"Seg\xfan peso: <60 kg: 30 mg; 60-69 kg: 35 mg; 70-79 kg: 40 mg; 80-89 kg: 45 mg; \u226590 kg: 50 mg IV en bolo",via:"IV"},{nombre:"Alteplasa (alternativa)",dosis:"15 mg IV bolo, luego 0.75 mg/kg en 30 min (m\xe1x 50 mg), luego 0.5 mg/kg en 60 min (m\xe1x 35 mg). Total m\xe1x: 100 mg",via:"IV"}]},{orden:6,tiempo:"Continuo",accion:"Manejo complementario y monitorizaci\xf3n",detalles:"Betabloqueante oral en las primeras 24h si no hay contraindicaci\xf3n (IC, bradicardia, hipotensi\xf3n). IECA/ARA-II en las primeras 24h si funci\xf3n sist\xf3lica reducida. Estatina de alta potencia.",farmacos:[{nombre:"Atorvastatina",dosis:"80 mg VO",via:"VO"},{nombre:"Metoprolol",dosis:"25-50 mg VO cada 6-12h (si FC >60, PAS >100, sin IC)",via:"VO"}]}],resumenFarmacos:[{nombre:"Aspirina",dosis:"300 mg VO masticada",via:"VO",indicacion:"Antiagregante plaquetario de primera l\xednea en SCA"},{nombre:"Clopidogrel",dosis:"300-600 mg VO (carga)",via:"VO",indicacion:"Segundo antiagregante plaquetario en doble antiagregaci\xf3n"},{nombre:"Heparina no fraccionada",dosis:"60 UI/kg bolo IV, luego 12 UI/kg/h",via:"IV",indicacion:"Anticoagulaci\xf3n en SCA para prevenir extensi\xf3n del trombo"},{nombre:"Nitroglicerina",dosis:"0.4 mg SL o 5-200 mcg/min IV",via:"SL/IV",indicacion:"Vasodilatador coronario para alivio del dolor isqu\xe9mico"},{nombre:"Morfina",dosis:"2-4 mg IV cada 5-15 min",via:"IV",indicacion:"Analgesia cuando nitroglicerina no alivia el dolor"},{nombre:"Tenecteplasa",dosis:"30-50 mg IV seg\xfan peso corporal",via:"IV",indicacion:"Fibrinol\xedtico cuando ICP no disponible en <120 min"},{nombre:"Atorvastatina",dosis:"80 mg VO",via:"VO",indicacion:"Estatina de alta intensidad para estabilizaci\xf3n de placa"},{nombre:"Metoprolol",dosis:"25-50 mg VO cada 6-12h",via:"VO",indicacion:"Betabloqueante para reducir demanda mioc\xe1rdica de O2"}],notasEnfermeria:["El tiempo es miocardio: cada minuto de retraso en la reperfusi\xf3n aumenta la mortalidad. Objetivo puerta-ECG <10 min.","NO administrar nitroglicerina si PAS <90 mmHg, FC <50 o >100, o sospecha de IAM de ventr\xedculo derecho (derivaciones derechas V3R-V4R).","Mantener dos accesos venosos permeables de gran calibre; nunca administrar fibrinol\xedtico por la misma v\xeda de heparina.","Vigilar signos de reperfusi\xf3n post-fibrinolisis: alivio del dolor, resoluci\xf3n del ST >50%, arritmias de reperfusi\xf3n (RIVA).","Monitorizaci\xf3n continua de ECG, PA y SpO2. Tener desfibrilador listo por riesgo de arritmias ventriculares."]},{id:"proto_acv_agudo",nombre:"ACV Agudo - Ictus Isqu\xe9mico",abreviatura:"ACV",descripcion:"Protocolo de manejo del accidente cerebrovascular isqu\xe9mico agudo. La ventana terap\xe9utica para tromb\xf3lisis IV con alteplasa es de 4.5 horas desde el inicio de los s\xedntomas. La trombectom\xeda mec\xe1nica puede extenderse hasta 24 horas en pacientes seleccionados.",categoria:"neurologico",prioridad:"critico",banderasRojas:["D\xe9ficit neurol\xf3gico focal de inicio s\xfabito (hemiparesia, afasia, hemianopsia)","Desviaci\xf3n de la comisura labial y debilidad de extremidades","Alteraci\xf3n del habla (disartria o afasia) de inicio brusco","P\xe9rdida de equilibrio o coordinaci\xf3n con otros d\xe9ficits neurol\xf3gicos","Cefalea intensa s\xfabita con rigidez de nuca (descartar hemorragia)"],pasos:[{orden:1,tiempo:"0-10 min",accion:"Activar c\xf3digo ictus y evaluaci\xf3n inicial",detalles:"Establecer hora de inicio de s\xedntomas (o \xfaltima vez visto normal). Escala NIHSS. Glucemia capilar inmediata (descartar hipoglucemia). Asegurar v\xeda a\xe9rea, O2 si SpO2 <94%. Dos accesos IV.",critico:!0},{orden:2,tiempo:"10-25 min",accion:"TC craneal urgente sin contraste",detalles:"Descartar hemorragia intracraneal antes de tromb\xf3lisis. Angiotomograf\xeda si disponible para evaluar oclusi\xf3n de gran vaso. No retrasar la TC.",critico:!0,decision:{pregunta:"\xbfLa TC muestra hemorragia intracraneal?",si:"Descartar tromb\xf3lisis; consultar neurocirug\xeda. Manejar como ACV hemorr\xe1gico.",no:"Continuar evaluaci\xf3n para tromb\xf3lisis IV si est\xe1 dentro de ventana terap\xe9utica (paso 3)"}},{orden:3,tiempo:"25-45 min",accion:"Evaluar criterios de tromb\xf3lisis IV",detalles:"Ventana: <4.5 horas desde inicio de s\xedntomas. Contraindicaciones: sangrado activo, plaquetas <100,000, INR >1.7, cirug\xeda mayor <14 d\xedas, ACV o TCE <3 meses, PA no controlable. Obtener consentimiento.",critico:!0,decision:{pregunta:"\xbfCumple criterios para tromb\xf3lisis IV (<4.5h, sin contraindicaciones)?",si:"Administrar alteplasa IV (paso 4). Objetivo puerta-aguja <60 min.",no:"Evaluar trombectom\xeda mec\xe1nica si oclusi\xf3n de gran vaso (<24h en pacientes seleccionados)"}},{orden:4,tiempo:"45-60 min",accion:"Administrar Alteplasa IV",detalles:"Dosis total: 0.9 mg/kg (m\xe1x. 90 mg). 10% en bolo IV en 1 minuto, 90% restante en infusi\xf3n IV en 60 minutos. No administrar anticoagulantes ni antiagregantes en las siguientes 24 horas.",critico:!0,farmacos:[{nombre:"Alteplasa (rt-PA)",dosis:"0.9 mg/kg IV (m\xe1x. 90 mg): 10% en bolo en 1 min, 90% en infusi\xf3n en 60 min",via:"IV"}]},{orden:5,tiempo:"Durante y post-infusi\xf3n",accion:"Control estricto de PA durante y despu\xe9s de tromb\xf3lisis",detalles:"Mantener PA <185/110 mmHg antes y durante tromb\xf3lisis; <180/105 mmHg en las 24h siguientes. Usar labetalol o nicardipina IV si es necesario.",critico:!0,farmacos:[{nombre:"Labetalol",dosis:"10-20 mg IV en 1-2 min, puede repetirse cada 10-20 min (m\xe1x. 300 mg)",via:"IV"},{nombre:"Nicardipina",dosis:"5 mg/h IV, titular cada 5-15 min, incrementos de 2.5 mg/h (m\xe1x. 15 mg/h)",via:"IV"}]},{orden:6,tiempo:"Post-tromb\xf3lisis",accion:"Monitorizaci\xf3n neurol\xf3gica intensiva",detalles:"NIHSS cada 15 min durante la infusi\xf3n, cada 30 min por 6h, luego cada hora por 18h. Vigilar signos de hemorragia intracraneal: cefalea intensa, v\xf3mitos, deterioro del nivel de conciencia, aumento de PA. TC de control a las 24h.",critico:!0,decision:{pregunta:"\xbfDeterioro neurol\xf3gico durante o despu\xe9s de la infusi\xf3n?",si:"Detener infusi\xf3n de alteplasa, TC craneal urgente, solicitar hemograma, fibrin\xf3geno y pruebas cruzadas",no:"Continuar monitorizaci\xf3n. TC de control a las 24h antes de iniciar antiagregaci\xf3n."}}],resumenFarmacos:[{nombre:"Alteplasa (rt-PA)",dosis:"0.9 mg/kg IV (m\xe1x. 90 mg): 10% bolo + 90% en 60 min",via:"IV",indicacion:"Tromb\xf3lisis en ACV isqu\xe9mico dentro de ventana de 4.5 horas"},{nombre:"Labetalol",dosis:"10-20 mg IV cada 10-20 min (m\xe1x. 300 mg)",via:"IV",indicacion:"Control de PA peri-tromb\xf3lisis"},{nombre:"Nicardipina",dosis:"5-15 mg/h IV en infusi\xf3n",via:"IV",indicacion:"Control de PA cuando se requiere titulaci\xf3n precisa"}],notasEnfermeria:["Tiempo es cerebro: el objetivo es puerta-aguja <60 minutos. Cada minuto de retraso se pierden ~1.9 millones de neuronas.","NO administrar antiagregantes ni anticoagulantes en las 24 horas posteriores a la tromb\xf3lisis IV.","Realizar escala NIHSS de forma seriada y documentar cualquier cambio neurol\xf3gico inmediatamente.","Mantener al paciente en ayuno hasta evaluaci\xf3n de degluci\xf3n (riesgo de disfagia y broncoaspiraci\xf3n).","Evitar punciones arteriales, sondaje vesical y procedimientos invasivos durante al menos 24h post-tromb\xf3lisis."]},{id:"proto_status_epileptico",nombre:"Status Epil\xe9ptico",descripcion:"Protocolo de manejo del estado epil\xe9ptico, definido como crisis convulsiva continua de >5 minutos o dos o m\xe1s crisis sin recuperaci\xf3n de conciencia entre ellas. Es una emergencia neurol\xf3gica con alta morbimortalidad.",categoria:"neurologico",prioridad:"critico",banderasRojas:["Crisis convulsiva t\xf3nico-cl\xf3nica generalizada que dura >5 minutos","Crisis recurrentes sin recuperaci\xf3n de conciencia entre episodios","Cianosis durante crisis prolongada","Fiebre alta asociada a convulsiones (descartar meningoencefalitis)","Antecedente de epilepsia con incumplimiento terap\xe9utico reciente"],pasos:[{orden:1,tiempo:"0-5 min",accion:"Estabilizaci\xf3n inicial y primera l\xednea de tratamiento",detalles:"Proteger v\xeda a\xe9rea (posici\xf3n lateral, aspirar secreciones, NO introducir objetos en la boca). O2 al 100%. Monitorizar SpO2, ECG, PA. Glucemia capilar inmediata. Acceso IV.",critico:!0,farmacos:[{nombre:"Diazepam",dosis:"10 mg IV lento (2 mg/min) o 20 mg rectal. Pedi\xe1trico: 0.2-0.5 mg/kg IV (m\xe1x. 10 mg)",via:"IV/Rectal"},{nombre:"Midazolam (si no hay acceso IV)",dosis:"10 mg IM o 10 mg intranasal/bucal. Pedi\xe1trico: 0.2 mg/kg IM (m\xe1x. 10 mg)",via:"IM/Intranasal"}],decision:{pregunta:"\xbfSe tiene acceso venoso?",si:"Administrar diazepam 10 mg IV lento. Puede repetir una vez en 5 min si persiste crisis.",no:"Administrar midazolam 10 mg IM o intranasal mientras se obtiene acceso IV."}},{orden:2,tiempo:"5-10 min",accion:"Tratar hipoglucemia si est\xe1 presente",detalles:"Si glucemia <60 mg/dL, administrar dextrosa IV. En pacientes alcoh\xf3licos o desnutridos, administrar tiamina ANTES de la dextrosa.",farmacos:[{nombre:"Dextrosa 50%",dosis:"50 mL IV (25 g de glucosa). Pedi\xe1trico: Dextrosa 25% 2-4 mL/kg IV",via:"IV"},{nombre:"Tiamina",dosis:"100 mg IV (administrar antes de dextrosa en sospecha de d\xe9ficit)",via:"IV"}]},{orden:3,tiempo:"10-20 min",accion:"Segunda l\xednea: antiepil\xe9ptico de carga",detalles:"Si las crisis persisten tras benzodiazepinas, iniciar un antiepil\xe9ptico de segunda l\xednea. Levetiracetam es preferido por menor sedaci\xf3n y menos interacciones. Fenito\xedna es alternativa cl\xe1sica (no usar en miocl\xf3nicas).",critico:!0,farmacos:[{nombre:"Levetiracetam",dosis:"60 mg/kg IV (m\xe1x. 4500 mg) en 15 min",via:"IV"},{nombre:"Fenito\xedna",dosis:"20 mg/kg IV a velocidad m\xe1xima de 50 mg/min (o fosfenito\xedna 20 mg EF/kg a 150 mg EF/min). Monitorizar ECG.",via:"IV"},{nombre:"\xc1cido valproico (alternativa)",dosis:"40 mg/kg IV en 10 min (m\xe1x. 3000 mg)",via:"IV"}]},{orden:4,tiempo:"20-40 min",accion:"Status epil\xe9ptico refractario",detalles:"Si persiste tras benzodiazepinas + antiepil\xe9ptico de segunda l\xednea. Considerar intubaci\xf3n y soporte en UCI. Iniciar anest\xe9sicos en infusi\xf3n continua con monitoreo EEG.",critico:!0,farmacos:[{nombre:"Midazolam (infusi\xf3n)",dosis:"0.2 mg/kg IV bolo, luego 0.1-2 mg/kg/h en infusi\xf3n continua",via:"IV"},{nombre:"Propofol",dosis:"1-2 mg/kg IV bolo, luego 2-10 mg/kg/h en infusi\xf3n continua (vigilar s\xedndrome de infusi\xf3n de propofol)",via:"IV"}]},{orden:5,tiempo:"Continuo",accion:"Estudios complementarios y b\xfasqueda etiol\xf3gica",detalles:"Anal\xedtica completa: electrolitos, calcio, magnesio, niveles de antiepil\xe9pticos, t\xf3xicos. TC craneal urgente. Punci\xf3n lumbar si sospecha de infecci\xf3n del SNC. EEG continuo en UCI.",critico:!1}],resumenFarmacos:[{nombre:"Diazepam",dosis:"10 mg IV lento (puede repetir x1) o 20 mg rectal",via:"IV/Rectal",indicacion:"Primera l\xednea para abortar crisis convulsiva"},{nombre:"Midazolam",dosis:"10 mg IM/intranasal (si no hay acceso IV)",via:"IM/Intranasal",indicacion:"Alternativa a diazepam cuando no hay acceso venoso"},{nombre:"Levetiracetam",dosis:"60 mg/kg IV (m\xe1x. 4500 mg) en 15 min",via:"IV",indicacion:"Segunda l\xednea; carga antiepil\xe9ptica con menos interacciones"},{nombre:"Fenito\xedna",dosis:"20 mg/kg IV a m\xe1x. 50 mg/min",via:"IV",indicacion:"Segunda l\xednea cl\xe1sica; requiere monitoreo card\xedaco por riesgo de arritmias"},{nombre:"\xc1cido valproico",dosis:"40 mg/kg IV en 10 min (m\xe1x. 3000 mg)",via:"IV",indicacion:"Alternativa de segunda l\xednea, \xfatil en crisis generalizadas y miocl\xf3nicas"},{nombre:"Propofol",dosis:"1-2 mg/kg IV bolo, luego 2-10 mg/kg/h",via:"IV",indicacion:"Status refractario en UCI con intubaci\xf3n"}],notasEnfermeria:["NO introducir objetos en la boca durante la crisis; proteger al paciente de lesiones retirando objetos cercanos.","La fenito\xedna debe administrarse SOLO en soluci\xf3n salina (incompatible con dextrosa); vigilar flebitis y extravasaci\xf3n (puede causar necrosis tisular).","Monitorizar ECG continuamente durante la infusi\xf3n de fenito\xedna por riesgo de arritmias y bradicardia.","Documentar duraci\xf3n exacta de cada crisis, tipo de movimientos y nivel de conciencia entre episodios.","Preparar equipo de intubaci\xf3n si las crisis persisten >20 minutos o hay compromiso de v\xeda a\xe9rea."]},{id:"proto_hipoglucemia",nombre:"Hipoglucemia Severa",descripcion:"Protocolo de manejo de la hipoglucemia severa (glucemia <54 mg/dL o s\xedntomas neuroglucop\xe9nicos), una emergencia metab\xf3lica frecuente en pacientes diab\xe9ticos tratados con insulina o sulfonilureas.",categoria:"metabolico",prioridad:"urgente",banderasRojas:["Glucemia <54 mg/dL con alteraci\xf3n del nivel de conciencia","Convulsiones asociadas a hipoglucemia","Paciente diab\xe9tico con diaforesis, temblor y confusi\xf3n","Incapacidad para ingerir glucosa por v\xeda oral","Uso reciente de insulina o sulfonilureas con ingesta alimentaria inadecuada"],pasos:[{orden:1,tiempo:"0-1 min",accion:"Confirmar hipoglucemia y evaluar estado de conciencia",detalles:"Glucemia capilar inmediata. Evaluar nivel de conciencia y capacidad de degluci\xf3n. Asegurar v\xeda a\xe9rea si hay alteraci\xf3n de conciencia.",critico:!0,decision:{pregunta:"\xbfEl paciente est\xe1 consciente y puede deglutir?",si:"Administrar 15-20 g de glucosa oral (jugo, tabletas de glucosa). Reevaluar en 15 min.",no:"Administrar dextrosa IV o glucag\xf3n IM (pasos 2-3)"}},{orden:2,tiempo:"1-3 min",accion:"Administrar Dextrosa IV (si hay acceso venoso)",detalles:"Dextrosa 50% por v\xeda IV es el tratamiento de elecci\xf3n en paciente con alteraci\xf3n de conciencia. Puede repetirse si no hay respuesta en 5 minutos.",critico:!0,farmacos:[{nombre:"Dextrosa 50%",dosis:"25-50 mL IV (12.5-25 g de glucosa) en bolo. Pedi\xe1trico: Dextrosa 10% 5 mL/kg IV",via:"IV"}]},{orden:3,tiempo:"1-3 min",accion:"Administrar Glucag\xf3n (si no hay acceso IV)",detalles:"Glucag\xf3n IM/SC cuando no se puede obtener acceso venoso. Inicio de acci\xf3n: 10-15 minutos. Menos efectivo en pacientes con depleci\xf3n de gluc\xf3geno hep\xe1tico (alcoholismo, insuficiencia hep\xe1tica).",farmacos:[{nombre:"Glucag\xf3n",dosis:"1 mg IM/SC (adultos). Pedi\xe1trico <25 kg: 0.5 mg IM/SC",via:"IM/SC"}]},{orden:4,tiempo:"15 min",accion:"Reevaluar glucemia y respuesta cl\xednica",detalles:"Control de glucemia capilar a los 15 minutos. Si glucemia sigue <70 mg/dL, repetir tratamiento. Una vez glucemia >70 mg/dL, administrar snack con carbohidratos complejos y prote\xednas.",critico:!0,decision:{pregunta:"\xbfGlucemia >70 mg/dL tras tratamiento?",si:"Dar snack con carbohidratos complejos. Investigar causa de hipoglucemia.",no:"Repetir dextrosa 50% IV. Si persiste, iniciar infusi\xf3n de dextrosa 10% y evaluar causa."}},{orden:5,tiempo:"30-60 min",accion:"Prevenir recurrencia e investigar causa",detalles:"Si hipoglucemia por sulfonilureas: alto riesgo de recurrencia prolongada (hasta 72h); considerar infusi\xf3n de dextrosa 10% y observaci\xf3n prolongada. Ajustar dosis de insulina/hipoglucemiantes. Si hipoglucemia por insulina de acci\xf3n prolongada, monitorizar \u226524h.",farmacos:[{nombre:"Dextrosa 10%",dosis:"100-200 mL/h IV en infusi\xf3n continua (ajustar seg\xfan glucemias cada 1-2h)",via:"IV"}]}],resumenFarmacos:[{nombre:"Dextrosa 50%",dosis:"25-50 mL IV en bolo (12.5-25 g de glucosa)",via:"IV",indicacion:"Primera l\xednea en hipoglucemia severa con alteraci\xf3n de conciencia y acceso IV"},{nombre:"Glucag\xf3n",dosis:"1 mg IM/SC",via:"IM/SC",indicacion:"Hipoglucemia severa sin acceso venoso disponible"},{nombre:"Dextrosa 10%",dosis:"100-200 mL/h IV en infusi\xf3n continua",via:"IV",indicacion:"Prevenci\xf3n de recurrencia de hipoglucemia, especialmente por sulfonilureas"}],notasEnfermeria:["La dextrosa 50% es vesicante: verificar permeabilidad del acceso IV antes de administrar. Si hay extravasaci\xf3n, suspender inmediatamente.","En hipoglucemia por sulfonilureas (glibenclamida, glimepirida), el paciente requiere observaci\xf3n prolongada (24-72h) por riesgo de recurrencia.","Monitorizar glucemia capilar cada 15-30 min durante la fase aguda, luego cada 1-2 horas durante la observaci\xf3n.","Documentar la causa probable de la hipoglucemia: omisi\xf3n de comida, error en dosis de insulina, ejercicio excesivo, interacci\xf3n farmacol\xf3gica.","Educar al paciente y familiares sobre reconocimiento de s\xedntomas y uso de glucag\xf3n antes del alta."]},{id:"proto_hiperpotasemia",nombre:"Hiperpotasemia",descripcion:"Protocolo de manejo de la hiperpotasemia severa (K+ >6.5 mEq/L o con cambios electrocardiogr\xe1ficos). La hiperpotasemia es una emergencia metab\xf3lica que puede causar arritmias letales. El tratamiento sigue tres principios: estabilizaci\xf3n de membrana card\xedaca, redistribuci\xf3n intracelular de potasio y eliminaci\xf3n corporal.",categoria:"metabolico",prioridad:"urgente",banderasRojas:["K+ >6.5 mEq/L o cualquier nivel con cambios en ECG","Cambios ECG: ondas T picudas, PR prolongado, QRS ancho, ondas sinusoidales","Debilidad muscular progresiva o par\xe1lisis fl\xe1cida","Paciente con insuficiencia renal y oliguria/anuria","Bradicardia o arritmias ventriculares en contexto de falla renal"],pasos:[{orden:1,tiempo:"0-2 min",accion:"ECG inmediato y estabilizaci\xf3n de membrana card\xedaca",detalles:"Realizar ECG de 12 derivaciones. Si hay cambios electrocardiogr\xe1ficos (ondas T picudas, ensanchamiento QRS, bradiarritmias), administrar calcio IV inmediatamente para estabilizar la membrana mioc\xe1rdica. El calcio NO reduce el potasio.",critico:!0,farmacos:[{nombre:"Gluconato de calcio 10%",dosis:"10-20 mL (1-2 ampollas) IV lento en 2-3 min. Puede repetir en 5 min si persisten cambios ECG",via:"IV"}]},{orden:2,tiempo:"2-10 min",accion:"Redistribuci\xf3n del potasio al espacio intracelular",detalles:"La insulina con glucosa es el m\xe9todo m\xe1s efectivo para la redistribuci\xf3n. El salbutamol nebulizado tiene efecto aditivo. Reducci\xf3n esperada: 0.5-1.5 mEq/L en 30-60 minutos.",critico:!0,farmacos:[{nombre:"Insulina regular + Dextrosa",dosis:"Insulina regular 10 UI IV + Dextrosa 50% 50 mL IV (25 g). Monitorizar glucemia cada 30 min por 4-6h",via:"IV"},{nombre:"Salbutamol",dosis:"10-20 mg nebulizado en 10 min (4-8 veces la dosis broncodilatadora habitual)",via:"Nebulizaci\xf3n"}]},{orden:3,tiempo:"5-15 min",accion:"Corregir acidosis metab\xf3lica si est\xe1 presente",detalles:"El bicarbonato de sodio solo es efectivo si hay acidosis metab\xf3lica concomitante (pH <7.2). No es primera l\xednea como monoterapia para hiperpotasemia. Desplaza potasio al espacio intracelular al corregir el pH.",farmacos:[{nombre:"Bicarbonato de sodio",dosis:"50 mEq IV en 5 min (si pH <7.2). No mezclar con calcio en la misma v\xeda.",via:"IV"}],decision:{pregunta:"\xbfHay acidosis metab\xf3lica (pH <7.2)?",si:"Administrar bicarbonato de sodio 50 mEq IV",no:"Omitir bicarbonato; continuar con medidas de eliminaci\xf3n (paso 4)"}},{orden:4,tiempo:"15-30 min",accion:"Eliminaci\xf3n corporal de potasio",detalles:"Furosemida si hay funci\xf3n renal residual. Sulfonato de poliestireno s\xf3dico (Kayexalate) como resina de intercambio cati\xf3nico (inicio de acci\xf3n lento: 1-4 horas). Si insuficiencia renal severa o refractariedad: hemodi\xe1lisis urgente.",farmacos:[{nombre:"Furosemida",dosis:"40-80 mg IV (mayor dosis si insuficiencia renal)",via:"IV"},{nombre:"Sulfonato de poliestireno s\xf3dico (Kayexalate)",dosis:"15-30 g VO con sorbitol al 20% o 30-50 g en enema de retenci\xf3n",via:"VO/Rectal"}]},{orden:5,tiempo:"30-60 min",accion:"Reevaluaci\xf3n y considerar hemodi\xe1lisis",detalles:"Control de K+ s\xe9rico cada 1-2 horas. ECG de control. Si K+ refractario a tratamiento m\xe9dico, oliguria/anuria, o cambios ECG persistentes: hemodi\xe1lisis urgente.",critico:!0,decision:{pregunta:"\xbfK+ sigue >6.5 mEq/L o persisten cambios ECG tras tratamiento?",si:"Solicitar hemodi\xe1lisis urgente. Repetir calcio IV si hay arritmias.",no:"Continuar monitoreo. Tratar causa subyacente. Control de K+ cada 2-4h."}}],resumenFarmacos:[{nombre:"Gluconato de calcio 10%",dosis:"10-20 mL IV en 2-3 min",via:"IV",indicacion:"Cardioprotecci\xf3n; estabiliza la membrana mioc\xe1rdica (no reduce K+)"},{nombre:"Insulina regular + Dextrosa 50%",dosis:"10 UI insulina + 25 g dextrosa IV",via:"IV",indicacion:"Redistribuci\xf3n intracelular de K+ (reduce 0.5-1.5 mEq/L en 30-60 min)"},{nombre:"Salbutamol (dosis alta)",dosis:"10-20 mg nebulizado en 10 min",via:"Nebulizaci\xf3n",indicacion:"Redistribuci\xf3n intracelular de K+ (efecto aditivo con insulina)"},{nombre:"Bicarbonato de sodio",dosis:"50 mEq IV",via:"IV",indicacion:"Solo si acidosis metab\xf3lica concomitante (pH <7.2)"},{nombre:"Furosemida",dosis:"40-80 mg IV",via:"IV",indicacion:"Eliminaci\xf3n renal de K+ (requiere funci\xf3n renal residual)"},{nombre:"Kayexalate",dosis:"15-30 g VO o 30-50 g rectal",via:"VO/Rectal",indicacion:"Resina de intercambio cati\xf3nico para eliminaci\xf3n gastrointestinal de K+"}],notasEnfermeria:["El gluconato de calcio IV debe administrarse lentamente (2-3 min); la infusi\xf3n r\xe1pida puede causar bradicardia severa o asistolia.","NUNCA mezclar calcio y bicarbonato de sodio en la misma v\xeda IV (precipitaci\xf3n de carbonato de calcio).","Monitorizar glucemia cada 30 min durante 4-6h tras la infusi\xf3n de insulina + dextrosa por riesgo de hipoglucemia tard\xeda.","El Kayexalate est\xe1 contraindicado en \xedleo paral\xedtico o post-operatorio intestinal por riesgo de necrosis col\xf3nica.","Monitorizaci\xf3n ECG continua; cualquier cambio en el ritmo card\xedaco debe reportarse inmediatamente."]},{id:"proto_sepsis",nombre:"Sepsis - Hour-1 Bundle",abreviatura:"SEP-1",descripcion:"Protocolo del paquete de la primera hora (Hour-1 Bundle) de la Surviving Sepsis Campaign para el manejo de la sepsis y el shock s\xe9ptico. Todos los elementos deben iniciarse dentro de la primera hora del reconocimiento de la sepsis.",categoria:"sepsis",prioridad:"critico",banderasRojas:["Sospecha de infecci\xf3n con \u22652 criterios SIRS o qSOFA \u22652","Hipotensi\xf3n persistente (PAS <90 mmHg o PAM <65 mmHg) tras cristaloides","Lactato s\xe9rico >2 mmol/L","Alteraci\xf3n aguda del estado mental en contexto de infecci\xf3n","Disfunci\xf3n org\xe1nica nueva: oliguria, coagulopat\xeda, hiperbilirrubinemia, hipoxemia"],pasos:[{orden:1,tiempo:"0-15 min",accion:"Medir lactato s\xe9rico",detalles:"Lactato s\xe9rico inmediato. Si lactato >2 mmol/L, repetir en 2-4 horas para evaluar aclaramiento. Lactato >4 mmol/L indica alto riesgo de mortalidad y necesidad de resucitaci\xf3n agresiva.",critico:!0},{orden:2,tiempo:"0-15 min",accion:"Obtener hemocultivos antes de antibi\xf3ticos",detalles:"Al menos 2 sets de hemocultivos (aerobio + anaerobio) de sitios diferentes ANTES de iniciar antibi\xf3ticos. No retrasar antibi\xf3ticos >45 min por cultivos. Obtener tambi\xe9n cultivos del foco sospechado.",critico:!0},{orden:3,tiempo:"0-60 min",accion:"Iniciar antibi\xf3ticos de amplio espectro IV",detalles:"Antibi\xf3ticos emp\xedricos de amplio espectro dentro de la PRIMERA HORA. Cada hora de retraso en antibi\xf3ticos aumenta la mortalidad un 7.6%. Cubrir pat\xf3genos m\xe1s probables seg\xfan foco sospechado. Desescalar cuando est\xe9n disponibles los cultivos.",critico:!0,farmacos:[{nombre:"Meropenem",dosis:"1 g IV cada 8h (o Piperacilina/Tazobactam 4.5 g IV cada 6h)",via:"IV"},{nombre:"Vancomicina",dosis:"25-30 mg/kg IV (dosis de carga) si sospecha de SAMR",via:"IV"}]},{orden:4,tiempo:"0-60 min",accion:"Resucitaci\xf3n con cristaloides",detalles:"Administrar 30 mL/kg de cristaloides IV si hay hipotensi\xf3n o lactato \u22654 mmol/L. Iniciar en la primera hora. Evaluar respuesta a volumen frecuentemente. Usar SSN 0.9% o Ringer Lactato.",critico:!0,farmacos:[{nombre:"SSN 0.9% o Ringer Lactato",dosis:"30 mL/kg IV en la primera hora (para 70 kg = ~2100 mL). Reevaluar tolerancia a volumen.",via:"IV"}]},{orden:5,tiempo:"60 min",accion:"Iniciar vasopresores si hipotensi\xf3n persistente",detalles:"Si PAM <65 mmHg a pesar de resucitaci\xf3n con cristaloides, iniciar norepinefrina como vasopresor de primera l\xednea. Objetivo PAM \u226565 mmHg. Preferir acceso venoso central, pero puede iniciarse por v\xeda perif\xe9rica temporalmente.",critico:!0,farmacos:[{nombre:"Norepinefrina",dosis:"0.1-0.5 mcg/kg/min IV en infusi\xf3n continua. Titular hasta PAM \u226565 mmHg (m\xe1x. 2-3 mcg/kg/min)",via:"IV"},{nombre:"Vasopresina (adyuvante)",dosis:"0.03-0.04 UI/min IV en infusi\xf3n continua (agregar si norepinefrina >0.25 mcg/kg/min)",via:"IV"}],decision:{pregunta:"\xbfPAM \u226565 mmHg con norepinefrina sola?",si:"Mantener infusi\xf3n y monitorizar. Reevaluar lactato cada 2-4h.",no:"Agregar vasopresina 0.03 UI/min. Si persiste refractario, considerar hidrocortisona 200 mg/d\xeda IV."}},{orden:6,tiempo:"2-6 horas",accion:"Reevaluaci\xf3n del estado hemodin\xe1mico y perfusi\xf3n",detalles:"Reevaluar respuesta a l\xedquidos (elevaci\xf3n pasiva de piernas, variaci\xf3n de presi\xf3n de pulso, ecocardiograf\xeda). Repetir lactato si inicial >2 mmol/L. Monitorizar diuresis (objetivo \u22650.5 mL/kg/h). Si shock refractario: considerar hidrocortisona.",farmacos:[{nombre:"Hidrocortisona",dosis:"200 mg/d\xeda IV (50 mg IV cada 6h) en shock refractario a vasopresores",via:"IV"}]},{orden:7,tiempo:"Continuo",accion:"Control de foco infeccioso",detalles:"Identificar y controlar el foco infeccioso lo antes posible: drenaje de abscesos, desbridamiento de tejidos necr\xf3ticos, retiro de dispositivos infectados, cirug\xeda si es necesario. El control de foco es tan importante como los antibi\xf3ticos.",critico:!0}],resumenFarmacos:[{nombre:"Meropenem",dosis:"1 g IV cada 8h",via:"IV",indicacion:"Antibi\xf3tico de amplio espectro emp\xedrico en sepsis"},{nombre:"Piperacilina/Tazobactam",dosis:"4.5 g IV cada 6h",via:"IV",indicacion:"Alternativa a carbapen\xe9micos como cobertura de amplio espectro"},{nombre:"Vancomicina",dosis:"25-30 mg/kg IV (carga)",via:"IV",indicacion:"Cobertura contra SAMR si hay factores de riesgo"},{nombre:"SSN 0.9% / Ringer Lactato",dosis:"30 mL/kg IV en la primera hora",via:"IV",indicacion:"Resucitaci\xf3n con cristaloides en sepsis con hipoperfusi\xf3n"},{nombre:"Norepinefrina",dosis:"0.1-2 mcg/kg/min IV en infusi\xf3n",via:"IV",indicacion:"Vasopresor de primera l\xednea en shock s\xe9ptico"},{nombre:"Vasopresina",dosis:"0.03-0.04 UI/min IV",via:"IV",indicacion:"Vasopresor adyuvante si norepinefrina >0.25 mcg/kg/min"},{nombre:"Hidrocortisona",dosis:"200 mg/d\xeda IV (50 mg cada 6h)",via:"IV",indicacion:"Shock s\xe9ptico refractario a vasopresores"}],notasEnfermeria:["El paquete de la primera hora (Hour-1 Bundle) debe completarse en los primeros 60 minutos desde la identificaci\xf3n de la sepsis.","Hemocultivos SIEMPRE antes de antibi\xf3ticos, pero NO retrasar antibi\xf3ticos por m\xe1s de 45 minutos esperando cultivos.","La norepinefrina puede iniciarse por v\xeda perif\xe9rica transitoriamente mientras se obtiene acceso central; vigilar extravasaci\xf3n.","Monitorizar diuresis horaria con sonda vesical; objetivo \u22650.5 mL/kg/h como indicador de perfusi\xf3n renal.","Registrar balance h\xeddrico estricto; la sobrecarga de l\xedquidos puede ser perjudicial tras la resucitaci\xf3n inicial."]},{id:"proto_eap",nombre:"EAP - Edema Agudo de Pulm\xf3n",abreviatura:"EAP",descripcion:"Protocolo de manejo del edema agudo de pulm\xf3n cardiog\xe9nico, una emergencia cardiovascular causada por aumento de la presi\xf3n capilar pulmonar secundaria a falla ventricular izquierda aguda.",categoria:"cardiaco",prioridad:"critico",banderasRojas:["Disnea s\xfabita severa con ortopnea y crepitantes bilaterales","Esputo rosado espumoso","Desaturaci\xf3n r\xe1pida (SpO2 <90%) con signos de trabajo respiratorio","Hipotensi\xf3n con signos de bajo gasto card\xedaco (shock cardiog\xe9nico)","Taquicardia, diaforesis y ansiedad intensa con disnea"],pasos:[{orden:1,tiempo:"0-2 min",accion:"Posici\xf3n y oxigenoterapia",detalles:"Sentar al paciente con piernas colgando (reduce retorno venoso). O2 al 100% con mascarilla de alto flujo. Si SpO2 <90% o trabajo respiratorio severo: CPAP/BiPAP (CPAP 5-10 cmH2O). Preparar intubaci\xf3n si falla la VNI.",critico:!0},{orden:2,tiempo:"2-5 min",accion:"Diur\xe9tico de asa IV",detalles:"Furosemida IV para reducir precarga mediante diuresis y venodilataci\xf3n directa. Inicio de acci\xf3n: 5 min (efecto venodilatador) y 15-30 min (efecto diur\xe9tico). Si el paciente toma furosemida cr\xf3nica, administrar al menos el doble de su dosis habitual.",critico:!0,farmacos:[{nombre:"Furosemida",dosis:"40-80 mg IV en bolo (o 2.5 veces la dosis oral habitual si ya la toma). Puede repetirse en 20 min si no hay respuesta.",via:"IV"}]},{orden:3,tiempo:"2-5 min",accion:"Nitroglicerina para reducir precarga y poscarga",detalles:"La nitroglicerina es clave en el manejo del EAP por su efecto venodilatador y vasodilatador coronario. NO administrar si PAS <90 mmHg. Titular seg\xfan PA y respuesta cl\xednica.",critico:!0,farmacos:[{nombre:"Nitroglicerina",dosis:"0.4 mg SL cada 5 min (hasta 3 dosis), luego infusi\xf3n IV 5-200 mcg/min (titular seg\xfan PA)",via:"SL/IV"}],decision:{pregunta:"\xbfPAS >90 mmHg?",si:"Administrar nitroglicerina SL y considerar infusi\xf3n IV. Titular para mantener PAS >90 mmHg.",no:"NO administrar vasodilatadores. Considerar soporte inotr\xf3pico (dobutamina) o vasopresores."}},{orden:4,tiempo:"5-10 min",accion:"Considerar morfina en casos seleccionados",detalles:"Morfina reduce la ansiedad, el trabajo respiratorio y la precarga. Uso controvertido actualmente; reservar para ansiedad severa refractaria. Precauci\xf3n: depresi\xf3n respiratoria, hipotensi\xf3n y n\xe1useas.",farmacos:[{nombre:"Morfina",dosis:"2-4 mg IV lento. Puede repetir cada 5-15 min (monitorizar FR y PA)",via:"IV"}]},{orden:5,tiempo:"10-30 min",accion:"Reevaluar y manejo seg\xfan PA",detalles:"Si PAS <90 mmHg: shock cardiog\xe9nico, considerar inotr\xf3picos y soporte mec\xe1nico. Si PAS 90-140 mmHg: continuar manejo est\xe1ndar. Si PAS >140 mmHg: priorizar vasodilatadores.",critico:!0,farmacos:[{nombre:"Dobutamina (si bajo gasto)",dosis:"2-20 mcg/kg/min IV en infusi\xf3n continua",via:"IV"},{nombre:"Norepinefrina (si shock)",dosis:"0.1-0.5 mcg/kg/min IV en infusi\xf3n continua",via:"IV"}]},{orden:6,tiempo:"30-60 min",accion:"Identificar y tratar causa precipitante",detalles:"ECG: descartar SCA/arritmias. Ecocardiograma urgente. Anal\xedtica: troponina, BNP/NT-proBNP, funci\xf3n renal. Causas comunes: SCA, crisis hipertensiva, arritmias, valvulopat\xeda aguda, incumplimiento terap\xe9utico.",critico:!1}],resumenFarmacos:[{nombre:"Furosemida",dosis:"40-80 mg IV en bolo",via:"IV",indicacion:"Diur\xe9tico de asa para reducir sobrecarga de volumen y precarga"},{nombre:"Nitroglicerina",dosis:"0.4 mg SL o 5-200 mcg/min IV",via:"SL/IV",indicacion:"Vasodilatador para reducir precarga y poscarga (requiere PAS >90)"},{nombre:"Morfina",dosis:"2-4 mg IV cada 5-15 min",via:"IV",indicacion:"Ansiol\xedtico y reductor de precarga en casos seleccionados"},{nombre:"Dobutamina",dosis:"2-20 mcg/kg/min IV",via:"IV",indicacion:"Soporte inotr\xf3pico en EAP con bajo gasto card\xedaco"},{nombre:"Norepinefrina",dosis:"0.1-0.5 mcg/kg/min IV",via:"IV",indicacion:"Vasopresor en EAP con shock cardiog\xe9nico"}],notasEnfermeria:["Sentar al paciente con piernas colgando para reducir el retorno venoso y mejorar la mec\xe1nica respiratoria.","Monitorizar diuresis horaria; la respuesta a furosemida se espera en 15-30 minutos. Reportar si diuresis <0.5 mL/kg/h.","CPAP/BiPAP es de primera l\xednea en VNI; reduce la necesidad de intubaci\xf3n. Asegurar buen sellado de mascarilla.","Vigilar signos de deterioro: esputo rosado espumoso en aumento, desaturaci\xf3n progresiva, confusi\xf3n, bradicardia.","Balance h\xeddrico negativo es el objetivo; registrar ingresos y egresos de forma estricta."]},{id:"proto_estado_asmatico",nombre:"Estado Asm\xe1tico - Crisis Asm\xe1tica Severa",descripcion:"Protocolo de manejo del estado asm\xe1tico (crisis asm\xe1tica severa o casi fatal), definido como una exacerbaci\xf3n de asma que no responde al tratamiento broncodilatador inicial y amenaza la vida del paciente.",categoria:"respiratorio",prioridad:"urgente",banderasRojas:["Dificultad para hablar (frases entrecortadas o palabras sueltas)","Uso de m\xfasculos accesorios con tiraje intercostal y supraclavicular","SpO2 <92% o PEF <25% del predicho","T\xf3rax silente (disminuci\xf3n de sibilancias = obstrucci\xf3n severa)","Alteraci\xf3n del nivel de conciencia, agotamiento respiratorio, cianosis"],pasos:[{orden:1,tiempo:"0-5 min",accion:"Ox\xedgeno y broncodilatador de acci\xf3n corta",detalles:"O2 para mantener SpO2 93-95%. Salbutamol nebulizado continuo o MDI con espaciador (4-8 puffs cada 20 min). En crisis severa, preferir nebulizaci\xf3n continua.",critico:!0,farmacos:[{nombre:"Salbutamol",dosis:"2.5-5 mg nebulizado cada 20 min x 3 dosis, luego cada 1-4h. O nebulizaci\xf3n continua 10-15 mg/h. MDI: 4-8 puffs cada 20 min",via:"Nebulizaci\xf3n/MDI"},{nombre:"Ipratropio",dosis:"0.5 mg nebulizado junto con salbutamol cada 20 min x 3 dosis",via:"Nebulizaci\xf3n"}]},{orden:2,tiempo:"5-15 min",accion:"Corticosteroide sist\xe9mico",detalles:"Administrar corticosteroide sist\xe9mico lo antes posible. Reduce la inflamaci\xf3n de la v\xeda a\xe9rea. El beneficio m\xe1ximo se observa a las 4-6 horas, por lo que la administraci\xf3n temprana es crucial.",critico:!0,farmacos:[{nombre:"Metilprednisolona",dosis:"60-125 mg IV. Pedi\xe1trico: 1-2 mg/kg IV (m\xe1x. 60 mg)",via:"IV"},{nombre:"Hidrocortisona (alternativa)",dosis:"200 mg IV",via:"IV"}]},{orden:3,tiempo:"15-30 min",accion:"Evaluar respuesta y considerar sulfato de magnesio",detalles:"Si no hay mejor\xeda con broncodilatadores + corticosteroide, administrar MgSO4 IV. El magnesio tiene efecto broncodilatador por relajaci\xf3n del m\xfasculo liso bronquial.",farmacos:[{nombre:"Sulfato de magnesio (MgSO4)",dosis:"2 g IV en 20 min (diluido en 100 mL de SSN). Pedi\xe1trico: 25-75 mg/kg IV (m\xe1x. 2 g)",via:"IV"}],decision:{pregunta:"\xbfHay mejor\xeda con broncodilatadores y corticosteroide?",si:"Continuar salbutamol cada 1-4h, espaciar seg\xfan mejor\xeda. Mantener corticosteroide.",no:"Administrar MgSO4 IV. Evaluar necesidad de tratamientos de rescate (paso 4)."}},{orden:4,tiempo:"30-60 min",accion:"Tratamientos de rescate en crisis refractaria",detalles:"Si persiste sin mejor\xeda: considerar epinefrina IM/SC, aminofilina IV (uso controvertido), o ketamina. Preparar intubaci\xf3n si hay signos de fallo respiratorio inminente.",critico:!0,farmacos:[{nombre:"Epinefrina",dosis:"0.3-0.5 mg IM/SC (soluci\xf3n 1:1000) cada 20 min x 3 dosis",via:"IM/SC"},{nombre:"Aminofilina (uso controvertido)",dosis:"Carga: 5-6 mg/kg IV en 20 min (si no toma teofilina). Mantenimiento: 0.5-0.9 mg/kg/h",via:"IV"}]},{orden:5,tiempo:"Si deterioro",accion:"Intubaci\xf3n y ventilaci\xf3n mec\xe1nica",detalles:"Indicaciones: apnea, alteraci\xf3n de conciencia, agotamiento respiratorio, hipoxemia refractaria (SpO2 <90% con O2 alto flujo), hipercapnia progresiva. Usar ketamina como agente inductor (broncodilatador). Ventilaci\xf3n protectora con tiempos espiratorios prolongados.",critico:!0,farmacos:[{nombre:"Ketamina (inducci\xf3n)",dosis:"1-2 mg/kg IV para intubaci\xf3n",via:"IV"}]}],resumenFarmacos:[{nombre:"Salbutamol",dosis:"2.5-5 mg nebulizado cada 20 min o nebulizaci\xf3n continua 10-15 mg/h",via:"Nebulizaci\xf3n",indicacion:"Broncodilatador beta-2 agonista de acci\xf3n corta, primera l\xednea"},{nombre:"Ipratropio",dosis:"0.5 mg nebulizado cada 20 min x 3 dosis",via:"Nebulizaci\xf3n",indicacion:"Anticolin\xe9rgico broncodilatador, sin\xe9rgico con salbutamol"},{nombre:"Metilprednisolona",dosis:"60-125 mg IV",via:"IV",indicacion:"Corticosteroide sist\xe9mico antiinflamatorio para crisis asm\xe1tica"},{nombre:"Sulfato de magnesio",dosis:"2 g IV en 20 min",via:"IV",indicacion:"Broncodilatador por relajaci\xf3n del m\xfasculo liso; en crisis refractaria"},{nombre:"Epinefrina",dosis:"0.3-0.5 mg IM/SC cada 20 min",via:"IM/SC",indicacion:"Broncodilatador de rescate en crisis severa refractaria"},{nombre:"Ketamina",dosis:"1-2 mg/kg IV",via:"IV",indicacion:"Agente de inducci\xf3n con propiedades broncodilatadoras para intubaci\xf3n"}],notasEnfermeria:["El t\xf3rax silente (ausencia de sibilancias) NO indica mejor\xeda; significa obstrucci\xf3n tan severa que no hay flujo a\xe9reo suficiente para generar sibilancias.","Monitorizar PEF antes y despu\xe9s de cada tratamiento para objetivar respuesta. Documentar la mejor cifra obtenida.","La nebulizaci\xf3n continua de salbutamol requiere monitorizaci\xf3n de FC y K+ (riesgo de taquicardia e hipopotasemia).","Preparar equipo de intubaci\xf3n desde el inicio en toda crisis severa; la descompensaci\xf3n puede ser r\xe1pida.","Evitar sedaci\xf3n excesiva; los sedantes pueden suprimir el est\xedmulo respiratorio y precipitar paro respiratorio."]},{id:"proto_hemorragia_masiva",nombre:"Hemorragia Masiva",descripcion:"Protocolo de manejo de la hemorragia masiva, definida como la p\xe9rdida de un volumen sangu\xedneo completo en 24 horas, 50% en 3 horas, o sangrado >150 mL/min. Incluye activaci\xf3n del protocolo de transfusi\xf3n masiva.",categoria:"trauma",prioridad:"critico",banderasRojas:["Taquicardia >120 lpm con hipotensi\xf3n (PAS <90 mmHg)","Sangrado visible activo no controlable con presi\xf3n directa","\xcdndice de choque (FC/PAS) >1.0","Alteraci\xf3n del nivel de conciencia con palidez y diaforesis","Necesidad de >4 concentrados de gl\xf3bulos rojos en 1 hora"],pasos:[{orden:1,tiempo:"0-3 min",accion:"Control del sangrado y acceso vascular",detalles:"Presi\xf3n directa sobre herida externa. Torniquete si extremidad con hemorragia no controlable. Dos accesos venosos de gran calibre (14-16G) o acceso intra\xf3seo. Muestra de sangre para grupo, Rh, pruebas cruzadas, coagulaci\xf3n, hemograma y gasometr\xeda.",critico:!0},{orden:2,tiempo:"0-10 min",accion:"Administrar \xe1cido tranex\xe1mico",detalles:"Administrar dentro de las primeras 3 horas del inicio de la hemorragia. Reduce la mortalidad por hemorragia en un 20-30%. NO administrar despu\xe9s de 3 horas (puede ser perjudicial).",critico:!0,farmacos:[{nombre:"\xc1cido tranex\xe1mico",dosis:"1 g IV en 10 min (bolo inicial), luego 1 g IV en infusi\xf3n en 8 horas",via:"IV"}]},{orden:3,tiempo:"5-15 min",accion:"Activar protocolo de transfusi\xf3n masiva",detalles:"Activar PTM cuando se cumplen criterios. Relaci\xf3n de hemoderivados 1:1:1 (GR:PFC:plaquetas). Solicitar sangre tipo O Rh negativo si no hay tiempo para pruebas cruzadas. Usar calentador de hemoderivados.",critico:!0,farmacos:[{nombre:"Concentrados de Gl\xf3bulos Rojos",dosis:"Tipo O Rh- inicialmente, luego isogrupo. Administrar con calentador.",via:"IV"},{nombre:"Plasma Fresco Congelado",dosis:"10-15 mL/kg IV. Relaci\xf3n 1:1 con GR en protocolo de transfusi\xf3n masiva.",via:"IV"},{nombre:"Plaquetas",dosis:"1 concentrado plaquetario por cada 5-6 unidades de GR. Objetivo plaquetas >50,000/\u03bcL.",via:"IV"}]},{orden:4,tiempo:"15-30 min",accion:"Resucitaci\xf3n inicial con cristaloides y monitoreo",detalles:"Cristaloides como puente hasta disponibilidad de hemoderivados. Evitar resucitaci\xf3n excesiva con cristaloides (diluci\xf3n de factores de coagulaci\xf3n). Objetivo de PAS: 80-90 mmHg (hipotensi\xf3n permisiva) excepto en TEC.",farmacos:[{nombre:"Ringer Lactato",dosis:"500-1000 mL IV en bolo r\xe1pido (calentado a 37-40\xb0C si es posible)",via:"IV"}]},{orden:5,tiempo:"30-60 min",accion:"Corregir coagulopat\xeda y monitoreo de laboratorio",detalles:"Obtener gasometr\xeda, fibrin\xf3geno, TP/TTPa, plaquetas cada 30-60 min. Corregir acidosis, hipotermia y coagulopat\xeda (tr\xedada letal del trauma). Administrar fibrin\xf3geno si <150 mg/dL.",critico:!0,farmacos:[{nombre:"Fibrin\xf3geno (crioprecipitado)",dosis:"Crioprecipitado: 10 unidades IV si fibrin\xf3geno <150 mg/dL. Objetivo >200 mg/dL.",via:"IV"},{nombre:"Calcio gluconato",dosis:"1-2 g IV cada 30 min seg\xfan Ca++ ionizado (mantener >1.1 mmol/L). La hipocalcemia por citrato de transfusiones afecta la coagulaci\xf3n.",via:"IV"}]},{orden:6,tiempo:"Continuo",accion:"Control quir\xfargico definitivo",detalles:"Cirug\xeda de control de da\xf1os si es necesario: empaquetamiento, clampaje, reparaci\xf3n vascular. Angioembolizaci\xf3n en hemorragias no quir\xfargicas. El control del foco hemorr\xe1gico es la prioridad definitiva.",critico:!0}],resumenFarmacos:[{nombre:"\xc1cido tranex\xe1mico",dosis:"1 g IV en 10 min + 1 g IV en 8h",via:"IV",indicacion:"Antifibrinol\xedtico; administrar en las primeras 3 horas de la hemorragia"},{nombre:"Concentrados de Gl\xf3bulos Rojos",dosis:"Seg\xfan necesidad, relaci\xf3n 1:1:1",via:"IV",indicacion:"Restaurar capacidad de transporte de ox\xedgeno"},{nombre:"Plasma Fresco Congelado",dosis:"10-15 mL/kg IV",via:"IV",indicacion:"Reponer factores de coagulaci\xf3n en transfusi\xf3n masiva"},{nombre:"Plaquetas",dosis:"1 unidad por cada 5-6 unidades de GR",via:"IV",indicacion:"Mantener plaquetas >50,000/\u03bcL durante hemorragia activa"},{nombre:"Fibrin\xf3geno/Crioprecipitado",dosis:"10 unidades IV si fibrin\xf3geno <150 mg/dL",via:"IV",indicacion:"Reponer fibrin\xf3geno consumido en coagulopat\xeda"},{nombre:"Calcio gluconato",dosis:"1-2 g IV cada 30 min seg\xfan niveles",via:"IV",indicacion:"Corregir hipocalcemia por citrato de hemoderivados; esencial para coagulaci\xf3n"}],notasEnfermeria:["Aplicar el protocolo de transfusi\xf3n masiva: relaci\xf3n 1:1:1 de GR:PFC:plaquetas para prevenir la coagulopat\xeda dilucional.","Calentar TODOS los hemoderivados y cristaloides; la hipotermia agrava la coagulopat\xeda y debe prevenirse activamente.","Monitorizar calcio ionizado cada 30 min durante la transfusi\xf3n masiva; el citrato de los hemoderivados quela el calcio.","El \xe1cido tranex\xe1mico debe administrarse en los primeros 180 minutos del inicio de la hemorragia; pasadas las 3 horas puede ser perjudicial.","Documentar cada unidad de hemoderivado administrada con hora exacta. Comunicar al m\xe9dico si el sangrado supera la reposici\xf3n."]},{id:"proto_hipertermia_maligna",nombre:"Hipertermia Maligna",descripcion:"Protocolo de manejo de la hipertermia maligna, una emergencia anest\xe9sica farmacogen\xe9tica potencialmente mortal desencadenada por anest\xe9sicos halogenados o succinilcolina en individuos susceptibles. La mortalidad sin tratamiento supera el 70%.",categoria:"otro",prioridad:"critico",banderasRojas:["Elevaci\xf3n inexplicable de ETCO2 y taquicardia durante anestesia general","Rigidez muscular generalizada, especialmente trismus al administrar succinilcolina","Temperatura corporal en ascenso r\xe1pido (>1\xb0C cada 5 min)","Acidosis mixta (respiratoria y metab\xf3lica) con hiperpotasemia","Arritmias ventriculares con rabdomi\xf3lisis (elevaci\xf3n de CK, mioglobinuria)"],pasos:[{orden:1,tiempo:"0-2 min",accion:"Suspender agente desencadenante y pedir ayuda",detalles:"Suspender INMEDIATAMENTE todos los anest\xe9sicos halogenados y succinilcolina. Avisar al equipo. Hiperventilar con O2 al 100% a flujos altos (\u226510 L/min). Cambiar circuito y absorbedor de CO2 si es posible.",critico:!0},{orden:2,tiempo:"2-5 min",accion:"Administrar Dantroleno IV",detalles:"Dantroleno es el \xdaNICO ant\xeddoto espec\xedfico. Cada vial de 20 mg se reconstituye con 60 mL de agua est\xe9ril (NO usar SSN). La reconstituci\xf3n es laboriosa; se necesitan m\xfaltiples personas. Administrar lo m\xe1s r\xe1pido posible.",critico:!0,farmacos:[{nombre:"Dantroleno",dosis:"2.5 mg/kg IV en bolo r\xe1pido. Repetir cada 5-10 min hasta controlar s\xedntomas (m\xe1x. acumulado ~10 mg/kg, sin l\xedmite real si necesario)",via:"IV"}]},{orden:3,tiempo:"5-15 min",accion:"Enfriamiento activo",detalles:"Iniciar enfriamiento agresivo si temperatura >39\xb0C. Objetivo: temperatura central <38.5\xb0C. Detener enfriamiento al alcanzar 38\xb0C para evitar hipotermia reactiva.",critico:!0,farmacos:[{nombre:"SSN 0.9% fr\xedo",dosis:"Lavado g\xe1strico, vesical y rectal con SSN fr\xeda. Infusi\xf3n IV de SSN fr\xedo (4\xb0C) 15 mL/kg.",via:"IV/Lavados"}]},{orden:4,tiempo:"5-15 min",accion:"Tratar hiperpotasemia y arritmias",detalles:"La rabdomi\xf3lisis libera potasio masivamente. Tratar hiperpotasemia con protocolo est\xe1ndar. Tratar arritmias ventriculares con amiodarona. EVITAR bloqueantes de canales de calcio (interacci\xf3n letal con dantroleno).",critico:!0,farmacos:[{nombre:"Insulina regular + Dextrosa",dosis:"Insulina 10 UI IV + Dextrosa 50% 50 mL IV",via:"IV"},{nombre:"Gluconato de calcio 10%",dosis:"10-20 mL IV en 2-3 min (para hiperpotasemia con cambios ECG)",via:"IV"},{nombre:"Bicarbonato de sodio",dosis:"1-2 mEq/kg IV si acidosis metab\xf3lica severa (pH <7.2)",via:"IV"}]},{orden:5,tiempo:"Continuo",accion:"Protecci\xf3n renal y monitoreo",detalles:"Forzar diuresis con l\xedquidos IV y furosemida para prevenir fallo renal por mioglobinuria. Objetivo: diuresis >2 mL/kg/h. Monitorizar CK, mioglobina, K+, Ca++, gasometr\xeda y coagulaci\xf3n seriados. Mantener dantroleno cada 4-6h por 24-48h.",critico:!0,farmacos:[{nombre:"Furosemida",dosis:"40-80 mg IV (si diuresis inadecuada)",via:"IV"},{nombre:"Dantroleno (mantenimiento)",dosis:"1 mg/kg IV cada 4-6h durante 24-48h post-crisis",via:"IV"}]}],resumenFarmacos:[{nombre:"Dantroleno",dosis:"2.5 mg/kg IV bolo, repetir cada 5-10 min. Mantenimiento: 1 mg/kg IV cada 4-6h x 24-48h",via:"IV",indicacion:"Ant\xeddoto espec\xedfico; relajante muscular de acci\xf3n directa que inhibe la liberaci\xf3n de calcio del ret\xedculo sarcopl\xe1smico"},{nombre:"Insulina regular + Dextrosa 50%",dosis:"10 UI insulina + 25 g dextrosa IV",via:"IV",indicacion:"Tratamiento de hiperpotasemia asociada a rabdomi\xf3lisis"},{nombre:"Gluconato de calcio 10%",dosis:"10-20 mL IV",via:"IV",indicacion:"Estabilizaci\xf3n de membrana card\xedaca en hiperpotasemia"},{nombre:"Bicarbonato de sodio",dosis:"1-2 mEq/kg IV",via:"IV",indicacion:"Correcci\xf3n de acidosis metab\xf3lica severa"},{nombre:"Furosemida",dosis:"40-80 mg IV",via:"IV",indicacion:"Forzar diuresis para protecci\xf3n renal ante mioglobinuria"}],notasEnfermeria:["NUNCA administrar bloqueantes de canales de calcio (verapamilo, diltiazem) junto con dantroleno; la combinaci\xf3n puede causar colapso cardiovascular fatal.","La reconstituci\xf3n del dantroleno es laboriosa (cada vial de 20 mg requiere 60 mL de agua est\xe9ril); asignar personal exclusivo para esta tarea.","Conocer la ubicaci\xf3n del kit de hipertermia maligna en el \xe1rea quir\xfargica. Verificar stock de dantroleno peri\xf3dicamente (m\xednimo 36 viales).","Monitorizar temperatura central (esof\xe1gica, rectal o vesical); la axilar es inexacta en esta emergencia.","Asesorar a la familia sobre la naturaleza gen\xe9tica de la condici\xf3n y la necesidad de estudio (test de contractura in vitro) para familiares de primer grado."]},{id:"proto_cad",nombre:"CAD - Cetoacidosis Diab\xe9tica",abreviatura:"CAD",descripcion:"Protocolo de manejo de la cetoacidosis diab\xe9tica, una complicaci\xf3n aguda grave de la diabetes mellitus caracterizada por hiperglucemia, cetonemia, acidosis metab\xf3lica y deshidrataci\xf3n. Es m\xe1s frecuente en DM tipo 1 pero puede ocurrir en DM tipo 2.",categoria:"metabolico",prioridad:"urgente",banderasRojas:["Glucemia >250 mg/dL con cetonuria/cetonemia y pH <7.3","Respiraci\xf3n de Kussmaul (r\xe1pida y profunda) con aliento cet\xf3nico","Deshidrataci\xf3n severa con taquicardia e hipotensi\xf3n","Dolor abdominal difuso con n\xe1useas y v\xf3mitos","Alteraci\xf3n del nivel de conciencia (obnubilaci\xf3n, coma) con pH <7.0"],pasos:[{orden:1,tiempo:"0-15 min",accion:"Evaluaci\xf3n inicial y estudios de laboratorio",detalles:"Glucemia, gasometr\xeda arterial, electrolitos (Na+, K+, Cl-, Mg++), cetonas en sangre/orina, osmolaridad, funci\xf3n renal, hemograma, ECG. Calcular anion gap: Na - (Cl + HCO3); valor normal 12\xb14. CAD: anion gap >12. Clasificar severidad seg\xfan pH.",critico:!0,decision:{pregunta:"\xbfK+ s\xe9rico >3.3 mEq/L?",si:"Puede iniciarse insulina junto con reposici\xf3n de K+ (paso 3)",no:"NO iniciar insulina hasta corregir K+ >3.3 mEq/L (riesgo de arritmias letales)"}},{orden:2,tiempo:"0-30 min",accion:"Resucitaci\xf3n con l\xedquidos IV",detalles:"La hidrataci\xf3n es la primera prioridad. D\xe9ficit t\xedpico: 5-7 litros. SSN 0.9% en la primera hora. Despu\xe9s, ajustar seg\xfan Na+ corregido. Cuando glucemia <250 mg/dL, cambiar a dextrosa 5% + SSN 0.45% para prevenir hipoglucemia.",critico:!0,farmacos:[{nombre:"SSN 0.9%",dosis:"1000-1500 mL IV en la primera hora. Luego 250-500 mL/h (ajustar seg\xfan estado hemodin\xe1mico).",via:"IV"},{nombre:"Dextrosa 5% + SSN 0.45%",dosis:"150-250 mL/h IV cuando glucemia <250 mg/dL (para mantener glucemia 150-200 mg/dL mientras se resuelve la cetosis)",via:"IV"}]},{orden:3,tiempo:"15-60 min",accion:"Insulina regular en infusi\xf3n continua",detalles:"Iniciar SOLO si K+ >3.3 mEq/L. Objetivo: reducir glucemia 50-75 mg/dL por hora. Si la glucemia baja m\xe1s r\xe1pido, reducir dosis o agregar dextrosa. NO suspender insulina hasta que se resuelva la cetosis (pH >7.3, HCO3 >15, anion gap <12).",critico:!0,farmacos:[{nombre:"Insulina regular",dosis:"Bolo: 0.1 UI/kg IV, luego infusi\xf3n: 0.1 UI/kg/h IV. Alternativa sin bolo: 0.14 UI/kg/h IV",via:"IV"}]},{orden:4,tiempo:"30-60 min",accion:"Reposici\xf3n de potasio",detalles:"El K+ total corporal est\xe1 deplecionado aunque el nivel s\xe9rico pueda estar normal o elevado (por acidosis). La insulina desplaza K+ al intracelular, pudiendo causar hipopotasemia peligrosa. Reposici\xf3n seg\xfan niveles.",critico:!0,farmacos:[{nombre:"Cloruro de potasio (KCl)",dosis:"K+ <3.3: 20-40 mEq/h IV (NO iniciar insulina). K+ 3.3-5.3: 20-30 mEq por cada litro de SSN. K+ >5.3: no reponer, control en 2h.",via:"IV"}]},{orden:5,tiempo:"Cada 1-2 horas",accion:"Monitoreo seriado y ajustes",detalles:"Glucemia capilar cada hora. Electrolitos y gasometr\xeda cada 2-4 horas. Ajustar velocidad de insulina para descenso de glucemia de 50-75 mg/dL/h. Cuando glucemia <250: reducir insulina a 0.02-0.05 UI/kg/h y agregar dextrosa.",critico:!0},{orden:6,tiempo:"Resoluci\xf3n",accion:"Criterios de resoluci\xf3n y transici\xf3n a insulina SC",detalles:"Criterios de resoluci\xf3n de CAD: pH >7.3, HCO3 >15 mEq/L, anion gap <12, paciente tolerando VO. Administrar insulina SC 1-2 horas ANTES de suspender la infusi\xf3n IV para evitar rebote de hiperglucemia y cetosis.",farmacos:[{nombre:"Insulina glargina o NPH",dosis:"Administrar dosis SC basal 1-2h antes de suspender infusi\xf3n IV. Calcular seg\xfan requerimientos previos del paciente.",via:"SC"}]}],resumenFarmacos:[{nombre:"SSN 0.9%",dosis:"1000-1500 mL IV primera hora, luego 250-500 mL/h",via:"IV",indicacion:"Resucitaci\xf3n h\xeddrica; corrige deshidrataci\xf3n y mejora perfusi\xf3n renal"},{nombre:"Insulina regular (infusi\xf3n)",dosis:"0.1 UI/kg/h IV (con o sin bolo de 0.1 UI/kg)",via:"IV",indicacion:"Suprime cetog\xe9nesis y corrige hiperglucemia"},{nombre:"Cloruro de potasio (KCl)",dosis:"20-40 mEq/h IV seg\xfan niveles de K+",via:"IV",indicacion:"Reposici\xf3n de K+ deplecionado; prevenir hipopotasemia por insulina"},{nombre:"Dextrosa 5%",dosis:"Agregar cuando glucemia <250 mg/dL (150-250 mL/h)",via:"IV",indicacion:"Prevenir hipoglucemia mientras se mantiene insulina para resolver cetosis"},{nombre:"Bicarbonato de sodio",dosis:"100 mEq en 400 mL de agua + 20 mEq KCl, a pasar en 2h (solo si pH <6.9)",via:"IV",indicacion:"Solo en acidosis severa (pH <6.9); uso controvertido"}],notasEnfermeria:["NUNCA iniciar insulina si K+ <3.3 mEq/L; la insulina desplaza K+ al intracelular y puede causar arritmias ventriculares fatales.","La resoluci\xf3n de la CAD se define por pH, bicarbonato y anion gap, NO por la glucemia. La insulina se mantiene hasta que se resuelva la cetosis.","Monitorizar glucemia capilar cada hora y electrolitos cada 2-4h. Vigilar signos de hipopotasemia: debilidad, calambres, cambios ECG.","Administrar insulina SC basal 1-2h ANTES de suspender la infusi\xf3n IV para evitar el efecto rebote.","Investigar y tratar el factor precipitante: infecci\xf3n (m\xe1s com\xfan), incumplimiento terap\xe9utico, debut diab\xe9tico, IAM, pancreatitis."]},{id:"proto_eclampsia",nombre:"Eclampsia / Preeclampsia Severa",abreviatura:"PE/E",descripcion:"Protocolo de manejo de la emergencia hipertensiva en el embarazo. La preeclampsia severa (PA \u2265160/110 con proteinuria y/o da\xf1o org\xe1nico) puede progresar a eclampsia (convulsiones) y s\xedndrome HELLP. Emergencia obst\xe9trica que amenaza la vida materna y fetal.",categoria:"obstetrico",prioridad:"critico",banderasRojas:["PA sist\xf3lica \u2265160 mmHg o diast\xf3lica \u2265110 mmHg persistente","Convulsiones t\xf3nico-cl\xf3nicas (eclampsia)","Cefalea intensa refractaria a analgesia","Alteraciones visuales: escotomas, visi\xf3n borrosa, amaurosis","Dolor epig\xe1strico o en hipocondrio derecho (distensi\xf3n hep\xe1tica)","Oliguria <500 mL/24h","Edema pulmonar agudo","Plaquetas <100.000/\xb5L o LDH elevada (HELLP)"],pasos:[{orden:1,tiempo:"0-5 min",accion:"Estabilizaci\xf3n inmediata y protecci\xf3n de la v\xeda a\xe9rea",detalles:"Posici\xf3n en dec\xfabito lateral izquierdo (mejorar retorno venoso y prevenir aspiraci\xf3n). Si convulsiona: proteger de lesiones, no introducir objetos en boca, aspirar secreciones. Ox\xedgeno a alto flujo. Monitorizaci\xf3n continua: PA, FC, SatO2, FCF.",critico:!0},{orden:2,tiempo:"0-5 min",accion:"Administrar Sulfato de Magnesio (MgSO4) \u2014 PRIMERA L\xcdNEA",detalles:"Dosis de carga: 4-6 g IV en 15-20 min diluidos en 100 mL SF. Mantenimiento: 1-2 g/h en perfusi\xf3n continua. El MgSO4 es anticonvulsivante de elecci\xf3n en eclampsia (superior a diazepam y fenito\xedna). Mantener 24-48h postparto.",critico:!0,farmacos:[{nombre:"Sulfato de Magnesio",dosis:"Carga: 4-6 g IV en 15-20 min; Mantenimiento: 1-2 g/h",via:"IV"}]},{orden:3,tiempo:"5-15 min",accion:"Control de la presi\xf3n arterial",detalles:"Objetivo: PA <160/110 pero no descender >25% en primeras horas (riesgo de hipoperfusi\xf3n placentaria). Labetalol IV es primera l\xednea. Alternativas: hidralazina IV, nifedipino oral.",critico:!0,farmacos:[{nombre:"Labetalol",dosis:"20 mg IV en bolo; repetir 40-80 mg cada 10-15 min (m\xe1x 300 mg)",via:"IV"},{nombre:"Hidralazina",dosis:"5-10 mg IV cada 15-20 min (m\xe1x 30 mg)",via:"IV"},{nombre:"Nifedipino",dosis:"10-20 mg VO cada 30 min (m\xe1x 60 mg)",via:"Oral"}]},{orden:4,tiempo:"15-30 min",accion:"Evaluaci\xf3n materna y fetal completa",detalles:"Anal\xedtica urgente: hemograma, plaquetas, LDH, GOT/GPT, bilirrubina, creatinina, \xe1cido \xfarico, proteinuria. Descartar s\xedndrome HELLP (hem\xf3lisis + enzimas hep\xe1ticas elevadas + trombocitopenia). Monitorizaci\xf3n fetal continua: RCTG.",critico:!1},{orden:5,tiempo:"30 min - 2h",accion:"Decisi\xf3n sobre finalizaci\xf3n del embarazo",detalles:"La eclampsia y preeclampsia severa refractaria son indicaci\xf3n de parto urgente independientemente de la edad gestacional. En <34 semanas: considerar maduraci\xf3n pulmonar con corticoides si el estado materno lo permite (betametasona 12 mg IM \xd7 2 dosis/24h). La v\xeda de parto depende de las condiciones obst\xe9tricas.",critico:!0,decision:{pregunta:"\xbfEclampsia refractaria al MgSO4 o deterioro materno/fetal?",si:"Ces\xe1rea urgente",no:"Estabilizar y planificar parto seg\xfan condiciones obst\xe9tricas"}},{orden:6,tiempo:"Postparto",accion:"Vigilancia postparto intensiva",detalles:"Mantener MgSO4 24-48h postparto. Continuar antihipertensivos. Vigilar diuresis, PA cada 15 min las primeras 4h. El riesgo de eclampsia persiste hasta 48-72h postparto. Control de hemorragia postparto (mayor riesgo en HELLP).",critico:!1}],resumenFarmacos:[{nombre:"Sulfato de Magnesio",dosis:"Carga: 4-6 g IV en 15-20 min; Mantenimiento: 1-2 g/h",via:"IV",indicacion:"Anticonvulsivante de primera l\xednea en eclampsia y prevenci\xf3n en preeclampsia severa"},{nombre:"Labetalol",dosis:"20 mg IV en bolo, escalar cada 10-15 min (m\xe1x 300 mg)",via:"IV",indicacion:"Antihipertensivo de primera l\xednea en emergencia hipertensiva del embarazo"},{nombre:"Hidralazina",dosis:"5-10 mg IV cada 15-20 min",via:"IV",indicacion:"Alternativa antihipertensiva"},{nombre:"Nifedipino",dosis:"10-20 mg VO cada 30 min",via:"Oral",indicacion:"Alternativa si no hay acceso IV"},{nombre:"Betametasona",dosis:"12 mg IM cada 24h \xd7 2 dosis",via:"IM",indicacion:"Maduraci\xf3n pulmonar fetal si <34 semanas"}],notasEnfermeria:["Monitorizar reflejo rotuliano cada hora durante infusi\xf3n de MgSO4: la AUSENCIA de reflejo indica toxicidad por magnesio.","Mantener ant\xeddoto preparado: Gluconato de Calcio 1 g IV lento para toxicidad por MgSO4 (depresi\xf3n respiratoria, bradicardia).","Controlar diuresis horaria: debe ser >25-30 mL/h. El MgSO4 se excreta por v\xeda renal; la oliguria aumenta el riesgo de toxicidad.","NUNCA administrar nifedipino y MgSO4 simult\xe1neamente sin supervisi\xf3n estrecha: hipotensi\xf3n severa.","El s\xedndrome HELLP puede presentarse sin hipertensi\xf3n significativa: sospechar ante dolor epig\xe1strico + malestar + n\xe1useas."]},{id:"proto_sobredosis_opioides",nombre:"Intoxicaci\xf3n por Opioides",abreviatura:"IOp",descripcion:"Protocolo de manejo de la sobredosis/intoxicaci\xf3n aguda por opioides (hero\xedna, fentanilo, morfina, metadona, tramadol). La depresi\xf3n respiratoria es la principal causa de muerte. La naloxona es el ant\xeddoto espec\xedfico.",categoria:"otro",prioridad:"critico",banderasRojas:["Depresi\xf3n respiratoria: FR <12 rpm o apnea","Miosis puntiforme bilateral (pupilas en alfiler)","Disminuci\xf3n del nivel de conciencia / coma","Cianosis","Hipotensi\xf3n","Bradicardia","Edema pulmonar no cardiog\xe9nico (hero\xedna/fentanilo)"],pasos:[{orden:1,tiempo:"0-1 min",accion:"Evaluaci\xf3n r\xe1pida y apertura de v\xeda a\xe9rea",detalles:"Evaluar consciencia (est\xedmulo verbal/dolor), respiraci\xf3n y pulso. Abrir v\xeda a\xe9rea (maniobra frente-ment\xf3n), aspirar secreciones. Si apnea: iniciar ventilaci\xf3n con bolsa-mascarilla. Si paro card\xedaco: iniciar RCP.",critico:!0},{orden:2,tiempo:"1-3 min",accion:"Administrar Naloxona",detalles:"Naloxona 0.4-2 mg IV/IM/SC/IN. Si no hay respuesta en 2-3 minutos, repetir dosis. En sospecha de fentanilo o derivados potentes: pueden requerirse dosis mayores (hasta 10 mg totales). V\xeda intranasal: 4 mg (2 mg por fosa nasal) si no hay acceso IV.",critico:!0,farmacos:[{nombre:"Naloxona",dosis:"0.4-2 mg IV/IM/SC; repetir cada 2-3 min hasta respuesta (m\xe1x 10 mg)",via:"IV/IM/SC/IN"}]},{orden:3,tiempo:"3-10 min",accion:"Monitorizaci\xf3n continua y soporte respiratorio",detalles:"Monitorizar SatO2, FR, FC, PA, ECG. Ox\xedgeno suplementario. La naloxona tiene vida media m\xe1s corta (30-90 min) que muchos opioides: riesgo de re-sedaci\xf3n. Si paciente intubado, mantener ventilaci\xf3n mec\xe1nica hasta respuesta.",critico:!0},{orden:4,tiempo:"10-60 min",accion:"Infusi\xf3n continua de Naloxona (si renarcotizaci\xf3n)",detalles:"Si se requieren dosis repetidas o el opioide es de larga duraci\xf3n (metadona, fentanilo transd\xe9rmico): perfusi\xf3n continua de naloxona 0.4-0.8 mg/h IV. Ajustar seg\xfan respuesta cl\xednica. Mantener m\xednimo 4-6h (24h si metadona).",critico:!0,farmacos:[{nombre:"Naloxona (perfusi\xf3n)",dosis:"0.4-0.8 mg/h IV en perfusi\xf3n continua (2/3 de la dosis de respuesta por hora)",via:"IV"}]},{orden:5,tiempo:"Continuo",accion:"Evaluaci\xf3n de complicaciones y observaci\xf3n",detalles:"Vigilar: edema pulmonar no cardiog\xe9nico, rabdomi\xf3lisis (CK, mioglobina), hipotermia, s\xedndrome compartimental (por inmovilizaci\xf3n prolongada). Observaci\xf3n m\xednima: 4-6h si opioides de corta duraci\xf3n, 24h si metadona u opioides de liberaci\xf3n prolongada.",critico:!1}],resumenFarmacos:[{nombre:"Naloxona",dosis:"0.4-2 mg IV/IM/SC/IN; repetir cada 2-3 min (m\xe1x 10 mg)",via:"IV/IM/SC/IN",indicacion:"Antagonista opioide espec\xedfico \u2014 revierte depresi\xf3n respiratoria, sedaci\xf3n y miosis"},{nombre:"Naloxona (perfusi\xf3n)",dosis:"0.4-0.8 mg/h IV ajustable",via:"IV",indicacion:"Prevenir renarcotizaci\xf3n con opioides de larga duraci\xf3n"}],notasEnfermeria:["Al administrar naloxona, dosificar PROGRESIVAMENTE: despertar brusco puede causar agitaci\xf3n severa, v\xf3mito con aspiraci\xf3n, edema pulmonar o s\xedndrome de abstinencia agudo.","La naloxona tiene vida media MENOR que la mayor\xeda de opioides: vigilar renarcotizaci\xf3n. Nunca dar de alta tras una sola dosis sin observaci\xf3n.","En pacientes con dependencia cr\xf3nica a opioides: usar dosis menores de naloxona (0.04-0.1 mg) y titular para restaurar respiraci\xf3n sin precipitar abstinencia completa.","Buscar parches de fentanilo transd\xe9rmico en todo el cuerpo (pueden estar ocultos); retirarlos si se encuentran.","Documentar: sustancia sospechada, v\xeda de consumo, hora estimada de exposici\xf3n, dosis de naloxona y respuesta."]},{id:"proto_reaccion_transfusional",nombre:"Reacci\xf3n Transfusional Aguda",abreviatura:"RTA",descripcion:"Protocolo de manejo de reacciones adversas agudas a la transfusi\xf3n de hemoderivados. Incluye reacciones hemol\xedticas (incompatibilidad ABO), febriles no hemol\xedticas, al\xe9rgicas/anafil\xe1cticas, TRALI y sobrecarga circulatoria (TACO).",categoria:"otro",prioridad:"urgente",banderasRojas:["Fiebre >1\xb0C sobre la basal durante o tras transfusi\xf3n","Escalofr\xedos intensos / rigidez","Hipotensi\xf3n o hipertensi\xf3n s\xfabita","Taquicardia","Disnea / desaturaci\xf3n / edema pulmonar","Urticaria, prurito, angioedema","Dolor lumbar o tor\xe1cico","Hemoglobinuria (orina oscura)","Sensaci\xf3n de muerte inminente"],pasos:[{orden:1,tiempo:"0-1 min",accion:"DETENER LA TRANSFUSI\xd3N INMEDIATAMENTE",detalles:"Clamplar la v\xeda de transfusi\xf3n pero NO retirar el acceso venoso. Mantener permeable con SF 0.9%. Verificar la identidad del paciente y la etiqueta de la bolsa de hemoderivado. Monitorizar signos vitales.",critico:!0},{orden:2,tiempo:"1-5 min",accion:"Evaluaci\xf3n cl\xednica y clasificaci\xf3n de la reacci\xf3n",detalles:"Valorar: fiebre, urticaria, disnea, hipotensi\xf3n, dolor. Si shock anafil\xe1ctico: epinefrina 0.3-0.5 mg IM. Si disnea con infiltrados bilaterales: sospechar TRALI. Si fiebre + hemoglobinuria: sospechar reacci\xf3n hemol\xedtica.",critico:!0,decision:{pregunta:"\xbfHay signos de anafilaxia o reacci\xf3n hemol\xedtica?",si:"Tratamiento de emergencia: epinefrina (anafilaxia) o fluidoterapia agresiva + consulta hematolog\xeda (hemol\xedtica)",no:"Tratamiento sintom\xe1tico: antihistam\xednicos (alergia leve), paracetamol (febril)"}},{orden:3,tiempo:"5-15 min",accion:"Tratamiento seg\xfan tipo de reacci\xf3n",detalles:"Febril no hemol\xedtica: paracetamol 1g IV. Al\xe9rgica leve (urticaria): dexclorfeniramina 5 mg IV. Anafilaxia: epinefrina 0.3-0.5 mg IM + corticoides + fluidos. Hemol\xedtica: SF 0.9% a 200 mL/h, mantener diuresis >100 mL/h, alertar UCI.",critico:!0,farmacos:[{nombre:"Epinefrina (anafilaxia)",dosis:"0.3-0.5 mg IM; repetir cada 5-15 min si necesario",via:"IM"},{nombre:"Dexclorfeniramina",dosis:"5 mg IV",via:"IV"},{nombre:"Hidrocortisona",dosis:"100-200 mg IV",via:"IV"},{nombre:"Paracetamol",dosis:"1 g IV",via:"IV"}]},{orden:4,tiempo:"15-30 min",accion:"Estudios de laboratorio y notificaci\xf3n",detalles:"Enviar: muestra de sangre del paciente (nueva extracci\xf3n), bolsa de hemoderivado con sistema de infusi\xf3n, muestra de orina. Solicitar: Coombs directo, haptoglobina, LDH, bilirrubina, hemograma. Notificar al banco de sangre y cumplimentar formulario de reacci\xf3n transfusional.",critico:!1},{orden:5,tiempo:"Continuo",accion:"Monitorizaci\xf3n y prevenci\xf3n de complicaciones",detalles:"Vigilar funci\xf3n renal: creatinina, diuresis. En reacci\xf3n hemol\xedtica: mantener diuresis >100 mL/h (furosemida si necesario). Vigilar CID: fibrin\xf3geno, DD, plaquetas. Monitorizaci\xf3n continua m\xednimo 4-6h.",critico:!1}],resumenFarmacos:[{nombre:"Epinefrina",dosis:"0.3-0.5 mg IM (anafilaxia)",via:"IM",indicacion:"Reacci\xf3n anafil\xe1ctica a la transfusi\xf3n"},{nombre:"Dexclorfeniramina",dosis:"5 mg IV",via:"IV",indicacion:"Reacci\xf3n al\xe9rgica leve-moderada (urticaria, prurito)"},{nombre:"Hidrocortisona",dosis:"100-200 mg IV",via:"IV",indicacion:"Complemento en reacciones al\xe9rgicas severas"},{nombre:"Paracetamol",dosis:"1 g IV",via:"IV",indicacion:"Reacci\xf3n febril no hemol\xedtica"},{nombre:"Furosemida",dosis:"20-40 mg IV",via:"IV",indicacion:"Mantener diuresis en reacci\xf3n hemol\xedtica o TACO"}],notasEnfermeria:["Los primeros 15 minutos de transfusi\xf3n son CR\xcdTICOS: permanecer junto al paciente y tomar signos vitales a los 0, 5 y 15 min.","NUNCA reanudar una transfusi\xf3n detenida por sospecha de reacci\xf3n hemol\xedtica o anafil\xe1ctica.","Verificar SIEMPRE la identidad del paciente con doble comprobaci\xf3n (nombre + fecha nacimiento + pulsera) antes de iniciar.","La reacci\xf3n hemol\xedtica aguda por incompatibilidad ABO es la causa m\xe1s frecuente de muerte por transfusi\xf3n y es SIEMPRE un error humano prevenible.","Distinguir TRALI (edema pulmonar no cardiog\xe9nico, 6h post-transfusi\xf3n) de TACO (sobrecarga circulatoria): TRALI cursa con hipotensi\xf3n, TACO con hipertensi\xf3n y PVC elevada."]},{id:"proto_acv_hemorragico",nombre:"ACV Hemorr\xe1gico",abreviatura:"HIC",descripcion:"Protocolo de manejo de la hemorragia intracerebral espont\xe1nea (no traum\xe1tica). Segunda causa de ictus (15-20%). Mortalidad a 30 d\xedas del 40%. El control precoz de la presi\xf3n arterial y la reversi\xf3n de anticoagulaci\xf3n son pilares del tratamiento.",categoria:"neurologico",prioridad:"critico",banderasRojas:["D\xe9ficit neurol\xf3gico focal de inicio brusco","Cefalea intensa s\xfabita ('la peor de mi vida')","Disminuci\xf3n r\xe1pida del nivel de conciencia (GCS descendente)","V\xf3mitos en escopetazo","Rigidez de nuca (si hemorragia subaracnoidea asociada)","Crisis convulsiva","Anisocoria (herniaci\xf3n cerebral inminente)","HTA severa (PA >220/120 mmHg)"],pasos:[{orden:1,tiempo:"0-10 min",accion:"Estabilizaci\xf3n inicial y ABC",detalles:"Asegurar v\xeda a\xe9rea (GCS \u22648: intubar). Ox\xedgeno para SatO2 >94%. Monitorizaci\xf3n continua: PA, FC, SatO2, GCS. Posici\xf3n: cabecera elevada 30\xb0. Acceso venoso con SF (NO suero glucosado). Glucemia capilar urgente.",critico:!0},{orden:2,tiempo:"0-15 min",accion:"Neuroimagen urgente \u2014 TAC craneal SIN contraste",detalles:"TAC urgente para confirmar hemorragia y diferenciar de ictus isqu\xe9mico. Determinar localizaci\xf3n, volumen (ABC/2) y presencia de hidrocefalia o efecto masa. Angiotac si sospecha de malformaci\xf3n vascular o aneurisma.",critico:!0,decision:{pregunta:"\xbfHemorragia confirmada en TAC?",si:"Continuar protocolo de HIC: control PA + reversi\xf3n anticoagulaci\xf3n si aplica",no:"Reevaluar: considerar protocolo de ictus isqu\xe9mico o HSA"}},{orden:3,tiempo:"15-60 min",accion:"Control intensivo de la presi\xf3n arterial",detalles:"Objetivo: PAS <140 mmHg en las primeras horas (estudio INTERACT2). Labetalol IV es primera l\xednea. Si refractario: nicardipino en perfusi\xf3n. Evitar descensos bruscos de PA >60 mmHg en la primera hora.",critico:!0,farmacos:[{nombre:"Labetalol",dosis:"10-20 mg IV en 1-2 min; repetir cada 10-15 min (m\xe1x 300 mg/d\xeda)",via:"IV"},{nombre:"Nicardipino",dosis:"5 mg/h IV, titular cada 5 min (m\xe1x 15 mg/h)",via:"IV"}]},{orden:4,tiempo:"Inmediato si aplica",accion:"Reversi\xf3n de anticoagulaci\xf3n",detalles:"Si anticoagulaci\xf3n con warfarina: vitamina K 10 mg IV + CCP (concentrado de complejo protromb\xednico) 25-50 UI/kg. Si ACODs (dabigatr\xe1n): idarucizumab 5 g IV. Si ACODs anti-Xa (rivaroxab\xe1n, apixab\xe1n): andexanet alfa o CCP. Objetivo: INR <1.3 en <60 min.",critico:!0,farmacos:[{nombre:"Vitamina K (fitomenadiona)",dosis:"10 mg IV lento (en 10-20 min)",via:"IV"},{nombre:"CCP (Concentrado Complejo Protromb\xednico)",dosis:"25-50 UI/kg IV seg\xfan INR",via:"IV"},{nombre:"Idarucizumab (si dabigatr\xe1n)",dosis:"5 g IV en 2 bolos de 2.5 g",via:"IV"},{nombre:"\xc1cido tranex\xe1mico",dosis:"1 g IV en 10 min (primeras 4.5h)",via:"IV"}]},{orden:5,tiempo:"Continuo",accion:"Prevenci\xf3n y tratamiento de complicaciones",detalles:"Profilaxis anticonvulsiva si crisis (levetiracetam 1 g IV). Profilaxis de TVP: compresi\xf3n neum\xe1tica intermitente (NO heparina en primeras 24-48h). Normoglucemia (140-180 mg/dL). Normotermia (tratar fiebre agresivamente). Monitorizaci\xf3n neurol\xf3gica: GCS cada hora.",critico:!1},{orden:6,tiempo:"Variable",accion:"Valoraci\xf3n neuroquir\xfargica",detalles:"Indicaciones quir\xfargicas: hematoma cerebeloso >3 cm con deterioro, hidrocefalia obstructiva (drenaje ventricular), hematoma lobar superficial >30 mL con deterioro. Los hematomas profundos (ganglios basales) rara vez se benefician de cirug\xeda.",critico:!1,decision:{pregunta:"\xbfHematoma cerebeloso >3 cm, hidrocefalia o deterioro r\xe1pido?",si:"Neurocirug\xeda urgente: evacuaci\xf3n o DVE",no:"Manejo conservador en UCI neurol\xf3gica"}}],resumenFarmacos:[{nombre:"Labetalol",dosis:"10-20 mg IV en bolo, escalar cada 10-15 min",via:"IV",indicacion:"Control de HTA \u2014 primera l\xednea"},{nombre:"Nicardipino",dosis:"5-15 mg/h IV en perfusi\xf3n",via:"IV",indicacion:"Control de HTA refractaria a labetalol"},{nombre:"Vitamina K",dosis:"10 mg IV",via:"IV",indicacion:"Reversi\xf3n de warfarina (efecto en 6-24h)"},{nombre:"CCP",dosis:"25-50 UI/kg IV",via:"IV",indicacion:"Reversi\xf3n r\xe1pida de warfarina/ACODs anti-Xa"},{nombre:"Idarucizumab",dosis:"5 g IV",via:"IV",indicacion:"Reversi\xf3n espec\xedfica de dabigatr\xe1n"},{nombre:"Levetiracetam",dosis:"1 g IV",via:"IV",indicacion:"Anticonvulsivante si crisis epil\xe9ptica"},{nombre:"\xc1cido tranex\xe1mico",dosis:"1 g IV en 10 min",via:"IV",indicacion:"Reducir expansi\xf3n del hematoma (primeras 4.5h)"}],notasEnfermeria:["Monitorizaci\xf3n neurol\xf3gica estricta: GCS, pupilas y focalidad cada hora las primeras 24h. Cualquier descenso de GCS \u22652 puntos: alertar inmediatamente.","Control de PA cada 15 min durante fase aguda. Evitar PA extremas: tanto la HTA (expansi\xf3n hematoma) como la hipotensi\xf3n (isquemia perilesional) son delet\xe9reas.","Cabecera elevada 30\xb0 para favorecer retorno venoso cerebral. Evitar flexi\xf3n del cuello (impide drenaje yugular).","En pacientes anticoagulados: la reversi\xf3n tiene PRIORIDAD incluso antes del TAC si hay alta sospecha cl\xednica.","Tratar la fiebre agresivamente: cada grado >37\xb0C empeora el pron\xf3stico neurol\xf3gico. Paracetamol 1g/6h + medidas f\xedsicas."]}]},788,[]);
