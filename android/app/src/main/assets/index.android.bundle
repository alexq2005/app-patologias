__d(function(o,i,e,a,n,r,c){n.exports=[{id:"cardiovascular",nombre:"Sistema Cardiovascular",descripcion:"Coraz\xf3n, vasos sangu\xedneos y circulaci\xf3n. Incluye patolog\xedas como hipertensi\xf3n, insuficiencia card\xedaca, infarto y arritmias.",color:"#E55050",icon:"heart-pulse",pathologyCount:16},{id:"respiratorio",nombre:"Sistema Respiratorio",descripcion:"V\xedas a\xe9reas, pulmones e intercambio gaseoso. Incluye EPOC, asma, neumon\xeda y embolia pulmonar.",color:"#54A0FF",icon:"lungs",pathologyCount:13},{id:"neurologico",nombre:"Sistema Neurol\xf3gico",descripcion:"Cerebro, m\xe9dula espinal y nervios perif\xe9ricos. Incluye ACV, epilepsia, Parkinson y meningitis.",color:"#6C5CE7",icon:"brain",pathologyCount:13},{id:"digestivo",nombre:"Sistema Digestivo",descripcion:"Tracto gastrointestinal, h\xedgado, p\xe1ncreas y ves\xedcula. Incluye \xfalcera p\xe9ptica, cirrosis y pancreatitis.",color:"#F78B3D",icon:"stomach",pathologyCount:13},{id:"endocrino",nombre:"Sistema Endocrino",descripcion:"Gl\xe1ndulas y hormonas. Incluye diabetes mellitus, hipo/hipertiroidismo e insuficiencia suprarrenal.",color:"#E0A030",icon:"scale-balance",pathologyCount:12},{id:"renal_urinario",nombre:"Sistema Renal y Urinario",descripcion:"Ri\xf1ones, ur\xe9teres, vejiga y uretra. Incluye insuficiencia renal, infecci\xf3n urinaria y litiasis.",color:"#FDAD5A",icon:"water-pump",pathologyCount:14},{id:"musculoesqueletico",nombre:"Sistema Musculoesquel\xe9tico",descripcion:"Huesos, articulaciones, m\xfasculos y tejido conectivo. Incluye fracturas, artritis y osteoporosis.",color:"#00B894",icon:"bone",pathologyCount:13},{id:"hematologico",nombre:"Sistema Hematol\xf3gico",descripcion:"Sangre y \xf3rganos hematopoy\xe9ticos. Incluye anemias, leucemias y trastornos de coagulaci\xf3n.",color:"#C44569",icon:"water",pathologyCount:13},{id:"inmunologico",nombre:"Sistema Inmunol\xf3gico",descripcion:"Defensa del organismo. Incluye VIH/SIDA, lupus, artritis reumatoide y reacciones al\xe9rgicas.",color:"#2ECC71",icon:"shield-plus-outline",pathologyCount:12},{id:"tegumentario",nombre:"Sistema Tegumentario",descripcion:"Piel, cabello y u\xf1as. Incluye \xfalceras por presi\xf3n, quemaduras, dermatitis y heridas.",color:"#E8A87C",icon:"hand-back-right-outline",pathologyCount:12},{id:"reproductivo",nombre:"Sistema Reproductivo",descripcion:"\xd3rganos reproductivos masculinos y femeninos. Incluye preeclampsia, c\xe1ncer de mama y prostatitis.",color:"#FD79A8",icon:"human-pregnant",pathologyCount:12},{id:"traumatologico",nombre:"Traumatolog\xeda y Emergencias",descripcion:"Lesiones por trauma, quemaduras y emergencias traum\xe1ticas. Incluye TCE, politraumatismo, fracturas y lesi\xf3n medular.",color:"#FF6348",icon:"ambulance",pathologyCount:10}]},799,[]);
__d(function(e,a,i,o,n,l,r){n.exports=[{id:"scale_glasgow",nombre:"Escala de Coma de Glasgow",abreviatura:"GCS",descripcion:"Escala neurol\xf3gica que valora el nivel de conciencia mediante tres par\xe1metros: apertura ocular, respuesta verbal y respuesta motora.",tipo:"components",categoria:"neurologia",componentes:[{nombre:"Apertura ocular",opciones:[{label:"Ninguna",value:1},{label:"Al dolor",value:2},{label:"A la voz",value:3},{label:"Espont\xe1nea",value:4}]},{nombre:"Respuesta verbal",opciones:[{label:"Ninguna",value:1},{label:"Sonidos incomprensibles",value:2},{label:"Palabras inapropiadas",value:3},{label:"Confusa",value:4},{label:"Orientada",value:5}]},{nombre:"Respuesta motora",opciones:[{label:"Ninguna",value:1},{label:"Extensi\xf3n anormal (descerebraci\xf3n)",value:2},{label:"Flexi\xf3n anormal (decorticaci\xf3n)",value:3},{label:"Retirada al dolor",value:4},{label:"Localiza el dolor",value:5},{label:"Obedece \xf3rdenes",value:6}]}],interpretaciones:[{rango:[3,8],label:"Traumatismo craneoencef\xe1lico grave",color:"#DC2626",descripcion:"Coma profundo. Requiere intubaci\xf3n, ventilaci\xf3n mec\xe1nica y manejo en UCI. Evaluar necesidad de TAC urgente e intervenci\xf3n neuroquir\xfargica."},{rango:[9,12],label:"Traumatismo craneoencef\xe1lico moderado",color:"#EA580C",descripcion:"Alteraci\xf3n significativa del nivel de conciencia. Requiere monitorizaci\xf3n estrecha, TAC cerebral y valoraci\xf3n neuroquir\xfargica."},{rango:[13,15],label:"Traumatismo craneoencef\xe1lico leve",color:"#16A34A",descripcion:"Nivel de conciencia conservado o levemente alterado. Observaci\xf3n cl\xednica y seguimiento neurol\xf3gico peri\xf3dico."}],rangoTotal:[3,15],contextoClinico:"Utilizada en urgencias, UCI y servicios de neurolog\xeda para evaluar el nivel de conciencia en pacientes con traumatismo craneoencef\xe1lico, ictus u otras lesiones neurol\xf3gicas. Se debe reevaluar peri\xf3dicamente para detectar cambios en el estado neurol\xf3gico.",referencia:"Teasdale G, Jennett B. Assessment of coma and impaired consciousness: a practical scale. Lancet. 1974;2(7872):81-84."},{id:"scale_apgar",nombre:"Test de APGAR",abreviatura:"APGAR",descripcion:"Evaluaci\xf3n r\xe1pida del estado cl\xednico del reci\xe9n nacido al minuto y a los 5 minutos de vida, valorando cinco par\xe1metros vitales.",tipo:"components",categoria:"neonatologia",componentes:[{nombre:"Apariencia (color de piel)",opciones:[{label:"Cianosis generalizada o palidez",value:0},{label:"Acrocianosis (cuerpo rosado, extremidades azules)",value:1},{label:"Completamente rosado",value:2}]},{nombre:"Pulso (frecuencia card\xedaca)",opciones:[{label:"Ausente",value:0},{label:"Menor de 100 lpm",value:1},{label:"Mayor o igual a 100 lpm",value:2}]},{nombre:"Gesticulaci\xf3n (irritabilidad refleja)",opciones:[{label:"Sin respuesta",value:0},{label:"Mueca o llanto d\xe9bil ante est\xedmulo",value:1},{label:"Llanto vigoroso, tos o estornudo",value:2}]},{nombre:"Actividad (tono muscular)",opciones:[{label:"Fl\xe1cido, sin tono",value:0},{label:"Cierta flexi\xf3n de extremidades",value:1},{label:"Movimientos activos, buena flexi\xf3n",value:2}]},{nombre:"Respiraci\xf3n (esfuerzo respiratorio)",opciones:[{label:"Ausente",value:0},{label:"Llanto d\xe9bil, irregular o jadeo",value:1},{label:"Llanto fuerte y vigoroso",value:2}]}],interpretaciones:[{rango:[0,3],label:"Depresi\xf3n severa",color:"#DC2626",descripcion:"Requiere reanimaci\xf3n neonatal inmediata. Iniciar ventilaci\xf3n con presi\xf3n positiva, valorar intubaci\xf3n y compresiones tor\xe1cicas seg\xfan protocolo NRP."},{rango:[4,6],label:"Depresi\xf3n moderada",color:"#EA580C",descripcion:"Requiere intervenci\xf3n activa: estimulaci\xf3n t\xe1ctil, aspiraci\xf3n de secreciones, ox\xedgeno suplementario y valorar ventilaci\xf3n con presi\xf3n positiva."},{rango:[7,10],label:"Normal",color:"#16A34A",descripcion:"Reci\xe9n nacido en buenas condiciones. Continuar con cuidados rutinarios: secado, contacto piel con piel y lactancia materna precoz."}],rangoTotal:[0,10],contextoClinico:"Se aplica a todo reci\xe9n nacido al minuto y a los 5 minutos de vida en la sala de partos. Si la puntuaci\xf3n a los 5 minutos es menor de 7, se repite cada 5 minutos hasta los 20 minutos.",referencia:"Apgar V. A proposal for a new method of evaluation of the newborn infant. Curr Res Anesth Analg. 1953;32(4):260-267."},{id:"scale_norton",nombre:"Escala de Norton",abreviatura:"Norton",descripcion:"Escala que eval\xfaa el riesgo de desarrollar \xfalceras por presi\xf3n (UPP) mediante cinco par\xe1metros cl\xednicos del paciente.",tipo:"components",categoria:"riesgo_ulceras",componentes:[{nombre:"Estado f\xedsico general",opciones:[{label:"Muy malo",value:1},{label:"Malo (pobre)",value:2},{label:"Regular (mediano)",value:3},{label:"Bueno",value:4}]},{nombre:"Estado mental",opciones:[{label:"Estuporoso / comatoso",value:1},{label:"Confuso",value:2},{label:"Ap\xe1tico",value:3},{label:"Alerta / orientado",value:4}]},{nombre:"Actividad",opciones:[{label:"Encamado",value:1},{label:"Sentado (silla de ruedas)",value:2},{label:"Camina con ayuda",value:3},{label:"Ambulante (independiente)",value:4}]},{nombre:"Movilidad",opciones:[{label:"Inm\xf3vil",value:1},{label:"Muy limitada",value:2},{label:"Ligeramente limitada",value:3},{label:"Completa",value:4}]},{nombre:"Incontinencia",opciones:[{label:"Urinaria y fecal",value:1},{label:"Urinaria habitual",value:2},{label:"Ocasional",value:3},{label:"Ninguna (continente)",value:4}]}],interpretaciones:[{rango:[5,9],label:"Riesgo muy alto",color:"#DC2626",descripcion:"Requiere medidas intensivas de prevenci\xf3n: colch\xf3n antiescaras, cambios posturales cada 2 horas, protecci\xf3n de prominencias \xf3seas, nutrici\xf3n hiperproteica y vigilancia continua de la piel."},{rango:[10,12],label:"Riesgo alto",color:"#EA580C",descripcion:"Implementar protocolo de prevenci\xf3n completo: superficies especiales de manejo de presi\xf3n (SEMP), cambios posturales frecuentes, hidrataci\xf3n cut\xe1nea y control nutricional."},{rango:[13,14],label:"Riesgo medio",color:"#F59E0B",descripcion:"Medidas preventivas b\xe1sicas: cambios posturales regulares, hidrataci\xf3n de la piel, vigilancia de zonas de riesgo y educaci\xf3n al paciente/familia."},{rango:[15,20],label:"Riesgo m\xednimo / sin riesgo",color:"#16A34A",descripcion:"Bajo riesgo de \xfalceras por presi\xf3n. Mantener medidas higi\xe9nicas habituales y reevaluar si cambia la situaci\xf3n cl\xednica del paciente."}],rangoTotal:[5,20],contextoClinico:"Aplicar al ingreso hospitalario y reevaluar peri\xf3dicamente en pacientes encamados, con movilidad reducida o en unidades de larga estancia. Es m\xe1s sencilla que la escala de Braden pero menos espec\xedfica.",referencia:"Norton D, McLaren R, Exton-Smith AN. An Investigation of Geriatric Nursing Problems in Hospital. London: Churchill Livingstone; 1962."},{id:"scale_braden",nombre:"Escala de Braden",abreviatura:"Braden",descripcion:"Escala de valoraci\xf3n del riesgo de \xfalceras por presi\xf3n que eval\xfaa seis subescalas. A menor puntuaci\xf3n, mayor riesgo.",tipo:"components",categoria:"riesgo_ulceras",componentes:[{nombre:"Percepci\xf3n sensorial",opciones:[{label:"Completamente limitada: no responde a est\xedmulos dolorosos",value:1},{label:"Muy limitada: solo responde a est\xedmulos dolorosos",value:2},{label:"Ligeramente limitada: responde a \xf3rdenes verbales pero no siempre comunica molestias",value:3},{label:"Sin limitaciones: responde y comunica adecuadamente",value:4}]},{nombre:"Humedad (exposici\xf3n de la piel)",opciones:[{label:"Constantemente h\xfameda: la piel permanece h\xfameda casi siempre",value:1},{label:"Muy h\xfameda: la piel est\xe1 frecuentemente h\xfameda",value:2},{label:"Ocasionalmente h\xfameda: la piel est\xe1 h\xfameda a veces",value:3},{label:"Raramente h\xfameda: la piel est\xe1 seca habitualmente",value:4}]},{nombre:"Actividad",opciones:[{label:"Encamado: confinado en cama",value:1},{label:"En silla: capacidad de deambulaci\xf3n muy limitada",value:2},{label:"Deambula ocasionalmente: con o sin ayuda, distancias cortas",value:3},{label:"Deambula frecuentemente: fuera de la habitaci\xf3n al menos 2 veces/d\xeda",value:4}]},{nombre:"Movilidad",opciones:[{label:"Completamente inm\xf3vil: no realiza ning\xfan cambio de posici\xf3n",value:1},{label:"Muy limitada: realiza cambios de posici\xf3n m\xednimos ocasionalmente",value:2},{label:"Ligeramente limitada: realiza cambios frecuentes aunque peque\xf1os",value:3},{label:"Sin limitaciones: realiza cambios mayores y frecuentes",value:4}]},{nombre:"Nutrici\xf3n",opciones:[{label:"Muy pobre: nunca come una comida completa, ingesta proteica inadecuada",value:1},{label:"Probablemente inadecuada: rara vez come una comida completa",value:2},{label:"Adecuada: come m\xe1s de la mitad de las comidas, ingesta proteica adecuada",value:3},{label:"Excelente: come la mayor\xeda de las comidas, nunca rechaza alimentos",value:4}]},{nombre:"Fricci\xf3n y cizallamiento",opciones:[{label:"Problema: requiere asistencia m\xe1xima para moverse, deslizamiento frecuente",value:1},{label:"Problema potencial: se mueve con dificultad, necesita ayuda m\xednima",value:2},{label:"Sin problema aparente: se mueve de forma independiente, buen control muscular",value:3}]}],interpretaciones:[{rango:[6,9],label:"Riesgo muy alto",color:"#DC2626",descripcion:"M\xe1xima prioridad preventiva. Superficie especial de apoyo din\xe1mica, cambios posturales cada 2 horas, protecci\xf3n de prominencias \xf3seas, suplementaci\xf3n nutricional y cuidados intensivos de la piel."},{rango:[10,12],label:"Riesgo alto",color:"#EA580C",descripcion:"Protocolo de prevenci\xf3n intensivo: colch\xf3n antiescaras, cambios posturales cada 2-3 horas, \xe1cidos grasos hiperoxigenados en zonas de riesgo y valoraci\xf3n nutricional."},{rango:[13,14],label:"Riesgo moderado",color:"#F59E0B",descripcion:"Medidas preventivas activas: cambios posturales regulares, hidrataci\xf3n cut\xe1nea, vigilancia de zonas de presi\xf3n y educaci\xf3n al paciente/cuidador."},{rango:[15,18],label:"Riesgo bajo",color:"#16A34A",descripcion:"Medidas preventivas b\xe1sicas: cuidados habituales de la piel, movilizaci\xf3n activa y reevaluaci\xf3n peri\xf3dica."},{rango:[19,23],label:"Sin riesgo significativo",color:"#16A34A",descripcion:"No precisa medidas especiales de prevenci\xf3n. Reevaluar si cambia la situaci\xf3n cl\xednica del paciente."}],rangoTotal:[6,23],contextoClinico:"Escala de referencia para la prevenci\xf3n de \xfalceras por presi\xf3n. Aplicar al ingreso y reevaluar cada 24-72 horas en pacientes hospitalizados, o semanalmente en residencias y atenci\xf3n domiciliaria.",referencia:"Bergstrom N, Braden BJ, Laguzza A, Holman V. The Braden Scale for predicting pressure sore risk. Nurs Res. 1987;36(4):205-210."},{id:"scale_news2",nombre:"National Early Warning Score 2",abreviatura:"NEWS2",descripcion:"Sistema de puntuaci\xf3n de alerta temprana que eval\xfaa seis par\xe1metros fisiol\xf3gicos para identificar precozmente el deterioro cl\xednico del paciente adulto.",tipo:"components",categoria:"sepsis",componentes:[{nombre:"Frecuencia respiratoria (rpm)",opciones:[{label:"12-20 rpm",value:0},{label:"9-11 rpm",value:1},{label:"21-24 rpm",value:2},{label:"\u22648 o \u226525 rpm",value:3}]},{nombre:"Saturaci\xf3n de ox\xedgeno (SpO\u2082)",opciones:[{label:"\u226596%",value:0},{label:"94-95%",value:1},{label:"92-93%",value:2},{label:"\u226491%",value:3}]},{nombre:"Presi\xf3n arterial sist\xf3lica (mmHg)",opciones:[{label:"111-219 mmHg",value:0},{label:"101-110 mmHg",value:1},{label:"91-100 mmHg",value:2},{label:"\u226490 o \u2265220 mmHg",value:3}]},{nombre:"Frecuencia card\xedaca (lpm)",opciones:[{label:"51-90 lpm",value:0},{label:"41-50 o 91-110 lpm",value:1},{label:"111-130 lpm",value:2},{label:"\u226440 o \u2265131 lpm",value:3}]},{nombre:"Nivel de conciencia (ACVPU)",opciones:[{label:"Alerta (A)",value:0},{label:"Confusi\xf3n de nueva aparici\xf3n (C)",value:3},{label:"Responde a voz (V)",value:3},{label:"Responde a dolor (P)",value:3},{label:"No responde (U)",value:3}]},{nombre:"Temperatura (\xb0C)",opciones:[{label:"36.1-38.0 \xb0C",value:0},{label:"35.1-36.0 \xb0C o 38.1-39.0 \xb0C",value:1},{label:"\u226539.1 \xb0C",value:2},{label:"\u226435.0 \xb0C",value:3}]}],interpretaciones:[{rango:[0,4],label:"Riesgo cl\xednico bajo",color:"#16A34A",descripcion:"Monitorizaci\xf3n rutinaria. Reevaluar cada 4-6 horas como m\xednimo. Si puntuaci\xf3n individual de 3 en un par\xe1metro, aumentar frecuencia de monitorizaci\xf3n."},{rango:[5,6],label:"Riesgo cl\xednico medio",color:"#F59E0B",descripcion:"Respuesta cl\xednica urgente. Avisar al equipo m\xe9dico con competencia en atenci\xf3n aguda. Monitorizaci\xf3n cada hora como m\xednimo."},{rango:[7,18],label:"Riesgo cl\xednico alto",color:"#DC2626",descripcion:"Respuesta cl\xednica emergente. Activar equipo de respuesta r\xe1pida o equipo de cuidados cr\xedticos. Monitorizaci\xf3n continua y considerar traslado a UCI."}],rangoTotal:[0,18],contextoClinico:"Herramienta estandarizada para la detecci\xf3n precoz del deterioro cl\xednico en pacientes adultos hospitalizados. Se utiliza en plantas de hospitalizaci\xf3n, urgencias y servicios de emergencia prehospitalaria.",referencia:"Royal College of Physicians. National Early Warning Score (NEWS) 2: Standardising the assessment of acute-illness severity in the NHS. London: RCP; 2017."},{id:"scale_aldrete",nombre:"Escala de Aldrete modificada",abreviatura:"Aldrete",descripcion:"Escala de valoraci\xf3n postanest\xe9sica que determina si un paciente puede ser dado de alta de la Unidad de Recuperaci\xf3n Postanest\xe9sica (URPA).",tipo:"components",categoria:"postanestesia",componentes:[{nombre:"Actividad muscular",opciones:[{label:"Incapaz de mover extremidades",value:0},{label:"Mueve 2 extremidades voluntariamente",value:1},{label:"Mueve 4 extremidades voluntariamente",value:2}]},{nombre:"Respiraci\xf3n",opciones:[{label:"Apnea",value:0},{label:"Disnea, respiraci\xf3n limitada o taquipnea",value:1},{label:"Capaz de respirar profundamente y toser libremente",value:2}]},{nombre:"Circulaci\xf3n (PA sist\xf3lica)",opciones:[{label:"PA sist\xf3lica \xb150 mmHg del valor preanest\xe9sico",value:0},{label:"PA sist\xf3lica \xb120-49 mmHg del valor preanest\xe9sico",value:1},{label:"PA sist\xf3lica \xb120 mmHg del valor preanest\xe9sico",value:2}]},{nombre:"Conciencia",opciones:[{label:"No responde",value:0},{label:"Se despierta al llamarlo",value:1},{label:"Completamente despierto y orientado",value:2}]},{nombre:"Saturaci\xf3n de ox\xedgeno (SpO\u2082)",opciones:[{label:"SpO\u2082 <90% con O\u2082 suplementario",value:0},{label:"SpO\u2082 90-91% con O\u2082 suplementario",value:1},{label:"SpO\u2082 \u226592% con aire ambiente",value:2}]}],interpretaciones:[{rango:[0,5],label:"No apto para alta de URPA",color:"#DC2626",descripcion:"El paciente requiere vigilancia continua en la URPA. Mantener monitorizaci\xf3n hemodin\xe1mica y respiratoria estricta. Reevaluar cada 15 minutos."},{rango:[6,7],label:"Vigilancia estrecha",color:"#F59E0B",descripcion:"El paciente a\xfan no cumple criterios \xf3ptimos de alta. Continuar vigilancia en URPA y reevaluar cada 15-30 minutos hasta alcanzar puntuaci\xf3n \u22658."},{rango:[8,10],label:"Apto para alta de URPA",color:"#16A34A",descripcion:"El paciente cumple criterios de alta de la Unidad de Recuperaci\xf3n Postanest\xe9sica. Puede ser trasladado a planta con indicaciones postoperatorias."}],rangoTotal:[0,10],contextoClinico:"Se aplica en la Unidad de Recuperaci\xf3n Postanest\xe9sica (URPA) para evaluar la recuperaci\xf3n del paciente tras anestesia general o regional. Se valora al ingreso en URPA y cada 15 minutos hasta el alta.",referencia:"Aldrete JA. The post-anesthesia recovery score revisited. J Clin Anesth. 1995;7(1):89-91."},{id:"scale_nihss",nombre:"Escala NIHSS simplificada",abreviatura:"NIHSS",descripcion:"Versi\xf3n simplificada de la escala del National Institutes of Health Stroke Scale para la valoraci\xf3n r\xe1pida de la gravedad del ictus.",tipo:"components",categoria:"neurologia",componentes:[{nombre:"Nivel de conciencia",opciones:[{label:"Alerta, responde correctamente",value:0},{label:"Somnoliento, responde con estimulaci\xf3n menor",value:1},{label:"Estuporoso, requiere estimulaci\xf3n repetida",value:2},{label:"Coma, no responde o solo reflejos",value:3}]},{nombre:"Mirada conjugada",opciones:[{label:"Normal",value:0},{label:"Paresia parcial de la mirada",value:1},{label:"Desviaci\xf3n forzada de la mirada",value:2}]},{nombre:"Campo visual",opciones:[{label:"Sin d\xe9ficit campim\xe9trico",value:0},{label:"Hemianopsia parcial",value:1},{label:"Hemianopsia completa",value:2},{label:"Ceguera bilateral",value:3}]},{nombre:"Paresia facial",opciones:[{label:"Movimiento normal y sim\xe9trico",value:0},{label:"Paresia menor (asimetr\xeda al sonre\xedr)",value:1},{label:"Paresia parcial (par\xe1lisis facial inferior)",value:2},{label:"Par\xe1lisis completa (sin movimiento facial)",value:3}]},{nombre:"Motor miembros superiores",opciones:[{label:"Sin claudicaci\xf3n (mantiene 10 seg)",value:0},{label:"Claudicaci\xf3n (cae antes de 10 seg sin llegar a cama)",value:1},{label:"Esfuerzo contra gravedad pero no mantiene",value:2},{label:"Sin esfuerzo contra gravedad, cae",value:3},{label:"Sin movimiento",value:4}]},{nombre:"Motor miembros inferiores",opciones:[{label:"Sin claudicaci\xf3n (mantiene 5 seg)",value:0},{label:"Claudicaci\xf3n (cae antes de 5 seg sin llegar a cama)",value:1},{label:"Esfuerzo contra gravedad pero no mantiene",value:2},{label:"Sin esfuerzo contra gravedad, cae",value:3},{label:"Sin movimiento",value:4}]},{nombre:"Lenguaje",opciones:[{label:"Normal, sin afasia",value:0},{label:"Afasia leve a moderada (se comunica con dificultad)",value:1},{label:"Afasia severa (expresi\xf3n fragmentaria)",value:2},{label:"Afasia global o mutismo",value:3}]},{nombre:"Disartria",opciones:[{label:"Articulaci\xf3n normal",value:0},{label:"Disartria leve a moderada (se entiende con dificultad)",value:1},{label:"Disartria severa o anartria (ininteligible o mudo)",value:2}]}],interpretaciones:[{rango:[0,4],label:"Ictus menor",color:"#16A34A",descripcion:"D\xe9ficit neurol\xf3gico leve. Valorar tratamiento seg\xfan protocolo de ictus minor. Monitorizaci\xf3n neurol\xf3gica y prevenci\xf3n secundaria."},{rango:[5,15],label:"Ictus moderado",color:"#F59E0B",descripcion:"D\xe9ficit neurol\xf3gico moderado. Candidato a tratamiento de reperfusi\xf3n (fibrin\xf3lisis IV o trombectom\xeda mec\xe1nica) si est\xe1 dentro de ventana terap\xe9utica. Ingreso en Unidad de Ictus."},{rango:[16,20],label:"Ictus moderado-grave",color:"#EA580C",descripcion:"D\xe9ficit neurol\xf3gico importante. Considerar trombectom\xeda mec\xe1nica. Manejo en Unidad de Ictus o UCI. Alto riesgo de complicaciones."},{rango:[21,24],label:"Ictus grave",color:"#DC2626",descripcion:"D\xe9ficit neurol\xf3gico severo con pron\xf3stico grave. Manejo intensivo, control de complicaciones y decisiones sobre limitaci\xf3n del esfuerzo terap\xe9utico."}],rangoTotal:[0,24],contextoClinico:"Se aplica en urgencias ante sospecha de ictus para cuantificar la gravedad del d\xe9ficit neurol\xf3gico y guiar las decisiones de tratamiento de reperfusi\xf3n. Se reeval\xfaa a las 24 horas y al alta.",referencia:"Brott T, Adams HP Jr, Olinger CP, et al. Measurements of acute cerebral infarction: a clinical examination scale. Stroke. 1989;20(7):864-870."},{id:"scale_rass",nombre:"Escala de Agitaci\xf3n-Sedaci\xf3n de Richmond",abreviatura:"RASS",descripcion:"Escala de 10 puntos que valora el nivel de sedaci\xf3n y agitaci\xf3n del paciente cr\xedtico, desde sedaci\xf3n profunda hasta agitaci\xf3n extrema.",tipo:"selector",categoria:"sedacion",componentes:[{nombre:"Nivel de sedaci\xf3n-agitaci\xf3n",opciones:[{label:"No despertable: sin respuesta a la voz ni a la estimulaci\xf3n f\xedsica",value:-5},{label:"Sedaci\xf3n profunda: sin respuesta a la voz, movimiento o apertura ocular a la estimulaci\xf3n f\xedsica",value:-4},{label:"Sedaci\xf3n moderada: movimiento o apertura ocular a la voz, sin contacto visual",value:-3},{label:"Sedaci\xf3n ligera: se despierta brevemente a la voz, contacto visual <10 seg",value:-2},{label:"Somnoliento: no completamente alerta, pero despierta con la voz, contacto visual >10 seg",value:-1},{label:"Alerta y tranquilo",value:0},{label:"Inquieto: ansioso o aprensivo, sin movimientos agresivos o vigorosos",value:1},{label:"Agitado: movimientos frecuentes sin prop\xf3sito, lucha con el ventilador",value:2},{label:"Muy agitado: se retira tubos o cat\xe9teres, agresivo",value:3},{label:"Combativo: violento, peligro inmediato para el personal",value:4}]}],interpretaciones:[{rango:[-5,-5],label:"No despertable",color:"#DC2626",descripcion:"Sedaci\xf3n excesiva. Valorar reducir o suspender sedantes. Evaluar causas org\xe1nicas de la no respuesta. Monitorizaci\xf3n neurol\xf3gica."},{rango:[-4,-4],label:"Sedaci\xf3n profunda",color:"#DC2626",descripcion:"Solo indicada en situaciones espec\xedficas (SDRA severo, estatus epil\xe9ptico). Valorar necesidad de mantener este nivel o reducir sedaci\xf3n."},{rango:[-3,-3],label:"Sedaci\xf3n moderada",color:"#EA580C",descripcion:"Nivel que puede ser adecuado en las primeras horas de ventilaci\xf3n mec\xe1nica o en procedimientos invasivos. Evaluar transici\xf3n a sedaci\xf3n m\xe1s ligera."},{rango:[-2,-1],label:"Sedaci\xf3n ligera",color:"#F59E0B",descripcion:"Nivel objetivo habitual de sedaci\xf3n en UCI. El paciente puede colaborar y se facilita el destete de la ventilaci\xf3n mec\xe1nica."},{rango:[0,0],label:"Alerta y tranquilo",color:"#16A34A",descripcion:"Estado \xf3ptimo. El paciente est\xe1 despierto, tranquilo y cooperador. Es el objetivo ideal de sedaci\xf3n en la mayor\xeda de pacientes."},{rango:[1,1],label:"Inquieto",color:"#F59E0B",descripcion:"Inquietud leve. Identificar y tratar posibles causas (dolor, ansiedad, delirium, falta de sue\xf1o). Valorar medidas no farmacol\xf3gicas."},{rango:[2,2],label:"Agitado",color:"#EA580C",descripcion:"Agitaci\xf3n moderada. Buscar causas reversibles (dolor, hipoxia, retenci\xf3n urinaria, abstinencia). Considerar tratamiento farmacol\xf3gico si no hay causa tratable."},{rango:[3,4],label:"Muy agitado / Combativo",color:"#DC2626",descripcion:"Agitaci\xf3n severa con riesgo para el paciente y personal. Requiere intervenci\xf3n farmacol\xf3gica inmediata y medidas de seguridad. Descartar causas org\xe1nicas urgentes."}],rangoTotal:[-5,4],contextoClinico:"Escala de referencia en UCI para monitorizar el nivel de sedaci\xf3n-agitaci\xf3n del paciente cr\xedtico. Se eval\xfaa junto con la escala CAM-ICU para el diagn\xf3stico de delirium. Objetivo habitual: RASS entre -2 y 0.",referencia:"Sessler CN, Gosnell MS, Grap MJ, et al. The Richmond Agitation-Sedation Scale: validity and reliability in adult intensive care unit patients. Am J Respir Crit Care Med. 2002;166(10):1338-1344."},{id:"scale_eva",nombre:"Escala Visual Anal\xf3gica del Dolor",abreviatura:"EVA",descripcion:"Escala unidimensional que permite al paciente cuantificar la intensidad de su dolor en una l\xednea de 0 (sin dolor) a 10 (peor dolor imaginable).",tipo:"selector",categoria:"dolor",componentes:[{nombre:"Intensidad del dolor",opciones:[{label:"Sin dolor",value:0},{label:"Dolor muy leve, apenas perceptible",value:1},{label:"Dolor leve, molestia menor",value:2},{label:"Dolor leve, tolerable y no interfiere con actividades",value:3},{label:"Dolor moderado, interfiere con algunas actividades",value:4},{label:"Dolor moderado, interfiere con muchas actividades",value:5},{label:"Dolor moderado-severo, interfiere con la vida diaria",value:6},{label:"Dolor severo, dificulta la concentraci\xf3n",value:7},{label:"Dolor muy severo, afecta severamente las actividades",value:8},{label:"Dolor insoportable, requiere atenci\xf3n inmediata",value:9},{label:"Peor dolor imaginable, completamente incapacitante",value:10}]}],interpretaciones:[{rango:[0,0],label:"Sin dolor",color:"#16A34A",descripcion:"El paciente no refiere dolor. Mantener reevaluaci\xf3n peri\xf3dica."},{rango:[1,3],label:"Dolor leve",color:"#16A34A",descripcion:"Dolor tolerable que generalmente no requiere analgesia o puede tratarse con analg\xe9sicos no opioides (paracetamol, AINEs). Primer escal\xf3n de la OMS."},{rango:[4,6],label:"Dolor moderado",color:"#F59E0B",descripcion:"Requiere tratamiento analg\xe9sico activo. Segundo escal\xf3n de la OMS: analg\xe9sicos no opioides \xb1 opioides d\xe9biles (tramadol, code\xedna). Reevaluar en 30-60 minutos."},{rango:[7,10],label:"Dolor severo",color:"#DC2626",descripcion:"Dolor intenso que requiere intervenci\xf3n urgente. Tercer escal\xf3n de la OMS: opioides potentes (morfina, fentanilo). Reevaluar en 15-30 minutos tras administraci\xf3n."}],rangoTotal:[0,10],contextoClinico:"Quinta constante vital. Se aplica en toda valoraci\xf3n de enfermer\xeda y seguimiento del paciente con dolor. Reevaluar tras cada intervenci\xf3n analg\xe9sica para verificar eficacia del tratamiento.",referencia:"Huskisson EC. Measurement of pain. Lancet. 1974;2(7889):1127-1131."},{id:"scale_mallampati",nombre:"Clasificaci\xf3n de Mallampati",abreviatura:"Mallampati",descripcion:"Clasificaci\xf3n de la v\xeda a\xe9rea que predice la dificultad de intubaci\xf3n orotraqueal seg\xfan la visualizaci\xf3n de las estructuras far\xedngeas con la boca abierta.",tipo:"selector",categoria:"via_aerea",componentes:[{nombre:"Clase de Mallampati",opciones:[{label:"Clase I: paladar blando, \xfavula, fauces y pilares visibles completamente",value:1},{label:"Clase II: paladar blando, \xfavula y fauces visibles",value:2},{label:"Clase III: solo paladar blando y base de \xfavula visibles",value:3},{label:"Clase IV: solo paladar duro visible, paladar blando no visible",value:4}]}],interpretaciones:[{rango:[1,1],label:"Clase I - Intubaci\xf3n f\xe1cil",color:"#16A34A",descripcion:"Visualizaci\xf3n completa de las estructuras. Se prev\xe9 intubaci\xf3n sin dificultad con laringoscopia directa. Cormack-Lehane grado I esperado."},{rango:[2,2],label:"Clase II - Intubaci\xf3n probable sin dificultad",color:"#16A34A",descripcion:"Buena visualizaci\xf3n de estructuras. Intubaci\xf3n probablemente exitosa con laringoscopia directa convencional."},{rango:[3,3],label:"Clase III - Intubaci\xf3n posiblemente dif\xedcil",color:"#F59E0B",descripcion:"Visualizaci\xf3n limitada. Mayor probabilidad de intubaci\xf3n dif\xedcil. Tener preparado dispositivo supragl\xf3tico y videolaringoscopio como alternativa."},{rango:[4,4],label:"Clase IV - Intubaci\xf3n previsiblemente dif\xedcil",color:"#DC2626",descripcion:"No se visualizan estructuras far\xedngeas. Alto riesgo de intubaci\xf3n dif\xedcil. Planificar v\xeda a\xe9rea dif\xedcil: fibroscopio, videolaringoscopio, considerar intubaci\xf3n con paciente despierto."}],rangoTotal:[1,4],contextoClinico:"Se valora en la consulta preanest\xe9sica y antes de cualquier procedimiento que requiera intubaci\xf3n orotraqueal. Debe combinarse con otros predictores de v\xeda a\xe9rea dif\xedcil (distancia tiromentoniana, apertura oral, movilidad cervical).",referencia:"Mallampati SR, Gatt SP, Gugino LD, et al. A clinical sign to predict difficult tracheal intubation: a prospective study. Can Anaesth Soc J. 1985;32(4):429-434."},{id:"scale_asa",nombre:"Clasificaci\xf3n ASA del Estado F\xedsico",abreviatura:"ASA",descripcion:"Sistema de clasificaci\xf3n de la American Society of Anesthesiologists que eval\xfaa el estado f\xedsico del paciente antes de la cirug\xeda para estimar el riesgo anest\xe9sico.",tipo:"selector",categoria:"asa",componentes:[{nombre:"Estado f\xedsico ASA",opciones:[{label:"ASA I: Paciente sano, sin patolog\xeda previa",value:1},{label:"ASA II: Enfermedad sist\xe9mica leve, sin limitaci\xf3n funcional (p. ej., HTA controlada, DM controlada, obesidad leve, tabaquismo)",value:2},{label:"ASA III: Enfermedad sist\xe9mica grave con limitaci\xf3n funcional (p. ej., DM con complicaciones, ICC compensada, EPOC moderada, obesidad m\xf3rbida)",value:3},{label:"ASA IV: Enfermedad sist\xe9mica grave que amenaza la vida (p. ej., ICC descompensada, insuficiencia renal en di\xe1lisis, sepsis, IAM reciente)",value:4},{label:"ASA V: Paciente moribundo que no se espera que sobreviva sin la intervenci\xf3n (p. ej., aneurisma a\xf3rtico roto, TCE con herniaci\xf3n, fallo multiorg\xe1nico)",value:5},{label:"ASA VI: Paciente con muerte cerebral declarada, donante de \xf3rganos",value:6}]}],interpretaciones:[{rango:[1,1],label:"ASA I - Paciente sano",color:"#16A34A",descripcion:"Sin comorbilidades. Riesgo anest\xe9sico m\xednimo. No fumador, no o m\xednimo consumo de alcohol."},{rango:[2,2],label:"ASA II - Enfermedad sist\xe9mica leve",color:"#16A34A",descripcion:"Enfermedad leve sin limitaci\xf3n funcional significativa. Incluye fumador activo, bebedor social, embarazo, obesidad (30<IMC<40), HTA o DM bien controladas."},{rango:[3,3],label:"ASA III - Enfermedad sist\xe9mica grave",color:"#F59E0B",descripcion:"Limitaci\xf3n funcional sustantiva. Riesgo anest\xe9sico moderado. Puede requerir optimizaci\xf3n preoperatoria y planificaci\xf3n anest\xe9sica espec\xedfica."},{rango:[4,4],label:"ASA IV - Amenaza vital constante",color:"#EA580C",descripcion:"Alto riesgo anest\xe9sico y quir\xfargico. Requiere valoraci\xf3n exhaustiva y optimizaci\xf3n preoperatoria. Discusi\xf3n riesgo-beneficio con paciente y familia."},{rango:[5,5],label:"ASA V - Paciente moribundo",color:"#DC2626",descripcion:"No se espera supervivencia sin cirug\xeda. Riesgo extremo. La cirug\xeda es el \xfaltimo recurso terap\xe9utico."},{rango:[6,6],label:"ASA VI - Muerte cerebral",color:"#DC2626",descripcion:"Paciente con muerte cerebral declarada cuya cirug\xeda es para la extracci\xf3n de \xf3rganos para donaci\xf3n."}],rangoTotal:[1,6],contextoClinico:"Se asigna en la consulta preanest\xe9sica a todo paciente que va a ser sometido a un procedimiento anest\xe9sico. Se a\xf1ade el sufijo 'E' si la cirug\xeda es de emergencia (p. ej., ASA III-E).",referencia:"American Society of Anesthesiologists. ASA Physical Status Classification System. Last approved October 2019."},{id:"scale_wells",nombre:"Escala de Wells para TVP/TEP",abreviatura:"Wells",descripcion:"Modelo de predicci\xf3n cl\xednica que estima la probabilidad pretest de trombosis venosa profunda (TVP) o tromboembolismo pulmonar (TEP) mediante criterios cl\xednicos ponderados.",tipo:"checklist",categoria:"trombosis",componentes:[{nombre:"C\xe1ncer activo (tratamiento en curso, en los \xfaltimos 6 meses o paliativo)",opciones:[{label:"No",value:0},{label:"S\xed",value:1}]},{nombre:"Par\xe1lisis, paresia o inmovilizaci\xf3n reciente de MMII",opciones:[{label:"No",value:0},{label:"S\xed",value:1}]},{nombre:"Encamamiento >3 d\xedas o cirug\xeda mayor en las \xfaltimas 12 semanas",opciones:[{label:"No",value:0},{label:"S\xed",value:1}]},{nombre:"Dolor localizado a lo largo del sistema venoso profundo",opciones:[{label:"No",value:0},{label:"S\xed",value:1}]},{nombre:"Edema en toda la pierna",opciones:[{label:"No",value:0},{label:"S\xed",value:1}]},{nombre:"Hinchaz\xf3n de pantorrilla >3 cm respecto a la contralateral",opciones:[{label:"No",value:0},{label:"S\xed",value:1}]},{nombre:"Edema con f\xf3vea (mayor en la pierna sintom\xe1tica)",opciones:[{label:"No",value:0},{label:"S\xed",value:1}]},{nombre:"Venas superficiales colaterales (no varicosas)",opciones:[{label:"No",value:0},{label:"S\xed",value:1}]},{nombre:"TVP previa documentada",opciones:[{label:"No",value:0},{label:"S\xed",value:1}]},{nombre:"Diagn\xf3stico alternativo tan o m\xe1s probable que TVP",opciones:[{label:"No",value:0},{label:"S\xed (resta puntos)",value:-2}]}],interpretaciones:[{rango:[-2,0],label:"Baja probabilidad",color:"#16A34A",descripcion:"Probabilidad de TVP ~5%. Solicitar d\xedmero D: si es negativo, se descarta TVP. Si es positivo, realizar ecograf\xeda Doppler venosa."},{rango:[1,2],label:"Probabilidad moderada",color:"#F59E0B",descripcion:"Probabilidad de TVP ~17%. Solicitar d\xedmero D y ecograf\xeda Doppler venosa. Si d\xedmero D negativo con baja sospecha, se puede descartar."},{rango:[3,9],label:"Alta probabilidad",color:"#DC2626",descripcion:"Probabilidad de TVP ~53%. Realizar ecograf\xeda Doppler venosa de forma urgente. Considerar inicio de anticoagulaci\xf3n emp\xedrica mientras se confirma diagn\xf3stico."}],rangoTotal:[-2,9],contextoClinico:"Se aplica en urgencias ante sospecha cl\xednica de trombosis venosa profunda para estratificar el riesgo y guiar las pruebas diagn\xf3sticas. Debe combinarse con d\xedmero D y ecograf\xeda Doppler seg\xfan el resultado.",referencia:"Wells PS, Anderson DR, Bormanis J, et al. Value of assessment of pretest probability of deep-vein thrombosis in clinical management. Lancet. 1997;350(9094):1795-1798."},{id:"scale_qsofa",nombre:"Quick SOFA",abreviatura:"qSOFA",descripcion:"Herramienta de cribado r\xe1pido para identificar pacientes con sospecha de infecci\xf3n que tienen alto riesgo de mala evoluci\xf3n (sepsis) fuera de la UCI.",tipo:"checklist",categoria:"sepsis",componentes:[{nombre:"Frecuencia respiratoria \u226522 rpm",opciones:[{label:"No",value:0},{label:"S\xed",value:1}]},{nombre:"Presi\xf3n arterial sist\xf3lica \u2264100 mmHg",opciones:[{label:"No",value:0},{label:"S\xed",value:1}]},{nombre:"Alteraci\xf3n del nivel de conciencia (GCS <15)",opciones:[{label:"No",value:0},{label:"S\xed",value:1}]}],interpretaciones:[{rango:[0,1],label:"Bajo riesgo",color:"#16A34A",descripcion:"Bajo riesgo de mala evoluci\xf3n. No descarta sepsis. Continuar vigilancia cl\xednica y reevaluar si hay deterioro. Completar estudio si hay sospecha cl\xednica de infecci\xf3n."},{rango:[2,3],label:"Alto riesgo de sepsis",color:"#DC2626",descripcion:"Alto riesgo de mortalidad hospitalaria. Activar protocolo de sepsis: hemocultivos, lactato s\xe9rico, antibioterapia emp\xedrica precoz y fluidoterapia agresiva en la primera hora. Valorar ingreso en UCI."}],rangoTotal:[0,3],contextoClinico:"Herramienta de cribado a pie de cama para identificar r\xe1pidamente pacientes con sospecha de infecci\xf3n y riesgo de sepsis fuera de la UCI. No es diagn\xf3stica, sino una se\xf1al de alarma para iniciar evaluaci\xf3n y tratamiento urgente.",referencia:"Singer M, Deutschman CS, Seymour CW, et al. The Third International Consensus Definitions for Sepsis and Septic Shock (Sepsis-3). JAMA. 2016;315(8):801-810."},{id:"scale_morse",nombre:"Escala de Ca\xeddas de Morse",abreviatura:"MFS",descripcion:"Escala de valoraci\xf3n del riesgo de ca\xeddas en pacientes hospitalizados. Eval\xfaa seis factores de riesgo para identificar pacientes que requieren medidas preventivas.",tipo:"components",categoria:"caidas",componentes:[{nombre:"Antecedente de ca\xeddas (\xfaltimos 3 meses)",opciones:[{label:"No",value:0},{label:"S\xed",value:25}]},{nombre:"Diagn\xf3stico secundario",opciones:[{label:"No",value:0},{label:"S\xed",value:15}]},{nombre:"Ayuda para deambulaci\xf3n",opciones:[{label:"Ninguna / reposo en cama / ayuda de enfermer\xeda",value:0},{label:"Muletas / bast\xf3n / andador",value:15},{label:"Se apoya en muebles",value:30}]},{nombre:"Terapia intravenosa / dispositivo IV",opciones:[{label:"No",value:0},{label:"S\xed",value:20}]},{nombre:"Marcha",opciones:[{label:"Normal / reposo en cama / silla de ruedas",value:0},{label:"D\xe9bil",value:10},{label:"Alterada / tambaleante",value:20}]},{nombre:"Estado mental",opciones:[{label:"Consciente de sus limitaciones",value:0},{label:"Sobrevalora sus capacidades / olvida limitaciones",value:15}]}],interpretaciones:[{rango:[0,24],label:"Riesgo bajo",color:"#16A34A",descripcion:"Medidas est\xe1ndar de seguridad: cama en posici\xf3n baja, frenos activados, luz nocturna, timbre al alcance."},{rango:[25,44],label:"Riesgo moderado",color:"#F59E0B",descripcion:"Implementar protocolo de prevenci\xf3n: identificaci\xf3n visual (pulsera/cartel), acompa\xf1amiento en deambulaci\xf3n, revisi\xf3n de medicaci\xf3n, calzado antideslizante."},{rango:[45,125],label:"Riesgo alto",color:"#DC2626",descripcion:"Todas las medidas anteriores m\xe1s: valoraci\xf3n frecuente, posible sensor de movimiento, fisioterapia, revisi\xf3n de f\xe1rmacos de riesgo (sedantes, hipotensores, diur\xe9ticos). Considerar contenci\xf3n si agitaci\xf3n."}],rangoTotal:[0,125],contextoClinico:"Escala m\xe1s utilizada internacionalmente para valorar el riesgo de ca\xeddas en pacientes hospitalizados. Debe reevaluarse al ingreso, en cada turno y ante cambios en el estado del paciente. Las ca\xeddas son un indicador de calidad asistencial.",referencia:"Morse JM, Morse RM, Tylko SJ. Development of a scale to identify the fall-prone patient. Canadian Journal on Aging. 1989;8(4):366-377."},{id:"scale_barthel",nombre:"\xcdndice de Barthel",abreviatura:"IB",descripcion:"Escala de valoraci\xf3n funcional que mide la capacidad para realizar actividades b\xe1sicas de la vida diaria (ABVD). Eval\xfaa el grado de independencia del paciente.",tipo:"components",categoria:"funcional",componentes:[{nombre:"Alimentaci\xf3n",opciones:[{label:"Incapaz",value:0},{label:"Necesita ayuda (cortar, extender mantequilla)",value:5},{label:"Independiente",value:10}]},{nombre:"Ba\xf1o",opciones:[{label:"Dependiente",value:0},{label:"Independiente",value:5}]},{nombre:"Aseo personal",opciones:[{label:"Necesita ayuda",value:0},{label:"Independiente (cara, pelo, dientes, afeitado)",value:5}]},{nombre:"Vestirse",opciones:[{label:"Dependiente",value:0},{label:"Necesita ayuda (al menos la mitad)",value:5},{label:"Independiente (incluye botones, cremalleras)",value:10}]},{nombre:"Control de heces",opciones:[{label:"Incontinente",value:0},{label:"Accidente ocasional",value:5},{label:"Continente",value:10}]},{nombre:"Control de orina",opciones:[{label:"Incontinente o sondado",value:0},{label:"Accidente ocasional",value:5},{label:"Continente",value:10}]},{nombre:"Uso del retrete",opciones:[{label:"Dependiente",value:0},{label:"Necesita alguna ayuda",value:5},{label:"Independiente",value:10}]},{nombre:"Traslado cama-sill\xf3n",opciones:[{label:"Incapaz / no se mantiene sentado",value:0},{label:"Gran ayuda (persona fuerte o dos)",value:5},{label:"M\xednima ayuda (supervisi\xf3n o peque\xf1a ayuda)",value:10},{label:"Independiente",value:15}]},{nombre:"Deambulaci\xf3n",opciones:[{label:"Inm\xf3vil o <50 metros",value:0},{label:"Independiente en silla de ruedas >50 m",value:5},{label:"Camina con ayuda (persona) >50 m",value:10},{label:"Independiente >50 m (puede usar bast\xf3n)",value:15}]},{nombre:"Subir escaleras",opciones:[{label:"Incapaz",value:0},{label:"Necesita ayuda (f\xedsica o verbal)",value:5},{label:"Independiente",value:10}]}],interpretaciones:[{rango:[0,20],label:"Dependencia total",color:"#DC2626",descripcion:"Paciente totalmente dependiente para ABVD. Requiere cuidados integrales de enfermer\xeda, valorar institucionalizaci\xf3n o recursos sociosanitarios. Plan de cuidados individualizado."},{rango:[21,60],label:"Dependencia severa",color:"#EA580C",descripcion:"Necesita ayuda importante en la mayor\xeda de actividades. Rehabilitaci\xf3n activa, prevenci\xf3n de \xfalceras por presi\xf3n, movilizaci\xf3n precoz. Valorar cuidador principal."},{rango:[61,90],label:"Dependencia moderada",color:"#F59E0B",descripcion:"Requiere asistencia en algunas actividades. Programa de rehabilitaci\xf3n para mejorar independencia. Fomentar autonom\xeda progresiva."},{rango:[91,99],label:"Dependencia escasa",color:"#3B82F6",descripcion:"Pr\xe1cticamente independiente. Supervisi\xf3n m\xednima, refuerzo de actividades con peque\xf1a dificultad."},{rango:[100,100],label:"Independiente",color:"#16A34A",descripcion:"Independiente para todas las ABVD. No implica vivir solo; significa autonom\xeda funcional."}],rangoTotal:[0,100],contextoClinico:"Escala de referencia para valoraci\xf3n funcional en geriatr\xeda, rehabilitaci\xf3n y atenci\xf3n domiciliaria. Se eval\xfaa al ingreso, peri\xf3dicamente y al alta. Un descenso >20 puntos indica deterioro funcional significativo. Ampliamente usada como criterio de resultado en rehabilitaci\xf3n.",referencia:"Mahoney FI, Barthel DW. Functional evaluation: the Barthel Index. Maryland State Medical Journal. 1965;14:61-65."},{id:"scale_flacc",nombre:"Escala FLACC",abreviatura:"FLACC",descripcion:"Escala de valoraci\xf3n del dolor en pacientes pedi\xe1tricos (2 meses-7 a\xf1os) o no comunicativos, basada en la observaci\xf3n de cinco par\xe1metros conductuales.",tipo:"components",categoria:"dolor_pediatrico",componentes:[{nombre:"Face (Cara)",opciones:[{label:"Sin expresi\xf3n particular, sonrisa",value:0},{label:"Mueca o ce\xf1o fruncido ocasional, retra\xeddo",value:1},{label:"Temblor frecuente del ment\xf3n, mand\xedbula apretada",value:2}]},{nombre:"Legs (Piernas)",opciones:[{label:"Posici\xf3n normal o relajada",value:0},{label:"Inquietas, agitadas, tensas",value:1},{label:"Pataleo o piernas encogidas",value:2}]},{nombre:"Activity (Actividad)",opciones:[{label:"Acostado tranquilo, posici\xf3n normal, se mueve con facilidad",value:0},{label:"Se retuerce, se balancea, tenso",value:1},{label:"Arqueado, r\xedgido o con sacudidas",value:2}]},{nombre:"Cry (Llanto)",opciones:[{label:"No llora (despierto o dormido)",value:0},{label:"Gemidos o lloriqueos, queja ocasional",value:1},{label:"Llanto constante, gritos o sollozos frecuentes",value:2}]},{nombre:"Consolability (Consolabilidad)",opciones:[{label:"Contento, relajado",value:0},{label:"Se tranquiliza con contacto, abrazo, voz; distra\xedble",value:1},{label:"Dif\xedcil de consolar",value:2}]}],interpretaciones:[{rango:[0,0],label:"Sin dolor",color:"#16A34A",descripcion:"No se observan signos de dolor. Continuar vigilancia y reevaluar si hay cambios en procedimientos o estado cl\xednico."},{rango:[1,3],label:"Dolor leve \u2013 disconfort",color:"#3B82F6",descripcion:"Considerar medidas no farmacol\xf3gicas: contenci\xf3n, succi\xf3n no nutritiva, contacto piel con piel, distracci\xf3n."},{rango:[4,6],label:"Dolor moderado",color:"#F59E0B",descripcion:"Iniciar analgesia seg\xfan prescripci\xf3n (paracetamol, ibuprofeno). Reevaluar en 30-60 minutos tras intervenci\xf3n. Combinar con medidas no farmacol\xf3gicas."},{rango:[7,10],label:"Dolor severo",color:"#DC2626",descripcion:"Analgesia urgente requerida. Considerar opioides si dolor no controlado. Alertar al equipo m\xe9dico. Reevaluar frecuentemente cada 15-30 minutos."}],rangoTotal:[0,10],contextoClinico:"Escala est\xe1ndar de dolor para ni\xf1os de 2 meses a 7 a\xf1os y pacientes no comunicativos (intubados, con alteraci\xf3n cognitiva). Se valora observando al paciente durante 1-5 minutos. Reevaluar antes y despu\xe9s de intervenciones analg\xe9sicas. FLACC = Face, Legs, Activity, Cry, Consolability.",referencia:"Merkel SI, Voepel-Lewis T, Shayevitz JR, Malviya S. The FLACC: a behavioral scale for scoring postoperative pain in young children. Pediatric Nursing. 1997;23(3):293-297."},{id:"scale_must",nombre:"MUST \u2013 Screening Nutricional",abreviatura:"MUST",descripcion:"Herramienta de cribado nutricional universal (Malnutrition Universal Screening Tool) para identificar pacientes adultos con riesgo de desnutrici\xf3n o desnutrici\xf3n establecida.",tipo:"components",categoria:"nutricion",componentes:[{nombre:"IMC (\xcdndice de Masa Corporal)",opciones:[{label:">20 kg/m\xb2 (>30 si obeso)",value:0},{label:"18.5\u201320 kg/m\xb2",value:1},{label:"<18.5 kg/m\xb2",value:2}]},{nombre:"P\xe9rdida de peso involuntaria (\xfaltimos 3-6 meses)",opciones:[{label:"<5%",value:0},{label:"5\u201310%",value:1},{label:">10%",value:2}]},{nombre:"Efecto de enfermedad aguda",opciones:[{label:"No hay enfermedad aguda que afecte ingesta >5 d\xedas",value:0},{label:"Ingesta nula o casi nula >5 d\xedas (o riesgo de no ingesta)",value:2}]}],interpretaciones:[{rango:[0,0],label:"Riesgo bajo",color:"#16A34A",descripcion:"Cuidados rutinarios. Reevaluar semanalmente en hospitalizados, mensualmente en residencias, anualmente en comunidad. Continuar con dieta normal."},{rango:[1,1],label:"Riesgo medio",color:"#F59E0B",descripcion:"Observar: documentar ingesta alimentaria durante 3 d\xedas. Si la ingesta es adecuada, continuar observando. Si es inadecuada, iniciar plan nutricional. Reevaluar semanalmente."},{rango:[2,6],label:"Riesgo alto",color:"#DC2626",descripcion:"Tratar: derivar a nutricionista/dietista. Iniciar suplementos nutricionales orales. Considerar alimentaci\xf3n enteral si no tolera v\xeda oral. Monitorizar ingesta y peso. Reevaluar plan semanalmente."}],rangoTotal:[0,6],contextoClinico:"Herramienta de cribado recomendada por ESPEN y NICE para todos los pacientes al ingreso hospitalario. R\xe1pida de aplicar (3-5 min). Se debe complementar con valoraci\xf3n nutricional completa en pacientes con riesgo medio-alto. La desnutrici\xf3n hospitalaria afecta al 20-40% de los pacientes ingresados.",referencia:"Stratton RJ, Hackston A, Longmore D, et al. Malnutrition in hospital outpatients and inpatients: prevalence, concurrent validity and ease of use of the 'malnutrition universal screening tool' (MUST) for adults. British Journal of Nutrition. 2004;92(5):799-808."}]},800,[]);
__d(function(a,i,e,o,r,n,s){r.exports=[{id:"lab_hemoglobina",nombre:"Hemoglobina",abreviatura:"Hb",categoria:"hematologia",rangos:{adultoHombre:{min:13.5,max:17.5,unidad:"g/dL"},adultoMujer:{min:12,max:16,unidad:"g/dL"},pediatrico:{min:11,max:16,unidad:"g/dL"}},significadoAlto:"Puede indicar policitemia, deshidrataci\xf3n, enfermedad pulmonar cr\xf3nica o cardiopat\xedas cong\xe9nitas cian\xf3ticas.",significadoBajo:"Indica anemia de diversa etiolog\xeda (ferrop\xe9nica, megalobl\xe1stica, hemol\xedtica), hemorragia aguda o cr\xf3nica, o estados de sobrehidrataci\xf3n.",farmacosAlteran:["Eritropoyetina","Metotrexato","Zidovudina","Cloranfenicol","Hierro IV"],implicacionesEnfermeria:["Monitorizar signos de anemia: palidez, taquicardia, disnea y fatiga","Controlar signos vitales antes y durante transfusiones sangu\xedneas","Educar al paciente sobre alimentos ricos en hierro si hay d\xe9ficit","Vigilar signos de sangrado activo en valores descendentes"]},{id:"lab_hematocrito",nombre:"Hematocrito",abreviatura:"Hto",categoria:"hematologia",rangos:{adultoHombre:{min:40,max:54,unidad:"%"},adultoMujer:{min:36,max:48,unidad:"%"},pediatrico:{min:33,max:45,unidad:"%"}},significadoAlto:"Sugiere hemoconcentraci\xf3n por deshidrataci\xf3n, policitemia vera o eritrocitosis secundaria a hipoxia cr\xf3nica.",significadoBajo:"Indica anemia, hemorragia, sobrehidrataci\xf3n o destrucci\xf3n acelerada de eritrocitos (hem\xf3lisis).",farmacosAlteran:["Eritropoyetina","Diur\xe9ticos","Fluidos IV","Quimioterapia","Anticoagulantes"],implicacionesEnfermeria:["Evaluar estado de hidrataci\xf3n del paciente junto con el valor","Correlacionar con hemoglobina para valorar la severidad de la anemia","Monitorizar balance h\xeddrico en pacientes con valores alterados"]},{id:"lab_leucocitos",nombre:"Leucocitos",abreviatura:"WBC",categoria:"hematologia",rangos:{adulto:{min:4500,max:11e3,unidad:"c\xe9lulas/\xb5L"},pediatrico:{min:5e3,max:15e3,unidad:"c\xe9lulas/\xb5L"}},significadoAlto:"Leucocitosis: puede indicar infecci\xf3n bacteriana, inflamaci\xf3n, estr\xe9s, leucemia o respuesta a corticoides.",significadoBajo:"Leucopenia: sugiere inmunosupresi\xf3n, aplasia medular, infecciones virales graves o efecto de quimioterapia.",farmacosAlteran:["Corticosteroides","Quimioterapia","Antibi\xf3ticos","Litio","Filgrastim"],implicacionesEnfermeria:["Implementar precauciones de aislamiento en leucopenia severa (<1000/\xb5L)","Vigilar signos de infecci\xf3n: fiebre, escalofr\xedos, eritema","Monitorizar temperatura cada 4 horas en pacientes neutrop\xe9nicos","Educar al paciente sobre medidas de higiene y prevenci\xf3n de infecciones"]},{id:"lab_plaquetas",nombre:"Plaquetas",abreviatura:"PLT",categoria:"hematologia",rangos:{adulto:{min:15e4,max:4e5,unidad:"c\xe9lulas/\xb5L"},pediatrico:{min:15e4,max:45e4,unidad:"c\xe9lulas/\xb5L"}},significadoAlto:"Trombocitosis: puede asociarse a infecciones, inflamaci\xf3n cr\xf3nica, d\xe9ficit de hierro, esplenectom\xeda o trastornos mieloproliferativos.",significadoBajo:"Trombocitopenia: riesgo de sangrado; causas incluyen PTI, CID, hiperesplenismo, quimioterapia o f\xe1rmacos.",farmacosAlteran:["Heparina","Quimioterapia","\xc1cido valproico","AINEs","Vancomicina"],implicacionesEnfermeria:["Vigilar signos de sangrado: petequias, equimosis, epistaxis, hematuria","Evitar punciones innecesarias y aplicar presi\xf3n prolongada en sitios de punci\xf3n","Alertar si plaquetas <50000 (riesgo de sangrado) o <20000 (sangrado espont\xe1neo)","Instruir al paciente a usar cepillo dental suave y maquinilla el\xe9ctrica"]},{id:"lab_eritrocitos",nombre:"Eritrocitos",abreviatura:"RBC",categoria:"hematologia",rangos:{adultoHombre:{min:4.5,max:5.5,unidad:"millones/\xb5L"},adultoMujer:{min:4,max:5,unidad:"millones/\xb5L"},pediatrico:{min:3.8,max:5.5,unidad:"millones/\xb5L"}},significadoAlto:"Eritrocitosis: puede deberse a policitemia vera, hipoxia cr\xf3nica (EPOC, altitud), deshidrataci\xf3n o tumores productores de eritropoyetina.",significadoBajo:"Sugiere anemia de cualquier tipo, hemorragia, hem\xf3lisis o insuficiencia medular.",farmacosAlteran:["Eritropoyetina","Metotrexato","Cloranfenicol","Zidovudina","Hidroxiurea"],implicacionesEnfermeria:["Correlacionar con hemoglobina y hematocrito para evaluar anemia","Valorar s\xedntomas de hipoxia tisular: disnea, fatiga, mareos","Controlar dieta y suplementaci\xf3n en anemias carenciales"]},{id:"lab_vcm",nombre:"Volumen Corpuscular Medio",abreviatura:"VCM",categoria:"hematologia",rangos:{adulto:{min:80,max:100,unidad:"fL"},pediatrico:{min:70,max:95,unidad:"fL"}},significadoAlto:"Macrocitosis: asociada a d\xe9ficit de vitamina B12 o \xe1cido f\xf3lico, alcoholismo, hipotiroidismo o s\xedndromes mielodispl\xe1sicos.",significadoBajo:"Microcitosis: sugiere anemia ferrop\xe9nica, talasemia o anemia de enfermedad cr\xf3nica.",farmacosAlteran:["Metotrexato","Fenito\xedna","Zidovudina","Hidroxiurea","Trimetoprim"],implicacionesEnfermeria:["Utilizar el VCM para orientar el tipo de anemia y guiar la educaci\xf3n al paciente","Correlacionar con niveles de hierro, B12 y \xe1cido f\xf3lico seg\xfan corresponda","Informar al m\xe9dico sobre cambios significativos en el VCM durante tratamientos"]},{id:"lab_hcm",nombre:"Hemoglobina Corpuscular Media",abreviatura:"HCM",categoria:"hematologia",rangos:{adulto:{min:27,max:33,unidad:"pg"}},significadoAlto:"Hipercrom\xeda: puede asociarse a anemias megalobl\xe1sticas por d\xe9ficit de B12 o folato, o esferocitosis hereditaria.",significadoBajo:"Hipocrom\xeda: indica deficiencia de hierro o talasemia; los eritrocitos contienen menos hemoglobina de lo normal.",farmacosAlteran:["Hierro oral/IV","\xc1cido f\xf3lico","Vitamina B12","Metotrexato","Fenito\xedna"],implicacionesEnfermeria:["Complementar la valoraci\xf3n con VCM y CHCM para clasificar anemias","Educar sobre la importancia de la adherencia al tratamiento con hierro o vitaminas","Monitorizar respuesta al tratamiento con controles seriados"]},{id:"lab_reticulocitos",nombre:"Reticulocitos",abreviatura:"Ret",categoria:"hematologia",rangos:{adulto:{min:.5,max:2.5,unidad:"%"}},significadoAlto:"Indica respuesta medular activa: recuperaci\xf3n de anemia, hemorragia reciente, hem\xf3lisis o respuesta a tratamiento con hierro/EPO.",significadoBajo:"Sugiere producci\xf3n medular inadecuada: aplasia medular, anemia megalobl\xe1stica, infiltraci\xf3n tumoral o efecto de quimioterapia.",farmacosAlteran:["Eritropoyetina","Hierro IV","Quimioterapia","Cloranfenicol","\xc1cido f\xf3lico"],implicacionesEnfermeria:["Utilizar como indicador de respuesta al tratamiento antian\xe9mico","Esperar elevaci\xf3n a los 5-7 d\xedas de inicio de tratamiento con hierro","Informar valores bajos persistentes al equipo m\xe9dico"]},{id:"lab_glucosa",nombre:"Glucosa en ayunas",abreviatura:"Glu",categoria:"bioquimica",rangos:{adulto:{min:70,max:100,unidad:"mg/dL"},pediatrico:{min:60,max:100,unidad:"mg/dL"}},significadoAlto:"Hiperglucemia: puede indicar diabetes mellitus, estr\xe9s metab\xf3lico, pancreatitis, s\xedndrome de Cushing o efecto farmacol\xf3gico.",significadoBajo:"Hipoglucemia: riesgo de da\xf1o neurol\xf3gico; causas incluyen sobredosis de insulina, ayuno prolongado, insuficiencia hep\xe1tica o insulinoma.",farmacosAlteran:["Insulina","Metformina","Corticosteroides","Tiazidas","Betabloqueantes"],implicacionesEnfermeria:["Verificar que la muestra sea en ayunas de al menos 8 horas","Monitorizar glucemia capilar seg\xfan protocolo en pacientes diab\xe9ticos","Vigilar signos de hipoglucemia: sudoraci\xf3n, temblor, confusi\xf3n, taquicardia","Educar al paciente sobre el autocontrol gluc\xe9mico y dieta"]},{id:"lab_sodio",nombre:"Sodio",abreviatura:"Na",categoria:"bioquimica",rangos:{adulto:{min:135,max:145,unidad:"mEq/L"},pediatrico:{min:135,max:145,unidad:"mEq/L"}},significadoAlto:"Hipernatremia: indica deshidrataci\xf3n, diabetes ins\xedpida, exceso de ingesta de sodio o p\xe9rdida de agua libre.",significadoBajo:"Hiponatremia: puede causar edema cerebral; asociada a SIADH, insuficiencia card\xedaca, cirrosis, diur\xe9ticos o polidipsia.",farmacosAlteran:["Diur\xe9ticos tiaz\xeddicos","Furosemida","Litio","Carbamazepina","SSRIs"],implicacionesEnfermeria:["Monitorizar estado neurol\xf3gico: confusi\xf3n, letargia, convulsiones","Controlar balance h\xeddrico estricto y peso diario","Corregir lentamente (<10 mEq/L en 24h) para evitar mielin\xf3lisis pontina","Vigilar edema perif\xe9rico y signos de sobrecarga h\xeddrica"]},{id:"lab_potasio",nombre:"Potasio",abreviatura:"K",categoria:"bioquimica",rangos:{adulto:{min:3.5,max:5,unidad:"mEq/L"},pediatrico:{min:3.5,max:5.5,unidad:"mEq/L"}},significadoAlto:"Hiperpotasemia: riesgo de arritmias letales; causas incluyen insuficiencia renal, acidosis, rabdomi\xf3lisis o exceso de suplementos.",significadoBajo:"Hipopotasemia: riesgo de arritmias, debilidad muscular e \xedleo; asociada a v\xf3mitos, diarrea, diur\xe9ticos o alcalosis.",farmacosAlteran:["IECA/ARA-II","Espironolactona","Furosemida","Insulina","Digoxina"],implicacionesEnfermeria:["Monitorizaci\xf3n card\xedaca continua si K >6.0 o <3.0 mEq/L","Verificar funci\xf3n renal antes de administrar suplementos de potasio","Administrar potasio IV diluido y lento (nunca en bolo directo)","Vigilar ECG: ondas T picudas (hiperK) o aplanadas con onda U (hipoK)"]},{id:"lab_calcio",nombre:"Calcio s\xe9rico",abreviatura:"Ca",categoria:"bioquimica",rangos:{adulto:{min:8.5,max:10.5,unidad:"mg/dL"},pediatrico:{min:8.8,max:10.8,unidad:"mg/dL"}},significadoAlto:"Hipercalcemia: puede causar arritmias, confusi\xf3n y coma; asociada a hiperparatiroidismo, met\xe1stasis \xf3seas o intoxicaci\xf3n por vitamina D.",significadoBajo:"Hipocalcemia: causa tetania, espasmos y convulsiones; asociada a hipoparatiroidismo, d\xe9ficit de vitamina D o pancreatitis aguda.",farmacosAlteran:["Tiazidas","Furosemida","Bifosfonatos","Vitamina D","Corticosteroides"],implicacionesEnfermeria:["Valorar signos de Chvostek y Trousseau en hipocalcemia","Monitorizar ECG: QT prolongado (hipoCa) o QT corto (hiperCa)","Asegurar ingesta adecuada de vitamina D para absorci\xf3n del calcio","Mantener precauciones de seguridad por riesgo de convulsiones"]},{id:"lab_magnesio",nombre:"Magnesio",abreviatura:"Mg",categoria:"bioquimica",rangos:{adulto:{min:1.5,max:2.5,unidad:"mg/dL"}},significadoAlto:"Hipermagnesemia: causa hipotensi\xf3n, bradicardia, depresi\xf3n respiratoria y arreflexia; frecuente en insuficiencia renal.",significadoBajo:"Hipomagnesemia: causa arritmias, temblores y convulsiones; asociada a alcoholismo, diarrea cr\xf3nica y uso de diur\xe9ticos.",farmacosAlteran:["Sulfato de magnesio IV","Omeprazol","Furosemida","Aminogluc\xf3sidos","Cisplatino"],implicacionesEnfermeria:["Vigilar reflejos rotulianos durante infusi\xf3n de magnesio IV (preeclampsia)","Monitorizar ECG por riesgo de arritmias en ambas alteraciones","Valorar nivel de conciencia y funci\xf3n respiratoria con niveles altos","Corregir hipomagnesemia antes de tratar hipopotasemia resistente"]},{id:"lab_fosforo",nombre:"F\xf3sforo",abreviatura:"P",categoria:"bioquimica",rangos:{adulto:{min:2.5,max:4.5,unidad:"mg/dL"},pediatrico:{min:4,max:7,unidad:"mg/dL"}},significadoAlto:"Hiperfosfatemia: frecuente en insuficiencia renal cr\xf3nica; causa calcificaciones ect\xf3picas y prurito. Relaci\xf3n inversa con calcio.",significadoBajo:"Hipofosfatemia: causa debilidad muscular, insuficiencia respiratoria y hem\xf3lisis; asociada a realimentaci\xf3n, anti\xe1cidos y alcoholismo.",farmacosAlteran:["Anti\xe1cidos con aluminio","Vitamina D","Sevel\xe1mero","Insulina","Corticosteroides"],implicacionesEnfermeria:["Administrar quelantes de f\xf3sforo con las comidas en insuficiencia renal","Vigilar s\xedndrome de realimentaci\xf3n en pacientes desnutridos","Monitorizar niveles conjuntos de calcio y f\xf3sforo"]},{id:"lab_acido_urico",nombre:"\xc1cido \xfarico",abreviatura:"AU",categoria:"bioquimica",rangos:{adultoHombre:{min:3.4,max:7,unidad:"mg/dL"},adultoMujer:{min:2.4,max:6,unidad:"mg/dL"}},significadoAlto:"Hiperuricemia: riesgo de gota, litiasis renal y nefropat\xeda; asociada a dieta rica en purinas, s\xedndrome de lisis tumoral o insuficiencia renal.",significadoBajo:"Hipouricemia: poco frecuente; puede asociarse a s\xedndrome de Fanconi, enfermedad de Wilson o uso de uricos\xfaricos.",farmacosAlteran:["Alopurinol","Tiazidas","Aspirina a dosis bajas","Quimioterapia","Losart\xe1n"],implicacionesEnfermeria:["Fomentar ingesta h\xeddrica abundante (>2L/d\xeda) para prevenir litiasis","Educar sobre dieta baja en purinas: limitar carnes rojas, mariscos y alcohol","Monitorizar funci\xf3n renal en pacientes con hiperuricemia cr\xf3nica"]},{id:"lab_proteinas_totales",nombre:"Prote\xednas totales",abreviatura:"PT",categoria:"bioquimica",rangos:{adulto:{min:6,max:8.3,unidad:"g/dL"}},significadoAlto:"Hiperproteinemia: asociada a deshidrataci\xf3n, mieloma m\xfaltiple, infecciones cr\xf3nicas o enfermedades autoinmunes.",significadoBajo:"Hipoproteinemia: indica desnutrici\xf3n, s\xedndrome nefr\xf3tico, insuficiencia hep\xe1tica, enteropat\xeda perdedora de prote\xednas o quemaduras extensas.",farmacosAlteran:["Corticosteroides","Estr\xf3genos","Insulina","Hormona de crecimiento","Andr\xf3genos"],implicacionesEnfermeria:["Evaluar estado nutricional y valorar necesidad de soporte nutricional","Monitorizar presencia de edema por disminuci\xf3n de presi\xf3n onc\xf3tica","Correlacionar con alb\xfamina s\xe9rica para valoraci\xf3n nutricional completa"]},{id:"lab_tp_inr",nombre:"Tiempo de Protrombina / INR",abreviatura:"TP/INR",categoria:"coagulacion",rangos:{adulto:{min:.8,max:1.2,unidad:"INR"}},significadoAlto:"INR elevado: mayor riesgo de sangrado; indica deficiencia de factores de coagulaci\xf3n, hepatopat\xeda, d\xe9ficit de vitamina K o efecto de anticoagulantes orales.",significadoBajo:"INR bajo en paciente anticoagulado indica efecto terap\xe9utico insuficiente y mayor riesgo tromb\xf3tico.",farmacosAlteran:["Warfarina","Acenocumarol","Antibi\xf3ticos","Amiodarona","AINEs"],implicacionesEnfermeria:["Rango terap\xe9utico con anticoagulantes orales: INR 2.0-3.0 (v\xe1lvulas mec\xe1nicas: 2.5-3.5)","Vigilar signos de sangrado: hematuria, melenas, epistaxis, equimosis","Educar al paciente sobre interacciones con alimentos ricos en vitamina K","Tener disponible vitamina K y plasma fresco congelado como ant\xeddotos"]},{id:"lab_ttpa",nombre:"Tiempo de Tromboplastina Parcial Activada",abreviatura:"TTPa",categoria:"coagulacion",rangos:{adulto:{min:25,max:35,unidad:"segundos"}},significadoAlto:"TTPa prolongado: indica deficiencia de factores VIII, IX, XI, XII, hemofilia, CID, presencia de anticoagulante l\xfapico o efecto de heparina.",significadoBajo:"TTPa acortado: puede indicar hipercoagulabilidad, trombofilia o fase temprana de CID.",farmacosAlteran:["Heparina no fraccionada","Warfarina","Dabigatr\xe1n","\xc1cido tranex\xe1mico","Factor VII recombinante"],implicacionesEnfermeria:["Objetivo terap\xe9utico con heparina: TTPa 1.5-2.5 veces el valor control","Extraer muestra del brazo contrario a la infusi\xf3n de heparina","Tener disponible protamina como ant\xeddoto de heparina","Monitorizar cada 6 horas durante infusi\xf3n continua de heparina"]},{id:"lab_fibrinogeno",nombre:"Fibrin\xf3geno",abreviatura:"Fib",categoria:"coagulacion",rangos:{adulto:{min:200,max:400,unidad:"mg/dL"}},significadoAlto:"Hiperfibrinogenemia: reactante de fase aguda; elevado en infecciones, inflamaci\xf3n, embarazo, neoplasias y postquir\xfargico.",significadoBajo:"Hipofibrinogenemia: riesgo de sangrado; asociada a CID, fibrin\xf3lisis, hepatopat\xeda grave, transfusi\xf3n masiva o afibrinogenemia cong\xe9nita.",farmacosAlteran:["\xc1cido tranex\xe1mico","Estr\xf3genos","Trombol\xedticos","\xc1cido valproico","L-asparaginasa"],implicacionesEnfermeria:["Valor cr\xedtico <100 mg/dL: alertar inmediatamente al equipo m\xe9dico","Preparar crioprecipitado o concentrado de fibrin\xf3geno si hay sangrado activo","Monitorizar en conjunto con TP, TTPa y plaquetas en sospecha de CID"]},{id:"lab_dimero_d",nombre:"D\xedmero D",abreviatura:"DD",categoria:"coagulacion",rangos:{adulto:{min:0,max:500,unidad:"ng/mL"}},significadoAlto:"Elevado en trombosis venosa profunda, embolia pulmonar, CID, cirug\xeda reciente, embarazo, infecciones y neoplasias. Alta sensibilidad pero baja especificidad.",significadoBajo:"Valores normales tienen alto valor predictivo negativo para descartar eventos tromboemb\xf3licos.",farmacosAlteran:["Anticoagulantes","Trombol\xedticos","Estr\xf3genos","Heparina","\xc1cido tranex\xe1mico"],implicacionesEnfermeria:["Utilizado principalmente para descartar TEP/TVP (alto valor predictivo negativo)","Correlacionar siempre con la cl\xednica del paciente por su baja especificidad","Valorar signos de TVP: edema unilateral, dolor y enrojecimiento en extremidad"]},{id:"lab_tiempo_sangrado",nombre:"Tiempo de sangrado",abreviatura:"TS",categoria:"coagulacion",rangos:{adulto:{min:1,max:9,unidad:"minutos"}},significadoAlto:"Prolongado: indica disfunci\xf3n plaquetaria, enfermedad de von Willebrand, trombocitopenia severa o efecto de antiagregantes.",significadoBajo:"No tiene significado cl\xednico relevante; la hemostasia primaria funciona adecuadamente.",farmacosAlteran:["Aspirina","Clopidogrel","AINEs","Ticagrelor","Dipiridamol"],implicacionesEnfermeria:["Realizar prueba antes de procedimientos invasivos en pacientes con riesgo","Suspender antiagregantes seg\xfan protocolo prequir\xfargico (aspirina 7 d\xedas, clopidogrel 5 d\xedas)","Aplicar presi\xf3n sostenida en sitios de punci\xf3n si est\xe1 prolongado"]},{id:"lab_alt",nombre:"Alanina Aminotransferasa",abreviatura:"ALT/GPT",categoria:"hepatico",rangos:{adulto:{min:7,max:56,unidad:"U/L"}},significadoAlto:"Indica da\xf1o hepatocelular: hepatitis viral o t\xf3xica, esteatosis, cirrosis, isquemia hep\xe1tica o hepatotoxicidad por f\xe1rmacos. M\xe1s espec\xedfica del h\xedgado que la AST.",significadoBajo:"No tiene significado cl\xednico relevante. Valores muy bajos pueden verse en d\xe9ficit de piridoxina (vitamina B6).",farmacosAlteran:["Paracetamol","Estatinas","Isoniazida","Metotrexato","Amiodarona"],implicacionesEnfermeria:["Monitorizar en pacientes que inician estatinas, antituberculosos o antiepil\xe9pticos","Alertar si ALT >3 veces el l\xedmite superior normal con s\xedntomas","Educar al paciente sobre evitar alcohol y hepatot\xf3xicos","Correlacionar con AST: ratio AST/ALT >2 sugiere hepatopat\xeda alcoh\xf3lica"]},{id:"lab_ast",nombre:"Aspartato Aminotransferasa",abreviatura:"AST/GOT",categoria:"hepatico",rangos:{adulto:{min:10,max:40,unidad:"U/L"}},significadoAlto:"Indica da\xf1o celular hep\xe1tico o muscular: hepatitis, infarto de miocardio, rabdomi\xf3lisis, hem\xf3lisis o miopat\xeda por estatinas.",significadoBajo:"No tiene significado cl\xednico relevante. Puede verse en uremia o d\xe9ficit de vitamina B6.",farmacosAlteran:["Paracetamol","Estatinas","Isoniazida","Eritromicina","Anticonvulsivantes"],implicacionesEnfermeria:["No es espec\xedfica del h\xedgado; correlacionar con ALT y GGT","En sospecha de IAM, correlacionar con troponina y CK-MB","Monitorizar junto con CK en pacientes con miopat\xeda por estatinas"]},{id:"lab_bilirrubina_total",nombre:"Bilirrubina total",abreviatura:"BT",categoria:"hepatico",rangos:{adulto:{min:.1,max:1.2,unidad:"mg/dL"}},significadoAlto:"Hiperbilirrubinemia: causa ictericia visible >2.5 mg/dL; indica hem\xf3lisis, hepatopat\xeda, obstrucci\xf3n biliar o s\xedndrome de Gilbert.",significadoBajo:"No tiene significado cl\xednico relevante.",farmacosAlteran:["Rifampicina","Atazanavir","Paracetamol","Anabolizantes","Eritromicina"],implicacionesEnfermeria:["Valorar ictericia en piel, mucosas y escler\xf3ticas","Diferenciar bilirrubina directa/indirecta para orientar la causa","Monitorizar color de orina (coluria) y heces (acolia) como indicadores","Vigilar prurito asociado a colestasis y aplicar medidas de confort"]},{id:"lab_bilirrubina_directa",nombre:"Bilirrubina directa (conjugada)",abreviatura:"BD",categoria:"hepatico",rangos:{adulto:{min:0,max:.3,unidad:"mg/dL"}},significadoAlto:"Indica colestasis intrahep\xe1tica o extrahep\xe1tica: obstrucci\xf3n biliar por c\xe1lculos, tumores, hepatitis colest\xe1sica o cirrosis biliar primaria.",significadoBajo:"No tiene significado cl\xednico relevante.",farmacosAlteran:["Anticonceptivos orales","Eritromicina","Clorpromazina","Anabolizantes","Rifampicina"],implicacionesEnfermeria:["Correlacionar con fosfatasa alcalina y GGT en sospecha de colestasis","Vigilar signos de obstrucci\xf3n biliar: acolia, coluria, prurito","Preparar al paciente para estudios de imagen (ecograf\xeda, CPRE) si procede"]},{id:"lab_fosfatasa_alcalina",nombre:"Fosfatasa Alcalina",abreviatura:"FA",categoria:"hepatico",rangos:{adulto:{min:44,max:147,unidad:"U/L"},pediatrico:{min:100,max:400,unidad:"U/L"}},significadoAlto:"Elevada en colestasis, met\xe1stasis hep\xe1ticas, enfermedad de Paget, hiperparatiroidismo, fracturas en consolidaci\xf3n y crecimiento \xf3seo infantil.",significadoBajo:"Rara vez cl\xednicamente significativo; puede verse en hipotiroidismo, anemia perniciosa o d\xe9ficit de zinc.",farmacosAlteran:["Anticonvulsivantes","Anticonceptivos orales","Alopurinol","Antibi\xf3ticos","Metotrexato"],implicacionesEnfermeria:["Valores elevados en ni\xf1os y adolescentes son normales por el crecimiento \xf3seo","Diferenciar origen hep\xe1tico u \xf3seo con GGT (si GGT normal, origen \xf3seo)","Monitorizar en pacientes con patolog\xeda \xf3sea o hepatobiliar"]},{id:"lab_ggt",nombre:"Gamma-Glutamil Transferasa",abreviatura:"GGT",categoria:"hepatico",rangos:{adulto:{min:9,max:48,unidad:"U/L"}},significadoAlto:"Elevada en enfermedad hepatobiliar, alcoholismo cr\xf3nico, pancreatitis, uso de anticonvulsivantes y colestasis. Muy sensible a la ingesta de alcohol.",significadoBajo:"No tiene significado cl\xednico relevante.",farmacosAlteran:["Fenito\xedna","Carbamazepina","Barbit\xfaricos","Rifampicina","Paracetamol"],implicacionesEnfermeria:["\xdatil como marcador de consumo de alcohol: se eleva con ingesta cr\xf3nica","Ayuda a confirmar origen hep\xe1tico de la fosfatasa alcalina elevada","Monitorizar en pacientes con antecedentes de alcoholismo","Educar al paciente sobre abstinencia alcoh\xf3lica si GGT est\xe1 elevada"]},{id:"lab_creatinina",nombre:"Creatinina s\xe9rica",abreviatura:"Cr",categoria:"renal",rangos:{adultoHombre:{min:.7,max:1.3,unidad:"mg/dL"},adultoMujer:{min:.6,max:1.1,unidad:"mg/dL"}},significadoAlto:"Indica deterioro de la funci\xf3n renal: insuficiencia renal aguda o cr\xf3nica, deshidrataci\xf3n, obstrucci\xf3n urinaria, rabdomi\xf3lisis o nefrotoxicidad.",significadoBajo:"Puede verse en desnutrici\xf3n severa, p\xe9rdida de masa muscular (caquexia) o embarazo por aumento del filtrado glomerular.",farmacosAlteran:["AINEs","Aminogluc\xf3sidos","Vancomicina","IECA/ARA-II","Medios de contraste yodados"],implicacionesEnfermeria:["Calcular el aclaramiento de creatinina para ajustar dosis de f\xe1rmacos nefrot\xf3xicos","Asegurar hidrataci\xf3n adecuada antes de administrar contraste yodado","Monitorizar diuresis horaria en pacientes con insuficiencia renal aguda","Alertar si creatinina se duplica respecto al valor basal del paciente"]},{id:"lab_bun_urea",nombre:"BUN / Urea",abreviatura:"BUN",categoria:"renal",rangos:{adulto:{min:7,max:20,unidad:"mg/dL"},pediatrico:{min:5,max:18,unidad:"mg/dL"}},significadoAlto:"Azoemia: indica insuficiencia renal, deshidrataci\xf3n, hemorragia digestiva, dieta hiperproteica, catabolismo aumentado o insuficiencia card\xedaca.",significadoBajo:"Puede indicar enfermedad hep\xe1tica severa (menor s\xedntesis de urea), desnutrici\xf3n proteica o sobrehidrataci\xf3n.",farmacosAlteran:["AINEs","Aminogluc\xf3sidos","Corticosteroides","Tetraciclinas","Diur\xe9ticos"],implicacionesEnfermeria:["Calcular ratio BUN/Creatinina: >20:1 sugiere causa prerrenal (deshidrataci\xf3n)","Monitorizar balance h\xeddrico y peso diario","Valorar estado de hidrataci\xf3n: turgencia cut\xe1nea, mucosas, presi\xf3n arterial","Correlacionar con creatinina para diferenciar causa renal vs prerrenal"]},{id:"lab_acido_urico_renal",nombre:"\xc1cido \xfarico (perfil renal)",abreviatura:"AU",categoria:"renal",rangos:{adultoHombre:{min:3.4,max:7,unidad:"mg/dL"},adultoMujer:{min:2.4,max:6,unidad:"mg/dL"}},significadoAlto:"Hiperuricemia con riesgo de nefropat\xeda por uratos, litiasis renal y gota; frecuente en ERC, s\xedndrome de lisis tumoral y uso de diur\xe9ticos.",significadoBajo:"Puede indicar tubulopat\xeda renal con p\xe9rdida excesiva de \xe1cido \xfarico o efecto de f\xe1rmacos uricos\xfaricos.",farmacosAlteran:["Alopurinol","Febuxostat","Tiazidas","Ciclosporina","Rasburicasa"],implicacionesEnfermeria:["Hidratar abundantemente en s\xedndrome de lisis tumoral para prevenir nefropat\xeda","Monitorizar funci\xf3n renal en pacientes con hiperuricemia cr\xf3nica","Administrar alopurinol profil\xe1ctico antes de quimioterapia seg\xfan protocolo"]},{id:"lab_tfg",nombre:"Tasa de Filtrado Glomerular",abreviatura:"TFG",categoria:"renal",rangos:{adulto:{min:90,max:120,unidad:"mL/min/1.73m\xb2"}},significadoAlto:"TFG >120 puede verse en embarazo o fase inicial de nefropat\xeda diab\xe9tica (hiperfiltraci\xf3n glomerular).",significadoBajo:"Indica enfermedad renal cr\xf3nica: G1 >90, G2 60-89, G3a 45-59, G3b 30-44, G4 15-29, G5 <15 (di\xe1lisis).",farmacosAlteran:["IECA/ARA-II","AINEs","Aminogluc\xf3sidos","Metformina","Medios de contraste"],implicacionesEnfermeria:["Clasificar el estadio de ERC seg\xfan TFG para ajustar cuidados","Ajustar dosis de f\xe1rmacos de eliminaci\xf3n renal seg\xfan TFG","Contraindicar metformina si TFG <30 mL/min/1.73m\xb2","Derivar a nefrolog\xeda si TFG <30 para planificar terapia sustitutiva"]},{id:"lab_cistatina_c",nombre:"Cistatina C",abreviatura:"CysC",categoria:"renal",rangos:{adulto:{min:.6,max:1,unidad:"mg/L"}},significadoAlto:"Indica disminuci\xf3n de la funci\xf3n renal; m\xe1s preciso que la creatinina en ancianos, obesos y pacientes con masa muscular alterada.",significadoBajo:"Rara vez cl\xednicamente significativo; puede verse en hipertiroidismo.",farmacosAlteran:["Corticosteroides","Ciclosporina","AINEs","Aminogluc\xf3sidos","Cisplatino"],implicacionesEnfermeria:["\xdatil cuando la creatinina no es fiable (amputados, ancianos, caqu\xe9cticos)","No se afecta por la masa muscular, dieta ni g\xe9nero","Solicitar cuando hay discrepancia entre creatinina y cl\xednica del paciente"]},{id:"lab_troponina",nombre:"Troponina I",abreviatura:"TnI",categoria:"cardiaco",rangos:{adulto:{min:0,max:.04,unidad:"ng/mL"}},significadoAlto:"Elevada: indica da\xf1o mioc\xe1rdico; diagn\xf3stico de IAM si se acompa\xf1a de cl\xednica y ECG. Tambi\xe9n se eleva en miocarditis, TEP masiva, sepsis grave e insuficiencia renal.",significadoBajo:"Valores normales ayudan a descartar IAM con alto valor predictivo negativo.",farmacosAlteran:["Doxorrubicina","5-Fluorouracilo","Trastuzumab","Coca\xedna","Simpaticomim\xe9ticos"],implicacionesEnfermeria:["Extraer muestra seriada: al ingreso, a las 3h y 6h para detectar curva de elevaci\xf3n","No retrasar la extracci\xf3n por espera de ayuno; es una urgencia diagn\xf3stica","Monitorizaci\xf3n electrocardiogr\xe1fica continua si troponina elevada","Asegurar acceso venoso y preparar tratamiento de reperfusi\xf3n si IAM confirmado"]},{id:"lab_ck_mb",nombre:"Creatina Quinasa MB",abreviatura:"CK-MB",categoria:"cardiaco",rangos:{adulto:{min:0,max:5,unidad:"ng/mL"}},significadoAlto:"Elevada en infarto agudo de miocardio (pico a las 12-24h), miocarditis, cardioversi\xf3n, cirug\xeda card\xedaca o rabdomi\xf3lisis severa.",significadoBajo:"Valores normales ayudan a descartar da\xf1o mioc\xe1rdico reciente.",farmacosAlteran:["Estatinas","Fibratos","Doxorrubicina","Coca\xedna","Antipsic\xf3ticos"],implicacionesEnfermeria:["Se eleva a las 4-8h del IAM y normaliza en 48-72h; \xfatil para detectar reinfarto","Complementar siempre con troponina para mayor especificidad","Diferenciar de CK total elevada por causa muscular (ejercicio, inyecciones IM)"]},{id:"lab_bnp",nombre:"P\xe9ptido Natriur\xe9tico Cerebral",abreviatura:"BNP",categoria:"cardiaco",rangos:{adulto:{min:0,max:100,unidad:"pg/mL"}},significadoAlto:"Indica insuficiencia card\xedaca descompensada; valores correlacionan con la severidad. Tambi\xe9n se eleva en TEP, hipertensi\xf3n pulmonar y fibrilaci\xf3n auricular.",significadoBajo:"Ayuda a descartar insuficiencia card\xedaca como causa de disnea (alto valor predictivo negativo).",farmacosAlteran:["Sacubitrilo/valsart\xe1n","IECA","Diur\xe9ticos","Betabloqueantes","Nesiritida"],implicacionesEnfermeria:["BNP <100 pg/mL: IC improbable; >400 pg/mL: IC muy probable","Monitorizar peso diario y balance h\xeddrico en pacientes con BNP elevado","Valorar disnea, ortopnea, edema perif\xe9rico y crepitantes pulmonares","\xdatil para monitorizar respuesta al tratamiento de la insuficiencia card\xedaca"]},{id:"lab_pro_bnp",nombre:"Pro-P\xe9ptido Natriur\xe9tico Cerebral N-terminal",abreviatura:"NT-proBNP",categoria:"cardiaco",rangos:{adulto:{min:0,max:300,unidad:"pg/mL"}},significadoAlto:"Elevado en insuficiencia card\xedaca (valores ajustados por edad: <50 a\xf1os >450, 50-75 a\xf1os >900, >75 a\xf1os >1800 pg/mL). Tambi\xe9n en ERC y sepsis.",significadoBajo:"Valores normales descartan IC con alta sensibilidad. No se afecta por sacubitrilo (a diferencia del BNP).",farmacosAlteran:["IECA","ARA-II","Betabloqueantes","Diur\xe9ticos","Espironolactona"],implicacionesEnfermeria:["Interpretar seg\xfan edad del paciente por los diferentes puntos de corte","Preferido sobre BNP en pacientes tratados con sacubitrilo/valsart\xe1n","Monitorizar tendencia: descenso >30% indica buena respuesta al tratamiento","Correlacionar con cl\xednica y no interpretar de forma aislada"]},{id:"lab_ldh",nombre:"Lactato Deshidrogenasa",abreviatura:"LDH",categoria:"cardiaco",rangos:{adulto:{min:140,max:280,unidad:"U/L"}},significadoAlto:"Elevada en infarto de miocardio (tard\xedo), hem\xf3lisis, embolia pulmonar, hepatopat\xeda, linfoma, anemia megalobl\xe1stica y destrucci\xf3n tisular generalizada.",significadoBajo:"Rara vez cl\xednicamente significativo.",farmacosAlteran:["Anest\xe9sicos","Aspirina","Fluorouracilo","Metotrexato","Narc\xf3ticos"],implicacionesEnfermeria:["Marcador inespec\xedfico de da\xf1o tisular; correlacionar con otros marcadores espec\xedficos","En sospecha de hem\xf3lisis, correlacionar con haptoglobina y bilirrubina indirecta","Monitorizar como marcador pron\xf3stico en linfomas y tumores germinales"]},{id:"lab_tsh",nombre:"Hormona Estimulante de la Tiroides",abreviatura:"TSH",categoria:"endocrino",rangos:{adulto:{min:.4,max:4,unidad:"mUI/L"}},significadoAlto:"Indica hipotiroidismo primario; tambi\xe9n se eleva en tiroiditis de Hashimoto, d\xe9ficit de yodo o tras suspender levotiroxina.",significadoBajo:"Indica hipertiroidismo (enfermedad de Graves, bocio multinodular t\xf3xico) o supresi\xf3n por exceso de hormona tiroidea ex\xf3gena.",farmacosAlteran:["Levotiroxina","Amiodarona","Litio","Metimazol","Propiltiouracilo"],implicacionesEnfermeria:["Administrar levotiroxina en ayunas, 30-60 minutos antes del desayuno","Monitorizar TSH cada 6-8 semanas tras ajuste de dosis de levotiroxina","Vigilar signos de hipotiroidismo: fatiga, aumento de peso, bradicardia, intolerancia al fr\xedo","Vigilar signos de hipertiroidismo: taquicardia, p\xe9rdida de peso, temblor, ansiedad"]},{id:"lab_t4_libre",nombre:"Tiroxina Libre",abreviatura:"T4L",categoria:"endocrino",rangos:{adulto:{min:.8,max:1.8,unidad:"ng/dL"}},significadoAlto:"Indica hipertiroidismo, tiroiditis aguda (fase tirot\xf3xica), sobredosis de levotiroxina o amiodarona.",significadoBajo:"Indica hipotiroidismo; si TSH tambi\xe9n baja, sospechar hipotiroidismo central (hipofisario).",farmacosAlteran:["Levotiroxina","Amiodarona","Propranolol","Corticosteroides","Heparina"],implicacionesEnfermeria:["Interpretar siempre junto con TSH para diagn\xf3stico correcto","TSH alta + T4L baja = hipotiroidismo primario","TSH baja + T4L alta = hipertiroidismo","No extraer muestra justo despu\xe9s de tomar levotiroxina (falso elevado)"]},{id:"lab_t3",nombre:"Triyodotironina",abreviatura:"T3",categoria:"endocrino",rangos:{adulto:{min:80,max:200,unidad:"ng/dL"}},significadoAlto:"Elevada en hipertiroidismo (especialmente T3-tirotoxicosis), fase aguda de tiroiditis o exceso de tratamiento tiroideo.",significadoBajo:"Disminuida en hipotiroidismo, s\xedndrome del eutiroideo enfermo (enfermedad no tiroidea grave), desnutrici\xf3n o ayuno prolongado.",farmacosAlteran:["Levotiroxina","Amiodarona","Propranolol","Anticonvulsivantes","Estr\xf3genos"],implicacionesEnfermeria:["Solicitar T3 cuando TSH baja pero T4L normal (descartar T3-tirotoxicosis)","Valores bajos en pacientes cr\xedticos no siempre indican hipotiroidismo (s\xedndrome del enfermo eutiroideo)","Monitorizar frecuencia card\xedaca y presi\xf3n arterial en T3 elevada"]},{id:"lab_cortisol",nombre:"Cortisol s\xe9rico",abreviatura:"Cort",categoria:"endocrino",rangos:{adulto:{min:6,max:23,unidad:"\xb5g/dL"}},significadoAlto:"Indica s\xedndrome de Cushing, estr\xe9s agudo, depresi\xf3n, alcoholismo o tratamiento cr\xf3nico con corticoides ex\xf3genos.",significadoBajo:"Indica insuficiencia suprarrenal (enfermedad de Addison), hipopituitarismo o suspensi\xf3n brusca de corticoides.",farmacosAlteran:["Prednisona","Dexametasona","Ketoconazol","Estr\xf3genos","Opioides"],implicacionesEnfermeria:["Extraer muestra por la ma\xf1ana (6-8 AM) por el ritmo circadiano del cortisol","Nunca suspender corticoides bruscamente: reducir gradualmente para evitar crisis addisoniana","Vigilar signos de crisis suprarrenal: hipotensi\xf3n, hipoglucemia, confusi\xf3n","Educar al paciente con corticoterapia cr\xf3nica sobre la necesidad de portar identificaci\xf3n m\xe9dica"]},{id:"lab_hba1c",nombre:"Hemoglobina Glucosilada",abreviatura:"HbA1c",categoria:"endocrino",rangos:{adulto:{min:4,max:5.6,unidad:"%"}},significadoAlto:"Indica mal control gluc\xe9mico en los \xfaltimos 2-3 meses. HbA1c 5.7-6.4% = prediabetes; \u22656.5% = diabetes mellitus.",significadoBajo:"Puede verse en anemias hemol\xedticas, hemorragia reciente, embarazo o hemoglobinopat\xedas (falso resultado bajo).",farmacosAlteran:["Insulina","Metformina","Sulfonilureas","An\xe1logos GLP-1","Inhibidores SGLT2"],implicacionesEnfermeria:["Objetivo terap\xe9utico general en diabetes: HbA1c <7% (individualizar seg\xfan paciente)","No requiere ayuno para su determinaci\xf3n","Monitorizar cada 3 meses en pacientes con diabetes no controlada","Educar que refleja el promedio gluc\xe9mico de 2-3 meses, no un valor puntual"]},{id:"lab_insulina",nombre:"Insulina en ayunas",abreviatura:"Ins",categoria:"endocrino",rangos:{adulto:{min:2.6,max:24.9,unidad:"\xb5UI/mL"}},significadoAlto:"Hiperinsulinemia: indica resistencia a la insulina, s\xedndrome metab\xf3lico, obesidad, insulinoma o fase temprana de DM tipo 2.",significadoBajo:"Indica diabetes tipo 1 (destrucci\xf3n de c\xe9lulas beta), DM2 avanzada con agotamiento pancre\xe1tico o insuficiencia pancre\xe1tica exocrina.",farmacosAlteran:["Insulina ex\xf3gena","Sulfonilureas","Metformina","Corticosteroides","Tiazidas"],implicacionesEnfermeria:["Asegurar extracci\xf3n en ayunas de al menos 8 horas","Calcular \xedndice HOMA-IR junto con glucosa para evaluar resistencia a insulina","Correlacionar con p\xe9ptido C para diferenciar insulina end\xf3gena de ex\xf3gena"]},{id:"lab_ph_urinario",nombre:"pH urinario",abreviatura:"pH-U",categoria:"orina",rangos:{adulto:{min:4.5,max:8,unidad:""}},significadoAlto:"Orina alcalina (>8.0): infecci\xf3n urinaria por Proteus, dieta vegetariana, alcalosis metab\xf3lica, acidosis tubular renal o v\xf3mitos prolongados.",significadoBajo:"Orina \xe1cida (<4.5): dieta hiperproteica, acidosis metab\xf3lica, diabetes descompensada, diarrea severa o deshidrataci\xf3n.",farmacosAlteran:["Bicarbonato s\xf3dico","Acetazolamida","\xc1cido asc\xf3rbico","Cloruro am\xf3nico","Citrato pot\xe1sico"],implicacionesEnfermeria:["Considerar pH urinario al interpretar sedimento y prevenci\xf3n de litiasis","Alcalinizar orina con bicarbonato para prevenir nefropat\xeda por metotrexato","Recoger muestra de orina fresca; la orina en reposo se alcaliniza"]},{id:"lab_densidad_urinaria",nombre:"Densidad urinaria",abreviatura:"Dens",categoria:"orina",rangos:{adulto:{min:1.005,max:1.03,unidad:""}},significadoAlto:"Orina concentrada: deshidrataci\xf3n, SIADH, insuficiencia card\xedaca, proteinuria masiva o glucosuria.",significadoBajo:"Orina diluida: diabetes ins\xedpida, ingesta h\xeddrica excesiva, insuficiencia renal cr\xf3nica (incapacidad de concentrar orina) o uso de diur\xe9ticos.",farmacosAlteran:["Diur\xe9ticos","Desmopresina","Medios de contraste","Manitol","Glucosa IV"],implicacionesEnfermeria:["Correlacionar con estado de hidrataci\xf3n del paciente","Densidad fija ~1.010 indica p\xe9rdida de capacidad de concentraci\xf3n renal","Monitorizar en pacientes con sospecha de diabetes ins\xedpida"]},{id:"lab_proteinas_orina",nombre:"Prote\xednas en orina",abreviatura:"Prot-U",categoria:"orina",rangos:{adulto:{min:0,max:150,unidad:"mg/24h"}},significadoAlto:"Proteinuria: indica da\xf1o glomerular (>3.5 g/24h = s\xedndrome nefr\xf3tico), nefropat\xeda diab\xe9tica, preeclampsia, mieloma m\xfaltiple o nefritis.",significadoBajo:"Valores normales indican funci\xf3n glomerular adecuada; no hay significado cl\xednico en proteinuria baja.",farmacosAlteran:["IECA/ARA-II","AINEs","Aminogluc\xf3sidos","Litio","Ciclosporina"],implicacionesEnfermeria:["Instruir sobre recolecci\xf3n correcta de orina de 24 horas","Usar tira reactiva como cribado; confirmar con proteinuria cuantitativa","Monitorizar en pacientes diab\xe9ticos e hipertensos como marcador de nefropat\xeda","Los IECA/ARA-II tienen efecto nefroprotector al reducir proteinuria"]},{id:"lab_glucosa_orina",nombre:"Glucosa en orina",abreviatura:"Glu-U",categoria:"orina",rangos:{adulto:{min:0,max:15,unidad:"mg/dL"}},significadoAlto:"Glucosuria: aparece cuando la glucemia supera el umbral renal (~180 mg/dL). Indica diabetes descompensada, glucosuria renal o efecto de iSGLT2.",significadoBajo:"La ausencia de glucosa en orina es normal; valores de 0-15 mg/dL se consideran no detectables.",farmacosAlteran:["Inhibidores SGLT2","Corticosteroides","Tiazidas","\xc1cido asc\xf3rbico","Cefalosporinas"],implicacionesEnfermeria:["Tener en cuenta que iSGLT2 (dapagliflozina, empagliflozina) producen glucosuria terap\xe9utica","No usar glucosuria como \xfanico m\xe9todo de control en diabetes","Vigilar riesgo de infecciones urinarias en pacientes con glucosuria persistente"]},{id:"lab_microalbuminuria",nombre:"Microalbuminuria",abreviatura:"mAlb",categoria:"orina",rangos:{adulto:{min:0,max:30,unidad:"mg/g creatinina"}},significadoAlto:"Microalbuminuria (30-300 mg/g): marcador precoz de nefropat\xeda diab\xe9tica e hipertensiva. Macroalbuminuria (>300 mg/g): indica da\xf1o glomerular establecido.",significadoBajo:"Valores normales (<30 mg/g) indican ausencia de da\xf1o glomerular significativo.",farmacosAlteran:["IECA/ARA-II","AINEs","Aminogluc\xf3sidos","Inhibidores SGLT2","Finerenona"],implicacionesEnfermeria:["Cribado anual en pacientes diab\xe9ticos e hipertensos","Preferir muestra de primera orina de la ma\xf1ana (ratio alb\xfamina/creatinina)","Iniciar IECA/ARA-II ante microalbuminuria positiva en diab\xe9ticos","Evitar recoger muestra durante menstruaci\xf3n, infecci\xf3n urinaria o ejercicio intenso"]},{id:"lab_ph_arterial",nombre:"pH arterial",abreviatura:"pH",categoria:"gasometria",rangos:{adulto:{min:7.35,max:7.45,unidad:""}},significadoAlto:"Alcalemia (>7.45): alcalosis respiratoria (hiperventilaci\xf3n) o metab\xf3lica (v\xf3mitos, diur\xe9ticos). Puede causar tetania e irritabilidad neuromuscular.",significadoBajo:"Acidemia (<7.35): acidosis respiratoria (retenci\xf3n de CO2) o metab\xf3lica (cetoacidosis, acidosis l\xe1ctica, insuficiencia renal). pH <7.20 es potencialmente letal.",farmacosAlteran:["Bicarbonato s\xf3dico","Acetazolamida","Diur\xe9ticos del asa","Salicilatos","Metformina"],implicacionesEnfermeria:["pH <7.20 o >7.60: situaci\xf3n de emergencia que requiere intervenci\xf3n inmediata","Interpretar siempre junto con PaCO2 y HCO3 para determinar el trastorno primario","Verificar que la muestra sea arterial y se analice en menos de 15 minutos","Transportar la muestra en hielo y sin burbujas de aire"]},{id:"lab_pao2",nombre:"Presi\xf3n Parcial de Ox\xedgeno",abreviatura:"PaO2",categoria:"gasometria",rangos:{adulto:{min:80,max:100,unidad:"mmHg"}},significadoAlto:"Hiperoxemia: generalmente por FiO2 elevada. En neonatos prematuros, PaO2 alta aumenta riesgo de retinopat\xeda.",significadoBajo:"Hipoxemia: indica insuficiencia respiratoria. PaO2 <60 mmHg = insuficiencia respiratoria parcial; requiere oxigenoterapia. Causas: neumon\xeda, SDRA, TEP, EPOC.",farmacosAlteran:["Ox\xedgeno suplementario","Broncodilatadores","Sedantes/opioides","Anest\xe9sicos","\xd3xido n\xedtrico"],implicacionesEnfermeria:["Registrar FiO2 del paciente al momento de la extracci\xf3n","Calcular PaO2/FiO2 (\xedndice de Kirby): <300 = lesi\xf3n pulmonar; <200 = SDRA","Monitorizar saturaci\xf3n de O2 con pulsioximetr\xeda de forma continua","Ajustar oxigenoterapia seg\xfan objetivo de PaO2 del paciente"]},{id:"lab_paco2",nombre:"Presi\xf3n Parcial de Di\xf3xido de Carbono",abreviatura:"PaCO2",categoria:"gasometria",rangos:{adulto:{min:35,max:45,unidad:"mmHg"}},significadoAlto:"Hipercapnia (>45 mmHg): indica hipoventilaci\xf3n (EPOC, depresi\xf3n respiratoria, fatiga muscular) = acidosis respiratoria.",significadoBajo:"Hipocapnia (<35 mmHg): indica hiperventilaci\xf3n (ansiedad, dolor, TEP, compensaci\xf3n de acidosis metab\xf3lica) = alcalosis respiratoria.",farmacosAlteran:["Opioides","Benzodiazepinas","Broncodilatadores","Salicilatos","Progesterona"],implicacionesEnfermeria:["En pacientes con EPOC cr\xf3nico, tolerar PaCO2 m\xe1s alta (hipercapnia permisiva)","Monitorizar patr\xf3n respiratorio: frecuencia, profundidad y esfuerzo","Alertar si PaCO2 >50 mmHg con acidosis: posible necesidad de ventilaci\xf3n mec\xe1nica","Evaluar nivel de conciencia en hipercapnia progresiva (narcosis por CO2)"]},{id:"lab_hco3",nombre:"Bicarbonato",abreviatura:"HCO3",categoria:"gasometria",rangos:{adulto:{min:22,max:26,unidad:"mEq/L"}},significadoAlto:"HCO3 >26: alcalosis metab\xf3lica (v\xf3mitos, aspiraci\xf3n g\xe1strica, diur\xe9ticos) o compensaci\xf3n renal de acidosis respiratoria cr\xf3nica.",significadoBajo:"HCO3 <22: acidosis metab\xf3lica (cetoacidosis, acidosis l\xe1ctica, diarrea severa, insuficiencia renal) o compensaci\xf3n de alcalosis respiratoria.",farmacosAlteran:["Bicarbonato s\xf3dico","Acetazolamida","Diur\xe9ticos tiaz\xeddicos","Furosemida","Topiramato"],implicacionesEnfermeria:["Calcular ani\xf3n gap (Na - Cl - HCO3) para clasificar la acidosis metab\xf3lica","Ani\xf3n gap >12: cetoacidosis, acidosis l\xe1ctica, intoxicaciones","Ani\xf3n gap normal: diarrea, acidosis tubular renal, f\xedstulas intestinales","Monitorizar nivel de conciencia y patr\xf3n respiratorio (Kussmaul en acidosis severa)"]},{id:"lab_saturacion_o2",nombre:"Saturaci\xf3n de Ox\xedgeno Arterial",abreviatura:"SaO2",categoria:"gasometria",rangos:{adulto:{min:95,max:100,unidad:"%"}},significadoAlto:"100% generalmente indica ox\xedgeno suplementario. En pacientes con EPOC, SaO2 100% puede indicar oxigenoterapia excesiva.",significadoBajo:"SaO2 <90% indica hipoxemia significativa (equivale a PaO2 ~60 mmHg en la curva de disociaci\xf3n). Requiere intervenci\xf3n inmediata.",farmacosAlteran:["Ox\xedgeno suplementario","Opioides","Sedantes","Broncodilatadores","\xd3xido n\xedtrico"],implicacionesEnfermeria:["Objetivo en EPOC: SaO2 88-92% (evitar supresi\xf3n del est\xedmulo hip\xf3xico)","Objetivo general: SaO2 \u226594% (\u226592% si riesgo de hipercapnia)","La pulsioximetr\xeda puede ser inexacta con esmalte de u\xf1as, hipotermia o mala perfusi\xf3n","Correlacionar pulsioximetr\xeda con gasometr\xeda arterial en casos dudosos"]},{id:"lab_lactato",nombre:"Lactato",abreviatura:"Lac",categoria:"gasometria",rangos:{adulto:{min:.5,max:2,unidad:"mmol/L"},pediatrico:{min:.5,max:2.2,unidad:"mmol/L"}},significadoAlto:"Hiperlactatemia: puede indicar hipoperfusi\xf3n tisular, sepsis, shock, isquemia mesent\xe9rica, insuficiencia hep\xe1tica grave o efecto de metformina. Lactato >4 mmol/L se asocia a mortalidad elevada en sepsis.",significadoBajo:"Sin relevancia cl\xednica significativa en valores bajos.",farmacosAlteran:["Metformina","Epinefrina","Linezolid","Nucle\xf3sidos antirretrovirales","Propofol (infusi\xf3n prolongada)"],implicacionesEnfermeria:["Monitorizar lactato seriado cada 2-4h en sepsis/shock para evaluar respuesta al tratamiento","Objetivo de resucitaci\xf3n: aclaramiento de lactato >10% en primeras 6 horas","Lactato >4 mmol/L: alertar al equipo m\xe9dico inmediatamente","Asegurar extracci\xf3n venosa sin torniquete prolongado (falso aumento)","Correlacionar con signos de perfusi\xf3n: relleno capilar, diuresis, nivel de conciencia"]},{id:"lab_procalcitonina",nombre:"Procalcitonina",abreviatura:"PCT",categoria:"bioquimica",rangos:{adulto:{min:0,max:.05,unidad:"ng/mL"}},significadoAlto:"PCT >0.5 ng/mL sugiere infecci\xf3n bacteriana sist\xe9mica. PCT >2 ng/mL alta probabilidad de sepsis bacteriana. PCT >10 ng/mL asociada a shock s\xe9ptico o fallo multiorg\xe1nico. \xdatil para diferenciar infecci\xf3n bacteriana de viral.",significadoBajo:"Valores <0.1 ng/mL hacen improbable una infecci\xf3n bacteriana sist\xe9mica. \xdatil para guiar la suspensi\xf3n de antibi\xf3ticos.",farmacosAlteran:["Antibi\xf3ticos (disminuyen si efectivos)","OKT3","Alemtuzumab","Granulocyte-CSF"],implicacionesEnfermeria:["Monitorizar PCT seriada para guiar duraci\xf3n de antibioterapia (descenso >80% apoya suspensi\xf3n)","PCT <0.25 ng/mL: considerar suspensi\xf3n de antibi\xf3ticos (consenso con equipo m\xe9dico)","No se eleva significativamente en infecciones virales ni autoinmunes (valor diferencial)","Extraer muestra antes de iniciar antibi\xf3ticos cuando sea posible"]},{id:"lab_magnesio",nombre:"Magnesio",abreviatura:"Mg",categoria:"bioquimica",rangos:{adultoHombre:{min:1.7,max:2.2,unidad:"mg/dL"},adultoMujer:{min:1.7,max:2.2,unidad:"mg/dL"},pediatrico:{min:1.7,max:2.1,unidad:"mg/dL"}},significadoAlto:"Hipermagnesemia: puede causar hipotensi\xf3n, bradicardia, depresi\xf3n respiratoria, arreflexia y paro card\xedaco. Frecuente en insuficiencia renal con suplementos de Mg o anti\xe1cidos.",significadoBajo:"Hipomagnesemia: causa arritmias (torsades de pointes), convulsiones, tetania, debilidad muscular. Frecuente en alcoholismo, diur\xe9ticos, malabsorci\xf3n. Dificulta la correcci\xf3n de hipopotasemia e hipocalcemia.",farmacosAlteran:["Diur\xe9ticos de asa","Inhibidores de bomba de protones","Aminogluc\xf3sidos","Cisplatino","Ciclosporina","Sulfato de magnesio IV"],implicacionesEnfermeria:["Monitorizar ECG en hipo/hipermagnesemia: buscar prolongaci\xf3n QT, arritmias","Administrar sulfato de magnesio IV lento (riesgo de hipotensi\xf3n y paro si r\xe1pido)","Controlar reflejo rotuliano durante infusi\xf3n de MgSO4 (eclampsia): ausencia indica toxicidad","Vigilar en pacientes con diur\xe9ticos cr\xf3nicos: solicitar Mg junto con K+","Hipomagnesemia refractaria: corregir Mg antes de intentar corregir K+ o Ca2+"]},{id:"lab_bnp",nombre:"NT-proBNP",abreviatura:"NT-proBNP",categoria:"cardiaco",rangos:{adulto:{min:0,max:125,unidad:"pg/mL"}},significadoAlto:"Elevaci\xf3n proporcional a la severidad de la insuficiencia card\xedaca. >300 pg/mL en <50 a\xf1os, >900 en 50-75 a\xf1os, >1800 en >75 a\xf1os sugiere IC aguda. Tambi\xe9n se eleva en TEP, sepsis, insuficiencia renal y fibrilaci\xf3n auricular.",significadoBajo:"Valores dentro de rango descartan IC con alto valor predictivo negativo. \xdatil en urgencias para diferenciar disnea card\xedaca de pulmonar.",farmacosAlteran:["IECA/ARA-II (disminuyen)","Sacubitrilo-valsart\xe1n (aumenta BNP, no NT-proBNP)","Betabloqueantes","Diur\xe9ticos","Nesiritida"],implicacionesEnfermeria:["Monitorizar NT-proBNP seriado para evaluar respuesta al tratamiento de IC","Considerar edad al interpretar: umbrales diagn\xf3sticos aumentan con la edad","Correlacionar con peso diario, balance h\xeddrico y signos de congesti\xf3n","Valores muy elevados: alertar sobre posible descompensaci\xf3n aguda","En pacientes obesos los valores pueden estar falsamente bajos"]},{id:"lab_dimero_d",nombre:"D-d\xedmero",abreviatura:"DD",categoria:"coagulacion",rangos:{adulto:{min:0,max:500,unidad:"ng/mL"}},significadoAlto:"Indica activaci\xf3n de coagulaci\xf3n y fibrin\xf3lisis. Elevado en TVP, TEP, CID, sepsis, cirug\xeda reciente, neoplasias, embarazo. Alto valor predictivo negativo: DD normal descarta TVP/TEP en pacientes con baja probabilidad cl\xednica (Wells).",significadoBajo:"Sin relevancia cl\xednica. Valor normal con alta probabilidad cl\xednica no descarta trombosis.",farmacosAlteran:["Anticoagulantes (disminuyen)","Fibrinol\xedticos (aumentan transitoriamente)","Anticonceptivos orales (elevan)"],implicacionesEnfermeria:["Interpretar siempre junto con escalas cl\xednicas (Wells para TVP/TEP)","En >50 a\xf1os aplicar corte ajustado: edad \xd7 10 ng/mL (ej. 65 a\xf1os \u2192 650 ng/mL)","DD negativo con baja probabilidad cl\xednica: seguro excluir TEP sin imagen","Vigilar signos de TVP: edema unilateral, dolor gemelar, signo de Homans","En sospecha de CID: solicitar DD junto con fibrin\xf3geno, plaquetas y TP"]},{id:"lab_ferritina",nombre:"Ferritina",abreviatura:"Fer",categoria:"hematologia",rangos:{adultoHombre:{min:20,max:250,unidad:"ng/mL"},adultoMujer:{min:10,max:120,unidad:"ng/mL"},pediatrico:{min:7,max:140,unidad:"ng/mL"}},significadoAlto:"Sobrecarga de hierro (hemocromatosis, transfusiones repetidas), inflamaci\xf3n cr\xf3nica, hepatopat\xeda, neoplasias, s\xedndrome hemofagoc\xedtico. Ferritina >500 ng/mL en inflamaci\xf3n; >1000 ng/mL buscar hemocromatosis o hemofagocitosis.",significadoBajo:"Ferritina <10-15 ng/mL confirma ferropenia (marcador m\xe1s espec\xedfico de d\xe9ficit de hierro). Causa de anemia ferrop\xe9nica: p\xe9rdidas GI, menorragia, malabsorci\xf3n, dieta insuficiente.",farmacosAlteran:["Hierro oral/IV","Deferoxamina (quelante)","Eritropoyetina","Transfusiones sangu\xedneas"],implicacionesEnfermeria:["Ferritina <15 ng/mL: d\xe9ficit de hierro confirmado, educar sobre suplementaci\xf3n","Tomar hierro oral en ayunas con vitamina C (mejora absorci\xf3n)","Ferritina elevada + anemia: sospechar anemia de enfermedad cr\xf3nica (no dar hierro)","Monitorizar en pacientes politransfundidos: riesgo de sobrecarga f\xe9rrica"]},{id:"lab_fosforo",nombre:"F\xf3sforo",abreviatura:"P",categoria:"renal",rangos:{adulto:{min:2.5,max:4.5,unidad:"mg/dL"},pediatrico:{min:4,max:7,unidad:"mg/dL"}},significadoAlto:"Hiperfosfatemia: com\xfan en enfermedad renal cr\xf3nica (ERC), rabdomi\xf3lisis, lisis tumoral, hipoparatiroidismo. Causa calcificaciones metast\xe1sicas (producto Ca\xd7P >55). Principal causa de hiperparatiroidismo secundario en ERC.",significadoBajo:"Hipofosfatemia: causa debilidad muscular, insuficiencia respiratoria (debilidad diafragm\xe1tica), rabdomi\xf3lisis, hem\xf3lisis. Frecuente en s\xedndrome de realimentaci\xf3n, alcalosis respiratoria, hiperparatiroidismo.",farmacosAlteran:["Quelantes de f\xf3sforo (sevelamer, carbonato c\xe1lcico)","Vitamina D","Insulina","Fosfato s\xf3dico/pot\xe1sico IV","Anti\xe1cidos con aluminio"],implicacionesEnfermeria:["En ERC: monitorizar f\xf3sforo junto con calcio, PTH y vitamina D","Educar sobre dieta baja en f\xf3sforo: evitar procesados, refrescos de cola, l\xe1cteos excesivos","Administrar quelantes de f\xf3sforo CON las comidas (no entre comidas)","En s\xedndrome de realimentaci\xf3n: monitorizar P cada 6-12h las primeras 72h","Hipofosfatemia severa (<1 mg/dL): reposici\xf3n IV lenta, vigilar hipocalcemia"]},{id:"lab_acido_urico",nombre:"\xc1cido \xdarico",abreviatura:"AU",categoria:"renal",rangos:{adultoHombre:{min:3.4,max:7,unidad:"mg/dL"},adultoMujer:{min:2.4,max:6,unidad:"mg/dL"},pediatrico:{min:2,max:5.5,unidad:"mg/dL"}},significadoAlto:"Hiperuricemia: riesgo de gota (artritis aguda por cristales de urato), nefrolitiasis \xfarica, nefropat\xeda por uratos (lisis tumoral). Se asocia a s\xedndrome metab\xf3lico, HTA y enfermedad cardiovascular.",significadoBajo:"Hipouricemia: generalmente sin relevancia cl\xednica. Puede verse en s\xedndrome de Fanconi, SIADH, xantinuria hereditaria o tratamiento excesivo con uricos\xfaricos.",farmacosAlteran:["Alopurinol","Febuxostat","Diur\xe9ticos tiaz\xeddicos (aumentan)","Losart\xe1n (disminuye)","Rasburicasa","\xc1cido acetilsalic\xedlico (dosis-dependiente)"],implicacionesEnfermeria:["En crisis gotosa: aplicar fr\xedo local, elevar articulaci\xf3n, no manipular","Fomentar ingesta h\xeddrica >2L/d\xeda para prevenir litiasis renal","Educar sobre dieta baja en purinas: limitar carnes rojas, mariscos, alcohol (cerveza)","En lisis tumoral: hidrataci\xf3n vigorosa + rasburicasa o alopurinol profil\xe1ctico","Monitorizar funci\xf3n renal en pacientes con hiperuricemia cr\xf3nica"]},{id:"lab_pcr",nombre:"Prote\xedna C Reactiva",abreviatura:"PCR",categoria:"bioquimica",rangos:{adulto:{min:0,max:5,unidad:"mg/L"},pediatrico:{min:0,max:5,unidad:"mg/L"}},significadoAlto:"Indica inflamaci\xf3n aguda o cr\xf3nica. PCR >10 mg/L sugiere infecci\xf3n bacteriana significativa. PCR >100 mg/L orienta fuertemente a infecci\xf3n bacteriana severa, sepsis o necrosis tisular extensa. Valores entre 5-10 mg/L pueden verse en infecciones virales, inflamaci\xf3n leve o posquir\xfargico.",significadoBajo:"Valores normales o bajos descartan inflamaci\xf3n sist\xe9mica significativa. \xdatil como marcador de exclusi\xf3n de infecci\xf3n bacteriana activa.",farmacosAlteran:["Estatinas (disminuyen)","Anticonceptivos orales (aumentan)","AINEs (pueden disminuir)","Corticoides (disminuyen)","Tocilizumab (suprime PCR)"],implicacionesEnfermeria:["Monitorizar PCR seriada cada 24-48h para evaluar respuesta al tratamiento antibi\xf3tico","PCR que no desciende tras 48-72h de antibi\xf3ticos: alertar al equipo m\xe9dico sobre posible resistencia o foco no drenado","Correlacionar con cl\xednica: fiebre, leucocitosis, procalcitonina para valorar gravedad infecciosa","En posquir\xfargico: PCR elevada es normal las primeras 48-72h; si persiste o asciende, sospechar complicaci\xf3n","Extraer muestra en ayunas, tubo seco o con EDTA seg\xfan protocolo del laboratorio"]},{id:"lab_vsg",nombre:"Velocidad de Sedimentaci\xf3n Globular",abreviatura:"VSG",categoria:"hematologia",rangos:{adultoHombre:{min:0,max:15,unidad:"mm/h"},adultoMujer:{min:0,max:20,unidad:"mm/h"},pediatrico:{min:0,max:10,unidad:"mm/h"}},significadoAlto:"VSG elevada indica inflamaci\xf3n inespec\xedfica. Se eleva en infecciones, enfermedades autoinmunes (lupus, artritis reumatoidea), neoplasias, anemia y embarazo. VSG >100 mm/h sugiere mieloma m\xfaltiple, arteritis temporal, infecci\xf3n grave o neoplasia avanzada.",significadoBajo:"VSG muy baja puede verse en policitemia, insuficiencia card\xedaca congestiva, hipofibrinogenemia o uso de corticoides. Generalmente sin significado patol\xf3gico.",farmacosAlteran:["AINEs (disminuyen)","Corticoides (disminuyen)","Anticonceptivos orales (aumentan)","Heparina (puede aumentar)","\xc1cido valproico"],implicacionesEnfermeria:["La VSG es inespec\xedfica: siempre correlacionar con PCR y cl\xednica del paciente","Muestra de sangre venosa con anticoagulante EDTA; procesar dentro de 2 horas","\xdatil para seguimiento de enfermedades inflamatorias cr\xf3nicas (artritis reumatoidea, lupus)","En pacientes con VSG >100: considerar derivaci\xf3n urgente si no hay diagn\xf3stico establecido","No usar como marcador \xfanico de infecci\xf3n \u2014 la PCR y procalcitonina son m\xe1s espec\xedficas"]}]},801,[]);
__d(function(a,i,e,o,n,r,s){n.exports=[{id:"proto_acls",nombre:"ACLS - Paro Card\xedaco",abreviatura:"ACLS",descripcion:"Protocolo de soporte vital cardiovascular avanzado para el manejo del paro cardiorrespiratorio en adultos, incluyendo ritmos desfibrilables (FV/TV sin pulso) y no desfibrilables (asistolia/AESP).",categoria:"cardiaco",prioridad:"critico",banderasRojas:["Ausencia de pulso carot\xeddeo","Ausencia de respiraci\xf3n o respiraci\xf3n ag\xf3nica","P\xe9rdida s\xfabita de conciencia","Cianosis generalizada","Midriasis bilateral arreactiva"],pasos:[{orden:1,tiempo:"0-1 min",accion:"Confirmar paro card\xedaco e iniciar RCP de alta calidad",detalles:"Verificar ausencia de pulso (m\xe1x. 10 seg). Iniciar compresiones tor\xe1cicas 100-120/min, profundidad 5-6 cm. Relaci\xf3n 30:2 sin v\xeda a\xe9rea avanzada. Minimizar interrupciones (<10 seg).",critico:!0},{orden:2,tiempo:"1-2 min",accion:"Conectar monitor/desfibrilador y analizar ritmo",detalles:"Colocar parches de desfibrilaci\xf3n en posici\xf3n anterolateral. Analizar ritmo sin interrumpir compresiones m\xe1s de 10 segundos.",critico:!0,decision:{pregunta:"\xbfRitmo desfibrilable (FV/TV sin pulso)?",si:"Proceder a desfibrilaci\xf3n inmediata (paso 3)",no:"Continuar RCP, administrar epinefrina inmediatamente (paso 4) y reevaluar cada 2 min"}},{orden:3,tiempo:"2-3 min",accion:"Desfibrilaci\xf3n (si ritmo desfibrilable)",detalles:"Descarga bif\xe1sica 120-200 J (seg\xfan fabricante) o monof\xe1sica 360 J. Reanudar RCP inmediatamente despu\xe9s de la descarga durante 2 minutos sin verificar pulso.",critico:!0},{orden:4,tiempo:"3-5 min",accion:"Administrar Epinefrina",detalles:"En ritmo no desfibrilable: administrar lo antes posible. En ritmo desfibrilable: administrar despu\xe9s de la 2\xaa descarga. Repetir cada 3-5 minutos.",critico:!0,farmacos:[{nombre:"Epinefrina",dosis:"1 mg IV/IO cada 3-5 min",via:"IV/IO"}]},{orden:5,tiempo:"5-7 min",accion:"Asegurar v\xeda a\xe9rea avanzada",detalles:"Intubaci\xf3n endotraqueal o dispositivo supragl\xf3tico. Una vez colocada: ventilaciones continuas cada 6 seg (10/min) sin sincronizar con compresiones. Verificar capnograf\xeda (ETCO2).",critico:!1},{orden:6,tiempo:"5-10 min",accion:"Administrar Amiodarona (si FV/TV refractaria)",detalles:"Considerar despu\xe9s de la 3\xaa descarga si persiste FV/TV sin pulso. Si no hay amiodarona disponible, usar lidoca\xedna como alternativa.",critico:!0,farmacos:[{nombre:"Amiodarona",dosis:"300 mg IV/IO en bolo (1\xaa dosis); 150 mg IV/IO (2\xaa dosis)",via:"IV/IO"},{nombre:"Lidoca\xedna (alternativa)",dosis:"1-1.5 mg/kg IV/IO (1\xaa dosis); 0.5-0.75 mg/kg IV/IO (2\xaa dosis)",via:"IV/IO"}]},{orden:7,tiempo:"Cada 2 min",accion:"Reevaluar ritmo y buscar causas reversibles (5H y 5T)",detalles:"5H: Hipovolemia, Hipoxia, Hidrogeni\xf3n (acidosis), Hipo/Hiperpotasemia, Hipotermia. 5T: Neumot\xf3rax a Tensi\xf3n, Taponamiento card\xedaco, T\xf3xicos, Trombosis pulmonar, Trombosis coronaria.",critico:!0,decision:{pregunta:"\xbfSe identific\xf3 causa reversible?",si:"Tratar causa espec\xedfica de forma simult\xe1nea con RCP",no:"Continuar ciclos de RCP y reevaluar cada 2 minutos"}},{orden:8,tiempo:"Continuo",accion:"Cuidados post-paro card\xedaco (si hay RCE)",detalles:"Retorno de circulaci\xf3n espont\xe1nea (RCE): mantener PAS >90 mmHg, SpO2 94-99%, normocapnia, ECG 12 derivaciones, considerar manejo dirigido de temperatura (32-36\xb0C por 24h), angiograf\xeda coronaria si sospecha de SCA.",critico:!1,farmacos:[{nombre:"Norepinefrina",dosis:"0.1-0.5 mcg/kg/min en infusi\xf3n continua",via:"IV"}]}],resumenFarmacos:[{nombre:"Epinefrina",dosis:"1 mg IV/IO cada 3-5 min",via:"IV/IO",indicacion:"Vasopresor de primera l\xednea en paro card\xedaco para todos los ritmos"},{nombre:"Amiodarona",dosis:"300 mg IV/IO (1\xaa dosis); 150 mg IV/IO (2\xaa dosis)",via:"IV/IO",indicacion:"Antiarr\xedtmico en FV/TV sin pulso refractaria a desfibrilaci\xf3n"},{nombre:"Lidoca\xedna",dosis:"1-1.5 mg/kg IV/IO (1\xaa dosis); 0.5-0.75 mg/kg IV/IO (2\xaa dosis)",via:"IV/IO",indicacion:"Alternativa a amiodarona en FV/TV refractaria"},{nombre:"Norepinefrina",dosis:"0.1-0.5 mcg/kg/min en infusi\xf3n continua",via:"IV",indicacion:"Soporte hemodin\xe1mico post-RCE si hipotensi\xf3n persistente"}],notasEnfermeria:["Garantizar compresiones de alta calidad: profundidad 5-6 cm, frecuencia 100-120/min, permitir retroceso completo del t\xf3rax y minimizar interrupciones.","Registrar todos los tiempos: inicio de RCP, cada dosis de medicamento, cada descarga, y hora de RCE o cese de esfuerzos.","Monitorizar capnograf\xeda continua (ETCO2): valores <10 mmHg indican RCP de baja calidad; aumento s\xfabito >40 mmHg sugiere RCE.","Preparar infusi\xf3n de epinefrina o norepinefrina anticipadamente para soporte post-RCE.","Rotar al personal que realiza compresiones cada 2 minutos para evitar fatiga y mantener la calidad."]},{id:"proto_anafilaxia",nombre:"Anafilaxia",descripcion:"Protocolo de manejo de la reacci\xf3n anafil\xe1ctica severa, una emergencia m\xe9dica potencialmente mortal mediada por hipersensibilidad tipo I que requiere intervenci\xf3n inmediata con epinefrina.",categoria:"otro",prioridad:"critico",banderasRojas:["Edema de v\xeda a\xe9rea (estridor, voz ronca, disfagia)","Hipotensi\xf3n o shock distributivo","Broncoespasmo severo con sibilancias difusas","Urticaria generalizada con compromiso respiratorio o hemodin\xe1mico","Exposici\xf3n reciente a al\xe9rgeno conocido con deterioro r\xe1pido"],pasos:[{orden:1,tiempo:"0-1 min",accion:"Retirar al\xe9rgeno y administrar Epinefrina IM",detalles:"Administrar epinefrina IM en cara anterolateral del muslo. Es el f\xe1rmaco de primera l\xednea; NO debe retrasarse. Puede repetirse cada 5-15 minutos si no hay mejor\xeda.",critico:!0,farmacos:[{nombre:"Epinefrina",dosis:"0.3-0.5 mg IM (soluci\xf3n 1:1000 = 1 mg/mL). Pedi\xe1trico: 0.01 mg/kg IM (m\xe1x. 0.3 mg)",via:"IM"}]},{orden:2,tiempo:"0-2 min",accion:"Posicionar paciente y asegurar v\xeda a\xe9rea",detalles:"Posici\xf3n de Trendelenburg si hay hipotensi\xf3n. Posici\xf3n semisentada si hay distr\xe9s respiratorio. Administrar O2 al 100% con mascarilla de alto flujo (15 L/min). Preparar equipo de intubaci\xf3n.",critico:!0},{orden:3,tiempo:"1-3 min",accion:"Establecer acceso IV y administrar l\xedquidos",detalles:"Dos accesos venosos de gran calibre (14-16G). Bolo r\xe1pido de cristaloides. Puede requerir 1-2 litros adicionales en la primera hora si hay hipotensi\xf3n refractaria.",critico:!0,farmacos:[{nombre:"Soluci\xf3n Salina Normal (SSN 0.9%)",dosis:"500-1000 mL IV en bolo r\xe1pido (adultos); 20 mL/kg IV (pedi\xe1trico)",via:"IV"}]},{orden:4,tiempo:"3-5 min",accion:"Administrar broncodilatador si broncoespasmo",detalles:"Nebulizar salbutamol si hay sibilancias o broncoespasmo. Puede administrarse de forma continua en casos severos.",farmacos:[{nombre:"Salbutamol",dosis:"2.5-5 mg nebulizado cada 20 min o nebulizaci\xf3n continua",via:"Nebulizaci\xf3n"}]},{orden:5,tiempo:"5-10 min",accion:"Administrar corticosteroide IV",detalles:"Previene la fase tard\xeda de la anafilaxia (puede ocurrir 4-8 horas despu\xe9s). No sustituye a la epinefrina.",farmacos:[{nombre:"Hidrocortisona",dosis:"200 mg IV (adultos); 4 mg/kg IV (pedi\xe1trico, m\xe1x. 200 mg)",via:"IV"},{nombre:"Metilprednisolona (alternativa)",dosis:"1-2 mg/kg IV (m\xe1x. 125 mg)",via:"IV"}]},{orden:6,tiempo:"5-10 min",accion:"Administrar antihistam\xednicos",detalles:"Anti-H1 y anti-H2 como adyuvantes. NO reemplazan a la epinefrina como primera l\xednea.",farmacos:[{nombre:"Difenhidramina",dosis:"25-50 mg IV lento (adultos); 1 mg/kg IV (pedi\xe1trico, m\xe1x. 50 mg)",via:"IV"},{nombre:"Ranitidina",dosis:"50 mg IV en 100 mL de SSN a pasar en 15-20 min",via:"IV"}]},{orden:7,tiempo:"15-20 min",accion:"Reevaluar respuesta y considerar infusi\xf3n de epinefrina",detalles:"Si hipotensi\xf3n refractaria tras 2-3 dosis IM de epinefrina, iniciar infusi\xf3n IV continua. Monitorizar ECG continuo.",critico:!0,farmacos:[{nombre:"Epinefrina (infusi\xf3n)",dosis:"1-10 mcg/min IV en infusi\xf3n continua (titular seg\xfan respuesta)",via:"IV"}],decision:{pregunta:"\xbfEl paciente responde a las dosis IM de epinefrina?",si:"Mantener observaci\xf3n m\xednima de 6-8 horas por riesgo de reacci\xf3n bif\xe1sica",no:"Iniciar infusi\xf3n continua de epinefrina IV y considerar ingreso en UCI"}}],resumenFarmacos:[{nombre:"Epinefrina IM",dosis:"0.3-0.5 mg IM cada 5-15 min seg\xfan necesidad",via:"IM",indicacion:"Primera l\xednea en anafilaxia; vasoconstrictor y broncodilatador"},{nombre:"Epinefrina IV (infusi\xf3n)",dosis:"1-10 mcg/min IV en infusi\xf3n continua",via:"IV",indicacion:"Anafilaxia refractaria a dosis IM"},{nombre:"Salbutamol",dosis:"2.5-5 mg nebulizado cada 20 min",via:"Nebulizaci\xf3n",indicacion:"Broncoespasmo asociado a anafilaxia"},{nombre:"Hidrocortisona",dosis:"200 mg IV",via:"IV",indicacion:"Prevenci\xf3n de fase tard\xeda de anafilaxia"},{nombre:"Difenhidramina",dosis:"25-50 mg IV",via:"IV",indicacion:"Antihistam\xednico H1 adyuvante para s\xedntomas cut\xe1neos"},{nombre:"Ranitidina",dosis:"50 mg IV",via:"IV",indicacion:"Antihistam\xednico H2 adyuvante"},{nombre:"SSN 0.9%",dosis:"500-1000 mL IV en bolo r\xe1pido",via:"IV",indicacion:"Reposici\xf3n de volumen en shock anafil\xe1ctico"}],notasEnfermeria:["La epinefrina IM es el tratamiento de primera l\xednea; NUNCA debe retrasarse su administraci\xf3n en espera de otros f\xe1rmacos.","Monitorizar al paciente un m\xednimo de 6-8 horas por riesgo de reacci\xf3n bif\xe1sica (recurrencia de s\xedntomas sin nueva exposici\xf3n).","Registrar el al\xe9rgeno sospechoso, la hora de exposici\xf3n y la evoluci\xf3n temporal de los s\xedntomas.","Educar al paciente sobre el uso de autoinyector de epinefrina al alta y la necesidad de portar identificaci\xf3n de alergias.","Vigilar signos de edema de glotis: estridor, disfon\xeda, disfagia, babeo; preparar equipo de v\xeda a\xe9rea quir\xfargica."]},{id:"proto_crisis_hipertensiva",nombre:"Crisis Hipertensiva",descripcion:"Protocolo para el manejo de la emergencia hipertensiva (PA >180/120 mmHg con da\xf1o a \xf3rgano blanco) y la urgencia hipertensiva. El objetivo es la reducci\xf3n controlada de la PA para evitar isquemia.",categoria:"cardiaco",prioridad:"urgente",banderasRojas:["PA >180/120 mmHg con cefalea intensa, alteraci\xf3n visual o confusi\xf3n","Dolor tor\xe1cico o disnea (sospecha de disecci\xf3n a\xf3rtica o EAP)","D\xe9ficit neurol\xf3gico focal (sospecha de ACV)","Hematuria, oliguria o elevaci\xf3n de creatinina","Fondo de ojo con hemorragias, exudados o papiledema"],pasos:[{orden:1,tiempo:"0-5 min",accion:"Evaluaci\xf3n inicial y clasificaci\xf3n",detalles:"Confirmar PA en ambos brazos con manguito adecuado. Determinar si es emergencia hipertensiva (da\xf1o a \xf3rgano blanco) o urgencia hipertensiva (sin da\xf1o a \xf3rgano). ECG, anal\xedtica (creatinina, electrolitos, troponina), radiograf\xeda de t\xf3rax.",critico:!0,decision:{pregunta:"\xbfHay evidencia de da\xf1o a \xf3rgano blanco?",si:"Es EMERGENCIA hipertensiva \u2192 reducci\xf3n IV controlada en UCI (paso 3)",no:"Es URGENCIA hipertensiva \u2192 reducci\xf3n oral gradual en 24-48h (paso 2)"}},{orden:2,tiempo:"5-30 min",accion:"Manejo de urgencia hipertensiva (sin da\xf1o a \xf3rgano)",detalles:"Reducir PA gradualmente en 24-48 horas con antihipertensivos orales. Ambiente tranquilo, reposo. Objetivo: reducir PA un 20-25% en las primeras horas.",farmacos:[{nombre:"Captopril",dosis:"25 mg VO sublingual, puede repetirse en 30 min",via:"VO/SL"},{nombre:"Amlodipino",dosis:"5-10 mg VO",via:"VO"}]},{orden:3,tiempo:"5-15 min",accion:"Iniciar terapia IV para emergencia hipertensiva",detalles:"Meta: reducir PA no m\xe1s del 25% en la primera hora, luego a 160/100 mmHg en 2-6 horas. Reducci\xf3n excesiva puede causar isquemia cerebral o coronaria. Seleccionar f\xe1rmaco seg\xfan etiolog\xeda.",critico:!0,farmacos:[{nombre:"Labetalol",dosis:"20 mg IV en 2 min, luego 20-80 mg IV cada 10 min (m\xe1x. 300 mg) o infusi\xf3n 0.5-2 mg/min",via:"IV"}]},{orden:4,tiempo:"15-30 min",accion:"Alternativas seg\xfan etiolog\xeda y respuesta",detalles:"Si no hay respuesta a labetalol, considerar alternativas. Nicardipina en infusi\xf3n es preferible si se requiere titulaci\xf3n precisa. Nitroprusiato en emergencia refractaria (precauci\xf3n: toxicidad por cianuro).",farmacos:[{nombre:"Nicardipina",dosis:"5 mg/h IV en infusi\xf3n, titular cada 5-15 min en incrementos de 2.5 mg/h (m\xe1x. 15 mg/h)",via:"IV"},{nombre:"Nitroprusiato de sodio",dosis:"0.25-10 mcg/kg/min IV en infusi\xf3n continua (proteger de la luz)",via:"IV"}]},{orden:5,tiempo:"30-60 min",accion:"Monitoreo continuo y ajuste de tratamiento",detalles:"PA cada 5-15 minutos durante infusi\xf3n. Monitoreo neurol\xf3gico frecuente. Evaluar diuresis horaria. Ajustar infusi\xf3n para mantener PA en rango objetivo.",critico:!0},{orden:6,tiempo:"2-6 horas",accion:"Transici\xf3n a terapia oral",detalles:"Una vez estabilizada la PA IV, iniciar antihipertensivos orales con superposici\xf3n antes de suspender infusi\xf3n. No reducir PA a valores normales en las primeras 24-48h.",farmacos:[{nombre:"Labetalol oral",dosis:"200-400 mg VO cada 8-12h",via:"VO"}]}],resumenFarmacos:[{nombre:"Labetalol IV",dosis:"20 mg IV en bolo, luego 20-80 mg IV cada 10 min o infusi\xf3n 0.5-2 mg/min",via:"IV",indicacion:"Primera l\xednea en emergencia hipertensiva (excepto contraindicaciones de betabloqueantes)"},{nombre:"Nicardipina",dosis:"5-15 mg/h IV en infusi\xf3n continua",via:"IV",indicacion:"Alternativa a labetalol; preferida en ACV y si hay contraindicaci\xf3n de betabloqueantes"},{nombre:"Nitroprusiato de sodio",dosis:"0.25-10 mcg/kg/min IV en infusi\xf3n",via:"IV",indicacion:"Crisis refractaria a otros agentes; uso m\xe1ximo 48-72h por toxicidad de cianuro"},{nombre:"Captopril",dosis:"25 mg VO/SL",via:"VO/SL",indicacion:"Urgencia hipertensiva sin da\xf1o a \xf3rgano blanco"},{nombre:"Amlodipino",dosis:"5-10 mg VO",via:"VO",indicacion:"Urgencia hipertensiva, reducci\xf3n gradual oral"}],notasEnfermeria:["NO reducir la PA de forma abrupta; la reducci\xf3n excesiva puede causar isquemia cerebral, coronaria o renal.","Monitorizar PA con l\xednea arterial o PANI cada 5-15 min durante infusi\xf3n IV de antihipertensivos.","Vigilar signos de hipoperfusi\xf3n: confusi\xf3n, dolor tor\xe1cico, oliguria, deterioro neurol\xf3gico.","El nitroprusiato debe protegerse de la luz con cubierta opaca y no usar por m\xe1s de 48-72 horas.","Registrar balance h\xeddrico estricto y diuresis horaria durante el manejo agudo."]},{id:"proto_iam_stemi",nombre:"IAM con Elevaci\xf3n del ST (STEMI)",abreviatura:"STEMI",descripcion:"Protocolo de manejo del infarto agudo de miocardio con elevaci\xf3n del segmento ST. El objetivo primario es la reperfusi\xf3n lo m\xe1s r\xe1pida posible (puerta-bal\xf3n <90 min o puerta-aguja <30 min).",categoria:"cardiaco",prioridad:"critico",banderasRojas:["Dolor tor\xe1cico opresivo >20 min que no cede con nitroglicerina","Elevaci\xf3n del ST \u22651 mm en \u22652 derivaciones contiguas o BRIHH nuevo","Diaforesis, n\xe1useas, disnea con dolor precordial","Hipotensi\xf3n o signos de shock cardiog\xe9nico","Arritmias ventriculares (TV/FV) en contexto de dolor tor\xe1cico"],pasos:[{orden:1,tiempo:"0-5 min",accion:"ECG 12 derivaciones e identificaci\xf3n de STEMI",detalles:"ECG en los primeros 10 minutos del contacto. Identificar elevaci\xf3n del ST, territorio afectado. Activar c\xf3digo infarto/equipo de hemodin\xe1mica. Monitorizaci\xf3n continua.",critico:!0},{orden:2,tiempo:"0-5 min",accion:"MONA: Morfina, Ox\xedgeno, Nitroglicerina, Aspirina",detalles:"Aspirina masticada inmediatamente (si no hay alergia). O2 solo si SpO2 <90%. Nitroglicerina si PAS >90 mmHg y no hay IAM de VD. Morfina si dolor persiste tras nitroglicerina.",critico:!0,farmacos:[{nombre:"Aspirina (AAS)",dosis:"300 mg VO masticada (carga)",via:"VO"},{nombre:"Nitroglicerina",dosis:"0.4 mg SL cada 5 min (m\xe1x. 3 dosis); si persiste dolor: 5-200 mcg/min IV",via:"SL/IV"},{nombre:"Morfina",dosis:"2-4 mg IV cada 5-15 min seg\xfan dolor (si NTG no alivia)",via:"IV"},{nombre:"Ox\xedgeno",dosis:"2-4 L/min por c\xe1nula nasal (solo si SpO2 <90%)",via:"Inhalatoria"}]},{orden:3,tiempo:"5-10 min",accion:"Anticoagulaci\xf3n y segundo antiagregante",detalles:"Iniciar heparina. Agregar segundo antiagregante plaquetario (clopidogrel, ticagrelor o prasugrel seg\xfan disponibilidad y riesgo hemorr\xe1gico).",critico:!0,farmacos:[{nombre:"Heparina no fraccionada",dosis:"60 UI/kg IV en bolo (m\xe1x. 4000 UI), luego 12 UI/kg/h (m\xe1x. 1000 UI/h). Ajustar seg\xfan TTPa",via:"IV"},{nombre:"Clopidogrel",dosis:"300-600 mg VO (carga)",via:"VO"}]},{orden:4,tiempo:"10-30 min",accion:"Estrategia de reperfusi\xf3n",detalles:"ICP primaria es preferida si est\xe1 disponible en <120 min. Si ICP no disponible en tiempo, considerar fibrinolisis en <30 min del diagn\xf3stico.",critico:!0,decision:{pregunta:"\xbfAngioplastia primaria disponible en <120 minutos?",si:"Trasladar a hemodin\xe1mica para ICP primaria (puerta-bal\xf3n <90 min)",no:"Administrar fibrinol\xedtico si <12h de inicio de s\xedntomas y sin contraindicaciones (paso 5)"}},{orden:5,tiempo:"Seg\xfan decisi\xf3n",accion:"Fibrinolisis (si ICP no disponible)",detalles:"Administrar dentro de los primeros 30 min del diagn\xf3stico. Contraindicaciones absolutas: sangrado activo, ACV hemorr\xe1gico previo, cirug\xeda mayor <3 semanas. Evaluar criterios de reperfusi\xf3n a los 60-90 min.",farmacos:[{nombre:"Tenecteplasa (TNK)",dosis:"Seg\xfan peso: <60 kg: 30 mg; 60-69 kg: 35 mg; 70-79 kg: 40 mg; 80-89 kg: 45 mg; \u226590 kg: 50 mg IV en bolo",via:"IV"},{nombre:"Alteplasa (alternativa)",dosis:"15 mg IV bolo, luego 0.75 mg/kg en 30 min (m\xe1x 50 mg), luego 0.5 mg/kg en 60 min (m\xe1x 35 mg). Total m\xe1x: 100 mg",via:"IV"}]},{orden:6,tiempo:"Continuo",accion:"Manejo complementario y monitorizaci\xf3n",detalles:"Betabloqueante oral en las primeras 24h si no hay contraindicaci\xf3n (IC, bradicardia, hipotensi\xf3n). IECA/ARA-II en las primeras 24h si funci\xf3n sist\xf3lica reducida. Estatina de alta potencia.",farmacos:[{nombre:"Atorvastatina",dosis:"80 mg VO",via:"VO"},{nombre:"Metoprolol",dosis:"25-50 mg VO cada 6-12h (si FC >60, PAS >100, sin IC)",via:"VO"}]}],resumenFarmacos:[{nombre:"Aspirina",dosis:"300 mg VO masticada",via:"VO",indicacion:"Antiagregante plaquetario de primera l\xednea en SCA"},{nombre:"Clopidogrel",dosis:"300-600 mg VO (carga)",via:"VO",indicacion:"Segundo antiagregante plaquetario en doble antiagregaci\xf3n"},{nombre:"Heparina no fraccionada",dosis:"60 UI/kg bolo IV, luego 12 UI/kg/h",via:"IV",indicacion:"Anticoagulaci\xf3n en SCA para prevenir extensi\xf3n del trombo"},{nombre:"Nitroglicerina",dosis:"0.4 mg SL o 5-200 mcg/min IV",via:"SL/IV",indicacion:"Vasodilatador coronario para alivio del dolor isqu\xe9mico"},{nombre:"Morfina",dosis:"2-4 mg IV cada 5-15 min",via:"IV",indicacion:"Analgesia cuando nitroglicerina no alivia el dolor"},{nombre:"Tenecteplasa",dosis:"30-50 mg IV seg\xfan peso corporal",via:"IV",indicacion:"Fibrinol\xedtico cuando ICP no disponible en <120 min"},{nombre:"Atorvastatina",dosis:"80 mg VO",via:"VO",indicacion:"Estatina de alta intensidad para estabilizaci\xf3n de placa"},{nombre:"Metoprolol",dosis:"25-50 mg VO cada 6-12h",via:"VO",indicacion:"Betabloqueante para reducir demanda mioc\xe1rdica de O2"}],notasEnfermeria:["El tiempo es miocardio: cada minuto de retraso en la reperfusi\xf3n aumenta la mortalidad. Objetivo puerta-ECG <10 min.","NO administrar nitroglicerina si PAS <90 mmHg, FC <50 o >100, o sospecha de IAM de ventr\xedculo derecho (derivaciones derechas V3R-V4R).","Mantener dos accesos venosos permeables de gran calibre; nunca administrar fibrinol\xedtico por la misma v\xeda de heparina.","Vigilar signos de reperfusi\xf3n post-fibrinolisis: alivio del dolor, resoluci\xf3n del ST >50%, arritmias de reperfusi\xf3n (RIVA).","Monitorizaci\xf3n continua de ECG, PA y SpO2. Tener desfibrilador listo por riesgo de arritmias ventriculares."]},{id:"proto_acv_agudo",nombre:"ACV Agudo - Ictus Isqu\xe9mico",abreviatura:"ACV",descripcion:"Protocolo de manejo del accidente cerebrovascular isqu\xe9mico agudo. La ventana terap\xe9utica para tromb\xf3lisis IV con alteplasa es de 4.5 horas desde el inicio de los s\xedntomas. La trombectom\xeda mec\xe1nica puede extenderse hasta 24 horas en pacientes seleccionados.",categoria:"neurologico",prioridad:"critico",banderasRojas:["D\xe9ficit neurol\xf3gico focal de inicio s\xfabito (hemiparesia, afasia, hemianopsia)","Desviaci\xf3n de la comisura labial y debilidad de extremidades","Alteraci\xf3n del habla (disartria o afasia) de inicio brusco","P\xe9rdida de equilibrio o coordinaci\xf3n con otros d\xe9ficits neurol\xf3gicos","Cefalea intensa s\xfabita con rigidez de nuca (descartar hemorragia)"],pasos:[{orden:1,tiempo:"0-10 min",accion:"Activar c\xf3digo ictus y evaluaci\xf3n inicial",detalles:"Establecer hora de inicio de s\xedntomas (o \xfaltima vez visto normal). Escala NIHSS. Glucemia capilar inmediata (descartar hipoglucemia). Asegurar v\xeda a\xe9rea, O2 si SpO2 <94%. Dos accesos IV.",critico:!0},{orden:2,tiempo:"10-25 min",accion:"TC craneal urgente sin contraste",detalles:"Descartar hemorragia intracraneal antes de tromb\xf3lisis. Angiotomograf\xeda si disponible para evaluar oclusi\xf3n de gran vaso. No retrasar la TC.",critico:!0,decision:{pregunta:"\xbfLa TC muestra hemorragia intracraneal?",si:"Descartar tromb\xf3lisis; consultar neurocirug\xeda. Manejar como ACV hemorr\xe1gico.",no:"Continuar evaluaci\xf3n para tromb\xf3lisis IV si est\xe1 dentro de ventana terap\xe9utica (paso 3)"}},{orden:3,tiempo:"25-45 min",accion:"Evaluar criterios de tromb\xf3lisis IV",detalles:"Ventana: <4.5 horas desde inicio de s\xedntomas. Contraindicaciones: sangrado activo, plaquetas <100,000, INR >1.7, cirug\xeda mayor <14 d\xedas, ACV o TCE <3 meses, PA no controlable. Obtener consentimiento.",critico:!0,decision:{pregunta:"\xbfCumple criterios para tromb\xf3lisis IV (<4.5h, sin contraindicaciones)?",si:"Administrar alteplasa IV (paso 4). Objetivo puerta-aguja <60 min.",no:"Evaluar trombectom\xeda mec\xe1nica si oclusi\xf3n de gran vaso (<24h en pacientes seleccionados)"}},{orden:4,tiempo:"45-60 min",accion:"Administrar Alteplasa IV",detalles:"Dosis total: 0.9 mg/kg (m\xe1x. 90 mg). 10% en bolo IV en 1 minuto, 90% restante en infusi\xf3n IV en 60 minutos. No administrar anticoagulantes ni antiagregantes en las siguientes 24 horas.",critico:!0,farmacos:[{nombre:"Alteplasa (rt-PA)",dosis:"0.9 mg/kg IV (m\xe1x. 90 mg): 10% en bolo en 1 min, 90% en infusi\xf3n en 60 min",via:"IV"}]},{orden:5,tiempo:"Durante y post-infusi\xf3n",accion:"Control estricto de PA durante y despu\xe9s de tromb\xf3lisis",detalles:"Mantener PA <185/110 mmHg antes y durante tromb\xf3lisis; <180/105 mmHg en las 24h siguientes. Usar labetalol o nicardipina IV si es necesario.",critico:!0,farmacos:[{nombre:"Labetalol",dosis:"10-20 mg IV en 1-2 min, puede repetirse cada 10-20 min (m\xe1x. 300 mg)",via:"IV"},{nombre:"Nicardipina",dosis:"5 mg/h IV, titular cada 5-15 min, incrementos de 2.5 mg/h (m\xe1x. 15 mg/h)",via:"IV"}]},{orden:6,tiempo:"Post-tromb\xf3lisis",accion:"Monitorizaci\xf3n neurol\xf3gica intensiva",detalles:"NIHSS cada 15 min durante la infusi\xf3n, cada 30 min por 6h, luego cada hora por 18h. Vigilar signos de hemorragia intracraneal: cefalea intensa, v\xf3mitos, deterioro del nivel de conciencia, aumento de PA. TC de control a las 24h.",critico:!0,decision:{pregunta:"\xbfDeterioro neurol\xf3gico durante o despu\xe9s de la infusi\xf3n?",si:"Detener infusi\xf3n de alteplasa, TC craneal urgente, solicitar hemograma, fibrin\xf3geno y pruebas cruzadas",no:"Continuar monitorizaci\xf3n. TC de control a las 24h antes de iniciar antiagregaci\xf3n."}}],resumenFarmacos:[{nombre:"Alteplasa (rt-PA)",dosis:"0.9 mg/kg IV (m\xe1x. 90 mg): 10% bolo + 90% en 60 min",via:"IV",indicacion:"Tromb\xf3lisis en ACV isqu\xe9mico dentro de ventana de 4.5 horas"},{nombre:"Labetalol",dosis:"10-20 mg IV cada 10-20 min (m\xe1x. 300 mg)",via:"IV",indicacion:"Control de PA peri-tromb\xf3lisis"},{nombre:"Nicardipina",dosis:"5-15 mg/h IV en infusi\xf3n",via:"IV",indicacion:"Control de PA cuando se requiere titulaci\xf3n precisa"}],notasEnfermeria:["Tiempo es cerebro: el objetivo es puerta-aguja <60 minutos. Cada minuto de retraso se pierden ~1.9 millones de neuronas.","NO administrar antiagregantes ni anticoagulantes en las 24 horas posteriores a la tromb\xf3lisis IV.","Realizar escala NIHSS de forma seriada y documentar cualquier cambio neurol\xf3gico inmediatamente.","Mantener al paciente en ayuno hasta evaluaci\xf3n de degluci\xf3n (riesgo de disfagia y broncoaspiraci\xf3n).","Evitar punciones arteriales, sondaje vesical y procedimientos invasivos durante al menos 24h post-tromb\xf3lisis."]},{id:"proto_status_epileptico",nombre:"Status Epil\xe9ptico",descripcion:"Protocolo de manejo del estado epil\xe9ptico, definido como crisis convulsiva continua de >5 minutos o dos o m\xe1s crisis sin recuperaci\xf3n de conciencia entre ellas. Es una emergencia neurol\xf3gica con alta morbimortalidad.",categoria:"neurologico",prioridad:"critico",banderasRojas:["Crisis convulsiva t\xf3nico-cl\xf3nica generalizada que dura >5 minutos","Crisis recurrentes sin recuperaci\xf3n de conciencia entre episodios","Cianosis durante crisis prolongada","Fiebre alta asociada a convulsiones (descartar meningoencefalitis)","Antecedente de epilepsia con incumplimiento terap\xe9utico reciente"],pasos:[{orden:1,tiempo:"0-5 min",accion:"Estabilizaci\xf3n inicial y primera l\xednea de tratamiento",detalles:"Proteger v\xeda a\xe9rea (posici\xf3n lateral, aspirar secreciones, NO introducir objetos en la boca). O2 al 100%. Monitorizar SpO2, ECG, PA. Glucemia capilar inmediata. Acceso IV.",critico:!0,farmacos:[{nombre:"Diazepam",dosis:"10 mg IV lento (2 mg/min) o 20 mg rectal. Pedi\xe1trico: 0.2-0.5 mg/kg IV (m\xe1x. 10 mg)",via:"IV/Rectal"},{nombre:"Midazolam (si no hay acceso IV)",dosis:"10 mg IM o 10 mg intranasal/bucal. Pedi\xe1trico: 0.2 mg/kg IM (m\xe1x. 10 mg)",via:"IM/Intranasal"}],decision:{pregunta:"\xbfSe tiene acceso venoso?",si:"Administrar diazepam 10 mg IV lento. Puede repetir una vez en 5 min si persiste crisis.",no:"Administrar midazolam 10 mg IM o intranasal mientras se obtiene acceso IV."}},{orden:2,tiempo:"5-10 min",accion:"Tratar hipoglucemia si est\xe1 presente",detalles:"Si glucemia <60 mg/dL, administrar dextrosa IV. En pacientes alcoh\xf3licos o desnutridos, administrar tiamina ANTES de la dextrosa.",farmacos:[{nombre:"Dextrosa 50%",dosis:"50 mL IV (25 g de glucosa). Pedi\xe1trico: Dextrosa 25% 2-4 mL/kg IV",via:"IV"},{nombre:"Tiamina",dosis:"100 mg IV (administrar antes de dextrosa en sospecha de d\xe9ficit)",via:"IV"}]},{orden:3,tiempo:"10-20 min",accion:"Segunda l\xednea: antiepil\xe9ptico de carga",detalles:"Si las crisis persisten tras benzodiazepinas, iniciar un antiepil\xe9ptico de segunda l\xednea. Levetiracetam es preferido por menor sedaci\xf3n y menos interacciones. Fenito\xedna es alternativa cl\xe1sica (no usar en miocl\xf3nicas).",critico:!0,farmacos:[{nombre:"Levetiracetam",dosis:"60 mg/kg IV (m\xe1x. 4500 mg) en 15 min",via:"IV"},{nombre:"Fenito\xedna",dosis:"20 mg/kg IV a velocidad m\xe1xima de 50 mg/min (o fosfenito\xedna 20 mg EF/kg a 150 mg EF/min). Monitorizar ECG.",via:"IV"},{nombre:"\xc1cido valproico (alternativa)",dosis:"40 mg/kg IV en 10 min (m\xe1x. 3000 mg)",via:"IV"}]},{orden:4,tiempo:"20-40 min",accion:"Status epil\xe9ptico refractario",detalles:"Si persiste tras benzodiazepinas + antiepil\xe9ptico de segunda l\xednea. Considerar intubaci\xf3n y soporte en UCI. Iniciar anest\xe9sicos en infusi\xf3n continua con monitoreo EEG.",critico:!0,farmacos:[{nombre:"Midazolam (infusi\xf3n)",dosis:"0.2 mg/kg IV bolo, luego 0.1-2 mg/kg/h en infusi\xf3n continua",via:"IV"},{nombre:"Propofol",dosis:"1-2 mg/kg IV bolo, luego 2-10 mg/kg/h en infusi\xf3n continua (vigilar s\xedndrome de infusi\xf3n de propofol)",via:"IV"}]},{orden:5,tiempo:"Continuo",accion:"Estudios complementarios y b\xfasqueda etiol\xf3gica",detalles:"Anal\xedtica completa: electrolitos, calcio, magnesio, niveles de antiepil\xe9pticos, t\xf3xicos. TC craneal urgente. Punci\xf3n lumbar si sospecha de infecci\xf3n del SNC. EEG continuo en UCI.",critico:!1}],resumenFarmacos:[{nombre:"Diazepam",dosis:"10 mg IV lento (puede repetir x1) o 20 mg rectal",via:"IV/Rectal",indicacion:"Primera l\xednea para abortar crisis convulsiva"},{nombre:"Midazolam",dosis:"10 mg IM/intranasal (si no hay acceso IV)",via:"IM/Intranasal",indicacion:"Alternativa a diazepam cuando no hay acceso venoso"},{nombre:"Levetiracetam",dosis:"60 mg/kg IV (m\xe1x. 4500 mg) en 15 min",via:"IV",indicacion:"Segunda l\xednea; carga antiepil\xe9ptica con menos interacciones"},{nombre:"Fenito\xedna",dosis:"20 mg/kg IV a m\xe1x. 50 mg/min",via:"IV",indicacion:"Segunda l\xednea cl\xe1sica; requiere monitoreo card\xedaco por riesgo de arritmias"},{nombre:"\xc1cido valproico",dosis:"40 mg/kg IV en 10 min (m\xe1x. 3000 mg)",via:"IV",indicacion:"Alternativa de segunda l\xednea, \xfatil en crisis generalizadas y miocl\xf3nicas"},{nombre:"Propofol",dosis:"1-2 mg/kg IV bolo, luego 2-10 mg/kg/h",via:"IV",indicacion:"Status refractario en UCI con intubaci\xf3n"}],notasEnfermeria:["NO introducir objetos en la boca durante la crisis; proteger al paciente de lesiones retirando objetos cercanos.","La fenito\xedna debe administrarse SOLO en soluci\xf3n salina (incompatible con dextrosa); vigilar flebitis y extravasaci\xf3n (puede causar necrosis tisular).","Monitorizar ECG continuamente durante la infusi\xf3n de fenito\xedna por riesgo de arritmias y bradicardia.","Documentar duraci\xf3n exacta de cada crisis, tipo de movimientos y nivel de conciencia entre episodios.","Preparar equipo de intubaci\xf3n si las crisis persisten >20 minutos o hay compromiso de v\xeda a\xe9rea."]},{id:"proto_hipoglucemia",nombre:"Hipoglucemia Severa",descripcion:"Protocolo de manejo de la hipoglucemia severa (glucemia <54 mg/dL o s\xedntomas neuroglucop\xe9nicos), una emergencia metab\xf3lica frecuente en pacientes diab\xe9ticos tratados con insulina o sulfonilureas.",categoria:"metabolico",prioridad:"urgente",banderasRojas:["Glucemia <54 mg/dL con alteraci\xf3n del nivel de conciencia","Convulsiones asociadas a hipoglucemia","Paciente diab\xe9tico con diaforesis, temblor y confusi\xf3n","Incapacidad para ingerir glucosa por v\xeda oral","Uso reciente de insulina o sulfonilureas con ingesta alimentaria inadecuada"],pasos:[{orden:1,tiempo:"0-1 min",accion:"Confirmar hipoglucemia y evaluar estado de conciencia",detalles:"Glucemia capilar inmediata. Evaluar nivel de conciencia y capacidad de degluci\xf3n. Asegurar v\xeda a\xe9rea si hay alteraci\xf3n de conciencia.",critico:!0,decision:{pregunta:"\xbfEl paciente est\xe1 consciente y puede deglutir?",si:"Administrar 15-20 g de glucosa oral (jugo, tabletas de glucosa). Reevaluar en 15 min.",no:"Administrar dextrosa IV o glucag\xf3n IM (pasos 2-3)"}},{orden:2,tiempo:"1-3 min",accion:"Administrar Dextrosa IV (si hay acceso venoso)",detalles:"Dextrosa 50% por v\xeda IV es el tratamiento de elecci\xf3n en paciente con alteraci\xf3n de conciencia. Puede repetirse si no hay respuesta en 5 minutos.",critico:!0,farmacos:[{nombre:"Dextrosa 50%",dosis:"25-50 mL IV (12.5-25 g de glucosa) en bolo. Pedi\xe1trico: Dextrosa 10% 5 mL/kg IV",via:"IV"}]},{orden:3,tiempo:"1-3 min",accion:"Administrar Glucag\xf3n (si no hay acceso IV)",detalles:"Glucag\xf3n IM/SC cuando no se puede obtener acceso venoso. Inicio de acci\xf3n: 10-15 minutos. Menos efectivo en pacientes con depleci\xf3n de gluc\xf3geno hep\xe1tico (alcoholismo, insuficiencia hep\xe1tica).",farmacos:[{nombre:"Glucag\xf3n",dosis:"1 mg IM/SC (adultos). Pedi\xe1trico <25 kg: 0.5 mg IM/SC",via:"IM/SC"}]},{orden:4,tiempo:"15 min",accion:"Reevaluar glucemia y respuesta cl\xednica",detalles:"Control de glucemia capilar a los 15 minutos. Si glucemia sigue <70 mg/dL, repetir tratamiento. Una vez glucemia >70 mg/dL, administrar snack con carbohidratos complejos y prote\xednas.",critico:!0,decision:{pregunta:"\xbfGlucemia >70 mg/dL tras tratamiento?",si:"Dar snack con carbohidratos complejos. Investigar causa de hipoglucemia.",no:"Repetir dextrosa 50% IV. Si persiste, iniciar infusi\xf3n de dextrosa 10% y evaluar causa."}},{orden:5,tiempo:"30-60 min",accion:"Prevenir recurrencia e investigar causa",detalles:"Si hipoglucemia por sulfonilureas: alto riesgo de recurrencia prolongada (hasta 72h); considerar infusi\xf3n de dextrosa 10% y observaci\xf3n prolongada. Ajustar dosis de insulina/hipoglucemiantes. Si hipoglucemia por insulina de acci\xf3n prolongada, monitorizar \u226524h.",farmacos:[{nombre:"Dextrosa 10%",dosis:"100-200 mL/h IV en infusi\xf3n continua (ajustar seg\xfan glucemias cada 1-2h)",via:"IV"}]}],resumenFarmacos:[{nombre:"Dextrosa 50%",dosis:"25-50 mL IV en bolo (12.5-25 g de glucosa)",via:"IV",indicacion:"Primera l\xednea en hipoglucemia severa con alteraci\xf3n de conciencia y acceso IV"},{nombre:"Glucag\xf3n",dosis:"1 mg IM/SC",via:"IM/SC",indicacion:"Hipoglucemia severa sin acceso venoso disponible"},{nombre:"Dextrosa 10%",dosis:"100-200 mL/h IV en infusi\xf3n continua",via:"IV",indicacion:"Prevenci\xf3n de recurrencia de hipoglucemia, especialmente por sulfonilureas"}],notasEnfermeria:["La dextrosa 50% es vesicante: verificar permeabilidad del acceso IV antes de administrar. Si hay extravasaci\xf3n, suspender inmediatamente.","En hipoglucemia por sulfonilureas (glibenclamida, glimepirida), el paciente requiere observaci\xf3n prolongada (24-72h) por riesgo de recurrencia.","Monitorizar glucemia capilar cada 15-30 min durante la fase aguda, luego cada 1-2 horas durante la observaci\xf3n.","Documentar la causa probable de la hipoglucemia: omisi\xf3n de comida, error en dosis de insulina, ejercicio excesivo, interacci\xf3n farmacol\xf3gica.","Educar al paciente y familiares sobre reconocimiento de s\xedntomas y uso de glucag\xf3n antes del alta."]},{id:"proto_hiperpotasemia",nombre:"Hiperpotasemia",descripcion:"Protocolo de manejo de la hiperpotasemia severa (K+ >6.5 mEq/L o con cambios electrocardiogr\xe1ficos). La hiperpotasemia es una emergencia metab\xf3lica que puede causar arritmias letales. El tratamiento sigue tres principios: estabilizaci\xf3n de membrana card\xedaca, redistribuci\xf3n intracelular de potasio y eliminaci\xf3n corporal.",categoria:"metabolico",prioridad:"urgente",banderasRojas:["K+ >6.5 mEq/L o cualquier nivel con cambios en ECG","Cambios ECG: ondas T picudas, PR prolongado, QRS ancho, ondas sinusoidales","Debilidad muscular progresiva o par\xe1lisis fl\xe1cida","Paciente con insuficiencia renal y oliguria/anuria","Bradicardia o arritmias ventriculares en contexto de falla renal"],pasos:[{orden:1,tiempo:"0-2 min",accion:"ECG inmediato y estabilizaci\xf3n de membrana card\xedaca",detalles:"Realizar ECG de 12 derivaciones. Si hay cambios electrocardiogr\xe1ficos (ondas T picudas, ensanchamiento QRS, bradiarritmias), administrar calcio IV inmediatamente para estabilizar la membrana mioc\xe1rdica. El calcio NO reduce el potasio.",critico:!0,farmacos:[{nombre:"Gluconato de calcio 10%",dosis:"10-20 mL (1-2 ampollas) IV lento en 2-3 min. Puede repetir en 5 min si persisten cambios ECG",via:"IV"}]},{orden:2,tiempo:"2-10 min",accion:"Redistribuci\xf3n del potasio al espacio intracelular",detalles:"La insulina con glucosa es el m\xe9todo m\xe1s efectivo para la redistribuci\xf3n. El salbutamol nebulizado tiene efecto aditivo. Reducci\xf3n esperada: 0.5-1.5 mEq/L en 30-60 minutos.",critico:!0,farmacos:[{nombre:"Insulina regular + Dextrosa",dosis:"Insulina regular 10 UI IV + Dextrosa 50% 50 mL IV (25 g). Monitorizar glucemia cada 30 min por 4-6h",via:"IV"},{nombre:"Salbutamol",dosis:"10-20 mg nebulizado en 10 min (4-8 veces la dosis broncodilatadora habitual)",via:"Nebulizaci\xf3n"}]},{orden:3,tiempo:"5-15 min",accion:"Corregir acidosis metab\xf3lica si est\xe1 presente",detalles:"El bicarbonato de sodio solo es efectivo si hay acidosis metab\xf3lica concomitante (pH <7.2). No es primera l\xednea como monoterapia para hiperpotasemia. Desplaza potasio al espacio intracelular al corregir el pH.",farmacos:[{nombre:"Bicarbonato de sodio",dosis:"50 mEq IV en 5 min (si pH <7.2). No mezclar con calcio en la misma v\xeda.",via:"IV"}],decision:{pregunta:"\xbfHay acidosis metab\xf3lica (pH <7.2)?",si:"Administrar bicarbonato de sodio 50 mEq IV",no:"Omitir bicarbonato; continuar con medidas de eliminaci\xf3n (paso 4)"}},{orden:4,tiempo:"15-30 min",accion:"Eliminaci\xf3n corporal de potasio",detalles:"Furosemida si hay funci\xf3n renal residual. Sulfonato de poliestireno s\xf3dico (Kayexalate) como resina de intercambio cati\xf3nico (inicio de acci\xf3n lento: 1-4 horas). Si insuficiencia renal severa o refractariedad: hemodi\xe1lisis urgente.",farmacos:[{nombre:"Furosemida",dosis:"40-80 mg IV (mayor dosis si insuficiencia renal)",via:"IV"},{nombre:"Sulfonato de poliestireno s\xf3dico (Kayexalate)",dosis:"15-30 g VO con sorbitol al 20% o 30-50 g en enema de retenci\xf3n",via:"VO/Rectal"}]},{orden:5,tiempo:"30-60 min",accion:"Reevaluaci\xf3n y considerar hemodi\xe1lisis",detalles:"Control de K+ s\xe9rico cada 1-2 horas. ECG de control. Si K+ refractario a tratamiento m\xe9dico, oliguria/anuria, o cambios ECG persistentes: hemodi\xe1lisis urgente.",critico:!0,decision:{pregunta:"\xbfK+ sigue >6.5 mEq/L o persisten cambios ECG tras tratamiento?",si:"Solicitar hemodi\xe1lisis urgente. Repetir calcio IV si hay arritmias.",no:"Continuar monitoreo. Tratar causa subyacente. Control de K+ cada 2-4h."}}],resumenFarmacos:[{nombre:"Gluconato de calcio 10%",dosis:"10-20 mL IV en 2-3 min",via:"IV",indicacion:"Cardioprotecci\xf3n; estabiliza la membrana mioc\xe1rdica (no reduce K+)"},{nombre:"Insulina regular + Dextrosa 50%",dosis:"10 UI insulina + 25 g dextrosa IV",via:"IV",indicacion:"Redistribuci\xf3n intracelular de K+ (reduce 0.5-1.5 mEq/L en 30-60 min)"},{nombre:"Salbutamol (dosis alta)",dosis:"10-20 mg nebulizado en 10 min",via:"Nebulizaci\xf3n",indicacion:"Redistribuci\xf3n intracelular de K+ (efecto aditivo con insulina)"},{nombre:"Bicarbonato de sodio",dosis:"50 mEq IV",via:"IV",indicacion:"Solo si acidosis metab\xf3lica concomitante (pH <7.2)"},{nombre:"Furosemida",dosis:"40-80 mg IV",via:"IV",indicacion:"Eliminaci\xf3n renal de K+ (requiere funci\xf3n renal residual)"},{nombre:"Kayexalate",dosis:"15-30 g VO o 30-50 g rectal",via:"VO/Rectal",indicacion:"Resina de intercambio cati\xf3nico para eliminaci\xf3n gastrointestinal de K+"}],notasEnfermeria:["El gluconato de calcio IV debe administrarse lentamente (2-3 min); la infusi\xf3n r\xe1pida puede causar bradicardia severa o asistolia.","NUNCA mezclar calcio y bicarbonato de sodio en la misma v\xeda IV (precipitaci\xf3n de carbonato de calcio).","Monitorizar glucemia cada 30 min durante 4-6h tras la infusi\xf3n de insulina + dextrosa por riesgo de hipoglucemia tard\xeda.","El Kayexalate est\xe1 contraindicado en \xedleo paral\xedtico o post-operatorio intestinal por riesgo de necrosis col\xf3nica.","Monitorizaci\xf3n ECG continua; cualquier cambio en el ritmo card\xedaco debe reportarse inmediatamente."]},{id:"proto_sepsis",nombre:"Sepsis - Hour-1 Bundle",abreviatura:"SEP-1",descripcion:"Protocolo del paquete de la primera hora (Hour-1 Bundle) de la Surviving Sepsis Campaign para el manejo de la sepsis y el shock s\xe9ptico. Todos los elementos deben iniciarse dentro de la primera hora del reconocimiento de la sepsis.",categoria:"sepsis",prioridad:"critico",banderasRojas:["Sospecha de infecci\xf3n con \u22652 criterios SIRS o qSOFA \u22652","Hipotensi\xf3n persistente (PAS <90 mmHg o PAM <65 mmHg) tras cristaloides","Lactato s\xe9rico >2 mmol/L","Alteraci\xf3n aguda del estado mental en contexto de infecci\xf3n","Disfunci\xf3n org\xe1nica nueva: oliguria, coagulopat\xeda, hiperbilirrubinemia, hipoxemia"],pasos:[{orden:1,tiempo:"0-15 min",accion:"Medir lactato s\xe9rico",detalles:"Lactato s\xe9rico inmediato. Si lactato >2 mmol/L, repetir en 2-4 horas para evaluar aclaramiento. Lactato >4 mmol/L indica alto riesgo de mortalidad y necesidad de resucitaci\xf3n agresiva.",critico:!0},{orden:2,tiempo:"0-15 min",accion:"Obtener hemocultivos antes de antibi\xf3ticos",detalles:"Al menos 2 sets de hemocultivos (aerobio + anaerobio) de sitios diferentes ANTES de iniciar antibi\xf3ticos. No retrasar antibi\xf3ticos >45 min por cultivos. Obtener tambi\xe9n cultivos del foco sospechado.",critico:!0},{orden:3,tiempo:"0-60 min",accion:"Iniciar antibi\xf3ticos de amplio espectro IV",detalles:"Antibi\xf3ticos emp\xedricos de amplio espectro dentro de la PRIMERA HORA. Cada hora de retraso en antibi\xf3ticos aumenta la mortalidad un 7.6%. Cubrir pat\xf3genos m\xe1s probables seg\xfan foco sospechado. Desescalar cuando est\xe9n disponibles los cultivos.",critico:!0,farmacos:[{nombre:"Meropenem",dosis:"1 g IV cada 8h (o Piperacilina/Tazobactam 4.5 g IV cada 6h)",via:"IV"},{nombre:"Vancomicina",dosis:"25-30 mg/kg IV (dosis de carga) si sospecha de SAMR",via:"IV"}]},{orden:4,tiempo:"0-60 min",accion:"Resucitaci\xf3n con cristaloides",detalles:"Administrar 30 mL/kg de cristaloides IV si hay hipotensi\xf3n o lactato \u22654 mmol/L. Iniciar en la primera hora. Evaluar respuesta a volumen frecuentemente. Usar SSN 0.9% o Ringer Lactato.",critico:!0,farmacos:[{nombre:"SSN 0.9% o Ringer Lactato",dosis:"30 mL/kg IV en la primera hora (para 70 kg = ~2100 mL). Reevaluar tolerancia a volumen.",via:"IV"}]},{orden:5,tiempo:"60 min",accion:"Iniciar vasopresores si hipotensi\xf3n persistente",detalles:"Si PAM <65 mmHg a pesar de resucitaci\xf3n con cristaloides, iniciar norepinefrina como vasopresor de primera l\xednea. Objetivo PAM \u226565 mmHg. Preferir acceso venoso central, pero puede iniciarse por v\xeda perif\xe9rica temporalmente.",critico:!0,farmacos:[{nombre:"Norepinefrina",dosis:"0.1-0.5 mcg/kg/min IV en infusi\xf3n continua. Titular hasta PAM \u226565 mmHg (m\xe1x. 2-3 mcg/kg/min)",via:"IV"},{nombre:"Vasopresina (adyuvante)",dosis:"0.03-0.04 UI/min IV en infusi\xf3n continua (agregar si norepinefrina >0.25 mcg/kg/min)",via:"IV"}],decision:{pregunta:"\xbfPAM \u226565 mmHg con norepinefrina sola?",si:"Mantener infusi\xf3n y monitorizar. Reevaluar lactato cada 2-4h.",no:"Agregar vasopresina 0.03 UI/min. Si persiste refractario, considerar hidrocortisona 200 mg/d\xeda IV."}},{orden:6,tiempo:"2-6 horas",accion:"Reevaluaci\xf3n del estado hemodin\xe1mico y perfusi\xf3n",detalles:"Reevaluar respuesta a l\xedquidos (elevaci\xf3n pasiva de piernas, variaci\xf3n de presi\xf3n de pulso, ecocardiograf\xeda). Repetir lactato si inicial >2 mmol/L. Monitorizar diuresis (objetivo \u22650.5 mL/kg/h). Si shock refractario: considerar hidrocortisona.",farmacos:[{nombre:"Hidrocortisona",dosis:"200 mg/d\xeda IV (50 mg IV cada 6h) en shock refractario a vasopresores",via:"IV"}]},{orden:7,tiempo:"Continuo",accion:"Control de foco infeccioso",detalles:"Identificar y controlar el foco infeccioso lo antes posible: drenaje de abscesos, desbridamiento de tejidos necr\xf3ticos, retiro de dispositivos infectados, cirug\xeda si es necesario. El control de foco es tan importante como los antibi\xf3ticos.",critico:!0}],resumenFarmacos:[{nombre:"Meropenem",dosis:"1 g IV cada 8h",via:"IV",indicacion:"Antibi\xf3tico de amplio espectro emp\xedrico en sepsis"},{nombre:"Piperacilina/Tazobactam",dosis:"4.5 g IV cada 6h",via:"IV",indicacion:"Alternativa a carbapen\xe9micos como cobertura de amplio espectro"},{nombre:"Vancomicina",dosis:"25-30 mg/kg IV (carga)",via:"IV",indicacion:"Cobertura contra SAMR si hay factores de riesgo"},{nombre:"SSN 0.9% / Ringer Lactato",dosis:"30 mL/kg IV en la primera hora",via:"IV",indicacion:"Resucitaci\xf3n con cristaloides en sepsis con hipoperfusi\xf3n"},{nombre:"Norepinefrina",dosis:"0.1-2 mcg/kg/min IV en infusi\xf3n",via:"IV",indicacion:"Vasopresor de primera l\xednea en shock s\xe9ptico"},{nombre:"Vasopresina",dosis:"0.03-0.04 UI/min IV",via:"IV",indicacion:"Vasopresor adyuvante si norepinefrina >0.25 mcg/kg/min"},{nombre:"Hidrocortisona",dosis:"200 mg/d\xeda IV (50 mg cada 6h)",via:"IV",indicacion:"Shock s\xe9ptico refractario a vasopresores"}],notasEnfermeria:["El paquete de la primera hora (Hour-1 Bundle) debe completarse en los primeros 60 minutos desde la identificaci\xf3n de la sepsis.","Hemocultivos SIEMPRE antes de antibi\xf3ticos, pero NO retrasar antibi\xf3ticos por m\xe1s de 45 minutos esperando cultivos.","La norepinefrina puede iniciarse por v\xeda perif\xe9rica transitoriamente mientras se obtiene acceso central; vigilar extravasaci\xf3n.","Monitorizar diuresis horaria con sonda vesical; objetivo \u22650.5 mL/kg/h como indicador de perfusi\xf3n renal.","Registrar balance h\xeddrico estricto; la sobrecarga de l\xedquidos puede ser perjudicial tras la resucitaci\xf3n inicial."]},{id:"proto_eap",nombre:"EAP - Edema Agudo de Pulm\xf3n",abreviatura:"EAP",descripcion:"Protocolo de manejo del edema agudo de pulm\xf3n cardiog\xe9nico, una emergencia cardiovascular causada por aumento de la presi\xf3n capilar pulmonar secundaria a falla ventricular izquierda aguda.",categoria:"cardiaco",prioridad:"critico",banderasRojas:["Disnea s\xfabita severa con ortopnea y crepitantes bilaterales","Esputo rosado espumoso","Desaturaci\xf3n r\xe1pida (SpO2 <90%) con signos de trabajo respiratorio","Hipotensi\xf3n con signos de bajo gasto card\xedaco (shock cardiog\xe9nico)","Taquicardia, diaforesis y ansiedad intensa con disnea"],pasos:[{orden:1,tiempo:"0-2 min",accion:"Posici\xf3n y oxigenoterapia",detalles:"Sentar al paciente con piernas colgando (reduce retorno venoso). O2 al 100% con mascarilla de alto flujo. Si SpO2 <90% o trabajo respiratorio severo: CPAP/BiPAP (CPAP 5-10 cmH2O). Preparar intubaci\xf3n si falla la VNI.",critico:!0},{orden:2,tiempo:"2-5 min",accion:"Diur\xe9tico de asa IV",detalles:"Furosemida IV para reducir precarga mediante diuresis y venodilataci\xf3n directa. Inicio de acci\xf3n: 5 min (efecto venodilatador) y 15-30 min (efecto diur\xe9tico). Si el paciente toma furosemida cr\xf3nica, administrar al menos el doble de su dosis habitual.",critico:!0,farmacos:[{nombre:"Furosemida",dosis:"40-80 mg IV en bolo (o 2.5 veces la dosis oral habitual si ya la toma). Puede repetirse en 20 min si no hay respuesta.",via:"IV"}]},{orden:3,tiempo:"2-5 min",accion:"Nitroglicerina para reducir precarga y poscarga",detalles:"La nitroglicerina es clave en el manejo del EAP por su efecto venodilatador y vasodilatador coronario. NO administrar si PAS <90 mmHg. Titular seg\xfan PA y respuesta cl\xednica.",critico:!0,farmacos:[{nombre:"Nitroglicerina",dosis:"0.4 mg SL cada 5 min (hasta 3 dosis), luego infusi\xf3n IV 5-200 mcg/min (titular seg\xfan PA)",via:"SL/IV"}],decision:{pregunta:"\xbfPAS >90 mmHg?",si:"Administrar nitroglicerina SL y considerar infusi\xf3n IV. Titular para mantener PAS >90 mmHg.",no:"NO administrar vasodilatadores. Considerar soporte inotr\xf3pico (dobutamina) o vasopresores."}},{orden:4,tiempo:"5-10 min",accion:"Considerar morfina en casos seleccionados",detalles:"Morfina reduce la ansiedad, el trabajo respiratorio y la precarga. Uso controvertido actualmente; reservar para ansiedad severa refractaria. Precauci\xf3n: depresi\xf3n respiratoria, hipotensi\xf3n y n\xe1useas.",farmacos:[{nombre:"Morfina",dosis:"2-4 mg IV lento. Puede repetir cada 5-15 min (monitorizar FR y PA)",via:"IV"}]},{orden:5,tiempo:"10-30 min",accion:"Reevaluar y manejo seg\xfan PA",detalles:"Si PAS <90 mmHg: shock cardiog\xe9nico, considerar inotr\xf3picos y soporte mec\xe1nico. Si PAS 90-140 mmHg: continuar manejo est\xe1ndar. Si PAS >140 mmHg: priorizar vasodilatadores.",critico:!0,farmacos:[{nombre:"Dobutamina (si bajo gasto)",dosis:"2-20 mcg/kg/min IV en infusi\xf3n continua",via:"IV"},{nombre:"Norepinefrina (si shock)",dosis:"0.1-0.5 mcg/kg/min IV en infusi\xf3n continua",via:"IV"}]},{orden:6,tiempo:"30-60 min",accion:"Identificar y tratar causa precipitante",detalles:"ECG: descartar SCA/arritmias. Ecocardiograma urgente. Anal\xedtica: troponina, BNP/NT-proBNP, funci\xf3n renal. Causas comunes: SCA, crisis hipertensiva, arritmias, valvulopat\xeda aguda, incumplimiento terap\xe9utico.",critico:!1}],resumenFarmacos:[{nombre:"Furosemida",dosis:"40-80 mg IV en bolo",via:"IV",indicacion:"Diur\xe9tico de asa para reducir sobrecarga de volumen y precarga"},{nombre:"Nitroglicerina",dosis:"0.4 mg SL o 5-200 mcg/min IV",via:"SL/IV",indicacion:"Vasodilatador para reducir precarga y poscarga (requiere PAS >90)"},{nombre:"Morfina",dosis:"2-4 mg IV cada 5-15 min",via:"IV",indicacion:"Ansiol\xedtico y reductor de precarga en casos seleccionados"},{nombre:"Dobutamina",dosis:"2-20 mcg/kg/min IV",via:"IV",indicacion:"Soporte inotr\xf3pico en EAP con bajo gasto card\xedaco"},{nombre:"Norepinefrina",dosis:"0.1-0.5 mcg/kg/min IV",via:"IV",indicacion:"Vasopresor en EAP con shock cardiog\xe9nico"}],notasEnfermeria:["Sentar al paciente con piernas colgando para reducir el retorno venoso y mejorar la mec\xe1nica respiratoria.","Monitorizar diuresis horaria; la respuesta a furosemida se espera en 15-30 minutos. Reportar si diuresis <0.5 mL/kg/h.","CPAP/BiPAP es de primera l\xednea en VNI; reduce la necesidad de intubaci\xf3n. Asegurar buen sellado de mascarilla.","Vigilar signos de deterioro: esputo rosado espumoso en aumento, desaturaci\xf3n progresiva, confusi\xf3n, bradicardia.","Balance h\xeddrico negativo es el objetivo; registrar ingresos y egresos de forma estricta."]},{id:"proto_estado_asmatico",nombre:"Estado Asm\xe1tico - Crisis Asm\xe1tica Severa",descripcion:"Protocolo de manejo del estado asm\xe1tico (crisis asm\xe1tica severa o casi fatal), definido como una exacerbaci\xf3n de asma que no responde al tratamiento broncodilatador inicial y amenaza la vida del paciente.",categoria:"respiratorio",prioridad:"urgente",banderasRojas:["Dificultad para hablar (frases entrecortadas o palabras sueltas)","Uso de m\xfasculos accesorios con tiraje intercostal y supraclavicular","SpO2 <92% o PEF <25% del predicho","T\xf3rax silente (disminuci\xf3n de sibilancias = obstrucci\xf3n severa)","Alteraci\xf3n del nivel de conciencia, agotamiento respiratorio, cianosis"],pasos:[{orden:1,tiempo:"0-5 min",accion:"Ox\xedgeno y broncodilatador de acci\xf3n corta",detalles:"O2 para mantener SpO2 93-95%. Salbutamol nebulizado continuo o MDI con espaciador (4-8 puffs cada 20 min). En crisis severa, preferir nebulizaci\xf3n continua.",critico:!0,farmacos:[{nombre:"Salbutamol",dosis:"2.5-5 mg nebulizado cada 20 min x 3 dosis, luego cada 1-4h. O nebulizaci\xf3n continua 10-15 mg/h. MDI: 4-8 puffs cada 20 min",via:"Nebulizaci\xf3n/MDI"},{nombre:"Ipratropio",dosis:"0.5 mg nebulizado junto con salbutamol cada 20 min x 3 dosis",via:"Nebulizaci\xf3n"}]},{orden:2,tiempo:"5-15 min",accion:"Corticosteroide sist\xe9mico",detalles:"Administrar corticosteroide sist\xe9mico lo antes posible. Reduce la inflamaci\xf3n de la v\xeda a\xe9rea. El beneficio m\xe1ximo se observa a las 4-6 horas, por lo que la administraci\xf3n temprana es crucial.",critico:!0,farmacos:[{nombre:"Metilprednisolona",dosis:"60-125 mg IV. Pedi\xe1trico: 1-2 mg/kg IV (m\xe1x. 60 mg)",via:"IV"},{nombre:"Hidrocortisona (alternativa)",dosis:"200 mg IV",via:"IV"}]},{orden:3,tiempo:"15-30 min",accion:"Evaluar respuesta y considerar sulfato de magnesio",detalles:"Si no hay mejor\xeda con broncodilatadores + corticosteroide, administrar MgSO4 IV. El magnesio tiene efecto broncodilatador por relajaci\xf3n del m\xfasculo liso bronquial.",farmacos:[{nombre:"Sulfato de magnesio (MgSO4)",dosis:"2 g IV en 20 min (diluido en 100 mL de SSN). Pedi\xe1trico: 25-75 mg/kg IV (m\xe1x. 2 g)",via:"IV"}],decision:{pregunta:"\xbfHay mejor\xeda con broncodilatadores y corticosteroide?",si:"Continuar salbutamol cada 1-4h, espaciar seg\xfan mejor\xeda. Mantener corticosteroide.",no:"Administrar MgSO4 IV. Evaluar necesidad de tratamientos de rescate (paso 4)."}},{orden:4,tiempo:"30-60 min",accion:"Tratamientos de rescate en crisis refractaria",detalles:"Si persiste sin mejor\xeda: considerar epinefrina IM/SC, aminofilina IV (uso controvertido), o ketamina. Preparar intubaci\xf3n si hay signos de fallo respiratorio inminente.",critico:!0,farmacos:[{nombre:"Epinefrina",dosis:"0.3-0.5 mg IM/SC (soluci\xf3n 1:1000) cada 20 min x 3 dosis",via:"IM/SC"},{nombre:"Aminofilina (uso controvertido)",dosis:"Carga: 5-6 mg/kg IV en 20 min (si no toma teofilina). Mantenimiento: 0.5-0.9 mg/kg/h",via:"IV"}]},{orden:5,tiempo:"Si deterioro",accion:"Intubaci\xf3n y ventilaci\xf3n mec\xe1nica",detalles:"Indicaciones: apnea, alteraci\xf3n de conciencia, agotamiento respiratorio, hipoxemia refractaria (SpO2 <90% con O2 alto flujo), hipercapnia progresiva. Usar ketamina como agente inductor (broncodilatador). Ventilaci\xf3n protectora con tiempos espiratorios prolongados.",critico:!0,farmacos:[{nombre:"Ketamina (inducci\xf3n)",dosis:"1-2 mg/kg IV para intubaci\xf3n",via:"IV"}]}],resumenFarmacos:[{nombre:"Salbutamol",dosis:"2.5-5 mg nebulizado cada 20 min o nebulizaci\xf3n continua 10-15 mg/h",via:"Nebulizaci\xf3n",indicacion:"Broncodilatador beta-2 agonista de acci\xf3n corta, primera l\xednea"},{nombre:"Ipratropio",dosis:"0.5 mg nebulizado cada 20 min x 3 dosis",via:"Nebulizaci\xf3n",indicacion:"Anticolin\xe9rgico broncodilatador, sin\xe9rgico con salbutamol"},{nombre:"Metilprednisolona",dosis:"60-125 mg IV",via:"IV",indicacion:"Corticosteroide sist\xe9mico antiinflamatorio para crisis asm\xe1tica"},{nombre:"Sulfato de magnesio",dosis:"2 g IV en 20 min",via:"IV",indicacion:"Broncodilatador por relajaci\xf3n del m\xfasculo liso; en crisis refractaria"},{nombre:"Epinefrina",dosis:"0.3-0.5 mg IM/SC cada 20 min",via:"IM/SC",indicacion:"Broncodilatador de rescate en crisis severa refractaria"},{nombre:"Ketamina",dosis:"1-2 mg/kg IV",via:"IV",indicacion:"Agente de inducci\xf3n con propiedades broncodilatadoras para intubaci\xf3n"}],notasEnfermeria:["El t\xf3rax silente (ausencia de sibilancias) NO indica mejor\xeda; significa obstrucci\xf3n tan severa que no hay flujo a\xe9reo suficiente para generar sibilancias.","Monitorizar PEF antes y despu\xe9s de cada tratamiento para objetivar respuesta. Documentar la mejor cifra obtenida.","La nebulizaci\xf3n continua de salbutamol requiere monitorizaci\xf3n de FC y K+ (riesgo de taquicardia e hipopotasemia).","Preparar equipo de intubaci\xf3n desde el inicio en toda crisis severa; la descompensaci\xf3n puede ser r\xe1pida.","Evitar sedaci\xf3n excesiva; los sedantes pueden suprimir el est\xedmulo respiratorio y precipitar paro respiratorio."]},{id:"proto_hemorragia_masiva",nombre:"Hemorragia Masiva",descripcion:"Protocolo de manejo de la hemorragia masiva, definida como la p\xe9rdida de un volumen sangu\xedneo completo en 24 horas, 50% en 3 horas, o sangrado >150 mL/min. Incluye activaci\xf3n del protocolo de transfusi\xf3n masiva.",categoria:"trauma",prioridad:"critico",banderasRojas:["Taquicardia >120 lpm con hipotensi\xf3n (PAS <90 mmHg)","Sangrado visible activo no controlable con presi\xf3n directa","\xcdndice de choque (FC/PAS) >1.0","Alteraci\xf3n del nivel de conciencia con palidez y diaforesis","Necesidad de >4 concentrados de gl\xf3bulos rojos en 1 hora"],pasos:[{orden:1,tiempo:"0-3 min",accion:"Control del sangrado y acceso vascular",detalles:"Presi\xf3n directa sobre herida externa. Torniquete si extremidad con hemorragia no controlable. Dos accesos venosos de gran calibre (14-16G) o acceso intra\xf3seo. Muestra de sangre para grupo, Rh, pruebas cruzadas, coagulaci\xf3n, hemograma y gasometr\xeda.",critico:!0},{orden:2,tiempo:"0-10 min",accion:"Administrar \xe1cido tranex\xe1mico",detalles:"Administrar dentro de las primeras 3 horas del inicio de la hemorragia. Reduce la mortalidad por hemorragia en un 20-30%. NO administrar despu\xe9s de 3 horas (puede ser perjudicial).",critico:!0,farmacos:[{nombre:"\xc1cido tranex\xe1mico",dosis:"1 g IV en 10 min (bolo inicial), luego 1 g IV en infusi\xf3n en 8 horas",via:"IV"}]},{orden:3,tiempo:"5-15 min",accion:"Activar protocolo de transfusi\xf3n masiva",detalles:"Activar PTM cuando se cumplen criterios. Relaci\xf3n de hemoderivados 1:1:1 (GR:PFC:plaquetas). Solicitar sangre tipo O Rh negativo si no hay tiempo para pruebas cruzadas. Usar calentador de hemoderivados.",critico:!0,farmacos:[{nombre:"Concentrados de Gl\xf3bulos Rojos",dosis:"Tipo O Rh- inicialmente, luego isogrupo. Administrar con calentador.",via:"IV"},{nombre:"Plasma Fresco Congelado",dosis:"10-15 mL/kg IV. Relaci\xf3n 1:1 con GR en protocolo de transfusi\xf3n masiva.",via:"IV"},{nombre:"Plaquetas",dosis:"1 concentrado plaquetario por cada 5-6 unidades de GR. Objetivo plaquetas >50,000/\u03bcL.",via:"IV"}]},{orden:4,tiempo:"15-30 min",accion:"Resucitaci\xf3n inicial con cristaloides y monitoreo",detalles:"Cristaloides como puente hasta disponibilidad de hemoderivados. Evitar resucitaci\xf3n excesiva con cristaloides (diluci\xf3n de factores de coagulaci\xf3n). Objetivo de PAS: 80-90 mmHg (hipotensi\xf3n permisiva) excepto en TEC.",farmacos:[{nombre:"Ringer Lactato",dosis:"500-1000 mL IV en bolo r\xe1pido (calentado a 37-40\xb0C si es posible)",via:"IV"}]},{orden:5,tiempo:"30-60 min",accion:"Corregir coagulopat\xeda y monitoreo de laboratorio",detalles:"Obtener gasometr\xeda, fibrin\xf3geno, TP/TTPa, plaquetas cada 30-60 min. Corregir acidosis, hipotermia y coagulopat\xeda (tr\xedada letal del trauma). Administrar fibrin\xf3geno si <150 mg/dL.",critico:!0,farmacos:[{nombre:"Fibrin\xf3geno (crioprecipitado)",dosis:"Crioprecipitado: 10 unidades IV si fibrin\xf3geno <150 mg/dL. Objetivo >200 mg/dL.",via:"IV"},{nombre:"Calcio gluconato",dosis:"1-2 g IV cada 30 min seg\xfan Ca++ ionizado (mantener >1.1 mmol/L). La hipocalcemia por citrato de transfusiones afecta la coagulaci\xf3n.",via:"IV"}]},{orden:6,tiempo:"Continuo",accion:"Control quir\xfargico definitivo",detalles:"Cirug\xeda de control de da\xf1os si es necesario: empaquetamiento, clampaje, reparaci\xf3n vascular. Angioembolizaci\xf3n en hemorragias no quir\xfargicas. El control del foco hemorr\xe1gico es la prioridad definitiva.",critico:!0}],resumenFarmacos:[{nombre:"\xc1cido tranex\xe1mico",dosis:"1 g IV en 10 min + 1 g IV en 8h",via:"IV",indicacion:"Antifibrinol\xedtico; administrar en las primeras 3 horas de la hemorragia"},{nombre:"Concentrados de Gl\xf3bulos Rojos",dosis:"Seg\xfan necesidad, relaci\xf3n 1:1:1",via:"IV",indicacion:"Restaurar capacidad de transporte de ox\xedgeno"},{nombre:"Plasma Fresco Congelado",dosis:"10-15 mL/kg IV",via:"IV",indicacion:"Reponer factores de coagulaci\xf3n en transfusi\xf3n masiva"},{nombre:"Plaquetas",dosis:"1 unidad por cada 5-6 unidades de GR",via:"IV",indicacion:"Mantener plaquetas >50,000/\u03bcL durante hemorragia activa"},{nombre:"Fibrin\xf3geno/Crioprecipitado",dosis:"10 unidades IV si fibrin\xf3geno <150 mg/dL",via:"IV",indicacion:"Reponer fibrin\xf3geno consumido en coagulopat\xeda"},{nombre:"Calcio gluconato",dosis:"1-2 g IV cada 30 min seg\xfan niveles",via:"IV",indicacion:"Corregir hipocalcemia por citrato de hemoderivados; esencial para coagulaci\xf3n"}],notasEnfermeria:["Aplicar el protocolo de transfusi\xf3n masiva: relaci\xf3n 1:1:1 de GR:PFC:plaquetas para prevenir la coagulopat\xeda dilucional.","Calentar TODOS los hemoderivados y cristaloides; la hipotermia agrava la coagulopat\xeda y debe prevenirse activamente.","Monitorizar calcio ionizado cada 30 min durante la transfusi\xf3n masiva; el citrato de los hemoderivados quela el calcio.","El \xe1cido tranex\xe1mico debe administrarse en los primeros 180 minutos del inicio de la hemorragia; pasadas las 3 horas puede ser perjudicial.","Documentar cada unidad de hemoderivado administrada con hora exacta. Comunicar al m\xe9dico si el sangrado supera la reposici\xf3n."]},{id:"proto_hipertermia_maligna",nombre:"Hipertermia Maligna",descripcion:"Protocolo de manejo de la hipertermia maligna, una emergencia anest\xe9sica farmacogen\xe9tica potencialmente mortal desencadenada por anest\xe9sicos halogenados o succinilcolina en individuos susceptibles. La mortalidad sin tratamiento supera el 70%.",categoria:"otro",prioridad:"critico",banderasRojas:["Elevaci\xf3n inexplicable de ETCO2 y taquicardia durante anestesia general","Rigidez muscular generalizada, especialmente trismus al administrar succinilcolina","Temperatura corporal en ascenso r\xe1pido (>1\xb0C cada 5 min)","Acidosis mixta (respiratoria y metab\xf3lica) con hiperpotasemia","Arritmias ventriculares con rabdomi\xf3lisis (elevaci\xf3n de CK, mioglobinuria)"],pasos:[{orden:1,tiempo:"0-2 min",accion:"Suspender agente desencadenante y pedir ayuda",detalles:"Suspender INMEDIATAMENTE todos los anest\xe9sicos halogenados y succinilcolina. Avisar al equipo. Hiperventilar con O2 al 100% a flujos altos (\u226510 L/min). Cambiar circuito y absorbedor de CO2 si es posible.",critico:!0},{orden:2,tiempo:"2-5 min",accion:"Administrar Dantroleno IV",detalles:"Dantroleno es el \xdaNICO ant\xeddoto espec\xedfico. Cada vial de 20 mg se reconstituye con 60 mL de agua est\xe9ril (NO usar SSN). La reconstituci\xf3n es laboriosa; se necesitan m\xfaltiples personas. Administrar lo m\xe1s r\xe1pido posible.",critico:!0,farmacos:[{nombre:"Dantroleno",dosis:"2.5 mg/kg IV en bolo r\xe1pido. Repetir cada 5-10 min hasta controlar s\xedntomas (m\xe1x. acumulado ~10 mg/kg, sin l\xedmite real si necesario)",via:"IV"}]},{orden:3,tiempo:"5-15 min",accion:"Enfriamiento activo",detalles:"Iniciar enfriamiento agresivo si temperatura >39\xb0C. Objetivo: temperatura central <38.5\xb0C. Detener enfriamiento al alcanzar 38\xb0C para evitar hipotermia reactiva.",critico:!0,farmacos:[{nombre:"SSN 0.9% fr\xedo",dosis:"Lavado g\xe1strico, vesical y rectal con SSN fr\xeda. Infusi\xf3n IV de SSN fr\xedo (4\xb0C) 15 mL/kg.",via:"IV/Lavados"}]},{orden:4,tiempo:"5-15 min",accion:"Tratar hiperpotasemia y arritmias",detalles:"La rabdomi\xf3lisis libera potasio masivamente. Tratar hiperpotasemia con protocolo est\xe1ndar. Tratar arritmias ventriculares con amiodarona. EVITAR bloqueantes de canales de calcio (interacci\xf3n letal con dantroleno).",critico:!0,farmacos:[{nombre:"Insulina regular + Dextrosa",dosis:"Insulina 10 UI IV + Dextrosa 50% 50 mL IV",via:"IV"},{nombre:"Gluconato de calcio 10%",dosis:"10-20 mL IV en 2-3 min (para hiperpotasemia con cambios ECG)",via:"IV"},{nombre:"Bicarbonato de sodio",dosis:"1-2 mEq/kg IV si acidosis metab\xf3lica severa (pH <7.2)",via:"IV"}]},{orden:5,tiempo:"Continuo",accion:"Protecci\xf3n renal y monitoreo",detalles:"Forzar diuresis con l\xedquidos IV y furosemida para prevenir fallo renal por mioglobinuria. Objetivo: diuresis >2 mL/kg/h. Monitorizar CK, mioglobina, K+, Ca++, gasometr\xeda y coagulaci\xf3n seriados. Mantener dantroleno cada 4-6h por 24-48h.",critico:!0,farmacos:[{nombre:"Furosemida",dosis:"40-80 mg IV (si diuresis inadecuada)",via:"IV"},{nombre:"Dantroleno (mantenimiento)",dosis:"1 mg/kg IV cada 4-6h durante 24-48h post-crisis",via:"IV"}]}],resumenFarmacos:[{nombre:"Dantroleno",dosis:"2.5 mg/kg IV bolo, repetir cada 5-10 min. Mantenimiento: 1 mg/kg IV cada 4-6h x 24-48h",via:"IV",indicacion:"Ant\xeddoto espec\xedfico; relajante muscular de acci\xf3n directa que inhibe la liberaci\xf3n de calcio del ret\xedculo sarcopl\xe1smico"},{nombre:"Insulina regular + Dextrosa 50%",dosis:"10 UI insulina + 25 g dextrosa IV",via:"IV",indicacion:"Tratamiento de hiperpotasemia asociada a rabdomi\xf3lisis"},{nombre:"Gluconato de calcio 10%",dosis:"10-20 mL IV",via:"IV",indicacion:"Estabilizaci\xf3n de membrana card\xedaca en hiperpotasemia"},{nombre:"Bicarbonato de sodio",dosis:"1-2 mEq/kg IV",via:"IV",indicacion:"Correcci\xf3n de acidosis metab\xf3lica severa"},{nombre:"Furosemida",dosis:"40-80 mg IV",via:"IV",indicacion:"Forzar diuresis para protecci\xf3n renal ante mioglobinuria"}],notasEnfermeria:["NUNCA administrar bloqueantes de canales de calcio (verapamilo, diltiazem) junto con dantroleno; la combinaci\xf3n puede causar colapso cardiovascular fatal.","La reconstituci\xf3n del dantroleno es laboriosa (cada vial de 20 mg requiere 60 mL de agua est\xe9ril); asignar personal exclusivo para esta tarea.","Conocer la ubicaci\xf3n del kit de hipertermia maligna en el \xe1rea quir\xfargica. Verificar stock de dantroleno peri\xf3dicamente (m\xednimo 36 viales).","Monitorizar temperatura central (esof\xe1gica, rectal o vesical); la axilar es inexacta en esta emergencia.","Asesorar a la familia sobre la naturaleza gen\xe9tica de la condici\xf3n y la necesidad de estudio (test de contractura in vitro) para familiares de primer grado."]},{id:"proto_cad",nombre:"CAD - Cetoacidosis Diab\xe9tica",abreviatura:"CAD",descripcion:"Protocolo de manejo de la cetoacidosis diab\xe9tica, una complicaci\xf3n aguda grave de la diabetes mellitus caracterizada por hiperglucemia, cetonemia, acidosis metab\xf3lica y deshidrataci\xf3n. Es m\xe1s frecuente en DM tipo 1 pero puede ocurrir en DM tipo 2.",categoria:"metabolico",prioridad:"urgente",banderasRojas:["Glucemia >250 mg/dL con cetonuria/cetonemia y pH <7.3","Respiraci\xf3n de Kussmaul (r\xe1pida y profunda) con aliento cet\xf3nico","Deshidrataci\xf3n severa con taquicardia e hipotensi\xf3n","Dolor abdominal difuso con n\xe1useas y v\xf3mitos","Alteraci\xf3n del nivel de conciencia (obnubilaci\xf3n, coma) con pH <7.0"],pasos:[{orden:1,tiempo:"0-15 min",accion:"Evaluaci\xf3n inicial y estudios de laboratorio",detalles:"Glucemia, gasometr\xeda arterial, electrolitos (Na+, K+, Cl-, Mg++), cetonas en sangre/orina, osmolaridad, funci\xf3n renal, hemograma, ECG. Calcular anion gap: Na - (Cl + HCO3); valor normal 12\xb14. CAD: anion gap >12. Clasificar severidad seg\xfan pH.",critico:!0,decision:{pregunta:"\xbfK+ s\xe9rico >3.3 mEq/L?",si:"Puede iniciarse insulina junto con reposici\xf3n de K+ (paso 3)",no:"NO iniciar insulina hasta corregir K+ >3.3 mEq/L (riesgo de arritmias letales)"}},{orden:2,tiempo:"0-30 min",accion:"Resucitaci\xf3n con l\xedquidos IV",detalles:"La hidrataci\xf3n es la primera prioridad. D\xe9ficit t\xedpico: 5-7 litros. SSN 0.9% en la primera hora. Despu\xe9s, ajustar seg\xfan Na+ corregido. Cuando glucemia <250 mg/dL, cambiar a dextrosa 5% + SSN 0.45% para prevenir hipoglucemia.",critico:!0,farmacos:[{nombre:"SSN 0.9%",dosis:"1000-1500 mL IV en la primera hora. Luego 250-500 mL/h (ajustar seg\xfan estado hemodin\xe1mico).",via:"IV"},{nombre:"Dextrosa 5% + SSN 0.45%",dosis:"150-250 mL/h IV cuando glucemia <250 mg/dL (para mantener glucemia 150-200 mg/dL mientras se resuelve la cetosis)",via:"IV"}]},{orden:3,tiempo:"15-60 min",accion:"Insulina regular en infusi\xf3n continua",detalles:"Iniciar SOLO si K+ >3.3 mEq/L. Objetivo: reducir glucemia 50-75 mg/dL por hora. Si la glucemia baja m\xe1s r\xe1pido, reducir dosis o agregar dextrosa. NO suspender insulina hasta que se resuelva la cetosis (pH >7.3, HCO3 >15, anion gap <12).",critico:!0,farmacos:[{nombre:"Insulina regular",dosis:"Bolo: 0.1 UI/kg IV, luego infusi\xf3n: 0.1 UI/kg/h IV. Alternativa sin bolo: 0.14 UI/kg/h IV",via:"IV"}]},{orden:4,tiempo:"30-60 min",accion:"Reposici\xf3n de potasio",detalles:"El K+ total corporal est\xe1 deplecionado aunque el nivel s\xe9rico pueda estar normal o elevado (por acidosis). La insulina desplaza K+ al intracelular, pudiendo causar hipopotasemia peligrosa. Reposici\xf3n seg\xfan niveles.",critico:!0,farmacos:[{nombre:"Cloruro de potasio (KCl)",dosis:"K+ <3.3: 20-40 mEq/h IV (NO iniciar insulina). K+ 3.3-5.3: 20-30 mEq por cada litro de SSN. K+ >5.3: no reponer, control en 2h.",via:"IV"}]},{orden:5,tiempo:"Cada 1-2 horas",accion:"Monitoreo seriado y ajustes",detalles:"Glucemia capilar cada hora. Electrolitos y gasometr\xeda cada 2-4 horas. Ajustar velocidad de insulina para descenso de glucemia de 50-75 mg/dL/h. Cuando glucemia <250: reducir insulina a 0.02-0.05 UI/kg/h y agregar dextrosa.",critico:!0},{orden:6,tiempo:"Resoluci\xf3n",accion:"Criterios de resoluci\xf3n y transici\xf3n a insulina SC",detalles:"Criterios de resoluci\xf3n de CAD: pH >7.3, HCO3 >15 mEq/L, anion gap <12, paciente tolerando VO. Administrar insulina SC 1-2 horas ANTES de suspender la infusi\xf3n IV para evitar rebote de hiperglucemia y cetosis.",farmacos:[{nombre:"Insulina glargina o NPH",dosis:"Administrar dosis SC basal 1-2h antes de suspender infusi\xf3n IV. Calcular seg\xfan requerimientos previos del paciente.",via:"SC"}]}],resumenFarmacos:[{nombre:"SSN 0.9%",dosis:"1000-1500 mL IV primera hora, luego 250-500 mL/h",via:"IV",indicacion:"Resucitaci\xf3n h\xeddrica; corrige deshidrataci\xf3n y mejora perfusi\xf3n renal"},{nombre:"Insulina regular (infusi\xf3n)",dosis:"0.1 UI/kg/h IV (con o sin bolo de 0.1 UI/kg)",via:"IV",indicacion:"Suprime cetog\xe9nesis y corrige hiperglucemia"},{nombre:"Cloruro de potasio (KCl)",dosis:"20-40 mEq/h IV seg\xfan niveles de K+",via:"IV",indicacion:"Reposici\xf3n de K+ deplecionado; prevenir hipopotasemia por insulina"},{nombre:"Dextrosa 5%",dosis:"Agregar cuando glucemia <250 mg/dL (150-250 mL/h)",via:"IV",indicacion:"Prevenir hipoglucemia mientras se mantiene insulina para resolver cetosis"},{nombre:"Bicarbonato de sodio",dosis:"100 mEq en 400 mL de agua + 20 mEq KCl, a pasar en 2h (solo si pH <6.9)",via:"IV",indicacion:"Solo en acidosis severa (pH <6.9); uso controvertido"}],notasEnfermeria:["NUNCA iniciar insulina si K+ <3.3 mEq/L; la insulina desplaza K+ al intracelular y puede causar arritmias ventriculares fatales.","La resoluci\xf3n de la CAD se define por pH, bicarbonato y anion gap, NO por la glucemia. La insulina se mantiene hasta que se resuelva la cetosis.","Monitorizar glucemia capilar cada hora y electrolitos cada 2-4h. Vigilar signos de hipopotasemia: debilidad, calambres, cambios ECG.","Administrar insulina SC basal 1-2h ANTES de suspender la infusi\xf3n IV para evitar el efecto rebote.","Investigar y tratar el factor precipitante: infecci\xf3n (m\xe1s com\xfan), incumplimiento terap\xe9utico, debut diab\xe9tico, IAM, pancreatitis."]},{id:"proto_eclampsia",nombre:"Eclampsia / Preeclampsia Severa",abreviatura:"PE/E",descripcion:"Protocolo de manejo de la emergencia hipertensiva en el embarazo. La preeclampsia severa (PA \u2265160/110 con proteinuria y/o da\xf1o org\xe1nico) puede progresar a eclampsia (convulsiones) y s\xedndrome HELLP. Emergencia obst\xe9trica que amenaza la vida materna y fetal.",categoria:"obstetrico",prioridad:"critico",banderasRojas:["PA sist\xf3lica \u2265160 mmHg o diast\xf3lica \u2265110 mmHg persistente","Convulsiones t\xf3nico-cl\xf3nicas (eclampsia)","Cefalea intensa refractaria a analgesia","Alteraciones visuales: escotomas, visi\xf3n borrosa, amaurosis","Dolor epig\xe1strico o en hipocondrio derecho (distensi\xf3n hep\xe1tica)","Oliguria <500 mL/24h","Edema pulmonar agudo","Plaquetas <100.000/\xb5L o LDH elevada (HELLP)"],pasos:[{orden:1,tiempo:"0-5 min",accion:"Estabilizaci\xf3n inmediata y protecci\xf3n de la v\xeda a\xe9rea",detalles:"Posici\xf3n en dec\xfabito lateral izquierdo (mejorar retorno venoso y prevenir aspiraci\xf3n). Si convulsiona: proteger de lesiones, no introducir objetos en boca, aspirar secreciones. Ox\xedgeno a alto flujo. Monitorizaci\xf3n continua: PA, FC, SatO2, FCF.",critico:!0},{orden:2,tiempo:"0-5 min",accion:"Administrar Sulfato de Magnesio (MgSO4) \u2014 PRIMERA L\xcdNEA",detalles:"Dosis de carga: 4-6 g IV en 15-20 min diluidos en 100 mL SF. Mantenimiento: 1-2 g/h en perfusi\xf3n continua. El MgSO4 es anticonvulsivante de elecci\xf3n en eclampsia (superior a diazepam y fenito\xedna). Mantener 24-48h postparto.",critico:!0,farmacos:[{nombre:"Sulfato de Magnesio",dosis:"Carga: 4-6 g IV en 15-20 min; Mantenimiento: 1-2 g/h",via:"IV"}]},{orden:3,tiempo:"5-15 min",accion:"Control de la presi\xf3n arterial",detalles:"Objetivo: PA <160/110 pero no descender >25% en primeras horas (riesgo de hipoperfusi\xf3n placentaria). Labetalol IV es primera l\xednea. Alternativas: hidralazina IV, nifedipino oral.",critico:!0,farmacos:[{nombre:"Labetalol",dosis:"20 mg IV en bolo; repetir 40-80 mg cada 10-15 min (m\xe1x 300 mg)",via:"IV"},{nombre:"Hidralazina",dosis:"5-10 mg IV cada 15-20 min (m\xe1x 30 mg)",via:"IV"},{nombre:"Nifedipino",dosis:"10-20 mg VO cada 30 min (m\xe1x 60 mg)",via:"Oral"}]},{orden:4,tiempo:"15-30 min",accion:"Evaluaci\xf3n materna y fetal completa",detalles:"Anal\xedtica urgente: hemograma, plaquetas, LDH, GOT/GPT, bilirrubina, creatinina, \xe1cido \xfarico, proteinuria. Descartar s\xedndrome HELLP (hem\xf3lisis + enzimas hep\xe1ticas elevadas + trombocitopenia). Monitorizaci\xf3n fetal continua: RCTG.",critico:!1},{orden:5,tiempo:"30 min - 2h",accion:"Decisi\xf3n sobre finalizaci\xf3n del embarazo",detalles:"La eclampsia y preeclampsia severa refractaria son indicaci\xf3n de parto urgente independientemente de la edad gestacional. En <34 semanas: considerar maduraci\xf3n pulmonar con corticoides si el estado materno lo permite (betametasona 12 mg IM \xd7 2 dosis/24h). La v\xeda de parto depende de las condiciones obst\xe9tricas.",critico:!0,decision:{pregunta:"\xbfEclampsia refractaria al MgSO4 o deterioro materno/fetal?",si:"Ces\xe1rea urgente",no:"Estabilizar y planificar parto seg\xfan condiciones obst\xe9tricas"}},{orden:6,tiempo:"Postparto",accion:"Vigilancia postparto intensiva",detalles:"Mantener MgSO4 24-48h postparto. Continuar antihipertensivos. Vigilar diuresis, PA cada 15 min las primeras 4h. El riesgo de eclampsia persiste hasta 48-72h postparto. Control de hemorragia postparto (mayor riesgo en HELLP).",critico:!1}],resumenFarmacos:[{nombre:"Sulfato de Magnesio",dosis:"Carga: 4-6 g IV en 15-20 min; Mantenimiento: 1-2 g/h",via:"IV",indicacion:"Anticonvulsivante de primera l\xednea en eclampsia y prevenci\xf3n en preeclampsia severa"},{nombre:"Labetalol",dosis:"20 mg IV en bolo, escalar cada 10-15 min (m\xe1x 300 mg)",via:"IV",indicacion:"Antihipertensivo de primera l\xednea en emergencia hipertensiva del embarazo"},{nombre:"Hidralazina",dosis:"5-10 mg IV cada 15-20 min",via:"IV",indicacion:"Alternativa antihipertensiva"},{nombre:"Nifedipino",dosis:"10-20 mg VO cada 30 min",via:"Oral",indicacion:"Alternativa si no hay acceso IV"},{nombre:"Betametasona",dosis:"12 mg IM cada 24h \xd7 2 dosis",via:"IM",indicacion:"Maduraci\xf3n pulmonar fetal si <34 semanas"}],notasEnfermeria:["Monitorizar reflejo rotuliano cada hora durante infusi\xf3n de MgSO4: la AUSENCIA de reflejo indica toxicidad por magnesio.","Mantener ant\xeddoto preparado: Gluconato de Calcio 1 g IV lento para toxicidad por MgSO4 (depresi\xf3n respiratoria, bradicardia).","Controlar diuresis horaria: debe ser >25-30 mL/h. El MgSO4 se excreta por v\xeda renal; la oliguria aumenta el riesgo de toxicidad.","NUNCA administrar nifedipino y MgSO4 simult\xe1neamente sin supervisi\xf3n estrecha: hipotensi\xf3n severa.","El s\xedndrome HELLP puede presentarse sin hipertensi\xf3n significativa: sospechar ante dolor epig\xe1strico + malestar + n\xe1useas."]},{id:"proto_sobredosis_opioides",nombre:"Intoxicaci\xf3n por Opioides",abreviatura:"IOp",descripcion:"Protocolo de manejo de la sobredosis/intoxicaci\xf3n aguda por opioides (hero\xedna, fentanilo, morfina, metadona, tramadol). La depresi\xf3n respiratoria es la principal causa de muerte. La naloxona es el ant\xeddoto espec\xedfico.",categoria:"otro",prioridad:"critico",banderasRojas:["Depresi\xf3n respiratoria: FR <12 rpm o apnea","Miosis puntiforme bilateral (pupilas en alfiler)","Disminuci\xf3n del nivel de conciencia / coma","Cianosis","Hipotensi\xf3n","Bradicardia","Edema pulmonar no cardiog\xe9nico (hero\xedna/fentanilo)"],pasos:[{orden:1,tiempo:"0-1 min",accion:"Evaluaci\xf3n r\xe1pida y apertura de v\xeda a\xe9rea",detalles:"Evaluar consciencia (est\xedmulo verbal/dolor), respiraci\xf3n y pulso. Abrir v\xeda a\xe9rea (maniobra frente-ment\xf3n), aspirar secreciones. Si apnea: iniciar ventilaci\xf3n con bolsa-mascarilla. Si paro card\xedaco: iniciar RCP.",critico:!0},{orden:2,tiempo:"1-3 min",accion:"Administrar Naloxona",detalles:"Naloxona 0.4-2 mg IV/IM/SC/IN. Si no hay respuesta en 2-3 minutos, repetir dosis. En sospecha de fentanilo o derivados potentes: pueden requerirse dosis mayores (hasta 10 mg totales). V\xeda intranasal: 4 mg (2 mg por fosa nasal) si no hay acceso IV.",critico:!0,farmacos:[{nombre:"Naloxona",dosis:"0.4-2 mg IV/IM/SC; repetir cada 2-3 min hasta respuesta (m\xe1x 10 mg)",via:"IV/IM/SC/IN"}]},{orden:3,tiempo:"3-10 min",accion:"Monitorizaci\xf3n continua y soporte respiratorio",detalles:"Monitorizar SatO2, FR, FC, PA, ECG. Ox\xedgeno suplementario. La naloxona tiene vida media m\xe1s corta (30-90 min) que muchos opioides: riesgo de re-sedaci\xf3n. Si paciente intubado, mantener ventilaci\xf3n mec\xe1nica hasta respuesta.",critico:!0},{orden:4,tiempo:"10-60 min",accion:"Infusi\xf3n continua de Naloxona (si renarcotizaci\xf3n)",detalles:"Si se requieren dosis repetidas o el opioide es de larga duraci\xf3n (metadona, fentanilo transd\xe9rmico): perfusi\xf3n continua de naloxona 0.4-0.8 mg/h IV. Ajustar seg\xfan respuesta cl\xednica. Mantener m\xednimo 4-6h (24h si metadona).",critico:!0,farmacos:[{nombre:"Naloxona (perfusi\xf3n)",dosis:"0.4-0.8 mg/h IV en perfusi\xf3n continua (2/3 de la dosis de respuesta por hora)",via:"IV"}]},{orden:5,tiempo:"Continuo",accion:"Evaluaci\xf3n de complicaciones y observaci\xf3n",detalles:"Vigilar: edema pulmonar no cardiog\xe9nico, rabdomi\xf3lisis (CK, mioglobina), hipotermia, s\xedndrome compartimental (por inmovilizaci\xf3n prolongada). Observaci\xf3n m\xednima: 4-6h si opioides de corta duraci\xf3n, 24h si metadona u opioides de liberaci\xf3n prolongada.",critico:!1}],resumenFarmacos:[{nombre:"Naloxona",dosis:"0.4-2 mg IV/IM/SC/IN; repetir cada 2-3 min (m\xe1x 10 mg)",via:"IV/IM/SC/IN",indicacion:"Antagonista opioide espec\xedfico \u2014 revierte depresi\xf3n respiratoria, sedaci\xf3n y miosis"},{nombre:"Naloxona (perfusi\xf3n)",dosis:"0.4-0.8 mg/h IV ajustable",via:"IV",indicacion:"Prevenir renarcotizaci\xf3n con opioides de larga duraci\xf3n"}],notasEnfermeria:["Al administrar naloxona, dosificar PROGRESIVAMENTE: despertar brusco puede causar agitaci\xf3n severa, v\xf3mito con aspiraci\xf3n, edema pulmonar o s\xedndrome de abstinencia agudo.","La naloxona tiene vida media MENOR que la mayor\xeda de opioides: vigilar renarcotizaci\xf3n. Nunca dar de alta tras una sola dosis sin observaci\xf3n.","En pacientes con dependencia cr\xf3nica a opioides: usar dosis menores de naloxona (0.04-0.1 mg) y titular para restaurar respiraci\xf3n sin precipitar abstinencia completa.","Buscar parches de fentanilo transd\xe9rmico en todo el cuerpo (pueden estar ocultos); retirarlos si se encuentran.","Documentar: sustancia sospechada, v\xeda de consumo, hora estimada de exposici\xf3n, dosis de naloxona y respuesta."]},{id:"proto_reaccion_transfusional",nombre:"Reacci\xf3n Transfusional Aguda",abreviatura:"RTA",descripcion:"Protocolo de manejo de reacciones adversas agudas a la transfusi\xf3n de hemoderivados. Incluye reacciones hemol\xedticas (incompatibilidad ABO), febriles no hemol\xedticas, al\xe9rgicas/anafil\xe1cticas, TRALI y sobrecarga circulatoria (TACO).",categoria:"otro",prioridad:"urgente",banderasRojas:["Fiebre >1\xb0C sobre la basal durante o tras transfusi\xf3n","Escalofr\xedos intensos / rigidez","Hipotensi\xf3n o hipertensi\xf3n s\xfabita","Taquicardia","Disnea / desaturaci\xf3n / edema pulmonar","Urticaria, prurito, angioedema","Dolor lumbar o tor\xe1cico","Hemoglobinuria (orina oscura)","Sensaci\xf3n de muerte inminente"],pasos:[{orden:1,tiempo:"0-1 min",accion:"DETENER LA TRANSFUSI\xd3N INMEDIATAMENTE",detalles:"Clamplar la v\xeda de transfusi\xf3n pero NO retirar el acceso venoso. Mantener permeable con SF 0.9%. Verificar la identidad del paciente y la etiqueta de la bolsa de hemoderivado. Monitorizar signos vitales.",critico:!0},{orden:2,tiempo:"1-5 min",accion:"Evaluaci\xf3n cl\xednica y clasificaci\xf3n de la reacci\xf3n",detalles:"Valorar: fiebre, urticaria, disnea, hipotensi\xf3n, dolor. Si shock anafil\xe1ctico: epinefrina 0.3-0.5 mg IM. Si disnea con infiltrados bilaterales: sospechar TRALI. Si fiebre + hemoglobinuria: sospechar reacci\xf3n hemol\xedtica.",critico:!0,decision:{pregunta:"\xbfHay signos de anafilaxia o reacci\xf3n hemol\xedtica?",si:"Tratamiento de emergencia: epinefrina (anafilaxia) o fluidoterapia agresiva + consulta hematolog\xeda (hemol\xedtica)",no:"Tratamiento sintom\xe1tico: antihistam\xednicos (alergia leve), paracetamol (febril)"}},{orden:3,tiempo:"5-15 min",accion:"Tratamiento seg\xfan tipo de reacci\xf3n",detalles:"Febril no hemol\xedtica: paracetamol 1g IV. Al\xe9rgica leve (urticaria): dexclorfeniramina 5 mg IV. Anafilaxia: epinefrina 0.3-0.5 mg IM + corticoides + fluidos. Hemol\xedtica: SF 0.9% a 200 mL/h, mantener diuresis >100 mL/h, alertar UCI.",critico:!0,farmacos:[{nombre:"Epinefrina (anafilaxia)",dosis:"0.3-0.5 mg IM; repetir cada 5-15 min si necesario",via:"IM"},{nombre:"Dexclorfeniramina",dosis:"5 mg IV",via:"IV"},{nombre:"Hidrocortisona",dosis:"100-200 mg IV",via:"IV"},{nombre:"Paracetamol",dosis:"1 g IV",via:"IV"}]},{orden:4,tiempo:"15-30 min",accion:"Estudios de laboratorio y notificaci\xf3n",detalles:"Enviar: muestra de sangre del paciente (nueva extracci\xf3n), bolsa de hemoderivado con sistema de infusi\xf3n, muestra de orina. Solicitar: Coombs directo, haptoglobina, LDH, bilirrubina, hemograma. Notificar al banco de sangre y cumplimentar formulario de reacci\xf3n transfusional.",critico:!1},{orden:5,tiempo:"Continuo",accion:"Monitorizaci\xf3n y prevenci\xf3n de complicaciones",detalles:"Vigilar funci\xf3n renal: creatinina, diuresis. En reacci\xf3n hemol\xedtica: mantener diuresis >100 mL/h (furosemida si necesario). Vigilar CID: fibrin\xf3geno, DD, plaquetas. Monitorizaci\xf3n continua m\xednimo 4-6h.",critico:!1}],resumenFarmacos:[{nombre:"Epinefrina",dosis:"0.3-0.5 mg IM (anafilaxia)",via:"IM",indicacion:"Reacci\xf3n anafil\xe1ctica a la transfusi\xf3n"},{nombre:"Dexclorfeniramina",dosis:"5 mg IV",via:"IV",indicacion:"Reacci\xf3n al\xe9rgica leve-moderada (urticaria, prurito)"},{nombre:"Hidrocortisona",dosis:"100-200 mg IV",via:"IV",indicacion:"Complemento en reacciones al\xe9rgicas severas"},{nombre:"Paracetamol",dosis:"1 g IV",via:"IV",indicacion:"Reacci\xf3n febril no hemol\xedtica"},{nombre:"Furosemida",dosis:"20-40 mg IV",via:"IV",indicacion:"Mantener diuresis en reacci\xf3n hemol\xedtica o TACO"}],notasEnfermeria:["Los primeros 15 minutos de transfusi\xf3n son CR\xcdTICOS: permanecer junto al paciente y tomar signos vitales a los 0, 5 y 15 min.","NUNCA reanudar una transfusi\xf3n detenida por sospecha de reacci\xf3n hemol\xedtica o anafil\xe1ctica.","Verificar SIEMPRE la identidad del paciente con doble comprobaci\xf3n (nombre + fecha nacimiento + pulsera) antes de iniciar.","La reacci\xf3n hemol\xedtica aguda por incompatibilidad ABO es la causa m\xe1s frecuente de muerte por transfusi\xf3n y es SIEMPRE un error humano prevenible.","Distinguir TRALI (edema pulmonar no cardiog\xe9nico, 6h post-transfusi\xf3n) de TACO (sobrecarga circulatoria): TRALI cursa con hipotensi\xf3n, TACO con hipertensi\xf3n y PVC elevada."]},{id:"proto_acv_hemorragico",nombre:"ACV Hemorr\xe1gico",abreviatura:"HIC",descripcion:"Protocolo de manejo de la hemorragia intracerebral espont\xe1nea (no traum\xe1tica). Segunda causa de ictus (15-20%). Mortalidad a 30 d\xedas del 40%. El control precoz de la presi\xf3n arterial y la reversi\xf3n de anticoagulaci\xf3n son pilares del tratamiento.",categoria:"neurologico",prioridad:"critico",banderasRojas:["D\xe9ficit neurol\xf3gico focal de inicio brusco","Cefalea intensa s\xfabita ('la peor de mi vida')","Disminuci\xf3n r\xe1pida del nivel de conciencia (GCS descendente)","V\xf3mitos en escopetazo","Rigidez de nuca (si hemorragia subaracnoidea asociada)","Crisis convulsiva","Anisocoria (herniaci\xf3n cerebral inminente)","HTA severa (PA >220/120 mmHg)"],pasos:[{orden:1,tiempo:"0-10 min",accion:"Estabilizaci\xf3n inicial y ABC",detalles:"Asegurar v\xeda a\xe9rea (GCS \u22648: intubar). Ox\xedgeno para SatO2 >94%. Monitorizaci\xf3n continua: PA, FC, SatO2, GCS. Posici\xf3n: cabecera elevada 30\xb0. Acceso venoso con SF (NO suero glucosado). Glucemia capilar urgente.",critico:!0},{orden:2,tiempo:"0-15 min",accion:"Neuroimagen urgente \u2014 TAC craneal SIN contraste",detalles:"TAC urgente para confirmar hemorragia y diferenciar de ictus isqu\xe9mico. Determinar localizaci\xf3n, volumen (ABC/2) y presencia de hidrocefalia o efecto masa. Angiotac si sospecha de malformaci\xf3n vascular o aneurisma.",critico:!0,decision:{pregunta:"\xbfHemorragia confirmada en TAC?",si:"Continuar protocolo de HIC: control PA + reversi\xf3n anticoagulaci\xf3n si aplica",no:"Reevaluar: considerar protocolo de ictus isqu\xe9mico o HSA"}},{orden:3,tiempo:"15-60 min",accion:"Control intensivo de la presi\xf3n arterial",detalles:"Objetivo: PAS <140 mmHg en las primeras horas (estudio INTERACT2). Labetalol IV es primera l\xednea. Si refractario: nicardipino en perfusi\xf3n. Evitar descensos bruscos de PA >60 mmHg en la primera hora.",critico:!0,farmacos:[{nombre:"Labetalol",dosis:"10-20 mg IV en 1-2 min; repetir cada 10-15 min (m\xe1x 300 mg/d\xeda)",via:"IV"},{nombre:"Nicardipino",dosis:"5 mg/h IV, titular cada 5 min (m\xe1x 15 mg/h)",via:"IV"}]},{orden:4,tiempo:"Inmediato si aplica",accion:"Reversi\xf3n de anticoagulaci\xf3n",detalles:"Si anticoagulaci\xf3n con warfarina: vitamina K 10 mg IV + CCP (concentrado de complejo protromb\xednico) 25-50 UI/kg. Si ACODs (dabigatr\xe1n): idarucizumab 5 g IV. Si ACODs anti-Xa (rivaroxab\xe1n, apixab\xe1n): andexanet alfa o CCP. Objetivo: INR <1.3 en <60 min.",critico:!0,farmacos:[{nombre:"Vitamina K (fitomenadiona)",dosis:"10 mg IV lento (en 10-20 min)",via:"IV"},{nombre:"CCP (Concentrado Complejo Protromb\xednico)",dosis:"25-50 UI/kg IV seg\xfan INR",via:"IV"},{nombre:"Idarucizumab (si dabigatr\xe1n)",dosis:"5 g IV en 2 bolos de 2.5 g",via:"IV"},{nombre:"\xc1cido tranex\xe1mico",dosis:"1 g IV en 10 min (primeras 4.5h)",via:"IV"}]},{orden:5,tiempo:"Continuo",accion:"Prevenci\xf3n y tratamiento de complicaciones",detalles:"Profilaxis anticonvulsiva si crisis (levetiracetam 1 g IV). Profilaxis de TVP: compresi\xf3n neum\xe1tica intermitente (NO heparina en primeras 24-48h). Normoglucemia (140-180 mg/dL). Normotermia (tratar fiebre agresivamente). Monitorizaci\xf3n neurol\xf3gica: GCS cada hora.",critico:!1},{orden:6,tiempo:"Variable",accion:"Valoraci\xf3n neuroquir\xfargica",detalles:"Indicaciones quir\xfargicas: hematoma cerebeloso >3 cm con deterioro, hidrocefalia obstructiva (drenaje ventricular), hematoma lobar superficial >30 mL con deterioro. Los hematomas profundos (ganglios basales) rara vez se benefician de cirug\xeda.",critico:!1,decision:{pregunta:"\xbfHematoma cerebeloso >3 cm, hidrocefalia o deterioro r\xe1pido?",si:"Neurocirug\xeda urgente: evacuaci\xf3n o DVE",no:"Manejo conservador en UCI neurol\xf3gica"}}],resumenFarmacos:[{nombre:"Labetalol",dosis:"10-20 mg IV en bolo, escalar cada 10-15 min",via:"IV",indicacion:"Control de HTA \u2014 primera l\xednea"},{nombre:"Nicardipino",dosis:"5-15 mg/h IV en perfusi\xf3n",via:"IV",indicacion:"Control de HTA refractaria a labetalol"},{nombre:"Vitamina K",dosis:"10 mg IV",via:"IV",indicacion:"Reversi\xf3n de warfarina (efecto en 6-24h)"},{nombre:"CCP",dosis:"25-50 UI/kg IV",via:"IV",indicacion:"Reversi\xf3n r\xe1pida de warfarina/ACODs anti-Xa"},{nombre:"Idarucizumab",dosis:"5 g IV",via:"IV",indicacion:"Reversi\xf3n espec\xedfica de dabigatr\xe1n"},{nombre:"Levetiracetam",dosis:"1 g IV",via:"IV",indicacion:"Anticonvulsivante si crisis epil\xe9ptica"},{nombre:"\xc1cido tranex\xe1mico",dosis:"1 g IV en 10 min",via:"IV",indicacion:"Reducir expansi\xf3n del hematoma (primeras 4.5h)"}],notasEnfermeria:["Monitorizaci\xf3n neurol\xf3gica estricta: GCS, pupilas y focalidad cada hora las primeras 24h. Cualquier descenso de GCS \u22652 puntos: alertar inmediatamente.","Control de PA cada 15 min durante fase aguda. Evitar PA extremas: tanto la HTA (expansi\xf3n hematoma) como la hipotensi\xf3n (isquemia perilesional) son delet\xe9reas.","Cabecera elevada 30\xb0 para favorecer retorno venoso cerebral. Evitar flexi\xf3n del cuello (impide drenaje yugular).","En pacientes anticoagulados: la reversi\xf3n tiene PRIORIDAD incluso antes del TAC si hay alta sospecha cl\xednica.","Tratar la fiebre agresivamente: cada grado >37\xb0C empeora el pron\xf3stico neurol\xf3gico. Paracetamol 1g/6h + medidas f\xedsicas."]}]},802,[]);
__d(function(g,r,i,a,m,e,d){var t=r(d[0]);Object.defineProperty(e,"__esModule",{value:!0}),e.useRecentPathologies=function(){var t=(0,u.useState)([]),f=(0,c.default)(t,2),o=f[0],v=f[1],_=(0,u.useState)(!1),h=(0,c.default)(_,2),S=h[0],b=h[1];(0,u.useEffect)(()=>{l.default.getItem(n).then(t=>{t&&v(JSON.parse(t)),b(!0)}).catch(()=>b(!0))},[]),(0,u.useEffect)(()=>{S&&l.default.setItem(n,JSON.stringify(o)).catch(()=>{})},[o,S]);var p=(0,u.useCallback)(t=>{v(c=>{var u=c.filter(c=>c!==t);return[t,...u].slice(0,s)})},[]),O=(0,u.useCallback)(()=>{v([])},[]);return{recent:o,addRecent:p,clearRecent:O,loaded:S}};var c=t(r(d[1])),u=r(d[2]),l=t(r(d[3])),n='@patologias_recent',s=10},803,[1,32,69,527]);
__d(function(g,r,i,a,m,e,d){Object.defineProperty(e,"__esModule",{value:!0}),e.getConditionImage=function(o,p){var s=_[o];if(s&&t[s])return t[s];return(0,r(d[12]).getSystemImage)(p)};var t={blood_pressure:r(d[0]),heart_monitor:r(d[1]),ecg:r(d[2]),chest_xray:r(d[3]),inhaler:r(d[3]),brain_ct:r(d[4]),neuron:r(d[4]),glucose:r(d[5]),liver:r(d[6]),stomach:r(d[6]),kidney:r(d[6]),bones_xray:r(d[7]),joints:r(d[7]),blood_test:r(d[1]),microscope:r(d[8]),virus:r(d[8]),pregnancy:r(d[1]),surgery:r(d[9]),iv_drip:r(d[10]),pills:r(d[10]),stethoscope:r(d[1]),bandage:r(d[11]),cancer_cells:r(d[8])},_={pat_hta:'blood_pressure',pat_icc:'heart_monitor',pat_iam:'ecg',pat_angina:'ecg',pat_fa:'ecg',pat_tvp:'iv_drip',pat_eap:'chest_xray',pat_endocarditis:'heart_monitor',pat_pericarditis:'heart_monitor',pat_shock_cardiogenico:'heart_monitor',pat_valvulopatia:'stethoscope',pat_miocardiopatia:'heart_monitor',pat_arteriopatia_periferica:'blood_pressure',pat_shock_hipovolemico:'iv_drip',pat_tamponamiento_cardiaco:'heart_monitor',pat_aneurisma_aorta:'surgery',pat_epoc:'chest_xray',pat_asma:'inhaler',pat_neumonia:'chest_xray',pat_tep:'chest_xray',pat_neumotorax:'chest_xray',pat_ira:'chest_xray',pat_tuberculosis:'chest_xray',pat_derrame_pleural:'chest_xray',pat_fibrosis_pulmonar:'chest_xray',pat_sdra:'heart_monitor',pat_bronquiectasias:'chest_xray',pat_cancer_pulmon:'cancer_cells',pat_hemotorax:'surgery',pat_acv:'brain_ct',pat_epilepsia:'neuron',pat_meningitis:'brain_ct',pat_parkinson:'neuron',pat_alzheimer:'neuron',pat_guillain_barre:'neuron',pat_esclerosis_lateral:'neuron',pat_miastenia_gravis:'neuron',pat_hipertension_intracraneal:'brain_ct',pat_neuralgia_trigemino:'neuron',pat_hidrocefalia:'brain_ct',pat_neuropatia_periferica:'neuron',pat_ulcera_peptica:'stomach',pat_cirrosis:'liver',pat_pancreatitis:'stomach',pat_eii:'stomach',pat_hemorragia_digestiva:'iv_drip',pat_apendicitis:'surgery',pat_obstruccion_intestinal:'surgery',pat_colecistitis:'liver',pat_hepatitis:'liver',pat_diverticulitis:'stomac